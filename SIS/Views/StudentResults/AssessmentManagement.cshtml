@model SIS.Models.Admin.CourseAssessmentViewModel

@{
    // Add this at the top of your view
    @Html.AntiForgeryToken()
}

<div class=" mx-auto p-4">
    <!-- Header with improved styling -->
    <div class="flex justify-between items-center mb-6 bg-white p-4 rounded-lg shadow">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Course Assessments Management</h1>
            <p class="text-gray-600 text-sm mt-1">Manage and track student assessments across academic years</p>
        </div>
        <div class="flex space-x-3 items-center">
            <!-- Bulk Import Results Button -->
            <a asp-controller="ResultImport" asp-action="MultiCourseImport"
               class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors duration-200 flex items-center gap-2">
                <i class="material-icons text-lg">upload_file</i>
                Bulk Import Results
            </a>

            <a asp-controller="ResultImport" asp-action="SupDefImport"
               class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 flex items-center gap-2">
                <i class="material-icons text-lg">upload_file</i>
                Import Sup Results
            </a>

            @* @if (Model.IsHOD)
            {
                <button onclick="showModal()"
                        class="px-4 py-2 bg-[#0082bb] text-white rounded-lg hover:bg-[#0082bb]/90 transition-colors duration-200 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M4 3a2 2 0 100 4h12a2 2 0 100-4H4z" />
                        <path fill-rule="evenodd" d="M3 8h14v7a2 2 0 01-2 2H5a2 2 0 01-2-2V8zm5 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z" clip-rule="evenodd" />
                    </svg>
                    Publish Results
                </button>
            } *@
        </div>
    </div>

    @if (!Model.AcademicYears.Any())
    {
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-yellow-700">
                        No academic years found with assigned courses.
                    </p>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Academic Year Tabs with improved styling -->
        <div class="mb-6">
            <div class="border-b border-gray-200">
                <nav class="flex space-x-4" role="tablist" aria-label="Academic Years">
                    @foreach (var year in Model.AcademicYears)
                    {
                        <button class="px-4 py-2 font-medium text-sm rounded-t-lg transition-colors duration-200
                                @(year.YearId == Model.SelectedYearId 
                                    ? "bg-blue-50 text-blue-600 border-b-2 border-blue-600" 
                                    : "text-gray-500 hover:text-gray-700 hover:bg-gray-50")"
                                onclick="switchTab('@year.YearId')"
                                id="tab-@year.YearId"
                                role="tab"
                                aria-selected="@(year.YearId == Model.SelectedYearId ? "true" : "false")"
                                aria-controls="content-@year.YearId">
                            @year.YearValue
                            @if (year.IsPublished)
                            {
                                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                                    Published
                                </span>
                            }
                        </button>
                    }
                </nav>
            </div>
        </div>

        <!-- Year Content with improved card styling -->
        @foreach (var year in Model.AcademicYears)
        {
            <div id="content-@year.YearId"
                 class="year-content @(year.YearId == Model.SelectedYearId ? "block" : "hidden")"
                 role="tabpanel"
                 aria-labelledby="tab-@year.YearId">

                @if (!year.Courses.Any())
                {
                    <!-- Show message when no courses exist for this year -->
                    <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-6">
                        <div class="flex items-center">
                            <div class="flex-shrink-0">
                                <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-blue-700">
                                    No courses have been registered for academic year @year.YearValue yet.
                                    Students need to register for courses before assessments can be managed.
                                </p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    @for (int semester = 1; semester <= 2; semester++)
                    {
                        var semesterCourses = year.Courses.Where(c => c.Semester == semester).ToList();
                        if (semesterCourses.Any())
                        {
                            <div class="mb-8">
                                <div class="flex items-center mb-4">
                                    <h2 class="text-lg font-semibold text-gray-800">Semester @semester</h2>
                                    <div class="ml-4 px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">
                                        @semesterCourses.Count() Courses
                                    </div>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                    @foreach (var course in semesterCourses)
                                    {
                                        <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow duration-200 overflow-hidden">
                                            <div class="p-4">
                                                <div class="flex justify-between items-start mb-4">
                                                    <div>
                                                        <h3 class="font-semibold text-lg text-gray-800">@course.CourseCode</h3>
                                                        <p class="text-sm text-gray-600 mt-1">@course.CourseName</p>
                                                    </div>
                                                    <span class="text-sm px-3 py-1 rounded-full font-medium
                                                @(course.AssessmentStatus == "Published" ? "bg-[#0082bb]/10 text-[#0082bb]" :
                                                  course.AssessmentStatus == "All Graded" ? "bg-green-100 text-green-800" :
                                                  course.AssessmentStatus == "Not Started" ? "bg-gray-100 text-gray-800" :
                                                  "bg-yellow-100 text-yellow-800")">
                                                        @course.AssessmentStatus
                                                    </span>
                                                </div>

                                                <div class="space-y-3 text-sm">
                                                    <div class="flex justify-between items-center">
                                                        <span class="text-gray-600">Enrolled Students</span>
                                                        <span class="font-medium">@course.EnrolledStudentsCount</span>
                                                    </div>
                                                    <div class="flex justify-between items-center">
                                                        <span class="text-gray-600">Pending Assessments</span>
                                                        <span class="font-medium @(course.PendingAssessments > 0 ? "text-yellow-600" : "text-green-600")">
                                                            @course.PendingAssessments
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="mt-4">
                                                    <div class="relative pt-1">
                                                        <div class="flex mb-2 items-center justify-between">
                                                            <div>
                                                                <span class="text-xs font-semibold inline-block text-[#0082bb]">
                                                                    Grading Progress
                                                                </span>
                                                            </div>
                                                            <div class="text-right">
                                                                <span class="text-xs font-semibold inline-block text-[#0082bb]">
                                                                    @course.GradedPercentage.ToString("F1")%
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <div class="overflow-hidden h-2 mb-4 text-xs flex rounded bg-[#0082bb]/20">
                                                            <div class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-[#0082bb] transition-all duration-300"
                                                                 style="width: @course.GradedPercentage%">
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Update the button color -->
                                                    <a href="@Url.Action("CourseAssessments", "StudentResults", new { id = course.CourseId, yearId = year.YearId })"
                                                       class="block text-center py-2 px-4 bg-[#0082bb] text-white rounded-lg hover:bg-[#0082bb]/90 transition-colors duration-200">
                                                        <span class="flex items-center justify-center gap-2">
                                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                                                <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                                                            </svg>
                                                            Manage Assessments
                                                        </span>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        }
    }
</div>

<!-- Custom Modal -->
<div id="confirmModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl p-6 max-w-md w-full mx-4 transform transition-all duration-300">
        <div class="text-center">
            <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-yellow-100 mb-4">
                <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">Confirm Publication</h3>
            <p class="text-sm text-gray-500 mb-6">
                Are you sure you want to publish these results? This action cannot be undone.
            </p>
            <div class="flex justify-center space-x-4">
                <button onclick="closeModal()"
                        class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors duration-200">
                    Cancel
                </button>
                <button onclick="confirmPublish()"
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200">
                    Publish Results
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="fixed bottom-4 right-4 transform transition-all duration-300 translate-y-full opacity-0">
    <div class="bg-white rounded-lg shadow-lg p-4 max-w-md flex items-center">
        <div id="toastIcon" class="flex-shrink-0 w-6 h-6 mr-3"></div>
        <p id="toastMessage" class="text-sm font-medium"></p>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(yearId) {
            // Hide all content
            document.querySelectorAll('.year-content').forEach(content => {
                content.classList.add('hidden');
            });

            // Show selected content
            document.getElementById(`content-${yearId}`).classList.remove('hidden');

            // Update tab styles
            document.querySelectorAll('[id^="tab-"]').forEach(tab => {
                tab.classList.remove('bg-blue-50', 'text-blue-600', 'border-b-2', 'border-blue-600');
                tab.classList.add('text-gray-500', 'hover:text-gray-700');
                tab.setAttribute('aria-selected', 'false');
            });

            const selectedTab = document.getElementById(`tab-${yearId}`);
            selectedTab.classList.add('bg-blue-50', 'text-blue-600', 'border-b-2', 'border-blue-600');
            selectedTab.classList.remove('hover:text-gray-700');
            selectedTab.setAttribute('aria-selected', 'true');
        }

        function showModal() {
            const modal = document.getElementById('confirmModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            modal.querySelector('.bg-white').classList.remove('scale-95', 'opacity-0');
            modal.querySelector('.bg-white').classList.add('scale-100', 'opacity-100');
        }

        function closeModal() {
            const modal = document.getElementById('confirmModal');
            modal.querySelector('.bg-white').classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 200);
        }

        function showToast(message, type) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const messageEl = document.getElementById('toastMessage');

            // Set icon and colors based on type
            if (type === 'success') {
                icon.innerHTML = '<svg class="w-6 h-6 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>';
                messageEl.classList.add('text-green-800');
            } else {
                icon.innerHTML = '<svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>';
                messageEl.classList.add('text-red-800');
            }

            messageEl.textContent = message;

            // Show toast
            toast.classList.remove('translate-y-full', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            // Hide toast after 3 seconds
            setTimeout(() => {
                toast.classList.add('translate-y-full', 'opacity-0');
                toast.classList.remove('translate-y-0', 'opacity-100');
            }, 3000);
        }

        function confirmPublish() {
            const activeYearId = document.querySelector('.year-content:not(.hidden)').id.replace('content-', '');

            closeModal();

            // Get the antiforgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch(`/StudentResults/PublishResults?yearId=${activeYearId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('Results published successfully!', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast(data.message || 'Failed to publish results', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('An error occurred while publishing results', 'error');
            });
        }
        console.log('hkbn');
    </script>
}
