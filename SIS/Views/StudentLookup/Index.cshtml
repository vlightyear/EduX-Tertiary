                                <select name="ProgrammeId" required id="addStudentProgrammeId"
                                        class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                    <option value="">Select Programme</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Programme Level *</label>
                                <select name="ProgrammeLevelId" required
                                        class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                    <option value="">Select Level</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Mode of Study *</label>
                                <select name="ModeOfStudyId" required
                                        class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
