@model SIS.Models.ViewModels.StudentLookupIndexViewModel
@{
    ViewData["Title"] = "Student Lookup";
}

<div class="min-h-screen bg-slate-50 p-6">
    @Html.AntiForgeryToken()

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-6">
        <div class="flex items-center text-slate-800">
            <i class="material-icons text-3xl mr-3 text-primary-600">people_alt</i>
            <div>
                <h1 class="text-2xl font-bold">Student Lookup</h1>
                <p class="text-sm text-slate-600">@Model.JurisdictionInfo</p>
            </div>
        </div>
        <div class="mt-4 md:mt-0 flex items-center space-x-4">
            <div class="flex items-center bg-white rounded-lg px-4 py-2 shadow-sm border border-slate-200">
                <i class="material-icons text-primary-600 mr-2">admin_panel_settings</i>
                <span class="text-sm font-medium text-slate-700">Role: @Model.UserRole</span>
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("Registrar"))
            {
                <!-- ADD STUDENT BUTTON -->
                @* <button type="button" id="openAddStudentModal"
                        class="inline-flex items-center px-4 py-2 bg-secondary-600 text-white text-sm font-medium rounded-lg hover:bg-secondary-700 focus:ring-4 focus:ring-secondary-300 transition-colors">
                    <i class="material-icons mr-2 text-sm">person_add</i>
                    Add Student
                </button> *@
            }
            <!-- STUDENTLIST BUTTON -->
            <a href="@Url.Action("StudentLists", "StudentLookup")"
               class="inline-flex items-center px-4 py-2 bg-primary-600 text-white text-sm font-medium rounded-lg hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 transition-colors">
                <i class="material-icons mr-2 text-sm">list_alt</i>
                Student Lists
            </a>
        </div>
    </div>

    <!-- Search Section -->
    <div class="bg-white rounded-xl shadow-sm mb-6 border border-slate-200">
        <div class="p-6">
            <div class="flex items-center mb-4">
                <i class="material-icons text-primary-600 mr-2">search</i>
                <h2 class="text-lg font-semibold text-slate-800">Search Students</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
                <!-- Search Input -->
                <div class="md:col-span-6">
                    <label for="searchInput" class="block text-sm font-medium text-slate-700 mb-2">Search Term</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                            <i class="material-icons text-slate-400 text-sm">search</i>
                        </div>
                        <input type="text"
                               id="searchInput"
                               class="block w-full pl-10 pr-4 py-3 text-sm border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500 transition-colors"
                               placeholder="Enter student number, name, NRC/passport, or email..."
                               autocomplete="off">
                    </div>
                </div>

                <!-- Search Type -->
                <div class="md:col-span-3">
                    <label for="searchType" class="block text-sm font-medium text-slate-700 mb-2">Search By</label>
                    <select id="searchType"
                            class="block w-full py-3 px-4 text-sm border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500 transition-colors">
                        <option value="">All Fields</option>
                        <option value="StudentNumber">Student Number</option>
                        <option value="Name">Full Name</option>
                        <option value="NrcPassport">NRC/Passport</option>
                        <option value="Email">Email Address</option>
                    </select>
                </div>

                <!-- Search Button -->
                <div class="md:col-span-2">
                    <button type="button"
                            id="searchButton"
                            class="w-full inline-flex items-center justify-center px-4 py-3 bg-primary-600 text-white text-sm font-medium rounded-lg hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 transition-colors">
                        <i class="material-icons mr-2 text-sm">search</i>
                        Search
                    </button>
                </div>

                <!-- Clear Button -->
                <div class="md:col-span-1">
                    <button type="button"
                            id="clearButton"
                            class="w-full inline-flex items-center justify-center px-4 py-3 bg-slate-200 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-300 focus:ring-4 focus:ring-slate-300 transition-colors">
                        <i class="material-icons text-sm">clear</i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Search Results Panel -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 flex flex-col" style="height: calc(100vh - 320px);">
                <div class="p-4 border-b border-slate-200 flex-shrink-0">
                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-semibold text-slate-800">Search Results</h3>
                        <span id="resultsCount" class="text-sm text-slate-600 bg-slate-100 px-2 py-1 rounded-full">0 results</span>
                    </div>
                </div>

                <!-- Scrollable Results Container -->
                <div class="flex-1 overflow-hidden">
                    <div id="searchResults" class="h-full overflow-y-auto p-4">
                        <div class="text-center py-12">
                            <i class="material-icons text-6xl text-slate-300 mb-4">search</i>
                            <p class="text-slate-500 text-lg font-medium">Start Your Search</p>
                            <p class="text-slate-400 text-sm mt-2">Enter a search term to find students within your jurisdiction</p>
                        </div>
                    </div>

                    <!-- Loading State -->
                    <div id="searchLoading" class="hidden h-full flex items-center justify-center p-4">
                        <div class="inline-flex items-center">
                            <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-primary-600"></div>
                            <span class="ml-2 text-slate-600">Searching...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Student Details Panel -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 flex flex-col" style="height: calc(100vh - 320px);">
                <div class="p-4 border-b border-slate-200 flex-shrink-0">
                    <h3 class="text-lg font-semibold text-slate-800">Student Details</h3>
                </div>
                <!-- Default "No Student Selected" Message -->
                <div id="studentDetails" class="flex-1 flex items-center justify-center p-4 overflow-y-auto">
                    <div class="text-center">
                        <i class="material-icons text-6xl text-slate-300 mb-4">person</i>
                        <p class="text-slate-500 text-lg font-medium">No Student Selected</p>
                        <p class="text-slate-400 text-sm mt-2">Select a student from the search results to view their details</p>
                    </div>
                </div>
                <!-- Student Detail Tabs -->
                <div id="studentTabs" class="hidden flex flex-col flex-1 overflow-hidden">
                    <div class="border-b border-slate-200 flex-shrink-0">
                        <nav class="flex space-x-8 px-4" aria-label="Tabs">
                            <button class="tab-button active py-2 px-1 border-b-2 border-primary-500 font-medium text-sm text-primary-600" data-tab="profile">
                                <i class="material-icons text-sm mr-1">person</i>
                                Profile
                            </button>
                            @if (User.IsInRole("Admin"))
                            {
                                <button class="tab-button py-2 px-1 border-b-2 border-transparent font-medium text-sm text-slate-500 hover:text-slate-700 hover:border-slate-300" data-tab="photo">
                                    <i class="material-icons text-sm mr-1">photo_camera</i>
                                    Photo
                                </button>
                                <button class="tab-button py-2 px-1 border-b-2 border-transparent font-medium text-sm text-slate-500 hover:text-slate-700 hover:border-slate-300" data-tab="idcard">
                                    <i class="material-icons text-sm mr-1">badge</i>
                                    ID Card
                                </button>
                            }
                            <button class="tab-button py-2 px-1 border-b-2 border-transparent font-medium text-sm text-slate-500 hover:text-slate-700 hover:border-slate-300" data-tab="financials">
                                <i class="material-icons text-sm mr-1">account_balance</i>
                                Financials
                            </button>
                            <button class="tab-button py-2 px-1 border-b-2 border-transparent font-medium text-sm text-slate-500 hover:text-slate-700 hover:border-slate-300" data-tab="results">
                                <i class="material-icons text-sm mr-1">assignment</i>
                                Results
                            </button>
                        </nav>
                    </div>
                    <!-- Admin Actions -->
                    <div id="adminActions" class="hidden border-b border-slate-200 p-4 bg-slate-50 flex-shrink-0">
                        <button id="studentAdminButton"
                                class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-colors">
                            <i class="material-icons mr-2 text-sm">admin_panel_settings</i>
                            Student Administration
                        </button>
                    </div>
                    <!-- Tab Content -->
                    <div id="tabContent" class="flex-1 overflow-y-auto p-4 min-h-0">
                        <!-- Content will be loaded here via AJAX -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Student Modal -->
<div id="addStudentModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
        <!-- Background overlay -->
        <div class="fixed inset-0 transition-opacity bg-slate-500 bg-opacity-75" aria-hidden="true"></div>

        <!-- Modal panel -->
        <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-4xl sm:w-full relative z-10">
            <form id="addStudentForm">
                @Html.AntiForgeryToken()
                <!-- Modal Header -->
                <div class="bg-primary-600 px-6 py-4">
                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-semibold text-white flex items-center">
                            <i class="material-icons mr-2">person_add</i>
                            Add Registered Student
                        </h3>
                        <button type="button" id="closeAddStudentModal" class="text-white hover:text-slate-200">
                            <i class="material-icons">close</i>
                        </button>
                    </div>
                </div>

                <!-- Modal Body -->
                <div class="px-6 py-4 max-h-[70vh] overflow-y-auto">
                    <!-- Personal Information -->
                    <div class="mb-6">
                        <h4 class="text-md font-semibold text-slate-800 mb-3 border-b pb-2">Personal Information</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Full Name *</label>
                                <input type="text" name="FullName" required
                                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Email *</label>
                                <input type="email" name="Email" required
                                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Student ID Number *</label>
                                <input type="text" name="StudentId_Number" required
                                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">NRC/Passport Number *</label>
                                <input type="text" name="NrcOrPassportNumber" required
                                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Date of Birth (YYYY-MM-DD) *</label>
                                <input type="date" name="DateOfBirth" required
                                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Gender *</label>
                                <select name="Gender" required
                                        class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                    <option value="">Select Gender</option>
                                    <option value="M">Male</option>
                                    <option value="F">Female</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Phone *</label>
                                <input type="tel" name="Phone" required
                                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Marital Status</label>
                                <select name="MaritalStatus"
                                        class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                    <option value="Single">Single</option>
                                    <option value="Married">Married</option>
                                    <option value="Divorced">Divorced</option>
                                    <option value="Widowed">Widowed</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Nationality *</label>
                                <select name="Nationality" required
                                        class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                    <option value="">Select Nationality</option>
                                    <option value="Afghan">Afghan</option>
                                    <option value="Albanian">Albanian</option>
                                    <option value="Algerian">Algerian</option>
                                    <option value="American">American</option>
                                    <option value="Angolan">Angolan</option>
                                    <option value="Argentinian">Argentinian</option>
