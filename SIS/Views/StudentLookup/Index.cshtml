<div class="lookup-page">
    @Html.AntiForgeryToken()

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-title-block">
            <div class="page-icon-wrap">
                <i class="material-icons">people_alt</i>
            </div>
            <div>
                <h1 class="page-title">Student Lookup</h1>
                <p class="page-subtitle">@Model.JurisdictionInfo</p>
            </div>
        </div>

        <div class="header-actions">
            <div class="role-chip">
                <i class="material-icons">admin_panel_settings</i>
                @Model.UserRole
            </div>

            @if (User.IsInRole("Admin") || User.IsInRole("Registrar"))
            {
                <button type="button" id="openAddStudentModal" class="btn-primary">
                    <i class="material-icons">person_add</i>
                    Add Student
                </button>
            }

            <a href="@Url.Action("StudentLists", "StudentLookup")" class="btn-primary">
                <i class="material-icons">list_alt</i>
                Student Lists
            </a>
        </div>
    </div>

    <!-- Search Card -->
    <div class="search-card">
        <div class="search-card-header">
            <i class="material-icons">search</i>
            <h2>Search Students</h2>
        </div>
        <div class="search-card-body">
            <div class="search-grid">
                <!-- Search Input -->
                <div>
                    <label class="form-label" for="searchInput">Search Term</label>
                    <div class="search-input-wrap">
                        <i class="material-icons search-input-icon">search</i>
                        <input type="text"
                               id="searchInput"
                               class="form-control"
                               placeholder="Student number, name, NRC/passport, or email…"
                               autocomplete="off">
                    </div>
                </div>

                <!-- Search By -->
                <div>
                    <label class="form-label" for="searchType">Search By</label>
                    <select id="searchType" class="form-select">
                        <option value="">All Fields</option>
                        <option value="StudentNumber">Student Number</option>
                        <option value="Name">Full Name</option>
                        <option value="NrcPassport">NRC / Passport</option>
                        <option value="Email">Email Address</option>
                    </select>
                </div>

                <!-- Search Button -->
                <div>
                    <label class="form-label">&nbsp;</label>
                    <button type="button" id="searchButton" class="btn-search">
                        <i class="material-icons">search</i>
                        Search
                    </button>
                </div>

                <!-- Clear Button -->
                <div>
                    <label class="form-label">&nbsp;</label>
                    <button type="button" id="clearButton" class="btn-clear" title="Clear search">
                        <i class="material-icons">clear</i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Layout -->
    <div class="results-layout">

        <!-- Search Results Panel -->
        <div class="panel panel-height">
            <div class="panel-header">
                <span class="panel-title">Search Results</span>
                <span id="resultsCount" class="results-badge">0 results</span>
            </div>
            <div class="panel-body">
                <!-- Results -->
                <div id="searchResults" class="panel-scroll">
                    <div class="empty-state-wrap">
                        <div class="empty-icon-wrap">
                            <i class="material-icons">search</i>
                        </div>
                        <p class="empty-title">Start Your Search</p>
                        <p class="empty-sub">Enter a search term to find students within your jurisdiction</p>
                    </div>
                </div>
                <!-- Loading -->
                <div id="searchLoading" class="loading-state" style="display:none;">
                    <div class="loading-spinner-wrap">
                        <div class="spinner"></div>
                        Searching…
                    </div>
                </div>
            </div>
        </div>

        <!-- Details Panel -->
        <div class="panel panel-height">
            <div class="details-panel-header">
                <span class="details-panel-title">Student Details</span>
            </div>

            <!-- Default no-student state -->
            <div id="studentDetails" class="no-student-state">
                <div style="text-align:center;">
                    <div class="empty-icon-wrap" style="margin: 0 auto 1rem;">
                        <i class="material-icons">person</i>
                    </div>
                    <p class="empty-title">No Student Selected</p>
                    <p class="empty-sub">Select a student from the results panel to view their details</p>
                </div>
            </div>

            <!-- Tabbed view (hidden until student selected) -->
            <div id="studentTabs" class="hidden" style="display:none; flex-direction:column; flex:1; overflow:hidden;">
                <!-- Tab Nav -->
                <nav class="tabs-nav" aria-label="Student detail tabs">
                    <button class="tab-button active" data-tab="profile">
                        <i class="material-icons">person</i>
                        Profile
                    </button>
                    @if (User.IsInRole("Admin"))
                    {
                        <button class="tab-button" data-tab="photo">
                            <i class="material-icons">photo_camera</i>
                            Photo
                        </button>
                        <button class="tab-button" data-tab="idcard">
                            <i class="material-icons">badge</i>
                            ID Card
                        </button>
                    }
                    <button class="tab-button" data-tab="financials">
                        <i class="material-icons">account_balance</i>
                        Financials
                    </button>
                    <button class="tab-button" data-tab="results">
                        <i class="material-icons">assignment</i>
                        Results
                    </button>
                </nav>

                <!-- Admin Actions Bar -->
                <div id="adminActions" class="hidden admin-actions-bar">
                    <button id="studentAdminButton" class="btn-admin">
                        <i class="material-icons">admin_panel_settings</i>
                        Student Administration
                    </button>
                </div>

                <!-- Tab Content -->
                <div id="tabContent" class="tab-content-area">
                    <!-- Loaded via AJAX -->
                </div>
            </div>
        </div>

    </div><!-- /results-layout -->
</div><!-- /lookup-page -->
