                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Religion</label>
                                <select name="Religion"
                                        class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
