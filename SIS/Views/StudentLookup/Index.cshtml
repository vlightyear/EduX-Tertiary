            </div>
            <div class="cred-row">
                <label>Student Number</label>
                <div id="createdStudentNumber" class="cred-value"></div>
            </div>
            <div class="cred-row password-row">
                <label>Default Password</label>
                <div class="password-copy-row">
                    <div id="createdStudentPassword" class="cred-value mono"></div>
                    <button type="button" onclick="copyPassword()" class="btn-copy" title="Copy password">
                        <i class="material-icons">content_copy</i>
                    </button>
                </div>
                <p class="password-note">
                    <i class="material-icons">info</i>
                    Please save and share this password with the student
                </p>
            </div>
            <div class="created-modal-actions">
                <button type="button" onclick="printStudentCredentials()" class="btn-print">
                    <i class="material-icons">print</i>
                    Print
                </button>
                <button type="button" onclick="closeStudentCreatedModal()" class="btn-done">
                    <i class="material-icons">done</i>
                    Done
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        console.log('=== Student Lookup page scripts loading... ===');

        document.addEventListener('DOMContentLoaded', function() {
            console.log('=== DOM fully loaded - Student Lookup ===');

            // DOM Elements
            const searchInput = document.getElementById('searchInput');
            const searchType = document.getElementById('searchType');
            const searchButton = document.getElementById('searchButton');
            const clearButton = document.getElementById('clearButton');
            const searchResults = document.getElementById('searchResults');
            const searchLoading = document.getElementById('searchLoading');
            const resultsCount = document.getElementById('resultsCount');
            const studentDetails = document.getElementById('studentDetails');
            const studentTabs = document.getElementById('studentTabs');
            const tabContent = document.getElementById('tabContent');

            // Add Student Modal Elements
            const addStudentModal = document.getElementById('addStudentModal');
            const openAddStudentModalBtn = document.getElementById('openAddStudentModal');
            const closeAddStudentModalBtn = document.getElementById('closeAddStudentModal');
            const cancelAddStudentBtn = document.getElementById('cancelAddStudent');
            const addStudentForm = document.getElementById('addStudentForm');

            // Debug logging
            console.log('=== Modal Element Debug ===');
            console.log('addStudentModal:', addStudentModal);
            console.log('openAddStudentModalBtn:', openAddStudentModalBtn);
            console.log('closeAddStudentModalBtn:', closeAddStudentModalBtn);

            let currentStudentId = null;
            let currentTab = 'profile';

            // Add Student Modal Functions
            function openAddStudentModal() {
                console.log('=== openAddStudentModal function called ===');
                console.log('Modal element exists:', !!addStudentModal);

                if (addStudentModal) {
                    console.log('Removing hidden class from modal');
                    addStudentModal.classList.remove('hidden');
                    console.log('Modal classList after removal:', addStudentModal.classList.toString());
                    loadDropdownData();
                } else {
                    console.error('Add Student Modal element not found!');
                    showToast('Error: Modal element not found in the DOM', 'error');
                }
            }

            function closeAddStudentModal() {
                console.log('=== closeAddStudentModal called ===');
                if (addStudentModal) {
                    addStudentModal.classList.add('hidden');
                    if (addStudentForm) {
                        addStudentForm.reset();
                    }
                }
            }

            async function loadDropdownData() {
                console.log('=== Loading dropdown data ===');
                try {
                    // Load Schools
                    const schoolsResponse = await fetch('/StudentLookup/GetSchools');
                    const schools = await schoolsResponse.json();
                    const schoolSelect = document.querySelector('#addStudentSchoolId');
                    const programmeLevelSelect = document.querySelector('select[name="ProgrammeLevelId"]');
                    const modeOfStudySelect = document.querySelector('select[name="ModeOfStudyId"]');
                    const academicYearSelect = document.querySelector('select[name="AcademicYearId"]');

                    if (schoolSelect) {
                        schoolSelect.innerHTML = '<option value="">Select School</option>';
                        schools.forEach(school => {
                            schoolSelect.innerHTML += `<option value="${school.id}">${school.name}</option>`;
                        });
                    }

                    // Load Programme Levels
                    const levelsResponse = await fetch('/StudentLookup/GetProgrammeLevels');
                    const levels = await levelsResponse.json();
                    if (programmeLevelSelect) {
                        programmeLevelSelect.innerHTML = '<option value="">Select Level</option>';
                        levels.forEach(level => {
                            programmeLevelSelect.innerHTML += `<option value="${level.id}">${level.name}</option>`;
                        });
                    }

                    // Load Modes of Study
                    const modesResponse = await fetch('/StudentLookup/GetModesOfStudy');
                    const modes = await modesResponse.json();
                    if (modeOfStudySelect) {
                        modeOfStudySelect.innerHTML = '<option value="">Select Mode</option>';
                        modes.forEach(mode => {
                            modeOfStudySelect.innerHTML += `<option value="${mode.modeId}">${mode.modeName}</option>`;
                        });
                    }

                    // Load Academic Years
                    const yearsResponse = await fetch('/StudentLookup/GetAcademicYears');
                    const years = await yearsResponse.json();
                    if (academicYearSelect) {
                        academicYearSelect.innerHTML = '<option value="">Select Academic Year</option>';
                        years.forEach(year => {
                            academicYearSelect.innerHTML += `<option value="${year.yearId}">${year.yearName}</option>`;
                        });
                    }

                    console.log('Dropdown data loaded successfully');
                } catch (error) {
                    console.error('Error loading dropdown data:', error);
                    showToast('Failed to load form data', 'error');
                }
            }

            // Handle School selection to load Programmes
            const schoolDropdown = document.querySelector('#addStudentSchoolId');
            if (schoolDropdown) {
                schoolDropdown.addEventListener('change', async function() {
                    const schoolId = this.value;
                    const progSelect = document.querySelector('#addStudentProgrammeId');

                    if (!schoolId) {
                        if (progSelect) progSelect.innerHTML = '<option value="">Select Programme</option>';
                        return;
                    }

                    try {
                        const progResponse = await fetch(`/StudentLookup/GetProgrammesForModal?schoolId=${schoolId}`);
                        const programmes = await progResponse.json();
                        if (progSelect) {
                            progSelect.innerHTML = '<option value="">Select Programme</option>';
                            programmes.forEach(prog => {
                                progSelect.innerHTML += `<option value="${prog.id}">${prog.name}</option>`;
                            });
                        }
                    } catch (error) {
                        console.error('Error loading school data:', error);
                    }
                });
            }

            // Handle Nationality selection to automatically set Is Foreigner field
            const nationalityDropdown = document.querySelector('select[name="Nationality"]');
            const isForeignerDropdown = document.querySelector('select[name="IsForeigner"]');
            let isForeignerLocked = false;

            if (nationalityDropdown && isForeignerDropdown) {
                isForeignerDropdown.addEventListener('mousedown', function(e) {
                    if (isForeignerLocked) { e.preventDefault(); return false; }
                });

                isForeignerDropdown.addEventListener('keydown', function(e) {
                    if (isForeignerLocked) { e.preventDefault(); return false; }
                });

                nationalityDropdown.addEventListener('change', function() {
                    const selectedNationality = this.value;
                    console.log('Nationality selected:', selectedNationality);

                    if (selectedNationality === 'Zambian') {
                        isForeignerDropdown.value = '0';
                        isForeignerDropdown.style.backgroundColor = '#f3f4f6';
                        isForeignerDropdown.style.cursor = 'not-allowed';
                        isForeignerDropdown.style.opacity = '0.6';
                        isForeignerLocked = true;
                    } else if (selectedNationality !== '') {
                        isForeignerDropdown.value = '1';
                        isForeignerDropdown.style.backgroundColor = '#f3f4f6';
                        isForeignerDropdown.style.cursor = 'not-allowed';
                        isForeignerDropdown.style.opacity = '0.6';
                        isForeignerLocked = true;
                    } else {
                        isForeignerDropdown.style.backgroundColor = '';
                        isForeignerDropdown.style.cursor = '';
                        isForeignerDropdown.style.opacity = '';
                        isForeignerLocked = false;
                    }
                });
            }

            // Handle Add Student Form Submit
            if (addStudentForm) {
                addStudentForm.addEventListener('submit', async function(e) {
                    e.preventDefault();

                    const formData = new FormData(this);
                    const submitButton = this.querySelector('button[type="submit"]');
                    submitButton.disabled = true;
                    submitButton.innerHTML = '<i class="material-icons" style="font-size:16px;animation:spin 0.8s linear infinite;">refresh</i> Saving...';

                    try {
                        const response = await fetch('/StudentLookup/AddStudent', {
                            method: 'POST',
                            body: formData
                        });

                        const result = await response.json();
                        console.log('=== Add student response ===');
                        console.log('Full result:', result);

                        if (result.success) {
                            closeAddStudentModal();
                            addStudentForm.reset();

                            const studentName = formData.get('FullName');
                            const studentNumber = result.studentNumber || formData.get('StudentId_Number');
                            const password = result.defaultPassword || '';

                            if (!password) {
                                showToast(result.message, 'success');
                                setTimeout(() => window.location.reload(), 3000);
                                return;
                            }

                            showStudentCreatedModal(studentName, studentNumber, password);
                        } else {
                            showToast(result.message || 'Failed to add student', 'error');
                        }
                    } catch (error) {
                        console.error('Error adding student:', error);
                        showToast('An error occurred while adding the student', 'error');
                    } finally {
                        submitButton.disabled = false;
                        submitButton.innerHTML = '<i class="material-icons" style="font-size:16px;">save</i> Add Student';
                    }
                });
            }

            // Add Student Modal Event Listeners
            if (openAddStudentModalBtn) {
                openAddStudentModalBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    openAddStudentModal();
                });
            }

            if (closeAddStudentModalBtn) {
                closeAddStudentModalBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    closeAddStudentModal();
                });
            }

            if (cancelAddStudentBtn) {
                cancelAddStudentBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    closeAddStudentModal();
                });
            }

            // --- Auto-load student if query string present ---
            const urlParams = new URLSearchParams(window.location.search);
            const studentNumber = urlParams.get('studentNumber');
            const studentIdParam = urlParams.get('studentId');

            if (studentNumber || studentIdParam) {
                if (studentIdParam) {
                    selectStudent(parseInt(studentIdParam));
                } else if (studentNumber) {
                    searchInput.value = studentNumber;
                    searchType.value = 'StudentNumber';
                    performSearch();

                    const observer = new MutationObserver(() => {
                        const firstResult = document.querySelector('.student-result');
                        if (firstResult) {
                            const id = parseInt(firstResult.dataset.studentId);
                            selectStudent(id);
                            observer.disconnect();
                        }
                    });

                    observer.observe(searchResults, { childList: true, subtree: true });
                }
            }

            // Search functionality
            function performSearch() {
                const searchTerm = searchInput.value.trim();
                if (!searchTerm) {
                    showToast('Please enter a search term', 'warning');
                    return;
                }

                searchLoading.style.display = 'flex';
                searchResults.style.display = 'none';

                fetch('/StudentLookup/SearchStudents', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: `searchTerm=${encodeURIComponent(searchTerm)}&searchType=${encodeURIComponent(searchType.value)}`
                })
                .then(response => response.json())
                .then(data => {
                    searchLoading.style.display = 'none';
                    searchResults.style.display = 'block';

                    if (data.success) {
                        displaySearchResults(data.students);
                    } else {
                        showToast(data.message || 'Search failed', 'error');
                        displaySearchResults([]);
                    }
                })
                .catch(error => {
                    console.error('Search error:', error);
                    searchLoading.style.display = 'none';
                    searchResults.style.display = 'block';
                    showToast('An error occurred while searching', 'error');
                    displaySearchResults([]);
                });
            }

            function displaySearchResults(students) {
                resultsCount.textContent = `${students.length} result${students.length !== 1 ? 's' : ''}`;

                if (students.length === 0) {
                    searchResults.innerHTML = `
                        <div class="empty-state-wrap">
                            <div class="empty-icon-wrap">
                                <i class="material-icons">search_off</i>
                            </div>
                            <p class="empty-title">No students found</p>
                            <p class="empty-sub">Try adjusting your search terms</p>
                        </div>`;
                    return;
                }

                let html = '';
                students.forEach(student => {
                    const statusColor = getStatusColor(student.registrationStatus);
                    const feeStatus = student.outstandingFees > 0 ? 'Outstanding' : 'Cleared';
                    const feeClass = student.outstandingFees > 0
                        ? 'fee-pill' + ' ' + 'text-red-600 bg-red-50'
                        : 'fee-pill' + ' ' + 'text-green-600 bg-green-50';

                    html += `
                        <div class="student-card student-result" data-student-id="${student.id}">
                            <div class="student-card-top">
                                <div style="flex:1;">
                                    <div style="display:flex;align-items:center;flex-wrap:wrap;gap:0.35rem;margin-bottom:0.35rem;">
                                        <span class="student-name">${student.fullName}</span>
                                        <span class="status-pill ${statusColor}">${student.registrationStatus}</span>
                                    </div>
                                    <div class="student-meta">
                                        <i class="material-icons">badge</i>
                                        ${student.studentNumber}
                                    </div>
                                    <div class="student-meta">
                                        <i class="material-icons">school</i>
                                        ${student.programmeName}
                                    </div>
                                    <div class="student-meta">
                                        <i class="material-icons">business</i>
                                        ${student.schoolName}
                                    </div>
                                </div>
                                <i class="material-icons chevron-icon">chevron_right</i>
                            </div>
                            <div class="student-card-footer">
                                <span class="year-tag">Year ${student.currentYear} &bull; ${student.academicYear}</span>
                                <span class="${feeClass}">${feeStatus}</span>
                            </div>
                        </div>`;
                });

                searchResults.innerHTML = html;

                document.querySelectorAll('.student-result').forEach(el => {
                    el.addEventListener('click', function() {
                        selectStudent(parseInt(this.dataset.studentId));
                    });
                });
            }

            function selectStudent(studentId) {
                console.log('=== Student selected:', studentId, '===');
                currentStudentId = studentId;

                document.querySelectorAll('.student-result').forEach(el => {
                    el.classList.remove('selected');
                });

                const selected = document.querySelector(`[data-student-id="${studentId}"]`);
                if (selected) selected.classList.add('selected');

                studentDetails.style.display = 'none';
                studentTabs.style.display = 'flex';

                showAdminActionsIfAuthorized();
                loadStudentTab('profile');
            }

            function loadStudentTab(tabName) {
                console.log('=== Loading tab:', tabName, 'for student:', currentStudentId, '===');
                if (!currentStudentId) return;

                currentTab = tabName;

                document.querySelectorAll('.tab-button').forEach(btn => {
                    btn.classList.remove('active');
                });

                const activeBtn = document.querySelector(`[data-tab="${tabName}"]`);
                if (activeBtn) activeBtn.classList.add('active');

                tabContent.innerHTML = `
                    <div class="tab-loading">
                        <div class="spinner"></div>
                        Loading ${tabName}…
                    </div>`;

                const endpoints = {
                    'profile':    `/StudentLookup/GetStudentProfile/${currentStudentId}`,
                    'photo':      `/StudentLookup/GetStudentPhoto/${currentStudentId}`,
                    'idcard':     `/StudentLookup/GetStudentIDCard/${currentStudentId}`,
                    'financials': `/StudentLookup/GetStudentFinancials/${currentStudentId}`,
                    'results':    `/StudentResults/Results/${currentStudentId}`
                };

                fetch(endpoints[tabName])
                    .then(r => r.text())
                    .then(html => {
                        const temp = document.createElement('div');
                        temp.innerHTML = html;

                        const scripts = temp.querySelectorAll('script');
                        scripts.forEach(s => s.remove());
                        tabContent.innerHTML = temp.innerHTML;

                        scripts.forEach((oldScript, i) => {
                            const newScript = document.createElement('script');
                            Array.from(oldScript.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
                            newScript.textContent = oldScript.textContent;
                            document.body.appendChild(newScript);
                            setTimeout(() => document.body.removeChild(newScript), 100);
                        });
                    })
                    .catch(error => {
                        console.error('Error loading tab content:', error);
                        tabContent.innerHTML = `
                            <div class="empty-state-wrap">
                                <div class="empty-icon-wrap" style="background:#fff1f1;">
                                    <i class="material-icons" style="color:#ffc5c5;">error</i>
                                </div>
                                <p class="empty-title">Error Loading Content</p>
                                <p class="empty-sub">${error.message}</p>
                                <button onclick="loadStudentTab('${tabName}')"
                                        style="margin-top:1rem;padding:0.5rem 1.1rem;background:var(--bgs-coral);color:white;border:none;border-radius:8px;font-size:0.82rem;font-weight:600;cursor:pointer;">
                                    Try Again
                                </button>
                            </div>`;
                    });
            }

            function clearSearch() {
                searchInput.value = '';
                searchType.value = '';
                searchResults.innerHTML = `
                    <div class="empty-state-wrap">
                        <div class="empty-icon-wrap">
                            <i class="material-icons">search</i>
                        </div>
                        <p class="empty-title">Start Your Search</p>
                        <p class="empty-sub">Enter a search term to find students within your jurisdiction</p>
                    </div>`;
                resultsCount.textContent = '0 results';

                studentDetails.style.display = '';
                studentTabs.style.display = 'none';

                const adminActions = document.getElementById('adminActions');
                if (adminActions) adminActions.classList.add('hidden');

                currentStudentId = null;
            }

            function getStatusColor(status) {
                const map = {
                    'Registered':   'text-green-600 bg-green-50',
                    'Unregistered': 'text-amber-600 bg-amber-50',
                    'Pending':      'text-blue-600 bg-blue-50',
                    'Suspended':    'text-red-600 bg-red-50',
                    'Excluded':     'text-red-600 bg-red-50',
                    'Withdrawn':    'text-slate-600 bg-slate-50'
                };
                return map[status] || 'text-slate-600 bg-slate-50';
            }

            function showToast(message, type = 'info') {
                window.showAppToast(message, type);
            }

            // Student Created Modal Functions
            function showStudentCreatedModal(studentName, studentNumber, password) {
                const modal = document.getElementById('studentCreatedModal');
                if (!modal) {
                    showToast(`Student created. Number: ${studentNumber}`, 'success');
                    return;
                }

                document.getElementById('createdStudentName').textContent = studentName;
                document.getElementById('createdStudentNumber').textContent = studentNumber;
                document.getElementById('createdStudentPassword').textContent = password;

                modal.classList.remove('hidden');
                modal.style.display = 'flex';
            }

            function closeStudentCreatedModal() {
                const modal = document.getElementById('studentCreatedModal');
                if (modal) {
                    modal.classList.add('hidden');
                    modal.style.display = 'none';
                }
                window.location.reload();
            }

            function copyPassword() {
                const passwordElement = document.getElementById('createdStudentPassword');
                if (passwordElement) {
                    navigator.clipboard.writeText(passwordElement.textContent)
                        .then(() => showToast('Password copied to clipboard!', 'success'))
                        .catch(() => showToast('Failed to copy password', 'error'));
                }
            }

            function printStudentCredentials() {
                const studentName = document.getElementById('createdStudentName').textContent;
                const studentNumber = document.getElementById('createdStudentNumber').textContent;
                const password = document.getElementById('createdStudentPassword').textContent;

                const printWindow = window.open('', '_blank');
                printWindow.document.write(`
                    <!DOCTYPE html>
                    <html>
                    <head>
                        <title>Student Credentials</title>
                        <style>
                            body { font-family: 'Segoe UI', Arial, sans-serif; padding: 40px; max-width: 600px; margin: 0 auto; }
                            .header { text-align: center; margin-bottom: 30px; border-bottom: 3px solid #e85c5c; padding-bottom: 20px; }
                            .header h1 { color: #1e2d5e; margin: 0; font-size: 1.4rem; }
                            .header p { color: #64748b; font-size: 0.85rem; margin: 6px 0 0; }
                            .cred { background: #f8fafc; padding: 18px 20px; border-radius: 10px; margin: 14px 0; border-left: 4px solid #e85c5c; }
                            .lbl { font-weight: 700; color: #64748b; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 5px; }
                            .val { font-size: 1.1rem; color: #1e2d5e; font-weight: 700; }
                            .pw { background: #fffbeb; border-left-color: #f59e0b; }
                            .pw .val { font-family: 'Courier New', monospace; color: #78350f; }
                            .footer { margin-top: 40px; text-align: center; color: #94a3b8; font-size: 0.75rem; }
                        <\/style>
                    <\/head>
                    <body>
                        <div class="header">
                            <h1>Student Login Credentials</h1>
                            <p>Please keep this information secure</p>
                        </div>
                        <div class="cred"><div class="lbl">Student Name</div><div class="val">${studentName}</div></div>
                        <div class="cred"><div class="lbl">Student Number</div><div class="val">${studentNumber}</div></div>
                        <div class="cred pw"><div class="lbl">Default Password</div><div class="val">${password}</div></div>
                        <div class="footer">
                            <p>Generated on ${new Date().toLocaleString()}</p>
                            <p>Please change your password after first login</p>
                        </div>
                    <\/body>
                    <\/html>
                `);
                printWindow.document.close();
                printWindow.focus();
                setTimeout(() => printWindow.print(), 250);
            }

            // Make modal functions globally available
            window.showStudentCreatedModal = showStudentCreatedModal;
            window.closeStudentCreatedModal = closeStudentCreatedModal;
            window.copyPassword = copyPassword;
            window.printStudentCredentials = printStudentCredentials;

            // Event listeners
            if (searchButton) searchButton.addEventListener('click', performSearch);
            if (clearButton) clearButton.addEventListener('click', clearSearch);
            if (searchInput) {
                searchInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') performSearch();
                });
            }

            // Tab click handlers
            document.addEventListener('click', function(e) {
                const tabBtn = e.target.classList.contains('tab-button') ? e.target : e.target.closest('.tab-button');
                if (tabBtn && tabBtn.dataset.tab) {
                    loadStudentTab(tabBtn.dataset.tab);
                }
            });

            // Make functions globally available
            window.loadStudentTab = loadStudentTab;
            window.showToast = showToast;

            function showAdminActionsIfAuthorized() {
                const userRole = '@Model.UserRole';
                const adminActions = document.getElementById('adminActions');
                if (adminActions && (userRole === 'Admin' || userRole === 'Registrar' || userRole === 'VC' || userRole === 'DVC')) {
                    adminActions.classList.remove('hidden');
                }
            }

            const adminButton = document.getElementById('studentAdminButton');
            if (adminButton) {
                adminButton.addEventListener('click', function() {
                    if (currentStudentId) {
                        window.location.href = `/StudentAdministration/Index/${currentStudentId}`;
                    }
                });
            }

            console.log('=== Student Lookup initialization complete ===');
        });

        // Study Permit Modal functionality
        $(document).ready(function () {
            console.log('=== Study permit modal scripts loaded ===');

            const modal = $('#studyPermitModal');

            function openModal() {
                const modalElement = document.getElementById('studyPermitModal');
                if (modalElement) {
                    modalElement.classList.remove('hidden');
                    modalElement.classList.add('flex');
                }
            }

            window.closeModal = function() {
                const modalElement = document.getElementById('studyPermitModal');
                if (modalElement) {
                    modalElement.classList.remove('flex');
                    modalElement.classList.add('hidden');
                }
            }

            window.printIframe = function() {
                const iframe = document.getElementById('idCardFrame');
                if (iframe && iframe.contentWindow) {
                    iframe.contentWindow.focus();
                    iframe.contentWindow.print();
                }
            }

            window.reprintIframe = async function(studentId) {
                const iframe = document.getElementById('idCardFrame');
                try {
                    const response = await fetch(`/StudentLookup/ReprintIdCard/${studentId}`, { method: 'POST' });
                    const result = await response.json();
                    if (result.success) {
                        if (iframe && iframe.contentWindow) {
                            iframe.contentWindow.focus();
                            iframe.contentWindow.print();
                        }
                    } else {
                        showToast('Failed to prepare ID card for printing: ' + (result.message || 'Unknown error.'), 'error');
                    }
                } catch (error) {
                    console.error('Error during reprint request:', error);
                    showToast('An error occurred while preparing the ID card.', 'error');
                }
            };

            function loadPdf(url) {
                const viewerBase = "/pdfjs/web/viewer.html";
                const pdfFrame = document.getElementById("pdfFrame");
                if (pdfFrame) pdfFrame.src = `${viewerBase}?file=${url}`;
            }

            window.openPermitModal = function() {
                const mode = $(this).data('mode');
                const permitId = $(this).data('permit-id');
                const form = $('#studyPermitForm')[0];
                if (form) form.reset();

                $('#PermitId').val('');
                $('#studyPermitLabel').text(mode === 'add' ? 'Add Study Permit' : 'Update Study Permit');
                $('#savePermitBtn').text(mode === 'add' ? 'Add Permit' : 'Update Permit');

                if (mode === 'edit' && permitId) {
                    $.get(`/StudyPermit/Get/${permitId}`, function(data) {
                        if (data) {
                            $('#PermitId').val(data.id);
                            $('#PermitNumber').val(data.permitNumber);
                            $('#IssueDate').val(data.issueDate.split('T')[0]);
                            $('#ExpiryDate').val(data.expiryDate.split('T')[0]);
                            $('#IssuingAuthority').val(data.issuingAuthority);
                        }
                    }).fail(() => showToast('Failed to load permit data.', 'error'));
                }

                openModal();
            }

            $('#closePermitModal, #cancelPermitBtn').on('click', window.closeModal);
            $(document).on('click', function(e) {
                if ($(e.target).is('#studyPermitModal')) window.closeModal();
            });

            $(document).on('submit', '#studyPermitForm', function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                $.ajax({
                    url: '/StudyPermit/Save',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function() {
                        window.closeModal();
                        if (typeof loadStudentTab === 'function') loadStudentTab('profile');
                    },
                    error: function() {
                        showToast('Error saving study permit.', 'error');
                    }
                });
            });
        });
    </script>
}
