@model SIS.Models.ViewModels.StudentLookupIndexViewModel
@{
    ViewData["Title"] = "Student Lookup";
}

<style>
    :root {
        --bgs-coral: #e85c5c;
        --bgs-coral-dark: #d43f3f;
        --bgs-coral-light: #fff1f1;
        --bgs-coral-mid: #ffc5c5;
        --bgs-navy: #1e2d5e;
        --bgs-navy-light: #eef2ff;
        --bgs-navy-mid: #c2d0ff;
        --bgs-bg: #f0f4f8;
        --bgs-surface: #ffffff;
        --bgs-border: #e2e8f0;
        --bgs-text: #1e2d5e;
        --bgs-text-muted: #64748b;
        --bgs-text-light: #94a3b8;
    }

    /* Page */
    .lookup-page {
        background: var(--bgs-bg);
        min-height: 100vh;
        padding: 1.5rem;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    /* Page Header */
    .page-header {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    @@media (min-width: 768px) {
        .page-header {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }

    .page-title-block {
        display: flex;
        align-items: center;
        gap: 0.875rem;
    }

    .page-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--bgs-coral);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(232,92,92,0.3);
    }

        .page-icon-wrap .material-icons {
            color: white;
            font-size: 24px;
        }

    .page-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--bgs-navy);
        margin: 0;
        line-height: 1.2;
    }

    .page-subtitle {
        font-size: 0.8rem;
        color: var(--bgs-text-muted);
        margin: 0;
        margin-top: 2px;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .role-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.875rem;
        background: var(--bgs-navy-light);
        border: 1px solid var(--bgs-navy-mid);
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--bgs-navy);
    }

        .role-chip .material-icons {
            font-size: 14px;
            color: var(--bgs-coral);
        }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1.1rem;
        background: var(--bgs-coral);
        color: white;
        font-size: 0.82rem;
        font-weight: 600;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.18s, box-shadow 0.18s, transform 0.12s;
        box-shadow: 0 2px 8px rgba(232,92,92,0.28);
    }

        .btn-primary:hover {
            background: var(--bgs-coral-dark);
            box-shadow: 0 4px 14px rgba(232,92,92,0.38);
            transform: translateY(-1px);
            color: white;
            text-decoration: none;
        }

        .btn-primary .material-icons {
            font-size: 16px;
        }

    /* Search Card */
    .search-card {
        background: var(--bgs-surface);
        border-radius: 14px;
        border: 1px solid var(--bgs-border);
        box-shadow: 0 2px 8px rgba(30,45,94,0.06);
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .search-card-header {
        padding: 1rem 1.25rem 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .search-card-header .material-icons {
            color: var(--bgs-coral);
            font-size: 20px;
        }

        .search-card-header h2 {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--bgs-navy);
            margin: 0;
        }

    .search-card-body {
        padding: 1rem 1.25rem 1.25rem;
    }

    .search-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
        align-items: end;
    }

    @@media (min-width: 768px) {
        .search-grid {
            grid-template-columns: 1fr 220px 140px 52px;
        }
    }

    .form-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--bgs-navy);
        margin-bottom: 0.4rem;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    .search-input-wrap {
        position: relative;
    }

    .search-input-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--bgs-text-light);
        font-size: 18px;
        pointer-events: none;
    }

    .form-control {
        width: 100%;
        padding: 0.65rem 0.9rem 0.65rem 2.4rem;
        font-size: 0.85rem;
        border: 1.5px solid var(--bgs-border);
        border-radius: 8px;
        color: var(--bgs-text);
        background: #fafbfc;
        transition: border-color 0.18s, box-shadow 0.18s;
        outline: none;
        box-sizing: border-box;
    }

        .form-control:focus {
            border-color: var(--bgs-coral);
            box-shadow: 0 0 0 3px rgba(232,92,92,0.12);
            background: white;
        }

    .form-select {
        width: 100%;
        padding: 0.65rem 0.9rem;
        font-size: 0.85rem;
        border: 1.5px solid var(--bgs-border);
        border-radius: 8px;
        color: var(--bgs-text);
        background: #fafbfc;
        transition: border-color 0.18s, box-shadow 0.18s;
        outline: none;
        cursor: pointer;
        box-sizing: border-box;
    }

        .form-select:focus {
            border-color: var(--bgs-coral);
            box-shadow: 0 0 0 3px rgba(232,92,92,0.12);
            background: white;
        }

    .btn-search {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        width: 100%;
        padding: 0.65rem 1rem;
        background: var(--bgs-coral);
        color: white;
        font-size: 0.82rem;
        font-weight: 700;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: background 0.18s, box-shadow 0.18s;
        box-shadow: 0 2px 8px rgba(232,92,92,0.25);
        white-space: nowrap;
    }

        .btn-search:hover {
            background: var(--bgs-coral-dark);
        }

        .btn-search .material-icons {
            font-size: 17px;
        }

    .btn-clear {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 0.65rem;
        background: #f1f5f9;
        color: var(--bgs-text-muted);
        border-radius: 8px;
        border: 1.5px solid var(--bgs-border);
        cursor: pointer;
        transition: background 0.18s, border-color 0.18s;
    }

        .btn-clear:hover {
            background: #e2e8f0;
            border-color: #cbd5e1;
            color: var(--bgs-navy);
        }

        .btn-clear .material-icons {
            font-size: 18px;
        }

    /* Results Layout */
    .results-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
    }

    @@media (min-width: 1024px) {
        .results-layout {
            grid-template-columns: 340px 1fr;
        }
    }

    /* Panel */
    .panel {
        background: var(--bgs-surface);
        border-radius: 14px;
        border: 1px solid var(--bgs-border);
        box-shadow: 0 2px 8px rgba(30,45,94,0.06);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .panel-height {
        height: calc(100vh - 320px);
    }

    .panel-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--bgs-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
        background: linear-gradient(to right, #fafbff, var(--bgs-surface));
    }

    .panel-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--bgs-navy);
    }

    .results-badge {
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.2rem 0.7rem;
        background: var(--bgs-navy-light);
        color: var(--bgs-navy);
        border-radius: 999px;
        border: 1px solid var(--bgs-navy-mid);
    }

    .panel-body {
        flex: 1;
        overflow: hidden;
        position: relative;
    }

    .panel-scroll {
        height: 100%;
        overflow-y: auto;
        padding: 1rem;
    }

        .panel-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .panel-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .panel-scroll::-webkit-scrollbar-thumb {
            background: var(--bgs-coral-mid);
            border-radius: 4px;
        }

    /* Empty State */
    .empty-state-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        padding: 2rem 1.5rem;
        text-align: center;
    }

    .empty-icon-wrap {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: var(--bgs-navy-light);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

        .empty-icon-wrap .material-icons {
            font-size: 34px;
            color: var(--bgs-navy-mid);
        }

    .empty-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--bgs-navy);
        margin-bottom: 0.35rem;
    }

    .empty-sub {
        font-size: 0.78rem;
        color: var(--bgs-text-light);
        max-width: 200px;
        line-height: 1.5;
    }

    /* Loading */
    .loading-state {
        display: none;
        height: 100%;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .loading-spinner-wrap {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--bgs-text-muted);
        font-size: 0.85rem;
        font-weight: 500;
    }

    .spinner {
        width: 24px;
        height: 24px;
        border: 2.5px solid var(--bgs-coral-mid);
        border-top-color: var(--bgs-coral);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Student Result Cards */
    .student-card {
        border: 1.5px solid var(--bgs-border);
        border-radius: 10px;
        padding: 0.875rem;
        cursor: pointer;
        transition: all 0.18s;
        background: white;
        margin-bottom: 0.65rem;
    }

        .student-card:last-child {
            margin-bottom: 0;
        }

        .student-card:hover {
            border-color: var(--bgs-coral-mid);
            background: var(--bgs-coral-light);
            box-shadow: 0 3px 12px rgba(232,92,92,0.12);
            transform: translateX(2px);
        }

        .student-card.selected {
            border-color: var(--bgs-coral);
            background: var(--bgs-coral-light);
            box-shadow: 0 3px 12px rgba(232,92,92,0.18);
        }

    .student-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }

    .student-name {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--bgs-navy);
    }

    .status-pill {
        font-size: 0.68rem;
        font-weight: 600;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
        margin-left: 0.5rem;
        white-space: nowrap;
    }

    .student-meta {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.76rem;
        color: var(--bgs-text-muted);
        margin-bottom: 0.25rem;
    }

        .student-meta .material-icons {
            font-size: 13px;
            color: var(--bgs-coral);
        }

    .student-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 0.5rem;
        padding-top: 0.5rem;
        border-top: 1px solid var(--bgs-border);
    }

    .year-tag {
        font-size: 0.72rem;
        color: var(--bgs-text-light);
        font-weight: 500;
    }

    .fee-pill {
        font-size: 0.68rem;
        font-weight: 600;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
    }

    .chevron-icon {
        color: var(--bgs-coral);
        font-size: 18px;
        flex-shrink: 0;
        opacity: 0.5;
        transition: opacity 0.18s;
    }

    .student-card:hover .chevron-icon,
    .student-card.selected .chevron-icon {
        opacity: 1;
    }

    /* Details Panel */
    .details-panel-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--bgs-border);
        flex-shrink: 0;
        background: linear-gradient(to right, #fafbff, var(--bgs-surface));
    }

    .details-panel-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--bgs-navy);
    }

    /* Tabs */
    .tabs-nav {
        border-bottom: 1px solid var(--bgs-border);
        display: flex;
        padding: 0 1.25rem;
        gap: 0.125rem;
        flex-shrink: 0;
        overflow-x: auto;
    }

        .tabs-nav::-webkit-scrollbar {
            height: 0;
        }

    .tab-button {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.75rem 0.875rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--bgs-text-muted);
        border: none;
        border-bottom: 2.5px solid transparent;
        background: none;
        cursor: pointer;
        transition: color 0.18s, border-color 0.18s;
        white-space: nowrap;
        margin-bottom: -1px;
    }

        .tab-button .material-icons {
            font-size: 15px;
        }

        .tab-button:hover {
            color: var(--bgs-navy);
        }

        .tab-button.active {
            color: var(--bgs-coral);
            border-bottom-color: var(--bgs-coral);
        }

    /* Admin actions bar */
    .admin-actions-bar {
        padding: 0.75rem 1.25rem;
        border-bottom: 1px solid var(--bgs-border);
        background: var(--bgs-navy-light);
        flex-shrink: 0;
    }

    .btn-admin {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 1rem;
        background: var(--bgs-navy);
        color: white;
        font-size: 0.8rem;
        font-weight: 600;
        border-radius: 7px;
        border: none;
        cursor: pointer;
        transition: background 0.18s;
    }

        .btn-admin:hover {
            background: #16224a;
        }

        .btn-admin .material-icons {
            font-size: 16px;
        }

    /* Tab content area */
    .tab-content-area {
        flex: 1;
        overflow-y: auto;
        padding: 1.25rem;
        min-height: 0;
    }

        .tab-content-area::-webkit-scrollbar {
            width: 4px;
        }

        .tab-content-area::-webkit-scrollbar-thumb {
            background: var(--bgs-coral-mid);
            border-radius: 4px;
        }

    /* Default no-student state */
    .no-student-state {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    /* ---- MODAL STYLES ---- */
    .bgs-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        overflow-y: auto;
        display: none;
    }

        .bgs-modal-overlay:not(.hidden) {
            display: block;
        }

    .bgs-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(30,45,94,0.55);
        backdrop-filter: blur(3px);
    }

    .bgs-modal-positioner {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 1.5rem;
    }

    .bgs-modal-box {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 24px 48px rgba(30,45,94,0.22);
        width: 100%;
        max-width: 860px;
        position: relative;
        z-index: 10;
    }

    .bgs-modal-header {
        background: linear-gradient(135deg, var(--bgs-coral) 0%, var(--bgs-coral-dark) 100%);
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bgs-modal-header-title {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: white;
        font-size: 1rem;
        font-weight: 700;
    }

        .bgs-modal-header-title .material-icons {
            font-size: 20px;
        }

    .bgs-modal-close {
        background: rgba(255,255,255,0.15);
        border: none;
        border-radius: 6px;
        color: white;
        cursor: pointer;
        padding: 0.3rem;
        display: flex;
        align-items: center;
        transition: background 0.15s;
    }

        .bgs-modal-close:hover {
            background: rgba(255,255,255,0.28);
        }

    .bgs-modal-body {
        padding: 1.5rem;
        max-height: 72vh;
        overflow-y: auto;
    }

        .bgs-modal-body::-webkit-scrollbar {
            width: 4px;
        }

        .bgs-modal-body::-webkit-scrollbar-thumb {
            background: var(--bgs-coral-mid);
            border-radius: 4px;
        }

    .form-section-title {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--bgs-navy);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding-bottom: 0.6rem;
        border-bottom: 2px solid var(--bgs-coral-light);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

        .form-section-title::before {
            content: '';
            width: 4px;
            height: 14px;
            background: var(--bgs-coral);
            border-radius: 2px;
        }

    .modal-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    @@media (min-width: 640px) {
        .modal-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .modal-grid-full {
        grid-column: 1 / -1;
    }

    .modal-field label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--bgs-navy);
        margin-bottom: 0.35rem;
    }

    .modal-input {
        width: 100%;
        padding: 0.6rem 0.875rem;
        font-size: 0.83rem;
        border: 1.5px solid var(--bgs-border);
        border-radius: 8px;
        color: var(--bgs-text);
        background: #fafbfc;
        transition: border-color 0.18s, box-shadow 0.18s;
        outline: none;
        box-sizing: border-box;
    }

        .modal-input:focus {
            border-color: var(--bgs-coral);
            box-shadow: 0 0 0 3px rgba(232,92,92,0.1);
            background: white;
        }

    .bgs-modal-footer {
        background: #f8fafc;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        border-top: 1px solid var(--bgs-border);
    }

    .btn-cancel {
        padding: 0.55rem 1.1rem;
        font-size: 0.82rem;
        font-weight: 600;
        border-radius: 8px;
        border: 1.5px solid var(--bgs-border);
        background: white;
        color: var(--bgs-text-muted);
        cursor: pointer;
        transition: background 0.18s, border-color 0.18s;
    }

        .btn-cancel:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
            color: var(--bgs-navy);
        }

    /* Toast */
    .bgs-toast {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        min-width: 280px;
        max-width: 420px;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        z-index: 100;
        display: none;
    }

        .bgs-toast.show {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
        }

        .bgs-toast .material-icons {
            font-size: 20px;
            flex-shrink: 0;
        }

    /* Success created modal */
    .created-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(30,45,94,0.55);
        backdrop-filter: blur(3px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 60;
        padding: 1.5rem;
    }

    .created-modal-box {
        background: white;
        border-radius: 18px;
        overflow: hidden;
        max-width: 440px;
        width: 100%;
        box-shadow: 0 24px 48px rgba(30,45,94,0.25);
    }

    .created-modal-header {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: white;
    }

        .created-modal-header .material-icons {
            font-size: 28px;
        }

        .created-modal-header h3 {
            font-size: 1.05rem;
            font-weight: 700;
            margin: 0;
        }

    .created-modal-body {
        padding: 1.5rem;
    }

    .cred-row {
        background: #f8fafc;
        border-radius: 10px;
        padding: 0.875rem 1rem;
        margin-bottom: 0.75rem;
    }

        .cred-row label {
            display: block;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--bgs-text-muted);
            margin-bottom: 0.25rem;
        }

    .cred-value {
        font-size: 1rem;
        font-weight: 700;
        color: var(--bgs-navy);
