</div>

<script>
    (function() {
        console.log('🎬 ID tab script STARTED executing...');
        console.log('Current timestamp:', new Date().toISOString());
        console.log('Document readyState:', document.readyState);

        // Test if we can find the button
        setTimeout(() => {
            const testBtn = document.querySelector('[data-action="start-camera"]');
            console.log('Can find start camera button?', !!testBtn);
            if (testBtn) {
                console.log('Button element:', testBtn);
                console.log('Button studentId:', testBtn.dataset.studentId);
            }
        }, 100);

        // Initialize global storage
        if (!window.studentPhotoState) {
            window.studentPhotoState = {
                streams: {},
                capturedImages: {}
            };
            console.log('✅ Created window.studentPhotoState');
        }

        // Add a test click listener first
        console.log('Adding test click listener to document...');
        document.addEventListener('click', function(e) {
            console.log('🖱️ DOCUMENT CLICKED!', e.target);
            console.log('Target tagName:', e.target.tagName);
            console.log('Target classes:', e.target.className);
            console.log('Target data-action:', e.target.dataset?.action);

            const closestButton = e.target.closest('[data-action]');
            console.log('Closest button with data-action:', closestButton);
            if (closestButton) {
                console.log('Found button action:', closestButton.dataset.action);
            }
        }, true); // Use capture phase

        // Use event delegation on document for dynamically loaded content
        document.addEventListener('click', async function(e) {
            const button = e.target.closest('[data-action]');
            if (!button) return;

            const action = button.dataset.action;
            const studentId = button.dataset.studentId;

            console.log('🎯 Button clicked:', action, 'for student:', studentId);

            if (!studentId) {
                console.error('No studentId found on button');
                return;
            }

            switch(action) {
                case 'start-camera':
                    await handleStartCamera(studentId);
                    break;
                case 'stop-camera':
                    handleStopCamera(studentId);
                    break;
                case 'capture-photo':
                    handleCapturePhoto(studentId);
                    break;
                case 'save-photo':
                    await handleSavePhoto(studentId, button.dataset.studentNumber);
                    break;
                case 'delete-photo':
                    await handleDeletePhoto(studentId);
                    break;
            }
        });

        // Handler functions
        async function handleStartCamera(studentId) {
            console.log('🎥 Starting camera for student:', studentId);

            const video = document.getElementById(`cameraVideo_${studentId}`);
            const errorDiv = document.getElementById(`cameraError_${studentId}`);
            const errorMsg = document.getElementById(`cameraErrorMessage_${studentId}`);
            const errorDetails = document.getElementById(`cameraErrorDetails_${studentId}`);
            const startBtn = document.getElementById(`startCameraBtn_${studentId}`);
            const stopBtn = document.getElementById(`stopCameraBtn_${studentId}`);
            const captureBtn = document.getElementById(`capturePhotoBtn_${studentId}`);
            const cameraControls = document.getElementById(`cameraControls_${studentId}`);

            if (!video) {
                console.error('❌ Video element not found');
                alert('Error: Video element not found');
                return;
            }

            if (!navigator.mediaDevices?.getUserMedia) {
                console.error('❌ Camera API not supported');
                alert('Camera API is not supported in your browser');
                return;
            }

            try {
                console.log('📷 Requesting camera permissions...');

                const stream = await navigator.mediaDevices.getUserMedia({
                    video: {
                        width: { ideal: 640 },
                        height: { ideal: 480 },
                        facingMode: 'user'
                    },
                    audio: false
                });

                console.log('✅ Camera access granted!');

                window.studentPhotoState.streams[studentId] = stream;
                video.srcObject = stream;

                video.onloadedmetadata = () => {
                    console.log('📹 Video metadata loaded');
                    video.play().then(() => {
                        console.log('▶️ Video playing');

                        startBtn.style.display = 'none';
                        if (cameraControls) cameraControls.style.display = 'flex';
                        errorDiv.classList.add('hidden');

                        showToast('Camera started successfully', 'success');
                    }).catch(err => {
                        console.error('❌ Error playing video:', err);
                        alert('Error playing video: ' + err.message);
                    });
                };

            } catch (error) {
                console.error('❌ Camera error:', error.name, error.message);

                errorDiv.classList.remove('hidden');
                video.classList.add('hidden');

                const errorMap = {
                    'NotAllowedError': ['Camera access denied', 'Please allow camera access in browser settings'],
                    'NotFoundError': ['No camera found', 'Please connect a camera device'],
                    'NotReadableError': ['Camera in use', 'Camera is being used by another application'],
                    'SecurityError': ['Security error', 'Camera requires HTTPS or localhost']
                };

                const [msg, details] = errorMap[error.name] || ['Camera error', error.message];
                errorMsg.textContent = msg;
                errorDetails.textContent = details;

                showToast(msg, 'error');
            }
        }

        function handleStopCamera(studentId) {
            console.log('⏹️ Stopping camera for student:', studentId);

            const stream = window.studentPhotoState.streams[studentId];
            const video = document.getElementById(`cameraVideo_${studentId}`);
            const startBtn = document.getElementById(`startCameraBtn_${studentId}`);
            const cameraControls = document.getElementById(`cameraControls_${studentId}`);
            const captureBtn = document.getElementById(`capturePhotoBtn_${studentId}`);

            if (stream) {
                stream.getTracks().forEach(track => track.stop());
                delete window.studentPhotoState.streams[studentId];
            }

            if (video) video.srcObject = null;

            startBtn.style.display = 'flex';
            if (cameraControls) cameraControls.style.display = 'none';

            showToast('Camera stopped', 'info');
        }

        function handleCapturePhoto(studentId) {
            console.log('📸 Capturing photo for student:', studentId);

            const video = document.getElementById(`cameraVideo_${studentId}`);
            const canvas = document.getElementById(`photoCanvas_${studentId}`);
            const saveBtn = document.getElementById(`savePhotoBtn_${studentId}`);
            const captureBtn = document.getElementById(`capturePhotoBtn_${studentId}`);

            if (!window.studentPhotoState.streams[studentId]) {
                alert('Please start the camera first');
                return;
            }

            const context = canvas.getContext('2d');

            // Set canvas size to match video's natural dimensions
            const videoWidth = video.videoWidth;
            const videoHeight = video.videoHeight;

            console.log('Video dimensions:', videoWidth, 'x', videoHeight);

            if (videoWidth === 0 || videoHeight === 0) {
                alert('Camera not ready. Please wait.');
                return;
            }

            // Set canvas to proper portrait size (4:5 ratio - passport style)
            canvas.width = 320;
            canvas.height = 400;

            // Calculate scaling to fit video into canvas while maintaining aspect ratio
            const videoAspect = videoWidth / videoHeight;
            const canvasAspect = canvas.width / canvas.height;

            let sourceX = 0, sourceY = 0, sourceWidth = videoWidth, sourceHeight = videoHeight;

            if (videoAspect > canvasAspect) {
                // Video is wider - crop sides
                sourceWidth = videoHeight * canvasAspect;
                sourceX = (videoWidth - sourceWidth) / 2;
            } else {
                // Video is taller - crop top/bottom
                sourceHeight = videoWidth / canvasAspect;
                sourceY = (videoHeight - sourceHeight) / 2;
            }

            // Draw the cropped and scaled video frame
            context.drawImage(video, sourceX, sourceY, sourceWidth, sourceHeight, 0, 0, canvas.width, canvas.height);

            window.studentPhotoState.capturedImages[studentId] = canvas.toDataURL('image/png');

            saveBtn.classList.remove('hidden');
            captureBtn.innerHTML = '<i class="material-icons text-sm mr-2">camera_alt</i>Retake Photo';

            showToast('Photo captured! Click "Save Photo" to store it.', 'success');
        }

        async function handleSavePhoto(studentId, studentNumber) {
            console.log('💾 Saving photo for student:', studentId);

            const imageData = window.studentPhotoState.capturedImages[studentId];
            if (!imageData) {
                alert('Please capture a photo first');
                return;
            }

            const saveBtn = document.getElementById(`savePhotoBtn_${studentId}`);
            const originalContent = saveBtn.innerHTML;

            saveBtn.disabled = true;
            saveBtn.innerHTML = '<div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2 inline-block"></div>Saving...';

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const response = await fetch('/StudentLookup/SaveStudentPhoto', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ studentId: parseInt(studentId), imageData: imageData })
                });

                const result = await response.json();

                if (result.success) {
                    showToast('Photo saved successfully!', 'success');

                    const photoContainer = document.getElementById('currentPhotoContainer');
                    if (photoContainer) {
                        photoContainer.innerHTML = `<img src="${result.photoPath}?v=${Date.now()}" class="w-full h-full object-cover">`;
                    }

                    delete window.studentPhotoState.capturedImages[studentId];
                    const canvas = document.getElementById(`photoCanvas_${studentId}`);
                    canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);

                    saveBtn.classList.add('hidden');
                    document.getElementById(`capturePhotoBtn_${studentId}`).innerHTML = '<i class="material-icons text-sm mr-2">camera_alt</i>Capture Photo';

                    handleStopCamera(studentId);

                    setTimeout(() => {
                        if (typeof window.loadStudentTab === 'function') {
                            window.loadStudentTab('photo');
                        }
                    }, 1500);
                } else {
                    alert('Failed to save: ' + (result.message || 'Unknown error'));
                }
            } catch (error) {
                console.error('❌ Save error:', error);
                alert('Error saving photo: ' + error.message);
            } finally {
                saveBtn.disabled = false;
                saveBtn.innerHTML = originalContent;
            }
        }

        async function handleDeletePhoto(studentId) {
            if (!confirm('Are you sure you want to delete this photo?')) return;

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const response = await fetch('/StudentLookup/DeleteStudentPhoto', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `studentId=${studentId}`
                });

                const result = await response.json();

                if (result.success) {
                    showToast('Photo deleted successfully!', 'success');
                    setTimeout(() => {
                        if (typeof window.loadStudentTab === 'function') {
                            window.loadStudentTab('photo');
                        }
                    }, 1500);
                } else {
                    alert('Failed to delete: ' + (result.message || 'Unknown error'));
                }
            } catch (error) {
                console.error('❌ Delete error:', error);
                alert('Error deleting photo: ' + error.message);
            }
        }

        function showToast(message, type) {
            if (typeof window.showToast === 'function') {
                window.showToast(message, type);
            } else {
                console.log(`[${type}] ${message}`);
            }
        }

        console.log('✅ Photo tab script loaded with event delegation');

        // Try to manually attach to button as backup
        setTimeout(() => {
            const startBtn = document.querySelector('[data-action="start-camera"]');
            if (startBtn) {
                console.log('🎯 Found start button, adding direct onclick...');
                startBtn.onclick = function(e) {
                    console.log('🚀 DIRECT ONCLICK FIRED!');
                    e.preventDefault();
                    e.stopPropagation();
                    const studentId = this.dataset.studentId;
                    console.log('Student ID from button:', studentId);
                    handleStartCamera(studentId);
                };
            } else {
                console.error('❌ Could not find start camera button');
            }
        }, 200);
    })();
</script>
