            @if(Model.IdCardPrintedDate == null)
            {
                <button onclick="printIframe()" style="padding: 10px 20px; margin: 10px; background: @(ViewBag.IdCardPrimaryColor ?? "#1991cf"); color: white; border: none; border-radius: 5px; cursor: pointer;">
                    Print ID Card
                </button>
            }
            else
            {
                <button onclick="reprintIframe(@Model.StudentId)" style="padding: 10px 20px; margin: 10px; background: #f0ad4e; color: white; border: none; border-radius: 5px; cursor: pointer;">
                    Reprint ID Card
                </button>
            }
            
            <iframe id="idCardFrame"
