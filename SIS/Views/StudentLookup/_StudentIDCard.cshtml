                <i class="material-icons text-primary-600 mr-2">photo_camera</i>
                Student ID Card Management
            </h3>
        </div>
        <div class="p-6">
            <div class="text-center mb-4">
                <p class="text-sm text-slate-600 mb-2">
                    <strong>Student:</strong> @Model.StudentName (@Model.StudentNumber)
                </p>
            </div>

            <div class="mb-5 rounded-lg border border-slate-200 bg-slate-50 p-4">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h4 class="text-sm font-semibold text-slate-800 flex items-center mb-2">
                            <i class="material-icons text-primary-600 mr-2 text-base">badge</i>
                            Active ID Card Configuration
                        </h4>
                        <div class="grid gap-2 text-sm text-slate-600 md:grid-cols-3">
                            <div>
                                <span class="block text-xs font-semibold uppercase text-slate-500">Institution</span>
                                <span>@(ViewBag.IdCardInstitutionName ?? "Institution")</span>
                            </div>
                            <div>
                                <span class="block text-xs font-semibold uppercase text-slate-500">Contact Details</span>
                                <span style="white-space: pre-line;">@(ViewBag.IdCardContactDetails ?? "")</span>
                            </div>
                            <div>
                                <span class="block text-xs font-semibold uppercase text-slate-500">Card Color</span>
                                <span class="inline-flex items-center gap-2">
                                    <span class="inline-block h-4 w-4 rounded border border-slate-300" style="background-color: @(ViewBag.IdCardPrimaryColor ?? "#1991cf");"></span>
                                    @(ViewBag.IdCardPrimaryColor ?? "#1991cf")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

