@* @{
    ViewData["Title"] = "Student Disqualification Management";
}

<div class="min-h-screen p-2 sm:p-4">
    <!-- Header Section -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 gap-2">
        <div class="flex items-center text-secondary-800">
            <i class="material-icons text-2xl sm:text-3xl mr-2 text-red-600">gavel</i>
            <div>
                <h1 class="text-xl sm:text-2xl font-bold">Student Disqualification Management</h1>
                <p class="text-xs sm:text-sm text-slate-600">Record and manage student disqualifications due to malpractice</p>
            </div>
        </div>
    </div>

    <!-- Statistics Cards Section -->
    <div class="mb-4">
        <!-- Filter Row -->
        <div class="bg-white rounded-lg shadow-md p-3 sm:p-4 mb-4">
            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 items-start sm:items-end">
                <div class="w-full sm:w-auto flex-1 sm:flex-none">
                    <label class="block text-xs font-medium text-slate-600 mb-1">Academic Year</label>
                    <select id="filterAcademicYear" onchange="loadStatistics()"
                            class="w-full sm:w-48 px-3 py-2 border border-slate-300 rounded-lg focus:ring-red-500 focus:border-red-500 text-sm">
                        <option value="">All Years</option>
                        @if (ViewBag.AcademicYears != null)
                        {
                            foreach (var item in ViewBag.AcademicYears)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="w-full sm:w-auto flex-1 sm:flex-none">
                    <label class="block text-xs font-medium text-slate-600 mb-1">Semester</label>
                    <select id="filterSemester" onchange="loadStatistics()"
                            class="w-full sm:w-36 px-3 py-2 border border-slate-300 rounded-lg focus:ring-red-500 focus:border-red-500 text-sm">
                        <option value="">All Semesters</option>
                        <option value="1">Semester 1</option>
                        <option value="2">Semester 2</option>
                    </select>
                </div>
                <div class="w-full sm:w-auto flex-1 sm:flex-none">
                    <label class="block text-xs font-medium text-slate-600 mb-1">Status</label>
                    <select id="filterStatus" onchange="loadStatistics()"
                            class="w-full sm:w-40 px-3 py-2 border border-slate-300 rounded-lg focus:ring-red-500 focus:border-red-500 text-sm">
                        <option value="">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="Confirmed">Confirmed</option>
                        <option value="Appealed">Appealed</option>
                        <option value="Overturned">Overturned</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
                <button type="button" onclick="loadStatistics()"
                        class="w-full sm:w-auto px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center justify-center">
                    <i class="material-icons text-sm mr-1">refresh</i>
                    Refresh
                </button>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2 sm:gap-4">
            <!-- Total Records -->
            <div class="bg-white rounded-lg shadow-md p-3 sm:p-4 border-l-4 border-slate-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Total</p>
                        <p id="statTotal" class="text-xl sm:text-2xl font-bold text-slate-700">0</p>
                    </div>
                    <div class="hidden sm:flex w-10 h-10 bg-slate-100 rounded-full items-center justify-center">
                        <i class="material-icons text-slate-600">assessment</i>
                    </div>
                </div>
            </div>

            <!-- Pending -->
            <div class="bg-white rounded-lg shadow-md p-3 sm:p-4 border-l-4 border-yellow-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Pending</p>
                        <p id="statPending" class="text-xl sm:text-2xl font-bold text-yellow-600">0</p>
                    </div>
                    <div class="hidden sm:flex w-10 h-10 bg-yellow-100 rounded-full items-center justify-center">
                        <i class="material-icons text-yellow-600">hourglass_empty</i>
                    </div>
                </div>
            </div>

            <!-- Confirmed -->
            <div class="bg-white rounded-lg shadow-md p-3 sm:p-4 border-l-4 border-red-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Confirmed</p>
                        <p id="statConfirmed" class="text-xl sm:text-2xl font-bold text-red-600">0</p>
                    </div>
                    <div class="hidden sm:flex w-10 h-10 bg-red-100 rounded-full items-center justify-center">
                        <i class="material-icons text-red-600">verified</i>
                    </div>
                </div>
            </div>

            <!-- Appealed -->
            <div class="bg-white rounded-lg shadow-md p-3 sm:p-4 border-l-4 border-blue-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Appealed</p>
                        <p id="statAppealed" class="text-xl sm:text-2xl font-bold text-blue-600">0</p>
                    </div>
                    <div class="hidden sm:flex w-10 h-10 bg-blue-100 rounded-full items-center justify-center">
                        <i class="material-icons text-blue-600">gavel</i>
                    </div>
                </div>
            </div>

            <!-- Overturned -->
            <div class="bg-white rounded-lg shadow-md p-3 sm:p-4 border-l-4 border-green-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Overturned</p>
                        <p id="statOverturned" class="text-xl sm:text-2xl font-bold text-green-600">0</p>
                    </div>
                    <div class="hidden sm:flex w-10 h-10 bg-green-100 rounded-full items-center justify-center">
                        <i class="material-icons text-green-600">undo</i>
                    </div>
                </div>
            </div>

            <!-- Completed -->
            <div class="bg-white rounded-lg shadow-md p-3 sm:p-4 border-l-4 border-purple-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 uppercase tracking-wider">Completed</p>
                        <p id="statCompleted" class="text-xl sm:text-2xl font-bold text-purple-600">0</p>
                    </div>
                    <div class="hidden sm:flex w-10 h-10 bg-purple-100 rounded-full items-center justify-center">
                        <i class="material-icons text-purple-600">check_circle</i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Layout -->
    <div class="flex flex-col lg:flex-row gap-4 min-h-[60vh] lg:h-[calc(100vh-380px)]">
        <!-- Student Search Section -->
        <div class="w-full lg:w-2/5">
            <div class="bg-white rounded-lg shadow-md h-full flex flex-col">
                <div class="p-3 sm:p-4 border-b border-slate-200">
                    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2">
                        <div class="relative flex-1">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <i class="material-icons text-slate-400 text-sm">search</i>
                            </div>
                            <input type="text" id="studentSearch"
                                   class="block w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-red-500 focus:border-red-500 text-sm"
                                   placeholder="Search by Student ID, Name, Email..." />
                        </div>
                        <button type="button" onclick="searchStudents()"
                                class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center justify-center">
                            <i class="material-icons mr-1 text-sm">search</i>
                            <span class="sm:inline">Search</span>
                        </button>
                    </div>
                </div>

                <div class="flex-1 overflow-y-auto p-3 sm:p-4 max-h-[40vh] lg:max-h-none">
                    <div id="studentsContainer" class="space-y-2">
                        <div class="text-center py-6 sm:py-8 text-slate-500">
                            <i class="material-icons text-4xl sm:text-6xl mb-2 text-slate-300">search</i>
                            <p class="text-base sm:text-lg">Search for a student</p>
                            <p class="text-xs sm:text-sm">Enter Student ID, Name, or Email</p>
                        </div>
                    </div>
                </div>

                <!-- Pagination -->
                <div id="paginationContainer" class="hidden p-3 sm:p-4 border-t border-slate-200 bg-slate-50">
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-2">
                        <span id="paginationInfo" class="text-xs sm:text-sm text-slate-600 text-center sm:text-left"></span>
                        <div class="flex gap-2">
                            <button type="button" id="prevPageBtn" onclick="previousPage()"
                                    class="px-3 py-1 bg-slate-200 text-slate-700 rounded hover:bg-slate-300 disabled:opacity-50 disabled:cursor-not-allowed text-sm">
                                Previous
                            </button>
                            <button type="button" id="nextPageBtn" onclick="nextPage()"
                                    class="px-3 py-1 bg-slate-200 text-slate-700 rounded hover:bg-slate-300 disabled:opacity-50 disabled:cursor-not-allowed text-sm">
                                Next
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Disqualification Details Section -->
        <div class="w-full lg:w-3/5">
            <div class="bg-white rounded-lg shadow-md h-full flex flex-col">
                <div class="p-3 sm:p-4 border-b border-slate-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2">
                    <div>
                        <h3 class="text-base sm:text-lg font-semibold text-slate-700">Disqualification Records</h3>
                        <p id="selectedStudentName" class="text-xs sm:text-sm text-slate-500">Select a student to view records</p>
                    </div>
                    <div class="flex items-center gap-2 sm:gap-4 w-full sm:w-auto">
                        <div id="disqualificationCountContainer" class="text-right hidden">
                            <p class="text-xs text-slate-500">Total Records</p>
                            <p id="disqualificationCount" class="text-lg font-bold text-red-600">0</p>
                        </div>
                        <button type="button" id="createDisqualificationBtn" onclick="showCreateModal()" disabled
                                class="flex-1 sm:flex-none px-3 sm:px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center justify-center disabled:opacity-50 disabled:cursor-not-allowed text-sm">
                            <i class="material-icons mr-1 sm:mr-2 text-sm">add_circle</i>
                            <span class="hidden sm:inline">Add</span> Disqualification
                        </button>
                    </div>
                </div>

                <div class="flex-1 overflow-y-auto p-3 sm:p-4 max-h-[50vh] lg:max-h-none">
                    <div id="disqualificationsContainer">
                        <div class="text-center py-6 sm:py-8 text-slate-500">
                            <i class="material-icons text-4xl sm:text-6xl mb-2 text-slate-300">gavel</i>
                            <p class="text-base sm:text-lg">No student selected</p>
                            <p class="text-xs sm:text-sm">Select a student from the left to view disqualification records</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loading Indicator -->
<div id="loadingIndicator" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-lg p-6 flex items-center space-x-4">
        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-red-600"></div>
        <span class="text-slate-700">Loading...</span>
    </div>
</div>

<!-- Create/Edit Disqualification Modal -->
<div id="disqualificationModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-3/4 lg:w-2/3 z-10 overflow-hidden max-h-[90vh] overflow-y-auto">
        <div class="px-6 py-4 bg-red-600 text-white sticky top-0">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2" id="modalIcon">add_circle</i>
                <span id="modalTitle">Add Disqualification Record</span>
            </h3>
        </div>
        <form id="disqualificationForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="disqualificationId" />
            <input type="hidden" id="studentId" name="StudentId" />

            <div class="px-6 py-4">
                <!-- Student Info Display -->
                <div class="mb-6 p-4 bg-slate-50 rounded-lg">
                    <h4 class="text-sm font-semibold text-slate-600 mb-2">Student Information</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <p class="text-xs text-slate-500">Student ID</p>
                            <p id="modalStudentId" class="font-medium text-slate-800">-</p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-500">Student Name</p>
                            <p id="modalStudentName" class="font-medium text-slate-800">-</p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-500">Programme</p>
                            <p id="modalProgrammeName" class="font-medium text-slate-800">-</p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-500">Current Year</p>
                            <p id="modalCurrentYear" class="font-medium text-slate-800">-</p>
                        </div>
                    </div>
                </div>

                <!-- Academic Year and Semester Selection -->
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="relative z-0 w-full group">
                        <select required name="AcademicYearId" id="academicYearId" onchange="loadStudentCourses()"
                                class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer">
                            <option value="">Select Academic Year</option>
                            @if (ViewBag.AcademicYears != null)
                            {
                                foreach (var item in ViewBag.AcademicYears)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                        <label for="academicYearId"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Academic Year *
                        </label>
                    </div>

                    <div class="relative z-0 w-full group">
                        <select required name="Semester" id="semester" onchange="loadStudentCourses()"
                                class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer">
                            <option value="">Select Semester</option>
                            <option value="1">Semester 1</option>
                            <option value="2">Semester 2</option>
                        </select>
                        <label for="semester"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Semester *
                        </label>
                    </div>
                </div>

                <!-- Course Selection Section -->
                <div class="mb-6">
                    <h4 class="text-md font-semibold text-slate-700 mb-3">Select Course</h4>
                    <div id="coursesLoadingIndicator" class="hidden text-center py-4 text-slate-500">
                        <i class="material-icons animate-spin">refresh</i>
                        <p class="text-sm">Loading courses...</p>
                    </div>
                    <div id="coursesContainer" class="border border-slate-200 rounded-lg max-h-48 overflow-y-auto">
                        <div class="text-center py-8 text-slate-500">
                            <i class="material-icons text-4xl mb-2 text-slate-300">school</i>
                            <p class="text-sm">Select academic year and semester to load courses</p>
                        </div>
                    </div>
                </div>

                <!-- Selected Course Info (Auto-filled) -->
                <div id="selectedCourseInfo" class="mb-6 p-4 bg-blue-50 rounded-lg hidden">
                    <h4 class="text-sm font-semibold text-blue-800 mb-2">Selected Course</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <p class="text-xs text-blue-600">Course Code</p>
                            <p id="selectedCourseCode" class="font-bold text-blue-900">-</p>
                        </div>
                        <div>
                            <p class="text-xs text-blue-600">Course Name</p>
                            <p id="selectedCourseName" class="font-bold text-blue-900">-</p>
                        </div>
                    </div>
                    <input type="hidden" id="courseId" name="CourseId" />
                </div>

                <!-- Disqualification Details -->
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="relative z-0 w-full group">
                        <select required name="DisqualificationType" id="disqualificationType"
                                class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer">
                            @if (ViewBag.DisqualificationTypes != null)
                            {
                                foreach (var item in ViewBag.DisqualificationTypes)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                        <label for="disqualificationType"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Disqualification Type *
                        </label>
                    </div>

                    <div class="relative z-0 w-full group">
                        <input type="date" required name="IncidentDate" id="incidentDate"
                               class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                               placeholder=" " />
                        <label for="incidentDate"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Incident Date *
                        </label>
                    </div>

                    <div class="relative z-0 w-full group">
                        <input type="date" required name="DisqualificationDate" id="disqualificationDate"
                               class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                               placeholder=" " />
                        <label for="disqualificationDate"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Disqualification Date *
                        </label>
                    </div>

                    <div class="relative z-0 w-full group">
                        <input type="text" name="EvidenceReference" id="evidenceReference"
                               class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                               placeholder=" " />
                        <label for="evidenceReference"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Evidence Reference (Document/File Reference)
                        </label>
                    </div>
                </div>

                <!-- Description -->
                <div class="mb-6">
                    <label for="description" class="block text-sm font-medium text-gray-700 mb-2">
                        Description of Incident *
                    </label>
                    <textarea required name="Description" id="description" rows="4"
                              class="block w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-red-500 focus:border-red-500"
                              placeholder="Provide detailed description of the malpractice incident..."></textarea>
                </div>

                <!-- Penalty Details -->
                <div class="mb-6 p-4 bg-orange-50 rounded-lg border border-orange-200">
                    <h4 class="text-md font-semibold text-orange-800 mb-3">Penalty Details</h4>
                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div class="relative z-0 w-full group">
                            <textarea name="PenaltyDescription" id="penaltyDescription" rows="2"
                                      class="block w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-orange-500 focus:border-orange-500"
                                      placeholder="Describe the penalty imposed..."></textarea>
                        </div>

                        <div>
                            <div class="relative z-0 w-full group">
                                <input type="number" name="PenaltyDurationSemesters" id="penaltyDurationSemesters" min="0" max="10"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-orange-600 peer"
                                       placeholder=" " />
                                <label for="penaltyDurationSemesters"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-orange-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Penalty Duration (Semesters)
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Penalty Type Checkboxes -->
                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div class="flex items-center">
                            <input type="checkbox" name="IsBannedFromCourse" id="isBannedFromCourse" value="true"
                                   onchange="toggleSuspensionFields()"
                                   class="w-4 h-4 text-orange-600 bg-gray-100 border-gray-300 rounded focus:ring-orange-500 focus:ring-2" />
                            <label for="isBannedFromCourse" class="ml-2 text-sm font-medium text-gray-700">
                                Banned from Course
                            </label>
                        </div>

                        <div class="flex items-center">
                            <input type="checkbox" name="IsSuspended" id="isSuspended" value="true"
                                   onchange="toggleSuspensionFields()"
                                   class="w-4 h-4 text-orange-600 bg-gray-100 border-gray-300 rounded focus:ring-orange-500 focus:ring-2" />
                            <label for="isSuspended" class="ml-2 text-sm font-medium text-gray-700">
                                Suspended from Institution
                            </label>
                        </div>
                    </div>

                    <!-- Years Suspended (shown only when Is Suspended is checked and Is Banned is not checked) -->
                    <div id="yearsSuspendedContainer" class="hidden">
                        <div class="p-3 bg-red-50 rounded-lg border border-red-200">
                            <div class="relative z-0 w-full group">
                                <input type="number" name="YearsSuspended" id="yearsSuspended" min="1" max="10" value="2"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                                       placeholder=" " />
                                <label for="yearsSuspended"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Number of Years Suspended *
                                </label>
                            </div>
                            <p class="text-xs text-red-600 mt-1">
                                <i class="material-icons text-xs align-middle">warning</i>
                                Student will be suspended from the institution for this duration
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Status (for editing) -->
                <div id="statusSection" class="hidden mb-6">
                    <div class="relative z-0 w-full group">
                        <select name="Status" id="status"
                                class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer">
                            @if (ViewBag.Statuses != null)
                            {
                                foreach (var item in ViewBag.Statuses)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                        <label for="status"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Status
                        </label>
                    </div>
                </div>
            </div>

            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2 sticky bottom-0">
                <button type="button" onclick="hideModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                    Save Record
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideDeleteModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-full md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 bg-red-600 text-white">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2">warning</i>
                Confirm Delete
            </h3>
        </div>
        <form id="deleteForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteDisqualificationId" />
            <div class="px-6 py-4">
                <p class="text-slate-700 mb-4">
                    Are you sure you want to delete this disqualification record for
                    <strong id="deleteCourseName"></strong>?
                </p>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
                <button type="button" onclick="hideDeleteModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                    Delete Record
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        let totalPages = 1;
        let currentSearchTerm = '';
        let selectedStudentId = null;
        let selectedStudent = null;
        let studentCourses = [];

        // Load statistics on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadStatistics();
        });

        // Toggle suspension fields visibility
        function toggleSuspensionFields() {
            const isBanned = document.getElementById('isBannedFromCourse').checked;
            const isSuspended = document.getElementById('isSuspended').checked;
            const yearsSuspendedContainer = document.getElementById('yearsSuspendedContainer');

            // Show years suspended only if suspended is checked AND banned is NOT checked
            if (isSuspended && !isBanned) {
                yearsSuspendedContainer.classList.remove('hidden');
            } else {
                yearsSuspendedContainer.classList.add('hidden');
            }
        }

        // Load statistics
        async function loadStatistics() {
            const academicYearId = document.getElementById('filterAcademicYear').value;
            const semester = document.getElementById('filterSemester').value;
            const status = document.getElementById('filterStatus').value;

            try {
                let url = '/Disqualification/GetStatistics?';
                if (academicYearId) url += `academicYearId=${academicYearId}&`;
                if (semester) url += `semester=${semester}&`;
                if (status) url += `status=${status}`;

                const response = await fetch(url);
                const result = await response.json();

                if (result.success) {
                    document.getElementById('statTotal').textContent = result.data.total;
                    document.getElementById('statPending').textContent = result.data.pending;
                    document.getElementById('statConfirmed').textContent = result.data.confirmed;
                    document.getElementById('statAppealed').textContent = result.data.appealed;
                    document.getElementById('statOverturned').textContent = result.data.overturned;
                    document.getElementById('statCompleted').textContent = result.data.completed;
                }
            } catch (error) {
                console.error('Error loading statistics:', error);
            }
        }

        // Search students
        async function searchStudents(page = 1) {
            const searchTerm = document.getElementById('studentSearch').value.trim();
            currentSearchTerm = searchTerm;
            currentPage = page;

            if (!searchTerm) {
                showNotification('Please enter a search term', 'error');
                return;
            }

            showLoading(true);

            try {
                const response = await fetch(`/Disqualification/SearchStudents?searchTerm=${encodeURIComponent(searchTerm)}&pageNumber=${page}&pageSize=20`);
                const result = await response.json();

                if (result.success) {
                    displayStudents(result.data);
                    updatePagination(result);
                } else {
                    showNotification(result.message, 'error');
                }
            } catch (error) {
                console.error('Error searching students:', error);
                showNotification('Error searching students', 'error');
            } finally {
                showLoading(false);
            }
        }

        // Display students
        function displayStudents(students) {
            const container = document.getElementById('studentsContainer');

            if (!students || students.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-8 text-slate-500">
                        <i class="material-icons text-6xl mb-2 text-slate-300">search_off</i>
                        <p class="text-lg">No students found</p>
                        <p class="text-sm">Try a different search term</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = students.map(student => `
                <div class="p-4 border border-slate-200 rounded-lg hover:bg-slate-50 cursor-pointer transition-colors ${selectedStudentId === student.id ? 'bg-red-50 border-red-300' : ''}"
                     onclick='selectStudent(${JSON.stringify(student).replace(/'/g, "&#39;")})'>
                    <div class="flex justify-between items-start">
                        <div class="flex-1">
                            <h4 class="font-semibold text-slate-800">${student.fullName}</h4>
                            <p class="text-sm text-slate-600">${student.studentId_Number}</p>
                            <p class="text-xs text-slate-500 mt-1">
                                <i class="material-icons text-xs align-middle">school</i>
                                ${student.programmeName}
                            </p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-slate-500">Year ${student.studentCurrentYear || 1}</p>
                            <p class="text-sm font-medium text-slate-700">Sem ${student.currentSemester || 1}</p>
                        </div>
                    </div>
                    <div class="mt-2 pt-2 border-t border-slate-100 text-xs text-slate-600">
                        <span><i class="material-icons text-xs align-middle">email</i> ${student.email}</span>
                    </div>
                </div>
            `).join('');
        }

        // Update pagination
        function updatePagination(result) {
            const container = document.getElementById('paginationContainer');
            const info = document.getElementById('paginationInfo');
            const prevBtn = document.getElementById('prevPageBtn');
            const nextBtn = document.getElementById('nextPageBtn');

            totalPages = result.totalPages;

            if (result.totalCount > 0) {
                container.classList.remove('hidden');
                info.textContent = `Showing ${((result.pageNumber - 1) * result.pageSize) + 1} to ${Math.min(result.pageNumber * result.pageSize, result.totalCount)} of ${result.totalCount} students`;
                prevBtn.disabled = result.pageNumber <= 1;
                nextBtn.disabled = result.pageNumber >= result.totalPages;
            } else {
                container.classList.add('hidden');
            }
        }

        // Pagination functions
        function previousPage() {
            if (currentPage > 1) {
                searchStudents(currentPage - 1);
            }
        }

        function nextPage() {
            if (currentPage < totalPages) {
                searchStudents(currentPage + 1);
            }
        }

        // Select student
        async function selectStudent(studentData) {
            selectedStudentId = studentData.id;
            selectedStudent = studentData;
            document.getElementById('selectedStudentName').textContent = `${studentData.fullName} (${studentData.studentId_Number})`;
            document.getElementById('createDisqualificationBtn').disabled = false;

            // Show disqualification count container
            document.getElementById('disqualificationCountContainer').classList.remove('hidden');

            // Reload student list to show selection
            if (currentSearchTerm) {
                await searchStudents(currentPage);
            }

            await loadStudentDisqualifications(studentData.id);
        }

        // Load student disqualifications
        async function loadStudentDisqualifications(studentId) {
            showLoading(true);

            try {
                const response = await fetch(`/Disqualification/GetStudentDisqualifications?studentId=${studentId}`);
                const result = await response.json();

                if (result.success) {
                    displayDisqualifications(result.data);
                    document.getElementById('disqualificationCount').textContent = result.data.length;
                } else {
                    showNotification(result.message, 'error');
                }
            } catch (error) {
                console.error('Error loading disqualifications:', error);
                showNotification('Error loading disqualification records', 'error');
            } finally {
                showLoading(false);
            }
        }

        // Display disqualifications
        function displayDisqualifications(disqualifications) {
            const container = document.getElementById('disqualificationsContainer');

            if (!disqualifications || disqualifications.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-8 text-slate-500">
                        <i class="material-icons text-6xl mb-2 text-green-300">check_circle</i>
                        <p class="text-lg">No disqualification records</p>
                        <p class="text-sm">This student has no malpractice records</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = disqualifications.map(d => `
                <div class="p-4 border border-slate-200 rounded-lg hover:shadow-md transition-shadow mb-3 ${d.status === 'Confirmed' ? 'border-l-4 border-l-red-500' : d.status === 'Overturned' ? 'border-l-4 border-l-green-500' : 'border-l-4 border-l-yellow-500'}">
                    <div class="flex justify-between items-start mb-2">
                        <div>
                            <h4 class="font-semibold text-slate-800">${d.courseCode} - ${d.courseName}</h4>
                            <p class="text-xs text-slate-500">${d.disqualificationType}</p>
                        </div>
                        <span class="px-2 py-1 rounded-full text-xs ${getStatusClass(d.status)}">
                            ${d.status}
                        </span>
                    </div>
                    <p class="text-sm text-slate-600 mb-3 line-clamp-2">${d.description}</p>
                    <div class="grid grid-cols-3 gap-2 text-sm mb-3">
                        <div>
                            <p class="text-xs text-slate-500">Academic Year</p>
                            <p class="font-medium">${d.academicYear}</p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-500">Semester</p>
                            <p class="font-medium">${d.semester}</p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-500">Incident Date</p>
                            <p class="font-medium">${new Date(d.incidentDate).toLocaleDateString()}</p>
                        </div>
                    </div>
                    <div class="flex gap-2 text-xs mb-3 flex-wrap">
                        ${d.isBannedFromCourse ? `<span class="px-2 py-1 bg-orange-100 text-orange-800 rounded">Banned from Course</span>` : ''}
                        ${d.isSuspended ? `<span class="px-2 py-1 bg-red-100 text-red-800 rounded">Suspended (${d.yearsSuspended} years)</span>` : ''}
                        ${d.appealStatus ? `<span class="px-2 py-1 bg-blue-100 text-blue-800 rounded">Appeal: ${d.appealStatus}</span>` : ''}
                    </div>
                    <div class="flex gap-2 pt-2 border-t border-slate-100">
                        <button type="button" onclick="editDisqualification(${d.id})"
                                class="flex-1 px-3 py-1 bg-blue-600 text-white text-sm rounded hover:bg-blue-700 transition-colors flex items-center justify-center">
                            <i class="material-icons text-sm mr-1">edit</i>
                            Edit
                        </button>
                        ${d.status === 'Pending' ? `
                        <button type="button" onclick="confirmDisqualification(${d.id})"
                                class="flex-1 px-3 py-1 bg-green-600 text-white text-sm rounded hover:bg-green-700 transition-colors flex items-center justify-center">
                            <i class="material-icons text-sm mr-1">check</i>
                            Confirm
                        </button>
                        ` : ''}
                        <button type="button" onclick="deleteDisqualification(${d.id}, '${d.courseCode} - ${d.courseName}')"
                                class="flex-1 px-3 py-1 bg-red-600 text-white text-sm rounded hover:bg-red-700 transition-colors flex items-center justify-center">
                            <i class="material-icons text-sm mr-1">delete</i>
                            Delete
                        </button>
                    </div>
                </div>
            `).join('');
        }

        // Get status badge class
        function getStatusClass(status) {
            const statusClasses = {
                'Pending': 'bg-yellow-100 text-yellow-800',
                'Confirmed': 'bg-red-100 text-red-800',
                'Appealed': 'bg-blue-100 text-blue-800',
                'Overturned': 'bg-green-100 text-green-800',
                'Completed': 'bg-slate-100 text-slate-800'
            };
            return statusClasses[status] || 'bg-slate-100 text-slate-800';
        }

        // Show create modal
        function showCreateModal() {
            if (!selectedStudentId || !selectedStudent) {
                showNotification('Please select a student first', 'error');
                return;
            }

            document.getElementById('modalTitle').textContent = 'Add Disqualification Record';
            document.getElementById('modalIcon').textContent = 'add_circle';
            document.getElementById('disqualificationForm').reset();
            document.getElementById('disqualificationId').value = '';
            document.getElementById('studentId').value = selectedStudentId;
            document.getElementById('statusSection').classList.add('hidden');

            // Fill student info
            document.getElementById('modalStudentId').textContent = selectedStudent.studentId_Number;
            document.getElementById('modalStudentName').textContent = selectedStudent.fullName;
            document.getElementById('modalProgrammeName').textContent = selectedStudent.programmeName;
            document.getElementById('modalCurrentYear').textContent = `Year ${selectedStudent.studentCurrentYear || 1}`;

            // Set defaults
            if (selectedStudent.academicYearId) {
                document.getElementById('academicYearId').value = selectedStudent.academicYearId;
            }
            if (selectedStudent.currentSemester) {
                document.getElementById('semester').value = selectedStudent.currentSemester;
            }

            // Set today's date
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('incidentDate').value = today;
            document.getElementById('disqualificationDate').value = today;

            // Hide selected course info
            document.getElementById('selectedCourseInfo').classList.add('hidden');
            document.getElementById('courseId').value = '';

            // Reset checkboxes and hide years suspended
            document.getElementById('isBannedFromCourse').checked = false;
            document.getElementById('isSuspended').checked = false;
            document.getElementById('yearsSuspended').value = 2;
            document.getElementById('yearsSuspendedContainer').classList.add('hidden');

            // Reset courses container
            document.getElementById('coursesContainer').innerHTML = `
                <div class="text-center py-8 text-slate-500">
                    <i class="material-icons text-4xl mb-2 text-slate-300">school</i>
                    <p class="text-sm">Select academic year and semester to load courses</p>
                </div>
            `;

            document.getElementById('disqualificationModal').classList.remove('hidden');

            // Load courses if academic year and semester are set
            if (selectedStudent.academicYearId && selectedStudent.currentSemester) {
                loadStudentCourses();
            }
        }

        // Load student courses
        async function loadStudentCourses() {
            if (!selectedStudentId) return;

            const academicYearId = document.getElementById('academicYearId').value;
            const semester = document.getElementById('semester').value;

            if (!academicYearId || !semester) {
                document.getElementById('coursesContainer').innerHTML = `
                    <div class="text-center py-8 text-slate-500">
                        <i class="material-icons text-4xl mb-2 text-slate-300">school</i>
                        <p class="text-sm">Select academic year and semester to load courses</p>
                    </div>
                `;
                return;
            }

            document.getElementById('coursesLoadingIndicator').classList.remove('hidden');
            document.getElementById('coursesContainer').innerHTML = '';

            try {
                const response = await fetch(`/Disqualification/GetStudentCourses?studentId=${selectedStudentId}&academicYearId=${academicYearId}&semester=${semester}`);
                const result = await response.json();

                if (result.success) {
                    studentCourses = result.data;
                    displayCourses(result.data, result.source);
                } else {
                    showNotification(result.message, 'error');
                    displayCourses([], null);
                }
            } catch (error) {
                console.error('Error loading courses:', error);
                showNotification('Error loading courses', 'error');
                displayCourses([], null);
            } finally {
                document.getElementById('coursesLoadingIndicator').classList.add('hidden');
            }
        }

        // Display courses
        function displayCourses(courses, source) {
            const container = document.getElementById('coursesContainer');

            if (!courses || courses.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-8 text-slate-500">
                        <i class="material-icons text-4xl mb-2 text-slate-300">school</i>
                        <p class="text-sm">No courses found for this student</p>
                    </div>
                `;
                return;
            }

            const sourceNote = source === 'programme' ?
                '<p class="text-xs text-amber-600 p-2 bg-amber-50 border-b border-amber-200"><i class="material-icons text-xs align-middle">info</i> Showing programme courses (no registered courses found)</p>' : '';

            container.innerHTML = sourceNote + courses.map(course => `
                <div class="p-3 border-b border-slate-100 hover:bg-slate-50 transition-colors cursor-pointer"
                     onclick="selectCourse(${JSON.stringify(course).replace(/"/g, '&quot;')})">
                    <label class="flex items-start cursor-pointer">
                        <input type="radio" name="courseSelection"
                               class="course-radio mt-1 mr-3 h-4 w-4 text-red-600 border-gray-300 focus:ring-red-500"
                               data-course-id="${course.id}"
                               data-course-code="${course.courseCode}"
                               data-course-name="${course.courseName}" />
                        <div class="flex-1">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="font-semibold text-slate-800">${course.courseCode}</p>
                                    <p class="text-sm text-slate-600">${course.courseName}</p>
                                </div>
                                <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded">
                                    ${course.courseType || 'Course'}
                                </span>
                            </div>
                            <p class="text-xs text-slate-500 mt-1">Year ${course.yearTaken} | Semester ${course.semesterTaken}</p>
                        </div>
                    </label>
                </div>
            `).join('');
        }

        // Select course
        function selectCourse(course) {
            // Check the radio button
            const radios = document.querySelectorAll('.course-radio');
            radios.forEach(radio => {
                if (radio.dataset.courseId == course.id) {
                    radio.checked = true;
                }
            });

            // Update selected course info
            document.getElementById('selectedCourseInfo').classList.remove('hidden');
            document.getElementById('selectedCourseCode').textContent = course.courseCode;
            document.getElementById('selectedCourseName').textContent = course.courseName;
            document.getElementById('courseId').value = course.id;
        }

        // Edit disqualification
        async function editDisqualification(id) {
            showLoading(true);

            try {
                const response = await fetch(`/Disqualification/GetDisqualification?id=${id}`);
                const result = await response.json();

                if (result.success) {
                    const d = result.data;

                    document.getElementById('modalTitle').textContent = 'Edit Disqualification Record';
                    document.getElementById('modalIcon').textContent = 'edit';
                    document.getElementById('disqualificationId').value = d.id;
                    document.getElementById('studentId').value = d.studentId;
                    document.getElementById('statusSection').classList.remove('hidden');

                    // Fill student info
                    document.getElementById('modalStudentId').textContent = selectedStudent?.studentId_Number || '-';
                    document.getElementById('modalStudentName').textContent = selectedStudent?.fullName || '-';
                    document.getElementById('modalProgrammeName').textContent = selectedStudent?.programmeName || '-';
                    document.getElementById('modalCurrentYear').textContent = `Year ${selectedStudent?.studentCurrentYear || 1}`;

                    // Fill form fields
                    document.getElementById('academicYearId').value = d.academicYearId;
                    document.getElementById('semester').value = d.semester;
                    document.getElementById('disqualificationType').value = d.disqualificationType;
                    document.getElementById('incidentDate').value = d.incidentDate?.split('T')[0] || '';
                    document.getElementById('disqualificationDate').value = d.disqualificationDate?.split('T')[0] || '';
                    document.getElementById('evidenceReference').value = d.evidenceReference || '';
                    document.getElementById('description').value = d.description || '';
                    document.getElementById('penaltyDescription').value = d.penaltyDescription || '';
                    document.getElementById('penaltyDurationSemesters').value = d.penaltyDurationSemesters || '';
                    document.getElementById('status').value = d.status;

                    // Set checkbox values
                    document.getElementById('isBannedFromCourse').checked = d.isBannedFromCourse || false;
                    document.getElementById('isSuspended').checked = d.isSuspended || false;
                    document.getElementById('yearsSuspended').value = d.yearsSuspended || 2;

                    // Trigger the toggle to show/hide years suspended field
                    toggleSuspensionFields();

                    // Show selected course
                    document.getElementById('selectedCourseInfo').classList.remove('hidden');
                    document.getElementById('selectedCourseCode').textContent = d.courseCode;
                    document.getElementById('selectedCourseName').textContent = d.courseName;
                    document.getElementById('courseId').value = d.courseId;

                    document.getElementById('disqualificationModal').classList.remove('hidden');

                    // Load courses
                    await loadStudentCourses();

                    // Select the course radio
                    setTimeout(() => {
                        const radios = document.querySelectorAll('.course-radio');
                        radios.forEach(radio => {
                            if (radio.dataset.courseId == d.courseId) {
                                radio.checked = true;
                            }
                        });
                    }, 500);
                } else {
                    showNotification(result.message, 'error');
                }
            } catch (error) {
                console.error('Error loading disqualification:', error);
                showNotification('Error loading disqualification record', 'error');
            } finally {
                showLoading(false);
            }
        }

        // Hide modal
        function hideModal() {
            document.getElementById('disqualificationModal').classList.add('hidden');
        }

        // Confirm disqualification
        async function confirmDisqualification(id) {
            if (!await window.showAppConfirm('Are you sure you want to confirm this disqualification?', {
                title: 'Confirm Disqualification',
                icon: 'warning',
                confirmButtonText: 'Confirm'
            })) return;

            showLoading(true);

            try {
                const formData = new FormData();
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                const response = await fetch(`/Disqualification/ConfirmDisqualification?id=${id}`, {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    showNotification(result.message, 'success');
                    await loadStudentDisqualifications(selectedStudentId);
                    await loadStatistics();
                } else {
                    showNotification(result.message, 'error');
                }
            } catch (error) {
                console.error('Error confirming disqualification:', error);
                showNotification('Error confirming disqualification', 'error');
            } finally {
                showLoading(false);
            }
        }

        // Delete disqualification
        function deleteDisqualification(id, courseName) {
            document.getElementById('deleteDisqualificationId').value = id;
            document.getElementById('deleteCourseName').textContent = courseName;
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        // Hide delete modal
        function hideDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        // Submit form
        document.getElementById('disqualificationForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const courseId = document.getElementById('courseId').value;
            if (!courseId) {
                showNotification('Please select a course', 'error');
                return;
            }

            const formData = new FormData(e.target);
            const disqualificationId = document.getElementById('disqualificationId').value;
            const url = disqualificationId ?
                `/Disqualification/UpdateDisqualification?id=${disqualificationId}` :
                '/Disqualification/CreateDisqualification';

            showLoading(true);

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    showNotification(result.message, 'success');
                    hideModal();
                    await loadStudentDisqualifications(selectedStudentId);
                    await loadStatistics();
                } else {
                    showNotification(result.message, 'error');
                }
            } catch (error) {
                console.error('Error saving disqualification:', error);
                showNotification('Error saving disqualification record', 'error');
            } finally {
                showLoading(false);
            }
        });

        // Submit delete form
        document.getElementById('deleteForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const id = document.getElementById('deleteDisqualificationId').value;
            const formData = new FormData(e.target);

            showLoading(true);

            try {
                const response = await fetch(`/Disqualification/DeleteDisqualification?id=${id}`, {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    showNotification(result.message, 'success');
                    hideDeleteModal();
                    await loadStudentDisqualifications(selectedStudentId);
                    await loadStatistics();
                } else {
                    showNotification(result.message, 'error');
                }
            } catch (error) {
                console.error('Error deleting disqualification:', error);
                showNotification('Error deleting disqualification record', 'error');
            } finally {
                showLoading(false);
            }
        });

        // Show loading indicator
        function showLoading(show) {
            document.getElementById('loadingIndicator').style.display = show ? 'flex' : 'none';
        }

        // Show notification
        function showNotification(message, type = 'success') {
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 z-50 px-6 py-4 rounded-lg shadow-lg transition-all transform ${
                type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
            }`;
            notification.innerHTML = `
                <div class="flex items-center space-x-2">
                    <i class="material-icons">${type === 'success' ? 'check_circle' : 'error'}</i>
                    <span>${message}</span>
                </div>
            `;
            document.body.appendChild(notification);

            setTimeout(() => {
                notification.style.transform = 'translateX(400px)';
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }

        // Enter key to search
        document.getElementById('studentSearch').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                searchStudents();
            }
        });

        // Close modals on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                hideModal();
                hideDeleteModal();
            }
        });
    </script>
}
