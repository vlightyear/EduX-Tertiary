@model IEnumerable<SIS.Models.StudentAccommodation.ResourceType>
@{
    ViewData["Title"] = "Resource Type Management";
}

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">inventory_2</i>
            Accommodation Resource Type Management
        </h1>
        <button type="button"
                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center"
                onclick="openCreateModal()">
            <i class="material-icons mr-2">add</i>
            Create Resource Type
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <div class="w-full">
            <div class="bg-white rounded-lg shadow-md h-full overflow-auto">
                <div class="p-4">
                    <table id="resourceTypeTable" class="w-full text-sm text-secondary-600">
                        <thead>
                            <tr>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Name
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Description
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Usage
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int counter = 1;
                                foreach (var item in Model)
                                {
                                    <tr class="border-b hover:bg-gray-50 transition-colors">
                                        <td class="px-6 py-4 text-gray-400">@counter</td>
                                        <td class="px-6 py-4 font-medium text-slate-600">@item.Name</td>
                                        <td class="px-6 py-4">
                                            @if (!string.IsNullOrEmpty(item.Description))
                                            {
                                                @item.Description
                                            }
                                            else
                                            {
                                                <span class="text-gray-400 italic">No description provided</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (item.RoomResources.Any())
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                                    <i class="material-icons text-xs mr-1">meeting_room</i>
                                                    @item.RoomResources.Count room(s)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                                    <i class="material-icons text-xs mr-1">remove_circle_outline</i>
                                                    Not in use
                                                </span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex space-x-2">
                                                <button onclick="openEditModal(@item.ResourceTypeId)"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">edit</i> Edit
                                                </button>
                                                <button onclick="deleteResourceType(@item.ResourceTypeId)"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">delete</i> Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="px-6 py-4 text-center text-gray-500">No resource types found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Resource Type Modal -->
<div id="createResourceTypeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New Resource Type
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" onclick="closeModal('createResourceTypeModal')">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <div class="space-y-6">
                        <!-- Name -->
                        <div class="relative z-0 w-full group">
                            <input type="text" id="createName"
                                   class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                   placeholder=" " />
                            <label for="createName"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Resource Type Name
                            </label>
                        </div>

                        <!-- Description -->
                        <div class="relative z-0 w-full group">
                            <textarea id="createDescription" rows="3"
                                      class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                      placeholder=" "></textarea>
                            <label for="createDescription"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Description
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" onclick="closeModal('createResourceTypeModal')">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" onclick="saveResourceType(false)" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Resource Type Modal -->
<div id="updateResourceTypeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-gray-700 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">edit</i>
                        Update Resource Type
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" onclick="closeModal('updateResourceTypeModal')">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <input type="hidden" id="updateResourceTypeId" value="0" />
                    <div class="space-y-6">
                        <!-- Name -->
                        <div class="relative z-0 w-full group">
                            <input type="text" id="updateName"
                                   class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                   placeholder=" " />
                            <label for="updateName"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Resource Type Name
                            </label>
                        </div>

                        <!-- Description -->
                        <div class="relative z-0 w-full group">
                            <textarea id="updateDescription" rows="3"
                                      class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                      placeholder=" "></textarea>
                            <label for="updateDescription"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Description
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" onclick="closeModal('updateResourceTypeModal')">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" onclick="saveResourceType(true)" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Update
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Resource Type Modal -->
<div id="deleteResourceTypeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" onclick="closeModal('deleteResourceTypeModal')">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <input type="hidden" id="deleteResourceTypeId" value="0" />

                    <div class="space-y-4">
                        <div class="flex items-center text-red-600 mb-4">
                            <i class="material-icons mr-2">error_outline</i>
                            <p class="text-lg font-medium">Delete Resource Type</p>
                        </div>

                        <p class="text-gray-700">Are you sure you want to delete this resource type?</p>

                        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                            <p class="text-gray-700 font-medium mb-2">Resource Type Details:</p>
                            <p class="text-secondary-600">
                                <span class="font-medium">Name:</span>
                                <span id="deleteResourceTypeName" class="ml-2"></span>
                            </p>
                        </div>

                        <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                            <div class="flex items-center text-red-800">
                                <i class="material-icons text-red-600 mr-2 text-sm">info</i>
                                <p class="text-sm">This action cannot be undone. All associated data will be permanently deleted.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" onclick="closeModal('deleteResourceTypeModal')">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" onclick="confirmDelete()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function openModal(id) {
            document.getElementById(id).classList.remove('hidden');
        }

        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }

        function openCreateModal() {
            document.getElementById('createName').value = '';
            document.getElementById('createDescription').value = '';
            openModal('createResourceTypeModal');
        }

        function openEditModal(id) {
            fetch(`/ResourceType/Edit?id=${id}`)
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        document.getElementById('updateResourceTypeId').value = result.data.resourceTypeId;
                        document.getElementById('updateName').value = result.data.name;
                        document.getElementById('updateDescription').value = result.data.description || '';
                        openModal('updateResourceTypeModal');
                    } else {
                        Swal.fire('Error', result.message, 'error');
                    }
                })
                .catch(() => Swal.fire('Error', 'Failed to load resource type data', 'error'));
        }

        function saveResourceType(isUpdate) {
            const name = document.getElementById(isUpdate ? 'updateName' : 'createName').value.trim();
            const description = document.getElementById(isUpdate ? 'updateDescription' : 'createDescription').value.trim();
            const id = isUpdate ? document.getElementById('updateResourceTypeId').value : '0';

            if (!name) {
                Swal.fire('Validation Error', 'Please enter a resource type name', 'warning');
                return;
            }

            const url = isUpdate ? '/ResourceType/Update' : '/ResourceType/Create';

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ resourceTypeId: parseInt(id), name, description })
            })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    Swal.fire({ icon: 'success', title: 'Success', text: result.message, showConfirmButton: false, timer: 1500 })
                        .then(() => location.reload());
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            })
            .catch(() => Swal.fire('Error', 'An error occurred while saving', 'error'));
        }

        function deleteResourceType(id) {
            // Fetch the name from the table row to populate the modal
            const row = document.querySelector(`button[onclick="deleteResourceType(${id})"]`).closest('tr');
            const name = row.querySelector('td:nth-child(2)').textContent.trim();
            document.getElementById('deleteResourceTypeId').value = id;
            document.getElementById('deleteResourceTypeName').textContent = name;
            openModal('deleteResourceTypeModal');
        }

        function confirmDelete() {
            const id = document.getElementById('deleteResourceTypeId').value;
            fetch('/ResourceType/Delete?id=' + id, { method: 'POST' })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        Swal.fire({ icon: 'success', title: 'Deleted!', text: result.message, showConfirmButton: false, timer: 1500 })
                            .then(() => location.reload());
                    } else {
                        Swal.fire('Error', result.message, 'error');
                    }
                })
                .catch(() => Swal.fire('Error', 'An error occurred while deleting', 'error'));
        }

        document.addEventListener('keydown', e => { if (e.key === 'Escape') ['createResourceTypeModal', 'updateResourceTypeModal', 'deleteResourceTypeModal'].forEach(closeModal); });
    </script>
}
