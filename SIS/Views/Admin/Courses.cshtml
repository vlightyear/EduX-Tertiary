@{
    ViewData["Title"] = "Course Management";
}

<link rel="stylesheet" href="~/css/course-management.css" />

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">library_books</i>
            Course Management
        </h1>
        <button type="button"
                onclick="location.href='@Url.Action("CreateCourse", "Admin")'"
                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center">
            <i class="material-icons mr-2">add</i>
            Create Course
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <div class="w-full">
            <div class="bg-white rounded-lg shadow-md h-full overflow-auto">
                <div class="p-4">
                    <!-- Search and Filter Bar -->
                    <div class="mb-4 flex gap-4">
                        <div class="flex-1">
                            <input type="text" id="courseSearch" placeholder="Search courses..."
                                   class="min-w-[36] px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                        </div>
                        <select id="courseTypeFilter" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                            <option value="all">All Types</option>
                            <option value="Full Course">Full Course</option>
                            <option value="Half Course">Half Course</option>
                        </select>
                        <select id="yearFilter" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                            <option value="all">All Years</option>
                            @foreach (var year in ViewBag.YearTakenValues)
                            {
                                <option value="@year">Year @year</option>
                            }
                        </select>
                        <select id="programmeFilter" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                            <option value="all">All Programmes</option>
                            @foreach (var programme in ViewBag.Programmes)
                            {
                                <option value="@programme.Name">@programme.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Loading Indicator -->
                    <div id="loadingIndicator" class="hidden text-center py-8">
                        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
                        <p class="mt-2 text-secondary-600">Loading courses...</p>
                    </div>

                    <!-- Table -->
                    <div id="tableContainer">
                        <table id="courseTable" class="w-full text-sm text-secondary-600">
                            <thead>
                                <tr class="bg-gray-50 text-left border-b">
                                    <th class="px-6 py-4 cursor-pointer" data-sort="index">
                                        <span class="flex items-center">
                                            #
                                            <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                            </svg>
                                        </span>
                                    </th>
                                    <th class="px-6 py-4 cursor-pointer" data-sort="code">
                                        <span class="flex items-center">
                                            Course Code
                                            <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                            </svg>
                                        </span>
                                    </th>
                                    <th class="px-6 py-4 cursor-pointer" data-sort="name">
                                        <span class="flex items-center">
                                            Course Name
                                            <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                            </svg>
                                        </span>
                                    </th>
                                    <th class="px-6 py-4 cursor-pointer" data-sort="type">Course Type</th>
                                    <th class="px-6 py-4 cursor-pointer" data-sort="year">Year</th>
                                    <th class="px-6 py-4 cursor-pointer" data-sort="semester">Period</th>
                                    <th class="px-6 py-4 cursor-pointer" data-sort="mandatory">Mandatory</th>
                                    <th class="px-6 py-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="courseTableBody">
                                <!-- Data loaded via AJAX -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Enhanced Pagination -->
                    <div class="flex justify-between items-center mt-4">
                        <div class="text-sm text-gray-500">
                            Showing <span id="startRow">0</span> to <span id="endRow">0</span> of <span id="totalRows">0</span> entries
                        </div>
                        <div class="flex items-center space-x-2">
                            <button id="firstPage" class="px-3 py-1 text-sm text-secondary-600 hover:bg-gray-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">First</button>
                            <button id="prevPage" class="px-3 py-1 text-sm text-secondary-600 hover:bg-gray-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">Previous</button>
                            <div id="paginationButtons" class="flex space-x-1"></div>
                            <button id="nextPage" class="px-3 py-1 text-sm text-secondary-600 hover:bg-gray-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">Next</button>
                            <button id="lastPage" class="px-3 py-1 text-sm text-secondary-600 hover:bg-gray-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">Last</button>
                            <div class="ml-4 flex items-center space-x-2">
                                <span class="text-sm text-secondary-600">Show:</span>
                                <select id="pageSizeSelect" class="px-2 py-1 text-sm border border-gray-300 rounded">
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Course Modal -->
<div id="deleteCourseModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg">
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>
                <div class="p-6">
                    <form id="deleteCourseForm" method="post">
                        <input type="hidden" id="deleteCourseId" name="id" />
                        @Html.AntiForgeryToken()
                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-2">error_outline</i>
                                <p class="text-lg font-medium">Delete Course</p>
                            </div>
                            <p class="text-gray-700">Are you sure you want to delete this course? This action cannot be undone.</p>
                            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mt-4">
                                <p class="text-gray-700 font-medium mb-2">Course Details:</p>
                                <p class="text-secondary-600">
                                    <span class="font-medium">Course Code:</span>
                                    <span id="deleteCourseCode" class="ml-2"></span>
                                </p>
                                <p class="text-secondary-600">
                                    <span class="font-medium">Course Name:</span>
                                    <span id="deleteCourseName" class="ml-2"></span>
                                </p>
                            </div>
                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-sm">info</i>
                                    <p class="text-sm">This action cannot be undone. All associated data will be permanently deleted.</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmDelete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var config = {
                currentPage:    1,
                pageSize:       10,
                sortColumn:     'index',
                sortDirection:  'asc',
                searchTerm:     '',
                courseType:     'all',
                year:           'all',
                programme:      'all',
                totalPages:     1,
                debounceTimeout: null
            };

            var courseTableBody   = document.getElementById('courseTableBody');
            var courseSearch      = document.getElementById('courseSearch');
            var courseTypeFilter  = document.getElementById('courseTypeFilter');
            var yearFilter        = document.getElementById('yearFilter');
            var programmeFilter   = document.getElementById('programmeFilter');
            var pageSizeSelect    = document.getElementById('pageSizeSelect');
            var loadingIndicator  = document.getElementById('loadingIndicator');
            var tableContainer    = document.getElementById('tableContainer');
            var deleteCourseModal = document.getElementById('deleteCourseModal');
            var deleteCourseForm  = document.getElementById('deleteCourseForm');
            var confirmDeleteBtn  = document.getElementById('confirmDelete');
            var paginationButtons = document.getElementById('paginationButtons');
            var firstPageBtn      = document.getElementById('firstPage');
            var prevPageBtn       = document.getElementById('prevPage');
            var nextPageBtn       = document.getElementById('nextPage');
            var lastPageBtn       = document.getElementById('lastPage');
            var startRowElem      = document.getElementById('startRow');
            var endRowElem        = document.getElementById('endRow');
            var totalRowsElem     = document.getElementById('totalRows');

            // Init
            loadCourseData();
            loadStatistics();

            // Event listeners
            courseSearch.addEventListener('input', debounceSearch);
            courseTypeFilter.addEventListener('change', filterChanged);
            yearFilter.addEventListener('change', filterChanged);
            programmeFilter.addEventListener('change', filterChanged);
            pageSizeSelect.addEventListener('change', pageSizeChanged);

            document.querySelectorAll('th[data-sort]').forEach(function (th) {
                th.addEventListener('click', function () { sortChanged(th.getAttribute('data-sort')); });
            });

            firstPageBtn.addEventListener('click', function () { goToPage(1); });
            prevPageBtn.addEventListener('click',  function () { goToPage(config.currentPage - 1); });
            nextPageBtn.addEventListener('click',  function () { goToPage(config.currentPage + 1); });
            lastPageBtn.addEventListener('click',  function () { goToPage(config.totalPages); });

            function debounceSearch() {
                clearTimeout(config.debounceTimeout);
                config.debounceTimeout = setTimeout(function () {
                    config.searchTerm  = courseSearch.value;
                    config.currentPage = 1;
                    loadCourseData();
                }, 300);
            }

            function filterChanged() {
                config.courseType  = courseTypeFilter.value;
                config.year        = yearFilter.value;
                config.programme   = programmeFilter.value;
                config.currentPage = 1;
                loadCourseData();
            }

            function pageSizeChanged() {
                config.pageSize    = parseInt(pageSizeSelect.value);
                config.currentPage = 1;
                loadCourseData();
            }

            function sortChanged(column) {
                config.sortDirection = (config.sortColumn === column && config.sortDirection === 'asc') ? 'desc' : 'asc';
                config.sortColumn    = column;
                loadCourseData();
            }

            function goToPage(page) {
                if (page >= 1 && page <= config.totalPages) {
                    config.currentPage = page;
                    loadCourseData();
                }
            }

            window.goToPage = goToPage;

            // ── Load course data ──────────────────────────────────────────────────
            async function loadCourseData() {
                showLoading(true);
                try {
                    var response = await fetch('@Url.Action("GetCoursesData", "Admin")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value
                        },
                        body: JSON.stringify({
                            page:          config.currentPage,
                            pageSize:      config.pageSize,
                            searchTerm:    config.searchTerm,
                            courseType:    config.courseType,
                            year:          config.year,
                            programme:     config.programme,
                            sortColumn:    config.sortColumn,
                            sortDirection: config.sortDirection
                        })
                    });

                    if (!response.ok) throw new Error('Network response was not ok');
                    var data = await response.json();
                    if (data.success === false) throw new Error(data.message || 'Unknown error');

                    renderTable(data);
                    renderPagination(data);
                    updatePaginationInfo(data);
                    config.totalPages = data.totalPages;

                } catch (error) {
                    console.error('Error loading courses:', error);
                    courseTableBody.innerHTML = '<tr><td colspan="8" class="px-6 py-4 text-center text-red-500">Error loading courses: ' + error.message + '</td></tr>';
                } finally {
                    showLoading(false);
                }
            }

            // ── Render table ──────────────────────────────────────────────────────
            function renderTable(data) {
                if (!data.courses || data.courses.length === 0) {
                    courseTableBody.innerHTML = '<tr><td colspan="8" class="px-6 py-4 text-center text-gray-500">No courses found matching your criteria.</td></tr>';
                    return;
                }

                // Group by school → programme
                var grouped = {};
                data.courses.forEach(function (course) {
                    var school    = course.schoolName    || 'No School Assigned';
                    var programme = course.programmeName || 'No Programme Assigned';
                    if (!grouped[school]) grouped[school] = {};
                    if (!grouped[school][programme]) grouped[school][programme] = [];
                    grouped[school][programme].push(course);
                });

                var html = '';

                Object.keys(grouped).sort().forEach(function (schoolName) {
                    var programmes  = grouped[schoolName];
                    var schoolTotal = Object.values(programmes).reduce(function (s, rows) { return s + rows.length; }, 0);

                    html += '<tr class="bg-primary-50 border-b border-primary-200">'
                          + '<td colspan="8" class="px-6 py-3">'
                          + '<span class="flex items-center text-primary-700 font-semibold text-sm uppercase tracking-wide">'
                          + '<i class="material-icons text-primary-600 mr-2 text-base">account_balance</i>'
                          + schoolName
                          + '<span class="ml-2 px-2 py-0.5 bg-primary-100 text-primary-600 rounded-full text-xs font-medium">'
                          + schoolTotal + (schoolTotal === 1 ? ' course' : ' courses')
                          + '</span></span></td></tr>';

                    Object.keys(programmes).sort().forEach(function (programmeName) {
                        var courses = programmes[programmeName];

                        html += '<tr class="bg-gray-50 border-b border-gray-200">'
                              + '<td colspan="8" class="px-6 py-2 pl-10">'
                              + '<span class="flex items-center text-gray-600 font-medium text-xs uppercase tracking-wide">'
                              + '<i class="material-icons text-gray-400 mr-2 text-sm">school</i>'
                              + programmeName
                              + '<span class="ml-2 px-2 py-0.5 bg-gray-200 text-gray-500 rounded-full text-xs">'
                              + courses.length + (courses.length === 1 ? ' course' : ' courses')
                              + '</span></span></td></tr>';

                        courses.forEach(function (course) {
                            // ── Period label ──────────────────────────────────────────────
                            // course.periodTaken is the AcademicPeriod.PeriodName string
                            // e.g. "Semester 1", "Term 2", "Year" — set in GetCoursesData.
                            var periodLabel = course.periodTaken || '—';

                            var mandatoryBadge = course.isMandatory
                                ? '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary-100 text-secondary-800"><i class="material-icons text-sm mr-1">check_circle</i> Yes</span>'
                                : '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-secondary-800"><i class="material-icons text-sm mr-1">radio_button_unchecked</i> No</span>';

                            html += '<tr class="border-b hover:bg-gray-50 transition-colors">'
                                  + '<td class="px-6 py-4 text-gray-400">' + course.rowNumber + '</td>'
                                  + '<td class="px-6 py-4 font-medium text-gray-900">' + course.courseCode + '</td>'
                                  + '<td class="px-6 py-4">' + course.courseName + '</td>'
                                  + '<td class="px-6 py-4">' + course.courseType + '</td>'
                                  + '<td class="px-6 py-4">Year ' + course.yearTaken + '</td>'
                                  + '<td class="px-6 py-4">' + periodLabel + '</td>'
                                  + '<td class="px-6 py-4">' + mandatoryBadge + '</td>'
                                  + '<td class="px-6 py-4">'
                                  + '<div class="flex space-x-2">'
                                  + '<a href="@Url.Action("UpdateCourse", "Admin")/' + course.id + '" class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors"><i class="material-icons text-sm mr-1">edit</i> Edit</a>'
                                  + '<button onclick="showDeleteCourseModal(\'' + course.id + '\', \'' + course.courseCode + '\', \'' + course.courseName + '\')" class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors"><i class="material-icons text-sm mr-1">delete</i> Delete</button>'
                                  + '</div></td></tr>';
                        });
                    });
                });

                courseTableBody.innerHTML = html;
            }

            // ── Pagination ────────────────────────────────────────────────────────
            function renderPagination(data) {
                var totalPages  = data.totalPages;
                var currentPage = data.currentPage;

                if (totalPages <= 1) { paginationButtons.innerHTML = ''; updatePaginationButtonStates(data); return; }

                var buttons  = [];
                var maxVis   = 5;
                var start    = Math.max(1, currentPage - 2);
                var end      = Math.min(totalPages, currentPage + 2);

                if (totalPages <= maxVis) {
                    for (var i = 1; i <= totalPages; i++) buttons.push(mkBtn(i, i === currentPage));
                } else {
                    if (start > 1) { buttons.push(mkBtn(1, false)); if (start > 2) buttons.push('<span class="px-3 py-1 text-sm text-gray-500">...</span>'); }
                    for (var p = start; p <= end; p++) buttons.push(mkBtn(p, p === currentPage));
                    if (end < totalPages) { if (end < totalPages - 1) buttons.push('<span class="px-3 py-1 text-sm text-gray-500">...</span>'); buttons.push(mkBtn(totalPages, false)); }
                }

                paginationButtons.innerHTML = buttons.join('');
                updatePaginationButtonStates(data);
            }

            function mkBtn(n, active) {
                var cls = active ? 'bg-primary-100 text-primary-600' : 'text-secondary-600 hover:bg-gray-100';
                return '<button onclick="goToPage(' + n + ')" class="px-3 py-1 text-sm ' + cls + ' rounded-md transition-colors">' + n + '</button>';
            }

            function updatePaginationButtonStates(data) {
                firstPageBtn.disabled = data.currentPage === 1;
                prevPageBtn.disabled  = data.currentPage === 1;
                nextPageBtn.disabled  = data.currentPage === data.totalPages;
                lastPageBtn.disabled  = data.currentPage === data.totalPages;
            }

            function updatePaginationInfo(data) {
                var s = data.totalRecords === 0 ? 0 : (data.currentPage - 1) * data.pageSize + 1;
                var e = Math.min(data.currentPage * data.pageSize, data.totalRecords);
                startRowElem.textContent  = s;
                endRowElem.textContent    = e;
                totalRowsElem.textContent = data.totalRecords;
            }

            function showLoading(show) {
                if (show) { loadingIndicator.classList.remove('hidden'); tableContainer.style.opacity = '0.5'; }
                else       { loadingIndicator.classList.add('hidden');    tableContainer.style.opacity = '1'; }
            }

            // ── Statistics ────────────────────────────────────────────────────────
            async function loadStatistics() {
                try {
                    var res  = await fetch('@Url.Action("GetCourseStatistics", "Admin")');
                    if (!res.ok) throw new Error('Network error');
                    var data = await res.json();
                    if (data.success === false) throw new Error(data.message);
                    renderStatistics(data);
                    renderChart(data.courseDistribution);
                } catch (e) { console.error('Statistics error:', e); }
            }

            function renderStatistics(data) {
                var el = document.getElementById('statisticsContent');
                if (!el) return;
                el.innerHTML =
                    '<div class="flex items-center"><div class="p-3 bg-primary-100 rounded-lg"><i class="material-icons text-primary-600 text-xl">library_books</i></div><div class="ml-4"><p class="text-gray-500 text-sm">Total Courses</p><p class="text-xl font-semibold">' + data.totalCourses + '</p></div></div>' +
                    '<div class="flex items-center"><div class="p-3 bg-secondary-100 rounded-lg"><i class="material-icons text-secondary-600 text-xl">school</i></div><div class="ml-4"><p class="text-gray-500 text-sm">Full Courses</p><p class="text-xl font-semibold text-secondary-600">' + data.fullCourses + '</p></div></div>' +
                    '<div class="flex items-center"><div class="p-3 bg-purple-100 rounded-lg"><i class="material-icons text-purple-600 text-xl">verified</i></div><div class="ml-4"><p class="text-gray-500 text-sm">Mandatory Courses</p><p class="text-xl font-semibold text-purple-600">' + data.mandatoryCourses + '</p></div></div>';
            }

            function renderChart(dist) {
                if (typeof ApexCharts === 'undefined' || !dist || !dist.length) return;
                var el = document.querySelector('#courseDistributionChart');
                if (!el) return;
                new ApexCharts(el, {
                    series: dist.map(function (d) { return d.count; }),
                    chart: { type: 'donut', height: '100%' },
                    labels: dist.map(function (d) { return d.type; }),
                    colors: ['#0891b2', '#10b981', '#f59e0b', '#ef4444'],
                    plotOptions: { pie: { donut: { size: '70%', labels: { show: true, total: { show: true, label: 'Total', formatter: function (w) { return w.globals.seriesTotals.reduce(function (a, b) { return a + b; }, 0) + ' courses'; } } } } } },
                    legend: { show: false },
                    dataLabels: { enabled: false }
                }).render();
            }

            // ── Modal ─────────────────────────────────────────────────────────────
            function showModal(m) { m.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
            function hideModal(m) { m.classList.add('hidden');    document.body.style.overflow = 'auto'; }

            deleteCourseModal.addEventListener('click', function (e) { if (e.target === deleteCourseModal) hideModal(deleteCourseModal); });
            deleteCourseModal.querySelectorAll('[data-bs-dismiss="modal"]').forEach(function (b) { b.addEventListener('click', function () { hideModal(deleteCourseModal); }); });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') hideModal(deleteCourseModal); });

            window.showDeleteCourseModal = function (id, code, name) {
                document.getElementById('deleteCourseId').value        = id;
                document.getElementById('deleteCourseCode').textContent = code;
                document.getElementById('deleteCourseName').textContent = name;
                deleteCourseForm.action = '/Admin/DeleteCourse/' + id;
                showModal(deleteCourseModal);
            };

            confirmDeleteBtn.addEventListener('click', function () { deleteCourseForm.submit(); });
        });
    </script>
}
