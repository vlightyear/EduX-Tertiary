@model IEnumerable<SIS.Models.Admin.LearningRoom>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">meeting_room</i>
            Learning Rooms
        </h1>
        <button type="button"
                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center"
                onclick="showCreateRoomModal()">
            <i class="material-icons mr-2">add_circle</i>
            Create Learning Room
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-full">
            <div class="bg-white rounded-lg shadow-md h-full overflow-auto">
                <div class="p-4">
                    <table id="roomsTable" class="w-full text-sm text-slate-600">
                        <thead>
                            <tr>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Room Name
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Building
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Room Type
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Capacity
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                var groupedByBuilding = Model.GroupBy(r => r.Building?.Name ?? "No Building Assigned");
                                int index = 1;

                                foreach (var buildingGroup in groupedByBuilding.OrderBy(g => g.Key))
                                {
                                    <!-- Building Group Header Row -->
                                    <tr class="bg-primary-50 border-b border-primary-200">
                                        <td colspan="6" class="px-6 py-3">
                                            <span class="flex items-center text-primary-700 font-semibold text-sm uppercase tracking-wide">
                                                <i class="material-icons text-primary-600 mr-2 text-base">apartment</i>
                                                @buildingGroup.Key
                                                <span class="ml-2 px-2 py-0.5 bg-primary-100 text-primary-600 rounded-full text-xs font-medium">
                                                    @buildingGroup.Count() @(buildingGroup.Count() == 1 ? "room" : "rooms")
                                                </span>
                                            </span>
                                        </td>
                                    </tr>

                                    foreach (var room in buildingGroup)
                                    {
                                        <tr class="border-b hover:bg-gray-50 transition-colors">
                                            <td class="px-6 py-4 text-gray-400">@index</td>
                                            <td class="px-6 py-4 font-medium text-gray-900">@room.Name</td>
                                            <td class="px-6 py-4">@room.Building.Name</td>
                                            <td class="px-6 py-4">@room.RoomType</td>
                                            <td class="px-6 py-4">
                                                <div class="flex flex-col">
                                                    <span>Learning: @room.LearningCapacity</span>
                                                    <span>Exam: @room.ExamCapacity</span>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex space-x-2">
                                                    <button onclick="showUpdateRoomModal('@room.Id', '@room.Name', '@room.BuildingId', '@room.RoomType', '@room.LearningCapacity', '@room.ExamCapacity', '@room.Area', '@room.Description')"
                                                            class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                        <i class="material-icons text-sm mr-1">edit</i> Edit
                                                    </button>
                                                    <button onclick="showDeleteRoomModal('@room.Id', '@room.Name')"
                                                            class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                        <i class="material-icons text-sm mr-1">delete</i> Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-4 text-center text-gray-500">No learning rooms found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Learning Room Modal -->
<div id="createRoomModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New Learning Room
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="createRoomForm" method="post" asp-controller="Admin" asp-action="CreateLearningRoom">
                        @Html.AntiForgeryToken()

                        <div class="space-y-6">
                            <!-- Room Name -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="roomName"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="roomName"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Room Name
                                </label>
                            </div>

                            <!-- Building Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="BuildingId" id="buildingId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                        required>
                                    <option value="" disabled selected></option>
                                    @foreach (var building in ViewBag.BuildingId)
                                    {
                                        <option value="@building.Value">@building.Text</option>
                                    }
                                </select>
                                <label for="buildingId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Select Building
                                </label>
                            </div>

                            <!-- Room Type -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="RoomType" id="roomType"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="roomType"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Room Type
                                </label>
                            </div>

                            <!-- Capacity Section -->
                            <div class="grid grid-cols-2 gap-6">
                                <!-- Learning Capacity -->
                                <div class="relative z-0 w-full group">
                                    <input type="number" name="LearningCapacity" id="learningCapacity"
                                           class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                           placeholder=" " required />
                                    <label for="learningCapacity"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Learning Capacity
                                    </label>
                                </div>

                                <!-- Exam Capacity -->
                                <div class="relative z-0 w-full group">
                                    <input type="number" name="ExamCapacity" id="examCapacity"
                                           class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                           placeholder=" " required />
                                    <label for="examCapacity"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Exam Capacity
                                    </label>
                                </div>
                            </div>

                            <!-- Room Area -->
                            <div class="relative z-0 w-full group">
                                <input type="number" name="Area" id="area"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="area"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Room Area (sq ft)
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="description" rows="3"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" "></textarea>
                                <label for="description"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmCreate" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center">
                        <i class="material-icons mr-1">add</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Update Learning Room Modal -->
