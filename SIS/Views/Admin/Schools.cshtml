@model IEnumerable<SIS.Models.Admin.School>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-gray-800 flex items-center">
            <i class="material-icons mr-2">school</i>
            Schools
        </h1>
        <button type="button"
                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center"
                onclick="showCreateSchoolModal()">
            <i class="material-icons mr-2">add</i>
            Create School
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full overflow-hidden">
                <div class="p-4">
                    <table id="schoolsTable" class="w-full text-sm text-gray-600">
                        <thead>
                            <tr>
                                <th>
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th>
                                    <span class="flex items-center">
                                        School Name
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th>
                                    <span class="flex items-center">
                                        Description
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th>
                                    <span class="flex items-center">
                                        Dean
                                    </span>
                                </th>
                                <th>
                                    <span class="flex items-center">
                                        Assistant Dean
                                    </span>
                                </th>
                                <th>
                                    <span class="flex items-center">
                                        Assistant Registrar
                                    </span>
                                </th>
                                <th>
                                    <span class="flex items-center">
                                        Actions
                                    </span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int index = 1;
                                foreach (var school in Model)
                                {
                                    <tr class="border-b hover:bg-gray-50">
                                        <td class="px-6 py-4">@index</td>
                                        <td class="px-6 py-4 font-medium text-gray-900">@school.Name</td>
                                        <td class="px-6 py-4">@school.Description</td>
                                        <td class="px-6 py-4">@(school.Dean?.FullName ?? "Not Assigned")</td>
                                        <td class="px-6 py-4">@(school.AssistantDean?.FullName ?? "Not Assigned")</td>
                                        <td class="px-6 py-4">@(school.AssistantRegistrar?.FullName ?? "Not Assigned")</td>
                                        <td class="px-6 py-4">
                                            <div class="flex space-x-2">
                                                <button onclick="showUpdateSchoolModal('@school.Id')"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">edit</i> Edit
                                                </button>
                                                <button onclick="showDeleteSchoolModal('@school.Id', '@school.Name')"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">delete</i> Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="grid grid-cols-1 gap-4">
                <!-- Total Schools -->
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">school</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Schools</p>
                            <p class="text-xl font-semibold">@Model.Count()</p>
                        </div>
                    </div>
                </div>

                <!-- Total Students -->
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">groups</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Students</p>
                            <p class="text-xl font-semibold text-green-600">@ViewBag.TotalStudents</p>
                        </div>
                    </div>
                </div>

                <!-- Teachers Count -->
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-orange-100 rounded-lg">
                            <i class="material-icons text-orange-600 text-xl">psychology</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Lecturers</p>
                            <p class="text-xl font-semibold text-orange-600">@ViewBag.TotalLecturers</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Schools Distribution Chart -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Student Distribution by School</h3>
                <div id="schoolStatsChart" class="min-h-74"></div>
            </div>
        </div>
    </div>
</div>

<!-- Create School Modal -->
<div id="createSchoolModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-blue-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New School
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="createSchoolForm" method="post" enctype="multipart/form-data" asp-controller="Admin" asp-action="CreateSchool">
                        @Html.AntiForgeryToken()

                        <!-- Mode Selection -->
                        <div class="mb-6">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Select Mode:</label>
                            <div class="flex space-x-4">
                                <label class="inline-flex items-center">
                                    <input type="radio" id="single" name="mode" value="single" checked
                                           class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500">
                                    <span class="ml-2 text-gray-700">Single Grade</span>
                                </label>
                                <label class="inline-flex items-center">
                                    <input type="radio" id="bulk" name="mode" value="bulk"
                                           class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500">
                                    <span class="ml-2 text-gray-700">Bulk Upload</span>
                                </label>
                            </div>
                        </div>

                        <!-- Single School Form -->
                        <div id="singleSchool" class="space-y-4">
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="schoolName"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="schoolName"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    School Name
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="description" rows="3"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" "></textarea>
                                <label for="description"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- Dean Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="DeanId" id="deanId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                    <option value="">Select Dean</option>
                                    @foreach (var item in ViewBag.DeanUsers)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="deanId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Dean
                                </label>
                            </div>

                            <!-- Assistant Dean Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="AssistantDeanId" id="assistantDeanId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                    <option value="">Select Assistant Dean</option>
                                    @foreach (var item in ViewBag.DeanUsers)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="assistantDeanId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Assistant Dean
                                </label>
                            </div>

                            <!-- Assistant Registrar Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="AssistantDeanId" id="assistantDeanId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                    <option value="">Select Assistant Registrar</option>
                                    @foreach (var item in ViewBag.ArUsers)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="assistantRegistrarId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Assistant Registrar
                                </label>
                            </div>
                        </div>

                        <!-- Bulk Upload Form -->
                        <div id="bulkSchool" class="hidden space-y-4">
                            <div class="mt-2">
                                <label class="block text-sm font-medium text-gray-700 mb-2">Upload CSV File</label>
                                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg">
                                    <div class="space-y-1 text-center">
                                        <i class="material-icons text-gray-400 text-3xl mb-2">cloud_upload</i>
                                        <div class="flex text-sm text-gray-600">
                                            <label for="file" class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-blue-500">
                                                <span>Upload a file</span>
                                                <input id="file" name="File" type="file" class="sr-only" accept=".csv">
                                            </label>
                                            <p class="pl-1">or drag and drop</p>
                                        </div>
                                        <p class="text-xs text-gray-500">CSV files only</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmCreate" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">add</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update School Modal -->
<div id="updateSchoolModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-gray-700 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">edit</i>
                        Update School
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="updateSchoolForm" method="post" asp-controller="Admin" asp-action="UpdateSchool">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="updateSchoolId" name="Id" />
                        <div class="space-y-4">
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="updateSchoolName"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="updateSchoolName"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    School Name
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="updateDescription" rows="3"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" "></textarea>
                                <label for="updateDescription"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- Dean Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="DeanId" id="updateDeanId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                    <option value="">Select Dean</option>
                                    @foreach (var item in ViewBag.DeanUsers)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="updateDeanId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Dean
                                </label>
                            </div>

                            <!-- Assistant Dean Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="AssistantDeanId" id="updateAssistantDeanId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                    <option value="">Select Assistant Dean</option>
                                    @foreach (var item in ViewBag.DeanUsers)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="updateAssistantDeanId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Assistant Dean
                                </label>
                            </div>

                            <!-- Assistant Registrar Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="AssistantRegistrarId" id="updateAssistantRegistrarId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                    <option value="">Select Assistant Registrar</option>
                                    @foreach (var item in ViewBag.ArUsers)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="updateAssistantRegistrarId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Assistant Registrar
                                </label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmUpdate" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Update
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete School Modal -->
<div id="deleteSchoolModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="deleteSchoolForm" method="post" asp-controller="Admin" asp-action="DeleteSchool">
                        <input type="hidden" id="deleteSchoolId" name="Id" />
                        @Html.AntiForgeryToken()

                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-2">error_outline</i>
                                <p class="text-lg font-medium">Delete School</p>
                            </div>

                            <p class="text-gray-700">Are you sure you want to delete this school? This action cannot be undone.</p>

                            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mt-4">
                                <p class="text-gray-700 font-medium mb-2">School Details:</p>
                                <p class="text-gray-600">
                                    <span class="font-medium">School Name:</span>
                                    <span id="deleteSchoolName" class="ml-2"></span>
                                </p>
                            </div>

                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-sm">info</i>
                                    <p class="text-sm">This action cannot be undone. All associated data will be permanently deleted.</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmDelete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="module" src="~/js/schools.js"></script>

<script>
    // Pass data from server to JavaScript for the chart
    var studentDistributionData = @Html.Raw(Json.Serialize(ViewBag.StudentDistribution));
</script>