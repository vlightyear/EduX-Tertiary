@model IEnumerable<SIS.Models.Admin.Department>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-gray-800 flex items-center">
            <i class="material-icons mr-2">business</i>
            Department Management
        </h1>
        <button type="button"
                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center"
                onclick="showCreateDepartmentModal()">
            <i class="material-icons mr-2">add</i>
            Create Department
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full overflow-auto">
                <div class="p-4">
                    <table id="departmentsTable" class="w-full text-sm text-gray-600">
                        <thead>
                            <tr>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Department Name
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Description
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        School
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        HOD
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="overflow-auto">
                            @if (Model != null && Model.Any())
                            {
                                int index = 1;
                                foreach (var department in Model)
                                {
                                    <tr class="border-b hover:bg-gray-50 transition-colors">
                                        <td class="px-6 py-4">@index</td>
                                        <td class="px-6 py-4 font-medium text-gray-900">@department.Name</td>
                                        <td class="px-6 py-4">@department.Description</td>
                                        <td class="px-6 py-4">@department.School?.Name</td>
                                        <td class="px-6 py-4">@department.HOD?.UserName</td>
                                        <td class="px-6 py-4">
                                            <div class="flex space-x-2">
                                                <button onclick="showUpdateDepartmentModal('@department.Id')"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">edit</i> Edit
                                                </button>
                                                <button onclick="showDeleteDepartmentModal('@department.Id', '@department.Name')"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">delete</i> Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-4 text-center text-gray-500">No departments found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Department Summary</h3>
                <div class="space-y-4">
                    <!-- Total Departments -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-emerald-100 rounded-lg">
                                <i class="material-icons text-emerald-600 text-xl">business</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Total Departments</p>
                                <p class="text-xl font-semibold">@Model?.Count()</p>
                            </div>
                        </div>
                    </div>

                    <!-- Total Schools -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-blue-100 rounded-lg">
                                <i class="material-icons text-blue-600 text-xl">account_balance</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Total Schools</p>
                                <p class="text-xl font-semibold">@Model?.Select(d => d.School?.Name).Distinct().Count()</p>
                            </div>
                        </div>
                    </div>

                    <!-- Active HODs -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-red-100 rounded-lg">
                                <i class="material-icons text-red-600 text-xl">person</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Active HODs</p>
                                <p class="text-xl font-semibold">@Model?.Count(d => d.HOD != null)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Total Programs -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-yellow-100 rounded-lg">
                                <i class="material-icons text-yellow-600 text-xl">school</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Total Programs</p>
                                <p class="text-xl font-semibold">@ViewBag.TotalPrograms</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Distribution Chart -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Department Distribution</h3>
                <div id="department-distribution-chart" class="h-64"></div>
            </div>
        </div>
    </div>
</div>

<!-- Create Department Modal -->
<div id="createDepartmentModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-blue-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New Department
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="createDepartmentForm" method="post" asp-controller="Admin" asp-action="CreateDepartment">
                        @Html.AntiForgeryToken()
                        <div class="space-y-6">
                            <!-- Department Name -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="Name"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="Name"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Department Name
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="Description" rows="3"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" "></textarea>
                                <label for="Description"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- School Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="SchoolId" id="SchoolId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                        required>
                                    <option value="">Select School</option>
                                    @foreach (var item in ViewBag.Schools)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="SchoolId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    School
                                </label>
                            </div>

                            <!-- HOD Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="HODId" id="HODId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                    <option value="">Select HOD</option>
                                    @foreach (var item in ViewBag.HODs)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="HODId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Head of Department
                                </label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmCreate" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Department Modal -->
<div id="updateDepartmentModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-gray-700 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">edit</i>
                        Update Department
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="updateDepartmentForm" method="post" asp-controller="Admin" asp-action="UpdateDepartment">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="updateDepId" name="Id" />

                        <div class="space-y-6">
                            <!-- Department Name -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="updateName"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="updateName"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Department Name
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="updateDescription" rows="3"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" "></textarea>
                                <label for="updateDescription"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- School Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="SchoolId" id="updateSchoolId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                        required>
                                    <option value="">Select School</option>
                                    @foreach (var item in ViewBag.Schools)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="updateSchoolId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    School
                                </label>
                            </div>

                            <!-- HOD Selection -->
                            <div class="relative z-0 w-full group">
                                <select name="HODId" id="updateHODId"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                    <option value="">Select HOD</option>
                                    @foreach (var item in ViewBag.HODs)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <label for="updateHODId"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Head of Department
                                </label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmUpdate" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Update
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Department Modal -->
<div id="deleteDepartmentModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="deleteDepartmentForm" method="post" asp-controller="Admin" asp-action="DeleteDepartment">
                        <input type="hidden" id="deleteDepId" name="Id" />
                        @Html.AntiForgeryToken()

                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-2">error_outline</i>
                                <p class="text-lg font-medium">Delete Department</p>
                            </div>

                            <p class="text-gray-700">Are you sure you want to delete this department?</p>

                            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                                <p class="text-gray-700 font-medium mb-2">Department Details:</p>
                                <p class="text-gray-600">
                                    <span class="font-medium">Department Name:</span>
                                    <span id="deleteDepName" class="ml-2"></span>
                                </p>
                            </div>

                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-sm">info</i>
                                    <p class="text-sm">This action cannot be undone. All associated data will be permanently deleted.</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmDelete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="module" src="~/js/departments.js"></script>

