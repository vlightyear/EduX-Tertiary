@model IEnumerable<SIS.Models.Admin.ProgressionRule>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-scondary-800 flex items-center">
            <i class="material-icons mr-2 text-primary-600">rule</i>
            Progression Rules
        </h1>
        <button type="button"
                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center shadow-md hover:shadow-lg"
                onclick="showCreateProgressionRuleModal()">
            <i class="material-icons mr-2">add_circle</i>
            Create Rule
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-full">
            <div class="bg-white rounded-lg shadow-lg h-full overflow-hidden border border-gray-100">
                <div class="p-4">
                    <table id="progressionRuleTable" class="w-full text-sm text-secondary-600">
                        <thead>
                            <tr class="bg-primary-50 border-b border-primary-100">
                                <th class="px-6 py-4 text-left">
                                    <span class="flex items-center text-primary-700 font-semibold">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4 text-left font-semibold">Name</th>
                                <th class="px-6 py-4 text-left font-semibold">School</th>
                                <th class="px-6 py-4 text-left font-semibold">% Failed Courses</th>
                                <th class="px-6 py-4 text-left font-semibold">Action</th>
                                <th class="px-6 py-4 text-left font-semibold">Academic Period</th>
                                <th class="px-6 py-4 text-left font-semibold">Attempt</th>
                                <th class="px-6 py-4 text-left font-semibold">Status</th>
                                <th class="px-6 py-4 text-left font-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                var groupedBySchool = Model
                                .GroupBy(r => r.SchoolId.HasValue && r.School != null ? r.School.Name : "Global Rules")
                                .OrderBy(g => g.Key == "Global Rules" ? "0" : g.Key); // Global Rules always first

                                int index = 1;

                                foreach (var schoolGroup in groupedBySchool)
                                {
                                    <tr class="bg-primary-50 border-b border-primary-200" data-group-header="true">
                                        <td colspan="9" class="px-6 py-3">
                                            <span class="flex items-center text-primary-700 font-semibold text-sm uppercase tracking-wide">
                                                @if (schoolGroup.Key == "Global Rules")
                                                {
                                                    <i class="material-icons text-primary-600 mr-2 text-base">public</i>
                                                }
                                                else
                                                {
                                                    <i class="material-icons text-primary-600 mr-2 text-base">account_balance</i>
                                                }
                                                @schoolGroup.Key
                                                <span class="ml-2 px-2 py-0.5 bg-primary-100 text-primary-600 rounded-full text-xs font-medium">
                                                    @schoolGroup.Count() @(schoolGroup.Count() == 1 ? "rule" : "rules")
                                                </span>
                                            </span>
                                        </td>
                                    </tr>

                                    foreach (var rule in schoolGroup)
                                    {
                                        <tr class="border-b border-gray-100 hover:bg-primary-50 transition-colors">
                                            <td class="px-6 py-4 text-secondary-600">@index</td>
                                            <td class="px-6 py-4 font-medium text-gray-900">@rule.Name</td>
                                            <td class="px-6 py-4">
                                                @if (rule.SchoolId.HasValue && rule.School != null)
                                                {
                                                    <span class="px-3 py-1 text-sm bg-blue-100 text-blue-700 rounded-full font-medium">
                                                        @rule.School.Name
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="px-3 py-1 text-sm bg-purple-100 text-purple-700 rounded-full font-medium">
                                                        Global Rule
                                                    </span>
                                                }
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="px-2 py-1 text-sm bg-gray-100 text-gray-700 rounded-full font-medium">
                                                    @rule.PercentFailedOfCourseLoad
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="px-2 py-1 text-xs bg-indigo-100 text-indigo-700 rounded-full font-medium">
                                                    @rule.Action
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="px-2 py-1 text-xs bg-indigo-100 text-indigo-700 rounded-full font-medium">
                                                    @rule.AcademicPeriod.PeriodName
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="px-2 py-1 text-xs bg-indigo-100 text-indigo-700 rounded-full font-medium">
                                                    @rule.Attempt
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                @if (rule.IsActive)
                                                {
                                                    <span class="px-3 py-1 text-sm bg-secondary-100 text-secondary-700 rounded-full font-medium flex items-center w-fit">
                                                        <i class="material-icons text-xs mr-1">check_circle</i>
                                                        Active
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="px-3 py-1 text-sm bg-red-100 text-red-700 rounded-full font-medium flex items-center w-fit">
                                                        <i class="material-icons text-xs mr-1">pause_circle</i>
                                                        Inactive
                                                    </span>
                                                }
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex space-x-2">
                                                    <button onclick="showUpdateProgressionRuleModal('@rule.Id')"
                                                            class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                        <i class="material-icons text-sm mr-1">edit</i> Edit
                                                    </button>
                                                    <button onclick="showDeleteRuleModal('@rule.Id', '@rule.Name')"
                                                            class="inline-flex items-center px-3 py-1.5 text-sm text-red-700 bg-red-50 hover:bg-red-100 rounded-lg transition-colors border border-red-200">
                                                        <i class="material-icons text-sm mr-1">delete</i> Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="px-6 py-8 text-center text-gray-500">
                                        <div class="flex flex-col items-center">
                                            <i class="material-icons text-4xl text-gray-300 mb-2">rule</i>
                                            <p class="text-lg font-medium">No progression rules found</p>
                                            <p class="text-sm">Create your first progression rule to get started</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Progression Rule Modal -->
<div id="createProgressionRuleModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-2xl border border-gray-200">
                <!-- Modal Header -->
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New Progression Rule
                    </h3>
                    <button type="button" class="text-white hover:text-primary-200 transition-colors" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="createProgressionRuleForm" method="post" asp-controller="Admin" asp-action="CreateProgressionRule">
                        @Html.AntiForgeryToken()

                        <!-- Basic Information Section -->
                        <div class="mb-6">
                            <h4 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                                <i class="material-icons text-primary-600 mr-2">info</i>
                                Basic Information
                            </h4>
                            <div class="space-y-6">
                                <!-- Rule Name -->
                                <div class="relative z-0 w-full group">
                                    <input type="text" name="Name" id="ruleName"
                                           class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                           placeholder=" " required maxlength="100" />
                                    <label for="ruleName"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Rule Name *
                                    </label>
                                </div>

                                <!-- Semester Selection -->
                                <div class="relative z-0 w-full group">
                                    <select name="Semester" id="semester"
                                            class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer">
                                        <option value=""></option>
                                        <option value="1">First</option>
                                        <option value="2">Second</option>
                                    </select>
                                    <label for="semester"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Semester (Leave empty for both semesters)
                                    </label>
                                </div>

                                <!-- Attempt Selection -->
                                <div class="relative z-0 w-full group">
                                    <select name="Attempt" id="attempt"
                                            class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer">
                                        <option value=""></option>
                                        <option value="1">First</option>
                                        <option value="2">Second</option>
                                    </select>
                                    <label for="attempt"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Attempt (Leave empty for both attempts)
                                    </label>
                                </div>

                                <!-- School Selection -->
                                <div class="relative z-0 w-full group">
                                    <select name="SchoolId" id="schoolId"
                                            class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer">
                                        <option value="" selected></option>
                                    </select>
                                    <label for="schoolId"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        School (Leave empty for global rule)
                                    </label>
                                </div>

                                <!-- Description -->
                                <div class="relative z-0 w-full group">
                                    <textarea name="Description" id="description" rows="3"
                                              class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                              placeholder=" " maxlength="500"></textarea>
                                    <label for="description"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Description
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Rule Configuration Section -->
                        <div class="mb-6">
                            <h4 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                                <i class="material-icons text-primary-600 mr-2">settings</i>
                                Rule Configuration
                            </h4>
                            <div class="grid grid-cols-2 gap-4">
                                <!-- Maximum Failed Courses -->
                                <div class="relative z-0 w-full group">
                                    <input type="number" name="PercentFailedOfCourseLoad" id="maximumFailedCourses"
                                           class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                           placeholder=" " required min="0" />
                                    <label for="maximumFailedCourses"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Percent Failed Courses *
                                    </label>
                                </div>

                                <!-- Progression Action -->
                                <div class="relative z-0 w-full group">
                                    <select name="Action" id="action"
                                            class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                            required>
                                        <option value="" disabled selected></option>
                                        <option value="Proceed">Proceed (Clear pass, move to next year)</option>
                                        <option value="Sup">Suplementary (Must reseat failed courses)</option>
                                        <option value="ProceedAndRepeat">Proceed with Repeat (Pass but repeat failed units)</option>
                                        <option value="RepeatYear">Repeat Year (Must repeat the entire year)</option>
                                        <option value="RepeatSemester">Repeat Semester (Must repeat the current semester)</option>
                                        <option value="Exclude">Exclude (Academic exclusion/discontinuation)</option>
                                        <option value="Withdraw">Withdraw (Voluntary/advised withdrawal)</option>
                                        <option value="ProceedOnProbation">Proceed on Probation</option>
                                    </select>
                                    <label for="action"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Progression Action *
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Status Section -->
                        <div class="mb-6">
                            <h4 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                                <i class="material-icons text-primary-600 mr-2">toggle_on</i>
                                Status Settings
                            </h4>
                            <div class="flex items-center p-3 bg-gray-50 rounded-lg">
                                <input type="checkbox" name="IsActive" id="IsActive" value="true"
                                       class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" checked />
                                <label for="IsActive" class="ml-3 text-sm text-gray-700 font-medium">Rule is active</label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmCreate" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors flex items-center shadow-md">
                        <i class="material-icons mr-1">add</i>Create Rule
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Progression Rule Modal -->
<div id="updateProgressionRuleModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-2xl border border-gray-200">
                <!-- Modal Header -->
                <div class="bg-secondary-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">edit</i>
                        Update Progression Rule
                    </h3>
                    <button type="button" class="text-white hover:text-secondary-200 transition-colors" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="updateProgressionRuleForm" method="post" asp-controller="Admin" asp-action="UpdateProgressionRule">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="updateRuleId" name="Id" />

                        <!-- Basic Information Section -->
                        <div class="mb-6">
                            <h4 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                                <i class="material-icons text-secondary-600 mr-2">info</i>
                                Basic Information
                            </h4>
                            <div class="space-y-6">
                                <!-- Rule Name -->
                                <div class="relative z-0 w-full group">
                                    <input type="text" name="Name" id="updateRuleName"
                                           class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                           placeholder=" " required />
                                    <label for="updateRuleName"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Rule Name *
                                    </label>
                                </div>

                                <!-- Semester Selection -->
                                <div class="relative z-0 w-full group">
                                    <select name="Semester" id="updateSemester"
                                            class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer">
                                        <option value=""></option>
                                        <option value="1">First</option>
                                        <option value="2">Second</option>
                                    </select>
                                    <label for="updateSemester"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Semester (Leave empty for both semesters)
                                    </label>
                                </div>

                                <!-- Attempt Selection -->
                                <div class="relative z-0 w-full group">
                                    <select name="Attempt" id="updateAttempt"
                                            class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer">
                                        <option value=""></option>
                                        <option value="1">First</option>
                                        <option value="2">Second</option>
                                    </select>
                                    <label for="updateAttempt"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Attempt (Leave empty for both attempts)
                                    </label>
                                </div>

                                <!-- School Selection -->
                                <div class="relative z-0 w-full group">
                                    <select name="SchoolId" id="updateSchoolId"
                                            class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer">
                                        <option value=""></option>
                                    </select>
                                    <label for="updateSchoolId"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        School (Leave empty for global rule)
                                    </label>
                                </div>

                                <!-- Description -->
                                <div class="relative z-0 w-full group">
                                    <textarea name="Description" id="updateDescription" rows="3"
                                              class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                              placeholder=" "></textarea>
                                    <label for="updateDescription"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Description
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Rule Configuration Section -->
                        <div class="mb-6">
                            <h4 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                                <i class="material-icons text-secondary-600 mr-2">settings</i>
                                Rule Configuration
                            </h4>
                            <div class="grid grid-cols-2 gap-4">
                                <!-- Maximum Failed Courses -->
                                <div class="relative z-0 w-full group">
                                    <input type="number" name="PercentFailedOfCourseLoad" id="updateMaximumFailedCourses"
                                           class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                           placeholder=" " required min="0" />
                                    <label for="updateMaximumFailedCourses"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Percent Failed Courses *
                                    </label>
                                </div>

                                <!-- Progression Action -->
                                <div class="relative z-0 w-full group">
                                    <select name="Action" id="updateAction"
                                            class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                            required>
                                        <option value="" disabled></option>
                                        <option value="Proceed">Proceed (Clear pass, move to next year)</option>
                                        <option value="Sup">Suplementary (Must reseat failed courses)</option>
                                        <option value="ProceedWithRepeat">Proceed with Repeat (Pass but repeat failed units)</option>
                                        <option value="RepeatYear">Repeat Year (Must repeat the entire year)</option>
                                        <option value="RepeatSemester">Repeat Semester (Must repeat the current semester)</option>
                                        <option value="Exclude">Exclude (Academic exclusion/discontinuation)</option>
                                        <option value="Withdraw">Withdraw (Voluntary/advised withdrawal)</option>
                                        <option value="ProceedOnProbation">Proceed on Probation</option>
                                    </select>
                                    <label for="updateAction"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Progression Action *
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Status Section -->
                        <div class="mb-6">
                            <h4 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                                <i class="material-icons text-secondary-600 mr-2">toggle_on</i>
                                Status Settings
                            </h4>
                            <div class="flex items-center p-3 bg-gray-50 rounded-lg">
                                <input type="checkbox" name="IsActive" id="updateIsActive" value="true"
                                       class="w-4 h-4 text-secondary-600 border-gray-300 rounded focus:ring-secondary-500" />
                                <label for="updateIsActive" class="ml-3 text-sm text-gray-700 font-medium">Rule is active</label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmUpdate" class="px-4 py-2 bg-secondary-600 text-white rounded-lg hover:bg-secondary-700 transition-colors flex items-center shadow-md">
                        <i class="material-icons mr-1">save</i>Update Rule
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Delete Progression Rule Modal -->
<div id="deleteProgressionRuleModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-lg border border-gray-200">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-red-200 transition-colors" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="deleteProgressionRuleForm" method="post" asp-controller="Admin" asp-action="DeleteProgressionRule">
                        <input type="hidden" id="deleteRuleId" name="Id" />
                        @Html.AntiForgeryToken()

                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-3 text-2xl">error_outline</i>
                                <p class="text-lg font-semibold">Delete Progression Rule</p>
                            </div>

                            <p class="text-gray-700 text-base">Are you sure you want to delete this progression rule? This action cannot be undone and will:</p>

                            <ul class="list-disc list-inside text-secondary-600 ml-4 space-y-2">
                                <li>Permanently remove the progression rule</li>
                                <li>Affect any students currently subject to this rule</li>
                                <li>Remove all associated rule configurations</li>
                            </ul>

                            <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
                                <p class="text-gray-700 font-semibold mb-2 flex items-center">
                                    <i class="material-icons text-amber-600 mr-2">info</i>
                                    Rule Details:
                                </p>
                                <div class="space-y-1 text-secondary-600">
                                    <p><span class="font-medium">Rule Name:</span> <span id="deleteRuleName" class="ml-2 font-semibold text-secondary-800"></span></p>
                                    <p><span class="font-medium">School:</span> <span id="deleteRuleSchool" class="ml-2 font-semibold text-secondary-800"></span></p>
                                    <p><span class="font-medium">Action:</span> <span id="deleteRuleAction" class="ml-2 font-semibold text-secondary-800"></span></p>
                                </div>
                            </div>

                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-lg">warning</i>
                                    <p class="text-sm font-medium">This action cannot be undone. Please be certain.</p>
                                </div>
                            </div>

                            <div class="mt-4">
                                <label class="inline-flex items-center p-3 bg-gray-50 rounded-lg w-full">
                                    <input type="checkbox" id="confirmDeleteCheckbox"
                                           class="w-4 h-4 text-red-600 border-gray-300 rounded focus:ring-red-500">
                                    <span class="ml-3 text-sm text-gray-700 font-medium">I understand that this action cannot be undone</span>
                                </label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3">
                    <button type="button"
                            class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300"
                            data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button"
                            id="confirmDelete"
                            disabled
                            class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center disabled:opacity-50 disabled:cursor-not-allowed shadow-md">
                        <i class="material-icons mr-1">delete</i>Delete Rule
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

