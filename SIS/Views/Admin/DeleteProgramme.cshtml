@model SIS.Models.Admin.Programme

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-red-800 flex items-center">
            <i class="material-icons mr-2 text-red-600">delete</i>
            Delete Programme
        </h1>
        <a asp-controller="Admin" asp-action="Programmes"
           class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors flex items-center shadow-md hover:shadow-lg">
            <i class="material-icons mr-2">arrow_back</i>
            Back
        </a>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Content Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-lg h-full overflow-auto border border-gray-100">
                <div class="p-6">
                    <form asp-action="DeleteProgramme" method="post" class="space-y-6">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <!-- Warning Alert -->
                        <div class="bg-red-50 border border-red-200 rounded-lg p-4 flex items-start">
                            <div class="flex-shrink-0">
                                <i class="material-icons text-red-500 text-2xl">warning</i>
                            </div>
                            <div class="ml-3">
                                <h3 class="text-lg font-semibold text-red-800 mb-2">
                                    Confirm Programme Deletion
                                </h3>
                                <p class="text-red-700 mb-2">
                                    Are you sure you want to delete this programme? This action cannot be undone and will permanently remove:
                                </p>
                                <ul class="text-red-700 text-sm list-disc list-inside space-y-1">
                                    <li>Programme information and settings</li>
                                    <li>Associated course requirements</li>
                                    <li>Programme coordinator assignments</li>
                                    <li>All related data and configurations</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Programme Information Cards -->
                        <div class="grid grid-cols-2 gap-6">
                            <!-- Basic Information -->
                            <div class="bg-gray-50 rounded-lg shadow-md p-6 border border-gray-200">
                                <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                                    <i class="material-icons text-primary-600 mr-2">info</i>
                                    Basic Information
                                </h2>

                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Programme Name</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                            <span class="text-gray-900 font-semibold">@Model.Name</span>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg min-h-[80px]">
                                            <span class="text-gray-900">@Model.Description</span>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Department</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                            <span class="text-gray-900">@Model.Department?.Name</span>
                                            @if (Model.Department?.School != null)
                                            {
                                                <span class="text-gray-500 text-sm block">(@Model.Department.School.Name)</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Programme Details -->
                            <div class="bg-gray-50 rounded-lg shadow-md p-6 border border-gray-200">
                                <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                                    <i class="material-icons text-secondary-600 mr-2">assignment</i>
                                    Programme Details
                                </h2>

                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Mode of Study</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                            <span class="text-gray-900">@Model.ModeOfStudy?.ModeName</span>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Programme Level</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                            <span class="text-gray-900">@Model.ProgrammeLevel?.Name</span>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Programme Coordinator</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                            <span class="text-gray-900">@Model.Coordinator?.FullName</span>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Duration</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                            <span class="text-gray-900">@Model.DurationYears years</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Additional Programme Information -->
                        <div class="grid grid-cols-2 gap-6">
                            <!-- Programme Settings -->
                            <div class="bg-gray-50 rounded-lg shadow-md p-6 border border-gray-200">
                                <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                                    <i class="material-icons text-blue-600 mr-2">settings</i>
                                    Programme Settings
                                </h2>

                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Minimum Points (Top 5)</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                            <span class="text-gray-900">@Model.MinimumPointsTop5Subjects points</span>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Enrollment Count</label>
                                        <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                            <span class="text-gray-900">@Model.EnrollmentCount students</span>
                                        </div>
                                    </div>

                                    <div class="flex items-center space-x-4">
                                        <div class="flex items-center p-3 bg-white border border-gray-300 rounded-lg flex-1">
                                            <i class="material-icons text-blue-600 mr-2">@(Model.IsSemesterBased ? "check_circle" : "cancel")</i>
                                            <span class="text-gray-900">Semester Based</span>
                                        </div>

                                        <div class="flex items-center p-3 bg-white border border-gray-300 rounded-lg flex-1">
                                            <i class="material-icons text-orange-600 mr-2">@(Model.IsNonQuota ? "check_circle" : "cancel")</i>
                                            <span class="text-gray-900">Non-Quota Programme</span>
                                        </div>
                                    </div>

                                    @if (!Model.IsNonQuota && Model.AssociatedNQProgramme != null)
                                    {
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Associated NQ Programme</label>
                                            <div class="p-3 bg-white border border-gray-300 rounded-lg">
                                                <span class="text-gray-900">@Model.AssociatedNQProgramme.Name</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                           
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex justify-end space-x-3 pt-6 border-t border-gray-200">
                            <a asp-controller="Admin" asp-action="Programmes"
                               class="px-6 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300">
                                <i class="material-icons mr-2">close</i>Cancel
                            </a>
                            <button type="submit"
                                    class="px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center shadow-md hover:shadow-lg">
                                <i class="material-icons mr-2">delete_forever</i>Delete Programme
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-100">
                <h3 class="text-lg font-bold text-gray-800 mb-6 flex items-center">
                    <i class="material-icons text-primary-600 mr-2">analytics</i>
                    Programme Summary
                </h3>
                <div class="space-y-4">
                    <!-- Total Programmes -->
                    <div class="flex items-center p-3 bg-primary-50 rounded-lg border border-primary-100">
                        <div class="p-3 bg-primary-100 rounded-lg">
                            <i class="material-icons text-primary-600 text-xl">school</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-600 text-sm font-medium">Total Programmes</p>
                            <p class="text-2xl font-bold text-primary-700">@(ViewBag.TotalProgrammes ?? 0)</p>
                        </div>
                    </div>

                    <!-- Total Regular Programmes -->
                    <div class="flex items-center p-3 bg-green-50 rounded-lg border border-green-100">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">school</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-600 text-sm font-medium">Regular Programmes</p>
                            <p class="text-2xl font-bold text-green-700">@(ViewBag.TotalRegularProgrammes ?? 0)</p>
                        </div>
                    </div>

                    <!-- Total NQ Programmes -->
                    <div class="flex items-center p-3 bg-orange-50 rounded-lg border border-orange-100">
                        <div class="p-3 bg-orange-100 rounded-lg">
                            <i class="material-icons text-orange-600 text-xl">stars</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-600 text-sm font-medium">Non-Quota Programmes</p>
                            <p class="text-2xl font-bold text-orange-700">@(ViewBag.TotalNQProgrammes ?? 0)</p>
                        </div>
                    </div>

                    <!-- Total Schools -->
                    <div class="flex items-center p-3 bg-blue-50 rounded-lg border border-blue-100">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">business</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-600 text-sm font-medium">Total Schools</p>
                            <p class="text-2xl font-bold text-blue-700">@(ViewBag.TotalSchools ?? 0)</p>
                        </div>
                    </div>

                    <!-- Programme Coordinators -->
                    <div class="flex items-center p-3 bg-secondary-50 rounded-lg border border-secondary-100">
                        <div class="p-3 bg-secondary-100 rounded-lg">
                            <i class="material-icons text-secondary-600 text-xl">people</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-600 text-sm font-medium">Programme Coordinators</p>
                            <p class="text-2xl font-bold text-secondary-700">@(ViewBag.TotalCoordinators ?? 0)</p>
                        </div>
                    </div>

                    <!-- Average Duration -->
                    <div class="flex items-center p-3 bg-amber-50 rounded-lg border border-amber-100">
                        <div class="p-3 bg-amber-100 rounded-lg">
                            <i class="material-icons text-amber-600 text-xl">schedule</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-600 text-sm font-medium">Average Duration</p>
                            <p class="text-2xl font-bold text-amber-700">@((ViewBag.AverageDuration ?? 0.0).ToString("F1")) yrs</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Distribution Chart -->
            <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-100">
                <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                    <i class="material-icons text-primary-600 mr-2">pie_chart</i>
                    Programme Distribution
                </h3>
                <div id="programme-distribution-chart" class="min-h-52"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/apexcharts/3.44.0/apexcharts.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Chart initialization with dynamic data
            const chartData = @Html.Raw(Json.Serialize(ViewBag.ChartData ?? new List<object>()));
            const series = chartData.map(item => item.count || item.Count);
            const labels = chartData.map(item => item.level || item.Level);

            if (series.length === 0) {
                series.push(1);
                labels.push('No Data');
            }

            // System-friendly color palette
            const systemColors = [
                '#4F46E5', // Primary - Indigo
                '#10B981', // Secondary - Emerald
                '#F59E0B', // Amber
                '#EF4444', // Red
                '#8B5CF6', // Purple
                '#06B6D4', // Cyan
                '#F97316', // Orange
                '#84CC16', // Lime
                '#EC4899', // Pink
                '#6B7280'  // Gray
            ];

            const chartOptions = {
                series: series,
                chart: {
                    type: 'donut',
                    height: '100%',
                    fontFamily: 'inherit',
                },
                labels: labels,
                colors: systemColors,
                plotOptions: {
                    pie: {
                        donut: {
                            size: '75%',
                            labels: {
                                show: true,
                                name: {
                                    show: true,
                                    fontSize: '14px',
                                    fontFamily: 'inherit',
                                    fontWeight: 600,
                                    color: '#374151',
                                    offsetY: -4
                                },
                                value: {
                                    show: true,
                                    fontSize: '16px',
                                    fontFamily: 'inherit',
                                    fontWeight: 700,
                                    color: '#111827',
                                    offsetY: 4,
                                    formatter: function (val) {
                                        return val + ' programmes'
                                    }
                                },
                                total: {
                                    show: true,
                                    showAlways: true,
                                    label: 'Total',
                                    fontSize: '14px',
                                    fontWeight: 600,
                                    color: '#6B7280',
                                    formatter: function (w) {
                                        const total = w.globals.seriesTotals.reduce((a, b) => a + b, 0);
                                        return total + ' programmes'
                                    }
                                }
                            }
                        }
                    }
                },
                dataLabels: {
                    enabled: false
                },
                legend: {
                    show: true,
                    position: 'bottom',
                    horizontalAlign: 'center',
                    fontSize: '12px',
                    fontFamily: 'inherit',
                    fontWeight: 500,
                    labels: {
                        colors: '#374151',
                        useSeriesColors: false
                    },
                    markers: {
                        width: 8,
                        height: 8,
                        radius: 2,
                    },
                    itemMargin: {
                        horizontal: 8,
                        vertical: 4
                    }
                },
                stroke: {
                    show: true,
                    width: 2,
                    colors: ['#ffffff']
                },
                responsive: [{
                    breakpoint: 480,
                    options: {
                        chart: {
                            height: 200
                        },
                        legend: {
                            fontSize: '10px'
                        }
                    }
                }],
                tooltip: {
                    enabled: true,
                    theme: 'light',
                    style: {
                        fontSize: '12px',
                        fontFamily: 'inherit'
                    },
                    y: {
                        formatter: function(val) {
                            return val + ' programmes'
                        }
                    }
                }
            };

            const chart = new ApexCharts(document.querySelector("#programme-distribution-chart"), chartOptions);
            chart.render();
        });
    </script>
}