@model IEnumerable<SIS.Models.Admin.ProgramLevel>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-gray-800 flex items-center">
            <i class="material-icons mr-2">school</i>
            Programme Levels
        </h1>
        <button type="button"
                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center"
                onclick="showCreateLevelModal()">
            <i class="material-icons mr-2">add</i>
            Create Level
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full overflow-hidden">
                <div class="p-4">
                    <table id="programLevelTable" class="w-full text-sm text-gray-600">
                        <thead>
                            <tr>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">Name</th>
                                <th class="px-6 py-4">Description</th>
                                <th class="px-6 py-4">Rank</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int index = 1;
                                foreach (var level in Model)
                                {
                                    <tr class="border-b hover:bg-gray-50 transition-colors">
                                        <td class="px-6 py-4">@index</td>
                                        <td class="px-6 py-4 font-medium text-gray-900">@level.Name</td>
                                        <td class="px-6 py-4">@(string.IsNullOrEmpty(level.Description) ? "-" : level.Description)</td>
                                        <td class="px-6 py-4">@level.Rank</td>
                                        <td class="px-6 py-4">
                                            @if (level.IsActive)
                                            {
                                                <span class="px-2 py-1 text-sm bg-green-100 text-green-800 rounded-full">Active</span>
                                            }
                                            else
                                            {
                                                <span class="px-2 py-1 text-sm bg-red-100 text-red-800 rounded-full">Inactive</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex space-x-2">
                                                <button onclick="showUpdateLevelModal('@level.Id', '@level.Name', '@level.Description', '@level.Rank', @level.IsActive.ToString().ToLower())"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">edit</i> Edit
                                                </button>
                                                <button onclick="showDeleteLevelModal('@level.Id', '@level.Name', '@level.Rank')"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">delete</i> Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-4 text-center text-gray-500">No program levels found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Program Level Summary</h3>
                <div class="space-y-4">
                    <!-- Total Levels -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-blue-100 rounded-lg">
                                <i class="material-icons text-blue-600 text-xl">list</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Total Program Levels</p>
                                <p class="text-xl font-semibold">@Model?.Count()</p>
                            </div>
                        </div>
                    </div>

                    <!-- Active Levels -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-green-100 rounded-lg">
                                <i class="material-icons text-green-600 text-xl">check_circle</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Active Levels</p>
                                <p class="text-xl font-semibold text-green-600">@Model?.Count(x => x.IsActive)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Inactive Levels -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-red-100 rounded-lg">
                                <i class="material-icons text-red-600 text-xl">pause_circle</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Inactive Levels</p>
                                <p class="text-xl font-semibold text-red-600">@Model?.Count(x => !x.IsActive)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Total Programs -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-purple-100 rounded-lg">
                                <i class="material-icons text-purple-600 text-xl">school</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Total Programs Offered</p>
                                <p class="text-xl font-semibold">15</p>
                            </div>
                        </div>
                    </div>

                    <!-- Active Programs -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-yellow-100 rounded-lg">
                                <i class="material-icons text-yellow-600 text-xl">star</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Active Programs</p>
                                <p class="text-xl font-semibold">10</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Distribution Chart -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Level Distribution</h3>
                <div id="level-distribution-chart" class="h-64"></div>
            </div>
        </div>
    </div>
</div>

<!-- Create Program Level Modal -->
<div id="createLevelModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-blue-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New Program Level
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="createLevelForm" method="post" asp-controller="Admin" asp-action="CreateProgramLevel">
                        @Html.AntiForgeryToken()

                        <div class="space-y-6">
                            <!-- Level Name -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="levelName"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="levelName"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Level Name
                                </label>
                            </div>

                            <!-- Rank -->
                            <div class="relative z-0 w-full group">
                                <input type="number" name="Rank" id="rank"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required min="1" />
                                <label for="rank"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Rank
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="description" rows="3"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" "></textarea>
                                <label for="description"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- Is Active -->
                            <div class="flex items-center">
                                <input type="checkbox" name="IsActive" id="isActive"
                                       class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500" checked />
                                <label for="isActive" class="ml-2 text-sm text-gray-600">Is Active</label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmCreate" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Program Level Modal -->
<div id="updateLevelModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-gray-700 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">edit</i>
                        Update Program Level
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="updateLevelForm" method="post" asp-controller="Admin" asp-action="UpdateProgramLevel">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="updateLevelId" name="Id" />

                        <div class="space-y-6">
                            <!-- Level Name -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="updateLevelName"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required />
                                <label for="updateLevelName"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Level Name
                                </label>
                            </div>

                            <!-- Rank -->
                            <div class="relative z-0 w-full group">
                                <input type="number" name="Rank" id="updateRank"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required min="1" />
                                <label for="updateRank"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Rank
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="updateDescription" rows="3"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" "></textarea>
                                <label for="updateDescription"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- Is Active -->
                            <div class="flex items-center">
                                <input type="checkbox" name="IsActive" id="updateIsActive"
                                       class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500" />
                                <label for="updateIsActive" class="ml-2 text-sm text-gray-600">Is Active</label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmUpdate" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Update
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Program Level Modal -->
<div id="deleteLevelModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="deleteLevelForm" method="post" asp-controller="Admin" asp-action="DeleteProgramLevel">
                        <input type="hidden" id="deleteLevelId" name="Id" />
                        @Html.AntiForgeryToken()

                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-2">error_outline</i>
                                <p class="text-lg font-medium">Delete Program Level</p>
                            </div>

                            <p class="text-gray-700">Are you sure you want to delete this program level?</p>

                            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                                <p class="text-gray-700 font-medium mb-2">Level Details:</p>
                                <p class="text-gray-600">
                                    <span class="font-medium">Name:</span>
                                    <span id="deleteLevelName" class="ml-2"></span>
                                </p>
                                <p class="text-gray-600">
                                    <span class="font-medium">Rank:</span>
                                    <span id="deleteLevelRank" class="ml-2"></span>
                                </p>
                            </div>

                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-sm">info</i>
                                    <p class="text-sm">This action cannot be undone. All associated data will be permanently deleted.</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmDelete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="module" src="~/js/program_level.js"></script>