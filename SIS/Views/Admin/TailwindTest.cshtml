@{
    ViewData["Title"] = "Tailwind CSS Test Page";
}

<div class="min-h-screen bg-gradient-to-r from-blue-50 to-purple-50 flex flex-col items-center justify-center p-6">
    <div class="bg-white shadow-xl rounded-lg p-8 max-w-2xl w-full">
        <h1 class="text-4xl font-bold text-center text-gray-800 mb-6">
            Welcome to the Tailwind CSS Test Page!
        </h1>
        <p class="text-lg text-gray-600 mb-8">
            This page is styled entirely using Tailwind CSS. If you see this, Tailwind is working correctly!
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-blue-100 p-6 rounded-lg">
                <h2 class="text-2xl font-semibold text-blue-800 mb-4">Feature One</h2>
                <p class="text-gray-700">
                    Tailwind makes it easy to build responsive, modern UIs with utility-first CSS.
                </p>
            </div>
            <div class="bg-purple-100 p-6 rounded-lg">
                <h2 class="text-2xl font-semibold text-purple-800 mb-4">Feature Two</h2>
                <p class="text-gray-700">
                    You can customize everything and keep your designs consistent.
                </p>
            </div>
        </div>
        <div class="mt-8 text-center">
            <a href="#" class="inline-block bg-blue-500 text-white px-6 py-3 rounded-lg hover:bg-blue-600 transition duration-300">
                Get Started
            </a>
        </div>
    </div>
</div>