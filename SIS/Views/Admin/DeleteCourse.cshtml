@model SIS.Models.Admin.Course

@{
    ViewData["Title"] = "Delete Course";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow p-3 mb-5 bg-white rounded">
                <div class="card-body" style="height: 75vh; overflow-y: auto;">
                    <h2 class="text-center mb-4">Delete Course</h2>
                    <form asp-controller="Admin" asp-action="DeleteCourse" method="post">
                        <!-- Hidden field for Course Id -->
                        <input type="hidden" asp-for="Id" />

                        <!-- Course Details -->
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label>Course Code:</label>
                                <input class="form-control" value="@Model.CourseCode" disabled />
                            </div>

                            <div class="form-group col-md-4">
                                <label>Course Name:</label>
                                <input class="form-control" value="@Model.CourseName" disabled />
                            </div>

                            <div class="form-group col-md-4">
                                <label>Course Type:</label>
                                <input class="form-control" value="@Model.CourseType" disabled />
                            </div>
                        </div>

                        <!-- Programme -->
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label>Programme:</label>
                                <input class="form-control" value="@Model.Programme?.Name" disabled />
                            </div>
                        </div>

                        <!-- Course Description -->
                        <div class="form-row">
                            <div class="form-group col-md-12">
                                <label>Course Description:</label>
                                <textarea class="form-control" rows="3" disabled>@Model.CourseDescription</textarea>
                            </div>
                        </div>

                        <!-- Year and Semester -->
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label>Year Taken:</label>
                                <input class="form-control" value="@Model.YearTaken" disabled />
                            </div>

                            <div class="form-group col-md-4">
                                <label>Period Taken:</label>
                                <input class="form-control" value="Period @Model.PeriodTakenLabel" disabled />
                            </div>

                            <div class="form-group col-md-4">
                                <label>Is this course mandatory?</label>
                                <input class="form-control" value="@(Model.IsMandatory ? "Yes" : "No")" disabled />
                            </div>
                        </div>

                        <!-- Courses Lecturers Section -->
                        <div class="form-row col-md-8 course-lecturers">
                            <div class="course-lecturers-title form-group row d-flex justify-content-center align-items-center col-md-12 mb-0" style="background-color: #2c3e50; border-radius: 10px 10px 0 0; height: 35px;">
                                <div class="col-md-2 text-white d-flex justify-content-center align-items-center">
                                    <input type="checkbox" id="header-check" class="mt-auto">
                                </div>
                                <div class="col-md-6 text-white d-flex justify-content-start align-items-center border-left">
                                    Lecturer
                                </div>
                                <div class="col-md-4 text-white d-flex justify-content-start align-items-center border-left">
                                    Role
                                </div>
                            </div>

                            <!-- Initial Lecturer Row -->
                            <div class="data-row form-group row d-flex justify-content-center align-items-center col-md-12" style="background-color: #ecf0f1; border-bottom: 1px solid #bdc3c7; height: 35px;">
                                <div class="col-md-2 d-flex justify-content-center align-items-center">
                                    <input type="checkbox" class="data-check">
                                </div>
                                <div class="col-md-6 d-flex justify-content-start align-items-center border-left">
                                    <select name="LecturerIds" class="form-control form-control-sm" asp-items="ViewBag.Lecturers">
                                        <option value="">Select Lecturer</option>
                                    </select>
                                </div>
                                <div class="col-md-4 d-flex justify-content-start align-items-center border-left">
                                    <input type="text" class="form-control form-control-sm" placeholder="" value="Lecturer" disabled>
                                </div>
                            </div>

                            <!-- Add/Remove Buttons -->
                            <div class="form-group row d-flex col-md-12 mt-2 add-rmv-btns-row">
                                <button type="button" class="btn btn-sm btn-primary d-flex justify-content-center align-items-center add-leturer-btn" id="add-leturer-btn">
                                    <i class="material-icons">add</i>
                                </button>
                                <div class="mx-1"></div>
                                <button type="button" class="btn btn-sm btn-outline-secondary d-flex justify-content-center align-items-center" id="rmv-leturer-btn">
                                    <i class="material-icons">remove</i>
                                </button>
                            </div>
                        </div>

                        <!-- Prerequisite Courses Section -->
                        <div class="form-row col-md-8 course-prerequisites">
                            <div class="prerequisite-header form-group row d-flex justify-content-center align-items-center col-md-12 mb-0" style="background-color: #2c3e50; border-radius: 10px 10px 0 0; height: 35px;">
                                <div class="col-md-2 text-white d-flex justify-content-center align-items-center">
                                    <input type="checkbox" id="prerequisite-check" class="mt-auto">
                                </div>
                                <div class="col-md-10 text-white d-flex justify-content-start align-items-center border-left">
                                    Prerequisite Course
                                </div>
                            </div>

                            <!-- Initial Prerequisite Row -->
                            <div class="prerequisite-data-row form-group row d-flex justify-content-center align-items-center col-md-12" style="background-color: #ecf0f1; border-bottom: 1px solid #bdc3c7; height: 35px;">
                                <div class="col-md-2 d-flex justify-content-center align-items-center">
                                    <input type="checkbox" class="prerequisite-data-check">
                                </div>
                                <div class="col-md-10 d-flex justify-content-start align-items-center border-left">
                                    <select name="PrerequisiteCourseIds" class="form-control form-control-sm" asp-items="ViewBag.Courses">
                                        <option value="">Select Course</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Add/Remove Buttons -->
                            <div class="form-group row d-flex col-md-12 mt-2 add-rmv-btns-row">
                                <button type="button" class="btn btn-sm btn-primary d-flex justify-content-center align-items-center" id="add-prerequisite-btn">
                                    <i class="material-icons">add</i>
                                </button>
                                <div class="mx-1"></div>
                                <button type="button" class="btn btn-sm btn-outline-secondary d-flex justify-content-center align-items-center" id="rmv-prerequisite-btn">
                                    <i class="material-icons">remove</i>
                                </button>
                            </div>
                        </div>

                        <!-- Delete Button -->
                        <button type="submit" class="btn btn-danger btn-block mt-4">Delete</button>

                        <!-- Back to List Button -->
                        <a asp-action="Courses" class="btn btn-outline-secondary btn-block mt-4">Back to List</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
