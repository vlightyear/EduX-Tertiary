@model SIS.Models.Admin.Course

<div class="h-[90vh] p-4">
    <!-- Header -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">school</i>
            Create Course
        </h1>
        <a asp-controller="Admin" asp-action="Courses"
               class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center">
            <i class="material-icons mr-2">arrow_back</i>
            Back
        </a>
    </div>

    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <div class="w-full">
            <div class="bg-white rounded-lg shadow-md p-4 overflow-auto h-full">
                <form asp-action="CreateCourse" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>

                    <!-- -- Row 1: Basic Info + Academic Details ------------------------ -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                        <!-- Basic Information -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-secondary-800 mb-4">Basic Information</h2>
                            <div class="space-y-4">
                                <div>
                                    <label asp-for="CourseCode" class="block text-sm font-medium text-gray-700 mb-1">Course Code</label>
                                    <input asp-for="CourseCode" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                                    <span asp-validation-for="CourseCode" class="text-sm text-red-600"></span>
                                </div>
                                <div>
                                    <label asp-for="CourseName" class="block text-sm font-medium text-gray-700 mb-1">Course Name</label>
                                    <input asp-for="CourseName" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                                    <span asp-validation-for="CourseName" class="text-sm text-red-600"></span>
                                </div>
                                <div>
                                    <label asp-for="CourseType" class="block text-sm font-medium text-gray-700 mb-1">Course Type</label>
                                    <select asp-for="CourseType" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                        <option value="">Select Course Type</option>
                                        <option value="Full Course">Full Course</option>
                                        <option value="Half Course">Half Course</option>
                                    </select>
                                    <span asp-validation-for="CourseType" class="text-sm text-red-600"></span>
                                </div>
                                <div>
                                    <label asp-for="CourseDescription" class="block text-sm font-medium text-gray-700 mb-1">Course Description</label>
                                    <textarea asp-for="CourseDescription" rows="3"
                                              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500"></textarea>
                                    <span asp-validation-for="CourseDescription" class="text-sm text-red-600"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Academic Details -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-secondary-800 mb-4">Academic Details</h2>
                            <div class="space-y-4">
                                <div>
                                    <label asp-for="ProgrammeID" class="block text-sm font-medium text-gray-700 mb-1">Programme</label>
                                    <select asp-for="ProgrammeID" asp-items="ViewBag.Programmes" id="programmeSelect"
                                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                        <option value="">Select Programme</option>
                                    </select>
                                    <span asp-validation-for="ProgrammeID" class="text-sm text-red-600"></span>
                                </div>
                                <div>
                                    <label asp-for="PassMark" class="block text-sm font-medium text-gray-700 mb-1">Pass Mark (%)</label>
                                    <input asp-for="PassMark" type="number" min="0" max="100" step="0.1"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                                    <span asp-validation-for="PassMark" class="text-sm text-red-600"></span>
                                </div>
                                <div>
                                    <label asp-for="YearTaken" class="block text-sm font-medium text-gray-700 mb-1">Year Taken</label>
                                    <input asp-for="YearTaken" type="number" min="1" max="6"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                                    <span asp-validation-for="YearTaken" class="text-sm text-red-600"></span>
                                </div>

                                <!-- Period Taken — populated from AcademicPeriods table,
                                     grouped by type via SelectListGroup in the controller.
                                     asp-items handles <optgroup> rendering automatically. -->
                                <div>
                                    <label asp-for="PeriodTakenId" class="block text-sm font-medium text-gray-700 mb-1">
                                        Period Taken
                                    </label>
                                    <select asp-for="PeriodTakenId"
                                            asp-items="ViewBag.AcademicPeriods"
                                            id="periodTakenSelect"
                                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                        <option value="">— select a period —</option>
                                    </select>
                                    <p class="text-xs text-gray-500 mt-1">
                                        <i class="material-icons text-xs align-middle">info</i>
                                        Periods are grouped by academic structure (Annual / Semester / Term).
                                    </p>
                                    <span asp-validation-for="PeriodTakenId" class="text-sm text-red-600"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- -- Row 2: Course Settings + Assessments ------------------------ -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                        <!-- Settings -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-secondary-800 mb-4">Course Settings</h2>
                            <div class="space-y-4">
                                <div>
                                    <label asp-for="IsMandatory" class="block text-sm font-medium text-gray-700 mb-1">Is this course mandatory?</label>
                                    <select asp-for="IsMandatory" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </select>
                                </div>
                                <div>
                                    <label asp-for="IsExaminable" class="block text-sm font-medium text-gray-700 mb-1">Is this course examinable?</label>
                                    <select asp-for="IsExaminable" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Assessments -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-secondary-800 flex items-center mb-4">
                                <i class="material-icons mr-2">assignment</i>Assessments
                            </h2>
                            <div class="border rounded-lg overflow-hidden">
                                <div class="bg-primary-900 text-white px-4 py-2 flex items-center">
                                    <div class="w-12 flex justify-center">
                                        <input type="checkbox" id="assessment-check" class="rounded">
                                    </div>
                                    <div class="flex-1">Assessment</div>
                                </div>
                                <div id="assessment-rows">
                                    <div class="assessment-row bg-gray-50 px-4 py-2 flex items-center border-b">
                                        <div class="w-12 flex justify-center">
                                            <input type="checkbox" class="assessment-data-check rounded">
                                        </div>
                                        <div class="flex-1">
                                            <select name="AssessmentIds"
                                                    class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                                <option value="">Select Assessment</option>
                                                @foreach (var item in ViewBag.Assessments)
                                                {
                                                    <option value="@item.Value">@item.Text</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="p-2 flex space-x-2">
                                    <button type="button" id="add-assessment-btn"
                                            class="p-1.5 bg-primary-600 text-white rounded hover:bg-primary-900 transition-colors">
                                        <i class="material-icons text-sm">add</i>
                                    </button>
                                    <button type="button" id="remove-assessment-btn"
                                            class="p-1.5 text-gray-700 border border-gray-300 rounded hover:bg-gray-100 transition-colors">
                                        <i class="material-icons text-sm">remove</i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- -- Timetabling Details ------------------------------------------ -->
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <h2 class="text-lg font-semibold text-secondary-800 flex items-center mb-4">
                            <i class="material-icons mr-2">schedule</i>Timetabling Details
                        </h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label asp-for="InstructorId" class="block text-sm font-medium text-gray-700 mb-1">Course Instructor</label>
                                <select asp-for="InstructorId" asp-items="ViewBag.Instructors"
                                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                    <option value="">Select Instructor</option>
                                </select>
                                <span asp-validation-for="InstructorId" class="text-sm text-red-600"></span>
                            </div>
                            <div>
                                <label asp-for="MeetingFrequencyPerWeek" class="block text-sm font-medium text-gray-700 mb-1">Meetings Per Week</label>
                                <input asp-for="MeetingFrequencyPerWeek" type="number" min="1" max="7" value="1"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                                <span asp-validation-for="MeetingFrequencyPerWeek" class="text-sm text-red-600"></span>
                            </div>
                            <div>
                                <label asp-for="CapacityRequired" class="block text-sm font-medium text-gray-700 mb-1">Required Capacity</label>
                                <input asp-for="CapacityRequired" type="number" min="1" value="30"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500" />
                                <span asp-validation-for="CapacityRequired" class="text-sm text-red-600"></span>
                            </div>
                            <div>
                                <label for="PreferredVenues" class="block text-sm font-medium text-gray-700 mb-1">Preferred Venues</label>
                                <select multiple id="PreferredVenues" name="PreferredVenues" size="4"
                                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                    @foreach (var item in ViewBag.Venues)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <p class="text-sm text-gray-500 mt-1">Hold Ctrl/Cmd to select multiple venues</p>
                            </div>
                        </div>
                    </div>

                    <!-- -- Lecturers + Prerequisites ------------------------------------ -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                        <!-- Lecturers -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-secondary-800 flex items-center mb-4">
                                <i class="material-icons mr-2">person</i>Course Lecturers
                            </h2>
                            <div class="border rounded-lg overflow-hidden">
                                <div class="bg-primary-900 text-white px-4 py-2 grid grid-cols-12 items-center">
                                    <div class="col-span-2 flex justify-center">
                                        <input type="checkbox" id="lecturer-check" class="rounded">
                                    </div>
                                    <div class="col-span-6">Lecturer</div>
                                    <div class="col-span-4">Role</div>
                                </div>
                                <div id="lecturer-rows">
                                    <div class="lecturer-row bg-gray-50 px-4 py-2 grid grid-cols-12 items-center border-b">
                                        <div class="col-span-2 flex justify-center">
                                            <input type="checkbox" class="lecturer-data-check rounded">
                                        </div>
                                        <div class="col-span-6">
                                            <select name="LecturerIds"
                                                    class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                                <option value="">Select Lecturer</option>
                                                @foreach (var item in ViewBag.Lecturers)
                                                {
                                                    <option value="@item.Value">@item.Text</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-span-4">
                                            <input type="text" value="Lecturer" disabled
                                                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg bg-gray-100" />
                                        </div>
                                    </div>
                                </div>
                                <div class="p-2 flex space-x-2">
                                    <button type="button" id="add-lecturer-btn"
                                            class="p-1.5 bg-primary-600 text-white rounded hover:bg-primary-900 transition-colors">
                                        <i class="material-icons text-sm">add</i>
                                    </button>
                                    <button type="button" id="remove-lecturer-btn"
                                            class="p-1.5 text-gray-700 border border-gray-300 rounded hover:bg-gray-100 transition-colors">
                                        <i class="material-icons text-sm">remove</i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Prerequisites -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-secondary-800 flex items-center mb-4">
                                <i class="material-icons mr-2">list</i>Prerequisites
                            </h2>
                            <div class="border rounded-lg overflow-hidden">
                                <div class="bg-primary-900 text-white px-4 py-2 flex items-center">
                                    <div class="w-12 flex justify-center">
                                        <input type="checkbox" id="prerequisite-check" class="rounded">
                                    </div>
                                    <div class="flex-1">Prerequisite Course</div>
                                </div>
                                <div id="prerequisite-rows">
                                    <div class="prerequisite-row bg-gray-50 px-4 py-2 flex items-center border-b">
                                        <div class="w-12 flex justify-center">
                                            <input type="checkbox" class="prerequisite-data-check rounded">
                                        </div>
                                        <div class="flex-1">
                                            <select name="PrerequisiteCourseIds"
                                                    class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                                                <option value="">Select Course</option>
                                                @foreach (var item in ViewBag.Courses)
                                                {
                                                    <option value="@item.Value">@item.Text</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="p-2 flex space-x-2">
                                    <button type="button" id="add-prerequisite-btn"
                                            class="p-1.5 bg-primary-600 text-white rounded hover:bg-primary-900 transition-colors">
                                        <i class="material-icons text-sm">add</i>
                                    </button>
                                    <button type="button" id="remove-prerequisite-btn"
                                            class="p-1.5 text-gray-700 border border-gray-300 rounded hover:bg-gray-100 transition-colors">
                                        <i class="material-icons text-sm">remove</i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="flex justify-end">
                        <button type="submit"
                                class="px-6 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center">
                            <i class="material-icons mr-2">save</i>Create Course
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        // -- Dynamic row management ------------------------------------------------
        // Shared helper: wires up add/remove/select-all for lecturer, assessment,
        // and prerequisite rows without duplicating the logic three times.
        function setupRowManager(containerId, checkAllId, addBtnId, removeBtnId, rowClass, checkClass) {
            const container = document.getElementById(containerId);
            const checkAll  = document.getElementById(checkAllId);
            const addBtn    = document.getElementById(addBtnId);
            const removeBtn = document.getElementById(removeBtnId);

            if (!container) return;

            addBtn?.addEventListener('click', function () {
                const firstRow = container.querySelector('.' + rowClass);
                if (!firstRow) return;
                const clone = firstRow.cloneNode(true);
                clone.querySelector('.' + checkClass).checked = false;
                clone.querySelectorAll('select').forEach(s => s.value = '');
                container.appendChild(clone);
            });

            removeBtn?.addEventListener('click', function () {
                const checked = container.querySelectorAll('.' + checkClass + ':checked');
                if (!checked.length) {
                    window.showAppToast('Please select at least one row to remove.');
                    return;
                }
                if (container.querySelectorAll('.' + rowClass).length <= 1) {
                    window.showAppToast('You must keep at least one row.');
                    return;
                }
                checked.forEach(cb => cb.closest('.' + rowClass).remove());
            });

            checkAll?.addEventListener('change', function () {
                container.querySelectorAll('.' + checkClass)
                         .forEach(cb => { cb.checked = this.checked; });
            });
        }

        setupRowManager('lecturer-rows',     'lecturer-check',     'add-lecturer-btn',     'remove-lecturer-btn',     'lecturer-row',     'lecturer-data-check');
        setupRowManager('assessment-rows',   'assessment-check',   'add-assessment-btn',   'remove-assessment-btn',   'assessment-row',   'assessment-data-check');
        setupRowManager('prerequisite-rows', 'prerequisite-check', 'add-prerequisite-btn', 'remove-prerequisite-btn', 'prerequisite-row', 'prerequisite-data-check');

        // -- Optional: narrow the period dropdown when a programme is chosen -------
        // The select is already fully populated server-side with all active periods
        // grouped by type.  This layer optionally re-fetches a filtered list when
        // the user picks a programme, so only compatible periods remain visible.
        // If the request fails, the full list is simply kept — the server validates
        // PeriodTakenId on POST regardless.

        const periodSelect    = document.getElementById('periodTakenSelect');
        const programmeSelect = document.getElementById('programmeSelect');

        // Snapshot the full option list before any filtering touches it
        const allOptionsHTML = periodSelect ? periodSelect.innerHTML : '';

        if (programmeSelect && periodSelect) {
            programmeSelect.addEventListener('change', async function () {
                const programmeId = this.value;

                if (!programmeId) {
                    periodSelect.innerHTML = allOptionsHTML;
                    return;
                }

                try {
                    const res  = await fetch('/Admin/GetPeriodsByProgramme?schoolId=' + programmeId);
                    const data = await res.json();

                    // data is [{value, text}] from GetProgrammesBySchool — reuse if
                    // you already have a programme?periods endpoint, or add GetPeriodsByType.
                    // Here we just restore the full list since GetPeriodsByProgramme
                    // returns programmes, not periods. Replace the URL below with your
                    // actual periods-by-programme endpoint if you build one.
                    // For now, keep the full list — the server will validate.
                } catch {
                    // Network error — keep the full server-rendered list
                }
            });
        }

        // -- Client-side submit guard ----------------------------------------------
        document.querySelector('form')?.addEventListener('submit', function (e) {
            let valid = true;

            // Check all required fields
            this.querySelectorAll('[required]').forEach(function (field) {
                if (!field.value.trim()) {
                    valid = false;
                    field.classList.add('border-red-500');
                    const next = field.nextElementSibling;
                    if (next && next.classList.contains('text-red-600')) {
                        next.textContent = 'This field is required.';
                    }
                } else {
                    field.classList.remove('border-red-500');
                    const next = field.nextElementSibling;
                    if (next && next.classList.contains('text-red-600') &&
                        next.textContent === 'This field is required.') {
                        next.textContent = '';
                    }
                }
            });

            // At least one lecturer must be selected
            const lecturerSelects = Array.from(this.querySelectorAll('select[name="LecturerIds"]'));
            if (!lecturerSelects.some(function (s) { return s.value !== ''; })) {
                valid = false;
                window.showAppToast('Please select at least one lecturer for this course.');
            }

            // Period must be selected
            if (!periodSelect || !periodSelect.value) {
                valid = false;
                window.showAppToast('Please select the period in which this course is taught.');
            }

            if (!valid) { e.preventDefault(); }
        });
    });
</script>
