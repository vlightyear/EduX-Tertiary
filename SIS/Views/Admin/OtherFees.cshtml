                                    <option value="">All Schools</option>
                                    @foreach (var school in ViewBag.Schools)
                                    {
                                        <option value="@school.Value">@school.Text</option>
                                    }
                                </select>
                                <label for="updateSchoolId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    School</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ProgrammeId" id="updateProgrammeId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Programmes</option>
                                    @foreach (var programme in ViewBag.Programmes)
                                    {
                                        <option value="@programme.Value">@programme.Text</option>
                                    }
                                </select>
                                <label for="updateProgrammeId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Programme</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ModeOfStudyId" id="updateModeOfStudyId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Modes</option>
                                    @foreach (var mode in ViewBag.ModesOfStudy)
                                    {
                                        <option value="@mode.Value">@mode.Text</option>
                                    }
                                </select>
                                <label for="updateModeOfStudyId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Mode of Study</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ProgramLevelId" id="updateProgramLevelId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Levels</option>
                                    @foreach (var level in ViewBag.ProgramLevels)
                                    {
                                        <option value="@level.Value">@level.Text</option>
                                    }
                                </select>
                                <label for="updateProgramLevelId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Programme Level</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="text" name="CreditNCode" id="updateCreditNCode" maxlength="20"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " />
                                <label for="updateCreditNCode" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Credit N-Code</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="text" name="DebitNCode" id="updateDebitNCode" maxlength="20"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " />
                                <label for="updateDebitNCode" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Debit N-Code</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <label class="block text-xs font-medium text-secondary-600 mb-1">Student Type</label>
                                <select id="filterStudentType" onchange="applyFilters()"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Types</option>
                                    <option value="true">Foreign Students</option>
                                    <option value="false">Local Students</option>
                                </select>
                            </div>

                        </div>
                    </form>
                </div>

                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3 sticky bottom-0">
                    <button type="button"
                            class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300"
                            data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmUpdate"
                            class="px-4 py-2 text-white rounded-lg transition-colors flex items-center shadow-md"
                            style="background-color: #334155;"
                            onmouseenter="this.style.backgroundColor='#1e293b'"
                            onmouseleave="this.style.backgroundColor='#334155'">
                        <i class="material-icons mr-1">save</i>Update
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

