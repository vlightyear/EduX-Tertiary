                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " required />
                                <label for="updateAmount" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Amount (ZMW) *</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="AcademicYearId" id="updateAcademicYearId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Academic Years</option>
                                    @foreach (var year in ViewBag.AcademicYears)
                                    {
                                        <option value="@year.Value">@year.Text</option>
                                    }
                                </select>
                                <label for="updateAcademicYearId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Academic Year</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="YearPeriodId" id="updateYearPeriodId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Periods</option>
                                    @foreach (var period in ViewBag.YearPeriods)
                                    {
                                        <option value="@period.Value">@period.Text</option>
                                    }
                                </select>
                                <label for="updateYearPeriodId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
