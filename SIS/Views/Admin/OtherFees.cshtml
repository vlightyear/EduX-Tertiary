@using SIS.Models.Fees
@model IEnumerable<OtherFees>

@{
    ViewData["Title"] = "Other Fees Configuration";
}

<div class="min-h-screen p-4">
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-primary-800 flex items-center">
            <i class="material-icons mr-2 text-primary-600">receipt_long</i>
            Other Fees Configuration
        </h1>
        <button type="button"
                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors flex items-center shadow-md hover:shadow-lg"
                onclick="showCreateFeeModal()">
            <i class="material-icons mr-2">add</i>
            Create Other Fee
        </button>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-4">
        <div class="xl:col-span-3">
            <div class="bg-white rounded-lg shadow-lg overflow-hidden border border-gray-100">
                <div class="p-4 bg-gray-50 border-b border-gray-200">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-sm font-semibold text-gray-700 flex items-center">
                            <i class="material-icons text-sm mr-2">filter_list</i>
                            Filters
                        </h3>
                        <button onclick="clearFilters()"
                                class="text-xs px-3 py-1 text-primary-600 hover:bg-primary-50 rounded-lg transition-colors flex items-center">
                            <i class="material-icons text-sm mr-1">clear</i>
                            Clear All
                        </button>
                    </div>

                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-600 mb-1">Academic Year</label>
                            <select id="filterAcademicYear"
                                    onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                <option value="">All Years</option>
                                @foreach (var year in ViewBag.AcademicYears)
                                {
                                    <option value="@year.Value">@year.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-600 mb-1">Semester</label>
                            <select id="filterSemester"
                                    onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                <option value="">All Semesters</option>
                                <option value="1">Semester 1</option>
                                <option value="2">Semester 2</option>
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-600 mb-1">School</label>
                            <select id="filterSchool"
                                    onchange="onSchoolFilterChange(); applyFilters();"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                <option value="">All Schools</option>
                                @foreach (var school in ViewBag.Schools)
                                {
                                    <option value="@school.Value">@school.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-600 mb-1">Programme</label>
                            <select id="filterProgramme"
                                    onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                <option value="">All Programmes</option>
                                @foreach (var programme in ViewBag.Programmes)
                                {
                                    <option value="@programme.Value">@programme.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-600 mb-1">Mode of Study</label>
                            <select id="filterMode"
                                    onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                <option value="">All Modes</option>
                                @foreach (var mode in ViewBag.ModesOfStudy)
                                {
                                    <option value="@mode.Value">@mode.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-600 mb-1">Program Level</label>
                            <select id="filterLevel"
                                    onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                <option value="">All Levels</option>
                                @foreach (var level in ViewBag.ProgramLevels)
                                {
                                    <option value="@level.Value">@level.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-600 mb-1">Student Type</label>
                            <select id="filterStudentType"
                                    onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                <option value="">All Types</option>
                                <option value="true">Foreign Students</option>
                                <option value="false">Local Students</option>
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-600 mb-1">Search</label>
                            <input type="text" id="searchTerm"
                                   onkeyup="applyFilters()"
                                   placeholder="Search fee name..."
                                   class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                        </div>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <div class="inline-block min-w-full align-middle">
                        <div class="overflow-hidden">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-primary-50">
                                    <tr>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">#</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">Fee Name</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">Student Type</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">Academic Year</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">Semester</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">School</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">Programme</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">Mode/Level</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">Amount</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-primary-700 uppercase tracking-wider">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="feeTableBody" class="bg-white divide-y divide-gray-200">
                                    <tr>
                                        <td colspan="10" class="px-6 py-8 text-center text-gray-500">
                                            <div class="flex flex-col items-center">
                                                <i class="material-icons text-4xl text-gray-300 mb-2 animate-spin">refresh</i>
                                                <p class="text-lg font-medium">Loading other fees...</p>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="border-t border-gray-200 px-4 py-3 bg-gray-50">
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                        <div class="flex items-center gap-2">
                            <label class="text-xs text-gray-600">Rows per page:</label>
                            <select id="pageSize"
                                    onchange="changePageSize()"
                                    class="px-2 py-1 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>

                        <div id="paginationInfo" class="text-xs text-gray-600">
                        </div>

                        <div id="paginationControls" class="flex gap-1">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="xl:col-span-1">
            <div class="space-y-4">
                <div class="bg-white rounded-lg shadow-lg p-4 border border-gray-100">
                    <h3 class="text-base font-bold text-gray-800 mb-4 flex items-center">
                        <i class="material-icons text-primary-600 mr-2 text-lg">analytics</i>
                        Statistics
                    </h3>
                    <div class="space-y-3">
                        <div class="flex items-center p-2 bg-primary-50 rounded-lg border border-primary-100">
                            <div class="p-2 bg-primary-100 rounded-lg">
                                <i class="material-icons text-primary-600 text-lg">receipt_long</i>
                            </div>
                            <div class="ml-3">
                                <p class="text-gray-600 text-xs font-medium">Total Fees</p>
                                <p id="statTotalFees" class="text-xl font-bold text-primary-700">0</p>
                            </div>
                        </div>

                        <div class="flex items-center p-2 bg-purple-50 rounded-lg border border-purple-100">
                            <div class="p-2 bg-purple-100 rounded-lg">
                                <i class="material-icons text-purple-600 text-lg">language</i>
                            </div>
                            <div class="ml-3">
                                <p class="text-gray-600 text-xs font-medium">Foreign Student Fees</p>
                                <p id="statForeignFees" class="text-xl font-bold text-purple-700">0</p>
                            </div>
                        </div>

                        <div class="flex items-center p-2 bg-secondary-50 rounded-lg border border-secondary-100">
                            <div class="p-2 bg-secondary-100 rounded-lg">
                                <i class="material-icons text-secondary-600 text-lg">person</i>
                            </div>
                            <div class="ml-3">
                                <p class="text-gray-600 text-xs font-medium">Local Student Fees</p>
                                <p id="statStandardFees" class="text-xl font-bold text-secondary-700">0</p>
                            </div>
                        </div>

                        <div class="flex items-center p-2 bg-blue-50 rounded-lg border border-blue-100">
                            <div class="p-2 bg-blue-100 rounded-lg">
                                <i class="material-icons text-blue-600 text-lg">looks_one</i>
                            </div>
                            <div class="ml-3">
                                <p class="text-gray-600 text-xs font-medium">Semester 1 Fees</p>
                                <p id="statSemester1Fees" class="text-xl font-bold text-blue-700">0</p>
                            </div>
                        </div>

                        <div class="flex items-center p-2 bg-green-50 rounded-lg border border-green-100">
                            <div class="p-2 bg-green-100 rounded-lg">
                                <i class="material-icons text-green-600 text-lg">looks_two</i>
                            </div>
                            <div class="ml-3">
                                <p class="text-gray-600 text-xs font-medium">Semester 2 Fees</p>
                                <p id="statSemester2Fees" class="text-xl font-bold text-green-700">0</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow-lg p-4 border border-gray-100">
                    <h3 class="text-base font-bold text-gray-800 mb-3 flex items-center">
                        <i class="material-icons text-primary-600 mr-2 text-lg">donut_large</i>
                        Fee Distribution
                    </h3>
                    <div id="fee-chart" style="min-height: 200px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div id="createFeeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-4xl border border-gray-200 max-h-[90vh] overflow-y-auto">
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between sticky top-0 z-10">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create Other Fee
                    </h3>
                    <button type="button" class="text-white hover:text-primary-200 transition-colors" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <div class="p-6">
                    <form id="createFeeForm" method="post" action="/Admin/CreateOtherFee">
                        @Html.AntiForgeryToken()

                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            <div class="relative z-0 w-full group">
                                <input type="text" name="FeeName" id="feeName"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                       placeholder=" " required maxlength="200" />
                                <label for="feeName" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Fee Name *
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="number" name="Amount" id="amount" step="0.01" min="0"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                       placeholder=" " required />
                                <label for="amount" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Amount (ZMW) *
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="AppliesOnlyToForeignStudents" id="appliesOnlyToForeignStudents"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer">
                                    <option value="false">Local Students</option>
                                    <option value="true">Foreign Students</option>
                                </select>
                                <label for="appliesOnlyToForeignStudents" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Student Type *
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="AcademicYearId" id="academicYearId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer">
                                    <option value="">All Academic Years</option>
                                    @foreach (var year in ViewBag.AcademicYears)
                                    {
                                        <option value="@year.Value">@year.Text</option>
                                    }
                                </select>
                                <label for="academicYearId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Academic Year
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="Semester" id="semester"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer">
                                    <option value="">Both Semesters</option>
                                    <option value="1">Semester 1</option>
                                    <option value="2">Semester 2</option>
                                </select>
                                <label for="semester" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Semester
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="SchoolId" id="schoolId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                        onchange="loadProgrammesBySchool(this.value, 'programmeId')">
                                    <option value="">All Schools</option>
                                    @foreach (var school in ViewBag.Schools)
                                    {
                                        <option value="@school.Value">@school.Text</option>
                                    }
                                </select>
                                <label for="schoolId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    School
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ProgrammeId" id="programmeId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer">
                                    <option value="">All Programmes</option>
                                </select>
                                <label for="programmeId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Programme
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ModeOfStudyId" id="modeOfStudyId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer">
                                    <option value="">All Modes</option>
                                    @foreach (var mode in ViewBag.ModesOfStudy)
                                    {
                                        <option value="@mode.Value">@mode.Text</option>
                                    }
                                </select>
                                <label for="modeOfStudyId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Mode of Study
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ProgramLevelId" id="programLevelId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer">
                                    <option value="">All Levels</option>
                                    @foreach (var level in ViewBag.ProgramLevels)
                                    {
                                        <option value="@level.Value">@level.Text</option>
                                    }
                                </select>
                                <label for="programLevelId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Programme Level
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="text" name="CreditNCode" id="creditNCode" maxlength="20"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                       placeholder=" " />
                                <label for="creditNCode" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Credit N-Code
                                </label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="text" name="DebitNCode" id="debitNCode" maxlength="20"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                       placeholder=" " />
                                <label for="debitNCode" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Debit N-Code
                                </label>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3 sticky bottom-0">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="createFeeButton" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors flex items-center shadow-md">
                        <i class="material-icons mr-1">save</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Modal -->
<div id="updateFeeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-4xl border border-gray-200 max-h-[90vh] overflow-y-auto">
                <div class="bg-secondary-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between sticky top-0 z-10">
                    <h3 class="text-lg font-semibold flex items-center">
<!-- Update Modal -->
<div id="updateFeeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-4xl border border-gray-200 max-h-[90vh] overflow-y-auto">
                <div class="bg-secondary-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between sticky top-0 z-10">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">edit</i>
                        Update Other Fee
                    </h3>
                    <button type="button" class="text-white hover:text-secondary-200 transition-colors" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
