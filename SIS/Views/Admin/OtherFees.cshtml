@section Scripts {
    <script>
        let currentPage = 1;
        let pageSize = 10;
        let totalRecords = 0;

        document.addEventListener('DOMContentLoaded', function () {
            loadOtherFees();
            initializeModals();
            loadStatistics();
        });

        async function loadOtherFees() {
            try {
                const filterData = {
                    page: currentPage,
                    pageSize: pageSize,
                    sortColumn: 'FeeName',
                    sortDirection: 'asc',
                    academicYearId: getFilterValue('filterAcademicYear'),
                    yearPeriodId: getFilterValue('filterYearPeriod'),
                    schoolId: getFilterValue('filterSchool'),
                    programmeId: getFilterValue('filterProgramme'),
                    modeOfStudyId: getFilterValue('filterMode'),
                    programLevelId: getFilterValue('filterLevel'),
                    studentType: document.getElementById('filterStudentType')?.value || null,
                    searchTerm: document.getElementById('searchTerm')?.value || null
                };

                const response = await fetch('/Admin/GetOtherFeesData', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(filterData)
                });

                const data = await response.json();

                if (data.fees) {
                    renderFees(data.fees);
                    updatePagination(data.totalRecords, data.totalPages, data.currentPage);
                    totalRecords = data.totalRecords;
                }
            } catch (error) {
                console.error('Error loading fees:', error);
                showError('Failed to load other fees');
            }
        }

        function getFilterValue(elementId) {
            const element = document.getElementById(elementId);
            const value = element?.value;
            return value && value !== '' ? parseInt(value) : null;
        }

        // ── Two-level grouping: School → Programme ─────────────────────
        function renderFees(fees) {
            const tbody = document.getElementById('feeTableBody');

            if (fees.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="10" class="px-6 py-8 text-center text-gray-500">
                            <div class="flex flex-col items-center">
                                <i class="material-icons text-4xl text-gray-300 mb-2">receipt_long</i>
                                <p class="text-lg font-medium">No fees found</p>
                                <p class="text-sm">Try adjusting your filters or create a new fee</p>
                            </div>
                        </td>
                    </tr>`;
                return;
            }

            // Build School → Programme → [fees] map
            const schoolMap = new Map();
            fees.forEach(f => {
                const school = f.schoolName || 'General / All Schools';
                const prog   = f.programmeName || 'All Programmes';
                if (!schoolMap.has(school)) schoolMap.set(school, new Map());
                const progMap = schoolMap.get(school);
                if (!progMap.has(prog)) progMap.set(prog, []);
                progMap.get(prog).push(f);
            });

            let html = '';

            schoolMap.forEach((progMap, school) => {
                // Count fees in this school for the badge
                let schoolTotal = 0;
                progMap.forEach(arr => schoolTotal += arr.length);

                // ── School header ─────────────────────────────────────
                html += `
                    <tr data-group-header="school" style="background-color: #1e293b;">
                        <td colspan="10" class="px-4 py-2.5">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <i class="material-icons text-sm" style="color: #e85c5c;">account_balance</i>
                                    <span class="text-sm font-semibold text-white">${school}</span>
                                </div>
                                <span class="text-xs font-medium px-2 py-0.5 rounded-full"
                                      style="background-color: rgba(232,92,92,0.2); color: #fca5a5;">
                                    ${schoolTotal} ${schoolTotal === 1 ? 'fee' : 'fees'}
                                </span>
                            </div>
                        </td>
                    </tr>`;

                progMap.forEach((feeList, prog) => {
                    // ── Programme sub-header ───────────────────────────
                    html += `
                        <tr data-group-header="programme" style="background-color: #fef2f2; border-left: 3px solid #e85c5c;">
                            <td colspan="10" class="px-4 py-2">
                                <div class="flex items-center justify-between pl-5">
                                    <div class="flex items-center gap-2">
                                        <i class="material-icons text-sm" style="color: #c53030;">school</i>
                                        <span class="text-xs font-semibold" style="color: #9b2c2c;">${prog}</span>
                                    </div>
                                    <span class="text-xs px-2 py-0.5 rounded-full font-medium"
                                          style="background-color: #fee2e2; color: #c53030;">
                                        ${feeList.length} ${feeList.length === 1 ? 'fee' : 'fees'}
                                    </span>
                                </div>
                            </td>
                        </tr>`;

                    // ── Data rows ──────────────────────────────────────
                    feeList.forEach(f => {
                        html += `
                            <tr class="hover:bg-gray-50 transition-colors border-l-2 border-transparent hover:border-l-2"
                                style="border-left-color: transparent;"
                                onmouseenter="this.style.borderLeftColor='#e85c5c'"
                                onmouseleave="this.style.borderLeftColor='transparent'">
                                <td class="px-3 py-3 text-sm text-secondary-600 pl-8">${f.rowNumber}</td>
                                <td class="px-3 py-3 text-sm">
                                    <span class="font-medium text-gray-900">${f.feeName}</span>
                                </td>
                                <td class="px-3 py-3 text-sm">
                                    <span class="px-2 py-1 text-xs rounded-full font-medium"
                                          style="background-color: #fee2e2; color: #c53030;">
                                        ${f.studentType}
                                    </span>
                                </td>
                                <td class="px-3 py-3 text-sm">
                                    <span class="px-2 py-1 text-xs rounded-full font-medium"
                                          style="background-color: #fef2f2; color: #e85c5c;">
                                        ${f.academicYear}
                                    </span>
                                </td>
                                <td class="px-3 py-3 text-sm">
                                    ${f.yearPeriodId
                                        ? `<span class="px-2 py-1 text-xs bg-green-100 text-green-700 rounded-full font-medium">${f.periodLabel}</span>`
                                        : `<span class="px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded-full font-medium">All Periods</span>`
                                    }
                                </td>
                                <td class="px-3 py-3 text-sm text-gray-700">${f.schoolName}</td>
                                <td class="px-3 py-3 text-sm text-gray-700">${f.programmeName}</td>
                                <td class="px-3 py-3 text-xs">
                                    <div>${f.modeName}</div>
                                    <div class="text-gray-500">${f.levelName}</div>
                                </td>
                                <td class="px-3 py-3 text-sm">
                                    <span class="font-bold text-gray-900">
                                        K${f.amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                                    </span>
                                </td>
                                <td class="px-3 py-3 text-sm">
                                    <div class="flex gap-1">
                                        <button onclick='showUpdateFeeModal(${JSON.stringify(f).replace(/'/g, "&#39;")})'
                                                class="inline-flex items-center px-2 py-1 text-xs rounded transition-colors"
                                                style="color: #e85c5c; background-color: #fef2f2;"
                                                onmouseenter="this.style.backgroundColor='#fee2e2'"
                                                onmouseleave="this.style.backgroundColor='#fef2f2'">
                                            <i class="material-icons text-sm">edit</i>
                                        </button>
                                        <button onclick="showDeleteFeeModal(${f.id}, '${f.feeName.replace(/'/g, "\\'")}', 'K${f.amount.toFixed(2)}')"
                                                class="inline-flex items-center px-2 py-1 text-xs text-red-700 bg-red-50 hover:bg-red-100 rounded transition-colors">
                                            <i class="material-icons text-sm">delete</i>
                                        </button>
                                    </div>
                                </td>
                            </tr>`;
                    });
                });
            });

            tbody.innerHTML = html;
        }

        function updatePagination(total, totalPages, current) {
            const startRecord = (current - 1) * pageSize + 1;
            const endRecord = Math.min(current * pageSize, total);

            document.getElementById('paginationInfo').innerHTML =
                `${startRecord}-${endRecord} of ${total}`;

            const controls = document.getElementById('paginationControls');
            let html = '';

            html += `
                <button onclick="changePage(${current - 1})"
                        ${current === 1 ? 'disabled' : ''}
                        class="px-2 py-1 text-xs ${current === 1 ? 'text-gray-400 cursor-not-allowed' : 'text-secondary-600 hover:bg-gray-100'} rounded transition-colors">
                    <i class="material-icons text-sm">chevron_left</i>
                </button>`;

            const maxVisiblePages = 3;
            let startPage = Math.max(1, current - Math.floor(maxVisiblePages / 2));
            let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
            if (endPage - startPage < maxVisiblePages - 1) {
                startPage = Math.max(1, endPage - maxVisiblePages + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const isActive = i === current;
                html += `
                    <button onclick="changePage(${i})"
                            class="px-2 py-1 text-xs rounded transition-colors font-${isActive ? 'semibold' : 'normal'}"
                            style="${isActive ? 'background-color:#fef2f2; color:#e85c5c;' : 'color:#475569;'}"
                            ${isActive ? '' : 'onmouseenter="this.style.backgroundColor=\'#f1f5f9\'" onmouseleave="this.style.backgroundColor=\'\'"'}>
                        ${i}
                    </button>`;
            }

            html += `
                <button onclick="changePage(${current + 1})"
                        ${current === totalPages ? 'disabled' : ''}
                        class="px-2 py-1 text-xs ${current === totalPages ? 'text-gray-400 cursor-not-allowed' : 'text-secondary-600 hover:bg-gray-100'} rounded transition-colors">
                    <i class="material-icons text-sm">chevron_right</i>
                </button>`;

            controls.innerHTML = html;
        }

        function changePage(page) {
            if (page < 1 || page > Math.ceil(totalRecords / pageSize)) return;
            currentPage = page;
            loadOtherFees();
        }

        function changePageSize() {
            pageSize = parseInt(document.getElementById('pageSize').value);
            currentPage = 1;
            loadOtherFees();
        }

        function applyFilters() {
            currentPage = 1;
            loadOtherFees();
        }

        function clearFilters() {
            document.getElementById('filterAcademicYear').value = '';
            document.getElementById('filterYearPeriod').value = '';
            document.getElementById('filterSchool').value = '';
            document.getElementById('filterProgramme').value = '';
            document.getElementById('filterMode').value = '';
            document.getElementById('filterLevel').value = '';
            document.getElementById('filterStudentType').value = '';
            document.getElementById('searchTerm').value = '';
            applyFilters();
        }

        function onSchoolFilterChange() {
            const schoolId = document.getElementById('filterSchool').value;
            const programmeSelect = document.getElementById('filterProgramme');
            if (!schoolId) return;

            fetch(`/Admin/GetProgrammesBySchool?schoolId=${schoolId}`)
                .then(r => r.json())
                .then(data => {
                    programmeSelect.innerHTML = '<option value="">All Programmes</option>';
                    data.forEach(p => {
                        const opt = document.createElement('option');
                        opt.value = p.value;
                        opt.textContent = p.text;
                        programmeSelect.appendChild(opt);
                    });
                })
                .catch(err => console.error('Error loading programmes:', err));
        }

        async function loadStatistics() {
            try {
                const response = await fetch('/Admin/GetOtherFeesStatistics');
                const data = await response.json();
                if (data) {
                    document.getElementById('statTotalFees').textContent = data.totalFees || 0;
                    document.getElementById('statForeignFees').textContent = data.foreignFees || 0;
                    document.getElementById('statStandardFees').textContent = data.standardFees || 0;
                    if (data.chartData && typeof ApexCharts !== 'undefined') renderChart(data.chartData);
                }
            } catch (error) {
                console.error('Error loading statistics:', error);
            }
        }

        function renderChart(chartData) {
            const chart = new ApexCharts(document.querySelector("#fee-chart"), {
                series: chartData.series,
                chart: { type: 'donut', height: 250, fontFamily: 'inherit' },
                labels: chartData.labels,
                colors: ['#e85c5c', '#c53030', '#9b2c2c', '#f87171'],
                plotOptions: {
                    pie: { donut: { size: '65%', labels: { show: true, total: { show: true, label: 'Total', fontSize: '12px', fontWeight: 500, color: '#6b7280' } } } }
                },
                dataLabels: { enabled: false },
                legend: { show: false },
                stroke: { width: 2, colors: ['#ffffff'] }
            });
            chart.render();
        }

        function showError(message) {
            document.getElementById('feeTableBody').innerHTML = `
                <tr>
                    <td colspan="10" class="px-6 py-8 text-center text-red-500">
                        <div class="flex flex-col items-center">
                            <i class="material-icons text-4xl text-red-300 mb-2">error_outline</i>
                            <p class="text-lg font-medium">${message}</p>
                            <button onclick="loadOtherFees()"
                                    class="mt-4 px-4 py-2 text-white rounded-lg"
                                    style="background-color:#e85c5c;"
                                    onmouseenter="this.style.backgroundColor='#c53030'"
                                    onmouseleave="this.style.backgroundColor='#e85c5c'">
                                Retry
                            </button>
                        </div>
                    </td>
                </tr>`;
        }

        function initializeModals() {
            const createFeeModal  = document.getElementById('createFeeModal');
            const updateFeeModal  = document.getElementById('updateFeeModal');
            const deleteFeeModal  = document.getElementById('deleteFeeModal');
            const createFeeForm   = document.getElementById('createFeeForm');
            const updateFeeForm   = document.getElementById('updateFeeForm');
            const deleteFeeForm   = document.getElementById('deleteFeeForm');
            const createFeeButton = document.getElementById('createFeeButton');
            const confirmUpdateBtn = document.getElementById('confirmUpdate');
            const confirmDeleteBtn = document.getElementById('confirmDelete');

            function showModal(m) { m.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
            function hideModal(m) { m.classList.add('hidden');    document.body.style.overflow = 'auto'; }

            function setupModalCloseHandlers(m) {
                m.addEventListener('click', e => { if (e.target === m) hideModal(m); });
                m.querySelectorAll('[data-bs-dismiss="modal"]').forEach(btn => {
                    btn.addEventListener('click', () => hideModal(m));
                });
            }

            [createFeeModal, updateFeeModal, deleteFeeModal].forEach(setupModalCloseHandlers);

            window.showCreateFeeModal = function () {
                createFeeForm.reset();
                showModal(createFeeModal);
            };

            window.showUpdateFeeModal = function (fee) {
                document.getElementById('updateFeeId').value         = fee.id;
                document.getElementById('updateFeeName').value       = fee.feeName;
                document.getElementById('updateAmount').value        = fee.amount;
                document.getElementById('updateAcademicYearId').value = fee.academicYearId || '';
                document.getElementById('updateSchoolId').value      = fee.schoolId || '';
                document.getElementById('updateProgrammeId').value   = fee.programmeId || '';
                document.getElementById('updateModeOfStudyId').value = fee.modeOfStudyId || '';
                document.getElementById('updateProgramLevelId').value = fee.programLevelId || '';
                document.getElementById('updateYearPeriodId').value  = fee.yearPeriodId || '';
                document.getElementById('updateCreditNCode').value   = fee.creditNCode || '';
                document.getElementById('updateDebitNCode').value    = fee.debitNCode || '';

                if (fee.schoolId) {
                    loadProgrammesBySchool(fee.schoolId, 'updateProgrammeId');
                    setTimeout(() => {
                        if (fee.programmeId) document.getElementById('updateProgrammeId').value = fee.programmeId;
                    }, 500);
                }
                showModal(updateFeeModal);
            };

            window.showDeleteFeeModal = function (id, feeName, amount) {
                document.getElementById('deleteFeeId').value    = id;
                document.getElementById('deleteFeeName').textContent = feeName;
                document.getElementById('deleteAmount').textContent  = amount;
                showModal(deleteFeeModal);
            };

            createFeeButton.addEventListener('click', () => {
                createFeeForm.checkValidity() ? createFeeForm.submit() : createFeeForm.reportValidity();
            });
            confirmUpdateBtn.addEventListener('click', () => {
                updateFeeForm.checkValidity() ? updateFeeForm.submit() : updateFeeForm.reportValidity();
            });
            confirmDeleteBtn.addEventListener('click', () => deleteFeeForm.submit());

            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') {
                    [createFeeModal, updateFeeModal, deleteFeeModal].forEach(m => {
                        if (!m.classList.contains('hidden')) hideModal(m);
                    });
                }
            });
        }

        function loadProgrammesBySchool(schoolId, targetSelectId) {
            const sel = document.getElementById(targetSelectId);
            sel.innerHTML = '<option value="">Loading...</option>';

            fetch(`/Admin/GetProgrammesBySchool?schoolId=${schoolId}`)
                .then(r => r.json())
                .then(data => {
                    sel.innerHTML = '<option value="">All Programmes</option>';
                    data.forEach(p => {
                        const opt = document.createElement('option');
                        opt.value = p.value;
                        opt.textContent = p.text;
                        sel.appendChild(opt);
                    });
                })
                .catch(err => {
                    console.error('Error loading programmes:', err);
                    sel.innerHTML = '<option value="">Error loading programmes</option>';
                });
        }
    </script>
}
