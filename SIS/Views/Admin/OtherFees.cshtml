@using SIS.Models.Fees
@model IEnumerable<OtherFees>

@{
    ViewData["Title"] = "Other Fees Configuration";
}

<div class="min-h-screen p-4">
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2" style="color: #e85c5c;">receipt_long</i>
            Other Fees Configuration
        </h1>
        <button type="button"
                class="px-4 py-2 text-white rounded-lg transition-colors flex items-center shadow-md hover:shadow-lg"
                style="background-color: #e85c5c;"
                onmouseenter="this.style.backgroundColor='#c53030'"
                onmouseleave="this.style.backgroundColor='#e85c5c'"
                onclick="showCreateFeeModal()">
            <i class="material-icons mr-2">add</i>
            Create Other Fee
        </button>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-4">
        <div class="xl:col-span-4">
            <div class="bg-white rounded-lg shadow-lg overflow-hidden border border-gray-100">

                <!-- Filters -->
                <div class="p-4 bg-gray-50 border-b border-gray-200">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-sm font-semibold text-gray-700 flex items-center">
                            <i class="material-icons text-sm mr-2">filter_list</i>
                            Filters
                        </h3>
                        <button onclick="clearFilters()"
                                class="text-xs px-3 py-1 rounded-lg transition-colors flex items-center"
                                style="color: #e85c5c;"
                                onmouseenter="this.style.backgroundColor='#fef2f2'"
                                onmouseleave="this.style.backgroundColor=''">
                            <i class="material-icons text-sm mr-1">clear</i>
                            Clear All
                        </button>
                    </div>

                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                        <div class="relative">
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Academic Year</label>
                            <select id="filterAcademicYear" onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:ring-2 focus:border-transparent outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Years</option>
                                @foreach (var year in ViewBag.AcademicYears)
                                {
                                    <option value="@year.Value">@year.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Academic Period</label>
                            <select id="filterYearPeriod" onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Periods</option>
                                @foreach (var period in ViewBag.YearPeriods)
                                {
                                    <option value="@period.Value">@period.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-secondary-600 mb-1">School</label>
                            <select id="filterSchool" onchange="onSchoolFilterChange(); applyFilters();"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Schools</option>
                                @foreach (var school in ViewBag.Schools)
                                {
                                    <option value="@school.Value">@school.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Programme</label>
                            <select id="filterProgramme" onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Programmes</option>
                                @foreach (var programme in ViewBag.Programmes)
                                {
                                    <option value="@programme.Value">@programme.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Mode of Study</label>
                            <select id="filterMode" onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Modes</option>
                                @foreach (var mode in ViewBag.ModesOfStudy)
                                {
                                    <option value="@mode.Value">@mode.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Program Level</label>
                            <select id="filterLevel" onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Levels</option>
                                @foreach (var level in ViewBag.ProgramLevels)
                                {
                                    <option value="@level.Value">@level.Text</option>
                                }
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Student Type</label>
                            <select id="filterStudentType" onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Types</option>
                                <option value="true">Foreign Students</option>
                                <option value="false">Local Students</option>
                            </select>
                        </div>

                        <div class="relative">
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Search</label>
                            <input type="text" id="searchTerm" onkeyup="applyFilters()"
                                   placeholder="Search fee name..."
                                   class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg outline-none"
                                   onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                   onblur="this.style.borderColor='';this.style.boxShadow=''">
                        </div>
                    </div>
                </div>

                <!-- Table -->
                <div class="overflow-x-auto">
                    <div class="inline-block min-w-full align-middle">
                        <div class="overflow-hidden">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead style="background-color: #fef2f2;">
                                    <tr>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">#</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Fee Name</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Student Type</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Academic Year</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Academic Period</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">School</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Programme</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Mode/Level</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Amount</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="feeTableBody" class="bg-white divide-y divide-gray-200">
                                    <tr>
                                        <td colspan="10" class="px-6 py-8 text-center text-gray-500">
                                            <div class="flex flex-col items-center">
                                                <i class="material-icons text-4xl text-gray-300 mb-2 animate-spin">refresh</i>
                                                <p class="text-lg font-medium">Loading other fees...</p>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Pagination -->
                <div class="border-t border-gray-200 px-4 py-3 bg-gray-50">
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                        <div class="flex items-center gap-2">
                            <label class="text-xs text-secondary-600">Rows per page:</label>
                            <select id="pageSize" onchange="changePageSize()"
                                    class="px-2 py-1 text-xs border border-gray-300 rounded-lg outline-none"
                                    onfocus="this.style.borderColor='#e85c5c'" onblur="this.style.borderColor=''">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>
                        <div id="paginationInfo" class="text-xs text-secondary-600"></div>
                        <div id="paginationControls" class="flex gap-1"></div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     CREATE MODAL
═══════════════════════════════════════════ -->
<div id="createFeeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-4xl border border-gray-200 max-h-[90vh] overflow-y-auto">

                <div class="text-white px-6 py-4 rounded-t-xl flex items-center justify-between sticky top-0 z-10"
                     style="background-color: #e85c5c;">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create Other Fee
                    </h3>
                    <button type="button" class="text-white transition-colors hover:text-red-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <div class="p-6">
                    <form id="createFeeForm" method="post" action="/Admin/CreateOtherFee">
                        @Html.AntiForgeryToken()
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                            <div class="relative z-0 w-full group">
                                <input type="text" name="FeeName" id="feeName"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " required maxlength="200" />
                                <label for="feeName" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6"
                                       style="--tw-peer-focus-color: #e85c5c;">Fee Name *</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="number" name="Amount" id="amount" step="0.01" min="0"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " required />
                                <label for="amount" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Amount (ZMW) *</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="AppliesOnlyToForeignStudents" id="appliesOnlyToForeignStudents"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="false">Local Students</option>
                                    <option value="true">Foreign Students</option>
                                </select>
                                <label for="appliesOnlyToForeignStudents" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Student Type *</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="AcademicYearId" id="academicYearId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Academic Years</option>
                                    @foreach (var year in ViewBag.AcademicYears)
                                    {
                                        <option value="@year.Value">@year.Text</option>
                                    }
                                </select>
                                <label for="academicYearId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Academic Year</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="YearPeriodId" id="yearPeriodId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Periods</option>
                                    @foreach (var period in ViewBag.YearPeriods)
                                    {
                                        <option value="@period.Value">@period.Text</option>
                                    }
                                </select>
                                <label for="yearPeriodId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Academic Period</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="SchoolId" id="schoolId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                        onchange="loadProgrammesBySchool(this.value, 'programmeId')">
                                    <option value="">All Schools</option>
                                    @foreach (var school in ViewBag.Schools)
                                    {
                                        <option value="@school.Value">@school.Text</option>
                                    }
                                </select>
                                <label for="schoolId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    School</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ProgrammeId" id="programmeId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Programmes</option>
                                </select>
                                <label for="programmeId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Programme</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ModeOfStudyId" id="modeOfStudyId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Modes</option>
                                    @foreach (var mode in ViewBag.ModesOfStudy)
                                    {
                                        <option value="@mode.Value">@mode.Text</option>
                                    }
                                </select>
                                <label for="modeOfStudyId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Mode of Study</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="ProgramLevelId" id="programLevelId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Levels</option>
                                    @foreach (var level in ViewBag.ProgramLevels)
                                    {
                                        <option value="@level.Value">@level.Text</option>
                                    }
                                </select>
                                <label for="programLevelId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Programme Level</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="text" name="CreditNCode" id="creditNCode" maxlength="20"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " />
                                <label for="creditNCode" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Credit N-Code</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="text" name="DebitNCode" id="debitNCode" maxlength="20"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " />
                                <label for="debitNCode" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Debit N-Code</label>
                            </div>

                        </div>
                    </form>
                </div>

                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3 sticky bottom-0">
                    <button type="button"
                            class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300"
                            data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="createFeeButton"
                            class="px-4 py-2 text-white rounded-lg transition-colors flex items-center shadow-md"
                            style="background-color: #e85c5c;"
                            onmouseenter="this.style.backgroundColor='#c53030'"
                            onmouseleave="this.style.backgroundColor='#e85c5c'">
                        <i class="material-icons mr-1">save</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     UPDATE MODAL
═══════════════════════════════════════════ -->
<div id="updateFeeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-4xl border border-gray-200 max-h-[90vh] overflow-y-auto">

                <div class="text-white px-6 py-4 rounded-t-xl flex items-center justify-between sticky top-0 z-10"
                     style="background-color: #1e293b;">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">edit</i>
                        Update Other Fee
                    </h3>
                    <button type="button" class="text-white transition-colors hover:text-slate-300" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <div class="p-6">
                    <form id="updateFeeForm" method="post" action="/Admin/UpdateOtherFee">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="updateFeeId" name="Id" />

                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                            <div class="relative z-0 w-full group">
                                <input type="text" name="FeeName" id="updateFeeName"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " required maxlength="200" />
                                <label for="updateFeeName" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Fee Name *</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="number" name="Amount" id="updateAmount" step="0.01" min="0"
