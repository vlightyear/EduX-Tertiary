@model IEnumerable<SIS.Models.Registration.AcademicYear>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">calendar_today</i>
            Academic Years
        </h1>
        <button type="button"
                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center"
                onclick="showCreateAcademicYearModal()">
            <i class="material-icons mr-2">add</i>
            Create Academic Year
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full overflow-hidden">
                <div class="p-4">
                    <!-- Search and Filter Bar -->
                    <div class="mb-4 flex gap-4">
                        <div class="flex-1">
                            <input type="text" id="yearSearch" placeholder="Search academic years..." 
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                        </div>
                        <select id="statusFilter" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                            <option value="all">All Status</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                        <select id="typeFilter" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                            <option value="all">All Types</option>
                            <option value="Annual">Annual</option>
                            <option value="Semester">Semester</option>
                        </select>
                    </div>

                    <table id="academicYearTable" class="w-full text-sm text-secondary-600">
                        <thead>
                            <tr class="bg-gray-50 text-left border-b">
                                <th class="px-6 py-4 cursor-pointer" data-sort="index">
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4 cursor-pointer" data-sort="year">
                                    <span class="flex items-center">
                                        Academic Year
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4 cursor-pointer" data-sort="type">
                                    <span class="flex items-center">
                                        Type
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4 cursor-pointer" data-sort="status">
                                    <span class="flex items-center">
                                        Status
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">Period</th>
                                <th class="px-6 py-4 cursor-pointer" data-sort="nextYear">
                                    <span class="flex items-center">
                                        Next Year
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int index = 1;
                                foreach (var academic in Model)
                                {
                                    <tr class="border-b hover:bg-gray-50 transition-colors">
                                        <td class="px-6 py-4">@index</td>
                                        <td class="px-6 py-4 font-medium text-gray-900">@academic.YearValue</td>
                                        <td class="px-6 py-4">
                                            @if (academic.AcademicType == SIS.Models.Registration.AcademicType.Semester)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                                    <i class="material-icons text-sm mr-1">calendar_view_week</i> Semester
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                    <i class="material-icons text-sm mr-1">calendar_view_month</i> Annual
                                                </span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (academic.IsActive)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary-100 text-secondary-800">
                                                    <i class="material-icons text-sm mr-1">check_circle</i> Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                    <i class="material-icons text-sm mr-1">cancel</i> Inactive
                                                </span>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-xs">
                                            <div class="text-secondary-600">
                                                @academic.StartDate.ToString("MMM dd, yyyy") - @academic.EndDate.ToString("MMM dd, yyyy")
                                            </div>
                                            @if (academic.AcademicType == SIS.Models.Registration.AcademicType.Semester && 
                                                 academic.Semester1StartDate.HasValue && academic.Semester2EndDate.HasValue)
                                            {
                                                <div class="mt-1 text-gray-500">
                                                    <div>Sem 1: @academic.Semester1StartDate.Value.ToString("MMM dd") - @academic.Semester1EndDate.Value.ToString("MMM dd")</div>
                                                    <div>Sem 2: @academic.Semester2StartDate.Value.ToString("MMM dd") - @academic.Semester2EndDate.Value.ToString("MMM dd")</div>
                                                </div>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-xs">
                                            @if (academic.NextAcademicYear != null)
                                            {
                                                <div class="flex items-center text-primary-600">
                                                    <i class="material-icons text-sm mr-1">arrow_forward</i>
                                                    <span>@academic.NextAcademicYear.YearValue</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-gray-400 italic">Not set</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex space-x-2">
                                                <button onclick="showUpdateAcademicYearModal({
                                                            yearId: '@academic.YearId',
                                                            yearValue: '@academic.YearValue',
                                                            academicType: '@((int)academic.AcademicType)',
                                                            startDate: '@academic.StartDate.ToString("yyyy-MM-dd")',
                                                            endDate: '@academic.EndDate.ToString("yyyy-MM-dd")',
                                                            semester1StartDate: '@(academic.Semester1StartDate.HasValue ? academic.Semester1StartDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            semester1EndDate: '@(academic.Semester1EndDate.HasValue ? academic.Semester1EndDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            semester2StartDate: '@(academic.Semester2StartDate.HasValue ? academic.Semester2StartDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            semester2EndDate: '@(academic.Semester2EndDate.HasValue ? academic.Semester2EndDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            registrationStartDate: '@(academic.RegistrationStartDate.HasValue ? academic.RegistrationStartDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            registrationEndDate: '@(academic.RegistrationEndDate.HasValue ? academic.RegistrationEndDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            finalExamStartDate: '@(academic.FinalExamStartDate.HasValue ? academic.FinalExamStartDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            finalExamEndDate: '@(academic.FinalExamEndDate.HasValue ? academic.FinalExamEndDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            gradeSubmissionStartDate: '@(academic.GradeSubmissionStartDate.HasValue ? academic.GradeSubmissionStartDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            gradeSubmissionEndDate: '@(academic.GradeSubmissionEndDate.HasValue ? academic.GradeSubmissionEndDate.Value.ToString("yyyy-MM-dd") : "")',
                                                            minRegistrationPaymentPercentage: '@academic.MinRegistrationPaymentPercentage',
                                                            minExamPaymentPercentage: '@academic.MinExamPaymentPercentage',
                                                            isActive: @academic.IsActive.ToString().ToLower(),
                                                            nextAcademicYearId: '@(academic.NextAcademicYearId?.ToString() ?? "")'
                                                        })"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">edit</i> Edit
                                                </button>
                                                <button onclick="showDeleteAcademicYearModal('@academic.YearId', '@academic.YearValue', '@academic.AcademicType')"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">delete</i> Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="px-6 py-4 text-center text-gray-500">No academic years found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <!-- Table Pagination -->
                    <div class="flex justify-between items-center mt-4">
                        <div class="text-sm text-gray-500">
                            Showing <span id="startRow">1</span> to <span id="endRow">10</span> of <span id="totalRows">@Model.Count()</span> entries
                        </div>
                        <div class="flex space-x-1">
                            <button id="prevPage" class="px-3 py-1 text-sm text-secondary-600 hover:bg-gray-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">Previous</button>
                            <div id="paginationButtons" class="flex space-x-1">
                                <!-- Pagination buttons will be inserted here by JS -->
                            </div>
                            <button id="nextPage" class="px-3 py-1 text-sm text-secondary-600 hover:bg-gray-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">Next</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="grid grid-cols-1 gap-4">
                <!-- Total Academic Years -->
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-primary-100 rounded-lg">
                            <i class="material-icons text-primary-600 text-xl">calendar_today</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Current Active Year</p>
                            <p class="text-xl font-semibold text-secondary-600">
                                @Model.FirstOrDefault(x => x.IsActive)?.YearValue
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Annual vs Semester Count -->
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-purple-100 rounded-lg">
                            <i class="material-icons text-purple-600 text-xl">pie_chart</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Academic Types</p>
                            <div class="text-sm">
                                <div>Annual: @Model.Count(x => x.AcademicType == SIS.Models.Registration.AcademicType.Annual)</div>
                                <div>Semester: @Model.Count(x => x.AcademicType == SIS.Models.Registration.AcademicType.Semester)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Academic Year Timeline -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Academic Calendar</h3>
                <div class="space-y-3">
                    @foreach (var academic in Model.Where(x => x.IsActive).Take(3))
                    {
                        <div class="border-l-4 border-primary-500 pl-3">
                            <div class="font-medium text-sm">@academic.YearValue</div>
                            <div class="text-xs text-gray-500">
                                @academic.StartDate.ToString("MMM dd") - @academic.EndDate.ToString("MMM dd, yyyy")
                            </div>
                            @if (academic.AcademicType == SIS.Models.Registration.AcademicType.Semester)
                            {
                                <div class="text-xs text-blue-600 mt-1">Semester-based</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Academic Year Modal -->
<div id="createAcademicYearModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-3xl">
                <!-- Modal Header -->
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New Academic Year
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6 max-h-[70vh] overflow-y-auto">
                    <!-- Create Academic Year Form -->
                    <form id="createAcademicYearForm" method="post" asp-controller="Admin" asp-action="CreateAcademicYear">
                        @Html.AntiForgeryToken()

                        <div class="space-y-6">
                            <!-- Academic Year Basic Details Section -->
                            <div class="border-b border-gray-200 pb-4">
                                <h4 class="text-lg font-medium text-secondary-800 mb-3">Basic Information</h4>
                                
                                <!-- Academic Type Selection -->
                                <div class="mb-4">
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Academic Year Type</label>
                                    <div class="flex space-x-4">
                                        <label class="flex items-center">
                                            <input type="radio" name="AcademicType" value="0" id="annualType" class="mr-2" checked>
                                            <span class="text-sm">Annual</span>
                                        </label>
                                        <label class="flex items-center">
                                            <input type="radio" name="AcademicType" value="1" id="semesterType" class="mr-2">
                                            <span class="text-sm">Semester-based</span>
                                        </label>
                                    </div>
                                </div>

                                <!-- Year Value -->
                                <div class="relative z-0 w-full group mb-4">
                                    <input type="text" name="YearValue" id="yearValue"
                                        class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                        placeholder=" " required />
                                    <label for="yearValue"
                                        class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Academic Year (e.g., 2024 or 2024/2025)
                                    </label>
                                </div>

                                <!-- Overall Academic Year Dates -->
                                <div class="grid grid-cols-2 gap-6">
                                    <!-- Start Date -->
                                    <div class="relative z-0 w-full group">
                                        <input type="date" name="StartDate" id="startDate"
                                            class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                            placeholder=" " required />
                                        <label for="startDate"
                                            class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Academic Year Start Date
                                        </label>
                                    </div>

                                    <!-- End Date -->
                                    <div class="relative z-0 w-full group">
                                        <input type="date" name="EndDate" id="endDate"
                                            class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                            placeholder=" " required />
                                        <label for="endDate"
                                            class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Academic Year End Date
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Semester Dates Section (Hidden by default) -->
                            <div id="semesterDatesSection" class="border-b border-gray-200 pb-4 hidden">
                                <h4 class="text-lg font-medium text-secondary-800 mb-3">Semester Dates</h4>
                                
                                <!-- Semester 1 Dates -->
                                <div class="mb-4">
                                    <h5 class="font-medium text-gray-700 mb-2">Semester 1</h5>
                                    <div class="grid grid-cols-2 gap-6">
                                        <div class="relative z-0 w-full group">
                                            <input type="date" name="Semester1StartDate" id="semester1StartDate"
                                                class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                                placeholder=" " />
                                            <label for="semester1StartDate"
                                                class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                                Semester 1 Start Date
                                            </label>
                                        </div>
                                        <div class="relative z-0 w-full group">
                                            <input type="date" name="Semester1EndDate" id="semester1EndDate"
                                                class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                                placeholder=" " />
                                            <label for="semester1EndDate"
                                                class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                                Semester 1 End Date
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <!-- Semester 2 Dates -->
                                <div class="mb-4">
                                    <h5 class="font-medium text-gray-700 mb-2">Semester 2</h5>
                                    <div class="grid grid-cols-2 gap-6">
                                        <div class="relative z-0 w-full group">
                                            <input type="date" name="Semester2StartDate" id="semester2StartDate"
                                                class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                                placeholder=" " />
                                            <label for="semester2StartDate"
                                                class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                                Semester 2 Start Date
                                            </label>
                                        </div>
                                        <div class="relative z-0 w-full group">
                                            <input type="date" name="Semester2EndDate" id="semester2EndDate"
                                                class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                                placeholder=" " />
                                            <label for="semester2EndDate"
                                                class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                                Semester 2 End Date
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Registration Period Section -->
                            <div class="border-b border-gray-200 pb-4">
                                <h4 class="text-lg font-medium text-secondary-800 mb-3">Registration Period (Optional)</h4>
                                
                                <div class="grid grid-cols-2 gap-6">
                                    <div class="relative z-0 w-full group">
                                        <input type="date" name="RegistrationStartDate" id="registrationStartDate"
                                            class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                            placeholder=" " />
                                        <label for="registrationStartDate"
                                            class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Registration Start Date
                                        </label>
                                    </div>
                                    <div class="relative z-0 w-full group">
                                        <input type="date" name="RegistrationEndDate" id="registrationEndDate"
                                            class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                            placeholder=" " />
                                        <label for="registrationEndDate"
                                            class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Registration End Date
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Exam Period Section -->
                            <div class="border-b border-gray-200 pb-4">
                                <h4 class="text-lg font-medium text-secondary-800 mb-3">Final Exams Period (Optional)</h4>
                                
                                <div class="grid grid-cols-2 gap-6">
                                    <div class="relative z-0 w-full group">
