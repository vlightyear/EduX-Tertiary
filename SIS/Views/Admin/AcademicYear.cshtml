@model IEnumerable<SIS.Models.Registration.AcademicYear>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">calendar_today</i>
            Academic Years
        </h1>
        <button type="button"
                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center"
                onclick="showCreateAcademicYearModal()">
            <i class="material-icons mr-2">add</i>
            Create Academic Year
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full overflow-hidden">
                <div class="p-4">
                    <!-- Search and Filter Bar -->
                    <div class="mb-4 flex gap-4">
                        <div class="flex-1">
                            <input type="text" id="yearSearch" placeholder="Search academic years..."
                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                        </div>
                        <select id="statusFilter" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                            <option value="all">All Status</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                        <select id="typeFilter" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                            <option value="all">All Types</option>
                            <option value="Annual">Annual</option>
                            <option value="Semester">Semester</option>
                            <option value="Term">Term</option>
                        </select>
                    </div>

                    <table id="academicYearTable" class="w-full text-sm text-secondary-600">
                        <thead>
                            <tr class="bg-gray-50 text-left border-b">
                                <th class="px-4 py-4 cursor-pointer" data-sort="index">#</th>
                                <th class="px-4 py-4 cursor-pointer" data-sort="year">Academic Year</th>
                                <th class="px-4 py-4 cursor-pointer" data-sort="type">Type</th>
                                <th class="px-4 py-4 cursor-pointer" data-sort="status">Status</th>
                                <th class="px-4 py-4">Periods</th>
                                <th class="px-4 py-4 cursor-pointer" data-sort="nextYear">Next Year</th>
                                <th class="px-4 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int index = 1;
                                foreach (var academic in Model)
                                {
                                    var periods = academic.YearPeriods?
                                        .OrderBy(yp => yp.AcademicPeriod?.PeriodNumber)
                                        .ToList() ?? new List<SIS.Models.Registration.AcademicYearPeriod>();

                                    <tr class="border-b hover:bg-gray-50 transition-colors">
                                        <td class="px-4 py-4">@index</td>

                                        <td class="px-4 py-4 font-medium text-gray-900">@academic.YearValue</td>

                                        <!-- Type badge -->
                                        <td class="px-4 py-4">
                                            @if (academic.AcademicType == SIS.Models.Registration.AcademicType.Semester)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                                    <i class="material-icons text-sm mr-1">calendar_view_week</i>Semester
                                                </span>
                                            }
                                            else if (academic.AcademicType == SIS.Models.Registration.AcademicType.Term)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                                    <i class="material-icons text-sm mr-1">date_range</i>Term
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                    <i class="material-icons text-sm mr-1">calendar_view_month</i>Annual
                                                </span>
                                            }
                                        </td>

                                        <!-- Status badge -->
                                        <td class="px-4 py-4">
                                            @if (academic.IsActive)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary-100 text-secondary-800">
                                                    <i class="material-icons text-sm mr-1">check_circle</i>Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                    <i class="material-icons text-sm mr-1">cancel</i>Inactive
                                                </span>
                                            }
                                        </td>

                                        <!-- Periods cell -->
                                        <td class="px-4 py-4">
                                            <div class="flex flex-col gap-1">
                                                @if (periods.Any())
                                                {
                                                    @foreach (var yp in periods)
                                                    {
                                                        <span class="inline-flex items-center gap-1 text-xs @(yp.IsActive ? "text-primary-700 font-semibold" : "text-gray-500")">
                                                            @if (yp.IsActive)
                                                            {
                                                                <i class="material-icons text-xs text-primary-600">radio_button_checked</i>
                                                            }
                                                            else
                                                            {
                                                                <i class="material-icons text-xs text-gray-400">radio_button_unchecked</i>
                                                            }
                                                            @yp.AcademicPeriod?.PeriodName
                                                            <span class="text-gray-400 font-normal">
                                                                (@yp.StartDate.ToString("MMM d") – @yp.EndDate.ToString("MMM d"))
                                                            </span>
                                                        </span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-xs text-amber-600 italic flex items-center gap-1">
                                                        <i class="material-icons text-xs">warning</i> No periods set
                                                    </span>
                                                }
                                                <button onclick="showManagePeriodsModal('@academic.YearId', '@academic.YearValue', @((int)academic.AcademicType))"
                                                        class="mt-1 inline-flex items-center px-2 py-0.5 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded transition-colors w-fit">
                                                    <i class="material-icons text-xs mr-1">tune</i>Manage
                                                </button>
                                            </div>
                                        </td>

                                        <!-- Next Year -->
                                        <td class="px-4 py-4 text-xs">
                                            @if (academic.NextAcademicYear != null)
                                            {
                                                <div class="flex items-center text-primary-600">
                                                    <i class="material-icons text-sm mr-1">arrow_forward</i>
                                                    <span>@academic.NextAcademicYear.YearValue</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-gray-400 italic">Not set</span>
                                            }
                                        </td>

                                        <!-- Actions -->
                                        <td class="px-4 py-4">
                                            <div class="flex space-x-2">
                                                <button onclick="showUpdateAcademicYearModal({
                                                    yearId: '@academic.YearId',
                                                    yearValue: '@academic.YearValue',
                                                    academicType: '@((int)academic.AcademicType)',
                                                    startDate: '@academic.StartDate.ToString("yyyy-MM-dd")',
                                                    endDate: '@academic.EndDate.ToString("yyyy-MM-dd")',
                                                    registrationStartDate: '@(academic.RegistrationStartDate.HasValue ? academic.RegistrationStartDate.Value.ToString("yyyy-MM-dd") : "")',
                                                    registrationEndDate: '@(academic.RegistrationEndDate.HasValue ? academic.RegistrationEndDate.Value.ToString("yyyy-MM-dd") : "")',
                                                    minRegistrationPaymentPercentage: '@academic.MinRegistrationPaymentPercentage',
                                                    minExamPaymentPercentage: '@academic.MinExamPaymentPercentage',
                                                    isActive: @academic.IsActive.ToString().ToLower(),
                                                    nextAcademicYearId: '@(academic.NextAcademicYearId?.ToString() ?? "")'
                                                    })"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">edit</i>Edit
                                                </button>
                                                <button onclick="showDeleteAcademicYearModal('@academic.YearId', '@academic.YearValue', '@academic.AcademicType')"
                                                        class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                    <i class="material-icons text-sm mr-1">delete</i>Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="px-6 py-4 text-center text-gray-500">No academic years found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <!-- Table Pagination -->
                    <div class="flex justify-between items-center mt-4">
                        <div class="text-sm text-gray-500">
                            Showing <span id="startRow">1</span> to <span id="endRow">10</span> of <span id="totalRows">@Model.Count()</span> entries
                        </div>
                        <div class="flex space-x-1">
                            <button id="prevPage" class="px-3 py-1 text-sm text-secondary-600 hover:bg-gray-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">Previous</button>
                            <div id="paginationButtons" class="flex space-x-1"></div>
                            <button id="nextPage" class="px-3 py-1 text-sm text-secondary-600 hover:bg-gray-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">Next</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <div class="grid grid-cols-1 gap-4">
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-primary-100 rounded-lg">
                            <i class="material-icons text-primary-600 text-xl">calendar_today</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Current Active Year</p>
                            <p class="text-xl font-semibold text-secondary-600">
                                @Model.FirstOrDefault(x => x.IsActive)?.YearValue
                            </p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-purple-100 rounded-lg">
                            <i class="material-icons text-purple-600 text-xl">pie_chart</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Academic Types</p>
                            <div class="text-sm space-y-0.5">
                                <div>Annual: @Model.Count(x => x.AcademicType == SIS.Models.Registration.AcademicType.Annual)</div>
                                <div>Semester: @Model.Count(x => x.AcademicType == SIS.Models.Registration.AcademicType.Semester)</div>
                                <div>Term: @Model.Count(x => x.AcademicType == SIS.Models.Registration.AcademicType.Term)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Academic Calendar</h3>
                <div class="space-y-3">
                    @foreach (var academic in Model.Where(x => x.IsActive).Take(3))
                    {
                        <div class="border-l-4 border-primary-500 pl-3">
                            <div class="font-medium text-sm">@academic.YearValue</div>
                            <div class="text-xs text-gray-500">
                                @academic.StartDate.ToString("MMM dd") – @academic.EndDate.ToString("MMM dd, yyyy")
                            </div>
                            @{
                                var typeLabel = academic.AcademicType switch
                                {
                                    SIS.Models.Registration.AcademicType.Semester => "Semester-based",
                                    SIS.Models.Registration.AcademicType.Term => "Term-based",
                                    _ => "Annual"
                                };
                                var typeColor = academic.AcademicType switch
                                {
                                    SIS.Models.Registration.AcademicType.Semester => "text-blue-600",
                                    SIS.Models.Registration.AcademicType.Term => "text-purple-600",
                                    _ => "text-green-600"
                                };
                            }
                            <div class="text-xs @typeColor mt-1">@typeLabel</div>
                            @if (academic.YearPeriods?.Any() == true)
                            {
                                <div class="text-xs text-gray-400 mt-1">@academic.YearPeriods.Count() period(s) configured</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ================================================================
     MANAGE PERIODS MODAL
     ================================================================ -->
<div id="managePeriodsModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-4xl">
                <!-- Header -->
                <div class="bg-primary-700 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">tune</i>
                        Manage Periods — <span id="mpYearLabel" class="ml-2 font-normal"></span>
                    </h3>
                    <button type="button" onclick="hideManagePeriodsModal()" class="text-white hover:text-gray-200">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Body -->
                <div class="p-6 max-h-[78vh] overflow-y-auto space-y-6">

                    <!-- Existing periods list -->
                    <div>
                        <h4 class="text-base font-semibold text-secondary-800 mb-3 flex items-center gap-2">
                            <i class="material-icons text-sm">list</i> Configured Periods
                        </h4>
                        <div id="existingPeriodsList" class="space-y-2">
                            <p class="text-gray-400 text-sm italic">Loading…</p>
                        </div>
                    </div>

                    <hr class="border-gray-200">

                    <!-- Add period form -->
                    <div>
                        <h4 class="text-base font-semibold text-secondary-800 mb-3 flex items-center gap-2">
                            <i class="material-icons text-sm">add_circle_outline</i> Add a Period
                        </h4>

                        <form id="addPeriodForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="AcademicYearId" id="mpAcademicYearId" />

                            <div class="grid grid-cols-2 gap-4 mb-4">
                                <!-- Period template selector -->
                                <div class="col-span-2">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Period</label>
                                    <select name="AcademicPeriodId" id="mpPeriodSelect"
                                            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-primary-500 focus:border-primary-500">
                                        <option value="">— select a period —</option>
                                    </select>
                                </div>

                                <!-- Start / End dates -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Start Date <span class="text-red-500">*</span></label>
                                    <input type="date" name="StartDate" id="mpStartDate"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-primary-500 focus:border-primary-500" required />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">End Date <span class="text-red-500">*</span></label>
                                    <input type="date" name="EndDate" id="mpEndDate"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-primary-500 focus:border-primary-500" required />
                                </div>

                                <!-- Exam window -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Exam Start</label>
                                    <input type="date" name="ExamStartDate" id="mpExamStart"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Exam End</label>
                                    <input type="date" name="ExamEndDate" id="mpExamEnd"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                                </div>

                                <!-- Registration window -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Registration Start</label>
                                    <input type="date" name="RegistrationStartDate" id="mpRegStart"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Registration End</label>
                                    <input type="date" name="RegistrationEndDate" id="mpRegEnd"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                                </div>

                                <!-- Grade submission window -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Grade Submission Start</label>
                                    <input type="date" name="GradeSubmissionStartDate" id="mpGradeStart"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Grade Submission End</label>
                                    <input type="date" name="GradeSubmissionEndDate" id="mpGradeEnd"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
                                </div>

                                <!-- Active toggle -->
                                <div class="col-span-2 flex items-center gap-3">
                                    <input type="checkbox" name="IsActive" id="mpIsActive" value="true"
                                           class="w-4 h-4 text-primary-600 rounded" />
                                    <label for="mpIsActive" class="text-sm font-medium text-gray-700">
                                        Set as the currently active period for this year
                                    </label>
                                </div>
                            </div>

                            <div id="addPeriodError" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2 mb-3"></div>

                            <button type="button" onclick="submitAddPeriod()"
                                    class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 text-sm flex items-center gap-1">
                                <i class="material-icons text-sm">add</i> Add Period
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end">
                    <button type="button" onclick="hideManagePeriodsModal()"
                            class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Period Modal (inline, populated per-row) -->
<div id="editPeriodModal" class="hidden fixed inset-0 z-[60]">
    <div class="fixed inset-0 bg-black bg-opacity-40"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <div class="bg-gray-700 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-base font-semibold flex items-center gap-2">
                        <i class="material-icons text-sm">edit</i> Edit Period — <span id="epPeriodName"></span>
                    </h3>
                    <button onclick="hideEditPeriodModal()" class="text-white hover:text-gray-200"><i class="material-icons">close</i></button>
                </div>
                <div class="p-6">
                    <form id="editPeriodForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="epId" name="Id" />

                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Start Date <span class="text-red-500">*</span></label>
                                <input type="date" name="StartDate" id="epStartDate" class="w-full px-3 py-2 border rounded-lg text-sm" required />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">End Date <span class="text-red-500">*</span></label>
                                <input type="date" name="EndDate" id="epEndDate" class="w-full px-3 py-2 border rounded-lg text-sm" required />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Exam Start</label>
                                <input type="date" name="ExamStartDate" id="epExamStart" class="w-full px-3 py-2 border rounded-lg text-sm" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Exam End</label>
                                <input type="date" name="ExamEndDate" id="epExamEnd" class="w-full px-3 py-2 border rounded-lg text-sm" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Registration Start</label>
                                <input type="date" name="RegistrationStartDate" id="epRegStart" class="w-full px-3 py-2 border rounded-lg text-sm" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Registration End</label>
                                <input type="date" name="RegistrationEndDate" id="epRegEnd" class="w-full px-3 py-2 border rounded-lg text-sm" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Grade Submission Start</label>
                                <input type="date" name="GradeSubmissionStartDate" id="epGradeStart" class="w-full px-3 py-2 border rounded-lg text-sm" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Grade Submission End</label>
                                <input type="date" name="GradeSubmissionEndDate" id="epGradeEnd" class="w-full px-3 py-2 border rounded-lg text-sm" />
                            </div>
                            <div class="col-span-2 flex items-center gap-3">
                                <input type="checkbox" name="IsActive" id="epIsActive" value="true" class="w-4 h-4 text-primary-600 rounded" />
                                <label for="epIsActive" class="text-sm font-medium text-gray-700">Set as active period</label>
                            </div>
                        </div>

                        <div id="editPeriodError" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2 mb-3"></div>
                    </form>
                </div>
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end gap-2">
                    <button onclick="hideEditPeriodModal()" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm">Cancel</button>
                    <button onclick="submitEditPeriod()" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 text-sm flex items-center gap-1">
                        <i class="material-icons text-sm">save</i> Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- ================================================================
     CREATE ACADEMIC YEAR MODAL
     ================================================================ -->
<div id="createAcademicYearModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-3xl">
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>Create New Academic Year
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>
                <div class="p-6 max-h-[70vh] overflow-y-auto">
                    <form id="createAcademicYearForm" method="post" asp-controller="Admin" asp-action="CreateAcademicYear">
                        @Html.AntiForgeryToken()
                        <div class="space-y-6">
                            <div class="border-b border-gray-200 pb-4">
                                <h4 class="text-lg font-medium text-secondary-800 mb-3">Basic Information</h4>
