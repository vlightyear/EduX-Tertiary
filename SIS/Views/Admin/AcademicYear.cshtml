<script>
    // ================================================================
    // STATE
    // ================================================================
    let _currentYearId   = null;
    let _currentYearType = null; // 0=Annual, 1=Semester, 2=Term

    // ================================================================
    // MANAGE PERIODS MODAL
    // ================================================================
    async function showManagePeriodsModal(yearId, yearLabel, academicType) {
        _currentYearId   = yearId;
        _currentYearType = academicType;

        document.getElementById('mpYearLabel').textContent   = yearLabel;
        document.getElementById('mpAcademicYearId').value    = yearId;
        document.getElementById('managePeriodsModal').classList.remove('hidden');

        await loadPeriodTemplates(academicType);
        await refreshExistingPeriods();
    }

    function hideManagePeriodsModal() {
        document.getElementById('managePeriodsModal').classList.add('hidden');
        _currentYearId   = null;
        _currentYearType = null;
        clearAddForm();
    }

    // Populate the "Add a Period" select with templates matching the year's academic type
    async function loadPeriodTemplates(academicType) {
        const select = document.getElementById('mpPeriodSelect');
        select.innerHTML = '<option value="">— select a period —</option>';
        try {
            const res  = await fetch(`/Admin/GetAcademicPeriodTemplates?academicType=${academicType}`);
            const data = await res.json();
            data.forEach(p => {
                const opt    = document.createElement('option');
                opt.value    = p.id;
                opt.textContent = p.periodName;
                select.appendChild(opt);
            });
        } catch (e) {
            console.error('Failed to load period templates', e);
        }
    }

    // Render the list of already-configured periods for this year
    async function refreshExistingPeriods() {
        const container = document.getElementById('existingPeriodsList');
        container.innerHTML = '<p class="text-gray-400 text-sm italic">Loading…</p>';
        try {
            const res     = await fetch(`/Admin/GetYearPeriods?yearId=${_currentYearId}`);
            const periods = await res.json();

            if (periods.length === 0) {
                container.innerHTML = '<p class="text-gray-400 text-sm italic">No periods configured yet.</p>';
                return;
            }

            container.innerHTML = periods.map(p => `
                <div class="flex items-start justify-between gap-4 p-3 rounded-lg border ${p.isActive ? 'border-primary-300 bg-primary-50' : 'border-gray-200 bg-gray-50'}">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="font-semibold text-sm text-gray-800">${p.periodName}</span>
                            ${p.isActive ? '<span class="text-xs bg-primary-600 text-white px-2 py-0.5 rounded-full">Active</span>' : ''}
                        </div>
                        <div class="text-xs text-gray-500 mt-1 space-y-0.5">
                            <div><i class="material-icons text-xs align-middle">date_range</i> ${fmt(p.startDate)} – ${fmt(p.endDate)}</div>
                            ${p.examStartDate    ? `<div><i class="material-icons text-xs align-middle">school</i> Exams: ${fmt(p.examStartDate)} – ${fmt(p.examEndDate)}</div>` : ''}
                            ${p.registrationStartDate ? `<div><i class="material-icons text-xs align-middle">app_registration</i> Registration: ${fmt(p.registrationStartDate)} – ${fmt(p.registrationEndDate)}</div>` : ''}
                            ${p.gradeSubmissionStartDate ? `<div><i class="material-icons text-xs align-middle">grading</i> Grades: ${fmt(p.gradeSubmissionStartDate)} – ${fmt(p.gradeSubmissionEndDate)}</div>` : ''}
                        </div>
                    </div>
                    <div class="flex gap-1 shrink-0">
                        <button onclick="openEditPeriod(${JSON.stringify(p).replace(/"/g, '&quot;')})"
                                class="p-1.5 text-blue-600 hover:bg-blue-100 rounded transition-colors" title="Edit">
                            <i class="material-icons text-sm">edit</i>
                        </button>
                        <button onclick="confirmRemovePeriod(${p.id}, '${p.periodName}')"
                                class="p-1.5 text-red-600 hover:bg-red-100 rounded transition-colors" title="Remove">
                            <i class="material-icons text-sm">delete</i>
                        </button>
                    </div>
                </div>
            `).join('');
        } catch (e) {
            container.innerHTML = '<p class="text-red-500 text-sm">Failed to load periods.</p>';
        }
    }

    function fmt(dateStr) {
        if (!dateStr) return '—';
        const d = new Date(dateStr);
        return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    // ================================================================
    // ADD PERIOD
    // ================================================================
    async function submitAddPeriod() {
        const errEl = document.getElementById('addPeriodError');
        errEl.classList.add('hidden');

        const form  = document.getElementById('addPeriodForm');
        const token = form.querySelector('[name="__RequestVerificationToken"]').value;

        const payload = {
            AcademicYearId:           _currentYearId,
            AcademicPeriodId:         document.getElementById('mpPeriodSelect').value,
            StartDate:                document.getElementById('mpStartDate').value,
            EndDate:                  document.getElementById('mpEndDate').value,
            ExamStartDate:            document.getElementById('mpExamStart').value   || null,
            ExamEndDate:              document.getElementById('mpExamEnd').value     || null,
            RegistrationStartDate:    document.getElementById('mpRegStart').value    || null,
            RegistrationEndDate:      document.getElementById('mpRegEnd').value      || null,
            GradeSubmissionStartDate: document.getElementById('mpGradeStart').value  || null,
            GradeSubmissionEndDate:   document.getElementById('mpGradeEnd').value    || null,
            IsActive:                 document.getElementById('mpIsActive').checked
        };

        if (!payload.AcademicPeriodId) { showAddError('Please select a period.'); return; }
        if (!payload.StartDate || !payload.EndDate) { showAddError('Start and end dates are required.'); return; }

        const params = new URLSearchParams({ ...payload, __RequestVerificationToken: token });

        try {
            const res  = await fetch('/Admin/AddYearPeriod', { method: 'POST', body: params });
            const data = await res.json();

            if (data.success) {
                clearAddForm();
                await refreshExistingPeriods();
            } else {
                showAddError(data.message);
            }
        } catch (e) {
            showAddError('Request failed. Please try again.');
        }
    }

    function showAddError(msg) {
        const el = document.getElementById('addPeriodError');
        el.textContent = msg;
        el.classList.remove('hidden');
    }

    function clearAddForm() {
        ['mpPeriodSelect','mpStartDate','mpEndDate','mpExamStart','mpExamEnd',
         'mpRegStart','mpRegEnd','mpGradeStart','mpGradeEnd'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = '';
        });
        document.getElementById('mpIsActive').checked = false;
        document.getElementById('addPeriodError').classList.add('hidden');
    }

    // ================================================================
    // EDIT PERIOD
    // ================================================================
    function openEditPeriod(p) {
        document.getElementById('epId').value          = p.id;
        document.getElementById('epPeriodName').textContent = p.periodName;
        document.getElementById('epStartDate').value   = p.startDate  || '';
        document.getElementById('epEndDate').value     = p.endDate    || '';
        document.getElementById('epExamStart').value   = p.examStartDate || '';
        document.getElementById('epExamEnd').value     = p.examEndDate   || '';
        document.getElementById('epRegStart').value    = p.registrationStartDate || '';
        document.getElementById('epRegEnd').value      = p.registrationEndDate   || '';
        document.getElementById('epGradeStart').value  = p.gradeSubmissionStartDate || '';
        document.getElementById('epGradeEnd').value    = p.gradeSubmissionEndDate   || '';
        document.getElementById('epIsActive').checked  = p.isActive;
        document.getElementById('editPeriodError').classList.add('hidden');
        document.getElementById('editPeriodModal').classList.remove('hidden');
    }

    function hideEditPeriodModal() {
        document.getElementById('editPeriodModal').classList.add('hidden');
    }

    async function submitEditPeriod() {
        const errEl = document.getElementById('editPeriodError');
        errEl.classList.add('hidden');

        const form  = document.getElementById('editPeriodForm');
        const token = form.querySelector('[name="__RequestVerificationToken"]').value;

        const payload = {
            Id:                       document.getElementById('epId').value,
            StartDate:                document.getElementById('epStartDate').value,
            EndDate:                  document.getElementById('epEndDate').value,
            ExamStartDate:            document.getElementById('epExamStart').value   || null,
            ExamEndDate:              document.getElementById('epExamEnd').value     || null,
            RegistrationStartDate:    document.getElementById('epRegStart').value    || null,
            RegistrationEndDate:      document.getElementById('epRegEnd').value      || null,
            GradeSubmissionStartDate: document.getElementById('epGradeStart').value  || null,
            GradeSubmissionEndDate:   document.getElementById('epGradeEnd').value    || null,
            IsActive:                 document.getElementById('epIsActive').checked
        };

        if (!payload.StartDate || !payload.EndDate) {
            errEl.textContent = 'Start and end dates are required.';
            errEl.classList.remove('hidden');
            return;
        }

        const params = new URLSearchParams({ ...payload, __RequestVerificationToken: token });

        try {
            const res  = await fetch('/Admin/UpdateYearPeriod', { method: 'POST', body: params });
            const data = await res.json();

            if (data.success) {
                hideEditPeriodModal();
                await refreshExistingPeriods();
            } else {
                errEl.textContent = data.message;
                errEl.classList.remove('hidden');
            }
        } catch (e) {
            errEl.textContent = 'Request failed. Please try again.';
            errEl.classList.remove('hidden');
        }
    }

    // ================================================================
    // REMOVE PERIOD
    // ================================================================
    async function confirmRemovePeriod(yearPeriodId, periodName) {
        if (!confirm(`Remove "${periodName}" from this academic year? This cannot be undone.`)) return;

        const token = document.querySelector('#addPeriodForm [name="__RequestVerificationToken"]').value;
        const params = new URLSearchParams({ yearPeriodId, __RequestVerificationToken: token });

        try {
            const res  = await fetch('/Admin/RemoveYearPeriod', { method: 'POST', body: params });
            const data = await res.json();

            if (data.success) {
                await refreshExistingPeriods();
            } else {
                alert(data.message);
            }
        } catch (e) {
            alert('Request failed. Please try again.');
        }
    }

    // ================================================================
    // CREATE / UPDATE / DELETE YEAR MODALS (existing logic preserved)
    // ================================================================
    function showCreateAcademicYearModal() {
        document.getElementById('createAcademicYearModal').classList.remove('hidden');
    }

    function showUpdateAcademicYearModal(data) {
        document.getElementById('updateYearId').value      = data.yearId;
        document.getElementById('updateYearValue').value   = data.yearValue;
        document.getElementById('updateStartDate').value   = data.startDate;
        document.getElementById('updateEndDate').value     = data.endDate;
        document.getElementById('updateRegistrationStartDate').value = data.registrationStartDate;
        document.getElementById('updateRegistrationEndDate').value   = data.registrationEndDate;
        document.getElementById('updateMinRegistrationPayment').value = data.minRegistrationPaymentPercentage;
        document.getElementById('updateMinExamPayment').value        = data.minExamPaymentPercentage;
        document.getElementById('updateIsActive').checked            = data.isActive;

        const typeVal = parseInt(data.academicType);
        document.getElementById('updateAnnualType').checked   = typeVal === 0;
        document.getElementById('updateSemesterType').checked = typeVal === 1;
        document.getElementById('updateTermType').checked     = typeVal === 2;

        const nextSelect = document.getElementById('updateNextAcademicYearId');
        if (nextSelect) nextSelect.value = data.nextAcademicYearId || '';

        document.getElementById('updateAcademicYearModal').classList.remove('hidden');
    }

    function showDeleteAcademicYearModal(yearId, yearValue, academicType) {
        document.getElementById('deleteYearId').value        = yearId;
        document.getElementById('deleteYearValue').textContent = yearValue;
        document.getElementById('deleteAcademicType').textContent = academicType;
        document.getElementById('deleteAcademicYearModal').classList.remove('hidden');
    }

    // Close modals on backdrop click
    document.querySelectorAll('[data-bs-dismiss="modal"]').forEach(btn => {
        btn.addEventListener('click', () => {
            btn.closest('.fixed').classList.add('hidden');
        });
    });
</script>

<script type="module" src="~/js/academic_years.js"></script>
