@model IEnumerable<SIS.Models.StudentAccommodation.ResourceType>
<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <div class="flex items-center text-secondary-800">
            <i class="material-icons text-3xl mr-2">inventory</i>
            <div>
                <h1 class="text-2xl font-bold">Resource Type Management</h1>
                <p class="text-sm text-slate-600">Manage resource types for room inventory</p>
            </div>
        </div>
        <button type="button"
                onclick="showCreateResourceTypeModal()"
                class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
            <i class="material-icons mr-2">add_circle</i>
            Create Resource Type
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full">
                <div class="p-4">
                    <div class="flex justify-between items-center mb-4">
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <i class="material-icons text-slate-400 text-sm">search</i>
                            </div>
                            <input type="text" id="searchInput"
                                   class="block w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                   placeholder="Search resource types..." />
                        </div>
                        <div class="flex items-center">
                            <label for="filterUsage" class="text-sm text-slate-600 mr-2">Filter:</label>
                            <select id="filterUsage"
                                    class="px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500">
                                <option value="all">All Resources</option>
                                <option value="used">In Use</option>
                                <option value="unused">Not Used</option>
                            </select>
                        </div>
                    </div>

                    <div class="overflow-y-auto h-[calc(100%-60px)]">
                        @if (TempData["Success"] != null)
                        {
                            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
                                <p>@TempData["Success"]</p>
                            </div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
                                <p>@TempData["Error"]</p>
                            </div>
                        }

                        <table id="resourceTypesTable" class="w-full text-sm text-secondary-600">
                            <thead class="sticky top-0 bg-slate-50">
                                <tr>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            #
                                            <button class="sort-btn ml-1" data-sort="index">
                                                <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                                </svg>
                                            </button>
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Resource Name
                                            <button class="sort-btn ml-1" data-sort="name">
                                                <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                                </svg>
                                            </button>
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Description
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Usage Count
                                            <button class="sort-btn ml-1" data-sort="usage">
                                                <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                                </svg>
                                            </button>
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Created On
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Actions
                                        </span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="resourceTypesTableBody">
                                @if (Model != null && Model.Any())
                                {
                                    @for (int i = 0; i < Model.Count(); i++)
                                    {
                                        var resourceType = Model.ElementAt(i);
                                        var usageCount = resourceType.RoomResources?.Count ?? 0;
                                        <tr class="hover:bg-slate-50 border-b"
                                            data-usage="@(usageCount > 0 ? "used" : "unused")">
                                            <td class="px-6 py-4">@(i + 1)</td>
                                            <td class="px-6 py-4 font-medium text-cyan-600">@resourceType.Name</td>
                                            <td class="px-6 py-4">
                                                @if (!string.IsNullOrEmpty(resourceType.Description))
                                                {
                                                    <span>@resourceType.Description</span>
                                                }
                                                else
                                                {
                                                    <span class="text-slate-400">-</span>
                                                }
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="font-medium">@usageCount</span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="text-slate-500">@resourceType.CreatedAt.ToString("MMM dd, yyyy")</span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex space-x-2">
                                                    <button onclick="showUpdateResourceTypeModal('@resourceType.ResourceTypeId')"
                                                            class="text-slate-600 hover:text-cyan-600" title="Edit">
                                                        <i class="material-icons text-base">edit</i>
                                                    </button>
                                                    <button onclick="showDeleteResourceTypeModal('@resourceType.ResourceTypeId', '@resourceType.Name.Replace("'", "\\'")', '@usageCount')"
                                                            class="text-slate-600 hover:text-red-600" title="Delete">
                                                        <i class="material-icons text-base">delete</i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                        <!-- Empty state message - shown/hidden via JS -->
                        <div id="emptyStateMessage" class="flex flex-col items-center justify-center h-[calc(100%-60px)] text-slate-500"
                             style="@(Model != null && Model.Any() ? "display: none;" : "")">
                            <i class="material-icons text-5xl mb-4">category</i>
                            <h3 class="text-xl font-medium mb-2">No Resource Types Found</h3>
                            <p class="text-sm mb-4">You haven't created any resource types yet.</p>
                            <button onclick="showCreateResourceTypeModal()"
                                    class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
                                <i class="material-icons mr-2">add_circle</i>
                                Create First Resource Type
                            </button>
                        </div>

                        <!-- Loading indicator -->
                        <div id="loadingIndicator" class="flex justify-center items-center h-[calc(100%-60px)]" style="display: none;">
                            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-cyan-600"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="grid grid-cols-1 gap-4">
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-cyan-100 rounded-lg">
                            <i class="material-icons text-cyan-600 text-xl">category</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Resource Types</p>
                            <div id="totalResourceTypes" class="text-xl font-semibold">@(Model?.Count() ?? 0)</div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">inventory_2</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Resources</p>
                            <div id="totalResources" class="text-xl font-semibold text-blue-600">
                                @ViewBag.TotalResources
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">check_circle</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Active Types</p>
                            <div id="activeResourceTypes" class="text-xl font-semibold text-green-600">
                                @ViewBag.ActiveResourceTypes
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resource Usage Chart -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Resource Usage</h3>
                <div id="resourceUsageChart" class="h-64"></div>
            </div>

            <!-- Common Resource Types -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Common Resources</h3>
                <div class="grid grid-cols-1 gap-2">
                    @if (Model != null && Model.Any())
                    {
                        <button onclick="createCommonResourceType('Chair', 'Standard chair for student use')"
                                class="w-full px-4 py-2 bg-slate-50 hover:bg-slate-100 text-sm text-slate-600 rounded-lg flex items-center">
                            <i class="material-icons text-cyan-600 mr-2">chair</i>
                            Chair
                        </button>
                        <button onclick="createCommonResourceType('Table', 'Study table or desk')"
                                class="w-full px-4 py-2 bg-slate-50 hover:bg-slate-100 text-sm text-slate-600 rounded-lg flex items-center">
                            <i class="material-icons text-cyan-600 mr-2">table_restaurant</i>
                            Table
                        </button>
                        <button onclick="createCommonResourceType('Bed', 'Standard single bed')"
                                class="w-full px-4 py-2 bg-slate-50 hover:bg-slate-100 text-sm text-slate-600 rounded-lg flex items-center">
                            <i class="material-icons text-cyan-600 mr-2">bed</i>
                            Bed
                        </button>
                        <button onclick="createCommonResourceType('Lamp', 'Reading lamp or desk light')"
                                class="w-full px-4 py-2 bg-slate-50 hover:bg-slate-100 text-sm text-slate-600 rounded-lg flex items-center">
                            <i class="material-icons text-cyan-600 mr-2">lightbulb</i>
                            Lamp
                        </button>
                        <button onclick="createCommonResourceType('Fan', 'Ceiling or table fan')"
                                class="w-full px-4 py-2 bg-slate-50 hover:bg-slate-100 text-sm text-slate-600 rounded-lg flex items-center">
                            <i class="material-icons text-cyan-600 mr-2">mode_fan</i>
                            Fan
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create ResourceType Modal -->
<div id="createResourceTypeModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideCreateResourceTypeModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 bg-cyan-600 text-white">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2">add_circle</i>
                Create New Resource Type
            </h3>
        </div>
        <form id="createResourceTypeForm" method="post" asp-controller="Admin" asp-action="CreateResourceType">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4">
                <div class="space-y-4">
                    <!-- Resource Type Name -->
                    <div class="relative z-0 w-full group">
                        <input type="text" name="Name" id="Name"
                               class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                               placeholder=" " required />
                        <label for="Name"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Resource Type Name
                        </label>
                    </div>

                    <!-- Description -->
                    <div class="relative z-0 w-full group">
                        <textarea name="Description" id="Description" rows="3"
                                  class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                  placeholder=" "></textarea>
                        <label for="Description"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Description
                        </label>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
                <button type="button" onclick="hideCreateResourceTypeModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                    Create Resource Type
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Update ResourceType Modal -->
<div id="updateResourceTypeModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideUpdateResourceTypeModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 bg-cyan-700 text-white">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2">edit</i>
                Update Resource Type
            </h3>
        </div>
        <form id="updateResourceTypeForm" method="post" asp-controller="Admin" asp-action="UpdateResourceType">
            @Html.AntiForgeryToken()
            <input type="hidden" id="updateResourceTypeId" name="ResourceTypeId" />
            <div class="px-6 py-4">
                <div class="space-y-4">
                    <!-- Resource Type Name -->
                    <div class="relative z-0 w-full group">
                        <input type="text" name="Name" id="updateName"
                               class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                               placeholder=" " required />
                        <label for="updateName"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Resource Type Name
                        </label>
                    </div>

                    <!-- Description -->
                    <div class="relative z-0 w-full group">
                        <textarea name="Description" id="updateDescription" rows="3"
                                  class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                  placeholder=" "></textarea>
                        <label for="updateDescription"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Description
                        </label>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
                <button type="button" onclick="hideUpdateResourceTypeModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                    Update Resource Type
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Delete ResourceType Modal -->
<div id="deleteResourceTypeModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideDeleteResourceTypeModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 bg-red-600 text-white">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2">warning</i>
                Confirm Deletion
            </h3>
        </div>
        <form id="deleteResourceTypeForm" method="post" asp-controller="Admin" asp-action="DeleteResourceType">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteResourceTypeId" name="id" />
            <div class="px-6 py-4">
                <p class="text-gray-700 mb-4">Are you sure you want to delete this resource type?</p>
                <div class="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-4">
                    <p id="deleteResourceTypeName" class="font-medium text-sm mb-2 text-slate-800"></p>
                    <div class="flex flex-wrap gap-1 mt-2" id="deleteResourceTypeDetails">
                        <span id="deleteResourceTypeUsageCount" class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full"></span>
                    </div>
                </div>

                <div id="deleteWarning" class="text-sm text-red-600 mb-4">
                    This action cannot be undone and will permanently remove this resource type from the system.
                </div>

                <div id="inUseWarning" class="bg-yellow-50 border-l-4 border-yellow-400 p-4 hidden">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i class="material-icons text-yellow-400">warning</i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-yellow-700">
                                This resource type is currently in use. You must remove all associated resources first.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
                <button type="button" onclick="hideDeleteResourceTypeModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit" id="confirmDeleteBtn" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                    Delete Resource Type
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/resourceTypes.js"></script>
}