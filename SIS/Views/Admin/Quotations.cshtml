@section Scripts
{
    <!-- Add these CDN links before your Scripts section -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script>
        let currentPage = 1, pageSize = 10;
        let allProgrammes = [];

        document.addEventListener('DOMContentLoaded', function() {
            showSection('generate');
            loadFilterOptions();
            changeFeeSource();
        });

        function showSection(section) {
            const generateSection = document.getElementById('generateSection');
            const listSection = document.getElementById('listSection');
            const btnGenerate = document.getElementById('btnShowGenerate');
            const btnList = document.getElementById('btnShowList');

            if (section === 'generate') {
                generateSection.classList.remove('hidden');
                listSection.classList.add('hidden');
                btnGenerate.classList.remove('bg-gray-600', 'hover:bg-gray-700');
                btnGenerate.classList.add('bg-primary-600', 'hover:bg-primary-700');
                btnList.classList.remove('bg-primary-600', 'hover:bg-primary-700');
                btnList.classList.add('bg-gray-600', 'hover:bg-gray-700');
            } else {
                generateSection.classList.add('hidden');
                listSection.classList.remove('hidden');
                btnGenerate.classList.remove('bg-primary-600', 'hover:bg-primary-700');
                btnGenerate.classList.add('bg-gray-600', 'hover:bg-gray-700');
                btnList.classList.remove('bg-gray-600', 'hover:bg-gray-700');
                btnList.classList.add('bg-primary-600', 'hover:bg-primary-700');
                loadQuotations();
            }
        }

        async function loadFilterOptions() {
            try {
                const [schools, programmes, modes, levels] = await Promise.all([
                    fetch('/Admin/GetSchools').then(r => r.json()),
                    fetch('/Admin/GetProgrammes').then(r => r.json()),
                    fetch('/Admin/GetModesOfStudy').then(r => r.json()),
                    fetch('/Admin/GetProgramLevels').then(r => r.json())
                ]);

                allProgrammes = programmes;
                //populateSelect('primaryFilterSchool', schools, 'Id', 'Name');
                populateSelect('filterMode', modes, 'modeId', 'modeName');
                populateSelect('filterLevel', levels, 'id', 'name');
            } catch (error) {
                console.error('Error loading filter options:', error);
            }
        }

        function populateSelect(id, data, valueField, textField) {
            const select = document.getElementById(id);
            if (!select) return;

            const currentValue = select.value;
            const firstOption = select.querySelector('option[value=""]');
            const placeholder = firstOption ? firstOption.textContent : 'All';

            select.innerHTML = '<option value="">' + placeholder + '</option>' +
                data.map(item => '<option value="' + item[valueField] + '">' + item[textField] + '</option>').join('');
            select.value = currentValue;
        }

        async function onSchoolChange() {
            const schoolId = document.getElementById('primaryFilterSchool').value;
            const programmeSelect = document.getElementById('primaryFilterProgramme');

            if (!schoolId) {
                programmeSelect.innerHTML = '<option value="">-- Select Programme --</option>';
                programmeSelect.value = '';
                applyFilters();
                return;
            }

            try {
                const response = await fetch('/Admin/GetProgrammesBySchool2?schoolId=' + schoolId);
                const programmes = await response.json();

                populateSelect('primaryFilterProgramme', programmes, 'id', 'name');
                applyFilters();
            } catch (error) {
                console.error('Error loading programmes:', error);
            }
        }

        function changeFeeSource() {
            const selectedSource = document.querySelector('input[name="feeSourceFilter"]:checked').value;
            const filtersDiv = document.getElementById('feeConfigFilters');

            if (selectedSource === 'FeeConfiguration') {
                filtersDiv.classList.remove('hidden');
            } else {
                filtersDiv.classList.add('hidden');
                clearAdditionalFilters();
            }

            applyFilters();
        }

        function applyFilters() {
            const primarySchoolId = document.getElementById('primaryFilterSchool') ? document.getElementById('primaryFilterSchool').value : '';
            const primaryProgrammeId = document.getElementById('primaryFilterProgramme') ? document.getElementById('primaryFilterProgramme').value : '';

            const hasRequiredFilters = primarySchoolId && primaryProgrammeId;

            const selectionPrompt = document.getElementById('selectionPrompt');
            const feesDisplayContainer = document.getElementById('feesDisplayContainer');

            if (!hasRequiredFilters) {
                selectionPrompt.classList.remove('hidden');
                feesDisplayContainer.classList.add('hidden');
                return;
            }

            selectionPrompt.classList.add('hidden');
            feesDisplayContainer.classList.remove('hidden');

            const selectedSource = document.querySelector('input[name="feeSourceFilter"]:checked').value;
            const selectedStudentType = document.querySelector('input[name="studentTypeFilter"]:checked').value;
            const feeItems = document.querySelectorAll('.fee-item');
            let visibleCount = 0;

            const filterModeId = document.getElementById('filterMode') ? document.getElementById('filterMode').value : '';
            const filterLevelId = document.getElementById('filterLevel') ? document.getElementById('filterLevel').value : '';
            const filterYearOfStudy = document.getElementById('filterYearOfStudy') ? document.getElementById('filterYearOfStudy').value : '';
            const filterSemester = document.getElementById('filterSemester') ? document.getElementById('filterSemester').value : '';

            // Check if ALL additional filters are selected (only for FeeConfiguration source)
            const allAdditionalFiltersSelected = selectedSource === 'FeeConfiguration' &&
                                                 filterModeId &&
                                                 filterLevelId &&
                                                 filterYearOfStudy &&
                                                 filterSemester;

            // Determine if we should auto-check fees (when student type is local or foreign AND all filters selected)
            const shouldAutoCheck = (selectedStudentType === 'local' || selectedStudentType === 'foreign') &&
                                    allAdditionalFiltersSelected;

            feeItems.forEach(item => {
                const feeSource = item.getAttribute('data-source');
                const isForeignFee = item.getAttribute('data-is-foreign') === 'true';
                const isLocalFee = item.getAttribute('data-is-local') === 'true';
                const isUniversalFee = item.getAttribute('data-is-foreign') === 'false' && item.getAttribute('data-is-local') === 'false';
                const schoolId = item.getAttribute('data-school-id');
                const programmeId = item.getAttribute('data-programme-id');

                let shouldShow = feeSource === selectedSource;

                // Apply required filters (school and programme)
                if (shouldShow) {
                    if (primarySchoolId && schoolId !== '0' && schoolId !== primarySchoolId) {
                        shouldShow = false;
                    }
                    if (primaryProgrammeId && programmeId !== '0' && programmeId !== primaryProgrammeId) {
                        shouldShow = false;
                    }
                }

                // Apply student type filter with new logic
                if (shouldShow && selectedStudentType !== 'all') {
                    if (selectedStudentType === 'foreign') {
                        // Show foreign fees AND universal fees
                        if (!isForeignFee && !isUniversalFee) {
                            shouldShow = false;
                        }
                    } else if (selectedStudentType === 'local') {
                        // Show local fees AND universal fees
                        if (!isLocalFee && !isUniversalFee) {
                            shouldShow = false;
                        }
                    }
                }

                // Apply additional filters for Fee Configuration
                if (shouldShow && selectedSource === 'FeeConfiguration') {
                    const modeId = item.getAttribute('data-mode-id');
                    const levelId = item.getAttribute('data-level-id');
                    const yearOfStudy = item.getAttribute('data-year-of-study');
                    const semester = item.getAttribute('data-semester');

                    if (filterModeId && modeId !== '0' && modeId !== filterModeId) shouldShow = false;
                    if (filterLevelId && levelId !== '0' && levelId !== filterLevelId) shouldShow = false;
                    if (filterYearOfStudy && yearOfStudy !== '0' && yearOfStudy !== filterYearOfStudy) shouldShow = false;
                    if (filterSemester && semester !== '0' && semester !== filterSemester) shouldShow = false;
                }

                const checkbox = item.querySelector('input[type="checkbox"]');

                if (shouldShow) {
                    item.style.display = '';
                    visibleCount++;

                    // Auto-check checkbox ONLY if all conditions are met:
                    // 1. Student type is local or foreign (not "all")
                    // 2. ALL additional filters are selected (Mode, Level, Year, Semester)
                    if (shouldAutoCheck && checkbox) {
                        checkbox.checked = true;
                    }
                } else {
                    item.style.display = 'none';
                    // Uncheck hidden items
                    if (checkbox && checkbox.checked) {
                        checkbox.checked = false;
                    }
                }
            });

            document.getElementById('availableFeesCount').textContent = visibleCount + ' fee' + (visibleCount !== 1 ? 's' : '') + ' available';
            updateSelectedFees();
        }

        function clearAdditionalFilters() {
            document.getElementById('filterMode').value = '';
            document.getElementById('filterLevel').value = '';
            document.getElementById('filterYearOfStudy').value = '';
            document.getElementById('filterSemester').value = '';
            applyFilters();
        }

        function updateSelectedFees() {
            const checkboxes = document.querySelectorAll('input[name="SelectedFeeIds"]:checked');
            let totalAmount = 0;

            checkboxes.forEach(cb => {
                const amount = parseFloat(cb.getAttribute('data-amount'));
                if (!isNaN(amount)) {
                    totalAmount += amount;
                }
            });

            const infoDiv = document.getElementById('selectedFeesInfo');
            if (checkboxes.length > 0) {
                infoDiv.classList.remove('hidden');
                document.getElementById('selectedFeesCount').textContent = checkboxes.length + ' fee' + (checkboxes.length !== 1 ? 's' : '') + ' selected';
                document.getElementById('totalAmount').textContent = 'K ' + totalAmount.toFixed(2);
            } else {
                infoDiv.classList.add('hidden');
            }
        }

        function addStudentInput() {
            const container = document.getElementById('studentInputsContainer');
            const row = document.createElement('div');
            row.className = 'flex gap-2 student-input-row';
            row.innerHTML = '<input type="text" placeholder="Student ID" class="flex-1 px-4 py-2 border rounded-lg student-id-input focus:ring-2 focus:ring-primary-500">' +
                '<button type="button" onclick="this.closest(\'.student-input-row\').remove()" class="px-3 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">' +
                '<i class="material-icons">remove</i></button>';
            container.appendChild(row);
        }

        async function validateStudents() {
            const inputs = document.querySelectorAll('.student-id-input');
            const ids = Array.from(inputs).map(i => i.value.trim()).filter(Boolean).join(',');

            if (!ids) {
                const resultsDiv = document.getElementById('validationResults');
                resultsDiv.classList.remove('hidden');
                resultsDiv.innerHTML = '<div class="bg-blue-50 p-4 rounded-lg border border-blue-200">' +
                    '<h4 class="font-semibold text-blue-900 mb-2 flex items-center"><i class="material-icons mr-2">info</i>General Quotation</h4>' +
                    '<p class="text-sm text-blue-800">No student IDs entered. This quotation will be created as a general quotation for walk-in inquiries or prospective students.</p></div>';
                document.getElementById('hiddenStudentIds').value = '';
                return;
            }

            document.getElementById('hiddenStudentIds').value = ids;

            try {
                const response = await fetch('/Admin/ValidateStudentsForQuotation', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({studentIds: ids})
                });

                const data = await response.json();
                const resultsDiv = document.getElementById('validationResults');
                resultsDiv.classList.remove('hidden');

                let html = '';

                if (data.totalValid > 0) {
                    html += '<div class="bg-green-50 p-4 rounded-lg border border-green-200">' +
                        '<h4 class="font-semibold text-green-900 mb-2 flex items-center"><i class="material-icons mr-2">check_circle</i>Valid Students: ' + data.totalValid + '</h4><div class="space-y-1">';
                    data.validStudents.forEach(s => {
                        html += '<div class="text-sm text-green-800"><strong>' + s.studentId_Number + '</strong> - ' + s.fullName +
                            '<span class="text-xs text-green-600 ml-2">(' + s.programmeName + ')</span></div>';
                    });
                    html += '</div></div>';
                }

                if (data.totalNew > 0) {
                    html += '<div class="bg-yellow-50 p-4 rounded-lg border border-yellow-200 ' + (data.totalValid > 0 ? 'mt-3' : '') + '">' +
                        '<h4 class="font-semibold text-yellow-900 mb-2 flex items-center"><i class="material-icons mr-2">info</i>New Students (Pending Admission): ' + data.totalNew + '</h4><div class="space-y-1">';
                    data.newStudents.forEach(s => {
                        html += '<div class="text-sm text-yellow-800"><strong>' + s.studentId_Number + '</strong> - ' + s.status + '</div>';
                    });
                    html += '</div><p class="text-xs text-yellow-700 mt-2 italic"><i class="material-icons text-xs">info</i> These students will be marked as pending admission. Quotations can still be generated for them.</p></div>';
                }

                if (data.totalInvalid > 0) {
                    html += '<div class="bg-red-50 p-4 rounded-lg border border-red-200 ' + (data.totalValid > 0 ? 'mt-3' : '') + '">' +
                        '<h4 class="font-semibold text-red-900 mb-2 flex items-center"><i class="material-icons mr-2">error</i>Invalid Student IDs: ' + data.totalInvalid + '</h4><div class="space-y-1">';
                    data.invalidStudents.forEach(s => {
                        html += '<div class="text-sm text-red-800"><strong>' + s.studentId_Number + '</strong> - ' + s.status + '</div>';
                    });
                    html += '</div></div>';
                }

                resultsDiv.innerHTML = html;
            } catch (error) {
                console.error('Validation error:', error);
                alert('Error validating students. Please try again.');
            }
        }

        async function loadQuotations() {
            try {
                const response = await fetch('/Admin/GetQuotations', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        page: currentPage,
                        pageSize: pageSize,
                        academicYearId: document.getElementById('filterAcademicYear') ? document.getElementById('filterAcademicYear').value : null,
                        semester: document.getElementById('filterListSemester') ? document.getElementById('filterListSemester').value : null,
                        status: document.getElementById('filterStatus') ? document.getElementById('filterStatus').value : null,
                        searchTerm: document.getElementById('searchTerm') ? document.getElementById('searchTerm').value : null
                    })
                });

                const data = await response.json();
                const tbody = document.getElementById('quotationTableBody');

                if (data.quotations && data.quotations.length > 0) {
                    tbody.innerHTML = data.quotations.map(q =>
                        '<tr class="border-b hover:bg-gray-50">' +
                        '<td class="px-3 py-3 text-sm">' + q.rowNumber + '</td>' +
                        '<td class="px-3 py-3"><div class="font-medium text-primary-700">' + q.quotationReference + '</div>' +
                        (q.batchReference ? '<div class="text-xs text-gray-500">' + q.batchReference + '</div>' : '') + '</td>' +
                        '<td class="px-3 py-3"><div class="flex items-center justify-between"><div><div class="font-medium">' + q.studentName + '</div>' +
                        '<div class="text-xs text-gray-500">' + q.studentId + '</div></div>' +
                        (q.isNewStudent ? '<span class="text-xs px-2 py-1 bg-yellow-100 text-yellow-700 rounded ml-2">New</span>' : '') + '</div></td>' +
                        '<td class="px-3 py-3 font-bold text-gray-900">K ' + q.totalAmount.toFixed(2) + '</td>' +
                        '<td class="px-3 py-3"><span class="px-2 py-1 rounded text-xs font-medium ' + getStatusColor(q.status) + '">' + q.status + '</span></td>' +
                        '<td class="px-3 py-3"><div class="text-sm text-gray-900">' + q.createdBy + '</div>' +
                        '<div class="text-xs text-gray-500">' + new Date(q.createdDate).toLocaleDateString() + '</div></td>' +
                        '<td class="px-3 py-3 text-sm text-secondary-600">' + new Date(q.validUntil).toLocaleDateString() + '</td>' +
                        '<td class="px-3 py-3"><button onclick="viewQuotation(' + q.id + ')" class="text-blue-600 hover:text-blue-800" title="View Details">' +
                        '<i class="material-icons text-sm">visibility</i></button></td></tr>'
                    ).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="8" class="px-3 py-8 text-center text-gray-500">' +
                        '<i class="material-icons text-4xl text-gray-300 mb-2">search_off</i><p>No quotations found</p></td></tr>';
                }
            } catch (error) {
                console.error('Error loading quotations:', error);
                document.getElementById('quotationTableBody').innerHTML = '<tr><td colspan="8" class="px-3 py-8 text-center text-red-500">' +
                    '<i class="material-icons text-4xl text-red-300 mb-2">error</i><p>Error loading quotations</p></td></tr>';
            }
        }

        function getStatusColor(status) {
            const colors = {
                'Pending': 'bg-yellow-100 text-yellow-800',
                'Accepted': 'bg-green-100 text-green-800',
                'Rejected': 'bg-red-100 text-red-800',
                'Converted': 'bg-blue-100 text-blue-800',
                'Expired': 'bg-gray-100 text-secondary-800'
            };
            return colors[status] || 'bg-gray-100 text-secondary-800';
        }

        async function viewQuotation(id) {
            try {
                const response = await fetch('/Admin/GetQuotationDetails?id=' + id);
                const data = await response.json();
                console.log(data);
            } catch (error) {
                console.error('Error viewing quotation:', error);
                alert('Error loading quotation details');
            }
        }

