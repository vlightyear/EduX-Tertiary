        function printQuotation(quotationData) {
            const printWindow = window.open('', '', 'height=800,width=800');
            const template = document.getElementById('printQuotationTemplate').innerHTML;

            printWindow.document.write('<html><head><title>Quotation - ' + quotationData.quotationReference + '</title>');
            printWindow.document.write('</head><body>');
            printWindow.document.write(template);
            printWindow.document.write('</body></html>');

            printWindow.document.close();

            const createdDate = new Date(quotationData.createdDate);
            const formattedCreatedDate = createdDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

            const validUntilDate = new Date(quotationData.validUntil);
            const formattedValidDate = validUntilDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

            setTimeout(() => {
                // Quotation details
                printWindow.document.getElementById('print-quotation-ref').textContent = quotationData.quotationReference || 'N/A';
                printWindow.document.getElementById('print-date').textContent = formattedCreatedDate;
                printWindow.document.getElementById('print-batch-ref').textContent = quotationData.batchReference || 'N/A';
                printWindow.document.getElementById('print-valid-until').textContent = formattedValidDate;

                // Student information
                printWindow.document.getElementById('print-student-name').textContent = quotationData.studentName || 'General Quotation';
                printWindow.document.getElementById('print-student-number').textContent = quotationData.studentId || 'N/A';
                printWindow.document.getElementById('print-academic-year').textContent = quotationData.academicYear || 'N/A';
                printWindow.document.getElementById('print-semester').textContent = quotationData.semester ? 'Semester ' + quotationData.semester : 'N/A';
                printWindow.document.getElementById('print-description').textContent = quotationData.quotationDescription || 'Standard Quotation';

                // New student badge
                if (quotationData.isNewStudent) {
                    printWindow.document.getElementById('print-new-student-badge').innerHTML =
                        '<span style="background: #fef3c7; color: #92400e; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: bold; border: 1px solid #d97706;">PENDING ADMISSION</span>';
                } else {
                    printWindow.document.getElementById('print-new-student-badge').innerHTML = '';
                }

                // Fees table
                let totalAmount = 0;
                let feesHtml = '';

                quotationData.items.forEach((item, index) => {
                    // Clean description - remove source tags
                    let cleanDescription = item.description || item.feeTypeName;
                    cleanDescription = cleanDescription.replace(/\s*\(OtherFees\)\s*/gi, '');
                    cleanDescription = cleanDescription.replace(/\s*\(FeeConfiguration\)\s*/gi, '');

                    const amount = parseFloat(item.amount);
                    totalAmount += amount;

                    // Alternating row colors
                    const bgColor = index % 2 === 0 ? '#f9fafb' : '#ffffff';

                    feesHtml += `
                        <tr style="background: ${bgColor};">
                            <td style="padding: 10px; border: 1px solid #e5e7eb;">${item.feeTypeName}</td>
                            <td style="padding: 10px; border: 1px solid #e5e7eb;">${cleanDescription}</td>
                            <td style="padding: 10px; text-align: right; border: 1px solid #e5e7eb;">K ${amount.toFixed(2)}</td>
                        </tr>
                    `;
                });

                printWindow.document.getElementById('print-fees-tbody').innerHTML = feesHtml;
                printWindow.document.getElementById('print-total-amount').textContent = totalAmount.toFixed(2);
                printWindow.document.getElementById('print-amount-words').textContent = formatAmountInWords(totalAmount);

                printWindow.print();
                printWindow.close();
            }, 250);
        }

        function generateQuotationPDF(quotationData) {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('p', 'mm', 'a4');

            const pageWidth = doc.internal.pageSize.getWidth();
            const pageHeight = doc.internal.pageSize.getHeight();
            const margin = 20;
            const contentWidth = pageWidth - (margin * 2);
            let yPosition = margin;

            // Colors
            const primaryColor = [30, 58, 138]; // #1e3a8a
            const secondaryColor = [59, 130, 246]; // #3b82f6
            const textColor = [0, 0, 0];
            const grayColor = [102, 102, 102];

            // Header
            doc.setFillColor(240, 249, 255);
            doc.rect(0, 0, pageWidth, 40, 'F');

            // University Logo (if you have it as base64, otherwise skip this)
            // doc.addImage(logoBase64, 'PNG', margin, yPosition, 30, 30);

            // University Info
            doc.setFontSize(24);
            doc.setTextColor(...primaryColor);
            doc.setFont('helvetica', 'bold');
            doc.text('Fee Quotation', margin, yPosition + 10);

            doc.setFontSize(18);
            doc.setTextColor(...secondaryColor);
            doc.text('Eden University', margin, yPosition + 18);

            doc.setFontSize(9);
            doc.setTextColor(...grayColor);
            doc.setFont('helvetica', 'normal');
            doc.text('Barlastone Park, Lusaka, Zambia', margin, yPosition + 24);
            doc.text('P.O Box 37787 | TEL: 0979079400/0979079480/0966686666', margin, yPosition + 28);
            doc.text('WEBSITE: www.edenuniversity.edu.zm', margin, yPosition + 32);

            yPosition = 55;

            // Quotation Details Box
            doc.setDrawColor(59, 130, 246);
            doc.setLineWidth(0.5);
            doc.line(margin, yPosition, pageWidth - margin, yPosition);
            yPosition += 8;

            // Two-column layout for quotation details
            doc.setFontSize(10);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(...textColor);
            doc.text('Quotation No:', margin, yPosition);
            doc.setFont('helvetica', 'normal');
            doc.text(quotationData.quotationReference || 'N/A', margin + 35, yPosition);

            const createdDate = new Date(quotationData.createdDate);
            const formattedDate = createdDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
            doc.setFont('helvetica', 'bold');
            doc.text('Date:', pageWidth - margin - 50, yPosition);
            doc.setFont('helvetica', 'normal');
            doc.text(formattedDate, pageWidth - margin - 30, yPosition);

            yPosition += 6;
            doc.setFont('helvetica', 'bold');
            doc.text('Batch Reference:', margin, yPosition);
            doc.setFont('helvetica', 'normal');
            doc.text(quotationData.batchReference || 'N/A', margin + 35, yPosition);

            const validUntilDate = new Date(quotationData.validUntil);
            const formattedValidDate = validUntilDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
            doc.setFont('helvetica', 'bold');
            doc.text('Valid Until:', pageWidth - margin - 50, yPosition);
            doc.setFont('helvetica', 'normal');
            doc.text(formattedValidDate, pageWidth - margin - 30, yPosition);

            yPosition += 10;

            // Student Information Box
            doc.setFillColor(239, 246, 255);
            doc.setDrawColor(59, 130, 246);
            doc.roundedRect(margin, yPosition, contentWidth, 28, 2, 2, 'FD');

            yPosition += 7;
            doc.setFontSize(11);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(...textColor);
            doc.text('Student Name:', margin + 5, yPosition);
            doc.setFont('helvetica', 'normal');
            doc.text(quotationData.studentName || 'General Quotation', margin + 40, yPosition);

            if (quotationData.isNewStudent) {
                doc.setFillColor(254, 243, 199);
                doc.setDrawColor(146, 64, 14);
                doc.roundedRect(pageWidth - margin - 45, yPosition - 4, 40, 5, 1, 1, 'FD');
                doc.setFontSize(8);
                doc.setTextColor(146, 64, 14);
                doc.setFont('helvetica', 'bold');
                doc.text('PENDING ADMISSION', pageWidth - margin - 43, yPosition);
            }

            yPosition += 6;
            doc.setFontSize(10);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(...textColor);
            doc.text('Student Number:', margin + 5, yPosition);
            doc.setFont('helvetica', 'normal');
            doc.text(quotationData.studentId || 'N/A', margin + 40, yPosition);

            yPosition += 6;
            doc.setFont('helvetica', 'bold');
            doc.text('Academic Year:', margin + 5, yPosition);
            doc.setFont('helvetica', 'normal');
            doc.text(quotationData.academicYear || 'N/A', margin + 40, yPosition);

            doc.setFont('helvetica', 'bold');
            doc.text('Semester:', margin + 90, yPosition);
            doc.setFont('helvetica', 'normal');
            doc.text(quotationData.semester ? 'Semester ' + quotationData.semester : 'N/A', margin + 110, yPosition);

            yPosition += 5;

            // Description
            doc.setFontSize(10);
            doc.setFont('helvetica', 'bold');
            doc.text('Description:', margin + 5, yPosition);
            doc.setFont('helvetica', 'italic');
            doc.setTextColor(...grayColor);
            const description = quotationData.quotationDescription || 'Standard Quotation';
            doc.text(description, margin + 30, yPosition, { maxWidth: contentWidth - 30 });

            yPosition += 10;

            // Fees Table Header
            doc.setFillColor(243, 244, 246);
            doc.setDrawColor(59, 130, 246);
            doc.rect(margin, yPosition, contentWidth, 8, 'FD');

            doc.setFontSize(9);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(...textColor);
            doc.text('Fee Type', margin + 2, yPosition + 5);
            doc.text('Description', margin + 50, yPosition + 5);
            doc.text('Amount (ZMW)', pageWidth - margin - 30, yPosition + 5);

            yPosition += 8;

            // Fees Table Body
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(9);

            let totalAmount = 0;
            quotationData.items.forEach((item, index) => {
                // Check if we need a new page
                if (yPosition > pageHeight - 40) {
                    doc.addPage();
                    yPosition = margin;
                }

                let cleanDescription = item.description || item.feeTypeName;
                cleanDescription = cleanDescription.replace(/\s*\(OtherFees\)\s*/gi, '');
                cleanDescription = cleanDescription.replace(/\s*\(FeeConfiguration\)\s*/gi, '');

                // Alternating row colors
                if (index % 2 === 0) {
                    doc.setFillColor(249, 250, 251);
                    doc.rect(margin, yPosition, contentWidth, 7, 'F');
                }

                doc.setDrawColor(229, 231, 235);
                doc.line(margin, yPosition, pageWidth - margin, yPosition);

                doc.text(item.feeTypeName.substring(0, 25), margin + 2, yPosition + 5);
                doc.text(cleanDescription.substring(0, 40), margin + 50, yPosition + 5);
                doc.text('K ' + parseFloat(item.amount).toFixed(2), pageWidth - margin - 30, yPosition + 5);

                totalAmount += parseFloat(item.amount);
                yPosition += 7;
            });

            // Total Row
            doc.setFillColor(243, 244, 246);
            doc.rect(margin, yPosition, contentWidth, 8, 'F');
            doc.setFont('helvetica', 'bold');
            doc.setFontSize(11);
            doc.setTextColor(...textColor);
            doc.text('Total Amount:', pageWidth - margin - 60, yPosition + 5);
            doc.setTextColor(5, 150, 105);
            doc.text('K ' + totalAmount.toFixed(2), pageWidth - margin - 30, yPosition + 5);

            yPosition += 12;

            // Amount in Words
            doc.setFillColor(249, 250, 251);
            doc.setDrawColor(59, 130, 246);
            doc.roundedRect(margin, yPosition, contentWidth, 12, 2, 2, 'FD');
            yPosition += 5;
            doc.setFontSize(9);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(...textColor);
            doc.text('Amount in Words:', margin + 3, yPosition);
            doc.setFont('helvetica', 'italic');
            const amountWords = formatAmountInWords(totalAmount);
            doc.text(amountWords, margin + 3, yPosition + 4, { maxWidth: contentWidth - 6 });

            yPosition += 15;

            // Important Notes
            if (yPosition > pageHeight - 50) {
                doc.addPage();
                yPosition = margin;
            }

            doc.setFillColor(255, 247, 237);
            doc.setDrawColor(254, 215, 170);
            doc.roundedRect(margin, yPosition, contentWidth, 20, 2, 2, 'FD');
            yPosition += 6;
            doc.setFontSize(10);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(146, 64, 14);
            doc.text('Important Notes:', margin + 3, yPosition);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(120, 53, 15);
            yPosition += 5;
            doc.text('• This is a quotation and not a receipt. Payment must be made to validate.', margin + 5, yPosition);
            yPosition += 4;
            doc.text('• Fees are subject to change without prior notice.', margin + 5, yPosition);

            // Footer
            yPosition = pageHeight - 20;
            doc.setDrawColor(229, 231, 235);
            doc.line(margin, yPosition, pageWidth - margin, yPosition);
            yPosition += 5;
            doc.setFontSize(8);
            doc.setTextColor(...grayColor);
            doc.setFont('helvetica', 'italic');
            doc.text('This is a computer-generated quotation and does not require a signature.', pageWidth / 2, yPosition, { align: 'center' });
            yPosition += 4;
            doc.text('For inquiries, please contact finance@edenuniversity.edu.zm', pageWidth / 2, yPosition, { align: 'center' });

            // Open PDF in new window
            const pdfBlob = doc.output('blob');
            const pdfUrl = URL.createObjectURL(pdfBlob);
            window.open(pdfUrl, '_blank');
        }

        function formatAmountInWords(amount) {
            const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
            const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
            const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];

            function numberToWords(num) {
                if (num === 0) return 'Zero';
                let words = '';
                if (Math.floor(num / 1000000) > 0) {
                    words += numberToWords(Math.floor(num / 1000000)) + ' Million ';
                    num %= 1000000;
                }
                if (Math.floor(num / 1000) > 0) {
                    words += numberToWords(Math.floor(num / 1000)) + ' Thousand ';
                    num %= 1000;
                }
                if (Math.floor(num / 100) > 0) {
                    words += ones[Math.floor(num / 100)] + ' Hundred ';
                    num %= 100;
                }
                if (num > 0) {
                    if (num < 10) {
                        words += ones[num];
                    } else if (num >= 10 && num < 20) {
                        words += teens[num - 10];
                    } else {
                        words += tens[Math.floor(num / 10)];
                        if (num % 10 > 0) {
                            words += ' ' + ones[num % 10];
                        }
                    }
                }
                return words.trim();
            }

            const integerPart = Math.floor(amount);
            const decimalPart = Math.round((amount - integerPart) * 100);
            let result = numberToWords(integerPart);
            if (decimalPart > 0) {
                result += ' and ' + decimalPart + '/100';
            }
            return result + ' Kwacha Only.';
        }

        document.getElementById('quotationForm').addEventListener('submit', function(e) {
            const primarySchoolId = document.getElementById('primaryFilterSchool') ? document.getElementById('primaryFilterSchool').value : '';
            const primaryProgrammeId = document.getElementById('primaryFilterProgramme') ? document.getElementById('primaryFilterProgramme').value : '';

            if (!primarySchoolId || !primaryProgrammeId) {
                e.preventDefault();
                alert('Please select both School and Programme before generating quotations.');
                return false;
            }

            const inputs = document.querySelectorAll('.student-id-input');
            const studentIds = Array.from(inputs).map(i => i.value.trim()).filter(Boolean).join(',');
            document.getElementById('hiddenStudentIds').value = studentIds;

            const selectedFees = document.querySelectorAll('input[name="SelectedFeeIds"]:checked');
            if (selectedFees.length === 0) {
                e.preventDefault();
                alert('Please select at least one fee before generating quotations.');
                return false;
            }

            const submitBtn = document.getElementById('generateQuotationBtn');
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="material-icons mr-2 animate-spin">sync</i>Generating...';
            }
        });
    </script>
