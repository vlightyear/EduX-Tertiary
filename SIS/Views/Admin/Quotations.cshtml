                            </p>
                        }
                    </div> *@

                    <div id="selectedFeesInfo" class="mt-4 p-3 bg-blue-50 rounded-lg border border-blue-200 hidden">
                        <div class="flex justify-between items-center">
                            <span class="font-medium text-blue-900">Selected Fees:</span>
                            <span id="selectedFeesCount" class="text-blue-700">0 fees selected</span>
                        </div>
                        <div class="mt-2 flex justify-between items-center">
                            <span class="text-blue-800">Total Amount per Quotation:</span>
                            <span id="totalAmount" class="font-bold text-lg text-blue-900">K 0.00</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 2: Quotation Details -->
            <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3 flex items-center">
                    <span class="bg-primary-600 text-white rounded-full w-8 h-8 flex items-center justify-center mr-2">2</span>
                    Quotation Details
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-2">Academic Year *</label>
                        <select name="AcademicYearId" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-primary-500">
                            <option value="">Select Year</option>
                            @if (ViewBag.AcademicYears != null)
                            {
                                @foreach (var year in ViewBag.AcademicYears)
                                {
                                    <option value="@year.Value">@year.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Semester</label>
                        <select name="Semester" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-primary-500">
                            <option value="">None</option>
                            <option value="1">Semester 1</option>
                            <option value="2">Semester 2</option>
                        </select>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-2">Description (Optional)</label>
                        <input type="text" name="QuotationDescription" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-primary-500"
                               placeholder="e.g., 2024/2025 Tuition Estimate">
                    </div>
                </div>
            </div>

            <!-- Step 3: Add Students -->
            <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3 flex items-center">
                    <span class="bg-primary-600 text-white rounded-full w-8 h-8 flex items-center justify-center mr-2">3</span>
                    Add Students (Optional)
                </h3>
                <div class="bg-gray-50 rounded-lg p-4 border">
                    <div class="mb-3 p-3 bg-blue-50 border border-blue-200 rounded-lg">
                        <p class="text-sm text-blue-800">
                            <i class="material-icons text-sm">info</i>
                            <strong>Note:</strong> You can generate a general quotation without student IDs for walk-in inquiries or prospective students.
                        </p>
                    </div>
                    <div id="studentInputsContainer" class="space-y-2 mb-3">
                        <div class="flex gap-2 student-input-row">
                            <input type="text" placeholder="Student ID (optional - leave empty for general quotation)" class="flex-1 px-4 py-2 border rounded-lg student-id-input focus:ring-2 focus:ring-primary-500">
                            <button type="button" onclick="addStudentInput()" class="px-3 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                                <i class="material-icons">add</i>
                            </button>
                        </div>
                    </div>
                    <button type="button" onclick="validateStudents()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                        <i class="material-icons text-sm mr-2">fact_check</i>Validate Students
                    </button>
                </div>
            </div>

            <div id="validationResults" class="mb-6 hidden"></div>

            <div class="flex justify-between items-center">
                <label class="flex items-center cursor-pointer">
                    <input type="checkbox" name="AllowDuplicates" value="true" checked class="rounded">
                    <span class="ml-2 text-sm">Allow duplicate quotations</span>
                </label>
                <button type="submit" id="generateQuotationBtn" class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 flex items-center shadow-lg">
                    <i class="material-icons mr-2">request_quote</i>Generate Quotations
                </button>
            </div>
        </form>
    </div>

    <!-- View Quotations Section -->
    <div id="listSection" class="bg-white rounded-lg shadow-lg hidden">
        <div class="p-4 bg-gray-50 border-b">
            <div class="grid grid-cols-4 gap-3">
                <select id="filterAcademicYear" onchange="loadQuotations()" class="px-3 py-2 text-sm border rounded-lg focus:ring-2 focus:ring-primary-500">
                    <option value="">All Years</option>
                    @if (ViewBag.AcademicYears != null)
                    {
                        @foreach (var year in ViewBag.AcademicYears)
                        {
                            <option value="@year.Value">@year.Text</option>
                        }
                    }
                </select>
                <select id="filterListSemester" onchange="loadQuotations()" class="px-3 py-2 text-sm border rounded-lg focus:ring-2 focus:ring-primary-500">
                    <option value="">All Semesters</option>
                    <option value="1">Semester 1</option>
                    <option value="2">Semester 2</option>
                </select>
                <select id="filterStatus" onchange="loadQuotations()" class="px-3 py-2 text-sm border rounded-lg focus:ring-2 focus:ring-primary-500">
                    <option value="">All Status</option>
                    <option value="Pending">Pending</option>
                    <option value="Accepted">Accepted</option>
                    <option value="Rejected">Rejected</option>
                    <option value="Converted">Converted</option>
                </select>
                <input type="text" id="searchTerm" onkeyup="loadQuotations()" placeholder="Search..." class="px-3 py-2 text-sm border rounded-lg focus:ring-2 focus:ring-primary-500">
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full">
                <thead class="bg-primary-50">
                    <tr>
                        <th class="px-3 py-3 text-left text-xs font-medium text-gray-700 uppercase">#</th>
                        <th class="px-3 py-3 text-left text-xs font-medium text-gray-700 uppercase">Quotation</th>
                        <th class="px-3 py-3 text-left text-xs font-medium text-gray-700 uppercase">Student</th>
                        <th class="px-3 py-3 text-left text-xs font-medium text-gray-700 uppercase">Amount</th>
                        <th class="px-3 py-3 text-left text-xs font-medium text-gray-700 uppercase">Status</th>
                        <th class="px-3 py-3 text-left text-xs font-medium text-gray-700 uppercase">Generated By</th>
                        <th class="px-3 py-3 text-left text-xs font-medium text-gray-700 uppercase">Valid Until</th>
                        <th class="px-3 py-3 text-left text-xs font-medium text-gray-700 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody id="quotationTableBody">
                    <tr>
                        <td colspan="8" class="px-3 py-8 text-center text-gray-500">
                            <i class="material-icons text-4xl text-gray-300 mb-2">assignment</i>
                            <p>No quotations to display</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Print Quotation Template (Hidden) -->
<div id="printQuotationTemplate" style="display: none;">
    <div style="width: 210mm; min-height: 297mm; padding: 20mm; font-family: Arial, sans-serif; background: white;">
        <!-- University Header -->
        <div style="text-align: center; margin-bottom: 30px; border-bottom: 3px solid #1e3a8a; padding-bottom: 20px;">
            <div style="display: flex; align-items: center; justify-center; margin-bottom: 10px;">
                <img src="/images/institution-logo.png" alt="Eden University Logo" style="width: 100px; height: 100px; object-fit: contain; margin-right: 20px;" />
                <div style="text-align: left;">
                    <h1 style="margin: 0; color: #1e3a8a; font-size: 28px;">Fee Quotation</h1>
                    <h2 style="margin: 5px 0; color: #3b82f6; font-size: 22px;">Eden University</h2>
