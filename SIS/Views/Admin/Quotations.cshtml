@{
    ViewData["Title"] = "Quotations Management";
}

<div class="min-h-screen p-4">
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-primary-800 flex items-center">
            <i class="material-icons mr-2 text-primary-600">request_quote</i>
            Quotations Management
        </h1>
        <div class="flex gap-2">
            <button onclick="showSection('generate')" id="btnShowGenerate"
                    class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 flex items-center">
                <i class="material-icons mr-2">add</i>Generate Quotation
            </button>
            <button onclick="showSection('list')" id="btnShowList"
                    class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 flex items-center">
                <i class="material-icons mr-2">list</i>View Quotations
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg flex items-start">
            <i class="material-icons mr-2">check_circle</i>
            <div class="flex-1">
                <p class="font-medium">Success!</p>
                <p class="text-sm">@TempData["SuccessMessage"]</p>
            </div>
            @if (TempData["LastQuotationData"] != null)
            {
                <button onclick='printQuotation(@Html.Raw(TempData["LastQuotationData"]))'
                        class="ml-3 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center shadow-md hover:shadow-lg">
                    <i class="material-icons text-sm mr-2">print</i>
                    Print Quotation
                </button>
            }
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg flex items-center">
            <i class="material-icons mr-2">error</i><span>@TempData["ErrorMessage"]</span>
        </div>
    }
    @if (TempData["WarningMessage"] != null)
    {
        <div class="mb-4 p-4 bg-yellow-100 border border-yellow-400 text-yellow-700 rounded-lg flex items-center">
            <i class="material-icons mr-2">warning</i><span>@Html.Raw(TempData["WarningMessage"])</span>
        </div>
    }

    <div id="generateSection" class="bg-white rounded-lg shadow-lg p-6">
        <form id="quotationForm" method="post" action="/Admin/GenerateQuotations">
            @Html.AntiForgeryToken()
            <input type="hidden" name="StudentIds" id="hiddenStudentIds" />

            <!-- Step 1: Select Fee Source and Filter -->
            <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3 flex items-center">
                    <span class="bg-primary-600 text-white rounded-full w-8 h-8 flex items-center justify-center mr-2">1</span>
                    Select Fee Source and Filters
                </h3>

                <!-- Primary Filters (School & Programme) - REQUIRED -->
                <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg p-4 border-2 border-blue-300 mb-4">
                    <div class="flex items-center mb-3">
                        <i class="material-icons text-blue-600 mr-2">filter_alt</i>
                        <h4 class="font-semibold text-blue-900">Required Filters</h4>
                        <span class="ml-2 text-xs px-2 py-1 bg-red-100 text-red-700 rounded-full font-medium">Required</span>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                School <span class="text-red-600">*</span>
                            </label>
                            <select id="primaryFilterSchool" onchange="onSchoolChange()"
                                    class="w-full px-4 py-2 border-2 border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                <option value="">-- Select School --</option>
                                @foreach (var school in ViewBag.Schools)
                                {
                                    <option value="@school.Id">@school.Name</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                Programme <span class="text-red-600">*</span>
                            </label>
                            <select id="primaryFilterProgramme" onchange="applyFilters()"
                                    class="w-full px-4 py-2 border-2 border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                <option value="">-- Select Programme --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Fee Source Selection -->
                <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Fee Source</label>
                    <div class="flex gap-4 mb-3">
                        @* <label class="flex items-center cursor-pointer">
                            <input type="radio" name="feeSourceFilter" value="OtherFees" checked onchange="changeFeeSource()" class="mr-2">
                            <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded text-sm font-medium">Other Fees</span>
                        </label> *@
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="feeSourceFilter" value="FeeConfiguration" checked onchange="changeFeeSource()" class="mr-2">
                            <span class="px-3 py-1 bg-green-100 text-green-700 rounded text-sm font-medium">Fee Configuration</span>
                        </label>
                    </div>

                    <!-- Student Type Filter -->
                    <div class="border-t pt-3">
                        <label class="block text-xs font-medium text-gray-700 mb-2">Filter by Student Type</label>
                        <div class="flex gap-3">
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="studentTypeFilter" value="all" checked onchange="applyFilters()" class="mr-1.5">
                                <span class="text-sm">All Students</span>
                            </label>
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="studentTypeFilter" value="local" onchange="applyFilters()" class="mr-1.5">
                                <span class="text-sm text-green-700">Local Only</span>
                            </label>
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="studentTypeFilter" value="foreign" onchange="applyFilters()" class="mr-1.5">
                                <span class="text-sm text-orange-700">Foreign Only</span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Additional Filters for Fee Configuration (shown only when Fee Configuration is selected) -->
                <div id="feeConfigFilters" class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-4 hidden">
                    <h4 class="font-medium text-gray-700 mb-3 flex items-center">
                        <i class="material-icons text-sm mr-2">tune</i>
                        Additional Filters (Optional)
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Mode of Study</label>
                            <select id="filterMode" onchange="applyFilters()" class="w-full px-3 py-2 text-sm border rounded-lg focus:ring-2 focus:ring-primary-500">
                                <option value="">All Modes</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Program Level</label>
                            <select id="filterLevel" onchange="applyFilters()" class="w-full px-3 py-2 text-sm border rounded-lg focus:ring-2 focus:ring-primary-500">
                                <option value="">All Levels</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Year of Study</label>
                            <select id="filterYearOfStudy" onchange="applyFilters()" class="w-full px-3 py-2 text-sm border rounded-lg focus:ring-2 focus:ring-primary-500">
                                <option value="">All Years</option>
                                <option value="1">Year 1</option>
                                <option value="2">Year 2</option>
                                <option value="3">Year 3</option>
                                <option value="4">Year 4</option>
                                <option value="5">Year 5</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-secondary-600 mb-1">Semester</label>
                            <select id="filterSemester" onchange="applyFilters()" class="w-full px-3 py-2 text-sm border rounded-lg focus:ring-2 focus:ring-primary-500">
                                <option value="">All Semesters</option>
                                <option value="1">Semester 1</option>
                                <option value="2">Semester 2</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="button" onclick="clearAdditionalFilters()" class="px-3 py-1.5 text-sm bg-gray-600 text-white rounded-lg hover:bg-gray-700">
                            <i class="material-icons text-sm mr-1">clear</i>Clear Additional Filters
                        </button>
                    </div>
                </div>

                <!-- Selection Prompt (shown when no filters selected) -->
                <div id="selectionPrompt" class="bg-white rounded-lg p-8 border-2 border-dashed border-gray-300 text-center">
                    <i class="material-icons text-6xl text-gray-300 mb-3">school</i>
                    <h4 class="text-lg font-semibold text-gray-700 mb-2">Select School and Programme</h4>
                    <p class="text-gray-500">Please select both school and programme from the filters above to view available fees</p>
                </div>

                <!-- Available Fees Display (shown only after filters selected) -->
                <div id="feesDisplayContainer" class="bg-gray-50 rounded-lg p-4 border border-gray-200 hidden">
                    <div class="flex justify-between items-center mb-3">
                        <h4 class="font-medium text-gray-700">Available Fees</h4>
                        <span id="availableFeesCount" class="text-sm text-secondary-600">0 fees available</span>
                    </div>

                    <div id="feesContainer">
                        @if (ViewBag.AllFees != null && ((IEnumerable<dynamic>)ViewBag.AllFees).Any())
                        {
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                                @foreach (var fee in ViewBag.AllFees)
                                {
                                    var isLocalFee = fee.AppliesOnlyToLocalStudents;
                                    var isForeignFee = fee.AppliesOnlyToForeignStudents;
                                    var isUniversalFee = !fee.AppliesOnlyToLocalStudents && !fee.AppliesOnlyToForeignStudents;

                                    <label class="fee-item flex items-start space-x-3 p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-500 cursor-pointer transition-all"
                                           data-source="@fee.Source"
                                           data-school-id="@(fee.SchoolId ?? 0)"
                                           data-programme-id="@(fee.ProgrammeId ?? 0)"
                                           data-mode-id="@(fee.ModeId ?? 0)"
                                           data-level-id="@(fee.LevelId ?? 0)"
                                           data-year-of-study="@(fee.YearOfStudy ?? 0)"
                                           data-semester="@(fee.Semester ?? 0)"
                                           data-is-foreign="@isForeignFee.ToString().ToLower()"
                                           data-is-local="@isLocalFee.ToString().ToLower()">
                                        <input type="checkbox" name="SelectedFeeIds" value="@(fee.Source)-@(fee.Id)"
                                               class="mt-1 rounded text-primary-600 focus:ring-primary-500"
                                               onchange="updateSelectedFees()"
                                               data-amount="@fee.Amount">
                                        <div class="flex-1">
                                            <div class="flex items-center justify-between mb-1">
                                                <div class="font-medium text-gray-900">@fee.FeeName</div>
                                                <span class="text-xs px-2 py-1 rounded @(fee.Source == "OtherFees" ? "bg-blue-100 text-blue-700" : "bg-green-100 text-green-700")">
                                                    @(fee.Source == "OtherFees" ? "Other" : "Config")
                                                </span>
                                            </div>
                                            <div class="text-sm text-secondary-600 fee-amount">K @fee.Amount.ToString("N2")</div>
                                            <div class="text-xs text-gray-500">@fee.SchoolName</div>

                                            @if (isUniversalFee)
                                            {
                                                <div class="text-xs text-blue-600 font-medium mt-1 flex items-center">
                                                    <span class="inline-block w-2 h-2 bg-blue-500 rounded-full mr-1"></span>
                                                    All Students
                                                </div>
                                            }
                                            else if (isForeignFee)
                                            {
                                                <div class="text-xs text-orange-600 font-medium mt-1 flex items-center">
                                                    <span class="inline-block w-2 h-2 bg-orange-500 rounded-full mr-1"></span>
                                                    Foreign Students
                                                </div>
                                            }
                                            else if (isLocalFee)
                                            {
                                                <div class="text-xs text-green-600 font-medium mt-1 flex items-center">
                                                    <span class="inline-block w-2 h-2 bg-green-500 rounded-full mr-1"></span>
                                                    Local Students
                                                </div>
                                            }

                                            @if (fee.Source == "FeeConfiguration")
                                            {
                                                @if (fee.YearOfStudy != null && fee.YearOfStudy > 0)
                                                {
                                                    <div class="text-xs text-blue-600 mt-1">Year @fee.YearOfStudy</div>
                                                }
                                                @if (fee.Semester != null && fee.Semester > 0)
                                                {
                                                    <div class="text-xs text-purple-600">Semester @fee.Semester</div>
                                                }
                                            }
                                        </div>
                                    </label>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-gray-500 text-center py-8">
                                <i class="material-icons text-4xl text-gray-300 mb-2">assignment</i><br>
                                No fees available. Please add fees first.
                            </p>
                        }
                    </div>

                    @* <div id="feesContainer">
                        @if (ViewBag.AllFees != null && ((IEnumerable<dynamic>)ViewBag.AllFees).Any())
                        {
