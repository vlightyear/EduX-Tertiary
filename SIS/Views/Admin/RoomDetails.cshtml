@model SIS.Models.StudentAccommodation.Room
@using SIS.Enums
@{
    ViewData["Title"] = $"Room Details - {Model.RoomNumber}";
}
<div class="h-[90vh] p-4">
    <!-- Header Section with Breadcrumb Navigation -->
    <div class="mb-6">
        <div class="flex justify-between items-center mb-2">
            <div class="flex items-center text-secondary-800">
                <i class="material-icons text-3xl mr-2">meeting_room</i>
                <div>
                    <h1 class="text-2xl font-bold">Room @Model.RoomNumber</h1>
                    <div class="flex items-center text-sm text-slate-600">
                        <a asp-controller="Admin" asp-action="Hostels" class="hover:text-cyan-600">Hostels</a>
                        <i class="material-icons text-xs mx-1">chevron_right</i>
                        <a asp-controller="Admin" asp-action="HostelDetails" asp-route-id="@Model.HostelId" class="hover:text-cyan-600">@Model.Hostel?.HostelName</a>
                        <i class="material-icons text-xs mx-1">chevron_right</i>
                        <span>Room @Model.RoomNumber</span>
                    </div>
                </div>
            </div>
            <div class="flex space-x-2">
                <a asp-controller="Admin" asp-action="HostelDetails" asp-route-id="@Model.HostelId"
                   class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors flex items-center">
                    <i class="material-icons mr-2">arrow_back</i>
                    Back to Hostel
                </a>
                <button onclick="showUpdateRoomModal('@Model.RoomId')"
                        class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
                    <i class="material-icons mr-2">edit</i>
                    Edit Room
                </button>
            </div>
        </div>
    </div>
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
            <p>@TempData["Success"]</p>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
            <p>@TempData["Error"]</p>
        </div>
    }

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-150px)]">
        <!-- Left Column: Room Info and Statistics (1/3) -->
        <div class="w-1/3 space-y-4">
            <!-- Room Information Card -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-lg font-semibold text-secondary-800 mb-4 flex items-center">
                    <i class="material-icons mr-2 text-cyan-600">info</i>
                    Room Information
                </h2>
                <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-2">
                        <!-- Room Type -->
                        <div class="bg-slate-50 p-3 rounded-lg">
                            <p class="text-xs text-slate-500">Room Type</p>
                            <div class="flex items-center mt-1">
                                <i class="material-icons text-cyan-600 mr-1">hotel</i>
                                <p class="font-medium">@Model.RoomType</p>
                            </div>
                        </div>

                        <!-- Floor -->
                        <div class="bg-slate-50 p-3 rounded-lg">
                            <p class="text-xs text-slate-500">Floor</p>
                            <div class="flex items-center mt-1">
                                <i class="material-icons text-cyan-600 mr-1">layers</i>
                                <p class="font-medium">@Model.Floor</p>
                            </div>
                        </div>

                        <!-- Capacity -->
                        <div class="bg-slate-50 p-3 rounded-lg">
                            <p class="text-xs text-slate-500">Capacity</p>
                            <div class="flex items-center mt-1">
                                <i class="material-icons text-cyan-600 mr-1">people</i>
                                <p class="font-medium">@Model.Capacity Beds</p>
                            </div>
                        </div>

                        <!-- Gender -->
                        <div class="bg-slate-50 p-3 rounded-lg">
                            <p class="text-xs text-slate-500">Gender</p>
                            <div class="flex items-center mt-1">
                                @{
                                    var genderIcon = "people";
                                    var genderClass = "text-purple-600";

                                    if (Model.Gender?.ToLower() == "male")
                                    {
                                        genderIcon = "male";
                                        genderClass = "text-blue-600";
                                    }
                                    else if (Model.Gender?.ToLower() == "female")
                                    {
                                        genderIcon = "female";
                                        genderClass = "text-pink-600";
                                    }
                                }
                                <i class="material-icons @genderClass mr-1">@genderIcon</i>
                                <p class="font-medium">@Model.Gender</p>
                            </div>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <p class="text-xs text-slate-500">Status</p>
                        <div class="flex items-center mt-1">
                            @{
                                var statusIcon = "check_circle";
                                var statusClass = "text-green-600";
                                var statusText = "Available";

                                if (Model.Status == Status.Maintenance)
                                {
                                    statusIcon = "build";
                                    statusClass = "text-yellow-600";
                                    statusText = "Maintenance";
                                }
                                else if (Model.Status == Status.Reserved)
                                {
                                    statusIcon = "bookmark";
                                    statusClass = "text-blue-600";
                                    statusText = "Reserved";
                                }
                                else if (Model.Status == Status.Occupied)
                                {
                                    statusIcon = "person";
                                    statusClass = "text-red-600";
                                    statusText = "Occupied";
                                }
                            }
                            <i class="material-icons @statusClass mr-1">@statusIcon</i>
                            <p class="font-medium">@statusText</p>
                        </div>
                    </div>

                    <!-- Special Reservation -->
                    @if (Model.IsSpecialReservation)
                    {
                        <div class="bg-indigo-50 p-3 rounded-lg border border-indigo-100">
                            <div class="flex items-center">
                                <i class="material-icons text-indigo-600 mr-1">stars</i>
                                <p class="font-medium text-indigo-800">Special Reservation</p>
                            </div>
                        </div>
                    }

                    <!-- Audit Info -->
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <p class="text-xs text-slate-500 mb-1">Created</p>
                        <div class="flex justify-between text-sm">
                            <div>
                                <i class="material-icons text-xs inline-block align-text-top">person</i>
                                <span>@Model.CreatedBy</span>
                            </div>
                            <div>
                                <i class="material-icons text-xs inline-block align-text-top">schedule</i>
                                <span>@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.UpdatedBy))
                        {
                            <p class="text-xs text-slate-500 mt-2 mb-1">Last Updated</p>
                            <div class="flex justify-between text-sm">
                                <div>
                                    <i class="material-icons text-xs inline-block align-text-top">person</i>
                                    <span>@Model.UpdatedBy</span>
                                </div>
                                <div>
                                    <i class="material-icons text-xs inline-block align-text-top">schedule</i>
                                    <span>@Model.UpdatedAt?.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-lg font-semibold text-secondary-800 mb-4 flex items-center">
                    <i class="material-icons mr-2 text-cyan-600">analytics</i>
                    Occupancy Statistics
                </h2>
                <div class="grid grid-cols-2 gap-3">
                    <!-- Total Beds -->
                    <div class="bg-purple-50 p-3 rounded-lg border border-purple-100">
                        <p class="text-xs text-purple-500">Total Beds</p>
                        <div class="flex items-center justify-between mt-1">
                            <p class="text-xl font-semibold text-purple-700">@Model.BedSpaces.Count</p>
                            <i class="material-icons text-purple-300">hotel</i>
                        </div>
                    </div>

                    <!-- Occupied Beds -->
                    <div class="bg-amber-50 p-3 rounded-lg border border-amber-100">
                        <p class="text-xs text-amber-500">Occupied Beds</p>
                        <div class="flex items-center justify-between mt-1">
                            <p class="text-xl font-semibold text-amber-700">@ViewBag.OccupiedBeds</p>
                            <i class="material-icons text-amber-300">person</i>
                        </div>
                    </div>

                    <!-- Available Beds -->
                    <div class="bg-green-50 p-3 rounded-lg border border-green-100">
                        <p class="text-xs text-green-500">Available Beds</p>
                        <div class="flex items-center justify-between mt-1">
                            <p class="text-xl font-semibold text-green-700">@ViewBag.AvailableBeds</p>
                            <i class="material-icons text-green-300">check_circle</i>
                        </div>
                    </div>

                    <!-- Resources Needing Repair -->
                    <div class="bg-yellow-50 p-3 rounded-lg border border-yellow-100">
                        <p class="text-xs text-yellow-500">Resources Needing Repair</p>
                        <div class="flex items-center justify-between mt-1">
                            <p class="text-xl font-semibold text-yellow-700">@ViewBag.ResourcesNeedingRepair</p>
                            <i class="material-icons text-yellow-300">build</i>
                        </div>
                    </div>
                </div>

                <!-- Occupancy Rate -->
                <div class="mt-3">
                    <p class="text-xs text-slate-500 mb-1">Occupancy Rate</p>
                    @{
                        var occupancyRate = ViewBag.OccupancyRate;
                        var occupancyColorClass = "bg-green-500";

                        if (occupancyRate < 30)
                        {
                            occupancyColorClass = "bg-red-500";
                        }
                        else if (occupancyRate < 70)
                        {
                            occupancyColorClass = "bg-yellow-500";
                        }
                    }
                    <div class="w-full bg-gray-200 rounded-full h-2.5">
                        <div class="@occupancyColorClass h-2.5 rounded-full" style="width: @occupancyRate%"></div>
                    </div>
                    <div class="flex justify-between text-xs text-slate-600 mt-1">
                        <span>@occupancyRate%</span>
                        <span>@ViewBag.OccupiedBeds of @Model.BedSpaces.Count beds</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Bed Spaces and Resources (2/3) -->
        <div class="w-2/3 space-y-4">
            <!-- Bed Spaces Section -->
            <div class="bg-white rounded-lg shadow-md">
                <div class="flex justify-between items-center p-6 border-b">
                    <h2 class="text-lg font-semibold text-secondary-800 flex items-center">
                        <i class="material-icons mr-2 text-cyan-600">hotel</i>
                        Bed Spaces
                    </h2>
                </div>

                <div class="p-6">
                    <div class="grid grid-cols-3 gap-4">
                        @foreach (var bedSpace in Model.BedSpaces.OrderBy(b => b.BedIdentifier))
                        {
                            var bedStatusClass = "bg-green-100 text-green-800 border-green-200";
                            var bedStatusIcon = "check_circle";
                            var bedStatusText = "Available";

                            if (bedSpace.Status == Status.Occupied)
                            {
                                bedStatusClass = "bg-amber-100 text-amber-800 border-amber-200";
                                bedStatusIcon = "person";
                                bedStatusText = "Occupied";
                            }
                            else if (bedSpace.Status == Status.Reserved)
                            {
                                bedStatusClass = "bg-blue-100 text-blue-800 border-blue-200";
                                bedStatusIcon = "bookmark";
                                bedStatusText = "Reserved";
                            }
                            else if (bedSpace.Status == Status.Maintenance)
                            {
                                bedStatusClass = "bg-yellow-100 text-yellow-800 border-yellow-200";
                                bedStatusIcon = "build";
                                bedStatusText = "Maintenance";
                            }

                            <div class="bg-slate-50 border border-slate-200 rounded-lg overflow-hidden">
                                <div class="p-4">
                                    <div class="flex justify-between items-start mb-3">
                                        <h3 class="text-lg font-semibold">Bed @bedSpace.BedIdentifier</h3>
                                        <span class="@bedStatusClass text-xs px-2 py-1 rounded-full flex items-center">
                                            <i class="material-icons text-xs mr-1">@bedStatusIcon</i>
                                            @bedStatusText
                                        </span>
                                    </div>

                                    @if (bedSpace.Status == Status.Occupied)
                                    {
                                        <div class="mt-2 text-sm text-slate-600">
                                            <p>Occupied by a student</p>
                                            <a href="#" class="text-cyan-600 hover:text-cyan-800 mt-2 inline-block">
                                                <i class="material-icons text-xs align-text-top">visibility</i>
                                                View Student
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Resources Section -->
            <div class="bg-white rounded-lg shadow-md">
                <div class="flex justify-between items-center p-6 border-b">
                    <h2 class="text-lg font-semibold text-secondary-800 flex items-center">
                        <i class="material-icons mr-2 text-cyan-600">inventory</i>
                        Room Resources
                    </h2>
                    <button onclick="showUpdateRoomModal('@Model.RoomId')"
                            class="px-3 py-1.5 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center text-sm">
                        <i class="material-icons text-sm mr-1">edit</i>
                        Manage Resources
                    </button>
                </div>

                <div class="p-6">
                    @if (Model.Resources != null && Model.Resources.Any())
                    {
                        <div class="grid grid-cols-1 gap-4">
                            @foreach (var resource in Model.Resources)
                            {
                                var resourceStatusClass = "bg-green-100 text-green-800";
                                var resourceStatusIcon = "check_circle";

                                if (resource.Status == Status.Maintenance)
                                {
                                    resourceStatusClass = "bg-yellow-100 text-yellow-800";
                                    resourceStatusIcon = "build";
                                }

                                <div class="bg-slate-50 border border-slate-200 rounded-lg p-4">
                                    <div class="flex justify-between items-start">
                                        <span class="@resourceStatusClass text-xs px-2 py-1 rounded-full flex items-center">
                                            <i class="material-icons text-xs mr-1">@resourceStatusIcon</i>
                                            @resource.Status
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="flex flex-col items-center justify-center py-8 text-slate-500">
                            <i class="material-icons text-4xl mb-3">inventory</i>
                            <h3 class="text-lg font-medium mb-2">No Resources</h3>
                            <p class="text-sm mb-3">This room doesn't have any resources assigned yet.</p>
                            <button onclick="showUpdateRoomModal('@Model.RoomId')"
                                    class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center text-sm">
                                <i class="material-icons mr-2">add_circle</i>
                                Add Resources
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Include the room modals -->
<!-- Update Room Modal -->
<div id="updateRoomModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideUpdateRoomModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-2/3 z-10 overflow-hidden">
        <div class="px-6 py-4 bg-cyan-700 text-white">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2">edit</i>
                Update Room
            </h3>
        </div>
        <form id="updateRoomForm" method="post" asp-controller="Admin" asp-action="UpdateRoom">
            @Html.AntiForgeryToken()
            <input type="hidden" id="updateRoomId" name="RoomId" />
            <input type="hidden" id="updateHostelId" name="HostelId" value="@Model.HostelId" />
            <div class="px-6 py-4">
                <div class="mb-6">
                    <h4 class="text-md font-semibold text-slate-700 mb-2 flex items-center">
                        <i class="material-icons text-cyan-600 mr-2">meeting_room</i>
                        Room Information
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- Room Number -->
                        <div class="relative z-0 w-full group">
                            <input type="text" name="RoomNumber" id="updateRoomNumber"
                                   class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                   placeholder=" " required />
                            <label for="updateRoomNumber"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Room Number
                            </label>
                        </div>

                        <!-- Floor -->
                        <div class="relative z-0 w-full group">
                            <input type="number" name="Floor" id="updateFloor"
                                   class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                   placeholder=" " required min="0" />
                            <label for="updateFloor"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Floor
                            </label>
                        </div>

                        <!-- Room Type -->
                        <div class="relative z-0 w-full group">
                            <select name="RoomType" id="updateRoomType"
                                    class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                    required>
                                <option value="">Select Room Type</option>
                                <option value="Single">Single</option>
                                <option value="Double">Double</option>
                                <option value="Triple">Triple</option>
                                <option value="Suite">Suite</option>
                            </select>
                            <label for="updateRoomType"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Room Type
                            </label>
                        </div>

                        <!-- Capacity -->
                        <div class="relative z-0 w-full group">
                            <input type="number" name="Capacity" id="updateCapacity"
                                   class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                   placeholder=" " required min="1" />
                            <label for="updateCapacity"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Capacity
                            </label>
                        </div>

                        <!-- Gender -->
                        <div class="relative z-0 w-full group">
                            <select name="Gender" id="updateGender"
                                    class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                    required>
                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Any">Any</option>
                            </select>
                            <label for="updateGender"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Gender
                            </label>
                        </div>

                        <!-- Status -->
                        <div class="relative z-0 w-full group">
                            <select name="Status" id="updateStatus"
                                    class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                    required>
                                <option value="@Status.Available">Available</option>
                                <option value="@Status.Maintenance">Maintenance</option>
                                <option value="@Status.Reserved">Reserved</option>
                            </select>
                            <label for="updateStatus"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Status
                            </label>
                        </div>
                    </div>

                    <!-- Special Reservation -->
                    <div class="flex items-center mt-4">
                        <input id="updateIsSpecialReservation" name="IsSpecialReservation" type="checkbox" value="true" class="w-4 h-4 text-cyan-600 bg-gray-100 border-gray-300 rounded focus:ring-cyan-500 focus:ring-2">
                        <label for="updateIsSpecialReservation" class="ms-2 text-sm font-medium text-gray-700">Special Reservation</label>
                    </div>
                </div>

                <!-- Room Resources Section -->
                <div class="mt-6">
                    <h4 class="text-md font-semibold text-slate-700 mb-2 flex items-center">
                        <i class="material-icons text-cyan-600 mr-2">inventory</i>
                        Room Resources
                        <button type="button" id="updateAddResourceBtn" class="ml-2 p-1 bg-cyan-100 text-cyan-600 rounded-full hover:bg-cyan-200 transition-colors">
                            <i class="material-icons text-sm">add</i>
                        </button>
                    </h4>

                    <div id="updateResourcesContainer" class="space-y-3">
                        <!-- Resources will be populated via JavaScript -->
                    </div>
                </div>

                <!-- Bed Spaces Information -->
                <div class="mt-6">
                    <h4 class="text-md font-semibold text-slate-700 mb-2 flex items-center">
                        <i class="material-icons text-cyan-600 mr-2">hotel</i>
                        Bed Spaces
                    </h4>
                    <div id="bedSpacesInfo" class="p-4 bg-slate-50 rounded-lg">
                        <div class="flex items-center text-sm text-slate-500">
                            <i class="material-icons text-amber-600 mr-2">warning</i>
                            <span>Changing the capacity will affect bed spaces. Reducing capacity below the number of occupied beds is not allowed.</span>
                        </div>
                        <div class="flex justify-between items-center mt-3">
                            <div class="flex items-center">
                                <span class="text-sm font-medium">Current Capacity:</span>
                                <span id="currentCapacity" class="ml-1 text-sm"></span>
                            </div>
                            <div class="flex items-center">
                                <span class="text-sm font-medium">Occupied Beds:</span>
                                <span id="occupiedBeds" class="ml-1 text-sm"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
                <button type="button" onclick="hideUpdateRoomModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                    Update Room
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Room Modal -->
<div id="deleteRoomModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideDeleteRoomModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 bg-red-600 text-white">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2">warning</i>
                Confirm Deletion
            </h3>
        </div>
        <form id="deleteRoomForm" method="post" asp-controller="Admin" asp-action="DeleteRoom">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteRoomId" name="id" />
            <div class="px-6 py-4">
                <p class="text-gray-700 mb-4">Are you sure you want to delete this room?</p>
                <div class="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-4">
                    <div class="flex items-center mb-2">
                        <i class="material-icons text-slate-600 mr-2">meeting_room</i>
                        <p id="deleteRoomNumber" class="font-medium text-slate-800"></p>
                    </div>
                    <div class="grid grid-cols-2 gap-2 text-sm text-slate-600">
                        <div class="flex items-center">
                            <i class="material-icons text-xs mr-1">hotel</i>
                            <span id="deleteRoomType"></span>
                        </div>
                        <div class="flex items-center">
                            <i class="material-icons text-xs mr-1">people</i>
                            <span id="deleteRoomCapacity"></span>
                        </div>
                    </div>
                    <div class="mt-2 flex flex-wrap gap-1">
                        <span id="deleteRoomBedCount" class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full"></span>
                        <span id="deleteRoomOccupiedBeds" class="bg-amber-100 text-amber-800 text-xs px-2 py-1 rounded-full"></span>
                    </div>
                </div>

                <div id="deleteWarning" class="text-sm text-red-600 mb-4">
                    This action cannot be undone and will permanently remove this room and all associated resources from the system.
                </div>

                <div id="hasOccupiedBedsWarning" class="bg-yellow-50 border-l-4 border-yellow-400 p-4 hidden">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i class="material-icons text-yellow-400">warning</i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-yellow-700">
                                This room has occupied beds. You must relocate all students before deleting this room.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
                <button type="button" onclick="hideDeleteRoomModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit" id="confirmDeleteBtn" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                    Delete Room
                </button>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <script src="~/js/roomDetails.js"></script>
}