function submitInvoiceAction(action, id) {
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = action;
    
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'id';
    input.value = id;
    
    form.appendChild(input);
    document.body.appendChild(form);
    form.submit();
}

function cancelInvoice(id) {
    window.showAppConfirm('Are you sure you want to delete this invoice? It will be soft deleted and can be restored later.', {
        title: 'Delete Invoice',
        icon: 'warning',
        confirmButtonText: 'Delete'
    }).then(confirmed => {
        if (confirmed) submitInvoiceAction('/Admin/CancelInvoice', id);
    });
}

function restoreInvoice(id) {
    window.showAppConfirm('Are you sure you want to restore this invoice?', {
        title: 'Restore Invoice',
        icon: 'question',
        confirmButtonText: 'Restore'
    }).then(confirmed => {
        if (confirmed) submitInvoiceAction('/Admin/RestoreInvoice', id);
    });
}

function updatePagination(total, totalPages, current) {
    const start = (current - 1) * pageSize + 1;
    const end = Math.min(current * pageSize, total);
    document.getElementById('paginationInfo').textContent = `${start}-${end} of ${total}`;

    let html = `
        <button onclick="changePage(${current - 1})" ${current === 1 ? 'disabled' : ''}
                class="px-2 py-1 text-xs rounded ${current === 1 ? 'text-gray-400' : 'text-secondary-600 hover:bg-gray-100'}">
            <i class="material-icons text-sm">chevron_left</i>
        </button>
    `;

    for (let i = Math.max(1, current - 1); i <= Math.min(totalPages, current + 1); i++) {
        html += `
            <button onclick="changePage(${i})"
                    class="px-2 py-1 text-xs rounded ${i === current ? 'bg-primary-100 text-primary-700 font-semibold' : 'text-secondary-600 hover:bg-gray-100'}">
                ${i}
            </button>
        `;
    }

    html += `
        <button onclick="changePage(${current + 1})" ${current === totalPages ? 'disabled' : ''}
                class="px-2 py-1 text-xs rounded ${current === totalPages ? 'text-gray-400' : 'text-secondary-600 hover:bg-gray-100'}">
            <i class="material-icons text-sm">chevron_right</i>
        </button>
    `;

    document.getElementById('paginationControls').innerHTML = html;
}

function changePage(page) {
    currentPage = page;
    loadInvoices();
}

function changePageSize() {
    pageSize = parseInt(document.getElementById('pageSize').value);
    currentPage = 1;
    loadInvoices();
}
