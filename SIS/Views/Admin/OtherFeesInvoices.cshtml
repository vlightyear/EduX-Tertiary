function addStudentInput() {
    const container = document.getElementById('studentInputsContainer');
    const newRow = document.createElement('div');
    newRow.className = 'flex gap-2 student-input-row';
    newRow.innerHTML = `
        <input type="text" placeholder="Enter Student ID" 
               class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 student-id-input">
        <button type="button" onclick="removeStudentInput(this)" 
                class="px-3 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
            <i class="material-icons">remove</i>
        </button>
    `;
    container.appendChild(newRow);
    updateStudentCount();
}

function removeStudentInput(btn) {
    btn.closest('.student-input-row').remove();
    updateStudentCount();
}

function updateStudentCount() {
    const inputs = document.querySelectorAll('.student-id-input');
    const filledInputs = Array.from(inputs).filter(input => input.value.trim() !== '');
    document.getElementById('studentCount').textContent = 
        `${filledInputs.length} student ID${filledInputs.length !== 1 ? 's' : ''} entered`;
}

document.addEventListener('input', function(e) {
    if (e.target.classList.contains('student-id-input')) {
        updateStudentCount();
    }
});

function collectStudentIds() {
    const inputs = document.querySelectorAll('.student-id-input');
    return Array.from(inputs)
        .map(input => input.value.trim())
        .filter(id => id !== '')
        .join(',');
}

function uploadCSV() {
    const fileInput = document.getElementById('csvFile');
    const file = fileInput.files[0];
    
    if (!file) {
        window.showAppToast('Please select a CSV file first');
        return;
    }

    if (!file.name.toLowerCase().endsWith('.csv')) {
        window.showAppToast('Please upload a CSV file');
        return;
    }

    const reader = new FileReader();
    reader.onload = function(e) {
        const text = e.target.result;
        
        const studentIds = text
            .split(/[\n\r,]+/)
            .map(s => s.trim())
            .filter(s => s !== '' && s !== 'StudentID' && s !== 'Student ID');

        if (studentIds.length === 0) {
            window.showAppToast('No valid student IDs found in CSV file');
            return;
        }

        const container = document.getElementById('studentInputsContainer');
        container.innerHTML = '';

        studentIds.forEach((id, index) => {
            const newRow = document.createElement('div');
            newRow.className = 'flex gap-2 student-input-row';
            newRow.innerHTML = `
                <input type="text" placeholder="Enter Student ID" value="${id}"
                       class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 student-id-input">
                <button type="button" onclick="${index === 0 ? 'addStudentInput()' : 'removeStudentInput(this)'}" 
                        class="px-3 py-2 ${index === 0 ? 'bg-blue-600 hover:bg-blue-700' : 'bg-red-600 hover:bg-red-700'} text-white rounded-lg transition-colors">
                    <i class="material-icons">${index === 0 ? 'add' : 'remove'}</i>
                </button>
            `;
            container.appendChild(newRow);
        });

        fileInput.value = '';
        updateStudentCount();
        window.showAppToast(`Imported ${studentIds.length} student IDs from CSV`);
    };

    reader.onerror = function() {
        window.showAppToast('Error reading CSV file. Please try again.');
    };

    reader.readAsText(file);
}

function downloadTemplate() {
    const csvContent = 'StudentID\n2025010041\n2025210003\n2023050285';
    const blob = new Blob([csvContent], { type: 'text/csv' });
    const url = window.URL.createObjectURL(blob);
    
    const link = document.createElement('a');
    link.href = url;
    link.download = 'student_ids_template.csv';
    document.body.appendChild(link);
    link.click();
    
    document.body.removeChild(link);
    window.URL.revokeObjectURL(url);
}

function updateSelectedFees() {
    const checkboxes = document.querySelectorAll('input[name="SelectedFeeIds"]:checked');
    const feesDataElement = document.querySelector('[data-fees-json]');
    
    if (!feesDataElement) return;
    
    const feesData = JSON.parse(feesDataElement.getAttribute('data-fees-json'));
    
    selectedFees = Array.from(checkboxes).map(cb => {
        const feeId = parseInt(cb.value);
        return feesData.find(f => f.Id === feeId);
    }).filter(f => f != null);

    const totalAmount = selectedFees.reduce((sum, fee) => sum + fee.Amount, 0);
    
    const infoDiv = document.getElementById('selectedFeesInfo');
    if (selectedFees.length > 0) {
        infoDiv.classList.remove('hidden');
        document.getElementById('selectedFeesCount').textContent = 
            `${selectedFees.length} fee${selectedFees.length !== 1 ? 's' : ''} selected`;
        document.getElementById('totalAmount').textContent = 
            `K ${totalAmount.toFixed(2)}`;
    } else {
        infoDiv.classList.add('hidden');
    }
}

async function validateStudents() {
    const studentIds = collectStudentIds();
    
    if (!studentIds) {
        window.showAppToast('Please enter at least one student ID');
        return;
    }

    document.getElementById('hiddenStudentIds').value = studentIds;

    try {
        const response = await fetch('/Admin/ValidateStudents', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ studentIds: studentIds })
        });

        const data = await response.json();
        
        document.getElementById('validationResults').classList.remove('hidden');
        
        if (data.validStudents.length > 0) {
            document.getElementById('validStudentsSection').classList.remove('hidden');
            document.getElementById('validCount').textContent = data.totalValid;
            
            const validBody = document.getElementById('validStudentsBody');
            validBody.innerHTML = data.validStudents.map(s => `
                <tr class="hover:bg-green-50">
                    <td class="px-3 py-2 font-medium text-gray-900">${s.studentId_Number}</td>
                    <td class="px-3 py-2">${s.fullName}</td>
                    <td class="px-3 py-2 text-secondary-600">${s.programmeName}</td>
                    <td class="px-3 py-2 text-secondary-600">${s.schoolName}</td>
                </tr>
            `).join('');
        } else {
            document.getElementById('validStudentsSection').classList.add('hidden');
        }

        if (data.invalidStudents.length > 0) {
            document.getElementById('invalidStudentsSection').classList.remove('hidden');
            document.getElementById('invalidCount').textContent = data.totalInvalid;
            
            const invalidBody = document.getElementById('invalidStudentsBody');
            invalidBody.innerHTML = data.invalidStudents.map(s => `
                <tr class="hover:bg-red-50">
                    <td class="px-3 py-2 font-medium text-red-900">${s.studentId_Number}</td>
                    <td class="px-3 py-2 text-red-700">NOT FOUND</td>
                </tr>
            `).join('');
        } else {
            document.getElementById('invalidStudentsSection').classList.add('hidden');
        }

        validatedStudents = data.validStudents;

    } catch (error) {
        console.error('Error validating students:', error);
        window.showAppToast('Error validating students. Please try again.');
    }
}

