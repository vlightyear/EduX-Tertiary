async function loadInvoices() {
    try {
        const response = await fetch('/Admin/GetInvoices', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                page: currentPage,
                pageSize: pageSize,
                academicYearId: document.getElementById('filterAcademicYear').value || null,
                semester: document.getElementById('filterSemester').value || null,
                status: document.getElementById('filterStatus').value || null,
                searchTerm: document.getElementById('searchTerm').value || null,
                includeDeleted: document.getElementById('includeDeleted').checked
            })
        });

        const data = await response.json();
        renderInvoices(data.invoices);
        updatePagination(data.totalRecords, data.totalPages, data.currentPage);
    } catch (error) {
        console.error('Error loading invoices:', error);
    }
}

function renderInvoices(invoices) {
