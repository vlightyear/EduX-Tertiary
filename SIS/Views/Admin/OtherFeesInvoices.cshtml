            <tr>
                <td colspan="10" class="px-6 py-8 text-center text-gray-500">
                    <i class="material-icons text-4xl text-gray-300 mb-2">receipt_long</i>
                    <p>No invoices found</p>
                </td>
            </tr>
        `;
        return;
    }

    tbody.innerHTML = invoices.map(inv => `
        <tr class="hover:bg-gray-50 ${inv.isDeleted ? 'bg-red-50' : ''}">
            <td class="px-3 py-3 text-sm">${inv.rowNumber}</td>
            <td class="px-3 py-3 text-sm font-medium text-primary-700">
                ${inv.invoiceReference}
                ${inv.isDeleted ? '<span class="ml-2 text-xs text-red-600">(Deleted)</span>' : ''}
            </td>
            <td class="px-3 py-3 text-sm text-secondary-600">${inv.batchReference || 'N/A'}</td>
            <td class="px-3 py-3 text-sm">
                <div class="font-medium">${inv.studentName}</div>
                <div class="text-gray-500 text-xs">${inv.studentId}</div>
            </td>
            <td class="px-3 py-3 text-sm">${inv.academicYear}</td>
            <td class="px-3 py-3 text-sm">${inv.semester || 'N/A'}</td>
            <td class="px-3 py-3 text-sm font-bold">K${inv.totalAmount.toLocaleString('en-US', {minimumFractionDigits: 2})}</td>
            <td class="px-3 py-3 text-sm">
                <span class="px-2 py-1 rounded-full text-xs font-medium ${getStatusColor(inv.status)}">
                    ${inv.status}
                </span>
            </td>
            <td class="px-3 py-3 text-sm">${new Date(inv.createdDate).toLocaleDateString()}</td>
            <td class="px-3 py-3 text-sm">
                <button onclick="viewInvoice(${inv.id})"
                        class="text-primary-600 hover:text-primary-800 mr-2">
                    <i class="material-icons text-sm">visibility</i>
                </button>
                <button onclick="printInvoiceById(${inv.id})"
                        class="text-green-600 hover:text-green-800 mr-2" title="Print Invoice">
                    <i class="material-icons text-sm">print</i>
                </button>
                ${inv.isDeleted ? `
                    <button onclick="restoreInvoice(${inv.id})"
                            class="text-green-600 hover:text-green-800" title="Restore Invoice">
                        <i class="material-icons text-sm">restore</i>
                    </button>
                ` : `
                    ${inv.status === 'Pending' ? `
                        <button onclick="cancelInvoice(${inv.id})"
                                class="text-red-600 hover:text-red-800" title="Delete Invoice">
                            <i class="material-icons text-sm">delete</i>
                        </button>
                    ` : ''}
                `}
            </td>
        </tr>
    `).join('');
}

function getStatusColor(status) {
    const colors = {
        'Pending': 'bg-yellow-100 text-yellow-700',
        'Paid': 'bg-green-100 text-green-700',
        'PartiallyPaid': 'bg-blue-100 text-blue-700',
        'Cancelled': 'bg-red-100 text-red-700'
    };
    return colors[status] || 'bg-gray-100 text-gray-700';
}

