@using SIS.Models.Fees
@model IEnumerable<FeeConfiguration>

@{
    ViewData["Title"] = "Fee Configuration";
}

<div class="h-[90vh] p-4">
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">settings</i>
            Fee Configurations
        </h1>
        <button type="button"
                class="px-4 py-2 text-white rounded-lg transition-colors flex items-center shadow-md hover:shadow-lg"
                style="background-color: #e85c5c;"
                onmouseenter="this.style.backgroundColor='#c53030'" onmouseleave="this.style.backgroundColor='#e85c5c'"
                onclick="showCreateFeeModal()">
            <i class="material-icons mr-2">add</i>
            Create Fee Configuration
        </button>
    </div>

    <div class="h-[calc(90vh-80px)] flex flex-col">
        <div class="bg-white rounded-lg shadow-md flex flex-col h-full overflow-hidden">

            <!-- Filters -->
            <div class="p-4 bg-gray-50 border-b border-gray-200 flex-shrink-0">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-sm font-semibold text-gray-700 flex items-center">
                        <i class="material-icons text-sm mr-2">filter_list</i>
                        Filters
                    </h3>
                    <button onclick="clearFilters()"
                            class="text-xs px-3 py-1 rounded-lg transition-colors flex items-center border border-gray-200 hover:bg-gray-100 text-gray-600">
                        <i class="material-icons text-sm mr-1">clear</i>
                        Clear All
                    </button>
                </div>

                <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Fee Type</label>
                        <select id="filterFeeType" onchange="applyFilters()"
                                class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:border-transparent"
                                onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                onblur="this.style.borderColor='';this.style.boxShadow=''">
                            <option value="">All Fee Types</option>
                            @foreach (var feeType in ViewBag.FeeTypes)
                            {
                                <option value="@feeType.Value">@feeType.Text</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Academic Year</label>
                        <select id="filterAcademicYear" onchange="applyFilters()"
                                class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                onblur="this.style.borderColor='';this.style.boxShadow=''">
                            <option value="">All Years</option>
                            @foreach (var year in ViewBag.AcademicYears)
                            {
                                <option value="@year.Value">@year.Text</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Semester</label>
                        <select id="filterSemester" onchange="applyFilters()"
                                class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                onblur="this.style.borderColor='';this.style.boxShadow=''">
                            <option value="">All Semesters</option>
                            <option value="1">Semester 1</option>
                            <option value="2">Semester 2</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">School</label>
                        <select id="filterSchool" onchange="onSchoolFilterChange(); applyFilters();"
                                class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                onblur="this.style.borderColor='';this.style.boxShadow=''">
                            <option value="">All Schools</option>
                            @foreach (var school in ViewBag.Schools)
                            {
                                <option value="@school.Value">@school.Text</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Programme</label>
                        <select id="filterProgramme" onchange="applyFilters()"
                                class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                onblur="this.style.borderColor='';this.style.boxShadow=''">
                            <option value="">All Programmes</option>
                            @foreach (var programme in ViewBag.Programmes)
                            {
                                <option value="@programme.Value">@programme.Text</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Mode of Study</label>
                        <select id="filterMode" onchange="applyFilters()"
                                class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                onblur="this.style.borderColor='';this.style.boxShadow=''">
                            <option value="">All Modes</option>
                            @foreach (var mode in ViewBag.ModesOfStudy)
                            {
                                <option value="@mode.Value">@mode.Text</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Year of Study</label>
                        <select id="filterYear" onchange="applyFilters()"
                                class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                onblur="this.style.borderColor='';this.style.boxShadow=''">
                            <option value="">All Years</option>
                            @for (int y = 1; y <= 7; y++)
                            {
                                <option value="@y">Year @y</option>
                            }
                        </select>
                    </div>

                    <div class="space-y-2">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Program Level</label>
                            <select id="filterProgramLevel" onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Levels</option>
                                @foreach (var level in ViewBag.ProgramLevels)
                                {
                                    <option value="@level.Value">@level.Text</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Student Type</label>
                            <select id="filterStudentType" onchange="applyFilters()"
                                    class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                    onfocus="this.style.borderColor='#e85c5c';this.style.boxShadow='0 0 0 3px rgba(232,92,92,0.15)'"
                                    onblur="this.style.borderColor='';this.style.boxShadow=''">
                                <option value="">All Types</option>
                                <option value="universal">Universal</option>
                                <option value="accommodated">Accommodated</option>
                                <option value="foreign">Foreign Students</option>
                                <option value="standard">Standard</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Table -->
            <div class="overflow-auto flex-1">
                <table class="min-w-full text-sm text-secondary-600">
                    <thead class="sticky top-0 z-10" style="background-color: #fef2f2;">
                        <tr>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">#</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Fee Type</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Academic Year</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Semester</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Mode/Year</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Level</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Student Type</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Amount</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: #9b2c2c;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="feeConfigTableBody" class="bg-white divide-y divide-gray-100">
                        <tr>
                            <td colspan="9" class="px-6 py-8 text-center text-gray-500">
                                <div class="flex flex-col items-center">
                                    <i class="material-icons text-4xl text-gray-300 mb-2 animate-spin">refresh</i>
                                    <p class="text-sm font-medium">Loading fee configurations...</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="border-t border-gray-200 px-4 py-3 bg-white flex-shrink-0">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                    <div class="flex items-center gap-2">
                        <label class="text-xs text-gray-500">Rows per page:</label>
                        <select id="pageSize" onchange="changePageSize()"
                                class="px-2 py-1 text-xs border border-gray-300 rounded-lg focus:outline-none"
                                onfocus="this.style.borderColor='#e85c5c'" onblur="this.style.borderColor=''">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>

                    <span id="paginationInfo" class="text-xs text-gray-500"></span>

                    <div id="paginationControls" class="flex gap-1"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div id="createFeeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-4xl max-h-[90vh] overflow-y-auto">
                <div class="text-white px-6 py-4 rounded-t-lg flex items-center justify-between sticky top-0 z-10"
                     style="background-color: #e85c5c;">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>Create Fee Configuration
                    </h3>
                    <button type="button" class="text-white hover:text-red-200 transition-colors" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <div class="p-6">
                    <form id="createFeeForm" method="post" asp-controller="Admin" asp-action="CreateFeeConfiguration">
                        @Html.AntiForgeryToken()
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                            @* ── floating label selects/inputs — all identical pattern ── *@
                            <div class="relative z-0 w-full group">
                                <select name="FeeTypeId" id="feeTypeId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''" required>
                                    <option value="" disabled selected></option>
                                    @foreach (var feeType in ViewBag.FeeTypes)
                                    {
                                        <option value="@feeType.Value">@feeType.Text</option>
                                    }
                                </select>
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Fee Type *</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="AcademicYearId" id="academicYearId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Academic Years</option>
                                    @foreach (var year in ViewBag.AcademicYears)
                                    {
                                        <option value="@year.Value">@year.Text</option>
                                    }
                                </select>
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Academic Year</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <select name="Semester" id="semester"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">Yearly (Both Semesters)</option>
                                    <option value="1">Semester 1</option>
                                    <option value="2">Semester 2</option>
                                </select>
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Semester</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="number" name="Amount" id="amount" step="0.01" min="0"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " required />
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Amount (ZMW) *</label>
                            </div>

                            <div class="relative z-0 w-full group" id="schoolGroup">
                                <select name="SchoolId" id="schoolId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                        onchange="loadProgrammesBySchool(this.value, 'programmeId')">
                                    <option value="">All Schools</option>
                                    @foreach (var school in ViewBag.Schools)
                                    {
                                        <option value="@school.Value">@school.Text</option>
                                    }
                                </select>
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">School</label>
                            </div>

                            <div class="relative z-0 w-full group" id="programmeGroup">
                                <select name="ProgrammeId" id="programmeId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Programmes</option>
                                </select>
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Programme</label>
                            </div>

                            <div class="relative z-0 w-full group" id="modeGroup">
                                <select name="ModeOfStudyId" id="modeOfStudyId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Modes</option>
                                    @foreach (var mode in ViewBag.ModesOfStudy)
                                    {
                                        <option value="@mode.Value">@mode.Text</option>
                                    }
                                </select>
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Mode of Study</label>
                            </div>

                            <div class="relative z-0 w-full group" id="yearGroup">
                                <input type="number" name="YearOfStudy" id="yearOfStudy" min="1" max="7"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " />
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Year of Study</label>
                            </div>

                            <div class="relative z-0 w-full group" id="levelGroup">
                                <select name="ProgramLevelId" id="programLevelId"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                        onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''">
                                    <option value="">All Levels</option>
                                    @foreach (var level in ViewBag.ProgramLevels)
                                    {
                                        <option value="@level.Value">@level.Text</option>
                                    }
                                </select>
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Programme Level</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="text" name="CreditNCode" id="creditNCode" maxlength="20"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " required />
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Credit N-Code *</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="text" name="DebitNCode" id="debitNCode" maxlength="20"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " required />
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Debit N-Code *</label>
                            </div>

                            <div class="relative z-0 w-full group">
                                <input type="number" name="RegistrationPaymentRequired" id="registrationPaymentRequired" max="100"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                                       onfocus="this.style.borderBottomColor='#e85c5c'" onblur="this.style.borderBottomColor=''"
                                       placeholder=" " required />
                                <label class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">Registration Payment Required *</label>
                            </div>
                        </div>

                        <div class="mt-6 p-4 bg-gray-50 rounded-lg border border-gray-200">
                            <h4 class="text-sm font-semibold text-gray-700 mb-4 flex items-center">
                                <i class="material-icons text-sm mr-2" style="color: #e85c5c;">rule</i>
                                Application Rules
                            </h4>
                            <div class="space-y-2">
                                @foreach (var rule in new[] {
                                                                ("appliesUniversally",         "AppliesUniversally",         "toggleUniversalApplication()",  "Universal Fee (applies to all students, ignores other filters)"),
                                                                ("appliesOnlyToAccommodated",  "AppliesOnlyToAccommodated",  "",                              "Accommodation Fee (applies only to accommodated students)"),
                                                                ("appliesOnlyToForeignStudents","AppliesOnlyToForeignStudents","",                            "Foreign Student Fee (applies only to international students)"),
                                                                ("appliesOnlyToLocalStudents", "AppliesOnlyToLocalStudents", "",                              "Local Student Fee (applies only to local students)")
                                                                })
                                {
                                    <div class="flex items-center p-3 bg-white rounded-lg border border-gray-200">
                                        <input type="checkbox" id="@rule.Item1" name="@rule.Item2" value="true"
                                               class="w-4 h-4 border-gray-300 rounded"
                                               style="accent-color: #e85c5c;"
                                               @(rule.Item3 != "" ? $"onchange=\"{rule.Item3}\"" : "") />
                                        <label for="@rule.Item1" class="ml-3 text-sm text-gray-700 font-medium cursor-pointer">@rule.Item4</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </form>
                </div>

                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2 sticky bottom-0">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="createFeeButton"
                            class="px-4 py-2 text-white rounded-lg transition-colors flex items-center shadow-sm"
                            style="background-color: #e85c5c;"
