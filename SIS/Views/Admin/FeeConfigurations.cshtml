@section Scripts {
    <script>
        let currentPage = 1;
        let pageSize    = 10;
        let totalRecords = 0;

        document.addEventListener('DOMContentLoaded', function () {
            loadFeeConfigurations();
            initializeModals();
        });

        async function loadFeeConfigurations() {
            try {
                const filterData = {
                    page: currentPage,
                    pageSize: pageSize,
                    sortColumn: 'academicYear',
                    sortDirection: 'desc',
                    feeTypeId:      getFilterValue('filterFeeType'),
                    academicYearId: getFilterValue('filterAcademicYear'),
                    semester:       getFilterValue('filterSemester'),
                    schoolId:       getFilterValue('filterSchool'),
                    programmeId:    getFilterValue('filterProgramme'),
                    modeOfStudyId:  getFilterValue('filterMode'),
                    yearOfStudy:    getFilterValue('filterYear'),
                    programLevelId: getFilterValue('filterProgramLevel'),
                    studentType:    document.getElementById('filterStudentType')?.value || null
                };

                const response = await fetch('/Admin/GetFeeConfigurationsData', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(filterData)
                });

                const data = await response.json();

                if (data.configurations) {
                    renderFeeConfigurations(data.configurations);
                    updatePagination(data.totalRecords, data.totalPages, data.currentPage);
                    totalRecords = data.totalRecords;
                }
            } catch (error) {
                console.error('Error loading fee configurations:', error);
                showError('Failed to load fee configurations');
            }
        }

        function getFilterValue(elementId) {
            const value = document.getElementById(elementId)?.value;
            return value && value !== '' ? parseInt(value) : null;
        }

        // ── Two-level grouping: School → Programme ────────────────────────
        function renderFeeConfigurations(configurations) {
            const tbody = document.getElementById('feeConfigTableBody');

            if (!configurations.length) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="9" class="px-6 py-8 text-center text-gray-500">
                            <div class="flex flex-col items-center">
                                <i class="material-icons text-4xl text-gray-300 mb-2">settings</i>
                                <p class="text-sm font-medium">No fee configurations found</p>
                                <p class="text-xs text-gray-400 mt-1">Try adjusting your filters or create a new configuration</p>
                            </div>
                        </td>
                    </tr>`;
                return;
            }

            // Group: schoolName → programmeName → [rows]
            const grouped = configurations.reduce((acc, fc) => {
                const school    = fc.schoolName    || 'No School Assigned';
                const programme = fc.programmeName || 'No Programme Assigned';
                if (!acc[school]) acc[school] = {};
                if (!acc[school][programme]) acc[school][programme] = [];
                acc[school][programme].push(fc);
                return acc;
            }, {});

            let html = '';
            let rowNum = (currentPage - 1) * pageSize + 1;

            Object.keys(grouped).sort().forEach(schoolName => {
                const programmes = grouped[schoolName];
                const schoolTotal = Object.values(programmes).reduce((sum, rows) => sum + rows.length, 0);

                // School header row
                html += `
                    <tr style="background-color: #fef2f2; border-bottom: 1px solid #fecaca;">
                        <td colspan="9" class="px-4 py-3">
                            <span class="flex items-center font-semibold text-xs uppercase tracking-wide" style="color: #9b2c2c;">
                                <i class="material-icons text-base mr-2" style="color: #e85c5c;">account_balance</i>
                                ${schoolName}
                                <span class="ml-2 px-2 py-0.5 rounded-full text-xs font-medium" style="background-color: #fee2e2; color: #c53030;">
                                    ${schoolTotal} ${schoolTotal === 1 ? 'fee' : 'fees'}
                                </span>
                            </span>
                        </td>
                    </tr>`;

                Object.keys(programmes).sort().forEach(programmeName => {
                    const rows = programmes[programmeName];

                    // Programme sub-header row
                    html += `
                        <tr class="bg-gray-50 border-b border-gray-200">
                            <td colspan="9" class="pl-10 pr-4 py-2">
                                <span class="flex items-center text-xs font-semibold text-gray-600 uppercase tracking-wide">
                                    <i class="material-icons text-sm mr-2 text-gray-400">school</i>
                                    ${programmeName}
                                    <span class="ml-2 px-2 py-0.5 bg-gray-200 text-gray-600 rounded-full text-xs font-medium">
                                        ${rows.length} ${rows.length === 1 ? 'fee' : 'fees'}
                                    </span>
                                </span>
                            </td>
                        </tr>`;

                    rows.forEach(fc => {
                        const studentTypeBadge = fc.appliesUniversally
                            ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700"><i class="material-icons text-xs mr-0.5">public</i>Universal</span>`
                            : fc.appliesOnlyToAccommodated
                            ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700"><i class="material-icons text-xs mr-0.5">home</i>Accommodated</span>`
                            : fc.appliesOnlyToForeignStudents
                            ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700"><i class="material-icons text-xs mr-0.5">language</i>Foreign</span>`
                            : fc.appliesOnlyToLocalStudents
                            ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700"><i class="material-icons text-xs mr-0.5">language</i>Local</span>`
                            : `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700"><i class="material-icons text-xs mr-0.5">person</i>Standard</span>`;

                        html += `
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="px-3 py-3 text-xs text-gray-400 pl-10">${rowNum++}</td>
                                <td class="px-3 py-3 text-sm font-medium text-gray-900">${fc.feeTypeName}</td>
                                <td class="px-3 py-3 text-xs">
                                    <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full font-medium">${fc.academicYear}</span>
                                </td>
                                <td class="px-3 py-3 text-xs">
                                    ${fc.semester
                                        ? `<span class="px-2 py-1 bg-green-100 text-green-700 rounded-full font-medium">Sem ${fc.semester}</span>`
                                        : `<span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full font-medium">Yearly</span>`}
                                </td>
                                <td class="px-3 py-3 text-xs text-gray-600">
                                    <div>${fc.modeName}</div>
                                    <div class="text-gray-400">Year ${fc.yearOfStudy}</div>
                                </td>
                                <td class="px-3 py-3 text-xs">
                                    <span class="px-2 py-1 bg-indigo-100 text-indigo-700 rounded-full font-medium">${fc.programLevelName}</span>
                                </td>
                                <td class="px-3 py-3 text-xs">${studentTypeBadge}</td>
                                <td class="px-3 py-3 text-sm font-bold text-gray-900">
                                    K${fc.amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                                </td>
                                <td class="px-3 py-3">
                                    <div class="flex gap-1">
                                        <button onclick="showUpdateFeeModal(${fc.id}, ${fc.feeTypeId}, ${fc.academicYearId}, ${fc.schoolId}, ${fc.programmeId}, ${fc.modeOfStudyId}, ${fc.yearOfStudy}, ${fc.programLevelId}, ${fc.amount}, ${fc.semester || 0}, '${fc.appliesUniversally}', '${fc.appliesOnlyToAccommodated}', '${fc.appliesOnlyToForeignStudents}', '${fc.appliesOnlyToLocalStudents}', '${fc.creditNCode || ''}', '${fc.debitNCode || ''}', '${fc.registrationPaymentRequired || ''}')"
                                                class="inline-flex items-center px-2 py-1 text-xs text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                            <i class="material-icons text-sm">edit</i>
                                        </button>
                                        <button onclick="showDeleteFeeModal(${fc.id}, '${fc.academicYear}', '${fc.programmeName}', 'K${fc.amount.toFixed(2)}')"
                                                class="inline-flex items-center px-2 py-1 text-xs text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                            <i class="material-icons text-sm">delete</i>
                                        </button>
                                    </div>
                                </td>
                            </tr>`;
                    });
                });
            });

            tbody.innerHTML = html;
        }

        // ── Pagination ────────────────────────────────────────────────────
        function updatePagination(total, totalPages, current) {
            const startRecord = (current - 1) * pageSize + 1;
            const endRecord   = Math.min(current * pageSize, total);

            document.getElementById('paginationInfo').textContent =
                `Showing ${startRecord} to ${endRecord} of ${total} entries`;

            const controls = document.getElementById('paginationControls');
            const accent   = '#e85c5c';
            let html = '';

            const prevDisabled = current === 1;
            html += `<button onclick="changePage(${current - 1})" ${prevDisabled ? 'disabled' : ''}
                             class="px-3 py-1.5 text-sm rounded-lg transition-colors ${prevDisabled ? 'text-gray-300 bg-gray-50 cursor-not-allowed' : 'text-gray-600 bg-white hover:bg-red-50 border border-gray-200'}">
                        <i class="material-icons text-sm">chevron_left</i>
                     </button>`;

            const pageWindow = 2;
            let lastPrinted  = 0;
            for (let p = 1; p <= totalPages; p++) {
                if (p === 1 || p === totalPages || (p >= current - pageWindow && p <= current + pageWindow)) {
                    if (lastPrinted && p - lastPrinted > 1) {
                        html += `<span class="px-2 text-gray-400 text-sm">...</span>`;
                    }
                    const isActive = p === current;
                    html += `<button onclick="changePage(${p})"
                                     class="px-3 py-1.5 text-sm rounded-lg transition-colors ${isActive ? 'text-white font-semibold' : 'text-gray-600 bg-white hover:bg-red-50 border border-gray-200'}"
                                     ${isActive ? `style="background-color: ${accent};"` : ''}>
                                 ${p}
                             </button>`;
                    lastPrinted = p;
                }
            }

            const nextDisabled = current === totalPages;
            html += `<button onclick="changePage(${current + 1})" ${nextDisabled ? 'disabled' : ''}
                             class="px-3 py-1.5 text-sm rounded-lg transition-colors ${nextDisabled ? 'text-gray-300 bg-gray-50 cursor-not-allowed' : 'text-gray-600 bg-white hover:bg-red-50 border border-gray-200'}">
                        <i class="material-icons text-sm">chevron_right</i>
                     </button>`;

            controls.innerHTML = html;
        }

        function changePage(page) {
            if (page < 1 || page > Math.ceil(totalRecords / pageSize)) return;
            currentPage = page;
            loadFeeConfigurations();
        }

        function changePageSize() {
            pageSize    = parseInt(document.getElementById('pageSize').value);
            currentPage = 1;
            loadFeeConfigurations();
        }

        function applyFilters()  { currentPage = 1; loadFeeConfigurations(); }
        function clearFilters()  {
            ['filterFeeType','filterAcademicYear','filterSemester','filterSchool',
             'filterProgramme','filterMode','filterYear','filterProgramLevel','filterStudentType']
                .forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
            applyFilters();
        }

        function onSchoolFilterChange() {
            const schoolId = document.getElementById('filterSchool').value;
            if (!schoolId) return;
            const programmeSelect = document.getElementById('filterProgramme');
            fetch(`/Admin/GetProgrammesBySchool?schoolId=${schoolId}`)
                .then(r => r.json())
                .then(data => {
                    programmeSelect.innerHTML = '<option value="">All Programmes</option>';
                    data.forEach(p => {
                        const o = document.createElement('option');
                        o.value = p.value; o.textContent = p.text;
                        programmeSelect.appendChild(o);
                    });
                });
        }

        function showError(message) {
            document.getElementById('feeConfigTableBody').innerHTML = `
                <tr>
                    <td colspan="9" class="px-6 py-8 text-center text-red-500">
                        <div class="flex flex-col items-center">
                            <i class="material-icons text-4xl text-red-300 mb-2">error_outline</i>
                            <p class="text-sm font-medium">${message}</p>
                            <button onclick="loadFeeConfigurations()"
                                    class="mt-4 px-4 py-2 text-white text-sm rounded-lg"
                                    style="background-color: #e85c5c;">Retry</button>
                        </div>
                    </td>
                </tr>`;
        }

        // ── Modals ────────────────────────────────────────────────────────
        function initializeModals() {
            const modals = ['createFeeModal','updateFeeModal','deleteFeeModal'].map(id => document.getElementById(id));

            function showModal(el) { el.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
            function hideModal(el) { el.classList.add('hidden');    document.body.style.overflow = 'auto';   }

            modals.forEach(modal => {
                modal.addEventListener('click', e => { if (e.target === modal) hideModal(modal); });
                modal.querySelectorAll('[data-bs-dismiss="modal"]').forEach(btn => {
                    btn.addEventListener('click', () => hideModal(modal));
                });
            });

            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') modals.forEach(m => { if (!m.classList.contains('hidden')) hideModal(m); });
            });

            window.showCreateFeeModal = function () {
                document.getElementById('createFeeForm').reset();
                ['schoolGroup','programmeGroup','modeGroup','yearGroup','levelGroup'].forEach(id => {
                    const g = document.getElementById(id);
                    if (g) { g.style.opacity = '1'; g.style.pointerEvents = 'auto'; }
                });
                showModal(modals[0]);
            };

            window.showUpdateFeeModal = function (id, feeTypeId, academicYearId, schoolId, programmeId, modeOfStudyId, yearOfStudy, programLevelId, amount, semester, appliesUniversally, appliesOnlyToAccommodated, appliesOnlyToForeignStudents, appliesOnlyToLocalStudents, creditNCode, debitNCode, registrationPaymentRequired) {
                const v = (val) => (val && val !== 0 && val !== '0') ? val : '';
                document.getElementById('updateFeeId').value                         = id;
                document.getElementById('updateFeeTypeId').value                     = feeTypeId;
                document.getElementById('updateAcademicYearId').value                = v(academicYearId);
                document.getElementById('updateSchoolId').value                      = v(schoolId);
                document.getElementById('updateProgrammeId').value                   = v(programmeId);
                document.getElementById('updateModeOfStudyId').value                 = v(modeOfStudyId);
                document.getElementById('updateYearOfStudy').value                   = v(yearOfStudy);
                document.getElementById('updateProgramLevelId').value                = v(programLevelId);
                document.getElementById('updateAmount').value                        = amount;
                document.getElementById('updateSemester').value                      = v(semester);
                document.getElementById('updateAppliesUniversally').checked          = appliesUniversally === 'true';
                document.getElementById('updateAppliesOnlyToAccommodated').checked   = appliesOnlyToAccommodated === 'true';
                document.getElementById('updateAppliesOnlyToForeignStudents').checked = appliesOnlyToForeignStudents === 'true';
                document.getElementById('updateAppliesOnlyToLocalStudents').checked  = appliesOnlyToLocalStudents === 'true';
                document.getElementById('updateCreditNCode').value                   = creditNCode || '';
                document.getElementById('updateDebitNCode').value                    = debitNCode || '';
                document.getElementById('updateRegistrationPaymentRequired').value   = registrationPaymentRequired || '';

                if (v(schoolId)) {
                    loadProgrammesBySchool(schoolId, 'updateProgrammeId');
                    if (v(programmeId)) setTimeout(() => { document.getElementById('updateProgrammeId').value = programmeId; }, 500);
                }

                toggleUpdateUniversalApplication();
                showModal(modals[1]);
            };

            window.showDeleteFeeModal = function (id, academicYear, programme, amount) {
                document.getElementById('deleteFeeId').value               = id;
                document.getElementById('deleteAcademicYear').textContent  = academicYear;
                document.getElementById('deleteProgramme').textContent     = programme;
                document.getElementById('deleteAmount').textContent        = amount;
                showModal(modals[2]);
            };

            window.toggleUniversalApplication = function () {
                const isUniversal = document.getElementById('appliesUniversally').checked;
                ['schoolGroup','programmeGroup','modeGroup','yearGroup','levelGroup'].forEach(id => {
                    const g = document.getElementById(id); if (!g) return;
                    g.style.opacity = isUniversal ? '0.4' : '1';
                    g.style.pointerEvents = isUniversal ? 'none' : 'auto';
                    if (isUniversal) {
                        const s = g.querySelector('select'), i = g.querySelector('input');
                        if (s) s.value = ''; if (i) i.value = '';
                    }
                });
            };

            window.toggleUpdateUniversalApplication = function () {
                const isUniversal = document.getElementById('updateAppliesUniversally').checked;
                ['updateSchoolGroup','updateProgrammeGroup','updateModeGroup','updateYearGroup','updateLevelGroup'].forEach(id => {
                    const g = document.getElementById(id); if (!g) return;
                    g.style.opacity = isUniversal ? '0.4' : '1';
                    g.style.pointerEvents = isUniversal ? 'none' : 'auto';
                });
            };

            document.getElementById('createFeeButton').addEventListener('click', () => {
                const f = document.getElementById('createFeeForm');
                f.checkValidity() ? f.submit() : f.reportValidity();
            });

            document.getElementById('confirmUpdate').addEventListener('click', () => {
                const f = document.getElementById('updateFeeForm');
                f.checkValidity() ? f.submit() : f.reportValidity();
            });

            document.getElementById('confirmDelete').addEventListener('click', () => {
                document.getElementById('deleteFeeForm').submit();
            });
        }

        function loadProgrammesBySchool(schoolId, targetSelectId) {
            const sel = document.getElementById(targetSelectId);
            sel.innerHTML = '<option value="">Loading...</option>';
            fetch(`/Admin/GetProgrammesBySchool?schoolId=${schoolId}`)
                .then(r => r.json())
                .then(data => {
                    sel.innerHTML = '<option value="">All Programmes</option>';
                    data.forEach(p => { const o = document.createElement('option'); o.value = p.value; o.textContent = p.text; sel.appendChild(o); });
                })
                .catch(() => { sel.innerHTML = '<option value="">Error loading programmes</option>'; });
        }
    </script>
}
