@model IEnumerable<SIS.Models.Admin.Programme>

@{
    ViewData["Title"] = "Programme Management";
    var programmes = Model?.ToList() ?? new List<SIS.Models.Admin.Programme>();
}

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2 text-primary-600">school</i>
            Programme Management
        </h1>
        <a asp-controller="Admin" asp-action="CreateProgramme"
           class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center shadow-md hover:shadow-lg">
            <i class="material-icons mr-2">add_circle</i>
            Create Programme
        </a>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-full">
            <div class="bg-white rounded-lg shadow-lg h-full overflow-hidden border border-gray-100">
                <div class="p-4">
                    <table id="programmesTable" class="w-full text-sm text-secondary-600">
                        <thead>
                            <tr class="bg-primary-50 border-b border-primary-100">
                                <th>
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4 text-left font-semibold">Programme Name</th>
                                <th class="px-6 py-4 text-left font-semibold">School</th>
                                <th class="px-6 py-4 text-left font-semibold">Department</th>
                                <th class="px-6 py-4 text-left font-semibold">Level</th>
                                <th class="px-6 py-4 text-left font-semibold">Duration</th>
                                <th class="px-6 py-4 text-left font-semibold">Coordinator</th>
                                <th class="px-6 py-4 text-left font-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (programmes.Any())
                            {
                                var groupedBySchool = programmes.GroupBy(p => p.Department?.School?.Name ?? "No School Assigned");
                                int index = 1;

                                foreach (var schoolGroup in groupedBySchool.OrderBy(g => g.Key))
                                {
                                    <!-- School Group Header Row -->
                                    <tr class="bg-primary-50 border-b border-primary-200" data-group-header="true">
                                        <td colspan="8" class="px-6 py-3">
                                            <span class="flex items-center text-primary-700 font-semibold text-sm uppercase tracking-wide">
                                                <i class="material-icons text-primary-600 mr-2 text-base">account_balance</i>
                                                @schoolGroup.Key
                                                <span class="ml-2 px-2 py-0.5 bg-primary-100 text-primary-600 rounded-full text-xs font-medium">
                                                    @schoolGroup.Count() @(schoolGroup.Count() == 1 ? "programme" : "programmes")
                                                </span>
                                            </span>
                                        </td>
                                    </tr>

                                    foreach (var programme in schoolGroup)
                                    {
                                        <tr class="border-b border-gray-100 hover:bg-primary-50 transition-colors">
                                            <td class="px-6 py-4 text-secondary-600">@index</td>
                                            <td class="px-6 py-4">
                                                <div class="flex flex-col">
                                                    <span class="font-semibold text-gray-900">@programme.Name</span>
                                                    @if (!string.IsNullOrEmpty(programme.Description))
                                                    {
                                                        <span class="text-xs text-gray-500 mt-1 line-clamp-2" title="@programme.Description">
                                                            @(programme.Description.Length > 60 ? programme.Description.Substring(0, 60) + "..." : programme.Description)
                                                        </span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex items-center">
                                                    <div class="p-2 bg-blue-100 rounded-lg mr-3">
                                                        <i class="material-icons text-blue-600 text-sm">business</i>
                                                    </div>
                                                    <span class="text-gray-700 font-medium">@(programme.Department?.School?.Name ?? "N/A")</span>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="px-3 py-1 text-sm bg-secondary-100 text-secondary-700 rounded-full font-medium">
                                                    @(programme.Department?.Name ?? "N/A")
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="px-3 py-1 text-sm bg-green-100 text-green-700 rounded-full font-medium">
                                                    @(programme.ProgrammeLevel?.Name ?? "N/A")
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex items-center">
                                                    <i class="material-icons text-amber-600 text-sm mr-2">schedule</i>
                                                    <span class="text-gray-700 font-medium">@programme.DurationYears years</span>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4">
                                                @if (programme.Coordinator != null)
                                                {
                                                    <div class="flex items-center">
                                                        <div class="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center mr-3">
                                                            <i class="material-icons text-primary-600 text-sm">person</i>
                                                        </div>
                                                        <div class="flex flex-col">
                                                            <span class="text-gray-900 font-medium text-sm">@(programme.Coordinator.FullName ?? programme.Coordinator.UserName)</span>
                                                            <span class="text-xs text-gray-500">@programme.Coordinator.Email</span>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-gray-400 italic">No coordinator assigned</span>
                                                }
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex space-x-2">
                                                    <a href="@Url.Action("UpdateProgramme", "Admin", new { id = programme.Id })"
                                                       class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                        <i class="material-icons text-sm mr-1">edit</i> Edit
                                                    </a>
                                                    <button onclick="showDeleteProgrammeModal('@programme.Id', '@programme.Name')"
                                                            class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                        <i class="material-icons text-sm mr-1">delete</i> Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="px-6 py-8 text-center text-gray-500">
                                        <div class="flex flex-col items-center">
                                            <i class="material-icons text-4xl text-gray-300 mb-2">school</i>
                                            <p class="text-lg font-medium">No programmes found</p>
                                            <p class="text-sm">Create your first programme to get started</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Programme Modal -->
    <div id="deleteProgrammeModal" class="hidden fixed inset-0 z-50">
        <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>

        <div class="fixed inset-0 z-10 overflow-y-auto">
            <div class="flex min-h-full items-center justify-center p-4">
                <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-lg border border-gray-200">
                    <!-- Modal Header -->
                    <div class="bg-red-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between">
                        <h3 class="text-lg font-semibold flex items-center">
                            <i class="material-icons mr-2">warning</i>
                            Confirm Delete
                        </h3>
                        <button type="button" class="text-white hover:text-red-200 transition-colors" data-bs-dismiss="modal">
                            <i class="material-icons">close</i>
                        </button>
                    </div>

                    <!-- Modal Body -->
                    <div class="p-6">
                        <form id="deleteProgrammeForm" method="post" asp-controller="Admin" asp-action="DeleteProgramme">
                            <input type="hidden" id="deleteProgrammeId" name="Id" />
                            @Html.AntiForgeryToken()

                            <div class="space-y-4">
                                <div class="flex items-center text-red-600 mb-4">
                                    <i class="material-icons mr-3 text-2xl">error_outline</i>
                                    <p class="text-lg font-semibold">Delete Programme</p>
                                </div>

                                <p class="text-gray-700 text-base">Are you sure you want to delete this programme? This action cannot be undone and will:</p>

                                <ul class="list-disc list-inside text-secondary-600 ml-4 space-y-2">
                                    <li>Permanently remove the programme</li>
                                    <li>Delete all associated data</li>
                                    <li>Remove student enrollments</li>
                                </ul>

                                <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
                                    <p class="text-gray-700 font-semibold mb-2 flex items-center">
                                        <i class="material-icons text-amber-600 mr-2">info</i>
                                        Programme Details:
                                    </p>
                                    <div class="space-y-1 text-secondary-600">
                                        <p><span class="font-medium">Programme Name:</span> <span id="deleteProgrammeName" class="ml-2 font-semibold text-secondary-800"></span></p>
                                    </div>
                                </div>

                                <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                    <div class="flex items-center text-red-800">
                                        <i class="material-icons text-red-600 mr-2 text-lg">warning</i>
                                        <p class="text-sm font-medium">This action cannot be undone. Please be certain.</p>
                                    </div>
                                </div>

                                <div class="mt-4">
                                    <label class="inline-flex items-center p-3 bg-gray-50 rounded-lg w-full">
                                        <input type="checkbox" id="confirmDeleteCheckbox"
                                               class="w-4 h-4 text-red-600 border-gray-300 rounded focus:ring-red-500">
                                        <span class="ml-3 text-sm text-gray-700 font-medium">I understand that this action cannot be undone</span>
                                    </label>
                                </div>
                            </div>
                        </form>
                    </div>

                    <!-- Modal Footer -->
                    <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3">
                        <button type="button"
                                class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300"
                                data-bs-dismiss="modal">
                            <i class="material-icons mr-1">close</i>Cancel
                        </button>
                        <button type="button"
                                id="confirmDelete"
                                disabled
                                class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center disabled:opacity-50 disabled:cursor-not-allowed shadow-md">
                            <i class="material-icons mr-1">delete</i>Delete Programme
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

