<script src="https://cdnjs.cloudflare.com/ajax/libs/simple-datatables/5.0.3/umd/simple-datatables.min.js"></script>
@* <script src="~/js/programmes.js"></script> *@

<script>
    window.chartData = @Html.Raw(Json.Serialize(ViewBag.ChartData ?? new List<object>()));
</script>

<script src="~/js/programmes.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const table = document.getElementById('programmesTable');
        const tbody = table.querySelector('tbody');
        const rowsPerPage = 10;
        let currentPage = 1;

        // Separate group headers from data rows, preserving DOM order
        function getOrderedRows() {
            return Array.from(tbody.querySelectorAll('tr'));
        }

        function getDataRows() {
            return Array.from(tbody.querySelectorAll('tr:not([data-group-header])'));
        }

        function getGroupHeaders() {
            return Array.from(tbody.querySelectorAll('tr[data-group-header]'));
        }

        function getTotalPages() {
            return Math.max(1, Math.ceil(getDataRows().length / rowsPerPage));
        }

        function renderPage(page) {
            const dataRows = getDataRows();
            const totalPages = getTotalPages();
            currentPage = Math.min(Math.max(1, page), totalPages);

            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            const visibleDataRows = new Set(dataRows.slice(start, end));

            // Find which group headers have at least one visible data row
            const allRows = getOrderedRows();
            const visibleGroupHeaders = new Set();

            let lastGroupHeader = null;
            allRows.forEach(row => {
                if (row.dataset.groupHeader) {
                    lastGroupHeader = row;
                } else if (visibleDataRows.has(row) && lastGroupHeader) {
                    visibleGroupHeaders.add(lastGroupHeader);
                }
            });

            // Show/hide rows
            allRows.forEach(row => {
                if (row.dataset.groupHeader) {
                    row.style.display = visibleGroupHeaders.has(row) ? '' : 'none';
                } else {
                    row.style.display = visibleDataRows.has(row) ? '' : 'none';
                }
            });

            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            const existing = document.getElementById('programmePagination');
            if (existing) existing.remove();

            if (totalPages <= 1) return;

            const dataRows = getDataRows();
            const startEntry = (currentPage - 1) * rowsPerPage + 1;
            const endEntry = Math.min(currentPage * rowsPerPage, dataRows.length);

            const wrapper = document.createElement('div');
            wrapper.id = 'programmePagination';
            wrapper.className = 'flex items-center justify-between px-4 py-3 border-t border-gray-200 bg-white';

            // Entries info
            const info = document.createElement('span');
            info.className = 'text-sm text-gray-600';
            info.textContent = `Showing ${startEntry} to ${endEntry} of ${dataRows.length} entries`;

            // Pagination buttons
            const nav = document.createElement('div');
            nav.className = 'flex items-center gap-1';

            const createBtn = (label, page, isIcon = false, disabled = false) => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.disabled = disabled;
                btn.className = `px-3 py-1.5 text-sm rounded-lg transition-colors ${
                    disabled
                        ? 'text-gray-300 bg-gray-50 cursor-not-allowed'
                        : page === currentPage
                            ? 'bg-primary-600 text-white font-semibold'
                            : 'text-gray-600 bg-white hover:bg-primary-50 border border-gray-200'
                }`;
                if (isIcon) {
                    btn.innerHTML = `<i class="material-icons text-sm">${label}</i>`;
                } else {
                    btn.textContent = label;
                }
                if (!disabled && page !== currentPage) {
                    btn.addEventListener('click', () => renderPage(page));
                }
                return btn;
            };

            // Prev button
            nav.appendChild(createBtn('chevron_left', currentPage - 1, true, currentPage === 1));

            // Page number buttons with ellipsis
            const pageWindow = 2;
            let lastPrinted = 0;
            for (let p = 1; p <= totalPages; p++) {
                if (p === 1 || p === totalPages || (p >= currentPage - pageWindow && p <= currentPage + pageWindow)) {
                    if (lastPrinted && p - lastPrinted > 1) {
                        const ellipsis = document.createElement('span');
                        ellipsis.className = 'px-2 text-gray-400';
                        ellipsis.textContent = '...';
                        nav.appendChild(ellipsis);
                    }
                    nav.appendChild(createBtn(p, p));
                    lastPrinted = p;
                }
            }

            // Next button
            nav.appendChild(createBtn('chevron_right', currentPage + 1, true, currentPage === totalPages));

            wrapper.appendChild(info);
            wrapper.appendChild(nav);

            // Insert after the table's parent div
            const tableWrapper = table.closest('.p-4');
            tableWrapper.appendChild(wrapper);
        }

        renderPage(1);
    });
</script>