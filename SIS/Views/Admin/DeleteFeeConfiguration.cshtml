@using SIS.Models.Fees
@model FeeConfiguration

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow p-3 mb-5 bg-white rounded">
                <div class="card-body">
                    <h2 class="text-center mb-4">Delete Fee Configuration</h2>
                    <form asp-action="DeleteFeeConfiguration" method="post">
                        <!-- Hidden field for FeeConfiguration Id -->
                        <input type="hidden" name="Id" value="@Model.Id" />

                        <!-- Academic Year -->
                        <div class="form-group">
                            <label for="AcademicYear">Academic Year:</label>
                            <input id="AcademicYear" class="form-control" value="@Model.AcademicYear?.YearValue" disabled />
                        </div>

                        <!-- School -->
                        <div class="form-group">
                            <label for="School">School:</label>
                            <input id="School" class="form-control" value="@Model.School?.Name" disabled />
                        </div>

                        <!-- Programme -->
                        <div class="form-group">
                            <label for="Programme">Programme:</label>
                            <input id="Programme" class="form-control" value="@Model.Programme?.Name" disabled />
                        </div>

                        <!-- Mode of Study -->
                        <div class="form-group">
                            <label for="ModeOfStudy">Mode of Study:</label>
                            <input id="ModeOfStudy" class="form-control" value="@Model.ModeOfStudy?.ModeName" disabled />
                        </div>

                        <!-- Year of Study -->
                        <div class="form-group">
                            <label for="YearOfStudy">Year of Study:</label>
                            <input id="YearOfStudy" class="form-control" value="@Model.YearOfStudy" disabled />
                        </div>

                        <!-- Fee Type -->
                        <div class="form-group">
                            <label for="FeeType">Fee Type:</label>
                            <input id="FeeType" class="form-control" value="@Model.FeeType?.Name" disabled />
                        </div>

                        <!-- Amount -->
                        <div class="form-group">
                            <label for="Amount">Amount:</label>
                            <input id="Amount" class="form-control" value="@Model.Amount" disabled />
                        </div>

                        <!-- Confirm Deletion Message -->
                        <div class="form-group text-center">
                            <p>Are you sure you want to delete this fee configuration?</p>
                        </div>

                        <!-- Delete Button -->
                        <button type="submit" class="btn btn-danger btn-block mt-4">Delete</button>

                        <!-- Back to List Button -->
                        <a asp-action="FeeConfigurations" class="btn btn-outline-secondary btn-block mt-4">Back to List</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
