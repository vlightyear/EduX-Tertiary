@using SIS.Models.Admin
@model IEnumerable<SIS.Models.Admin.WorkingDayConfiguration>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-gray-800 flex items-center">
            <i class="material-icons mr-2">calendar_month</i>
            Working Day Configurations
        </h1>
        <button type="button"
                onclick="location.href='@Url.Action("CreateWorkingDayConfig", "Admin")'"
                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
            <i class="material-icons mr-2">add</i>
            Create Configuration
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full overflow-auto">
                <div class="p-4">
                   <table id="workingDaysTable" class="w-full text-sm text-gray-600">
                        <thead>
                            <tr>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">Academic Year</th>
                                <th class="px-6 py-4">Mode of Study</th>
                                <th class="px-6 py-4">Working Days</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Created Date</th>
                                <th class="px-6 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var config in Model)
                            {
                                <tr class="border-b hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4">@(Model.ToList().IndexOf(config) + 1)</td>
                                    <td class="px-6 py-4 font-medium text-gray-900">@config.AcademicYear.YearValue</td>
                                    <td class="px-6 py-4">@config.ModeOfStudy.ModeName</td>
                                    <td class="px-6 py-4">
                                                        @{
                                                            var days = System.Text.Json.JsonSerializer.Deserialize<List<DayConfiguration>>(config.WorkingDaysData);
                                                            var workingDaysCount = days.Count(d => d.IsWorkingDay);
                                                        }
                                        <span class="inline-flex items-center">
                                            <i class="material-icons text-blue-600 mr-1 text-sm">calendar_today</i>
                                                            @workingDaysCount Days
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                                        @if (config.IsActive)
                                                        {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                    Active
                                                </span>
                                                        }
                                                        else
                                                        {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                                    Inactive
                                                </span>
                                                        }
                                    </td>
                                    <td class="px-6 py-4">@config.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td class="px-6 py-4">
                                        <div class="flex space-x-2">
                                            <button onclick="location.href='@Url.Action("UpdateWorkingDayConfig", "Admin", new { id = config.Id })'"
                                                    class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                <i class="material-icons text-sm mr-1">edit</i> Edit
                                            </button>
                                            <button onclick="showDeleteModal('@config.Id', '@config.AcademicYear.YearValue - @config.ModeOfStudy.ModeName')"
                                                    class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                <i class="material-icons text-sm mr-1">delete</i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Configuration Summary</h3>
                <div class="space-y-6">
                    <!-- Total Configurations -->
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">calendar_month</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Configurations</p>
                            <p class="text-xl font-semibold">@ViewBag.TotalConfigurations</p>
                        </div>
                    </div>

                    <!-- Active Configurations -->
                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">check_circle</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Active Configurations</p>
                            <p class="text-xl font-semibold text-green-600">@ViewBag.ActiveConfigurations</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Configuration Distribution Chart -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Mode Distribution</h3>
                <div id="modeDistributionChart" class="min-h-64"></div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Configuration Modal -->
<div id="deleteModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" onclick="hideDeleteModal()">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="deleteForm" method="post" asp-controller="Admin" asp-action="DeleteWorkingDayConfig">
                        <input type="hidden" id="deleteId" name="Id" />
                        @Html.AntiForgeryToken()

                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-2">error_outline</i>
                                <p class="text-lg font-medium">Delete Working Day Configuration</p>
                            </div>

                            <p class="text-gray-700">Are you sure you want to delete this working day configuration? This action cannot be undone.</p>

                            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mt-4">
                                <p class="text-gray-700 font-medium mb-2">Configuration Details:</p>
                                <p class="text-gray-600">
                                    <span class="font-medium">Configuration:</span>
                                    <span id="deleteConfig" class="ml-2"></span>
                                </p>
                            </div>

                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-sm">info</i>
                                    <p class="text-sm">This action cannot be undone. All associated data will be permanently deleted.</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button"
                            class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center"
                            onclick="hideDeleteModal()">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button"
                            onclick="document.getElementById('deleteForm').submit()"
                            class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize DataTable
            const dataTable = new simpleDatatables.DataTable("#workingDaysTable", {
                perPage: 10,
                searchable: true,
                sortable: true,
                labels: {
                    placeholder: "Search...",
                    perPage: "Show {select} entries",
                    noRows: "No configurations found",
                    info: "Showing {start} to {end} of {rows} configurations",
                },
                classes: {
                    wrapper: "datatable-wrapper",
                    input: "datatable-input px-3 py-2 text-sm border border-gray-300 rounded-lg",
                    selector: "datatable-selector px-3 py-2 text-sm border border-gray-300 rounded-lg",
                    paginationButton: "px-3 py-1 text-sm text-gray-600 hover:bg-gray-100 rounded-md",
                    paginationButtonActive: "bg-blue-50 text-blue-600 hover:bg-blue-100",
                    paginationButtonDisabled: "text-gray-400 hover:bg-transparent cursor-not-allowed",
                }
            });

            // Initialize Mode Distribution Chart
            const modeDistributionData = @Html.Raw(Json.Serialize(ViewBag.ConfigurationsByMode));
            const modeLabels = Object.keys(modeDistributionData);
            const modeValues = Object.values(modeDistributionData);

            const modeDistributionChart = new ApexCharts(document.querySelector("#modeDistributionChart"), {
                series: modeValues,
                chart: {
                    type: 'donut',
                    height: '100%'
                },
                labels: modeLabels,
                colors: ['#10B981', '#6B7280', '#3B82F6', '#8B5CF6'],
                plotOptions: {
                    pie: {
                        donut: {
                            size: '70%',
                            labels: {
                                show: true,
                                name: {
                                    show: true,
                                    fontSize: '14px',
                                    fontFamily: 'inherit',
                                    offsetY: -4
                                },
                                value: {
                                    show: true,
                                    fontSize: '16px',
                                    fontFamily: 'inherit',
                                    formatter: function (val) {
                                        return val + ' configs'
                                    }
                                },
                                total: {
                                    show: true,
                                    label: 'Total',
                                    color: '#373d3f',
                                    formatter: function (w) {
                                        return w.globals.seriesTotals.reduce((a, b) => a + b, 0) + ' configs'
                                    }
                                }
                            }
                        }
                    }
                },
                legend: {
                    show: false
                },
                dataLabels: {
                    enabled: false
                }
            });

            modeDistributionChart.render();
        });

          // Modal handling functions
        function showDeleteModal(id, config) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteConfig').textContent = config;
            const modal = document.getElementById('deleteModal');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hideDeleteModal() {
            const modal = document.getElementById('deleteModal');
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        // Close modal when clicking outside
        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === this) {
                hideDeleteModal();
            }
        });

        // Handle Escape key to close modal
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && !document.getElementById('deleteModal').classList.contains('hidden')) {
                hideDeleteModal();
            }
        });
    </script>
}