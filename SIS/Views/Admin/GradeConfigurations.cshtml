@model IEnumerable<SIS.Models.Admin.GradeConfiguration>
@using SIS.Models.Admin
@using SIS.Models.Registration
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var schoolsList = ViewBag.SchoolsList as List<School>;
    var academicYearsList = ViewBag.AcademicYearsList as List<AcademicYear>;
    var schoolsSelectList = ViewBag.Schools as IEnumerable<SelectListItem>;
    var academicYearsSelectList = ViewBag.AcademicYears as IEnumerable<SelectListItem>;
}

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">grade</i>
            Grade Configurations
        </h1>
        <button type="button"
                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center"
                onclick="showCreateGradeConfigModal()">
            <i class="material-icons mr-2">add</i>
            Create Grade
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full overflow-hidden">
                <div class="p-4">
                    <!-- Filter Section -->
                    <div class="mb-4 flex gap-4">
                        <div class="w-1/3">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Filter by School</label>
                            <select id="filterSchool" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
                                <option value="">All Schools</option>
                                <option value="global">Global Only</option>
                                @if (schoolsSelectList != null)
                                {
                                    foreach (var school in schoolsSelectList)
                                    {
                                        <option value="@school.Value">@school.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="w-1/3">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Filter by Academic Year</label>
                            <select id="filterAcademicYear" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
                                <option value="">All Academic Years</option>
                                @if (academicYearsSelectList != null)
                                {
                                    foreach (var year in academicYearsSelectList)
                                    {
                                        <option value="@year.Value">@year.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="w-1/3 flex items-end">
                            <button type="button" onclick="clearFilters()"
                                    class="px-4 py-2 text-secondary-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center">
                                <i class="material-icons mr-1 text-sm">clear</i>
                                Clear Filters
                            </button>
                        </div>
                    </div>

                    <div class="overflow-auto max-h-[calc(90vh-250px)]">
                        <table id="gradeConfigTable" class="w-full text-sm text-secondary-600">
                            <thead class="sticky top-0 bg-gray-50">
                                <tr>
                                    <th class="px-4 py-4 text-left">
                                        <span class="flex items-center">
                                            #
                                            <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                            </svg>
                                        </span>
                                    </th>
                                    <th class="px-4 py-4 text-left">Grade</th>
                                    <th class="px-4 py-4 text-left">Score Range</th>
                                    <th class="px-4 py-4 text-left">GPA Value</th>
                                    <th class="px-4 py-4 text-left">School</th>
                                    <th class="px-4 py-4 text-left">Academic Year</th>
                                    <th class="px-4 py-4 text-left">Status</th>
                                    <th class="px-4 py-4 text-left">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    int index = 1;
                                    foreach (var grade in Model)
                                    {
                                        <tr class="border-b hover:bg-gray-50 transition-colors"
                                            data-school-id="@(grade.SchoolId.HasValue ? grade.SchoolId.ToString() : "global")"
                                            data-academic-year-id="@(grade.AcademicYearId?.ToString() ?? "")">
                                            <td class="px-4 py-4">@index</td>
                                            <td class="px-4 py-4 font-medium text-gray-900">
                                                <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-lg font-bold">
                                                    @grade.GradeLetter
                                                </span>
                                                @if (grade.IsPassingGrade)
                                                {
                                                    <span class="ml-2 px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full">Pass</span>
                                                }
                                            </td>
                                            <td class="px-4 py-4">@grade.MinScore% - @grade.MaxScore%</td>
                                            <td class="px-4 py-4">
                                                <span class="font-semibold">@grade.GPAValue.ToString("N2")</span>
                                            </td>
                                            <td class="px-4 py-4">
                                                @if (grade.SchoolId.HasValue)
                                                {
                                                    var school = schoolsList?.FirstOrDefault(s => s.Id == grade.SchoolId);
                                                    <span class="px-2 py-1 bg-purple-100 text-purple-800 rounded-lg text-xs">
                                                        @(school?.Name ?? "N/A")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="px-2 py-1 bg-gray-100 text-secondary-600 rounded-lg text-xs italic">
                                                        <i class="material-icons text-xs align-middle">public</i> Global
                                                    </span>
                                                }
                                            </td>
                                            <td class="px-4 py-4">
                                                @if (grade.AcademicYearId.HasValue)
                                                {
                                                    var academicYear = academicYearsList?.FirstOrDefault(a => a.YearId == grade.AcademicYearId);
                                                    <span class="px-2 py-1 bg-indigo-100 text-indigo-800 rounded-lg text-xs">
                                                        @(academicYear?.YearValue ?? "N/A")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-gray-400 italic text-xs">N/A</span>
                                                }
                                            </td>
                                            <td class="px-4 py-4">
                                                @if (grade.IsActive)
                                                {
                                                    <span class="px-2 py-1 text-xs bg-green-100 text-green-800 rounded-full">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="px-2 py-1 text-xs bg-red-100 text-red-800 rounded-full">Inactive</span>
                                                }
                                            </td>
                                            <td class="px-4 py-4">
                                                <div class="flex space-x-2">
                                                    <button onclick="showUpdateGradeConfigModal('@grade.Id')"
                                                            class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                        <i class="material-icons text-sm mr-1">edit</i> Edit
                                                    </button>
                                                    <button onclick="showDeleteGradeModal('@grade.Id', '@grade.GradeLetter')"
                                                            class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                        <i class="material-icons text-sm mr-1">delete</i> Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="px-6 py-8 text-center text-gray-500">
                                            <i class="material-icons text-4xl text-gray-300 mb-2">info</i>
                                            <p>No grade configurations found.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4 overflow-auto max-h-[calc(90vh-80px)]">
            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Grade Configuration Summary</h3>
                <div class="space-y-4">
                    <!-- Total Grades -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-blue-100 rounded-lg">
                                <i class="material-icons text-blue-600 text-xl">list</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Total Grades</p>
                                <p class="text-xl font-semibold">@(Model?.Count() ?? 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Active Grades -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-green-100 rounded-lg">
                                <i class="material-icons text-green-600 text-xl">check_circle</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Active Grades</p>
                                <p class="text-xl font-semibold text-green-600">@(Model?.Count(x => x.IsActive) ?? 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Highest GPA -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-yellow-100 rounded-lg">
                                <i class="material-icons text-yellow-600 text-xl">star</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Highest GPA</p>
                                <p class="text-xl font-semibold text-yellow-600">@(Model?.Any() == true ? Model.Max(x => x.GPAValue).ToString("N2") : "0.00")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Pass Grade -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-purple-100 rounded-lg">
                                <i class="material-icons text-purple-600 text-xl">school</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Pass Grades</p>
                                <p class="text-xl font-semibold text-purple-600">@(Model?.Count(x => x.IsPassingGrade) ?? 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Global Configs -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-indigo-100 rounded-lg">
                                <i class="material-icons text-indigo-600 text-xl">public</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">Global Configs</p>
                                <p class="text-xl font-semibold text-indigo-600">@(Model?.Count(x => !x.SchoolId.HasValue) ?? 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- School-Specific Configs -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="p-3 bg-orange-100 rounded-lg">
                                <i class="material-icons text-orange-600 text-xl">business</i>
                            </div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">School-Specific</p>
                                <p class="text-xl font-semibold text-orange-600">@(Model?.Count(x => x.SchoolId.HasValue) ?? 0)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Distribution Chart -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Grade Distribution</h3>
                <div id="grade-distribution-chart" class="h-64"></div>
            </div>

            <!-- Quick Info -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Quick Info</h3>
                <div class="space-y-2 text-sm text-secondary-600">
                    <p><i class="material-icons text-sm align-middle text-blue-500">info</i> <strong>Global</strong> grades apply to all schools.</p>
                    <p><i class="material-icons text-sm align-middle text-purple-500">info</i> <strong>School-specific</strong> grades override global grades.</p>
                    <p><i class="material-icons text-sm align-middle text-green-500">info</i> <strong>Pass Grade</strong> defines the minimum passing threshold.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Grade Configuration Modal -->
<div id="createGradeConfigModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-blue-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New Grade Configuration
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" data-bs-dismiss="modal" onclick="hideCreateGradeConfigModal()">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="createGradeConfigForm" method="post" asp-controller="Admin" asp-action="CreateGradeConfig">
                        @Html.AntiForgeryToken()
                        <div class="space-y-6">
                            <!-- Academic Year and School Section -->
                            <div class="grid grid-cols-2 gap-6">
                                <!-- Academic Year (Mandatory) -->
                                <div class="relative z-0 w-full group">
                                    <label for="academicYearId" class="block text-sm font-medium text-gray-700 mb-1">
                                        Academic Year <span class="text-red-500">*</span>
                                    </label>
                                    <select name="AcademicYearId" id="academicYearId" required
                                            class="w-full px-3 py-2.5 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="">Select Academic Year</option>
                                        @if (academicYearsSelectList != null)
                                        {
                                            foreach (var item in academicYearsSelectList)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <!-- School (Optional) -->
                                <div class="relative z-0 w-full group">
                                    <label for="schoolId" class="block text-sm font-medium text-gray-700 mb-1">
                                        School <span class="text-gray-400 text-xs">(Optional - Leave blank for Global)</span>
                                    </label>
                                    <select name="SchoolId" id="schoolId"
                                            class="w-full px-3 py-2.5 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="">Global (All Schools)</option>
                                        @if (schoolsSelectList != null)
                                        {
                                            foreach (var item in schoolsSelectList)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Grade Letter -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="GradeLetter" id="gradeLetter"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required maxlength="3" />
                                <label for="gradeLetter"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Grade Letter (e.g., A+, A, B+) <span class="text-red-500">*</span>
                                </label>
                            </div>

                            <!-- Score Range Section -->
                            <div class="grid grid-cols-2 gap-6">
                                <div class="relative z-0 w-full group">
                                    <input type="number" name="MinScore" id="minScore"
                                           class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                           placeholder=" " required min="0" max="100" step="0.01"
                                           onchange="validateScoreRange(this, document.getElementById('maxScore'))" />
                                    <label for="minScore"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Minimum Score (%) <span class="text-red-500">*</span>
                                    </label>
                                </div>

                                <div class="relative z-0 w-full group">
                                    <input type="number" name="MaxScore" id="maxScore"
                                           class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                           placeholder=" " required min="0" max="100" step="0.01"
                                           onchange="validateScoreRange(document.getElementById('minScore'), this)" />
                                    <label for="maxScore"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Maximum Score (%) <span class="text-red-500">*</span>
                                    </label>
                                </div>
                            </div>

                            <!-- GPA Value -->
                            <div class="relative z-0 w-full group">
                                <input type="number" name="GPAValue" id="gpaValue"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required min="0" max="4.0" step="0.01" />
                                <label for="gpaValue"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    GPA Value (0-4.0) <span class="text-red-500">*</span>
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="description" rows="2"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" " maxlength="200"></textarea>
                                <label for="description"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- Checkboxes -->
                            <div class="space-y-3">
                                <div class="flex items-center">
                                    <input type="checkbox" id="isPassingGrade" name="IsPassingGrade" value="true"
                                           class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                                    <label for="isPassingGrade" class="ml-2 text-sm text-gray-700">Is Passing Grade</label>
                                </div>

                                <div class="flex items-center">
                                    <input type="checkbox" id="isActive" name="IsActive" value="true"
                                           class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" checked />
                                    <label for="isActive" class="ml-2 text-sm text-gray-700">Is Active</label>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" onclick="hideCreateGradeConfigModal()">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmCreate" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Grade Configuration Modal -->
<div id="updateGradeConfigModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl">
                <!-- Modal Header -->
                <div class="bg-gray-700 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">edit</i>
                        Update Grade Configuration
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" onclick="hideUpdateGradeConfigModal()">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="updateGradeConfigForm" method="post" asp-controller="Admin" asp-action="UpdateGradeConfig">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="updateGradeId" name="Id" />

                        <div class="space-y-6">
                            <!-- Academic Year and School Section -->
                            <div class="grid grid-cols-2 gap-6">
                                <!-- Academic Year (Mandatory) -->
                                <div class="relative z-0 w-full group">
                                    <label for="updateAcademicYearId" class="block text-sm font-medium text-gray-700 mb-1">
                                        Academic Year <span class="text-red-500">*</span>
                                    </label>
                                    <select name="AcademicYearId" id="updateAcademicYearId" required
                                            class="w-full px-3 py-2.5 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="">Select Academic Year</option>
                                        @if (academicYearsSelectList != null)
                                        {
                                            foreach (var item in academicYearsSelectList)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <!-- School (Optional) -->
                                <div class="relative z-0 w-full group">
                                    <label for="updateSchoolId" class="block text-sm font-medium text-gray-700 mb-1">
                                        School <span class="text-gray-400 text-xs">(Optional - Leave blank for Global)</span>
                                    </label>
                                    <select name="SchoolId" id="updateSchoolId"
                                            class="w-full px-3 py-2.5 text-sm text-gray-900 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="">Global (All Schools)</option>
                                        @if (schoolsSelectList != null)
                                        {
                                            foreach (var item in schoolsSelectList)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Grade Letter -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="GradeLetter" id="updateGradeLetter"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required maxlength="3" />
                                <label for="updateGradeLetter"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Grade Letter (e.g., A+, A, B+) <span class="text-red-500">*</span>
                                </label>
                            </div>

                            <!-- Score Range Section -->
                            <div class="grid grid-cols-2 gap-6">
                                <div class="relative z-0 w-full group">
                                    <input type="number" name="MinScore" id="updateMinScore"
                                           class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                           placeholder=" " required min="0" max="100" step="0.01"
                                           onchange="validateScoreRange(this, document.getElementById('updateMaxScore'))" />
                                    <label for="updateMinScore"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Minimum Score (%) <span class="text-red-500">*</span>
                                    </label>
                                </div>

                                <div class="relative z-0 w-full group">
                                    <input type="number" name="MaxScore" id="updateMaxScore"
                                           class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                           placeholder=" " required min="0" max="100" step="0.01"
                                           onchange="validateScoreRange(document.getElementById('updateMinScore'), this)" />
                                    <label for="updateMaxScore"
                                           class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Maximum Score (%) <span class="text-red-500">*</span>
                                    </label>
                                </div>
                            </div>

                            <!-- GPA Value -->
                            <div class="relative z-0 w-full group">
                                <input type="number" name="GPAValue" id="updateGPAValue"
                                       class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                       placeholder=" " required min="0" max="4.0" step="0.01" />
                                <label for="updateGPAValue"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    GPA Value (0-4.0) <span class="text-red-500">*</span>
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="updateDescription" rows="2"
                                          class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                          placeholder=" " maxlength="200"></textarea>
                                <label for="updateDescription"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- Checkboxes -->
                            <div class="space-y-3">
                                <div class="flex items-center">
                                    <input type="checkbox" id="updateIsPassingGrade" name="IsPassingGrade" value="true"
                                           class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                                    <label for="updateIsPassingGrade" class="ml-2 text-sm text-gray-700">Is Passing Grade</label>
                                </div>

                                <div class="flex items-center">
                                    <input type="checkbox" id="updateIsActive" name="IsActive" value="true"
                                           class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                                    <label for="updateIsActive" class="ml-2 text-sm text-gray-700">Is Active</label>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" onclick="hideUpdateGradeConfigModal()">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmUpdate" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">save</i>Update
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Grade Configuration Modal -->
<div id="deleteGradeConfigModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" onclick="hideDeleteGradeModal()">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="deleteGradeConfigForm" method="post" asp-controller="Admin" asp-action="DeleteGradeConfig">
                        <input type="hidden" id="deleteGradeId" name="Id" />
                        @Html.AntiForgeryToken()

                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-2">error_outline</i>
                                <p class="text-lg font-medium">Delete Grade Configuration</p>
                            </div>

                            <p class="text-gray-700">Are you sure you want to delete this grade configuration?</p>

                            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                                <p class="text-gray-700 font-medium mb-2">Grade Details:</p>
                                <p class="text-secondary-600">
                                    <span class="font-medium">Grade:</span>
                                    <span id="deleteGradeLetter" class="ml-2 px-2 py-1 bg-blue-100 text-blue-800 rounded-lg font-bold"></span>
                                </p>
                            </div>

                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-sm">info</i>
                                    <p class="text-sm">This action cannot be undone and may affect existing student grades.</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" onclick="hideDeleteGradeModal()">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmDelete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- JavaScript for modals and filtering -->
<script>
    // Filter functionality for the table
    document.getElementById('filterSchool').addEventListener('change', filterTable);
    document.getElementById('filterAcademicYear').addEventListener('change', filterTable);

    function filterTable() {
        const schoolFilter = document.getElementById('filterSchool').value;
        const yearFilter = document.getElementById('filterAcademicYear').value;
        const rows = document.querySelectorAll('#gradeConfigTable tbody tr');

        rows.forEach(row => {
            if (!row.hasAttribute('data-school-id')) return; // Skip empty row

            const schoolId = row.getAttribute('data-school-id') || '';
            const academicYearId = row.getAttribute('data-academic-year-id') || '';

            let showRow = true;

            if (schoolFilter) {
                if (schoolFilter === 'global') {
                    if (schoolId !== 'global') showRow = false;
                } else {
                    if (schoolId !== schoolFilter) showRow = false;
                }
            }

            if (yearFilter && academicYearId !== yearFilter) {
                showRow = false;
            }

            row.style.display = showRow ? '' : 'none';
        });

        // Update row numbers
        let visibleIndex = 1;
        rows.forEach(row => {
            if (row.style.display !== 'none' && row.hasAttribute('data-school-id')) {
                row.querySelector('td:first-child').textContent = visibleIndex++;
            }
        });
    }

    function clearFilters() {
        document.getElementById('filterSchool').value = '';
        document.getElementById('filterAcademicYear').value = '';
        filterTable();
    }

    // Modal functions
    function showCreateGradeConfigModal() {
        document.getElementById('createGradeConfigForm').reset();
        document.getElementById('isActive').checked = true;
        document.getElementById('createGradeConfigModal').classList.remove('hidden');
    }

    function hideCreateGradeConfigModal() {
        document.getElementById('createGradeConfigModal').classList.add('hidden');
    }

    async function showUpdateGradeConfigModal(id) {
        try {
            const response = await fetch(`/Admin/GetGradeConfig/${id}`);
            if (!response.ok) throw new Error('Failed to fetch grade configuration');

            const data = await response.json();

            // Populate form fields
            document.getElementById('updateGradeId').value = data.id;
            document.getElementById('updateGradeLetter').value = data.gradeLetter;
            document.getElementById('updateMinScore').value = data.minScore;
            document.getElementById('updateMaxScore').value = data.maxScore;
            document.getElementById('updateGPAValue').value = data.gpaValue;
            document.getElementById('updateDescription').value = data.description || '';
            document.getElementById('updateIsPassingGrade').checked = data.isPassingGrade;
            document.getElementById('updateIsActive').checked = data.isActive;

            // Set School dropdown
            const schoolSelect = document.getElementById('updateSchoolId');
            if (schoolSelect) {
                schoolSelect.value = data.schoolId || '';
            }

            // Set Academic Year dropdown
            const academicYearSelect = document.getElementById('updateAcademicYearId');
            if (academicYearSelect) {
                academicYearSelect.value = data.academicYearId || '';
            }

            // Show modal
            document.getElementById('updateGradeConfigModal').classList.remove('hidden');
        } catch (error) {
            console.error('Error:', error);
            alert('Failed to load grade configuration details');
        }
    }

    function hideUpdateGradeConfigModal() {
        document.getElementById('updateGradeConfigModal').classList.add('hidden');
    }

    function showDeleteGradeModal(id, gradeLetter) {
        document.getElementById('deleteGradeId').value = id;
        document.getElementById('deleteGradeLetter').textContent = gradeLetter;
        document.getElementById('deleteGradeConfigModal').classList.remove('hidden');
    }

    function hideDeleteGradeModal() {
        document.getElementById('deleteGradeConfigModal').classList.add('hidden');
    }

    // Form validation
    function validateScoreRange(minInput, maxInput) {
        const minScore = parseFloat(minInput.value);
        const maxScore = parseFloat(maxInput.value);

        if (!isNaN(minScore) && !isNaN(maxScore) && minScore >= maxScore) {
            alert('Minimum score must be less than maximum score');
            minInput.focus();
        }
    }

    // Form submission handlers
    document.getElementById('confirmCreate').addEventListener('click', function () {
        const form = document.getElementById('createGradeConfigForm');
        const academicYearSelect = document.getElementById('academicYearId');

        if (!academicYearSelect.value) {
            alert('Please select an Academic Year');
            academicYearSelect.focus();
            return;
        }

        if (form.checkValidity()) {
            form.submit();
        } else {
            form.reportValidity();
        }
    });

    document.getElementById('confirmUpdate').addEventListener('click', function () {
        const form = document.getElementById('updateGradeConfigForm');
        const academicYearSelect = document.getElementById('updateAcademicYearId');

        if (!academicYearSelect.value) {
            alert('Please select an Academic Year');
            academicYearSelect.focus();
            return;
        }

        if (form.checkValidity()) {
            form.submit();
        } else {
            form.reportValidity();
        }
    });

    document.getElementById('confirmDelete').addEventListener('click', function () {
        document.getElementById('deleteGradeConfigForm').submit();
    });

    // Close modals when clicking outside
    document.querySelectorAll('.fixed.inset-0.bg-black').forEach(overlay => {
        overlay.addEventListener('click', function () {
            this.closest('.fixed.inset-0.z-50').classList.add('hidden');
        });
    });
</script>

<script type="module" src="~/js/grade_config.js"></script>