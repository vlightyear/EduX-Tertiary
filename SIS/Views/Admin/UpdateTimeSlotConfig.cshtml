@model SIS.Models.Admin.TimeSlotConfiguration

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">schedule</i>
            Update Time Slot Configuration
        </h1>
        <a asp-controller="Admin" asp-action="TimeSlotConfigurations"
           class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center">
            <i class="material-icons mr-2">arrow_back</i>
            Back
        </a>
    </div>

    <!-- Main Content -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md overflow-auto">
                <form asp-action="UpdateTimeSlotConfig" method="post" id="timeSlotForm" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="CreatedBy" />

                    <!-- Basic Configuration Details -->
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <h2 class="text-lg font-semibold text-secondary-800 mb-4">Configuration Details</h2>
                        <div class="space-y-4">
                            <div>
                                <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Configuration Name</label>
                                <input asp-for="Name" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                                       placeholder="e.g., Regular Semester, Summer Term" />
                                <span asp-validation-for="Name" class="text-sm text-red-600"></span>
                            </div>

                            <div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input asp-for="IsActive" type="checkbox" class="sr-only peer">
                                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300
                                                rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full
                                                peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px]
                                                after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5
                                                after:transition-all peer-checked:bg-primary-600"></div>
                                    <span class="ms-3 text-sm font-medium text-gray-700">Active Configuration</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Periods Table -->
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <div class="flex justify-between items-center mb-4">
                            <h2 class="text-lg font-semibold text-secondary-800">Time Periods</h2>
                            <button type="button" id="addPeriodBtn"
                                    class="px-3 py-1.5 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center text-sm">
                                <i class="material-icons text-sm mr-1">add</i>
                                Add Period
                            </button>
                        </div>

                        <div class="border rounded-lg overflow-hidden">
                            <table class="w-full text-sm text-secondary-600">
                                <thead>
                                    <tr class="bg-gray-50 border-b">
                                        <th class="px-4 py-3 text-left">Period</th>
                                        <th class="px-4 py-3 text-left">Start Time</th>
                                        <th class="px-4 py-3 text-left">End Time</th>
                                        <th class="px-4 py-3 text-left">Type</th>
                                        <th class="px-4 py-3 text-left">Description</th>
                                        <th class="px-4 py-3 text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="periodsTableBody">
                                    <!-- Periods will be populated dynamically -->
                                </tbody>
                            </table>
                        </div>

                        <!-- Hidden input for periods data -->
                        <input type="hidden" asp-for="PeriodsData" id="periodsData" />
                    </div>

                    <!-- Validation Summary -->
                    <div id="validationSummary" class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50" role="alert">
                    </div>

                    <!-- Submit Button -->
                    <div class="flex justify-end p-6">
                        <button type="submit" class="px-6 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center">
                            <i class="material-icons mr-2">save</i>
                            Update Configuration
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="w-1/4 space-y-4">
            <!-- Audit Information -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Audit Information</h3>
                <div class="space-y-3">
                    <div>
                        <p class="text-sm text-gray-500">Created By</p>
                        <p class="font-medium">@Model.CreatedBy</p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500">Created At</p>
                        <p class="font-medium">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.UpdatedBy))
                    {
                        <div>
                            <p class="text-sm text-gray-500">Last Updated By</p>
                            <p class="font-medium">@Model.UpdatedBy</p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500">Last Updated At</p>
                            <p class="font-medium">@Model.UpdatedAt?.ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Validation Guide -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Validation Rules</h3>
                <ul class="space-y-3 text-sm text-secondary-600">
                    <li class="flex items-start">
                        <i class="material-icons text-blue-600 mr-2">check_circle</i>
                        <span>Times must be in 24-hour format (HH:mm)</span>
                    </li>
                    <li class="flex items-start">
                        <i class="material-icons text-blue-600 mr-2">check_circle</i>
                        <span>End time must be after start time</span>
                    </li>
                    <li class="flex items-start">
                        <i class="material-icons text-blue-600 mr-2">check_circle</i>
                        <span>No time overlaps between periods</span>
                    </li>
                    <li class="flex items-start">
                        <i class="material-icons text-blue-600 mr-2">check_circle</i>
                        <span>No gaps between consecutive periods</span>
                    </li>
                    <li class="flex items-start">
                        <i class="material-icons text-blue-600 mr-2">check_circle</i>
                        <span>At least one period is required</span>
                    </li>
                </ul>
            </div>

            <!-- Configuration Summary -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Configuration Summary</h3>
                <div class="space-y-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">view_timeline</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Periods</p>
                            <p class="text-xl font-semibold" id="totalPeriods">0</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">class</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Regular Periods</p>
                            <p class="text-xl font-semibold text-green-600" id="regularPeriods">0</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="p-3 bg-orange-100 rounded-lg">
                            <i class="material-icons text-orange-600 text-xl">coffee</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Break Periods</p>
                            <p class="text-xl font-semibold text-orange-600" id="breakPeriods">0</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Period Modal -->
<div id="deletePeriodModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-md">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" onclick="hideDeletePeriodModal()">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <div class="space-y-4">
                        <div class="flex items-center text-red-600 mb-4">
                            <i class="material-icons mr-2">error_outline</i>
                            <p class="text-lg font-medium">Delete Period</p>
                        </div>

                        <p class="text-gray-700">Are you sure you want to delete this period? This action cannot be undone.</p>

                        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mt-4">
                            <p class="text-gray-700 font-medium">Period Details:</p>
                            <p class="text-secondary-600 mt-2">
                                <span class="font-medium">Period Number:</span>
                                <span id="deletePeriodNumber" class="ml-2"></span>
                            </p>
                            <p class="text-secondary-600">
                                <span class="font-medium">Time:</span>
                                <span id="deletePeriodTime" class="ml-2"></span>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button"
                            class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center"
                            onclick="hideDeletePeriodModal()">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button"
                            id="confirmDeletePeriod"
                            class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Initialize periods data from model
        const initialPeriodsData = @Html.Raw(Model.PeriodsData ?? "[]");
    </script>
    <script type="module" src="~/js/timeSlotConfig.js"></script>
}