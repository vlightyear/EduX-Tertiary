@model SIS.Models.Registration.Grade

@{
    ViewData["Title"] = "Create Grade";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow p-3 mb-5 bg-white rounded">
                <div class="card-body" style="height: 75vh;">
                    <h2 class="text-center mb-4">Create Grade</h2>

                    <form asp-action="CreateGrade" method="post" enctype="multipart/form-data">
                        <div class="form-group">
                            <label>Select Mode:</label>
                            <div>
                                <input type="radio" id="single" name="mode" value="single" checked />
                                <label for="single">Single Grade</label>
                            </div>
                            <div>
                                <input type="radio" id="bulk" name="mode" value="bulk" />
                                <label for="bulk">Bulk Upload</label>
                            </div>
                        </div>

                        <!-- Single Grade Fields -->
                        <div id="singleGradeFields">
                            <div class="form-group">
                                <label asp-for="GradeValue">Grade Value:</label>
                                <input asp-for="GradeValue" class="form-control" placeholder="(like One, Two, Three)" />
                                <span asp-validation-for="GradeValue" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="GradePoint">Grade Point:</label>
                                <input asp-for="GradePoint" class="form-control" placeholder="(like 1.0, 2.0, 3.0)" />
                                <span asp-validation-for="GradePoint" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Code">Grade Code:</label>
                                <input asp-for="Code" class="form-control" placeholder="(like A+, A, B+, B)" />
                                <span asp-validation-for="Code" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Description">Grade Description:</label>
                                <input asp-for="Description" class="form-control" placeholder="(like Distinction, Merit, Credit)" />
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Bulk Upload Field -->
                        <div id="bulkUploadField" style="display: none;">
                            <div class="form-group">
                                <label for="fileUpload">Upload CSV/Excel File:</label>
                                <input type="file" id="fileUpload" name="fileUpload" class="form-control" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block mt-4">Submit</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('input[name="mode"]').forEach((radio) => {
        radio.addEventListener('change', function () {
            if (this.value === 'single') {
                document.getElementById('singleGradeFields').style.display = 'block';
                document.getElementById('bulkUploadField').style.display = 'none';
            } else {
                document.getElementById('singleGradeFields').style.display = 'none';
                document.getElementById('bulkUploadField').style.display = 'block';
            }
        });
    });
</script>
