@using SIS.Models.Fees
@model FeeConfiguration

<div class="row mt-2">
    <div class="col-9 me-0 ms-0">
        <div class="pt-4 row" style="height: 8vh;">
            <div class="col-10 d-flex text-dark align-items-center justify-content-start">
                <h3>
                    <i class="material-icons">edit</i>
                    Update Fee Configuration
                </h3>
            </div>
            <div class="col-2 d-flex justify-content-end">
                <a asp-controller="Admin" asp-action="FeeConfigurations" class="btn btn-secondary rounded-2 d-flex align-items-center justify-content-center" style="height: 40px; padding-top: 8px;">
                    <i class="material-icons me-1">arrow_back</i> Back
                </a>
            </div>
        </div>

        <div class="card shadow mt-2 ml-0" style="height: 78vh; overflow: auto;">
            <div class="card-body">
                <form asp-action="UpdateFeeConfiguration" method="post">
                    <!-- Hidden field for FeeConfiguration Id -->
                    <input type="hidden" asp-for="Id" />
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="AcademicYearId" class="form-label">Academic Year</label>
                            <select asp-for="AcademicYearId" class="form-control" asp-items="ViewBag.AcademicYears">
                                <option value="">-- Select Academic Year --</option>
                            </select>
                            <span asp-validation-for="AcademicYearId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SchoolId" class="form-label">School</label>
                            <select asp-for="SchoolId" class="form-control" asp-items="ViewBag.Schools">
                                <option value="">-- Select School --</option>
                            </select>
                            <span asp-validation-for="SchoolId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="ProgrammeId" class="form-label">Programme</label>
                            <select asp-for="ProgrammeId" class="form-control" asp-items="ViewBag.Programmes">
                                <option value="">-- Select Programme --</option>
                            </select>
                            <span asp-validation-for="ProgrammeId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ModeOfStudyId" class="form-label">Mode of Study</label>
                            <select asp-for="ModeOfStudyId" class="form-control" asp-items="ViewBag.ModesOfStudy">
                                <option value="">-- Select Mode of Study --</option>
                            </select>
                            <span asp-validation-for="ModeOfStudyId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="YearOfStudy" class="form-label">Year of Study</label>
                            <input asp-for="YearOfStudy" type="number" class="form-control" />
                            <span asp-validation-for="YearOfStudy" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label for="ProgramLevelId">Program Level</label>
                            <select asp-for="ProgramLevelId" class="form-control" asp-items="ViewBag.ProgramLevels">
                                <option value="">-- Select Program Level --</option>
                            </select>
                            <span asp-validation-for="ProgramLevelId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="FeeTypeId" class="form-label">Fee Type</label>
                            <select asp-for="FeeTypeId" class="form-control" asp-items="ViewBag.FeeTypes">
                                <option value="">-- Select Fee Type --</option>
                            </select>
                            <span asp-validation-for="FeeTypeId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label">Amount</label>
                            <input asp-for="Amount" type="number" class="form-control" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="AppliesUniversally" class="form-check-input" type="checkbox" id="appliesUniversally" />
                                <label class="form-check-label" asp-for="AppliesUniversally">
                                    Applies to all students (ignores School, Programme, Mode of Study, Year, and Level filters)
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-4">
                        <div class="col text-end">
                            <button type="submit" class="btn btn-primary d-flex align-items-center justify-content-center" style="float: right;">
                                <i class="material-icons me-1">save</i> Update Fee Configuration
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-3 pt-1 me-0 ms-0">
        <div class="">
            <div class="card p-3 text-dark" style="height: 44vh;">
                <h4>Fee Configuration Summary</h4>
                <div style="height: 2px; background-color: darkgray;"></div>
                <div class="fee-stats">
                    <div class="statistic">
                        <div class="d-flex align-items-center justify-content-start">
                            <i class="material-icons">list</i>
                            <span>Total Fee Configurations</span>
                        </div>
                        <div class="justify-content-end">
                            <h1>10</h1>
                        </div>
                    </div>
                    <div class="statistic">
                        <div class="d-flex align-items-center justify-content-start">
                            <i class="material-icons">category</i>
                            <span>Total Fee Types</span>
                        </div>
                        <div class="justify-content-end">
                            <h1>15</h1>
                        </div>
                    </div>

                    <div class="statistic">
                        <div class="d-flex align-items-center justify-content-start">
                            <i class="material-icons">check_circle</i>
                            <span>Active Configurations</span>
                        </div>
                        <div class="justify-content-end">
                            <h1>7</h1>
                        </div>
                    </div>

                    <div class="statistic">
                        <div class="d-flex align-items-center justify-content-start">
                            <i class="material-icons">pause_circle</i>
                            <span>Inactive Configurations</span>
                        </div>
                        <div class="justify-content-end">
                            <h1>3</h1>
                        </div>
                    </div>

                    <div class="statistic">
                        <div class="d-flex align-items-center justify-content-start">
                            <i class="material-icons">assignment_late</i>
                            <span>Pending Configurations</span>
                        </div>
                        <div class="justify-content-end">
                            <h1>2</h1>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-white shadow-lg p-2 mt-2" style="height: 41vh; border-radius: 5px;">
                <h4>Fee Summary Chart</h4>
                <div style="height: 2px; background-color: darkgray;"></div>
                <div class="d-flex align-items-center justify-content-center pt-3" id="fee-summary-chart"></div>
            </div>
        </div>
    </div>
</div>

<script type="module" src="~/js/create_fee_config.js"></script>