                        <input type="hidden" id="updateId" name="Id" />

                        <div class="space-y-6">
                            <!-- Fee Type Name -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="updateName"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                       placeholder=" " required />
                                <label for="updateName"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Fee Type Name *
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="updateDescription" rows="3"
                                          class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                          placeholder=" "></textarea>
                                <label for="updateDescription"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- Applicable For -->
                            <div class="relative z-0 w-full group">
                                <select name="ApplicableFor" id="updateApplicableFor"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                        required>
                                    <option value="">Select Applicable For</option>
                                    <option value="Student">Student</option>
                                    <option value="Candidate">Candidate</option>
                                </select>
                                <label for="updateApplicableFor"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Applicable For *
                                </label>
                            </div>

                            <!-- Is Active -->
                            <div class="flex items-center p-3 bg-gray-50 rounded-lg">
                                <input type="checkbox" id="updateIsActive" name="IsActive" value="true"
                                       class="w-4 h-4 text-secondary-600 border-gray-300 rounded focus:ring-secondary-500" />
                                <label for="updateIsActive" class="ml-3 text-sm text-gray-700 font-medium">Active Status</label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmUpdate" class="px-4 py-2 bg-secondary-600 text-white rounded-lg hover:bg-secondary-700 transition-colors flex items-center shadow-md">
                        <i class="material-icons mr-1">save</i>Update
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Fee Type Modal -->
<div id="deleteFeeTypeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-lg border border-gray-200">
                <!-- Modal Header -->
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-red-200 transition-colors" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="deleteFeeTypeForm" method="post" asp-controller="Admin" asp-action="DeleteFeeType">
                        <input type="hidden" id="deleteId" name="Id" />
                        @Html.AntiForgeryToken()

                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-3 text-2xl">error_outline</i>
                                <p class="text-lg font-semibold">Delete Fee Type</p>
                            </div>

                            <p class="text-gray-700 text-base">Are you sure you want to delete this fee type?</p>

                            <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
                                <p class="text-gray-700 font-semibold mb-2 flex items-center">
                                    <i class="material-icons text-amber-600 mr-2">info</i>
                                    Fee Type Details:
                                </p>
                                <p class="text-secondary-600">
                                    <span class="font-medium">Fee Type Name:</span>
                                    <span id="deleteName" class="ml-2 font-semibold text-secondary-800"></span>
                                </p>
                            </div>

                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-lg">warning</i>
                                    <p class="text-sm font-medium">This action cannot be undone.</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmDelete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center shadow-md">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Modal elements
            const createFeeTypeModal = document.getElementById('createFeeTypeModal');
            const updateFeeTypeModal = document.getElementById('updateFeeTypeModal');
            const deleteFeeTypeModal = document.getElementById('deleteFeeTypeModal');

            // Form elements
            const createFeeTypeForm = document.getElementById('createFeeTypeForm');
            const updateFeeTypeForm = document.getElementById('updateFeeTypeForm');
            const deleteFeeTypeForm = document.getElementById('deleteFeeTypeForm');

            // Button elements
            const confirmCreateBtn = document.getElementById('confirmCreate');
            const confirmUpdateBtn = document.getElementById('confirmUpdate');
            const confirmDeleteBtn = document.getElementById('confirmDelete');

            // Modal handling functions
            function showModal(modalElement) {
                modalElement.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            function hideModal(modalElement) {
                modalElement.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }

            // Close modal when clicking outside
            function setupModalCloseHandlers(modalElement) {
                modalElement.addEventListener('click', (e) => {
                    if (e.target === modalElement) {
                        hideModal(modalElement);
                    }
                });

                const closeButtons = modalElement.querySelectorAll('[data-bs-dismiss="modal"]');
                closeButtons.forEach(button => {
                    button.addEventListener('click', () => hideModal(modalElement));
                });
            }

            // Setup close handlers for all modals
            [createFeeTypeModal, updateFeeTypeModal, deleteFeeTypeModal].forEach(setupModalCloseHandlers);

            // Show create modal
            window.showCreateFeeTypeModal = function() {
                createFeeTypeForm.reset();
                showModal(createFeeTypeModal);
            };

            // Show update modal
            window.showUpdateFeeTypeModal = async function(id) {
                try {
                    const response = await fetch(`/Admin/GetFeeType/${id}`);
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    const feeType = await response.json();

                    document.getElementById('updateId').value = feeType.id;
                    document.getElementById('updateName').value = feeType.name;
                    document.getElementById('updateDescription').value = feeType.description;
                    document.getElementById('updateApplicableFor').value = feeType.applicableFor;
                    document.getElementById('updateIsActive').checked = feeType.isActive;

                    showModal(updateFeeTypeModal);
                } catch (error) {
                    console.error('Error:', error);
                    alert('Error fetching fee type details');
                }
            };

            // Show delete modal
            window.showDeleteFeeTypeModal = function(id, name) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteName').textContent = name;
                showModal(deleteFeeTypeModal);
            };

            // Handle form submissions
            confirmCreateBtn.addEventListener('click', function() {
                if (createFeeTypeForm.checkValidity()) {
                    createFeeTypeForm.submit();
                } else {
                    createFeeTypeForm.reportValidity();
                }
            });

            confirmUpdateBtn.addEventListener('click', function() {
                if (updateFeeTypeForm.checkValidity()) {
                    updateFeeTypeForm.submit();
                } else {
                    updateFeeTypeForm.reportValidity();
                }
            });

            confirmDeleteBtn.addEventListener('click', function() {
                deleteFeeTypeForm.submit();
            });

            // Handle Escape key to close modals
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    [createFeeTypeModal, updateFeeTypeModal, deleteFeeTypeModal].forEach(modal => {
                        if (!modal.classList.contains('hidden')) {
                            hideModal(modal);
                        }
                    });
                }
            });

            // Initialize DataTable if simpleDatatables is available
            if (typeof simpleDatatables !== 'undefined') {
                const dataTable = new simpleDatatables.DataTable("#feeTypesTable", {
                    perPage: 10,
                    searchable: true,
                    sortable: true,
                    labels: {
                        placeholder: "Search fee types...",
                        perPage: "Show {select} entries",
                        noRows: "No fee types found",
                        info: "Showing {start} to {end} of {rows} fee types",
                    },
                    classes: {
                        wrapper: "datatable-wrapper",
                        input: "datatable-input px-3 py-2 text-sm border border-gray-300 rounded-lg",
                        selector: "datatable-selector px-3 py-2 text-sm border border-gray-300 rounded-lg",
                        paginationButton: "px-3 py-1 text-sm text-secondary-600 rounded-md transition-colors",
                        paginationButtonActive: "bg-primary-100 text-primary-700",
                        paginationButtonDisabled: "text-gray-400 cursor-not-allowed",
                    }
                });

                // Add custom styles to DataTable elements after initialization
                setTimeout(() => {
                    const searchInput = document.querySelector('.datatable-input');
                    const selector = document.querySelector('.datatable-selector');
                    const paginationButtons = document.querySelectorAll('.datatable-pagination button');

                    if (searchInput) {
                        searchInput.addEventListener('focus', function() {
                            this.classList.add('ring-2', 'ring-primary-500', 'border-primary-500');
                        });
                        searchInput.addEventListener('blur', function() {
                            this.classList.remove('ring-2', 'ring-primary-500', 'border-primary-500');
                        });
                    }

                    if (selector) {
                        selector.addEventListener('focus', function() {
                            this.classList.add('ring-2', 'ring-primary-500', 'border-primary-500');
                        });
                        selector.addEventListener('blur', function() {
                            this.classList.remove('ring-2', 'ring-primary-500', 'border-primary-500');
                        });
                    }

                    paginationButtons.forEach(button => {
                        if (!button.classList.contains('datatable-pagination-active') &&
                            !button.classList.contains('datatable-pagination-disabled')) {
                            button.addEventListener('mouseenter', function() {
                                this.classList.add('bg-primary-50');
                            });
                            button.addEventListener('mouseleave', function() {
                                this.classList.remove('bg-primary-50');
                            });
                        }
                    });
                }, 100);
            }

            // Dynamic data from the model (passed from server)
            const feeTypeCounts = {
                student: @Model?.Count(f => f.ApplicableFor == "Student") ?? 0,
                candidate: @Model?.Count(f => f.ApplicableFor == "Candidate") ?? 0,
                inactive: @Model?.Count(f => !f.IsActive) ?? 0,
                total: @Model?.Count() ?? 0
            };

            // Dynamic chart options with real data
            const chartOptions = {
                series: [
                    feeTypeCounts.student,
                    feeTypeCounts.candidate,
                ],
                chart: {
                    type: 'donut',
                    height: '70%',
                    fontFamily: 'inherit'
                },
                labels: ['Student Fees', 'Candidate Fees'],
                colors: ['#06b6d4', '#10b981'], // Using your system colors
                plotOptions: {
                    pie: {
                        donut: {
                            size: '65%',
                            labels: {
                                show: true,
                                name: {
                                    show: true,
                                    fontSize: '14px',
                                    fontFamily: 'inherit',
                                    fontWeight: 500,
                                    color: '#374151',
                                    offsetY: -4
                                },
                                value: {
                                    show: true,
                                    fontSize: '20px',
                                    fontFamily: 'inherit',
                                    fontWeight: 700,
                                    color: '#111827',
                                    offsetY: 8,
                                    formatter: function(val) {
                                        return val;
                                    }
                                },
                                total: {
                                    show: true,
                                    label: 'Total',
                                    fontSize: '14px',
                                    fontWeight: 500,
                                    color: '#6b7280',
                                    formatter: function(w) {
                                        const total = w.globals.seriesTotals.reduce((a, b) => a + b, 0);
                                        return total;
                                    }
                                }
                            }
                        }
                    }
                },
                dataLabels: {
                    enabled: false
                },
                legend: {
                    show: false
                },
                stroke: {
                    width: 2,
                    colors: ['#ffffff']
                },
                tooltip: {
                    style: {
                        fontSize: '14px',
                        fontFamily: 'inherit'
                    },
                    y: {
                        formatter: function(val, opts) {
                            const label = opts.w.globals.labels[opts.seriesIndex];
                            const percentage = ((val / feeTypeCounts.total) * 100).toFixed(1);
                            return `${val} ${label} (${percentage}%)`;
                        }
                    }
                },
                responsive: [{
                    breakpoint: 480,
                    options: {
                        chart: {
                            height: 200
                        },
                        plotOptions: {
                            pie: {
                                donut: {
                                    labels: {
                                        show: true,
                                        name: {
                                            show: false
                                        },
                                        value: {
                                            show: true,
                                            fontSize: '16px'
                                        },
                                        total: {
                                            show: true,
                                            fontSize: '12px'
                                        }
                                    }
                                }
                            }
                        }
                    }
                }]
            };

            // Render the chart with dynamic data
            if (typeof ApexCharts !== 'undefined') {
                const chart = new ApexCharts(document.querySelector("#fee-distribution-chart"), chartOptions);
                chart.render();
            } else {
                // Fallback if ApexCharts is not available
                document.querySelector("#fee-distribution-chart").innerHTML =
                    '<div class="flex items-center justify-center h-full text-gray-500">' +
                    '<div class="text-center">' +
                    '<i class="material-icons text-4xl mb-2">pie_chart</i>' +
                    '<p>Chart library not loaded</p>' +
                    '</div>' +
                    '</div>';
            }

            // Add loading states to buttons
            function addLoadingState(button) {
                const originalText = button.innerHTML;
                button.disabled = true;
                button.innerHTML = '<i class="material-icons animate-spin mr-2">refresh</i>Processing...';

                return function removeLoadingState() {
                    button.disabled = false;
                    button.innerHTML = originalText;
                };
            }

            // Enhanced form submission with loading states
            confirmCreateBtn.addEventListener('click', function() {
                if (createFeeTypeForm.checkValidity()) {
                    addLoadingState(this);
                    createFeeTypeForm.submit();
                } else {
                    createFeeTypeForm.reportValidity();
                }
            });

            confirmUpdateBtn.addEventListener('click', function() {
                if (updateFeeTypeForm.checkValidity()) {
                    addLoadingState(this);
                    updateFeeTypeForm.submit();
                } else {
                    updateFeeTypeForm.reportValidity();
                }
            });

            confirmDeleteBtn.addEventListener('click', function() {
                addLoadingState(this);
                deleteFeeTypeForm.submit();
            });

        });
    </script>
}