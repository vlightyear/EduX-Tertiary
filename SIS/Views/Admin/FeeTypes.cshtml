@using SIS.Models.Fees
@model IEnumerable<FeeType>

@{
    ViewData["Title"] = "Fee Types";
}

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-primary-800 flex items-center">
            <i class="material-icons mr-2 text-primary-600">payments</i>
            Fee Types Management
        </h1>
        <button type="button"
                class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors flex items-center shadow-md hover:shadow-lg"
                onclick="showCreateFeeTypeModal()">
            <i class="material-icons mr-2">add</i>
            Create Fee Type
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-lg h-full overflow-hidden border border-gray-100">
                <div class="p-4">
                    <table id="feeTypesTable" class="w-full text-sm text-secondary-600">
                        <thead>
                            <tr class="bg-primary-50 border-b border-primary-100">
                                <th class="px-6 py-4 text-left">
                                    <span class="flex items-center text-primary-700 font-semibold">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4 text-left text-primary-700 font-semibold">Name</th>
                                <th class="px-6 py-4 text-left text-primary-700 font-semibold">Description</th>
                                <th class="px-6 py-4 text-left text-primary-700 font-semibold">Applicable For</th>
                                <th class="px-6 py-4 text-left text-primary-700 font-semibold">Status</th>
                                <th class="px-6 py-4 text-left text-primary-700 font-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int index = 1;
                                foreach (var feeType in Model)
                                {
                                    <tr class="border-b border-gray-100 hover:bg-primary-50 transition-colors">
                                        <td class="px-6 py-4 text-secondary-600">@index</td>
                                        <td class="px-6 py-4 font-medium text-gray-900">@feeType.Name</td>
                                        <td class="px-6 py-4 text-gray-700">@feeType.Description</td>
                                        <td class="px-6 py-4">
                                            <span class="px-3 py-1 text-sm @(feeType.ApplicableFor == "Student" ? "bg-primary-100 text-primary-700" : "bg-secondary-100 text-secondary-700") rounded-full font-medium">
                                                @feeType.ApplicableFor
                                            </span>
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (feeType.IsActive)
                                            {
                                                <span class="px-3 py-1 text-sm bg-secondary-100 text-secondary-700 rounded-full font-medium flex items-center w-fit">
                                                    <i class="material-icons text-xs mr-1">check_circle</i>
                                                    Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="px-3 py-1 text-sm bg-red-100 text-red-700 rounded-full font-medium flex items-center w-fit">
                                                    <i class="material-icons text-xs mr-1">cancel</i>
                                                    Inactive
                                                </span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex space-x-2">
                                                <button onclick="showUpdateFeeTypeModal('@feeType.Id')"
                                                        class="inline-flex items-center px-3 py-1.5 text-sm text-primary-700 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors border border-primary-200">
                                                    <i class="material-icons text-sm mr-1">edit</i> Edit
                                                </button>
                                                <button onclick="showDeleteFeeTypeModal('@feeType.Id', '@feeType.Name')"
                                                        class="inline-flex items-center px-3 py-1.5 text-sm text-red-700 bg-red-50 hover:bg-red-100 rounded-lg transition-colors border border-red-200">
                                                    <i class="material-icons text-sm mr-1">delete</i> Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                        <div class="flex flex-col items-center">
                                            <i class="material-icons text-4xl text-gray-300 mb-2">payments</i>
                                            <p class="text-lg font-medium">No fee types found</p>
                                            <p class="text-sm">Create your first fee type to get started</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-100">
                <h3 class="text-lg font-bold text-secondary-800 mb-6 flex items-center">
                    <i class="material-icons text-primary-600 mr-2">analytics</i>
                    Fee Types Summary
                </h3>
                <div class="space-y-4">
                    <!-- Total Fee Types -->
                    <div class="flex items-center p-3 bg-primary-50 rounded-lg border border-primary-100">
                        <div class="p-3 bg-primary-100 rounded-lg">
                            <i class="material-icons text-primary-600 text-xl">payments</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-secondary-600 text-sm font-medium">Total Fee Types</p>
                            <p class="text-2xl font-bold text-primary-700">@Model?.Count()</p>
                        </div>
                    </div>

                    <!-- Active Types -->
                    <div class="flex items-center p-3 bg-secondary-50 rounded-lg border border-secondary-100">
                        <div class="p-3 bg-secondary-100 rounded-lg">
                            <i class="material-icons text-secondary-600 text-xl">check_circle</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-secondary-600 text-sm font-medium">Active Types</p>
                            <p class="text-2xl font-bold text-secondary-700">@Model?.Count(f => f.IsActive)</p>
                        </div>
                    </div>

                    <!-- Student Fee Types -->
                    <div class="flex items-center p-3 bg-blue-50 rounded-lg border border-blue-100"> 
                         <div class="p-3 bg-blue-100 rounded-lg"> 
                            <i class="material-icons text-blue-600 text-xl">person</i> 
                         </div> 
                         <div class="ml-4"> 
                             <p class="text-secondary-600 text-sm font-medium">Student Fee Types</p> 
                             <p class="text-2xl font-bold text-blue-700">@Model?.Count(f => f.ApplicableFor == "Student")</p> 
                         </div> 
                    </div> 

                    <!-- Candidate Fee Types -->
                    @* <div class="flex items-center p-3 bg-orange-50 rounded-lg border border-orange-100"> *@
                    @*     <div class="p-3 bg-orange-100 rounded-lg"> *@
                    @*         <i class="material-icons text-orange-600 text-xl">school</i> *@
                    @*     </div> *@
                    @*     <div class="ml-4"> *@
                    @*         <p class="text-secondary-600 text-sm font-medium">Candidate Fee Types</p> *@
                    @*         <p class="text-2xl font-bold text-orange-700">@Model?.Count(f => f.ApplicableFor == "Candidate")</p> *@
                    @*     </div> *@
                    @* </div> *@
                </div>
            </div>

            <!-- Distribution Chart -->
            <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-100">
                <h3 class="text-lg font-bold text-secondary-800 mb-4 flex items-center">
                    <i class="material-icons text-primary-600 mr-2">pie_chart</i>
                    Fee Types Distribution
                </h3>
                <div id="fee-distribution-chart" class="h-64"></div>

                <!-- Legend -->
                <div class="mt-4 space-y-2">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="w-3 h-3 bg-primary-500 rounded-full mr-2"></div>
                            <span class="text-sm text-secondary-600">Student Fees</span>
                        </div>
                        <span class="text-sm font-medium text-secondary-800">@Model?.Count(f => f.ApplicableFor == "Student")</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="w-3 h-3 bg-secondary-500 rounded-full mr-2"></div>
                            <span class="text-sm text-secondary-600">Candidate Fees</span>
                        </div>
                        <span class="text-sm font-medium text-secondary-800">@Model?.Count(f => f.ApplicableFor == "Candidate")</span>
                    </div>
                    @* <div class="flex items-center justify-between"> *@
                    @*     <div class="flex items-center"> *@
                    @*         <div class="w-3 h-3 bg-red-500 rounded-full mr-2"></div> *@
                    @*         <span class="text-sm text-secondary-600">Inactive Fees</span> *@
                    @*     </div> *@
                    @*     <span class="text-sm font-medium text-secondary-800">@Model?.Count(f => !f.IsActive)</span> *@
                    @* </div> *@
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Fee Type Modal -->
<div id="createFeeTypeModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-2xl border border-gray-200">
                <!-- Modal Header -->
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-xl flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">add</i>
                        Create New Fee Type
                    </h3>
                    <button type="button" class="text-white hover:text-primary-200 transition-colors" data-bs-dismiss="modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <form id="createFeeTypeForm" method="post" asp-controller="Admin" asp-action="CreateFeeType">
                        @Html.AntiForgeryToken()
                        <div class="space-y-6">
                            <!-- Fee Type Name -->
                            <div class="relative z-0 w-full group">
                                <input type="text" name="Name" id="Name"
                                       class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                       placeholder=" " required />
                                <label for="Name"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Fee Type Name *
                                </label>
                            </div>

                            <!-- Description -->
                            <div class="relative z-0 w-full group">
                                <textarea name="Description" id="Description" rows="3"
                                          class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                          placeholder=" "></textarea>
                                <label for="Description"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Description
                                </label>
                            </div>

                            <!-- Applicable For -->
                            <div class="relative z-0 w-full group">
                                <select name="ApplicableFor" id="ApplicableFor"
                                        class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                        required>
                                    <option value="">Select Applicable For</option>
                                    <option value="Student">Student</option>
                                    <option value="Candidate">Candidate</option>
                                </select>
                                <label for="ApplicableFor"
                                       class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                    Applicable For *
                                </label>
                            </div>

                            <!-- Is Active -->
                            <div class="flex items-center p-3 bg-gray-50 rounded-lg">
                                <input type="checkbox" id="IsActive" name="IsActive" value="true"
                                       class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" checked />
                                <label for="IsActive" class="ml-3 text-sm text-gray-700 font-medium">Active Status</label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end space-x-3">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300" data-bs-dismiss="modal">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" id="confirmCreate" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors flex items-center shadow-md">
                        <i class="material-icons mr-1">save</i>Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Fee Type Modal -->
