        document.getElementById('debitNoteForm').addEventListener('submit', function(e) {
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="material-icons animate-spin mr-2">refresh</i>Processing...';
        });

        async function loadDebitNotesList() {
            const searchTerm = document.getElementById('searchBox').value;
            const startDate = document.getElementById('dateStart').value;
            const endDate = document.getElementById('dateEnd').value;
            const status = document.getElementById('statusBox').value;

            const params = new URLSearchParams({
                pageNumber: currentPage,
                pageSize: currentPageSize,
                searchTerm: searchTerm || '',
                startDate: startDate || '',
                endDate: endDate || '',
                status: status || ''
            });

            try {
                const response = await fetch(`/Admin/GetDebitNotesList?${params.toString()}`);
                const data = await response.json();
                displayDebitNotesList(data);
                updatePagination(data);
            } catch (error) {
                console.error('Error loading debit notes:', error);
            }
        }

        function displayDebitNotesList(data) {
            const tbody = document.getElementById('debitNoteTableBody');

            if (!data.items || data.items.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" class="px-6 py-8 text-center text-gray-500"><i class="material-icons text-4xl text-gray-300 mb-2">inbox</i><p>No debit notes found</p></td></tr>';
                document.getElementById('countText').textContent = 'No records';
                return;
            }

            tbody.innerHTML = data.items.map(i => {
                const statusClass = i.status === 'Paid' ? 'bg-green-100 text-green-800' : 
                                   i.status === 'Pending' ? 'bg-yellow-100 text-yellow-800' : 
                                   'bg-gray-100 text-gray-800';
                
                return `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <div>
                            <div class="font-medium">${new Date(i.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
                            <div class="text-gray-500 text-xs">${new Date(i.createdAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}</div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <div>
                            <div class="font-medium">${new Date(i.createdDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 py-1 text-xs font-mono bg-blue-100 text-blue-800 rounded">${i.invoiceReference}</span>
                        ${i.batchReference ? `<div class="text-xs text-blue-600 mt-1 flex items-center"><i class="material-icons text-xs mr-1">group</i>${i.batchReference}</div>` : ''}
                    </td>
                    <td class="px-6 py-4">
                        <div class="text-sm">
                            <div class="font-medium text-gray-900">${i.studentName || 'N/A'}</div>
                            <div class="text-gray-500">${i.studentNumber}</div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="text-sm font-semibold text-blue-600">K ${parseFloat(i.totalAmount).toFixed(2)}</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        ${i.academicYear}
                        ${i.semester ? `<span class="text-xs text-gray-500"> (S${i.semester})</span>` : ''}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 py-1 text-xs font-medium rounded ${statusClass}">${i.status}</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                        <div class="flex gap-2">
                            <button onclick='printDebitNote(${JSON.stringify({
                                studentName: i.studentName,
                                studentNumber: i.studentNumber,
                                amount: i.totalAmount,
                                reference: i.invoiceReference,
                                invoiceId: i.id,
                                reason: i.description,
                                date: i.createdDate,
                                postedBy: i.createdBy,
                                isDebitNote: true,
                                semester: i.semester
                            })})' class="inline-flex items-center px-3 py-1 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                                <i class="material-icons text-sm mr-1">print</i>
                                Print
                            </button>
                        </div>
                    </td>
                </tr>
            `}).join('');

            document.getElementById('countText').textContent =
                `Showing ${((currentPage - 1) * currentPageSize) + 1} to ${Math.min(currentPage * currentPageSize, data.totalCount)} of ${data.totalCount} records`;
        }

        function updatePagination(data) {
            document.getElementById('paginationInfo').textContent = `Page ${data.pageNumber} of ${data.totalPages}`;
            document.getElementById('prevBtn').disabled = !data.hasPreviousPage;
            document.getElementById('nextBtn').disabled = !data.hasNextPage;
        }

        function goToPrevPage() {
            if (currentPage > 1) {
                currentPage--;
                loadDebitNotesList();
            }
        }

        function goToNextPage() {
            currentPage++;
            loadDebitNotesList();
        }

        function changePageSize() {
            currentPageSize = parseInt(document.getElementById('pageSizeBox').value);
            currentPage = 1;
            loadDebitNotesList();
        }

        function applyFilters() {
            currentPage = 1;
            loadDebitNotesList();
        }

        function clearFilters() {
            document.getElementById('searchBox').value = '';
            document.getElementById('statusBox').value = '';
            setTodayDate();
            currentPage = 1;
            loadDebitNotesList();
        }
    </script>
}
