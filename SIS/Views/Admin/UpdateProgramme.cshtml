@model SIS.Models.Admin.Programme

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2 text-primary-600">edit</i>
            Update Programme
        </h1>
        <a asp-controller="Admin" asp-action="Programmes"
           class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center shadow-md hover:shadow-lg">
            <i class="material-icons mr-2">arrow_back</i>
            Back
        </a>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Form Section (3/4 width) -->
        <div class="w-full">
            <div class="bg-white rounded-lg shadow-lg h-full overflow-auto border border-gray-100">
                <div class="p-6">
                    <form asp-action="UpdateProgramme" method="post" class="space-y-6">
                        @Html.AntiForgeryToken()
                        <input asp-for="Id" type="hidden" />

                        <!-- Basic Information and Programme Details -->
                        <div class="grid grid-cols-2 gap-6">
                            <!-- Basic Information -->
                            <div class="bg-white rounded-lg shadow-md p-6 border border-gray-100">
                                <h2 class="text-lg font-bold text-secondary-800 mb-4 flex items-center">
                                    <i class="material-icons text-primary-600 mr-2">info</i>
                                    Basic Information
                                </h2>

                                <div class="space-y-4">
                                    <div class="relative z-0 w-full group">
                                        <input asp-for="Name"
                                               class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                               placeholder=" " required />
                                        <label asp-for="Name"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Programme Name *
                                        </label>
                                        <span asp-validation-for="Name" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>

                                    <div class="relative z-0 w-full group">
                                        <textarea asp-for="Description" rows="3"
                                                  class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer resize-none"
                                                  placeholder=" " required></textarea>
                                        <label asp-for="Description"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Programme Description *
                                        </label>
                                        <span asp-validation-for="Description" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>

                                    <div class="relative z-0 w-full group">
                                        <select asp-for="DepartmentId" asp-items="ViewBag.DepartmentId"
                                                class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-primary-600 peer"
                                                required>
                                            <option value="" disabled></option>
                                        </select>
                                        <label asp-for="DepartmentId"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-primary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Department *
                                        </label>
                                        <span asp-validation-for="DepartmentId" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Programme Details -->
                            <div class="bg-white rounded-lg shadow-md p-6 border border-gray-100">
                                <h2 class="text-lg font-bold text-secondary-800 mb-4 flex items-center">
                                    <i class="material-icons text-secondary-600 mr-2">assignment</i>
                                    Programme Details
                                </h2>

                                <div class="space-y-4">
                                    <div class="relative z-0 w-full group">
                                        <input asp-for="MinimumPointsTop5Subjects" type="number" min="0" max="100"
                                               class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                               placeholder=" " required />
                                        <label asp-for="MinimumPointsTop5Subjects"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Minimum Points (Top 5) *
                                        </label>
                                        <span asp-validation-for="MinimumPointsTop5Subjects" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>

                                    <div class="relative z-0 w-full group">
                                        <input asp-for="DurationYears" type="number" min="1" max="10"
                                               class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                               placeholder=" " required />
                                        <label asp-for="DurationYears"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Duration (Years) *
                                        </label>
                                        <span asp-validation-for="DurationYears" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>

                                    <div class="relative z-0 w-full group">
                                        <input asp-for="EnrollmentCount" type="number" min="0"
                                               class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                               placeholder=" " />
                                        <label asp-for="EnrollmentCount"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Enrollment Count
                                        </label>
                                        <span asp-validation-for="EnrollmentCount" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>

                                    <div class="relative z-0 w-full group">
                                        <select asp-for="ModeOfStudyId" asp-items="ViewBag.ModeOfStudyId"
                                                class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-secondary-600 peer"
                                                required>
                                            <option value="" disabled></option>
                                        </select>
                                        <label asp-for="ModeOfStudyId"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-secondary-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Mode of Study *
                                        </label>
                                        <span asp-validation-for="ModeOfStudyId" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Programme Settings and Financial Codes -->
                        <div class="grid grid-cols-1 gap-6">
                            <div class="bg-white rounded-lg shadow-md p-6 border border-gray-100">
                                <h2 class="text-lg font-bold text-secondary-800 mb-4 flex items-center">
                                    <i class="material-icons text-blue-600 mr-2">settings</i>
                                    Programme Settings
                                </h2>

                                <div class="space-y-4">
                                    <div class="relative z-0 w-full group">
                                        <select asp-for="ProgrammeLevelId" asp-items="ViewBag.ProgrammeLevelId"
                                                class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                                required>
                                            <option value="" disabled></option>
                                        </select>
                                        <label asp-for="ProgrammeLevelId"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Programme Level *
                                        </label>
                                        <span asp-validation-for="ProgrammeLevelId" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>

                                    <div class="relative z-0 w-full group">
                                        <select asp-for="CoordinatorId" asp-items="ViewBag.CoordinatorId"
                                                class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer"
                                                required>
                                            <option value="" disabled></option>
                                        </select>
                                        <label asp-for="CoordinatorId"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Programme Coordinator *
                                        </label>
                                        <span asp-validation-for="CoordinatorId" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>


                                    <!-- Non-Quota Programme Checkbox -->
                                    <div class="flex items-center p-3 bg-orange-50 rounded-lg border border-orange-100">
                                        <input asp-for="IsNonQuota" type="checkbox" id="IsNonQuota"
                                               class="w-4 h-4 text-orange-600 border-gray-300 rounded focus:ring-orange-500" />
                                        <label asp-for="IsNonQuota" class="ml-3 text-sm text-gray-700 font-medium">
                                            Non-Quota Programme
                                        </label>
                                        <div class="ml-auto">
                                            <div class="relative group">
                                                <i class="material-icons text-orange-500 text-sm cursor-help">help_outline</i>
                                                <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-3 py-2 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap z-10">
                                                    Check if this is a Non-Quota programme
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <span asp-validation-for="IsNonQuota" class="text-sm text-red-600"></span>

                                    <!-- Associated NQ Programme Dropdown -->
                                    <div id="associatedNQContainer" class="relative z-0 w-full group">
                                        <select asp-for="AssociatedNQProgrammeId" asp-items="ViewBag.AssociatedNQProgrammeId"
                                                class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 peer">
                                            <option value="">-- Select Associated NQ Programme --</option>
                                        </select>
                                        <label asp-for="AssociatedNQProgrammeId"
                                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-blue-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                            Associated NQ Programme
                                        </label>
                                        <span asp-validation-for="AssociatedNQProgrammeId" class="text-sm text-red-600 mt-1 block"></span>
                                    </div>


                                    <div class="flex items-center p-3 bg-blue-50 rounded-lg border border-blue-100">
                                        <input asp-for="IsSemesterBased" type="checkbox" id="IsSemesterBased"
                                               class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                                        <label asp-for="IsSemesterBased" class="ml-3 text-sm text-gray-700 font-medium">
                                            Semester Based Programme
                                        </label>
                                    </div>
                                    <span asp-validation-for="IsSemesterBased" class="text-sm text-red-600"></span>
                                </div>
                            </div>

                           
                        </div>

                        <!-- Yearly/Semester Course Requirements -->
                        <div class="bg-white rounded-lg shadow-md p-6 border border-gray-100">
                            <h2 class="text-lg font-bold text-secondary-800 mb-4 flex items-center">
                                <i class="material-icons text-purple-600 mr-2">list</i>
                                <span id="requirementsTitle">@(Model.IsSemesterBased ? "Semester Course Requirements" : "Yearly Course Requirements")</span>
                            </h2>

                            <div id="yearlyRequirementsContainer" class="space-y-4">
                                <!-- Dynamic fields will be added here -->
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <div class="flex justify-end space-x-3">
                            <a asp-controller="Admin" asp-action="Programmes"
                               class="px-6 py-2 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300">
                                <i class="material-icons mr-2">close</i>Cancel
                            </a>
                            <button type="submit"
                                    class="px-6 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-900 transition-colors flex items-center shadow-md hover:shadow-lg">
                                <i class="material-icons mr-2">update</i>Update Programme
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/apexcharts/3.44.0/apexcharts.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const durationInput = document.getElementById('DurationYears');
            const requirementsContainer = document.getElementById('yearlyRequirementsContainer');
            const semesterCheckbox = document.getElementById('IsSemesterBased');
            const requirementsTitle = document.getElementById('requirementsTitle');

            // Get existing data from server
            const existingYearlyRequirements = @Html.Raw(Json.Serialize(ViewBag.YearlyRequirements ?? new Dictionary<string, int>()));
            const existingSemesterRequirements = @Html.Raw(Json.Serialize(ViewBag.SemesterRequirements ?? new Dictionary<string, object>()));

            console.log('Existing Yearly Requirements:', existingYearlyRequirements);
            console.log('Existing Semester Requirements:', existingSemesterRequirements);
            console.log('Is Semester Based:', semesterCheckbox.checked);
            console.log('Duration Years:', durationInput.value);

            // Initial setup - populate fields with existing data
            updateYearlyRequirements(durationInput.value || 0, true);

            // Listen for changes to duration
            durationInput.addEventListener('change', function() {
                updateYearlyRequirements(this.value, false);
            });

            durationInput.addEventListener('input', function() {
                updateYearlyRequirements(this.value, false);
            });

            // Listen for changes to semester checkbox
            semesterCheckbox.addEventListener('change', function() {
                updateRequirementsTitle();
                updateYearlyRequirements(durationInput.value || 0, false);
            });

            function updateRequirementsTitle() {
                if (semesterCheckbox.checked) {
                    requirementsTitle.textContent = 'Semester Course Requirements';
                } else {
                    requirementsTitle.textContent = 'Yearly Course Requirements';
                }
            }

            function updateYearlyRequirements(years, isInitialLoad = false) {
                // Clear existing fields
                requirementsContainer.innerHTML = '';

                if (years <= 0) return;

                const isSemesterBased = semesterCheckbox.checked;

                // Create fields for each year
                for (let i = 1; i <= years; i++) {
                    const yearDiv = document.createElement('div');
                    yearDiv.className = 'bg-gray-50 p-4 rounded-lg border border-gray-200';
                    const yearKey = `Year${i}`;

                    if (isSemesterBased) {
                        // Get existing semester data - fix property name casing
                        let semester1Value = 0;
                        let semester2Value = 0;
                        let totalValue = 0;

                        if (isInitialLoad && existingSemesterRequirements[yearKey]) {
                            const existingSemester = existingSemesterRequirements[yearKey];
                            // Use lowercase property names as they come from server
                            semester1Value = existingSemester.semester1 || existingSemester.Semester1 || 0;
                            semester2Value = existingSemester.semester2 || existingSemester.Semester2 || 0;
                            totalValue = existingSemester.total || existingSemester.Total || 0;
                        }

                        console.log(`Year ${i} - Semester 1: ${semester1Value}, Semester 2: ${semester2Value}, Total: ${totalValue}`);

                        // Use simple labels instead of floating labels to avoid overlap
                        yearDiv.innerHTML = `
                            <h4 class="font-semibold text-secondary-800 mb-3 flex items-center">
                                <i class="material-icons text-purple-600 mr-2 text-sm">school</i>
                                Year ${i}
                            </h4>
                            <div class="grid grid-cols-3 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Semester 1</label>
                                    <input
                                        type="number"
                                        name="Semester1_Year${i}"
                                        id="Semester1_Year${i}"
                                        class="semester-input w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-purple-500 focus:border-purple-500"
                                        placeholder="0"
                                        min="0"
                                        data-year="${i}"
                                        data-semester="1"
                                    />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Semester 2</label>
                                    <input
                                        type="number"
                                        name="Semester2_Year${i}"
                                        id="Semester2_Year${i}"
                                        class="semester-input w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-purple-500 focus:border-purple-500"
                                        placeholder="0"
                                        min="0"
                                        data-year="${i}"
                                        data-semester="2"
                                    />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Total Courses</label>
                                    <input
                                        type="number"
                                        id="Total_Year${i}"
                                        class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-gray-100"
                                        placeholder="0"
                                        readonly
                                    />
                                </div>
                            </div>
                            <p class="text-xs text-gray-500 mt-2 flex items-center">
                                <i class="material-icons text-xs mr-1">info</i>
                                Total courses will be calculated automatically
                            </p>
                        `;
                    } else {
                        // Get existing yearly data
                        let existingValue = 0;

                        if (isInitialLoad && existingYearlyRequirements[yearKey]) {
                            existingValue = existingYearlyRequirements[yearKey];
                        }

                        console.log(`Year ${i} - Yearly Value: ${existingValue}`);

                        // Use simple labels instead of floating labels
                        yearDiv.innerHTML = `
                            <div class="flex items-center space-x-4">
                                <div class="w-1/3">
                                    <h4 class="font-semibold text-secondary-800 flex items-center">
                                        <i class="material-icons text-purple-600 mr-2 text-sm">school</i>
                                        Year ${i}
                                    </h4>
                                </div>
                                <div class="w-2/3">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Total Required Courses</label>
                                    <input
                                        type="number"
                                        name="YearlyRequirements_Year${i}"
                                        id="YearlyRequirements_Year${i}"
                                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-purple-500 focus:border-purple-500"
                                        placeholder="0"
                                        min="0"
                                    />
                                    <p class="text-xs text-gray-500 mt-1">Enter the total number of courses required for this year</p>
                                </div>
                            </div>
                        `;
                    }

                    requirementsContainer.appendChild(yearDiv);

                    // Set values after DOM elements are created
                    if (isSemesterBased) {
                        const sem1Input = document.getElementById(`Semester1_Year${i}`);
                        const sem2Input = document.getElementById(`Semester2_Year${i}`);
                        const totalInput = document.getElementById(`Total_Year${i}`);

                        if (sem1Input && isInitialLoad && existingSemesterRequirements[yearKey]) {
                            const existingSemester = existingSemesterRequirements[yearKey];
                            // Use lowercase property names
                            sem1Input.value = existingSemester.semester1 || existingSemester.Semester1 || 0;
                            sem2Input.value = existingSemester.semester2 || existingSemester.Semester2 || 0;
                            totalInput.value = existingSemester.total || existingSemester.Total || 0;

                            console.log(`Setting values - Year ${i}: Sem1=${sem1Input.value}, Sem2=${sem2Input.value}, Total=${totalInput.value}`);
                        }
                    } else {
                        const yearlyInput = document.getElementById(`YearlyRequirements_Year${i}`);
                        if (yearlyInput && isInitialLoad && existingYearlyRequirements[yearKey]) {
                            yearlyInput.value = existingYearlyRequirements[yearKey];
                            console.log(`Setting yearly value - Year ${i}: ${yearlyInput.value}`);
                        }
                    }
                }

                // Add event listeners for semester calculations
                if (isSemesterBased) {
                    const semesterInputs = document.querySelectorAll('.semester-input');
                    semesterInputs.forEach(input => {
                        input.addEventListener('input', calculateTotal);
                        input.addEventListener('blur', calculateTotal);
                    });
                }
            }

            function calculateTotal(event) {
                const year = event.target.dataset.year;
                const semester1Input = document.getElementById(`Semester1_Year${year}`);
                const semester2Input = document.getElementById(`Semester2_Year${year}`);
                const totalInput = document.getElementById(`Total_Year${year}`);

                if (semester1Input && semester2Input && totalInput) {
                    const semester1 = parseInt(semester1Input.value) || 0;
                    const semester2 = parseInt(semester2Input.value) || 0;
                    const total = semester1 + semester2;

                    totalInput.value = total;
                }
            }


            // NEW: Handle Non-Quota Programme checkbox logic
            const isNonQuotaCheckbox = document.getElementById('IsNonQuota');
            const associatedNQContainer = document.getElementById('associatedNQContainer');

            // Initialize visibility on page load
            toggleAssociatedNQField();

            // Listen for changes to Non-Quota checkbox
            isNonQuotaCheckbox.addEventListener('change', toggleAssociatedNQField);

            function toggleAssociatedNQField() {
                if (isNonQuotaCheckbox.checked) {
                    // If this IS a Non-Quota programme, hide the associated field
                    associatedNQContainer.style.display = 'none';
                    // Clear the associated programme selection
                    const associatedSelect = document.querySelector('#AssociatedNQProgrammeId');
                    if (associatedSelect) {
                        associatedSelect.value = '';
                    }
                } else {
                    // If this is a regular programme, show the associated field
                    associatedNQContainer.style.display = 'block';
                }
            }

            // Chart initialization with improved colors
            const chartData = @Html.Raw(Json.Serialize(ViewBag.ChartData ?? new List<object>()));
            const series = chartData.map(item => item.count);
            const labels = chartData.map(item => item.level);

            if (series.length === 0) {
                series.push(1);
                labels.push('No Data');
            }

            // System-friendly color palette
            const systemColors = [
                '#4F46E5', // Primary - Indigo
                '#10B981', // Secondary - Emerald
                '#F59E0B', // Amber
                '#EF4444', // Red
                '#8B5CF6', // Purple
                '#06B6D4', // Cyan
                '#F97316', // Orange
                '#84CC16', // Lime
                '#EC4899', // Pink
                '#6B7280'  // Gray
            ];

            const chartOptions = {
                series: series,
                chart: {
                    type: 'donut',
                    height: '100%',
                    fontFamily: 'inherit',
                },
                labels: labels,
                colors: systemColors,
                plotOptions: {
                    pie: {
                        donut: {
                            size: '75%',
                            labels: {
                                show: true,
                                name: {
                                    show: true,
                                    fontSize: '14px',
                                    fontFamily: 'inherit',
                                    fontWeight: 600,
                                    color: '#374151',
                                    offsetY: -4
                                },
                                value: {
                                    show: true,
                                    fontSize: '16px',
                                    fontFamily: 'inherit',
                                    fontWeight: 700,
                                    color: '#111827',
                                    offsetY: 4,
                                    formatter: function (val) {
                                        return val + ' programmes'
                                    }
                                },
                                total: {
                                    show: true,
                                    showAlways: true,
                                    label: 'Total',
                                    fontSize: '14px',
                                    fontWeight: 600,
                                    color: '#6B7280',
                                    formatter: function (w) {
                                        const total = w.globals.seriesTotals.reduce((a, b) => a + b, 0);
                                        return total + ' programmes'
                                    }
                                }
                            }
                        }
                    }
                },
                dataLabels: {
                    enabled: false
                },
                legend: {
                    show: true,
                    position: 'bottom',
                    horizontalAlign: 'center',
                    fontSize: '12px',
                    fontFamily: 'inherit',
                    fontWeight: 500,
                    labels: {
                        colors: '#374151',
                        useSeriesColors: false
                    },
                    markers: {
                        width: 8,
                        height: 8,
                        radius: 2,
                    },
                    itemMargin: {
                        horizontal: 8,
                        vertical: 4
                    }
                },
                stroke: {
                    show: true,
                    width: 2,
                    colors: ['#ffffff']
                },
                responsive: [{
                    breakpoint: 480,
                    options: {
                        chart: {
                            height: 200
                        },
                        legend: {
                            fontSize: '10px'
                        }
                    }
                }],
                tooltip: {
                    enabled: true,
                    theme: 'light',
                    style: {
                        fontSize: '12px',
                        fontFamily: 'inherit'
                    },
                    y: {
                        formatter: function(val) {
                            return val + ' programmes'
                        }
                    }
                }
            };

            const chart = new ApexCharts(document.querySelector("#programme-distribution-chart"), chartOptions);
            chart.render();
        });
    </script>
}