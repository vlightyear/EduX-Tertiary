    <!-- ── Info callouts (float over hero) ── -->
    @if ((ViewBag.TotalRequiredCourses > 0 && ViewBag.RegistrationStatus != SIS.Enums.Status.Registered) ||
        (hasPeriods && ViewBag.RegistrationStatus != SIS.Enums.Status.Registered))
    {
        <div class="cr-strip">
            @if (ViewBag.TotalRequiredCourses > 0 && ViewBag.RegistrationStatus != SIS.Enums.Status.Registered)
            {
                <div class="callout callout-blue">
                    <i class="material-icons">info</i>
                    <div class="callout-text">
                        <strong>Course Requirements — </strong>
                        @if (hasPeriods)
                        {
                            <text>Your programme requires <strong>@ViewBag.TotalRequiredCourses</strong> courses for @periodLabel.</text>
                        }
                        else
                        {
                            <text>Your programme requires <strong>@ViewBag.TotalRequiredCourses</strong> courses this year.</text>
                        }
                        @if (Model.Any(c => c.IsCarryover))
                        {
                            var cc = Model.Count(c => c.IsCarryover);
                            <text> <strong style="color:#d97706;">@cc carryover course@(cc != 1 ? "s" : "") must be retaken.</strong></text>
