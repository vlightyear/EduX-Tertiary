        @if (ViewBag.RegistrationStatus != SIS.Enums.Status.Registered &&
                ViewBag.RegistrationStatus != SIS.Enums.Status.Pending && ViewBag.CanRegister)
        {
            <button type="button" id="submitRegistrationBtnMobile" class="btn-mobile-submit" onclick="submitCourseRegistration()">
                <i id="submitIconMobile" class="material-icons">check_circle</i>
                <svg id="loadingSpinnerMobile" class="animate-spin hidden" style="width:1.1rem;height:1.1rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
