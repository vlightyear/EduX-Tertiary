            <a asp-controller="Payments" asp-action="StudentFinance" style="display:flex;align-items:center;justify-content:center;gap:.35rem;background:var(--navy);color:#fff;border-radius:.65rem;padding:.6rem;font-size:.82rem;font-weight:700;text-decoration:none;">
                <i class="material-icons" style="font-size:.85rem;">payment</i> Pay Now
