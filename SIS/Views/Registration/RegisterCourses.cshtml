        @if (!Model.Any())
        {
            <div style="padding:0 1rem;">
                <div class="callout callout-amber" style="margin-top:.5rem;">
                    <i class="material-icons">warning</i>
                    <p class="callout-text">
                        No courses available for registration at this time@(hasPeriods ? $" for {periodLabel}" : "").
                    </p>
                </div>
            </div>
        }
        else
        {
            <form id="courseRegistrationForm">
                @Html.AntiForgeryToken()

                <!-- Carryover section -->
                @if (Model.Any(c => c.IsCarryover))
                {
                    <div style="margin-bottom:1.5rem;">
                        <div class="section-head">
                            <div class="section-head-left">
                                <div class="section-icon" style="background:#fffbeb;">
                                    <i class="material-icons" style="color:#d97706;">refresh</i>
                                </div>
                                <span class="section-title">Carryover Courses</span>
                                @if (hasPeriods)
                                {
                                    <span class="section-sub">(@periodLabel)</span>
                                }
                            </div>
                            <span style="font-size:.68rem;font-weight:700;padding:.2rem .55rem;border-radius:2rem;background:#fffbeb;color:#d97706;border:1px solid #fde68a;">Required</span>
                        </div>

                        <div style="padding:.75rem 1rem .25rem;">
                            <div class="callout callout-amber" style="margin-bottom:.75rem;">
                                <i class="material-icons">info</i>
                                <p class="callout-text">These courses from previous periods are automatically included and do not count towards your elective limits.</p>
                            </div>
                            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:.65rem;">
                                @foreach (var course in Model.Where(c => c.IsCarryover))
                                {
                                    <div class="course-card carryover">
                                        <span class="status-dot carryover"></span>
                                        <div class="card-touch">
                                            <input class="course-checkbox carryover-checkbox" type="checkbox" value="@course.Id" checked disabled>
                                            <div style="flex:1;">
                                                <p class="card-course-code">@course.CourseCode <span class="badge-carryover">Carryover</span></p>
                                                <h3 class="card-course-name">@course.CourseName</h3>
                                                <p class="card-course-desc">@course.CourseDescription</p>
                                                @if (!string.IsNullOrEmpty(course.CarryoverReason))
                                                {
                                                    <p class="carryover-reason"><strong>Reason:</strong> @course.CarryoverReason</p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Mandatory section -->
                <div style="margin-bottom:1.5rem;">
                    <div class="section-head">
                        <div class="section-head-left">
                            <div class="section-icon" style="background:#eff6ff;">
                                <i class="material-icons" style="color:var(--navy);">star</i>
                            </div>
                            <span class="section-title">Mandatory Courses</span>
                            @if (hasPeriods)
                            {
                                <span class="section-sub">(@periodLabel)</span>
                            }
