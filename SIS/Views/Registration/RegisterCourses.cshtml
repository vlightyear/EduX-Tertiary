    </div>

    <!-- Mobile Floating Action Button -->
    @if (ViewBag.RegistrationStatus != SIS.Enums.Status.Registered &&
    ViewBag.RegistrationStatus != SIS.Enums.Status.Pending)
    {
        <div class="mobile-floating-action sm:hidden">
