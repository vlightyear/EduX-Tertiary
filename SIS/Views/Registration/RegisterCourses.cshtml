    doc.text(studentNumber, 60, studentY + 17);

    doc.setFont('helvetica', 'bold');
    doc.text('Programme:', 42, studentY + 24);
    doc.setFont('helvetica', 'normal');
    doc.text(programme, 75, studentY + 24);

    // Status
    doc.setFillColor(34, 197, 94);
    doc.roundedRect(width - 65, studentY + 8, 45, 8, 1, 1, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'bold');
    doc.text('REGISTERED', width - 42.5, studentY + 13, { align: 'center' });

    // Courses section
    const coursesY = studentY + 40;
    
    doc.setFillColor(248, 250, 252);
    doc.rect(15, coursesY, width - 30, 10, 'FD');
    
    doc.setTextColor(31, 41, 55);
    doc.setFontSize(11);
    doc.setFont('helvetica', 'bold');
    const coursesTitle = isSemesterBased ? 
        `REGISTERED COURSES - SEMESTER ${currentSemester}` : 
        'REGISTERED COURSES';
    doc.text(coursesTitle, 20, coursesY + 7);

    // Get courses
    const getCourseData = (selector, type) => {
        return Array.from(document.querySelectorAll(selector))
            .map(cb => {
                const courseDiv = cb.closest('.course-card, .bg-slate-50, .border, div');
                if (!courseDiv) return null;
                
                const codeElement = courseDiv.querySelector('p.text-sm, p[class*="text-sm"], p');
                const nameElement = courseDiv.querySelector('h3');
                
                if (!codeElement || !nameElement) return null;
                
                return {
                    code: codeElement.textContent.trim(),
                    name: nameElement.textContent.trim(),
                    type: type,
                    credits: '3'
                };
            })
            .filter(course => course && course.code && course.name);
    };

    const carryoverCourses = getCourseData('.carryover-checkbox:checked', 'Carryover');
    const mandatoryCourses = getCourseData('.mandatory-checkbox:checked', 'Mandatory');  
    const electiveCourses = getCourseData('input[name="elective"]:checked', 'Elective');
    
    const allCourses = [...carryoverCourses, ...mandatoryCourses, ...electiveCourses];

    // Course count
    doc.setFontSize(8);
    doc.setTextColor(107, 114, 128);
    doc.text(`Total: ${allCourses.length}`, width - 20, coursesY + 7, { align: 'right' });

    // Table headers
    let tableY = coursesY + 18;
    doc.setFillColor(249, 250, 251);
    doc.rect(15, tableY - 5, width - 30, 5, 'FD');
    
    doc.setTextColor(55, 65, 81);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'bold');
    doc.text('#', 20, tableY - 1);
    doc.text('CODE', 30, tableY - 1);
    doc.text('COURSE NAME', 60, tableY - 1);
    doc.text('TYPE', width - 65, tableY - 1);
    doc.text('CREDITS', width - 35, tableY - 1);

    // Course rows
    allCourses.forEach((course, index) => {
        if (index % 2 === 0) {
            doc.setFillColor(254, 254, 255);
            doc.rect(15, tableY, width - 30, 8, 'F');
        }

        doc.setTextColor(55, 65, 81);
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        doc.text((index + 1).toString(), 20, tableY + 5);
        
        doc.setFont('helvetica', 'bold');
        doc.text(course.code, 30, tableY + 5);
        
        doc.setFont('helvetica', 'normal');
        const maxNameLength = 35;
        const courseName = course.name.length > maxNameLength ? 
            course.name.substring(0, maxNameLength) + '...' : course.name;
        doc.text(courseName, 60, tableY + 5);

        // Type badge
        let typeColor;
        switch(course.type) {
            case 'Carryover': typeColor = [239, 68, 68]; break;
            case 'Mandatory': typeColor = [59, 130, 246]; break;
            case 'Elective': typeColor = [34, 197, 94]; break;
            default: typeColor = [107, 114, 128];
        }
        
        doc.setFillColor(...typeColor);
        doc.roundedRect(width - 70, tableY + 1, 18, 6, 1, 1, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(6);
        doc.setFont('helvetica', 'bold');
        doc.text(course.type.toUpperCase(), width - 61, tableY + 5, { align: 'center' });

        doc.setTextColor(55, 65, 81);
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        doc.text(course.credits, width - 35, tableY + 5);

        tableY += 8;
    });

    // Footer
    const footerY = height - 35;
    doc.setDrawColor(203, 213, 225);
    doc.setLineWidth(0.3);
    doc.line(15, footerY, width - 15, footerY);

    // Timestamp
    const now = new Date();
    const timestamp = now.toLocaleString('en-GB', {
        day: '2-digit',
        month: 'short', 
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    });

    doc.setTextColor(107, 114, 128);
    doc.setFontSize(7);
    doc.setFont('helvetica', 'normal');
    doc.text(`Generated: ${timestamp}`, 20, footerY + 6);
    doc.text('This document is digitally generated and valid without signature', 20, footerY + 12);

    // QR Code
    const allCourseCodes = allCourses.map(c => c.code);
    const semesterInfo = isSemesterBased ? `|SEM:${currentSemester}` : '';
    const qrData = `SIS_PASS|COURSES:${allCourseCodes.join(',')}${semesterInfo}|DATE:${now.getTime()}`;
    
    doc.setFillColor(255, 255, 255);
    doc.setDrawColor(203, 213, 225);
    doc.roundedRect(width - 35, footerY + 5, 25, 25, 1, 1, 'FD');
    
    const qrImage = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&format=png&margin=0&data=${encodeURIComponent(qrData)}`;
    doc.addImage(qrImage, 'PNG', width - 33, footerY + 7, 21, 21);

    doc.setFontSize(6);
    doc.text('Verify', width - 22.5, footerY + 31, { align: 'center' });

    // Save
    const timestamp_file = new Date().toISOString().split('T')[0];
    const fileName = isSemesterBased ? 
        `ClassPass_Sem${currentSemester}_${timestamp_file}.pdf` : 
        `ClassPass_${timestamp_file}.pdf`;
    
    doc.save(fileName);
}


    // Add these functions for exam docket functionality

    // Check for available exam dockets on page load
    document.addEventListener('DOMContentLoaded', function() {
        // Existing code...

        // Check for exam dockets if registered
        const registrationStatus = '@ViewBag.RegistrationStatus';
        if (registrationStatus === 'Registered') {
            checkExamDocketsOnLoad();
        }
    });

        function checkExamDocketsOnLoad() {
        fetch('/CourseRegistration/GetExamDocketStatus')
            .then(response => response.json())
            .then(data => {
                if (data.success && data.exams && data.exams.length > 0) {
                    // Show exam docket section for BOTH desktop and mobile
                    document.getElementById('examDocketSection').classList.remove('hidden');
                    document.getElementById('examDocketSectionMobile').classList.remove('hidden');

                    // Add notification badge if exams are available
                    const examBtn = document.getElementById('examDocketBtn');
                    const examBtnMobile = document.getElementById('examDocketBtnMobile');

                    if (data.exams.some(e => e.isEligible)) {
                        const badgeHTML = `
                            <i class="material-icons text-sm mr-1">assignment</i>
                            <span>Exam Docket</span>
                            <span class="ml-1 px-1.5 py-0.5 bg-red-600 text-white text-xs rounded-full">${data.exams.filter(e => e.isEligible).length}</span>
                        `;
                        examBtn.innerHTML = badgeHTML;
                        examBtnMobile.innerHTML = badgeHTML;
                    }
                }
            })
            .catch(error => console.error('Error checking exam dockets:', error));
    }

    function checkExamDockets() {
        const modal = document.getElementById('examDocketModal');
        const content = document.getElementById('examDocketContent');

        // Show loading
        content.innerHTML = `
            <div class="text-center py-8">
                <svg class="animate-spin h-8 w-8 text-slate-600 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <p class="mt-2 text-slate-600">Loading exam information...</p>
            </div>
        `;

        modal.classList.remove('hidden');
        modal.classList.add('flex');

        // Fetch exam docket status
        fetch('/CourseRegistration/GetExamDocketStatus')
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    displayExamDockets(data.exams);
                } else {
                    content.innerHTML = `
                        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                            <p class="text-red-700">${data.message || 'Error loading exam information'}</p>
                        </div>
                    `;
                }
            })
            .catch(error => {
                content.innerHTML = `
                    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                        <p class="text-red-700">Failed to load exam information. Please try again.</p>
                    </div>
                `;
            });
    }

    function displayExamDockets(exams) {
        const content = document.getElementById('examDocketContent');

        if (!exams || exams.length === 0) {
            content.innerHTML = `
                <div class="bg-slate-50 rounded-lg p-6 text-center">
                    <i class="material-icons text-slate-400 text-5xl mb-3">event_busy</i>
                    <p class="text-slate-600">No exam events scheduled within the next two weeks.</p>
                </div>
            `;
            return;
        }

        let html = '<div class="space-y-4">';

        exams.forEach(exam => {
            const examDate = new Date(exam.startDateTime);
            const today = new Date();
            const daysUntil = Math.ceil((examDate - today) / (1000 * 60 * 60 * 24));

            let statusBadge = '';
            let actionButton = '';

            if (exam.eventTypeName === 'Final Examination') {
                if (exam.isEligible) {
                    statusBadge = '<span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded-full">Eligible</span>';
                    actionButton = `
                        <button onclick="generateExamDocket(${exam.id}, '${exam.eventTypeName}')"
                                class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                            <i class="material-icons text-sm mr-1">download</i>
                            Generate Docket
                        </button>
                    `;
                } else {
                    statusBadge = '<span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs rounded-full">Payment Required</span>';
                    actionButton = `
                        <a href="/Payments/StudentFinance"
                           class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                            <i class="material-icons text-sm mr-1">payment</i>
                            Pay Fees
                        </a>
                    `;
                }
            } else if (exam.requiresApproval) {
                if (exam.hasApprovedRequest) {
                    statusBadge = '<span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded-full">Approved</span>';
                    actionButton = `
                        <button onclick="generateExamDocket(${exam.id}, '${exam.eventTypeName}')"
                                class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                            <i class="material-icons text-sm mr-1">download</i>
                            Generate Docket
                        </button>
                    `;
                } else {
                    statusBadge = `<span class="px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded-full">${exam.requestStatus}</span>`;
                    actionButton = `
                        <a href="/AcademicRequest/Submit"
                           class="px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition-colors flex items-center">
                            <i class="material-icons text-sm mr-1">request_page</i>
                            Submit Request
                        </a>
                    `;
                }
            }

            html += `
                <div class="border border-slate-200 rounded-lg p-4 hover:shadow-md transition-shadow">
                    <div class="flex justify-between items-start mb-3">
                        <div>
                            <h4 class="font-semibold text-slate-800 flex items-center">
                                <i class="material-icons text-red-600 mr-2 text-sm">event</i>
                                ${exam.title}
                            </h4>
                            <p class="text-sm text-slate-600 mt-1">${exam.eventTypeName}</p>
                        </div>
                        <div class="text-right">
                            ${statusBadge}
                            ${daysUntil >= 0 ? `
                                <p class="text-xs text-slate-500 mt-1">
                                    ${daysUntil === 0 ? 'Today' : daysUntil === 1 ? 'Tomorrow' : `In ${daysUntil} days`}
                                </p>
                            ` : ''}
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-3 text-sm text-slate-600 mb-3">
                        <div class="flex items-center">
                            <i class="material-icons text-xs mr-1">calendar_today</i>
                            ${examDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}
                        </div>
                        ${exam.location ? `
                            <div class="flex items-center">
                                <i class="material-icons text-xs mr-1">location_on</i>
                                ${exam.location}
                            </div>
                        ` : ''}
                    </div>

                    <div class="flex justify-end">
                        ${actionButton}
                    </div>
                </div>
            `;
        });

        html += '</div>';
        content.innerHTML = html;
    }

    function closeExamDocketModal() {
        const modal = document.getElementById('examDocketModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

       function generateExamDocket(examEventId, examType) {
        // Show loading state
        const button = event.target.closest('button');
        const originalContent = button.innerHTML;
        button.disabled = true;
        button.innerHTML = `
            <svg class="animate-spin h-4 w-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Generating...
        `;

        // Create form data for the request
        const formData = new FormData();
        formData.append('examEventId', examEventId);
        formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

        // Make request to generate docket
        fetch('/CourseRegistration/GenerateExamDocket', {
            method: 'POST',
            body: formData
        })
        .then(response => {
            if (response.ok) {
                return response.blob();
            } else {
                return response.json().then(data => {
                    throw new Error(data.message || 'Failed to generate exam docket');
                });
            }
        })
        .then(blob => {
            // Create download link
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.style.display = 'none';
            a.href = url;
            a.download = `ExamDocket_${examType.replace(/\s+/g, '')}_${new Date().toISOString().split('T')[0]}.pdf`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);

            // Show success message
            showCustomAlert('success', 'Success', 'Exam docket generated successfully!');

            // Close modal after delay
            setTimeout(() => {
                closeExamDocketModal();
            }, 2000);
        })
        .catch(error => {
            console.error('Error:', error);
            showCustomAlert('error', 'Error', error.message || 'An error occurred while generating the docket');
        })
        .finally(() => {
            // Reset button
            button.disabled = false;
            button.innerHTML = originalContent;
        });
    }

    


</script>