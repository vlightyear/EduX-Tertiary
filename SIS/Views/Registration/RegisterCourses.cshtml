@model IEnumerable<SIS.Models.Registration.CourseRegistrationViewModel>
@{
    ViewData["Title"] = "Register Courses";
    string periodLabel = (ViewBag.CurrentPeriodLabel as string) ?? "";
    bool hasPeriods = !string.IsNullOrEmpty(periodLabel) && periodLabel != "—";
}

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap');

        :root {
            --coral: #e85c5c;
            --coral-d: #c94040;
            --navy: #1e2d5e;
            --navy-l: #2e3f7a;
            --mist: #f5f7fa;
            --border: #e8ecf2;
            --ink: #1a1f2e;
            --text: #475569;
            --green: #16a34a;
            --greenl: #dcfce7;
        }

        body, .cr-wrap * {
            font-family: 'DM Sans',sans-serif;
        }

        /* Restore Material Icons font overridden by the wildcard above */
        .material-icons {
            font-family: 'Material Icons' !important;
            font-feature-settings: 'liga';
        }

        /* ── Animations ────────────────────── */
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .animate-spin {
            animation: spin 1s linear infinite;
        }

        .animate-fade-in {
            animation: fadeIn .3s ease-out;
        }

        /* ── Hero ──────────────────────────── */
        .cr-hero {
            background: linear-gradient(135deg,var(--navy) 0%,var(--navy-l) 55%,#3a2060 100%);
            padding: 1.5rem 1.5rem 3.25rem;
            position: relative;
            overflow: hidden;
        }

            .cr-hero::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 180px;
                height: 180px;
                background: rgba(232,92,92,.15);
                border-radius: 50%;
                pointer-events: none;
            }

            .cr-hero::after {
                content: '';
                position: absolute;
                bottom: -50px;
                left: 20%;
                width: 240px;
                height: 240px;
                background: rgba(255,255,255,.03);
                border-radius: 50%;
                pointer-events: none;
            }

        .cr-hero-inner {
            position: relative;
            z-index: 1;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            flex-wrap: wrap;
            gap: .85rem;
        }

        .cr-hero-eyebrow {
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: rgba(255,255,255,.5);
            margin-bottom: .3rem;
        }

        .cr-hero-title {
            font-family: 'DM Serif Display',serif;
            font-size: 1.7rem;
            color: #fff;
            line-height: 1.2;
            margin-bottom: .25rem;
        }

        .cr-hero-sub {
            font-size: .82rem;
            color: rgba(255,255,255,.6);
        }

        /* hero action row */
        .cr-hero-actions {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: .55rem;
            align-self: flex-start;
        }

        /* status pills in hero */
        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .4rem .85rem;
            border-radius: 2rem;
            font-size: .75rem;
            font-weight: 700;
            white-space: nowrap;
        }

            .status-pill i {
                font-size: .8rem;
            }

        .pill-registered {
            background: rgba(22,163,74,.2);
            color: #bbf7d0;
            border: 1px solid rgba(22,163,74,.35);
        }

        .pill-pending {
            background: rgba(245,158,11,.2);
            color: #fde68a;
            border: 1px solid rgba(245,158,11,.35);
        }

        .pill-threshold {
            background: rgba(245,158,11,.2);
            color: #fde68a;
            border: 1px solid rgba(245,158,11,.35);
        }

        /* hero buttons */
        .btn-hero-submit {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            background: var(--coral);
            color: #fff;
            border: none;
            font-size: .82rem;
            font-weight: 700;
            font-family: inherit;
            padding: .55rem 1.1rem;
            border-radius: .6rem;
            cursor: pointer;
            transition: background .15s;
            box-shadow: 0 4px 14px rgba(232,92,92,.3);
            min-width: 160px;
            justify-content: center;
        }

            .btn-hero-submit:hover:not(:disabled) {
                background: var(--coral-d);
            }

            .btn-hero-submit:disabled {
                background: #94a3b8;
                cursor: not-allowed;
                box-shadow: none;
            }

            .btn-hero-submit i {
                font-size: .85rem;
            }

        .btn-hero-classpass {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            background: transparent;
            color: #bbf7d0;
            border: 1.5px solid rgba(22,163,74,.5);
            font-size: .78rem;
            font-weight: 700;
            font-family: inherit;
            padding: .5rem .9rem;
            border-radius: .6rem;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-hero-classpass:hover {
                background: rgba(22,163,74,.15);
                color: #fff;
            }

            .btn-hero-classpass i {
                font-size: .8rem;
            }

        .btn-hero-pay {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            background: rgba(255,255,255,.12);
            color: #fff;
            border: 1.5px solid rgba(255,255,255,.2);
            font-size: .78rem;
            font-weight: 700;
            font-family: inherit;
            padding: .5rem .9rem;
            border-radius: .6rem;
            cursor: pointer;
            transition: all .15s;
            text-decoration: none;
        }

            .btn-hero-pay:hover {
                background: rgba(255,255,255,.2);
                color: #fff;
            }

            .btn-hero-pay i {
                font-size: .8rem;
            }

        .btn-hero-docket {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            background: transparent;
            color: #fca5a5;
            border: 1.5px solid rgba(232,92,92,.4);
            font-size: .78rem;
            font-weight: 700;
            font-family: inherit;
            padding: .5rem .9rem;
            border-radius: .6rem;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-hero-docket:hover {
                background: rgba(232,92,92,.15);
                color: #fff;
            }

            .btn-hero-docket i {
                font-size: .8rem;
            }

        /* ── Floating strip (callouts) ─────── */
        .cr-strip {
            margin: -2rem 1rem 0;
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            gap: .65rem;
        }

        /* ── Callouts ──────────────────────── */
        .callout {
            display: flex;
            align-items: flex-start;
            gap: .7rem;
            border-radius: .65rem;
            padding: .8rem 1rem;
        }

            .callout i {
                font-size: 1rem;
                flex-shrink: 0;
                margin-top: .05rem;
            }

        .callout-text {
            font-size: .78rem;
            line-height: 1.65;
        }

            .callout-text strong {
                font-weight: 700;
            }

        .callout-blue {
            background: #eff6ff;
            border: 1.5px solid #bfdbfe;
            color: #1e40af;
        }

            .callout-blue i {
                color: #2563eb;
            }

        .callout-purple {
            background: #f5f3ff;
            border: 1.5px solid #ddd6fe;
            color: #5b21b6;
        }

            .callout-purple i {
                color: #7c3aed;
            }

        .callout-amber {
            background: #fffbeb;
            border: 1.5px solid #fde68a;
            color: #92400e;
        }

            .callout-amber i {
                color: #d97706;
            }

        /* ── Section headers ───────────────── */
        .section-head {
            position: sticky;
            top: 0;
            z-index: 5;
            background: rgba(255,255,255,.97);
            backdrop-filter: blur(8px);
            border-bottom: 1.5px solid var(--border);
            padding: .75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .5rem;
        }

        .section-head-left {
            display: flex;
            align-items: center;
            gap: .55rem;
        }

        .section-icon {
            width: 28px;
            height: 28px;
            border-radius: .4rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .section-icon i {
                font-size: .9rem;
            }

        .section-title {
            font-family: 'DM Serif Display',serif;
            font-size: .95rem;
            color: var(--ink);
        }

        .section-sub {
            font-size: .72rem;
            color: var(--text);
            margin-left: .25rem;
        }

        /* counter badges */
        .counter-min {
            font-size: .68rem;
            font-weight: 700;
            padding: .2rem .5rem;
            border-radius: 2rem;
            background: #eff6ff;
            color: #1d4ed8;
        }

        #electiveCounter {
            font-size: .68rem;
            font-weight: 700;
            padding: .2rem .5rem;
            border-radius: 2rem;
            background: #f1f5f9;
            color: #475569;
            transition: all .2s;
        }

        /* ── Course cards ──────────────────── */
        .course-card {
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: .85rem;
            padding: .9rem 1rem;
            position: relative;
            cursor: pointer;
            transition: border-color .15s, box-shadow .15s, transform .1s;
            -webkit-tap-highlight-color: transparent;
        }

            .course-card:active {
                transform: scale(.98);
            }

            .course-card:hover {
                border-color: #cbd5e1;
                box-shadow: 0 4px 16px rgba(30,45,94,.06);
            }

            /* mandatory — navy left bar */
            .course-card.mandatory {
                border-left: 3px solid var(--navy);
                background: var(--mist);
                cursor: default;
            }
            /* carryover — amber left bar */
            .course-card.carryover {
                border-left: 3px solid #d97706;
                background: #fffbeb;
                cursor: default;
            }
            /* selected elective — coral */
            .course-card.selected {
                border-color: var(--coral);
                background: linear-gradient(135deg,#fff5f5,#fff0f0);
                box-shadow: 0 4px 16px rgba(232,92,92,.1);
            }
            /* disabled */
            .course-card.disabled {
                opacity: .55;
                cursor: not-allowed;
                pointer-events: none;
            }

        /* status dot */
        .status-dot {
            position: absolute;
            top: .7rem;
            right: .75rem;
            width: .6rem;
            height: .6rem;
            border-radius: 50%;
        }

            .status-dot.required {
                background: var(--navy);
            }

            .status-dot.carryover {
                background: #d97706;
            }

            .status-dot.selected {
                background: var(--coral);
            }

            .status-dot.unselected {
                background: #cbd5e1;
            }

        /* card inner */
        .card-touch {
            display: flex;
            align-items: center;
            min-height: 44px;
            gap: .65rem;
        }

        .card-course-code {
            font-size: .72rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: .2rem;
        }

        .card-course-name {
            font-size: .85rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: .15rem;
            line-height: 1.35;
        }

        .card-course-desc {
            font-size: .75rem;
            color: var(--text);
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .badge-carryover {
            display: inline-flex;
            font-size: .62rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: .15rem .4rem;
            border-radius: .3rem;
            background: #d97706;
            color: #fff;
            margin-left: .35rem;
        }

        .badge-mandatory {
            display: inline-flex;
            font-size: .62rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: .15rem .4rem;
            border-radius: .3rem;
            background: var(--navy);
            color: #fff;
            margin-left: .35rem;
        }

        .carryover-reason {
            margin-top: .5rem;
            padding: .4rem .6rem;
            background: rgba(217,119,6,.08);
            border-radius: .4rem;
            font-size: .72rem;
            color: #92400e;
        }

        /* checkbox styling */
        .course-checkbox {
            width: 1.1rem;
            height: 1.1rem;
            flex-shrink: 0;
            accent-color: var(--coral);
            cursor: pointer;
        }

        /* ── Empty state ───────────────────── */
        .empty-state {
            background: var(--mist);
            border: 1.5px solid var(--border);
            border-radius: .75rem;
            padding: 1.25rem;
            text-align: center;
        }

            .empty-state p {
                font-size: .8rem;
                color: var(--text);
            }

        /* ── Mobile header ─────────────────── */
        .mobile-header-bar {
            position: sticky;
            top: 0;
            z-index: 10;
            background: rgba(255,255,255,.97);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid var(--border);
            padding: .75rem 1rem;
        }

        /* ── Mobile floating action ────────── */
        .mobile-floating-action {
            position: fixed;
            bottom: 1rem;
            left: 1rem;
            right: 1rem;
            z-index: 20;
            box-shadow: 0 10px 25px rgba(30,45,94,.2);
        }

        .btn-mobile-submit {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            background: var(--coral);
            color: #fff;
            border: none;
            border-radius: .75rem;
            font-size: .9rem;
            font-weight: 700;
            font-family: inherit;
            padding: .8rem;
            cursor: pointer;
            transition: background .15s;
            box-shadow: 0 4px 16px rgba(232,92,92,.35);
        }

            .btn-mobile-submit:hover:not(:disabled) {
                background: var(--coral-d);
            }

            .btn-mobile-submit:disabled {
                background: #94a3b8;
                cursor: not-allowed;
                box-shadow: none;
            }

            .btn-mobile-submit i {
                font-size: 1rem;
            }

        /* swipe hint */
        .swipe-hint {
            display: none;
            text-align: center;
            color: var(--text);
            font-size: .78rem;
            padding: .5rem .75rem;
            background: var(--mist);
            border-radius: .5rem;
            border: 1px dashed var(--border);
            margin: .75rem 1rem;
        }

        /* ── Exam docket modal ─────────────── */
        .docket-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15,20,40,.55);
            backdrop-filter: blur(4px);
            z-index: 50;
            display: none;
            align-items: center;
            justify-content: center;
        }

            .docket-modal-backdrop.show {
                display: flex;
            }

        .docket-modal {
            background: #fff;
            border-radius: 1.25rem;
            overflow: hidden;
            width: 100%;
            max-width: 640px;
            margin: 1rem;
            max-height: 80vh;
            display: flex;
            flex-direction: column;
            box-shadow: 0 25px 50px rgba(15,20,40,.25);
        }

        .docket-modal-head {
            background: linear-gradient(135deg,var(--navy),var(--navy-l));
            padding: 1.1rem 1.35rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .docket-modal-title {
            font-family: 'DM Serif Display',serif;
            font-size: 1rem;
            color: #fff;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

            .docket-modal-title i {
                font-size: 1rem;
                color: #fca5a5;
            }

        .btn-docket-close {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.2);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

            .btn-docket-close:hover {
                background: rgba(255,255,255,.2);
            }

            .btn-docket-close i {
                font-size: .9rem;
            }

        .docket-modal-body {
            padding: 1.25rem;
            overflow-y: auto;
            flex: 1;
        }

        /* exam card inside modal */
        .exam-card {
            border: 1.5px solid var(--border);
            border-radius: .75rem;
            padding: 1rem;
            transition: box-shadow .15s;
            margin-bottom: .75rem;
        }

            .exam-card:hover {
                box-shadow: 0 4px 16px rgba(30,45,94,.08);
            }

        /* ── Custom alert modal ────────────── */
        .alert-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,20,40,.55);
            backdrop-filter: blur(4px);
            z-index: 60;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

            .alert-overlay.show {
                display: flex;
            }

        .alert-box-modal {
            background: #fff;
            border-radius: 1rem;
            padding: 1.75rem;
            max-width: 380px;
            width: 100%;
            text-align: center;
            box-shadow: 0 20px 40px rgba(15,20,40,.2);
            animation: fadeIn .25s ease-out;
        }

        .alert-icon-ring {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            margin: 0 auto .85rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .alert-icon-ring i {
                font-size: 1.4rem;
                color: #fff;
            }

        #alertTitle {
            font-family: 'DM Serif Display',serif;
            font-size: 1.05rem;
            color: var(--ink);
            margin-bottom: .4rem;
        }

        #alertMessage {
            font-size: .8rem;
            color: var(--text);
            line-height: 1.6;
            margin-bottom: 1.25rem;
        }

        .btn-alert-ok {
            width: 100%;
            padding: .65rem;
            border-radius: .65rem;
            background: var(--navy);
            color: #fff;
            border: none;
            font-size: .82rem;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-alert-ok:hover {
                background: var(--navy-l);
            }

        /* ── Loading overlay ───────────────── */
        .loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,20,40,.55);
            backdrop-filter: blur(4px);
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
        }

            .loading-overlay.show {
                display: flex;
            }

        .loading-box {
            background: #fff;
            border-radius: 1rem;
            padding: 1.75rem 2.25rem;
            text-align: center;
            box-shadow: 0 20px 40px rgba(15,20,40,.2);
        }

        .loading-spin {
            animation: spin 1s linear infinite;
            font-size: 2rem;
            color: var(--coral);
            display: block;
            margin: 0 auto .6rem;
        }

        .loading-box h3 {
            font-family: 'DM Serif Display',serif;
            font-size: 1rem;
            color: var(--ink);
        }

        /* mobile-only content padding */
        .mobile-course-content {
            padding-bottom: 5rem;
        }

        @@media (min-width: 640px) {
            .mobile-course-content {
                padding-bottom: 1.5rem;
            }

            .swipe-hint {
                display: none !important;
            }

            .mobile-floating-action {
                display: none !important;
            }
        }

        @@media (max-width: 639px) {
            .swipe-hint {
                display: block;
            }

            .cr-hero-actions {
                display: none;
            }

            .cr-mobile-actions {
                display: flex;
                flex-direction: column;
                gap: .5rem;
                padding: .75rem 1rem;
                background: #fff;
                border-bottom: 1px solid var(--border);
            }
        }

        @@media (min-width: 640px) {
            .cr-mobile-actions {
                display: none;
            }
        }
    </style>
}

<div class="cr-wrap">

    <!-- ── Hero ── -->
    <div class="cr-hero">
        <div class="cr-hero-inner">
            <div>
                <p class="cr-hero-eyebrow">Academic Registration</p>
                <h1 class="cr-hero-title">
                    @(ViewBag.RegistrationStatus == SIS.Enums.Status.Registered ? "Registered Courses" : "Register Courses")
                </h1>
                @if (hasPeriods)
                {
                    <p class="cr-hero-sub">@periodLabel</p>
                }
            </div>

            <!-- Desktop action cluster -->
            <div class="cr-hero-actions">
                @if (ViewBag.RegistrationStatus != SIS.Enums.Status.Registered &&
                                ViewBag.RegistrationStatus != SIS.Enums.Status.Pending && ViewBag.CanRegister)
                {
                    <button type="button" id="submitRegistrationBtn" class="btn-hero-submit" onclick="submitCourseRegistration()">
                        <i id="submitIcon" class="material-icons">check_circle</i>
                        <svg id="loadingSpinner" class="animate-spin hidden" style="width:1rem;height:1rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span id="submitText">Submit Registration</span>
                    </button>
                }
                else if (ViewBag.RegistrationStatus == SIS.Enums.Status.Pending)
                {
                    <span class="status-pill pill-pending"><i class="material-icons">hourglass_empty</i> Pending@(hasPeriods ? $" · {periodLabel}" : "")</span>
                    <a asp-controller="Payments" asp-action="StudentFinance" class="btn-hero-pay"><i class="material-icons">payment</i> Pay Now</a>
                }
                else if (ViewBag.RegistrationStatus == SIS.Enums.Status.Registered)
                {
                    <span class="status-pill pill-registered"><i class="material-icons">check_circle</i> Registered@(hasPeriods ? $" · {periodLabel}" : "")</span>
                    <button onclick="generateClassPass()" class="btn-hero-classpass"><i class="material-icons">school</i> Class Pass</button>
                    <a asp-controller="Payments" asp-action="StudentFinance" class="btn-hero-pay"><i class="material-icons">payment</i> Pay</a>
                    <div id="examDocketSection" class="hidden">
                        <button id="examDocketBtn" onclick="checkExamDockets()" class="btn-hero-docket"><i class="material-icons">assignment</i> Exam Docket</button>
                    </div>
                }
                else if (!ViewBag.CanRegister)
                {
                    <span class="status-pill pill-threshold"><i class="material-icons">hourglass_empty</i> Threshold Not Reached</span>
                    <a asp-controller="Payments" asp-action="StudentFinance" class="btn-hero-pay"><i class="material-icons">payment</i> Pay Now</a>
                }
            </div>
