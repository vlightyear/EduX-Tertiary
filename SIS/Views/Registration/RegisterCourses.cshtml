                        {
                            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:.65rem;">
                                @foreach (var course in Model.Where(c => c.IsMandatory && !c.IsCarryover))
                                {
                                    <div class="course-card mandatory">
                                        <span class="status-dot required"></span>
                                        <div class="card-touch">
                                            <input class="course-checkbox mandatory-checkbox" type="checkbox" value="@course.Id" checked disabled>
                                            <div style="flex:1;">
                                                <p class="card-course-code">@course.CourseCode <span class="badge-mandatory">Mandatory</span></p>
                                                <h3 class="card-course-name">@course.CourseName</h3>
                                                <p class="card-course-desc">@course.CourseDescription</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state"><p>No mandatory courses for this @(hasPeriods ? "period" : "year").</p></div>
                        }
                    </div>
                </div>

                <!-- Elective section -->
                <div style="padding-bottom:1rem;">
                    <div class="section-head">
                        <div class="section-head-left">
                            <div class="section-icon" style="background:var(--greenl);">
                                <i class="material-icons" style="color:var(--green);">library_books</i>
                            </div>
                            <span class="section-title">Elective Courses</span>
                            @if (hasPeriods)
                            {
                                <span class="section-sub">(@periodLabel)</span>
                            }
                        </div>
                        @if (ViewBag.RegistrationStatus != SIS.Enums.Status.Pending &&
                                            ViewBag.RegistrationStatus != SIS.Enums.Status.Registered)
                        {
                            <div style="display:flex;gap:.4rem;align-items:center;">
                                <span class="counter-min">Min: @ViewBag.MinimumElectives</span>
                                <span id="electiveCounter">0 selected</span>
                            </div>
                        }
                    </div>

                    <div style="padding:.75rem 1rem .25rem;">
                        @if (Model.Any(c => !c.IsMandatory && !c.IsCarryover))
                        {
                            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:.65rem;">
                                @foreach (var course in Model.Where(c => !c.IsMandatory && !c.IsCarryover))
                                {
                                    <div class="course-card @(course.IsSelected ? "selected" : "")"
                                         onclick="toggleCourseSelection(this, @course.Id)"
                                         data-course-id="@course.Id">
                                        <span class="status-dot @(course.IsSelected ? "selected" : "unselected")"></span>
                                        <div class="card-touch">
                                            <input class="course-checkbox elective-checkbox" type="checkbox" name="elective" value="@course.Id"
                                                   @(course.IsSelected ? "checked" : "")
                                                   @(ViewBag.RegistrationStatus == SIS.Enums.Status.Pending || ViewBag.RegistrationStatus == SIS.Enums.Status.Registered ? "disabled" : "")>
                                            <div style="flex:1;">
                                                <p class="card-course-code">@course.CourseCode</p>
                                                <h3 class="card-course-name">@course.CourseName</h3>
                                                <p class="card-course-desc">@course.CourseDescription</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state"><p>No elective courses available for this @(hasPeriods ? "period" : "year").</p></div>
                        }
                    </div>
                </div>

            </form>
        }
    </div>

    <!-- Mobile floating submit -->
    @if (ViewBag.RegistrationStatus != SIS.Enums.Status.Registered &&
        ViewBag.RegistrationStatus != SIS.Enums.Status.Pending && ViewBag.CanRegister)
    {
        <div class="mobile-floating-action" style="display:none;" id="mobileFloatingBar">
            <button type="button" id="mobileSubmitBtn" class="btn-mobile-submit" onclick="submitCourseRegistration()">
                <i id="mobileSubmitIcon" class="material-icons">check_circle</i>
                <svg id="mobileLoadingSpinner" class="animate-spin hidden" style="width:1.1rem;height:1.1rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span id="mobileSubmitText">Submit Registration</span>
            </button>
        </div>
        <script>
            if (window.innerWidth < 640) document.getElementById('mobileFloatingBar').style.display = 'block';
            window.addEventListener('resize', () => {
                const bar = document.getElementById('mobileFloatingBar');
                if (bar) bar.style.display = window.innerWidth < 640 ? 'block' : 'none';
            });
        </script>
    }

</div>

<!-- ── Exam Docket Modal ── -->
<div id="examDocketModal" class="docket-modal-backdrop">
    <div class="docket-modal">
        <div class="docket-modal-head">
            <span class="docket-modal-title"><i class="material-icons">assignment</i> Available Exam Dockets</span>
            <button class="btn-docket-close" onclick="closeExamDocketModal()"><i class="material-icons">close</i></button>
        </div>
        <div class="docket-modal-body" id="examDocketContent"></div>
    </div>
</div>

<!-- ── Custom Alert ── -->
<div id="customAlert" class="alert-overlay">
    <div class="alert-box-modal">
        <div id="alertIcon" class="alert-icon-ring"></div>
        <h3 id="alertTitle"></h3>
        <p id="alertMessage"></p>
        <button class="btn-alert-ok" onclick="closeCustomAlert()">OK</button>
    </div>
</div>

@if (ViewBag.RegistrationStatus != SIS.Enums.Status.Registered &&
     ViewBag.RegistrationStatus != SIS.Enums.Status.Pending)
{
    <script>
        function updateElectiveCounter() {
            const selectedElectives = document.querySelectorAll('.elective-checkbox:checked');
            const mandatoryCourses  = document.querySelectorAll('.mandatory-checkbox:checked');
            const carryoverCourses  = document.querySelectorAll('.carryover-checkbox:checked');
            const counterElement    = document.getElementById('electiveCounter');
            if (!counterElement) return;

            const selectedCount  = selectedElectives.length;
            const carryoverCount = carryoverCourses.length;
            const totalSelected  = selectedCount + mandatoryCourses.length + carryoverCount;
            const minimumElectives    = @ViewBag.MinimumElectives;
            const totalRequiredCourses = @ViewBag.TotalRequiredCourses;

            const counterText = carryoverCount > 0
                ? `${selectedCount} selected (+${carryoverCount} carryover)`
                : `${selectedCount} selected`;
            counterElement.textContent = counterText;

            if (selectedCount >= minimumElectives) {
                if (totalRequiredCourses > 0 && totalSelected > totalRequiredCourses) {
                    counterElement.style.cssText = 'font-size:.68rem;font-weight:700;padding:.2rem .5rem;border-radius:2rem;background:#fee2e2;color:#991b1b;';
                    counterElement.textContent = (carryoverCount > 0
                        ? `${selectedCount} selected (+${carryoverCount} carryover) — max exceeded`
                        : `${selectedCount} selected — max exceeded`);
                } else {
                    counterElement.style.cssText = 'font-size:.68rem;font-weight:700;padding:.2rem .5rem;border-radius:2rem;background:var(--greenl);color:#166534;';
                }
            } else {
                counterElement.style.cssText = 'font-size:.68rem;font-weight:700;padding:.2rem .5rem;border-radius:2rem;background:#fffbeb;color:#92400e;';
            }

            if (totalRequiredCourses > 0) {
                const unselected = document.querySelectorAll('.elective-checkbox:not(:checked)');
                if (totalSelected >= totalRequiredCourses) {
                    unselected.forEach(cb => {
                        cb.disabled = true;
                        cb.closest('.course-card')?.classList.add('disabled');
                    });
                } else {
                    unselected.forEach(cb => {
                        cb.disabled = false;
                        cb.closest('.course-card')?.classList.remove('disabled');
                    });
                }
            }
        }

        function toggleCourseSelection(cardElement, courseId) {
            const checkbox = cardElement.querySelector('.elective-checkbox');
            if (checkbox.disabled) return;
            checkbox.checked = !checkbox.checked;
            const dot = cardElement.querySelector('.status-dot');
            if (checkbox.checked) {
                cardElement.classList.add('selected');
                dot?.classList.replace('unselected','selected');
            } else {
                cardElement.classList.remove('selected');
                dot?.classList.replace('selected','unselected');
            }
            updateElectiveCounter();
            if (navigator.vibrate) navigator.vibrate(50);
        }

        function showCustomAlert(type, title, message) {
            const alertEl = document.getElementById('customAlert');
            const icon    = document.getElementById('alertIcon');
            document.getElementById('alertTitle').textContent   = title;
            document.getElementById('alertMessage').textContent = message;
            const map = {
                error:   { bg:'var(--coral)',  ico:'error' },
                success: { bg:'var(--green)',  ico:'check_circle' },
                warning: { bg:'#d97706',       ico:'warning' }
            };
            const cfg = map[type] || map.error;
            icon.style.background = cfg.bg;
            icon.innerHTML = `<i class="material-icons" style="font-size:1.4rem;color:#fff;">${cfg.ico}</i>`;
            alertEl.classList.add('show');
        }

        function closeCustomAlert() {
            document.getElementById('customAlert').classList.remove('show');
            if (window.pendingRedirect) {
                if (window.pendingRedirect === 'reload') window.location.reload();
                else window.location.href = window.pendingRedirect;
            }
        }

        function submitCourseRegistration() {
            const submitBtn    = document.getElementById('submitRegistrationBtn');
            const submitIcon   = document.getElementById('submitIcon');
            const loadingSpin  = document.getElementById('loadingSpinner');
            const submitText   = document.getElementById('submitText');
            const mobileBtn    = document.getElementById('mobileSubmitBtn');
            const mobileIcon   = document.getElementById('mobileSubmitIcon');
            const mobileSpin   = document.getElementById('mobileLoadingSpinner');
            const mobileText   = document.getElementById('mobileSubmitText');

            if ((submitBtn?.disabled) || (mobileBtn?.disabled)) return;

            function setLoading(on) {
                [{ btn:submitBtn, ico:submitIcon, spin:loadingSpin, txt:submitText },
                 { btn:mobileBtn, ico:mobileIcon, spin:mobileSpin,  txt:mobileText }].forEach(({btn,ico,spin,txt}) => {
                    if (!btn) return;
                    btn.disabled = on;
                    ico?.classList.toggle('hidden', on);
                    spin?.classList.toggle('hidden', !on);
                    if (txt) txt.textContent = on ? 'Registering...' : 'Submit Registration';
                });
            }

            function resetButtons() {
                setLoading(false);
                if (submitIcon) submitIcon.textContent = 'check_circle';
                if (mobileIcon) mobileIcon.textContent = 'check_circle';
            }

            const selectedElectives = document.querySelectorAll('input[name="elective"]:checked');
            const mandatoryCourses  = document.querySelectorAll('.mandatory-checkbox:checked');
            const carryoverCourses  = document.querySelectorAll('.carryover-checkbox:checked');
            const minimumElectives     = @ViewBag.MinimumElectives;
            const totalRequiredCourses = @ViewBag.TotalRequiredCourses;
            const carryoverCount = carryoverCourses.length;
            const totalSelected  = selectedElectives.length + mandatoryCourses.length + carryoverCount;
            const hasPeriods = @(hasPeriods ? "true" : "false");
            const currentPeriodLabel = '@Html.Raw(periodLabel)';

            if (selectedElectives.length < minimumElectives) {
                const pt = hasPeriods ? `for ${currentPeriodLabel}` : 'for this year';
                showCustomAlert('warning','Selection Required',`Please select at least ${minimumElectives} elective course${minimumElectives!==1?'s':''} ${pt}.`);
                return;
            }
            if (totalRequiredCourses > 0 && totalSelected > totalRequiredCourses) {
                const pt = hasPeriods ? `for ${currentPeriodLabel}` : 'for this year';
                showCustomAlert('warning','Too Many Courses',`You can only select a maximum of ${totalRequiredCourses} courses ${pt}. You have selected ${totalSelected}.`);
                return;
            }

            setLoading(true);

            const courses = [
                ...Array.from(carryoverCourses).map(cb => ({id:parseInt(cb.value),isSelected:true,isMandatory:true,isCarryover:true})),
                ...Array.from(mandatoryCourses).map(cb  => ({id:parseInt(cb.value),isSelected:true,isMandatory:true,isCarryover:false})),
                ...Array.from(document.querySelectorAll('input[name="elective"]')).map(cb => ({id:parseInt(cb.value),isSelected:cb.checked,isMandatory:false,isCarryover:false}))
            ];

            fetch('/CourseRegistration/SubmitRegistration', {
                method:'POST',
                headers:{ 'Content-Type':'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                body: JSON.stringify(courses)
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    setLoading(false);
                    [submitBtn,mobileBtn].forEach(b => { if(b) { b.disabled=true; b.style.background='var(--green)'; } });
                    if (submitText)  submitText.textContent  = 'Registration Successful!';
                    if (mobileText)  mobileText.textContent  = 'Registration Successful!';
                    window.pendingRedirect = data.redirect || 'reload';
                    setTimeout(() => showCustomAlert(data.warning?'warning':'success', data.warning?'Registration Complete with Warning':'Success!', data.message), 1000);
                } else {
                    resetButtons();
                    showCustomAlert('error','Registration Failed', data.message||'Registration failed. Please try again.');
                }
            })
            .catch(() => { resetButtons(); showCustomAlert('error','Error','An error occurred while submitting the registration.'); });
        }

        document.addEventListener('DOMContentLoaded', function() {
            const electiveCBs = document.querySelectorAll('.elective-checkbox');
            const counter = document.getElementById('electiveCounter');
            if (electiveCBs.length && counter) {
                updateElectiveCounter();
                electiveCBs.forEach(cb => cb.addEventListener('change', updateElectiveCounter));
            }
            electiveCBs.forEach(cb => {
                const card = cb.closest('.course-card');
                if (cb.checked && card) {
                    card.classList.add('selected');
                    card.querySelector('.status-dot')?.classList.replace('unselected','selected');
                }
            });
            document.addEventListener('keydown', e => {
                if (e.key==='Enter') {
                    const ae = document.activeElement;
                    const sb = document.getElementById('submitRegistrationBtn');
                    const mb = document.getElementById('mobileSubmitBtn');
                    if ((ae.type==='checkbox'||ae.id==='submitRegistrationBtn'||ae.id==='mobileSubmitBtn') && !(sb?.disabled||mb?.disabled)) {
                        e.preventDefault(); submitCourseRegistration();
                    }
                }
            });
            const isPending = @(ViewBag.RegistrationStatus == SIS.Enums.Status.Pending ? "true" : "false");
            if (isPending) {
                document.querySelectorAll('input[name="elective"]').forEach(cb => {
                    cb.removeAttribute('disabled'); cb.checked = true; cb.setAttribute('disabled','');
                    const card = cb.closest('.course-card');
                    if (card) { card.classList.add('selected'); card.querySelector('.status-dot')?.classList.replace('unselected','selected'); }
                });
                updateElectiveCounter();
            }
        });
    </script>
}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const isPending = @(ViewBag.RegistrationStatus == SIS.Enums.Status.Pending ? "true" : "false");
        if (isPending) {
            document.querySelectorAll('input[name="elective"]').forEach(cb => {
                cb.removeAttribute('disabled'); cb.checked = true; cb.setAttribute('disabled','');
                const card = cb.closest('.course-card');
                if (card) { card.classList.add('selected'); card.querySelector('.status-dot')?.classList.replace('unselected','selected'); }
            });
        }
        if ('@ViewBag.RegistrationStatus' === 'Registered') checkExamDocketsOnLoad();
    });
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
    function generateClassPass() {
        window.jsPDF = window.jspdf.jsPDF;
        const doc  = new jsPDF({ orientation:'landscape', unit:'mm', format:'a4' });
        const width  = doc.internal.pageSize.getWidth();
        const height = doc.internal.pageSize.getHeight();

        doc.setFillColor(255,255,255); doc.rect(0,0,width,height,'F');
        doc.setFillColor(248,250,252);
        for (let x=10;x<width;x+=25) for (let y=10;y<height;y+=25) doc.circle(x,y,0.2,'F');

        // Header — navy
        doc.setFillColor(30,45,94); doc.rect(0,0,width,22,'F');
        doc.setFillColor(255,255,255); doc.circle(15,11,7,'F');
        doc.setFillColor(232,92,92);   doc.circle(15,11,5,'F');
        doc.setTextColor(255,255,255); doc.setFontSize(9); doc.setFont('helvetica','bold');
        doc.text('SIS',15,13,{align:'center'});

        const hasPeriods = @(hasPeriods ? "true" : "false");
        const currentPeriodLabel = '@Html.Raw(periodLabel)';
        doc.setTextColor(255,255,255); doc.setFontSize(16); doc.setFont('helvetica','bold');
        doc.text(hasPeriods?`CLASS PASS - ${currentPeriodLabel.toUpperCase()}`:'CLASS PASS', width/2, 14, {align:'center'});
        doc.setFontSize(9); doc.setTextColor(203,213,225);
        const yr=new Date().getFullYear(); doc.text(`${yr}/${yr+1}`,width-15,14,{align:'right'});

        const studentY = 32;
        const studentName   = '@ViewBag.StudentName'  || 'Student Name';
        const studentNumber = '@ViewBag.StudentNumber'|| 'Student Number';
        const programme     = '@ViewBag.Programme'    || 'Programme Name';

        doc.setFillColor(255,255,255); doc.setDrawColor(203,213,225); doc.setLineWidth(0.3);
        doc.roundedRect(15,studentY,width-30,30,2,2,'FD');
        doc.setFillColor(248,250,252); doc.roundedRect(20,studentY+5,18,20,1,1,'FD');
        doc.setFillColor(156,163,175); doc.circle(29,studentY+12,2.5,'F'); doc.rect(26,studentY+16,6,6,'F');

        doc.setTextColor(31,41,55); doc.setFontSize(10);
        doc.setFont('helvetica','bold'); doc.text('Name:',42,studentY+10); doc.setFont('helvetica','normal'); doc.text(studentName,60,studentY+10);
        doc.setFont('helvetica','bold'); doc.text('ID:',42,studentY+17);   doc.setFont('helvetica','normal'); doc.text(studentNumber,60,studentY+17);
        doc.setFont('helvetica','bold'); doc.text('Programme:',42,studentY+24); doc.setFont('helvetica','normal'); doc.text(programme,75,studentY+24);

        doc.setFillColor(22,163,74); doc.roundedRect(width-65,studentY+8,45,8,1,1,'F');
        doc.setTextColor(255,255,255); doc.setFontSize(8); doc.setFont('helvetica','bold');
        doc.text('REGISTERED',width-42.5,studentY+13,{align:'center'});

        const coursesY = studentY+40;
        doc.setFillColor(248,250,252); doc.rect(15,coursesY,width-30,10,'FD');
        doc.setTextColor(31,41,55); doc.setFontSize(11); doc.setFont('helvetica','bold');
        doc.text(hasPeriods?`REGISTERED COURSES - ${currentPeriodLabel.toUpperCase()}`:'REGISTERED COURSES',20,coursesY+7);

        const getCourseData=(selector,type)=>Array.from(document.querySelectorAll(selector)).map(cb=>{
            const d=cb.closest('.course-card,[class*="course-card"],div');
            if(!d)return null;
            const code=d.querySelector('.card-course-code,p.card-course-code,p');
            const name=d.querySelector('h3');
            if(!code||!name)return null;
            return {code:code.textContent.trim(),name:name.textContent.trim(),type,credits:'3'};
        }).filter(c=>c&&c.code&&c.name);

        const allCourses=[
            ...getCourseData('.carryover-checkbox:checked','Carryover'),
            ...getCourseData('.mandatory-checkbox:checked','Mandatory'),
            ...getCourseData('input[name="elective"]:checked','Elective')
        ];

        doc.setFontSize(8); doc.setTextColor(107,114,128);
        doc.text(`Total: ${allCourses.length}`,width-20,coursesY+7,{align:'right'});

        let tableY=coursesY+18;
        doc.setFillColor(249,250,251); doc.rect(15,tableY-5,width-30,5,'FD');
        doc.setTextColor(55,65,81); doc.setFontSize(8); doc.setFont('helvetica','bold');
        doc.text('#',20,tableY-1); doc.text('CODE',30,tableY-1); doc.text('COURSE NAME',60,tableY-1);
        doc.text('TYPE',width-65,tableY-1); doc.text('CREDITS',width-35,tableY-1);

        allCourses.forEach((course,i)=>{
            if(i%2===0){doc.setFillColor(254,254,255);doc.rect(15,tableY,width-30,8,'F');}
            doc.setTextColor(55,65,81); doc.setFontSize(8); doc.setFont('helvetica','normal');
            doc.text(String(i+1),20,tableY+5);
            doc.setFont('helvetica','bold'); doc.text(course.code,30,tableY+5);
            doc.setFont('helvetica','normal');
            const nm=course.name.length>35?course.name.substring(0,35)+'...':course.name;
            doc.text(nm,60,tableY+5);
            const tColor={Carryover:[217,119,6],Mandatory:[30,45,94],Elective:[22,163,74]}[course.type]||[107,114,128];
            doc.setFillColor(...tColor); doc.roundedRect(width-70,tableY+1,18,6,1,1,'F');
            doc.setTextColor(255,255,255); doc.setFontSize(6); doc.setFont('helvetica','bold');
            doc.text(course.type.toUpperCase(),width-61,tableY+5,{align:'center'});
            doc.setTextColor(55,65,81); doc.setFontSize(8); doc.setFont('helvetica','normal');
            doc.text(course.credits,width-35,tableY+5);
            tableY+=8;
        });

        const footerY=height-35;
        doc.setDrawColor(203,213,225); doc.setLineWidth(0.3); doc.line(15,footerY,width-15,footerY);
        const now=new Date();
        const ts=now.toLocaleString('en-GB',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});
        doc.setTextColor(107,114,128); doc.setFontSize(7); doc.setFont('helvetica','normal');
        doc.text(`Generated: ${ts}`,20,footerY+6);
        doc.text('This document is digitally generated and valid without signature',20,footerY+12);

        const codes=allCourses.map(c=>c.code);
        const semInfo=hasPeriods?`|PERIOD:${currentPeriodLabel}`:'';
        const qrData=`SIS_PASS|COURSES:${codes.join(',')}${semInfo}|DATE:${now.getTime()}`;
        doc.setFillColor(255,255,255); doc.setDrawColor(203,213,225);
        doc.roundedRect(width-35,footerY+5,25,25,1,1,'FD');
        doc.addImage(`https://api.qrserver.com/v1/create-qr-code/?size=120x120&format=png&margin=0&data=${encodeURIComponent(qrData)}`,'PNG',width-33,footerY+7,21,21);
        doc.setFontSize(6); doc.text('Verify',width-22.5,footerY+31,{align:'center'});

        const tf=new Date().toISOString().split('T')[0];
        doc.save(hasPeriods?`ClassPass_${currentPeriodLabel.replace(/[^a-z0-9]/gi,'_')}_${tf}.pdf`:`ClassPass_${tf}.pdf`);
    }

    function checkExamDocketsOnLoad() {
        fetch('/CourseRegistration/GetExamDocketStatus')
            .then(r=>r.json())
            .then(data=>{
                if(data.success&&data.exams?.length>0){
                    document.getElementById('examDocketSection')?.classList.remove('hidden');
                    document.getElementById('examDocketSectionMobile')?.classList.remove('hidden');
                    if(data.exams.some(e=>e.isEligible)){
                        const n=data.exams.filter(e=>e.isEligible).length;
                        const html=`<i class="material-icons" style="font-size:.8rem;">assignment</i><span>Exam Docket</span><span style="margin-left:.3rem;padding:.1rem .4rem;background:var(--coral);color:#fff;font-size:.65rem;border-radius:2rem;">${n}</span>`;
                        ['examDocketBtn','examDocketBtnMobile'].forEach(id=>{ const el=document.getElementById(id); if(el)el.innerHTML=html; });
                    }
                }
            }).catch(()=>{});
    }

    function checkExamDockets() {
        const modal   = document.getElementById('examDocketModal');
        const content = document.getElementById('examDocketContent');
        content.innerHTML=`<div style="text-align:center;padding:2rem 0;"><i class="material-icons animate-spin" style="font-size:2rem;color:var(--coral);">refresh</i><p style="margin-top:.6rem;font-size:.8rem;color:var(--text);">Loading exam information…</p></div>`;
        modal.classList.add('show');
        fetch('/CourseRegistration/GetExamDocketStatus')
            .then(r=>r.json())
            .then(data=>{ if(data.success) displayExamDockets(data.exams); else content.innerHTML=`<div class="callout callout-amber" style="margin:0;"><i class="material-icons">warning</i><p class="callout-text">${data.message||'Error loading exam information'}</p></div>`; })
            .catch(()=>{ content.innerHTML=`<div class="callout callout-amber" style="margin:0;"><i class="material-icons">warning</i><p class="callout-text">Failed to load exam information. Please try again.</p></div>`; });
    }

    function displayExamDockets(exams) {
        const content=document.getElementById('examDocketContent');
        if(!exams?.length){
            content.innerHTML=`<div style="text-align:center;padding:2rem 0;"><i class="material-icons" style="font-size:2.5rem;color:#94a3b8;">event_busy</i><p style="font-size:.8rem;color:var(--text);margin-top:.5rem;">No exam events scheduled within the next two weeks.</p></div>`;
            return;
        }
        let html='';
        exams.forEach(exam=>{
            const examDate=new Date(exam.startDateTime);
            const daysUntil=Math.ceil((examDate-new Date())/(1000*60*60*24));
            let badge='', action='';
            if(exam.eventTypeName==='Final Examination'){
                if(exam.isEligible){
                    badge=`<span style="font-size:.65rem;font-weight:700;padding:.2rem .5rem;border-radius:2rem;background:var(--greenl);color:var(--green);">Eligible</span>`;
                    action=`<button onclick="generateExamDocket(${exam.id},'${exam.eventTypeName}')" style="display:inline-flex;align-items:center;gap:.3rem;background:var(--coral);color:#fff;border:none;border-radius:.55rem;padding:.5rem .85rem;font-size:.75rem;font-weight:700;cursor:pointer;font-family:inherit;"><i class="material-icons" style="font-size:.8rem;">download</i>Generate Docket</button>`;
                } else {
                    badge=`<span style="font-size:.65rem;font-weight:700;padding:.2rem .5rem;border-radius:2rem;background:#fffbeb;color:#d97706;">Payment Required</span>`;
                    action=`<a href="/Payments/StudentFinance" style="display:inline-flex;align-items:center;gap:.3rem;background:var(--navy);color:#fff;border-radius:.55rem;padding:.5rem .85rem;font-size:.75rem;font-weight:700;text-decoration:none;"><i class="material-icons" style="font-size:.8rem;">payment</i>Pay Fees</a>`;
                }
            } else if(exam.requiresApproval){
                if(exam.hasApprovedRequest){
                    badge=`<span style="font-size:.65rem;font-weight:700;padding:.2rem .5rem;border-radius:2rem;background:var(--greenl);color:var(--green);">Approved</span>`;
                    action=`<button onclick="generateExamDocket(${exam.id},'${exam.eventTypeName}')" style="display:inline-flex;align-items:center;gap:.3rem;background:var(--coral);color:#fff;border:none;border-radius:.55rem;padding:.5rem .85rem;font-size:.75rem;font-weight:700;cursor:pointer;font-family:inherit;"><i class="material-icons" style="font-size:.8rem;">download</i>Generate Docket</button>`;
                } else {
                    badge=`<span style="font-size:.65rem;font-weight:700;padding:.2rem .5rem;border-radius:2rem;background:var(--mist);color:var(--text);">${exam.requestStatus}</span>`;
                    action=`<a href="/AcademicRequest/Submit" style="display:inline-flex;align-items:center;gap:.3rem;background:var(--navy);color:#fff;border-radius:.55rem;padding:.5rem .85rem;font-size:.75rem;font-weight:700;text-decoration:none;"><i class="material-icons" style="font-size:.8rem;">request_page</i>Submit Request</a>`;
                }
            }
            html+=`<div class="exam-card">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.65rem;">
                    <div>
                        <h4 style="font-family:'DM Serif Display',serif;font-size:.9rem;color:var(--ink);display:flex;align-items:center;gap:.35rem;"><i class="material-icons" style="font-size:.9rem;color:var(--coral);">event</i>${exam.title}</h4>
                        <p style="font-size:.75rem;color:var(--text);margin-top:.15rem;">${exam.eventTypeName}</p>
                    </div>
                    <div style="text-align:right;">${badge}${daysUntil>=0?`<p style="font-size:.65rem;color:#94a3b8;margin-top:.25rem;">${daysUntil===0?'Today':daysUntil===1?'Tomorrow':`In ${daysUntil} days`}</p>`:''}</div>
                </div>
                <div style="display:flex;gap:1rem;font-size:.75rem;color:var(--text);margin-bottom:.65rem;">
                    <span style="display:flex;align-items:center;gap:.25rem;"><i class="material-icons" style="font-size:.8rem;">calendar_today</i>${examDate.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'})}</span>
                    ${exam.location?`<span style="display:flex;align-items:center;gap:.25rem;"><i class="material-icons" style="font-size:.8rem;">location_on</i>${exam.location}</span>`:''}
                </div>
                <div style="display:flex;justify-content:flex-end;">${action}</div>
            </div>`;
        });
        content.innerHTML=html;
    }

    function closeExamDocketModal() {
        document.getElementById('examDocketModal').classList.remove('show');
    }

    function generateExamDocket(examEventId, examType) {
        const button=event.target.closest('button');
        const orig=button.innerHTML;
        button.disabled=true;
        button.innerHTML=`<svg class="animate-spin" style="width:.9rem;height:.9rem;margin-right:.3rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Generating…`;
        const fd=new FormData();
        fd.append('examEventId',examEventId);
        fd.append('__RequestVerificationToken',document.querySelector('input[name="__RequestVerificationToken"]').value);
        fetch('/CourseRegistration/GenerateExamDocket',{method:'POST',body:fd})
            .then(r=>r.ok?r.blob():r.json().then(d=>{throw new Error(d.message||'Failed to generate exam docket');}))
            .then(blob=>{
                const url=window.URL.createObjectURL(blob);
                const a=document.createElement('a'); a.style.display='none'; a.href=url;
                a.download=`ExamDocket_${examType.replace(/\s+/g,'')}${new Date().toISOString().split('T')[0]}.pdf`;
                document.body.appendChild(a); a.click(); window.URL.revokeObjectURL(url); document.body.removeChild(a);
                showCustomAlert('success','Success','Exam docket generated successfully!');
                setTimeout(closeExamDocketModal,2000);
            })
            .catch(err=>{ showCustomAlert('error','Error',err.message||'An error occurred while generating the docket'); })
            .finally(()=>{ button.disabled=false; button.innerHTML=orig; });
    }
</script>
