                    <i class="material-icons">school</i> Class Pass
                </button>
                <a asp-controller="Payments" asp-action="StudentFinance" style="flex:1;display:flex;align-items:center;justify-content:center;gap:.35rem;background:var(--navy);color:#fff;border-radius:.65rem;padding:.6rem;font-size:.78rem;font-weight:700;text-decoration:none;">
                    <i class="material-icons" style="font-size:.8rem;">payment</i> Pay
