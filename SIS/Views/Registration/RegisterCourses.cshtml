            <div id="examDocketSectionMobile" class="hidden">
                <button id="examDocketBtnMobile" onclick="checkExamDockets()" style="width:100%;display:flex;align-items:center;justify-content:center;gap:.35rem;background:#fef2f2;color:var(--coral);border:1.5px solid rgba(232,92,92,.35);border-radius:.65rem;padding:.6rem;font-size:.78rem;font-weight:700;cursor:pointer;font-family:inherit;">
                    <i class="material-icons" style="font-size:.8rem;">assignment</i> Exam Docket
