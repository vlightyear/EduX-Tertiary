@if (ViewBag.RegistrationStatus != SIS.Enums.Status.Registered &&
ViewBag.RegistrationStatus != SIS.Enums.Status.Pending)
{
    <script>
        // Move updateElectiveCounter to global scope
        function updateElectiveCounter() {
            const selectedElectives = document.querySelectorAll('.elective-checkbox:checked');
            const mandatoryCourses = document.querySelectorAll('.mandatory-checkbox:checked');
            const carryoverCourses = document.querySelectorAll('.carryover-checkbox:checked');
            const counterElement = document.getElementById('electiveCounter');

            // Early return if counter element doesn't exist
            if (!counterElement) {
                return;
            }

            const selectedCount = selectedElectives.length;
            const carryoverCount = carryoverCourses.length;
            const totalSelected = selectedCount + mandatoryCourses.length + carryoverCount;
            const minimumElectives = @ViewBag.MinimumElectives;
            const totalRequiredCourses = @ViewBag.TotalRequiredCourses;

            // Update counter text
            const counterText = carryoverCount > 0 ?
                `${selectedCount} selected (+${carryoverCount} carryover)` :
                `${selectedCount} selected`;

            counterElement.textContent = counterText;

            // Update counter color based on requirements
            if (selectedCount >= minimumElectives) {
                if (totalRequiredCourses > 0 && totalSelected > totalRequiredCourses) {
                    counterElement.className = 'px-2 py-1 text-xs font-medium bg-red-100 text-red-800 rounded';
                    counterElement.textContent = carryoverCount > 0 ?
                        `${selectedCount} selected (+${carryoverCount} carryover) - max exceeded` :
                        `${selectedCount} selected - max exceeded`;
                } else {
                    counterElement.className = 'px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded';
                }
            } else {
                counterElement.className = 'px-2 py-1 text-xs font-medium bg-amber-100 text-amber-800 rounded';
            }

            // Disable additional checkboxes if maximum is reached
            if (totalRequiredCourses > 0) {
                const unselectedElectives = document.querySelectorAll('.elective-checkbox:not(:checked)');

                if (totalSelected >= totalRequiredCourses) {
                    // Disable all unchecked electives if maximum is reached
                    unselectedElectives.forEach(checkbox => {
                        checkbox.disabled = true;
                        // Add a visual indication that checkbox is disabled due to maximum limit
                        const courseCard = checkbox.closest('.course-card');
                        if (courseCard) {
                            courseCard.classList.add('disabled');
                        }
                    });
                } else {
                    // Re-enable all electives if below maximum
                    unselectedElectives.forEach(checkbox => {
                        checkbox.disabled = false;
                        const courseCard = checkbox.closest('.course-card');
                        if (courseCard) {
                            courseCard.classList.remove('disabled');
                        }
                    });
                }
            }
        }

        // Enhanced mobile course selection
        function toggleCourseSelection(cardElement, courseId) {
            const checkbox = cardElement.querySelector('.elective-checkbox');

            // Don't toggle if disabled
            if (checkbox.disabled) return;

            // Toggle checkbox
            checkbox.checked = !checkbox.checked;

            // Update visual state
            if (checkbox.checked) {
                cardElement.classList.add('selected');
                const statusIndicator = cardElement.querySelector('.status-indicator');
                if (statusIndicator) {
                    statusIndicator.classList.add('selected');
                }
            } else {
                cardElement.classList.remove('selected');
                const statusIndicator = cardElement.querySelector('.status-indicator');
                if (statusIndicator) {
                    statusIndicator.classList.remove('selected');
                }
            }

            // Update counter - this will now work since updateElectiveCounter is global
            updateElectiveCounter();

            // Provide haptic feedback on mobile
            if (navigator.vibrate) {
                navigator.vibrate(50);
            }
        }

        // Helper functions for custom alerts
        function showCustomAlert(type, title, message) {
            const alert = document.getElementById('customAlert');
            const alertIcon = document.getElementById('alertIcon');
            const alertTitle = document.getElementById('alertTitle');
            const alertMessage = document.getElementById('alertMessage');

            // Set icon and colors based on type
            let iconHtml = '';
            switch(type) {
                case 'error':
                    iconHtml = '<i class="material-icons text-white text-2xl">error</i>';
                    alertIcon.className = 'mx-auto flex items-center justify-center w-12 h-12 rounded-full mb-4 bg-red-500';
                    break;
                case 'success':
                    iconHtml = '<i class="material-icons text-white text-2xl">check_circle</i>';
                    alertIcon.className = 'mx-auto flex items-center justify-center w-12 h-12 rounded-full mb-4 bg-green-500';
                    break;
                case 'warning':
                    iconHtml = '<i class="material-icons text-white text-2xl">warning</i>';
                    alertIcon.className = 'mx-auto flex items-center justify-center w-12 h-12 rounded-full mb-4 bg-amber-500';
                    break;
            }

            alertIcon.innerHTML = iconHtml;
            alertTitle.textContent = title;
            alertMessage.textContent = message;

            // Show alert with animation
            alert.classList.remove('hidden');
            alert.classList.add('animate-fade-in');
        }

        function closeCustomAlert() {
            const alert = document.getElementById('customAlert');
            alert.classList.add('hidden');

            // If there's a pending redirect, execute it
            if (window.pendingRedirect) {
                if (window.pendingRedirect === 'reload') {
                    window.location.reload();
                } else {
                    window.location.href = window.pendingRedirect;
                }
            }
        }

        function submitCourseRegistration() {
            // Get button elements (both desktop and mobile)
            const submitBtn = document.getElementById('submitRegistrationBtn');
            const submitIcon = document.getElementById('submitIcon');
            const loadingSpinner = document.getElementById('loadingSpinner');
            const submitText = document.getElementById('submitText');

            const mobileSubmitBtn = document.getElementById('mobileSubmitBtn');
            const mobileSubmitIcon = document.getElementById('mobileSubmitIcon');
            const mobileLoadingSpinner = document.getElementById('mobileLoadingSpinner');
            const mobileSubmitText = document.getElementById('mobileSubmitText');

            // Check if already submitting
            if ((submitBtn && submitBtn.disabled) || (mobileSubmitBtn && mobileSubmitBtn.disabled)) {
                return;
            }

            // Set loading state
            function setLoadingState(isLoading) {
                if (isLoading) {
                    // Desktop button
                    if (submitBtn) {
                        submitBtn.disabled = true;
                        submitIcon.classList.add('hidden');
                        loadingSpinner.classList.remove('hidden');
                        submitText.textContent = 'Registering...';
                        submitBtn.classList.add('cursor-not-allowed');
                    }

                    // Mobile button
                    if (mobileSubmitBtn) {
                        mobileSubmitBtn.disabled = true;
                        mobileSubmitIcon.classList.add('hidden');
                        mobileLoadingSpinner.classList.remove('hidden');
                        mobileSubmitText.textContent = 'Registering...';
                        mobileSubmitBtn.classList.add('cursor-not-allowed');
                    }
                } else {
                    // Desktop button
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitIcon.classList.remove('hidden');
                        loadingSpinner.classList.add('hidden');
                        submitText.textContent = 'Submit Registration';
                        submitBtn.classList.remove('cursor-not-allowed');
                    }

                    // Mobile button
                    if (mobileSubmitBtn) {
                        mobileSubmitBtn.disabled = false;
                        mobileSubmitIcon.classList.remove('hidden');
                        mobileLoadingSpinner.classList.add('hidden');
                        mobileSubmitText.textContent = 'Submit Registration';
                        mobileSubmitBtn.classList.remove('cursor-not-allowed');
                    }
                }
            }

            // Reset button to original state
            function resetButtonState() {
                setLoadingState(false);

                if (submitBtn) {
                    submitBtn.classList.remove('bg-green-500');
                    submitBtn.classList.add('bg-green-600', 'hover:bg-green-700');
                    submitIcon.textContent = 'check_circle';
                }

                if (mobileSubmitBtn) {
                    mobileSubmitBtn.classList.remove('bg-green-500');
                    mobileSubmitBtn.classList.add('bg-green-600', 'hover:bg-green-700');
                    mobileSubmitIcon.textContent = 'check_circle';
                }
            }

            const selectedElectives = document.querySelectorAll('input[name="elective"]:checked');
            const mandatoryCourses = document.querySelectorAll('.mandatory-checkbox:checked');
            const carryoverCourses = document.querySelectorAll('.carryover-checkbox:checked');

            const minimumElectives = @ViewBag.MinimumElectives;
            const totalRequiredCourses = @ViewBag.TotalRequiredCourses;
            const carryoverCount = carryoverCourses.length;

            // Calculate totals (carryover courses don't count against elective limits)
            const totalSelected = selectedElectives.length + mandatoryCourses.length + carryoverCount;
            const isSemesterBased = @(ViewBag.IsSemesterBased ? "true" : "false");
            const currentSemester = @ViewBag.Semester;

            // Validate minimum elective selection
            if (selectedElectives.length < minimumElectives) {
                const periodText = isSemesterBased ? `for Semester ${currentSemester}` : 'for this year';
                showCustomAlert('warning', 'Selection Required',
                    `Please select at least ${minimumElectives} elective course${minimumElectives !== 1 ? 's' : ''} ${periodText}.`);
                return;
            }

            // Validate maximum course selection
            if (totalRequiredCourses > 0 && totalSelected > totalRequiredCourses) {
                const periodText = isSemesterBased ? `for Semester ${currentSemester}` : 'for this year';
                showCustomAlert('warning', 'Too Many Courses',
                    `You can only select a maximum of ${totalRequiredCourses} courses ${periodText}. You have selected ${totalSelected}.`);
                return;
            }

            // Set loading state
            setLoadingState(true);

            // Get all courses including carryover courses
            const carryoverCourseData = Array.from(carryoverCourses).map(cb => ({
                id: parseInt(cb.value),
                isSelected: true,
                isMandatory: true,
                isCarryover: true
            }));

            const mandatoryCourseData = Array.from(mandatoryCourses).map(cb => ({
                id: parseInt(cb.value),
                isSelected: true,
                isMandatory: true,
                isCarryover: false
            }));

            const electiveCourseData = Array.from(document.querySelectorAll('input[name="elective"]')).map(cb => ({
                id: parseInt(cb.value),
                isSelected: cb.checked,
                isMandatory: false,
                isCarryover: false
            }));

            // Combine all courses
            const selectedCourses = [...carryoverCourseData, ...mandatoryCourseData, ...electiveCourseData];

            // Submit the form using fetch
            fetch('/CourseRegistration/SubmitRegistration', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(selectedCourses)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Change button to success state temporarily
                    setLoadingState(false);

                    if (submitBtn) {
                        submitIcon.className = 'material-icons text-sm mr-1';
                        submitIcon.textContent = 'check_circle';
                        submitText.textContent = 'Registration Successful!';
                        submitBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
                        submitBtn.classList.add('bg-green-500');
                        submitBtn.disabled = true;
                    }

                    if (mobileSubmitBtn) {
                        mobileSubmitIcon.className = 'material-icons mr-2';
                        mobileSubmitIcon.textContent = 'check_circle';
                        mobileSubmitText.textContent = 'Registration Successful!';
                        mobileSubmitBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
                        mobileSubmitBtn.classList.add('bg-green-500');
                        mobileSubmitBtn.disabled = true;
                    }

                    // Set up redirect
                    window.pendingRedirect = data.redirect || 'reload';

                    // Determine alert type based on whether there's a warning
                    const alertType = data.warning ? 'warning' : 'success';
                    const alertTitle = data.warning ? 'Registration Complete with Warning' : 'Success!';

                    // Show success/warning state for 1 second before showing alert
                    setTimeout(() => {
                        showCustomAlert(alertType, alertTitle, data.message);
                    }, 1000);
                } else {
                    resetButtonState();
                    showCustomAlert('error', 'Registration Failed', data.message || 'Registration failed. Please try again.');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                resetButtonState();
                showCustomAlert('error', 'Error', 'An error occurred while submitting the registration.');
            });
        }





        // DOM Content Loaded event
        document.addEventListener('DOMContentLoaded', function() {
            const electiveCheckboxes = document.querySelectorAll('.elective-checkbox');
            const counterElement = document.getElementById('electiveCounter');

            if (electiveCheckboxes.length && counterElement) {
                // Initial count
                updateElectiveCounter();

                // Add event listeners to all checkboxes
                electiveCheckboxes.forEach(checkbox => {
                    checkbox.addEventListener('change', updateElectiveCounter);
                });
            }

            // Initialize selected state for course cards
            electiveCheckboxes.forEach(checkbox => {
                const card = checkbox.closest('.course-card');
                if (checkbox.checked && card) {
                    card.classList.add('selected');
                    const statusIndicator = card.querySelector('.status-indicator');
                    if (statusIndicator) {
                        statusIndicator.classList.add('selected');
                    }
                }
            });

            // Add keyboard accessibility
            document.addEventListener('keydown', function(event) {
                if (event.key === 'Enter') {
                    const activeElement = document.activeElement;
                    const submitBtn = document.getElementById('submitRegistrationBtn');
                    const mobileSubmitBtn = document.getElementById('mobileSubmitBtn');

                    // Only trigger if focused on a checkbox or the submit button, and button is not disabled
                    if ((activeElement.type === 'checkbox' ||
                         activeElement.id === 'submitRegistrationBtn' ||
                         activeElement.id === 'mobileSubmitBtn') &&
                        !((submitBtn && submitBtn.disabled) || (mobileSubmitBtn && mobileSubmitBtn.disabled))) {
                        event.preventDefault();
                        submitCourseRegistration();
                    }
                }
            });

            // Handle pending status - auto-select all elective courses
            const isPending = @(ViewBag.RegistrationStatus == SIS.Enums.Status.Pending ? "true" : "false");

            if (isPending === true) {
                const checkboxes = document.querySelectorAll('input[name="elective"]');

                checkboxes.forEach(checkbox => {
                    // Enable the disabled checkboxes first
                    if (checkbox.hasAttribute("disabled")) {
                        checkbox.removeAttribute("disabled");
                    }
                    // Then check them
                    checkbox.checked = true;
                    // Re-add the disabled attribute
                    checkbox.setAttribute("disabled", "");

                    // Update visual state for mobile
                    const card = checkbox.closest('.course-card');
                    if (card) {
                        card.classList.add('selected');
                        const statusIndicator = card.querySelector('.status-indicator');
                        if (statusIndicator) {
                            statusIndicator.classList.add('selected');
                        }
                    }
                });

                console.log('Elective courses have been selected because status is pending.');

                // Update counter after setting pending status
                updateElectiveCounter();
            }
        });
        console.log('Done');
    </script>
}

