@section Scripts {
    <script>
        /* ── Bed distribution ── */
        function generateBedDistributionInputs() {
            const cap = parseInt(document.getElementById('defaultCapacity').value) || 0;
            const cont = document.getElementById('bedDistributionInputs');
            const auto = document.getElementById('autoGenerateBeds').checked;
            cont.innerHTML = '';
            if (!auto || cap <= 0) { document.getElementById('bedDistributionSection').style.display = 'none'; return; }
            document.getElementById('bedDistributionSection').style.display = 'block';
            for (let i = 0; i < cap; i++) {
                const letter = String.fromCharCode(65 + i);
                const bc = document.createElement('div');
                bc.className = 'bdc';
                bc.innerHTML = `
                    <p class="bdc-t"><i class="material-icons">bed</i>Bed Space ${letter}</p>
                    <div class="fg2">
                        <div class="ff"><label>Year <span style="font-weight:400;color:#94a3b8;font-size:.67rem;">(0 = All)</span></label><input type="number" name="bedDistributions[${i}].Year" min="0" max="7" value="0" /></div>
                        <div class="ff"><label>Semester <span style="font-weight:400;color:#94a3b8;font-size:.67rem;">(0 = All)</span></label><input type="number" name="bedDistributions[${i}].Semester" min="0" max="2" value="0" /></div>
                        <input type="hidden" name="bedDistributions[${i}].BedIndex" value="${i}" />
                    </div>`;
                cont.appendChild(bc);
            }
        }
        function toggleBedSection() {
            if (document.getElementById('autoGenerateBeds').checked) generateBedDistributionInputs();
            else document.getElementById('bedDistributionSection').style.display = 'none';
        }

        /* ── Filter & sort ── */
        let sortState = {};
        function filterTable() {
            const term = document.getElementById('searchInput').value.toLowerCase();
            const camp = document.getElementById('filterCampus').value;
            const gen  = document.getElementById('filterGender').value;
            const sta  = document.getElementById('filterStatus').value;
            let n = 0;
            document.querySelectorAll('#hostelsTableBody tr').forEach(row => {
                if (row.querySelector('td[colspan]')) return;
                const name = row.querySelector('.h-name')?.textContent.toLowerCase() || '';
                const show = name.includes(term)
                          && (camp === 'all' || row.dataset.campus === camp)
                          && (gen  === 'all' || row.dataset.gender === gen)
                          && (sta  === 'all' || row.dataset.status === sta);
                row.style.display = show ? '' : 'none';
                if (show) row.cells[0].textContent = ++n;
            });
            document.getElementById('visibleCount').textContent = n;
            const fc = document.getElementById('footCount'); if (fc) fc.textContent = n;
        }
        function sortTable(key) {
            const tbody = document.getElementById('hostelsTableBody');
            const rows = Array.from(tbody.querySelectorAll('tr')).filter(r => !r.querySelector('td[colspan]'));
            sortState[key] = sortState[key] === 'asc' ? 'desc' : 'asc';
            rows.sort((a, b) => {
                let av, bv;
                if (key==='index')    { av=parseInt(a.cells[0].textContent); bv=parseInt(b.cells[0].textContent); }
                if (key==='name')     { av=a.querySelector('.h-name')?.textContent.toLowerCase()||''; bv=b.querySelector('.h-name')?.textContent.toLowerCase()||''; }
                if (key==='capacity') { av=parseInt(a.cells[4].textContent)||0; bv=parseInt(b.cells[4].textContent)||0; }
                if (av===undefined) return 0;
                return sortState[key]==='asc'?(av>bv?1:av<bv?-1:0):(av<bv?1:av>bv?-1:0);
            });
            rows.forEach((r,i) => { tbody.appendChild(r); r.cells[0].textContent = i+1; });
        }

        /* ── Helpers ── */
        const $ld  = () => document.getElementById('loadingIndicator').style.display = 'flex';
        const $uld = () => document.getElementById('loadingIndicator').style.display = 'none';
        const cleanFD = fd => { if (fd.get('WardenId')==='') fd.delete('WardenId'); return fd; };
        function showNotif(msg, type='success') {
            const el = document.createElement('div');
            el.style.cssText = `position:fixed;top:1.25rem;right:1.25rem;z-index:99999;display:flex;align-items:center;gap:.5rem;padding:.75rem 1.1rem;border-radius:.75rem;font-size:.82rem;font-weight:700;box-shadow:0 8px 24px rgba(15,20,40,.2);background:${type==='success'?'var(--green)':'var(--coral)'};color:#fff;animation:fadeUp .2s ease-out;`;
            el.innerHTML = `<i class="material-icons" style="font-size:1rem;">${type==='success'?'check_circle':'error'}</i><span>${msg}</span>`;
            document.body.appendChild(el);
            setTimeout(()=>{ el.style.opacity='0'; el.style.transform='translateX(24px)'; el.style.transition='all .28s'; setTimeout(()=>el.remove(),300); },3000);
        }
        async function handleForm(url, form, onSuccess) {
            const btn = form.querySelector('button[type="submit"]'), orig = btn.innerHTML;
            btn.disabled=true; btn.innerHTML='<i class="material-icons li-spin">refresh</i><span>Please wait…</span>'; $ld();
            try {
                const r = await fetch(url, { method:'POST', body: cleanFD(new FormData(form)) });
                if (r.redirected) { window.location.href=r.url; return; }
                if (r.ok) { onSuccess(); showNotif(onSuccess.successMsg||'Done!'); setTimeout(()=>location.reload(),1000); }
                else { let t=await r.text(); try{ const d=new DOMParser().parseFromString(t,'text/html'); const e=d.querySelector('.validation-summary-errors,.field-validation-error'); if(e)t=e.textContent.trim(); }catch{} showNotif(t,'error'); }
            } catch { showNotif('Network error. Please try again.','error'); }
            finally { btn.disabled=false; btn.innerHTML=orig; $uld(); }
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('defaultCapacity').addEventListener('change', generateBedDistributionInputs);
            generateBedDistributionInputs();
            document.getElementById('searchInput').addEventListener('input', filterTable);
            document.querySelectorAll('.th-s').forEach(el => el.addEventListener('click', ()=>sortTable(el.dataset.sort)));
            document.addEventListener('keydown', e => { if(e.key==='Escape'){hideCreateHostelModal();hideUpdateHostelModal();hideDeleteHostelModal();} });

            /* Create */
            const cf = document.getElementById('createHostelForm');
            cf.addEventListener('submit', e => { e.preventDefault(); handleForm('/Hostel/CreateHostel', cf, ()=>hideCreateHostelModal()); });
            window.showCreateHostelModal = () => { cf.reset(); generateBedDistributionInputs(); document.getElementById('createHostelModal').classList.remove('hidden'); };
            window.hideCreateHostelModal = () => document.getElementById('createHostelModal').classList.add('hidden');

            /* Update */
            const uf = document.getElementById('updateHostelForm');
            uf.addEventListener('submit', e => {
                e.preventDefault();
                const id = document.getElementById('updateHostelIDForUrl').value;
                handleForm(`/Hostel/UpdateHostel/${id}`, uf, ()=>hideUpdateHostelModal());
            });
            window.showUpdateHostelModal = async id => {
                $ld();
                try {
                    const r = await fetch(`/Hostel/GetHostel/${id}`);
                    if (!r.ok) throw new Error();
                    const h = await r.json();
                    document.getElementById('updateHostelID').value            = h.id;
                    document.getElementById('updateHostelIDForUrl').value      = h.id;
                    document.getElementById('updateHostelName').value          = h.name;
                    document.getElementById('updateCampusID').value            = h.campusId;
                    document.getElementById('updateGender').value              = h.gender;
                    document.getElementById('updateWardenID').value            = h.wardenId||'';
                    document.getElementById('updateTotalRooms').value          = h.totalRooms;
                    document.getElementById('updateStatus').value              = h.status;
                    document.getElementById('updateDescription').value         = h.description||'';
                    document.getElementById('updateDefaultRoomType').value     = h.defaultRoomType;
                    document.getElementById('updateDefaultCapacity').value     = h.defaultCapacity;
                    document.getElementById('updateRoomsPerFloor').value       = h.roomsPerFloor;
                    document.getElementById('updateRoomNumberingPattern').value= h.roomNumberingPattern;
                    document.getElementById('updateAutoGenerateBeds').checked  = h.autoGenerateBeds;
                    document.getElementById('updateHostelModal').classList.remove('hidden');
                } catch { showNotif('Error loading hostel data.','error'); }
                finally { $uld(); }
            };
            window.hideUpdateHostelModal = () => document.getElementById('updateHostelModal').classList.add('hidden');

            /* Delete */
            const df = document.getElementById('deleteHostelForm');
            const cdb = document.getElementById('confirmDeleteBtn');
            df.addEventListener('submit', async e => {
                e.preventDefault();
                const orig = cdb.innerHTML;
                cdb.disabled=true; cdb.innerHTML='<i class="material-icons li-spin">refresh</i><span>Deleting…</span>'; $ld();
                try {
                    const r = await fetch('/Hostel/DeleteHostel', { method:'POST', body:new FormData(df) });
                    if (r.redirected) { window.location.href=r.url; return; }
                    if (r.ok) { hideDeleteHostelModal(); showNotif('Hostel deleted successfully!'); setTimeout(()=>location.reload(),1000); }
                    else { let t=await r.text(); try{const d=new DOMParser().parseFromString(t,'text/html');const em=d.querySelector('.validation-summary-errors,.field-validation-error');if(em)t=em.textContent.trim();}catch{} showNotif(t,'error'); }
                } catch { showNotif('Network error. Please try again.','error'); }
                finally { cdb.disabled=false; cdb.innerHTML=orig; $uld(); }
            });
            window.showDeleteHostelModal = async (id, name) => {
                document.getElementById('deleteHostelID').value = id;
                document.getElementById('deleteHostelName').textContent = name;
                $ld();
                try {
                    const r = await fetch(`/Hostel/GetHostel/${id}`);
                    if (!r.ok) throw new Error();
                    const h = await r.json();
                    const hasRooms = h.statistics && h.statistics.totalRooms > 0;
                    document.getElementById('hasRoomsWarning').classList.toggle('hidden', !hasRooms);
                    cdb.disabled = hasRooms;
                    cdb.style.opacity = hasRooms ? '.5' : '1';
                    cdb.style.cursor  = hasRooms ? 'not-allowed' : '';
                } catch { document.getElementById('hasRoomsWarning').classList.add('hidden'); }
                finally { $uld(); document.getElementById('deleteHostelModal').classList.remove('hidden'); }
            };
            window.hideDeleteHostelModal = () => document.getElementById('deleteHostelModal').classList.add('hidden');
        });
    </script>
}
