@model SIS.Models.StudentAccommodation.AccommodationApplication
@{
    var config = ViewBag.Config as SIS.Models.StudentAccommodation.AccomodationConfiguration;
    var application = ViewBag.Application as SIS.Models.StudentAccommodation.AccommodationApplication;
    var reservationExpiryTime = ViewBag.ReservationExpiryTime as DateTime?;
    var isReservationExpired = ViewBag.IsReservationExpired as bool? ?? false;
    var studentBalance = ViewBag.StudentBalance as decimal? ?? 0;

    var period = application?.Period;
    decimal accommodationFee = 0;
    string feeDisplay = "";
    if (period != null)
    {
        if (period.TypeOfPayment == "PerDay")
        {
            var numberOfDays = application?.NumberOfDays ?? 1;
            accommodationFee = period.TypeOfPaymentAmount * numberOfDays;
            feeDisplay = $"K{period.TypeOfPaymentAmount:N2}/day × {numberOfDays} days";
        }
        else
        {
            accommodationFee = period.TypeOfPaymentAmount;
            feeDisplay = $"K{accommodationFee:N2} ({period.TypeOfPayment})";
        }
    }

    var hasSufficientBalance = studentBalance >= accommodationFee;
    ViewData["Title"] = "Application Status";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap');

        :root {
            --coral: #e85c5c;
            --coral-d: #c94040;
            --navy: #1e2d5e;
            --navy-l: #2e3f7a;
            --mist: #f5f7fa;
            --border: #e8ecf2;
            --ink: #1a1f2e;
            --text: #475569;
            --green: #16a34a;
            --green-l: #dcfce7;
        }

        .as-wrap {
            font-family: 'DM Sans',sans-serif;
        }

        /* ── Hero ──────────────────────────── */
        .as-hero {
            background: linear-gradient(135deg,var(--navy) 0%,var(--navy-l) 55%,#3a2060 100%);
            border-radius: 1.25rem;
            padding: 1.75rem 2rem 4rem;
            position: relative;
            overflow: hidden;
        }

            .as-hero::before {
                content: '';
                position: absolute;
                top: -50px;
                right: -50px;
                width: 200px;
                height: 200px;
                background: rgba(232,92,92,.15);
                border-radius: 50%;
                pointer-events: none;
            }

            .as-hero::after {
                content: '';
                position: absolute;
                bottom: -60px;
                left: 25%;
                width: 280px;
                height: 280px;
                background: rgba(255,255,255,.03);
                border-radius: 50%;
                pointer-events: none;
            }

        .hero-inner {
            position: relative;
            z-index: 1;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .hero-eyebrow {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: rgba(255,255,255,.5);
            margin-bottom: .35rem;
        }

        .hero-title {
            font-family: 'DM Serif Display',serif;
            font-size: 1.85rem;
            color: #fff;
            line-height: 1.2;
            margin-bottom: .3rem;
        }

        .hero-sub {
            font-size: .82rem;
            color: rgba(255,255,255,.55);
        }

        /* hero status pill */
        .hero-status-pill {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .45rem .9rem;
            border-radius: 2rem;
            font-size: .75rem;
            font-weight: 700;
            align-self: flex-start;
        }

            .hero-status-pill i {
                font-size: .85rem;
            }

            .hero-status-pill.pending {
                background: rgba(245,158,11,.2);
                color: #fde68a;
                border: 1px solid rgba(245,158,11,.35);
            }

            .hero-status-pill.expired {
                background: rgba(232,92,92,.2);
                color: #fca5a5;
                border: 1px solid rgba(232,92,92,.35);
            }

        /* ── Main two-col layout ───────────── */
        .as-cols {
            margin-top: -2.25rem;
            position: relative;
            z-index: 2;
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 1.25rem;
            align-items: start;
        }

        .as-left, .as-right {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        /* ── Cards ─────────────────────────── */
        .aa-card {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            box-shadow: 0 2px 12px rgba(30,45,94,.06);
            overflow: hidden;
        }

        .aa-card-head {
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: .5rem;
        }

            .aa-card-head i {
                font-size: 1rem;
                color: var(--coral);
            }

        .aa-card-title {
            font-family: 'DM Serif Display',serif;
            font-size: .95rem;
            color: var(--ink);
        }

        .aa-card-body {
            padding: 1.25rem;
        }

        /* ── Expired state ─────────────────── */
        .expired-banner {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            background: #fef2f2;
            border: 1.5px solid #fecaca;
            border-radius: .85rem;
            padding: 1.25rem 1.35rem;
        }

        .expired-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            flex-shrink: 0;
            background: #fee2e2;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .expired-icon i {
                font-size: 1.3rem;
                color: var(--coral);
            }

        .expired-title {
            font-family: 'DM Serif Display',serif;
            font-size: 1.1rem;
            color: #991b1b;
            margin-bottom: .3rem;
        }

        .expired-text {
            font-size: .8rem;
            color: #7f1d1d;
            line-height: 1.6;
        }

        /* ── Status banner (pending) ───────── */
        .status-banner {
            display: flex;
            align-items: center;
            gap: .85rem;
            padding: .9rem 1.1rem;
            border-radius: .75rem;
        }

            .status-banner.pending {
                background: #fffbeb;
                border: 1.5px solid #fde68a;
            }

        .status-banner-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .status-banner.pending .status-banner-icon {
            background: #fef3c7;
        }

            .status-banner.pending .status-banner-icon i {
                color: #d97706;
                font-size: 1.1rem;
            }

        .status-banner-title {
            font-size: .88rem;
            font-weight: 700;
            color: #92400e;
        }

        .status-banner-sub {
            font-size: .75rem;
            color: #a16207;
            margin-top: .1rem;
        }

        /* ── Fee summary ───────────────────── */
        .fee-hero {
            background: linear-gradient(135deg,#fffbeb,#fef3c7);
            border: 1.5px solid #fde68a;
            border-radius: .85rem;
            padding: 1.1rem 1.25rem;
        }

        .fee-hero-lbl {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: #a16207;
            margin-bottom: .25rem;
        }

        .fee-hero-amount {
            font-family: 'DM Serif Display',serif;
            font-size: 2.2rem;
            color: #92400e;
            line-height: 1;
            margin-bottom: .2rem;
        }

        .fee-hero-break {
            font-size: .75rem;
            color: #a16207;
            margin-bottom: .85rem;
        }

        .fee-cells {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: .5rem;
        }

        .fee-cell {
            background: rgba(255,255,255,.7);
            border: 1px solid #fde68a;
            border-radius: .5rem;
            padding: .5rem .6rem;
            text-align: center;
        }

        .fee-cell-lbl {
            font-size: .62rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #a16207;
            margin-bottom: .15rem;
        }

        .fee-cell-val {
            font-size: .88rem;
            font-weight: 800;
            color: #92400e;
        }

        /* ── Countdown ─────────────────────── */
        .countdown-card {
            background: #fff;
            border-radius: 1rem;
            border: 1.5px solid #fde68a;
            box-shadow: 0 2px 12px rgba(245,158,11,.1);
            overflow: hidden;
        }

        .countdown-head {
            padding: .8rem 1.1rem;
            border-bottom: 1px solid #fde68a;
            display: flex;
            align-items: center;
            gap: .45rem;
            background: linear-gradient(135deg,#fffbeb,#fef3c7);
        }

            .countdown-head i {
                font-size: .95rem;
                color: #d97706;
            }

            .countdown-head span {
                font-family: 'DM Serif Display',serif;
                font-size: .9rem;
                color: #92400e;
            }

        .countdown-body {
            padding: 1rem 1.1rem;
        }

        .countdown-display {
            display: flex;
            justify-content: center;
            gap: .65rem;
            margin-bottom: .75rem;
        }

        .countdown-item {
            background: var(--mist);
            border: 1.5px solid var(--border);
            border-radius: .6rem;
            padding: .6rem .5rem;
            min-width: 72px;
            text-align: center;
        }

        .countdown-val {
            font-family: 'DM Serif Display',serif;
            font-size: 1.75rem;
            color: #d97706;
            display: block;
            line-height: 1;
        }

        .countdown-lbl {
            font-size: .62rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #a16207;
            margin-top: .2rem;
        }

        .countdown-deadline {
            font-size: .72rem;
            color: #a16207;
            text-align: center;
        }

            .countdown-deadline strong {
                color: #92400e;
            }

        /* ── Detail grids ──────────────────── */
        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(150px,1fr));
            gap: .5rem;
        }

        .detail-cell {
            background: var(--mist);
            border: 1px solid var(--border);
            border-radius: .55rem;
            padding: .6rem .75rem;
        }

        .detail-lbl {
            font-size: .65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #94a3b8;
            margin-bottom: .15rem;
        }

        .detail-val {
            font-size: .84rem;
            font-weight: 700;
            color: var(--ink);
        }

            .detail-val.teal {
                color: #0d9488;
            }

            .detail-val.amber {
                color: #d97706;
            }

        /* payment type badge */
        .pay-badge {
            display: inline-flex;
            align-items: center;
            font-size: .68rem;
            font-weight: 700;
            padding: .2rem .55rem;
            border-radius: 2rem;
        }

            .pay-badge.semester {
                background: #dbeafe;
                color: #1d4ed8;
            }

            .pay-badge.year {
                background: var(--green-l);
                color: #166534;
            }

            .pay-badge.perday {
                background: #ffedd5;
                color: #9a3412;
            }

            .pay-badge.fixed {
                background: #f3e8ff;
                color: #7c3aed;
            }

        /* ── Alert callouts ────────────────── */
        .callout {
            display: flex;
            align-items: flex-start;
            gap: .7rem;
            border-radius: .65rem;
            padding: .85rem 1rem;
        }

            .callout i {
                font-size: 1rem;
                flex-shrink: 0;
                margin-top: .05rem;
            }

        .callout-text {
            font-size: .78rem;
            line-height: 1.65;
        }

            .callout-text strong {
                font-weight: 700;
            }

        .callout-warning {
            background: #fffbeb;
            border: 1.5px solid #fde68a;
            color: #92400e;
        }

            .callout-warning i {
                color: #d97706;
            }

        .callout-danger {
            background: #fef2f2;
            border: 1.5px solid #fecaca;
            color: #991b1b;
        }

            .callout-danger i {
                color: var(--coral);
            }

        .callout-blue {
            background: #eff6ff;
            border: 1.5px solid #bfdbfe;
            color: #1e40af;
        }

            .callout-blue i {
                color: #2563eb;
            }

        /* ── Right panel ───────────────────── */

        /* balance display */
        .balance-box {
            border-radius: .75rem;
            padding: 1rem 1.1rem;
            text-align: center;
            border: 1.5px solid;
        }

            .balance-box.ok {
                background: #f0fdf4;
                border-color: #86efac;
            }

            .balance-box.low {
                background: #fef2f2;
                border-color: #fecaca;
            }

        .balance-lbl {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: .4rem;
        }

        .balance-box.ok .balance-lbl {
            color: #166534;
        }

        .balance-box.low .balance-lbl {
            color: #991b1b;
        }

        .balance-amount {
            font-family: 'DM Serif Display',serif;
            font-size: 2rem;
            margin-bottom: .35rem;
        }

        .balance-box.ok .balance-amount {
            color: var(--green);
        }

        .balance-box.low .balance-amount {
            color: var(--coral);
        }

        .balance-status {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            font-size: .75rem;
            font-weight: 700;
            padding: .2rem .55rem;
            border-radius: 2rem;
        }

        .balance-box.ok .balance-status {
            background: var(--green-l);
            color: #166534;
        }

        .balance-box.low .balance-status {
            background: #fee2e2;
            color: #991b1b;
        }

        .balance-status i {
            font-size: .8rem;
        }

        /* fee comparison mini grid */
        .fee-compare {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(110px,1fr));
            gap: .5rem;
        }

        .fee-compare-cell {
            background: var(--mist);
            border: 1px solid var(--border);
            border-radius: .55rem;
            padding: .6rem .75rem;
            text-align: center;
        }

        .fee-compare-lbl {
            font-size: .65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #94a3b8;
            margin-bottom: .2rem;
        }

        .fee-compare-val {
            font-size: 1rem;
            font-weight: 800;
            color: var(--ink);
        }

        /* payment method tiles */
        .pay-method {
            background: var(--mist);
            border: 1.5px solid var(--border);
            border-radius: .75rem;
            padding: .9rem 1rem;
            transition: border-color .15s,box-shadow .15s;
        }

            .pay-method:not(.disabled):hover {
                border-color: var(--coral);
                box-shadow: 0 4px 16px rgba(232,92,92,.1);
            }

            .pay-method.disabled {
                opacity: .55;
                pointer-events: none;
            }

        .pay-method-head {
            display: flex;
            align-items: center;
            gap: .5rem;
            margin-bottom: .45rem;
        }

        .pay-method-icon {
            width: 30px;
            height: 30px;
            border-radius: .4rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .pay-method-icon i {
                font-size: .95rem;
            }

        .pay-method-title {
            font-size: .85rem;
            font-weight: 700;
            color: var(--ink);
        }

        .pay-method-desc {
            font-size: .75rem;
            color: var(--text);
            line-height: 1.55;
            margin-bottom: .75rem;
        }

        /* action buttons */
        .btn-pay-balance {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            background: var(--green);
            color: #fff;
            border: none;
            border-radius: .6rem;
            font-size: .82rem;
            font-weight: 700;
            font-family: inherit;
            padding: .6rem;
            cursor: pointer;
            transition: background .15s;
            box-shadow: 0 4px 12px rgba(22,163,74,.25);
        }

            .btn-pay-balance:hover {
                background: #15803d;
            }

            .btn-pay-balance i {
                font-size: .9rem;
            }

        .btn-pay-momo {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            background: #d97706;
            color: #fff;
            border: none;
            border-radius: .6rem;
            font-size: .82rem;
            font-weight: 700;
            font-family: inherit;
            padding: .6rem;
            cursor: pointer;
            transition: background .15s;
            box-shadow: 0 4px 12px rgba(217,119,6,.25);
        }

            .btn-pay-momo:hover {
                background: #b45309;
            }

            .btn-pay-momo i {
                font-size: .9rem;
            }

        .btn-disabled {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            background: #e2e8f0;
            color: #94a3b8;
            border: none;
            border-radius: .6rem;
            font-size: .82rem;
            font-weight: 700;
            font-family: inherit;
            padding: .6rem;
            cursor: not-allowed;
            opacity: .7;
        }

            .btn-disabled i {
                font-size: .9rem;
            }

        .btn-secondary-row {
            display: flex;
            gap: .65rem;
        }

        .btn-refresh-sm {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .35rem;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: .6rem;
            font-size: .78rem;
            font-weight: 700;
            font-family: inherit;
            padding: .55rem;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-refresh-sm:hover {
                background: var(--navy-l);
            }

            .btn-refresh-sm i {
                font-size: .85rem;
            }

        .btn-home-sm {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .35rem;
            background: var(--mist);
            color: var(--text);
            text-decoration: none;
            border: 1.5px solid var(--border);
            border-radius: .6rem;
            font-size: .78rem;
            font-weight: 700;
            font-family: inherit;
            padding: .55rem;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-home-sm:hover {
                background: #e2e8f0;
                color: var(--ink);
            }

            .btn-home-sm i {
                font-size: .85rem;
            }

        /* expired action row */
        .btn-new-app {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            background: var(--coral);
            color: #fff;
            border: none;
            border-radius: .65rem;
            font-size: .82rem;
            font-weight: 700;
            font-family: inherit;
            padding: .65rem 1.25rem;
            cursor: pointer;
            transition: background .15s;
            text-decoration: none;
            box-shadow: 0 4px 12px rgba(232,92,92,.25);
        }

            .btn-new-app:hover {
                background: var(--coral-d);
                color: #fff;
            }

        /* ── Loading overlay ───────────────── */
        .loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,20,40,.55);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

            .loading-overlay.show {
                display: flex;
            }

        .loading-box {
            background: #fff;
            border-radius: 1rem;
            padding: 1.75rem 2.25rem;
            text-align: center;
            box-shadow: 0 20px 40px rgba(15,20,40,.2);
        }

        .spin {
            animation: spin 1s linear infinite;
            font-size: 2rem;
            color: var(--coral);
            display: block;
            margin: 0 auto .65rem;
        }
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .loading-box h3 {
            font-family: 'DM Serif Display',serif;
            font-size: 1rem;
            color: var(--ink);
        }

        @@media (max-width:960px) {
            .as-cols {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width:540px) {
            .detail-grid {
                grid-template-columns: 1fr 1fr;
            }

            .fee-cells {
                grid-template-columns: 1fr 1fr 1fr;
            }

            .countdown-item {
                min-width: 62px;
            }

            .countdown-val {
                font-size: 1.4rem;
            }
        }
    </style>
}

<!-- Loading overlay -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="loading-box">
        <i class="material-icons spin">refresh</i>
        <h3>Processing…</h3>
    </div>
</div>

<div class="as-wrap p-4 md:p-6">

    <!-- Hero -->
    <div class="as-hero mb-6">
        <div class="hero-inner">
            <div>
                <p class="hero-eyebrow">Student Accommodation</p>
                <h1 class="hero-title">Application Status</h1>
                <p class="hero-sub">Track your application and complete payment to secure your bed space</p>
            </div>
            @if (isReservationExpired)
            {
                <span class="hero-status-pill expired"><i class="material-icons">error</i> Expired</span>
            }
            else
            {
                <span class="hero-status-pill pending"><i class="material-icons">hourglass_empty</i> Payment Pending</span>
            }
        </div>
    </div>

    <!-- ── Expired state ── -->
    @if (isReservationExpired)
    {
        <div style="max-width:680px; margin:0 auto; display:flex; flex-direction:column; gap:1.25rem;">

            <div class="expired-banner">
                <div class="expired-icon"><i class="material-icons">block</i></div>
                <div>
                    <p class="expired-title">Reservation Expired</p>
                    <p class="expired-text">Your bed reservation expired on <strong>@reservationExpiryTime?.ToString("MMMM dd, yyyy 'at' hh:mm tt")</strong>. Payment was not received within the @config?.ReservationHoursValidity-hour deadline, so the bed space has been released back to inventory.</p>
                </div>
            </div>

            <div class="callout callout-danger">
                <i class="material-icons">warning</i>
                <p class="callout-text">You may submit a new application if the accommodation period is still open. Your previous selection is no longer reserved.</p>
            </div>

            <div style="display:flex; gap:.65rem; flex-wrap:wrap;">
                <a href="@Url.Action("Index", "StudentAccommodationApplication")" class="btn-new-app">
                    <i class="material-icons" style="font-size:.9rem;">add_circle</i> Submit New Application
                </a>
                <a href="/" class="btn-home-sm" style="flex:0 0 auto;padding:.65rem 1rem;">
                    <i class="material-icons" style="font-size:.9rem;">home</i> Dashboard
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- ── Active pending state — two columns ── -->
        <div class="as-cols">

            <!-- Left panel -->
            <div class="as-left">

                <!-- Status banner -->
                <div class="status-banner pending">
                    <div class="status-banner-icon"><i class="material-icons">hourglass_empty</i></div>
                    <div>
                        <p class="status-banner-title">Application Pending Payment</p>
                        <p class="status-banner-sub">Complete payment before the deadline to secure your bed space</p>
                    </div>
                </div>

                <!-- Fee summary -->
                @if (period != null && accommodationFee > 0)
                {
                    <div class="fee-hero">
                        <p class="fee-hero-lbl">Accommodation Fee</p>
                        <p class="fee-hero-amount">K @accommodationFee.ToString("N2")</p>
                        <p class="fee-hero-break">@feeDisplay</p>
                        @if (period.TypeOfPayment == "PerDay")
                        {
                            <div class="fee-cells">
                                <div class="fee-cell"><p class="fee-cell-lbl">Rate/Day</p><p class="fee-cell-val">K @period.TypeOfPaymentAmount.ToString("N2")</p></div>
                                <div class="fee-cell"><p class="fee-cell-lbl">Days</p><p class="fee-cell-val">@(application?.NumberOfDays ?? 1)</p></div>
                                <div class="fee-cell"><p class="fee-cell-lbl">Total</p><p class="fee-cell-val">K @accommodationFee.ToString("N2")</p></div>
                            </div>
                        }
                    </div>
                }

                <!-- Countdown timer -->
                @if (reservationExpiryTime.HasValue)
                {
                    <div class="countdown-card">
                        <div class="countdown-head">
                            <i class="material-icons">timer</i>
                            <span>Time Remaining to Complete Payment</span>
                        </div>
                        <div class="countdown-body">
                            <div class="countdown-display">
                                <div class="countdown-item"><span class="countdown-val" id="hoursLeft">--</span><p class="countdown-lbl">Hours</p></div>
                                <div class="countdown-item"><span class="countdown-val" id="minutesLeft">--</span><p class="countdown-lbl">Minutes</p></div>
                                <div class="countdown-item"><span class="countdown-val" id="secondsLeft">--</span><p class="countdown-lbl">Seconds</p></div>
                            </div>
                            <p class="countdown-deadline"><strong>Deadline:</strong> @reservationExpiryTime?.ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
                        </div>
                    </div>
                }

                <!-- Application details -->
                <div class="aa-card">
                    <div class="aa-card-head">
                        <i class="material-icons">info</i>
                        <h3 class="aa-card-title">Application Details</h3>
                    </div>
                    <div class="aa-card-body">
                        <div class="detail-grid">
                            <div class="detail-cell"><p class="detail-lbl">Application ID</p><p class="detail-val">#@application?.ApplicationId</p></div>
                            <div class="detail-cell"><p class="detail-lbl">Date</p><p class="detail-val">@application?.ApplicationDate.ToString("MMM dd, yyyy")</p></div>
                            <div class="detail-cell">
                                <p class="detail-lbl">Status</p>
                                <p class="detail-val amber">@application?.Status</p>
                            </div>
                            <div class="detail-cell"><p class="detail-lbl">Period Type</p><p class="detail-val">@period?.Type</p></div>
                            <div class="detail-cell">
                                <p class="detail-lbl">Payment Type</p>
                                <span class="pay-badge @period?.TypeOfPayment?.ToLower()">@period?.TypeOfPayment</span>
                            </div>
                            @if (period?.TypeOfPayment == "PerDay" && application?.NumberOfDays.HasValue == true)
                            {
                                <div class="detail-cell"><p class="detail-lbl">Days</p><p class="detail-val">@application.NumberOfDays days</p></div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Reserved bed space -->
                @if (application?.BedSpace != null)
                {
                    <div class="aa-card">
                        <div class="aa-card-head">
                            <i class="material-icons">bed</i>
                            <h3 class="aa-card-title">Reserved Bed Space</h3>
                        </div>
                        <div class="aa-card-body">
                            <div class="detail-grid">
                                <div class="detail-cell"><p class="detail-lbl">Campus</p><p class="detail-val teal">@application.BedSpace.Room.Hostel.Campus.CampusName</p></div>
                                <div class="detail-cell"><p class="detail-lbl">Hostel</p><p class="detail-val teal">@application.BedSpace.Room.Hostel.HostelName</p></div>
                                <div class="detail-cell"><p class="detail-lbl">Room</p><p class="detail-val">@application.BedSpace.Room.RoomNumber</p></div>
                                <div class="detail-cell"><p class="detail-lbl">Bed</p><p class="detail-val">@application.BedSpace.BedIdentifier</p></div>
                                <div class="detail-cell"><p class="detail-lbl">Room Type</p><p class="detail-val">@application.BedSpace.Room.RoomType</p></div>
                                <div class="detail-cell"><p class="detail-lbl">Floor</p><p class="detail-val">Floor @application.BedSpace.Room.Floor</p></div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Deadline warning -->
                <div class="callout callout-warning">
                    <i class="material-icons">schedule</i>
                    <p class="callout-text">
                        <strong>Important:</strong> Your reservation expires on <strong>@reservationExpiryTime?.ToString("MMMM dd, yyyy 'at' hh:mm tt")</strong>.
                        Failure to pay before this deadline will release your bed space back to the pool.
                    </p>
                </div>

            </div>

            <!-- Right panel — payment -->
            <div class="as-right">

                <div class="aa-card">
                    <div class="aa-card-head">
                        <i class="material-icons">payments</i>
                        <h3 class="aa-card-title">Payment</h3>
                    </div>
                    <div class="aa-card-body" style="display:flex;flex-direction:column;gap:1rem;">

                        <!-- Balance display -->
                        <div class="balance-box @(hasSufficientBalance ? "ok" : "low")">
                            <p class="balance-lbl">Your Available Balance</p>
                            <p class="balance-amount">K @studentBalance.ToString("N2")</p>
                            <span class="balance-status">
                                <i class="material-icons">@(hasSufficientBalance ? "check_circle" : "error")</i>
                                @(hasSufficientBalance ? "Sufficient" : "Insufficient")
                            </span>
                        </div>

                        <!-- Fee comparison -->
                        <div class="fee-compare">
                            <div class="fee-compare-cell">
                                <p class="fee-compare-lbl">Fee Required</p>
                                <p class="fee-compare-val">K @accommodationFee.ToString("N2")</p>
                            </div>
                            <div class="fee-compare-cell">
                                <p class="fee-compare-lbl">Your Balance</p>
                                <p class="fee-compare-val" style="color:@(hasSufficientBalance ? "var(--green)" : "var(--coral)");">K @studentBalance.ToString("N2")</p>
                            </div>
                            @if (!hasSufficientBalance)
                            {
                                <div class="fee-compare-cell" style="border-color:#fecaca;">
                                    <p class="fee-compare-lbl">Shortfall</p>
                                    <p class="fee-compare-val" style="color:var(--coral);">K @((accommodationFee - studentBalance).ToString("N2"))</p>
                                </div>
                            }
                        </div>

                        <!-- Pay from balance -->
                        <div class="pay-method @(hasSufficientBalance ? "" : "disabled")">
                            <div class="pay-method-head">
                                <div class="pay-method-icon" style="background:var(--green-l);">
                                    <i class="material-icons" style="color:var(--green);">account_balance_wallet</i>
                                </div>
                                <span class="pay-method-title">Pay from Balance</span>
                            </div>
                            <p class="pay-method-desc">
                                @(hasSufficientBalance
                                                            ? "Use your existing student account balance to complete payment immediately."
                                                            : "Insufficient balance. Top up your student account first to use this option.")
                            </p>
                            @if (hasSufficientBalance)
                            {
                                <button type="button" onclick="payFromBalance()" class="btn-pay-balance">
                                    <i class="material-icons">check_circle</i> Pay K @accommodationFee.ToString("N2") Now
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn-disabled" disabled>
                                    <i class="material-icons">block</i> Insufficient Balance
                                </button>
                            }
                        </div>

                        <!-- Pay with Momo/Card -->
                        <div class="pay-method">
                            <div class="pay-method-head">
                                <div class="pay-method-icon" style="background:#ffedd5;">
                                    <i class="material-icons" style="color:#d97706;">smartphone</i>
                                </div>
                                <span class="pay-method-title">Pay with Momo / Card</span>
                            </div>
                            <p class="pay-method-desc">Secure your bed space with a mobile money or card payment.</p>
                            <button type="button" onclick="showPaymentModal()" class="btn-pay-momo">
                                <i class="material-icons">bed</i> Pay for Bed Space
                            </button>
                        </div>

                        <!-- Instructions -->
                        <div class="callout callout-blue">
                            <i class="material-icons">info</i>
                            <p class="callout-text">
                                Pay <strong>K @accommodationFee.ToString("N2")</strong> on the student payment page to complete this application.
                                @if (period?.TypeOfPayment == "PerDay")
                                {
                                    <text><br><strong>Breakdown:</strong> @feeDisplay</text>
                                }
                            </p>
                        </div>

                        <!-- Refresh / home -->
                        <div class="btn-secondary-row">
                            <button type="button" class="btn-refresh-sm" onclick="location.reload()">
                                <i class="material-icons">refresh</i> Refresh
                            </button>
                            <a href="/" class="btn-home-sm">
                                <i class="material-icons">home</i> Dashboard
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    }

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const applicationId       = @(application?.ApplicationId ?? 0);
        const reservationExpiry   = new Date('@reservationExpiryTime?.ToString("yyyy-MM-ddTHH:mm:ss")');
        const accommodationFee    = @accommodationFee;
        const isExpired           = @isReservationExpired.ToString().ToLower();
        const feeBreakdown        = '@feeDisplay';
        const paymentType         = '@(period?.TypeOfPayment ?? "")';

        /* ── Countdown ── */
        function updateCountdown() {
            if (isExpired) return;
            const diff = reservationExpiry - new Date();
            if (diff <= 0) {
                ['hoursLeft','minutesLeft','secondsLeft'].forEach(id => document.getElementById(id).textContent = '00');
                Swal.fire({ icon:'error', title:'Reservation Expired', text:'Your reservation has expired. The page will reload.', confirmButtonColor:'var(--navy)', allowOutsideClick:false })
                    .then(() => location.reload());
                return;
            }
            const h = Math.floor(diff / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);
            document.getElementById('hoursLeft').textContent   = String(h).padStart(2,'0');
            document.getElementById('minutesLeft').textContent = String(m).padStart(2,'0');
            document.getElementById('secondsLeft').textContent = String(s).padStart(2,'0');

            if (h === 0 && m === 59 && s === 59)
                Swal.fire({ icon:'warning', title:'1 Hour Remaining', text:'Less than one hour left to complete payment.', confirmButtonColor:'var(--navy)', timer:5000, timerProgressBar:true });
            if (h === 0 && m === 9  && s === 59)
                Swal.fire({ icon:'error', title:'10 Minutes Left!', text:'Only 10 minutes to complete payment before your reservation expires.', confirmButtonColor:'var(--navy)', timer:8000, timerProgressBar:true });
        }

        if (!isExpired) { updateCountdown(); setInterval(updateCountdown, 1000); }

        /* ── Pay from balance ── */
        async function payFromBalance() {
            const breakdownHtml = paymentType === 'PerDay'
                ? `<p style="font-size:.75rem;color:#64748b;margin-top:.4rem;"><strong>Breakdown:</strong> ${feeBreakdown}</p>` : '';

            const result = await Swal.fire({
                title: 'Confirm Balance Payment',
                html: `
                    <div style="text-align:left;padding:0 .25rem;">
                        <p style="font-size:.82rem;color:#475569;margin-bottom:.85rem;">You are about to pay the accommodation fee from your student account balance.</p>
                        <div style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1.5px solid #86efac;border-radius:.75rem;padding:1rem;text-align:center;margin-bottom:.85rem;">
                            <p style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#166534;margin-bottom:.25rem;">Payment Amount</p>
                            <p style="font-family:'DM Serif Display',serif;font-size:2rem;color:#16a34a;margin:0;">K ${accommodationFee.toFixed(2)}</p>
                            ${breakdownHtml}
                        </div>
                        <p style="font-size:.75rem;color:#64748b;margin:0;">Upon successful payment, your bed space will be allocated immediately.</p>
                    </div>`,
                icon: 'question', showCancelButton: true,
                confirmButtonColor:'#16a34a', cancelButtonColor:'#94a3b8',
                confirmButtonText:'Proceed with Payment', cancelButtonText:'Cancel', width:'480px'
            });

            if (!result.isConfirmed) return;
            document.getElementById('loadingOverlay').classList.add('show');

            try {
                const fd = new FormData();
                fd.append('applicationId', applicationId);
                fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                const res  = await fetch('@Url.Action("PayFromBalance", "StudentAccommodationApplication")', { method:'POST', body:fd });
                const data = await res.json();
                document.getElementById('loadingOverlay').classList.remove('show');

                if (data.success) {
                    await Swal.fire({
                        icon:'success', title:'Payment Successful!',
                        html:`<div style="text-align:center;padding:.5rem 0;">
                            <p style="font-size:.82rem;color:#64748b;margin-bottom:.75rem;">${data.message}</p>
                            <div style="background:#dcfce7;border:1.5px solid #86efac;border-radius:.65rem;padding:.85rem;">
                                <p style="color:#166534;font-size:.82rem;font-weight:700;margin:0;">✅ Your bed space has been allocated!</p>
                            </div>
                        </div>`,
                        confirmButtonColor:'#16a34a', confirmButtonText:'View My Allocation',
                        allowOutsideClick:false, allowEscapeKey:false, width:'460px'
                    });
                    window.location.href = '@Url.Action("CurrentAllocation", "StudentAccommodationApplication")';
                } else {
                    Swal.fire({ icon:'error', title:'Payment Failed', text:data.message, confirmButtonColor:'var(--navy)' });
                }
            } catch {
                document.getElementById('loadingOverlay').classList.remove('show');
                Swal.fire({ icon:'error', title:'Error', text:'Failed to process payment. Please try again.', confirmButtonColor:'var(--navy)' });
            }
        }

        /* ── Pay Later (bed now) ── */
        async function getBedspaceAndPayLater() {
            const breakdownHtml = paymentType === 'PerDay'
                ? `<p style="font-size:.72rem;color:#78350f;margin-top:.4rem;"><strong>Breakdown:</strong> ${feeBreakdown}</p>` : '';

            const result = await Swal.fire({
                title:'Confirm Allocation, Pay Later',
                html:`<div style="text-align:left;padding:0 .25rem;">
                    <div style="background:#fffbeb;border:1.5px solid #fde68a;border-radius:.65rem;padding:.85rem 1rem;margin-bottom:.75rem;">
                        <p style="font-size:.72rem;font-weight:700;color:#92400e;margin-bottom:.35rem;">⚠️ Important Notice</p>
                        <p style="font-size:.78rem;color:#78350f;line-height:1.6;margin:0;"><strong>K ${accommodationFee.toFixed(2)}</strong> will be added to your outstanding fees and must be paid before examinations, transcripts, and graduation.${breakdownHtml}</p>
                    </div>
                    <p style="font-size:.72rem;color:#64748b;margin:0;">By confirming you accept these payment terms.</p>
                </div>`,
                icon:'warning', showCancelButton:true,
                confirmButtonColor:'#d97706', cancelButtonColor:'#94a3b8',
                confirmButtonText:'Allocate Now', cancelButtonText:'Cancel', width:'460px'
            });

            if (!result.isConfirmed) return;
            document.getElementById('loadingOverlay').classList.add('show');

            try {
                const fd = new FormData();
                fd.append('applicationId', applicationId);
                fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                const res  = await fetch('@Url.Action("GetBedspaceAndPayLater", "StudentAccommodationApplication")', { method:'POST', body:fd });
                const data = await res.json();
                document.getElementById('loadingOverlay').classList.remove('show');

                if (data.success) {
                    await Swal.fire({
                        icon:'success', title:'Bed Space Allocated!',
                        html:`<div style="text-align:center;padding:.5rem 0;">
                            <p style="font-size:.82rem;color:#64748b;margin-bottom:.75rem;">${data.message}</p>
                            <div style="background:#fffbeb;border:1.5px solid #fde68a;border-radius:.65rem;padding:.75rem;">
                                <p style="font-size:.75rem;color:#92400e;font-weight:700;margin:0;">K ${accommodationFee.toFixed(2)} added to outstanding fees. Pay before examination period.</p>
                            </div>
                        </div>`,
                        confirmButtonColor:'#16a34a', confirmButtonText:'View My Allocation',
                        allowOutsideClick:false, allowEscapeKey:false, width:'460px'
                    });
                    window.location.href = '@Url.Action("CurrentAllocation", "StudentAccommodationApplication")';
                } else {
                    Swal.fire({ icon:'error', title:'Allocation Failed', text:data.message, confirmButtonColor:'var(--navy)' });
                }
            } catch {
                document.getElementById('loadingOverlay').classList.remove('show');
                Swal.fire({ icon:'error', title:'Error', text:'Failed to process. Please try again.', confirmButtonColor:'var(--navy)' });
            }
        }
    </script>

    @Html.AntiForgeryToken()
}

@await Html.PartialAsync("~/Views/Home/_PaymentModal.cshtml")
