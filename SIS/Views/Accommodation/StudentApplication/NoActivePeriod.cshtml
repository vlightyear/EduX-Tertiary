@{
    ViewData["Title"] = "No Active Period";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap');

        :root {
            --coral: #e85c5c;
            --coral-d: #c94040;
            --navy: #1e2d5e;
            --navy-l: #2e3f7a;
            --mist: #f5f7fa;
            --border: #e8ecf2;
            --ink: #1a1f2e;
            --text: #475569;
        }

        .np-wrap {
            font-family: 'DM Sans',sans-serif;
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        /* ── Card ─────────────────────── */
        .np-card {
            background: #fff;
            border-radius: 1.25rem;
            border: 1px solid var(--border);
            box-shadow: 0 8px 40px rgba(30,45,94,.1);
            width: 100%;
            max-width: 620px;
            overflow: hidden;
        }

        /* ── Hero band ────────────────── */
        .np-hero {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-l) 55%, #3a2060 100%);
            padding: 2.5rem 2rem 3.5rem;
            position: relative;
            overflow: hidden;
            text-align: center;
        }

            .np-hero::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 160px;
                height: 160px;
                background: rgba(232,92,92,.15);
                border-radius: 50%;
                pointer-events: none;
            }

            .np-hero::after {
                content: '';
                position: absolute;
                bottom: -50px;
                left: 20%;
                width: 220px;
                height: 220px;
                background: rgba(255,255,255,.03);
                border-radius: 50%;
                pointer-events: none;
            }

        /* floating icon ring */
        .icon-ring {
            position: relative;
            z-index: 1;
            width: 76px;
            height: 76px;
            border-radius: 50%;
            background: rgba(255,255,255,.12);
            border: 2px solid rgba(255,255,255,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
            animation: float 3.5s ease-in-out infinite;
        }

            .icon-ring i {
                font-size: 2rem;
                color: #fff;
            }

        .icon-ring-badge {
            position: absolute;
            bottom: -4px;
            right: -4px;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: var(--coral);
            border: 2px solid var(--navy);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .icon-ring-badge i {
                font-size: .7rem;
                color: #fff;
            }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        .np-hero-title {
            font-family: 'DM Serif Display',serif;
            font-size: 1.65rem;
            color: #fff;
            line-height: 1.25;
            position: relative;
            z-index: 1;
            margin-bottom: .4rem;
        }

        .np-hero-sub {
            font-size: .82rem;
            color: rgba(255,255,255,.6);
            position: relative;
            z-index: 1;
            line-height: 1.6;
            max-width: 380px;
            margin: 0 auto;
        }

        /* ── Body ─────────────────────── */
        .np-body {
            padding: 2rem;
            margin-top: -1.75rem;
        }

        /* message card — floats above body */
        .np-message {
            background: #fff;
            border-radius: .85rem;
            border: 1px solid var(--border);
            box-shadow: 0 4px 20px rgba(30,45,94,.08);
            padding: 1.1rem 1.35rem;
            margin-bottom: 1.5rem;
            font-size: .85rem;
            color: var(--text);
            line-height: 1.7;
            position: relative;
            z-index: 1;
        }

        /* info list */
        .info-list {
            display: flex;
            flex-direction: column;
            gap: .5rem;
            margin-bottom: 1.5rem;
        }

        .info-item {
            display: flex;
            align-items: flex-start;
            gap: .75rem;
            background: var(--mist);
            border: 1px solid var(--border);
            border-radius: .65rem;
            padding: .75rem .9rem;
        }

        .info-item-icon {
            width: 28px;
            height: 28px;
            border-radius: .4rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .info-item-icon i {
                font-size: .9rem;
            }

        .info-item-text {
            font-size: .8rem;
            color: var(--text);
            line-height: 1.6;
        }

        /* tip banner */
        .tip-banner {
            display: flex;
            align-items: flex-start;
            gap: .7rem;
            background: #fffbeb;
            border: 1.5px solid #fde68a;
            border-radius: .65rem;
            padding: .75rem .9rem;
            margin-bottom: 1.5rem;
        }

            .tip-banner i {
                font-size: 1rem;
                color: #d97706;
                flex-shrink: 0;
                margin-top: .05rem;
            }

        .tip-banner-text {
            font-size: .78rem;
            color: #92400e;
            line-height: 1.6;
        }

            .tip-banner-text strong {
                font-weight: 700;
            }

        /* actions */
        .np-actions {
            display: flex;
            gap: .65rem;
            flex-wrap: wrap;
        }

        .btn-dash {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            background: var(--navy);
            color: #fff;
            border: none;
            font-size: .82rem;
            font-weight: 700;
            font-family: inherit;
            padding: .65rem 1.25rem;
            border-radius: .7rem;
            text-decoration: none;
            cursor: pointer;
            transition: background .15s;
            box-shadow: 0 4px 14px rgba(30,45,94,.25);
        }

            .btn-dash:hover {
                background: var(--navy-l);
                color: #fff;
            }

            .btn-dash i {
                font-size: .9rem;
            }

        .btn-refresh {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            background: var(--mist);
            color: var(--text);
            border: 1.5px solid var(--border);
            font-size: .82rem;
            font-weight: 600;
            font-family: inherit;
            padding: .65rem 1rem;
            border-radius: .7rem;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-refresh:hover {
                background: #e2e8f0;
            }

            .btn-refresh i {
                font-size: .9rem;
            }

        @@media (max-width: 480px) {
            .np-actions {
                flex-direction: column;
            }

            .btn-dash, .btn-refresh {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}

<div class="np-wrap">
    <div class="np-card">

        <!-- Hero band -->
        <div class="np-hero">
            <div class="icon-ring">
                <i class="material-icons">hotel</i>
                <span class="icon-ring-badge"><i class="material-icons">schedule</i></span>
            </div>
            <h1 class="np-hero-title">No Active Accommodation Period</h1>
            <p class="np-hero-sub">The accommodation application window is currently closed.</p>
        </div>

        <!-- Body -->
        <div class="np-body">

            <!-- Dynamic message from controller -->
            @if (!string.IsNullOrEmpty(ViewBag.Message))
            {
                <div class="np-message">
                    <i class="material-icons" style="font-size:.9rem;vertical-align:middle;margin-right:.35rem;color:var(--coral);">info</i>
                    @ViewBag.Message
                </div>
            }

            <!-- Info items -->
            <div class="info-list">
                <div class="info-item">
                    <div class="info-item-icon" style="background:#fef2f2;">
                        <i class="material-icons" style="color:var(--coral);">event_busy</i>
                    </div>
                    <p class="info-item-text">There is currently no open application period for student accommodation.</p>
                </div>
                <div class="info-item">
                    <div class="info-item-icon" style="background:#eff6ff;">
                        <i class="material-icons" style="color:#2563eb;">calendar_today</i>
                    </div>
                    <p class="info-item-text">Accommodation applications are only accepted during designated periods announced by the university.</p>
                </div>
                <div class="info-item">
                    <div class="info-item-icon" style="background:#f0fdf4;">
                        <i class="material-icons" style="color:#16a34a;">notifications</i>
                    </div>
                    <p class="info-item-text">You will be notified by email when the next application period opens. Check back here regularly for updates.</p>
                </div>
            </div>

            <!-- Tip banner -->
            <div class="tip-banner">
                <i class="material-icons">lightbulb</i>
                <p class="tip-banner-text"><strong>Tip:</strong> Bookmark this page and check back when you receive an email notification about the next application period.</p>
            </div>

            <!-- Action buttons -->
            <div class="np-actions">
                <a href="@Url.Action("Index", "Home")" class="btn-dash">
                    <i class="material-icons">home</i> Return to Dashboard
                </a>
                <button type="button" class="btn-refresh" onclick="location.reload()">
                    <i class="material-icons">refresh</i> Refresh
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Silently poll every 5 minutes to detect if a period becomes active
        setInterval(function () {
            fetch(window.location.href, { method: 'HEAD' }).catch(() => {});
        }, 300000);
    </script>
}
