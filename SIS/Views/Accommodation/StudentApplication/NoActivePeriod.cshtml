@{
    ViewData["Title"] = "No Active Period";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-color: #16697a;
        --info-color: #3b82f6;
        --light-bg: #f8fafc;
        --border-color: #e2e8f0;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f2 100%);
        color: #334155;
    }

    .container-fluid {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .no-period-container {
        background: white;
        border-radius: 16px;
        padding: 60px 40px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        text-align: center;
        width: 100%;
        max-width: 800px;
    }

    .icon-container {
        margin-bottom: 30px;
        position: relative;
        display: inline-block;
    }

    .main-icon {
        font-size: 120px;
        color: #cbd5e1;
        animation: float 3s ease-in-out infinite;
    }

    .sub-icon {
        position: absolute;
        bottom: 10px;
        right: 10px;
        font-size: 50px;
        color: var(--info-color);
        background: white;
        border-radius: 50%;
        padding: 8px;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-20px);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }
    }

    h1 {
        font-size: 36px;
        color: var(--primary-color);
        margin-bottom: 20px;
        font-weight: 700;
    }

    .main-message {
        font-size: 20px;
        color: #64748b;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .info-box {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        border: 2px solid #93c5fd;
        border-radius: 12px;
        padding: 25px;
        margin: 30px 0;
        text-align: left;
    }

        .info-box h3 {
            color: var(--info-color);
            font-size: 20px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .info-box ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .info-box li {
            padding: 12px 0;
            color: #1e40af;
            font-size: 16px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            border-bottom: 1px solid #93c5fd;
        }

            .info-box li:last-child {
                border-bottom: none;
            }

            .info-box li i {
                color: var(--info-color);
                font-size: 24px;
                flex-shrink: 0;
                margin-top: 2px;
            }

    .contact-section {
        background: var(--light-bg);
        border-radius: 12px;
        padding: 25px;
        margin: 30px 0;
        border-left: 4px solid var(--primary-color);
    }

        .contact-section h3 {
            color: var(--primary-color);
            font-size: 20px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            justify-content: center;
        }

    .contact-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .contact-item {
        display: flex;
        align-items: center;
        gap: 12px;
        justify-content: center;
        color: #64748b;
        font-size: 16px;
    }

        .contact-item i {
            color: var(--primary-color);
            font-size: 24px;
        }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin-top: 40px;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 14px 28px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background: var(--primary-color);
        color: white;
        box-shadow: 0 4px 12px rgba(22, 105, 122, 0.3);
    }

        .btn-primary:hover {
            background: #0d4b56;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(22, 105, 122, 0.4);
        }

    .btn-secondary {
        background: white;
        color: var(--primary-color);
        border: 2px solid var(--primary-color);
    }

        .btn-secondary:hover {
            background: var(--light-bg);
            transform: translateY(-2px);
        }

    .btn i {
        font-size: 20px;
    }

    .notification-signup {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border: 2px solid #fbbf24;
        border-radius: 12px;
        padding: 20px;
        margin: 30px 0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .notification-signup i {
            font-size: 40px;
            color: #f59e0b;
            flex-shrink: 0;
        }

        .notification-signup .content {
            text-align: left;
            flex: 1;
        }

        .notification-signup h4 {
            color: #92400e;
            font-size: 18px;
            margin-bottom: 8px;
        }

        .notification-signup p {
            color: #78350f;
            font-size: 14px;
            margin: 0;
        }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .container-fluid {
            padding: 15px;
        }

        .no-period-container {
            padding: 40px 25px;
        }

        .main-icon {
            font-size: 80px;
        }

        .sub-icon {
            font-size: 35px;
        }

        h1 {
            font-size: 28px;
        }

        .main-message {
            font-size: 16px;
        }

        .contact-details {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }

        .notification-signup {
            flex-direction: column;
            text-align: center;
        }

            .notification-signup .content {
                text-align: center;
            }
    }
</style>

<div class="container-fluid">
    <div class="no-period-container">
        <!-- Icon -->
        <div class="icon-container">
            <i class="material-icons main-icon">hotel</i>
            <i class="material-icons sub-icon">schedule</i>
        </div>

        <!-- Main Heading -->
        <h1>No Active Accommodation Period</h1>

        <!-- Main Message -->
        <p class="main-message">
            @ViewBag.Message
        </p>

        <!-- Information Box -->
        <div class="info-box">
            <h3>
                <i class="material-icons">info</i>
                What This Means
            </h3>
            <ul>
                <li>
                    <i class="material-icons">event_busy</i>
                    <span>There is currently no open application period for student accommodation.</span>
                </li>
                <li>
                    <i class="material-icons">calendar_today</i>
                    <span>Accommodation applications are only accepted during designated periods announced by the university.</span>
                </li>
                <li>
                    <i class="material-icons">history</i>
                    <span>Please check back regularly or contact the accommodation office for updates on upcoming periods.</span>
                </li>
            </ul>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                <i class="material-icons">home</i>
                Return to Dashboard
            </a>
            <button type="button" class="btn btn-secondary" onclick="location.reload()">
                <i class="material-icons">refresh</i>
                Refresh Page
            </button>
        </div>

        <!-- Additional Help Text -->
        <p style="color: #94a3b8; font-size: 14px; margin-top: 40px; font-style: italic;">
            ?? Tip: Bookmark this page and check back when you receive an email notification about the next application period.
        </p>
    </div>
</div>

@section Scripts {
    <script>
        // Optional: Auto-refresh check every 5 minutes to see if a period becomes active
        setInterval(function() {
            // Silently check if page needs refresh (optional feature)
            fetch(window.location.href, { method: 'HEAD' })
                .then(response => {
                    if (response.ok) {
                        // Could implement logic here to check if period is now active
                    }
                });
        }, 300000); // 5 minutes
    </script>
}
