@model SIS.Models.StudentAccommodation.AccommodationApplication
@{
    var config = ViewBag.Config as SIS.Models.StudentAccommodation.AccomodationConfiguration;
    var availableBalance = ViewBag.AvailableBalance as decimal? ?? 0;
    ViewData["Title"] = "Application Status";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Determine status information
    var statusColor = Model.Status == SIS.Enums.Status.Pending ? "warning" :
                      Model.Status == SIS.Enums.Status.Active ? "success" :
                      Model.Status == SIS.Enums.Status.Approved ? "success" :
                      Model.Status == SIS.Enums.Status.Rejected ? "danger" : "info";

    var statusIcon = Model.Status == SIS.Enums.Status.Pending ? "schedule" :
                     Model.Status == SIS.Enums.Status.Active ? "check_circle" :
                     Model.Status == SIS.Enums.Status.Approved ? "check_circle" :
                     Model.Status == SIS.Enums.Status.Rejected ? "cancel" : "info";

    var hasAllocation = Model.Allocation != null;
    var isExpired = Model.Status == SIS.Enums.Status.Rejected &&
                   (Model.Notes?.Contains("expired", StringComparison.OrdinalIgnoreCase) ?? false);

    // Calculate time remaining for payment (if pending and no allocation)
    DateTime? paymentDeadline = null;
    TimeSpan? timeRemaining = null;
    bool isPaymentOverdue = false;

    if (Model.Status == SIS.Enums.Status.Pending && !hasAllocation && config != null)
    {
        paymentDeadline = Model.ApplicationDate.AddHours(config.ReservationHoursValidity);
        timeRemaining = paymentDeadline.Value - DateTime.Now;
        isPaymentOverdue = timeRemaining.Value.TotalHours <= 0;
    }

    // Calculate fee based on payment type
    decimal calculatedFee = 0;
    string feeDisplay = "";
    var period = Model.Period;
    if (period != null)
    {
        if (period.TypeOfPayment == "PerDay")
        {
            var numberOfDays = Model.NumberOfDays ?? 1;
            calculatedFee = period.TypeOfPaymentAmount * numberOfDays;
            feeDisplay = $"K{period.TypeOfPaymentAmount:N2}/day × {numberOfDays} days = K{calculatedFee:N2}";
        }
        else
        {
            calculatedFee = period.TypeOfPaymentAmount;
            feeDisplay = $"K{calculatedFee:N2} ({period.TypeOfPayment})";
        }
    }

    // Check if student has sufficient balance
    bool hasSufficientBalance = availableBalance >= calculatedFee;
}

<!-- SweetAlert2 CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<style>
    :root {
        --primary-color: #16697a;
        --primary-dark: #0d4b56;
        --success-color: #10b981;
        --warning-color: #f59e0b;
        --danger-color: #ef4444;
        --info-color: #3b82f6;
        --light-bg: #f8fafc;
        --border-color: #e2e8f0;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f2 100%);
