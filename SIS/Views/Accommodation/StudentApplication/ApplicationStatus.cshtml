        box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
    }

        .payment-alert.overdue {
            background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
            border-color: var(--danger-color);
        }

        .payment-alert h3 {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 20px;
            margin-bottom: 15px;
            color: #92400e;
        }

        .payment-alert.overdue h3 {
            color: #991b1b;
        }

        .payment-alert .countdown {
            font-size: 32px;
            font-weight: 800;
            text-align: center;
            margin: 20px 0;
            color: #92400e;
        }

        .payment-alert.overdue .countdown {
            color: var(--danger-color);
        }

    .payment-details {
        background: white;
        border-radius: 8px;
        padding: 20px;
        margin-top: 15px;
    }

        .payment-details .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-color);
        }

            .payment-details .detail-row:last-child {
                border-bottom: none;
            }

        .payment-details .detail-label {
            font-weight: 600;
            color: #64748b;
        }

        .payment-details .detail-value {
            font-weight: 600;
            color: var(--primary-color);
        }

        .payment-details .amount {
            font-size: 24px;
            color: var(--warning-color);
        }

    /* Balance Info Banner */
    .balance-info-banner {
        background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
        border: 2px solid #38bdf8;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 4px 12px rgba(56, 189, 248, 0.3);
    }

        .balance-info-banner.sufficient {
            background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
            border-color: var(--success-color);
        }

        .balance-info-banner h4 {
            font-size: 16px;
            margin-bottom: 10px;
            color: #0c4a6e;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .balance-info-banner.sufficient h4 {
            color: #065f46;
        }

        .balance-info-banner .balance-amount {
            font-size: 28px;
            font-weight: 800;
            color: #0369a1;
            margin-bottom: 8px;
        }

        .balance-info-banner.sufficient .balance-amount {
            color: #047857;
        }

        .balance-info-banner p {
            font-size: 14px;
            color: #0c4a6e;
            margin: 0;
        }

        .balance-info-banner.sufficient p {
            color: #065f46;
        }

    /* Info Grid */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 25px;
    }

    .info-item {
        background: var(--light-bg);
        padding: 20px;
        border-radius: 8px;
        border-left: 4px solid var(--primary-color);
    }

        .info-item .label {
            font-size: 13px;
            color: #64748b;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .info-item .value {
            font-size: 18px;
            color: var(--primary-color);
            font-weight: 600;
        }

    /* Allocation Card */
    .allocation-card {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border: 2px solid #86efac;
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: 0 4px 12px rgba(134, 239, 172, 0.3);
    }

        .allocation-card h3 {
            color: var(--success-color);
            font-size: 22px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .allocation-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }

    .allocation-item {
        background: white;
        padding: 15px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .allocation-item i {
            font-size: 28px;
            color: var(--success-color);
        }

        .allocation-item .allocation-label {
            font-size: 12px;
            color: #64748b;
            text-transform: uppercase;
            font-weight: 600;
        }

        .allocation-item .allocation-value {
            font-size: 16px;
            color: var(--primary-color);
            font-weight: 600;
        }

    /* Notes Section */
    .notes-section {
        background: var(--light-bg);
        padding: 20px;
        border-radius: 8px;
        border-left: 4px solid var(--info-color);
        margin-bottom: 25px;
    }

        .notes-section h4 {
            color: var(--primary-color);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .notes-section p {
            color: #64748b;
            line-height: 1.6;
        }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-primary {
        background: var(--primary-color);
        color: white;
    }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(22, 105, 122, 0.3);
        }

    .btn-success {
        background: var(--success-color);
        color: white;
    }

        .btn-success:hover {
            background: #059669;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

    .btn-warning {
        background: var(--warning-color);
        color: white;
    }

        .btn-warning:hover {
            background: #d97706;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
        }

    .btn-secondary {
        background: #e2e8f0;
        color: #475569;
    }

        .btn-secondary:hover {
            background: #cbd5e1;
        }

    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

        .btn:disabled:hover {
            transform: none;
            box-shadow: none;
        }

    /* Loading Overlay */
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 10000;
    }

        .loading-overlay.show {
            display: flex;
        }

    .loading-spinner {
        background: white;
        padding: 40px;
        border-radius: 12px;
        text-align: center;
    }

    .spinner {
        border: 4px solid var(--border-color);
        border-top: 4px solid var(--primary-color);
        border-radius: 50%;
        width: 50px;
        height: 50px;
        animation: spin 1s linear infinite;
        margin: 0 auto 20px;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .loading-spinner p {
        color: var(--primary-color);
        font-size: 16px;
        font-weight: 600;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .container-fluid {
            padding: 15px;
        }

        .page-header h1 {
            font-size: 24px;
        }

        .status-header {
            flex-direction: column;
            text-align: center;
        }

        .info-grid,
        .allocation-details {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="container-fluid">
    <!-- Page Header -->
    <div class="page-header">
        <h1>📋 Accommodation Application Status</h1>
        <p>View your accommodation application details and status</p>
    </div>

    <!-- Status Card -->
    <div class="status-card">
        <div class="status-header">
            <i class="material-icons status-icon @statusColor">@statusIcon</i>
            <div class="status-details">
                <h2>Application Status</h2>
                <span class="status-text @statusColor">@Model.Status.ToString()</span>
            </div>
        </div>

        <!-- Application Information -->
        <div class="info-grid">
            <div class="info-item">
                <div class="label">Application Date</div>
                <div class="value">@Model.ApplicationDate.ToString("MMMM dd, yyyy")</div>
            </div>
            <div class="info-item">
                <div class="label">Application ID</div>
                <div class="value">#@Model.ApplicationId.ToString("D6")</div>
            </div>
            <div class="info-item">
                <div class="label">Period Type</div>
                <div class="value">@Model.Period?.Type</div>
            </div>
            <div class="info-item">
                <div class="label">Payment Type</div>
                <div class="value">
                    <span class="payment-type-badge @Model.Period?.TypeOfPayment?.ToLower()">
                        @Model.Period?.TypeOfPayment
                    </span>
                </div>
            </div>
            @if (Model.Period?.TypeOfPayment == "PerDay" && Model.NumberOfDays.HasValue)
            {
                <div class="info-item">
                    <div class="label">Number of Days</div>
                    <div class="value">@Model.NumberOfDays days</div>
                </div>
            }
            <div class="info-item">
                <div class="label">Period Dates</div>
                <div class="value">
                    @Model.Period?.StartDate.ToString("MMM dd, yyyy") - @(Model.Period?.EndDate != null ? Model.Period.EndDate.Value.ToString("MMM dd, yyyy") : "Graduation")
                </div>
            </div>
        </div>

        <!-- Fee Summary Card -->
        @if (period != null && calculatedFee > 0)
        {
            <div class="fee-summary-card">
                <h4>
                    <i class="material-icons">receipt_long</i>
                    Accommodation Fee Summary
                </h4>
                <div class="fee-amount">K @calculatedFee.ToString("N2")</div>
                <div class="fee-breakdown">@feeDisplay</div>
                @if (period.TypeOfPayment == "PerDay")
                {
                    <div class="fee-details">
                        <div class="fee-detail-item">
                            <div class="label">Rate per Day</div>
                            <div class="value">K @period.TypeOfPaymentAmount.ToString("N2")</div>
                        </div>
                        <div class="fee-detail-item">
                            <div class="label">Number of Days</div>
                            <div class="value">@(Model.NumberOfDays ?? 1)</div>
                        </div>
                        <div class="fee-detail-item">
                            <div class="label">Total Fee</div>
                            <div class="value">K @calculatedFee.ToString("N2")</div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (Model.SelectedBedId.HasValue && Model.BedSpace != null)
        {
            <!-- Selected Bed Information -->
            <div style="background: #f0fdf4; border: 2px solid #bbf7d0; border-radius: 10px; padding: 20px; margin-bottom: 25px;">
                <h4 style="color: var(--success-color); font-size: 18px; margin-bottom: 15px; font-weight: 600;">
                    <i class="material-icons" style="vertical-align: middle;">check_circle</i>
                    Your Selected Bed Space
                </h4>
                <div class="info-grid">
                    <div class="info-item">
                        <div class="label">Campus</div>
                        <div class="value">@Model.BedSpace.Room?.Hostel?.Campus?.CampusName</div>
                    </div>
                    <div class="info-item">
                        <div class="label">Hostel</div>
                        <div class="value">@Model.BedSpace.Room?.Hostel?.HostelName</div>
                    </div>
                    <div class="info-item">
                        <div class="label">Room Number</div>
                        <div class="value">@Model.BedSpace.Room?.RoomNumber</div>
                    </div>
                    <div class="info-item">
                        <div class="label">Bed</div>
                        <div class="value">@Model.BedSpace.BedIdentifier</div>
                    </div>
                </div>
            </div>
        }

        @if (Model.Status == SIS.Enums.Status.Pending && !hasAllocation && config != null)
        {
            <!-- Payment Alert for Pending Applications -->
            <div class="payment-alert @(isPaymentOverdue ? "overdue" : "")">
                <h3>
                    <i class="material-icons">@(isPaymentOverdue ? "error" : "schedule")</i>
                    @(isPaymentOverdue ? "Payment Overdue!" : "Payment Required")
                </h3>

                @if (!isPaymentOverdue)
                {
                    <div class="countdown" id="countdown">
                        Calculating...
                    </div>
                    <p style="text-align: center; color: #92400e; font-weight: 600;">
                        ⏰ Time remaining to complete payment
                    </p>
                }
                else
                {
                    <div class="countdown">
                        EXPIRED
                    </div>
                    <p style="text-align: center; color: #991b1b; font-weight: 600;">
                        ⚠️ Your reservation has expired. The system will automatically cancel this application.
                    </p>
                }

                <div class="payment-details">
                    <div class="detail-row">
                        <span class="detail-label">Amount Due:</span>
                        <span class="detail-value amount">K @calculatedFee.ToString("N2")</span>
                    </div>
                    @if (period?.TypeOfPayment == "PerDay")
                    {
                        <div class="detail-row">
                            <span class="detail-label">Fee Breakdown:</span>
                            <span class="detail-value">@feeDisplay</span>
                        </div>
                    }
                    <div class="detail-row">
                        <span class="detail-label">Payment Deadline:</span>
                        <span class="detail-value">@paymentDeadline?.ToString("MMMM dd, yyyy hh:mm tt")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Payment Location:</span>
                        <span class="detail-value">@config.LocationToTakeAccommodationPaymentReceipt</span>
                    </div>
                </div>

                @if (!isPaymentOverdue)
                {
                    <!-- Balance Information -->
                    <div class="balance-info-banner @(hasSufficientBalance ? "sufficient" : "")">
                        <h4>
                            <i class="material-icons">account_balance_wallet</i>
                            Your Account Balance
                        </h4>
                        <div class="balance-amount">K @availableBalance.ToString("N2")</div>
                        @if (hasSufficientBalance)
                        {
                            <p>✅ <strong>You have sufficient balance to pay from your account!</strong></p>
                        }
                        else
                        {
                            <p>⚠️ Insufficient balance. Shortfall: K @((calculatedFee - availableBalance).ToString("N2"))</p>
                        }
                    </div>

                    <!-- Payment Action Buttons -->
                    <div class="action-buttons" style="margin-top: 20px;">
                        @if (hasSufficientBalance)
                        {
                            <button type="button" class="btn btn-success" onclick="payFromBalance()">
                                <i class="material-icons">account_balance</i>
                                Pay from Balance (K @calculatedFee.ToString("N2"))
                            </button>
                        }
                        <a href="@Url.Action("StudentPaymentSelection", "Payments")" class="btn btn-warning">
                            <i class="material-icons">payment</i>
                            Make Payment
                        </a>
                    </div>
                }
            </div>
        }

        @if (hasAllocation)
        {
            <!-- Allocation Details -->
            <div class="allocation-card">
                <h3>
                    <i class="material-icons">home</i>
                    Allocated Accommodation
                </h3>
                <div class="allocation-details">
                    <div class="allocation-item">
                        <i class="material-icons">domain</i>
                        <div>
                            <div class="allocation-label">Campus</div>
                            <div class="allocation-value">@Model.Allocation.Bed?.Room?.Hostel?.Campus?.CampusName</div>
                        </div>
                    </div>
                    <div class="allocation-item">
                        <i class="material-icons">apartment</i>
                        <div>
                            <div class="allocation-label">Hostel</div>
                            <div class="allocation-value">@Model.Allocation.Bed?.Room?.Hostel?.HostelName</div>
                        </div>
                    </div>
                    <div class="allocation-item">
                        <i class="material-icons">meeting_room</i>
                        <div>
                            <div class="allocation-label">Room</div>
                            <div class="allocation-value">@Model.Allocation.Bed?.Room?.RoomNumber</div>
                        </div>
                    </div>
                    <div class="allocation-item">
                        <i class="material-icons">bed</i>
                        <div>
                            <div class="allocation-label">Bed</div>
                            <div class="allocation-value">@Model.Allocation.Bed?.BedIdentifier</div>
                        </div>
                    </div>
                    <div class="allocation-item">
                        <i class="material-icons">layers</i>
                        <div>
                            <div class="allocation-label">Floor</div>
                            <div class="allocation-value">Floor @Model.Allocation.Bed?.Room?.Floor</div>
                        </div>
                    </div>
                    <div class="allocation-item">
                        <i class="material-icons">hotel</i>
                        <div>
                            <div class="allocation-label">Room Type</div>
                            <div class="allocation-value">@Model.Allocation.Bed?.Room?.RoomType</div>
                        </div>
                    </div>
                </div>

                <div class="info-grid" style="margin-top: 20px;">
                    <div class="info-item">
                        <div class="label">Allocation Date</div>
                        <div class="value">@Model.Allocation.AllocationDate.ToString("MMMM dd, yyyy")</div>
                    </div>
                    <div class="info-item">
                        <div class="label">Start Date</div>
                        <div class="value">@Model.Allocation.StartDate.ToString("MMMM dd, yyyy")</div>
                    </div>
                    <div class="info-item">
                        <div class="label">End Date</div>
                        <div class="value">@(Model.Allocation.EndDate?.ToString("MMMM dd, yyyy") ?? "Until Graduation")</div>
                    </div>
                    <div class="info-item">
                        <div class="label">Allocation Status</div>
                        <div class="value">@Model.Allocation.Status.ToString()</div>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <!-- Notes Section -->
            <div class="notes-section">
                <h4>
                    <i class="material-icons">note</i>
                    Additional Notes
                </h4>
                <p>@Model.Notes</p>
            </div>
        }
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons">
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
            <i class="material-icons">home</i>
            Return to Dashboard
        </a>

        @if (hasAllocation && Model.Allocation.Status == SIS.Enums.Status.Active)
        {
            <a href="@Url.Action("CurrentAllocation", "StudentAccommodationApplication")" class="btn btn-success">
                <i class="material-icons">visibility</i>
                View Full Allocation Details
            </a>
        }

        <button type="button" class="btn btn-secondary" onclick="window.print()">
            <i class="material-icons">print</i>
            Print Application
        </button>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="loading-spinner">
        <div class="spinner"></div>
        <p>Processing payment...</p>
    </div>
</div>

@section Scripts {
    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Countdown timer for payment deadline
        @if (Model.Status == SIS.Enums.Status.Pending && !hasAllocation && paymentDeadline.HasValue && !isPaymentOverdue)
        {
            <text>
                        const paymentDeadline = new Date('@paymentDeadline.Value.ToString("yyyy-MM-ddTHH:mm:ss")');

                        function updateCountdown() {
                            const now = new Date();
                            const distance = paymentDeadline - now;

                            if (distance < 0) {
                                document.getElementById('countdown').innerHTML = 'EXPIRED';
                                location.reload();
                                return;
                            }

                            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                            let countdownText = '';
                            if (days > 0) {
                                countdownText = `${days}d ${hours}h ${minutes}m ${seconds}s`;
                            } else if (hours > 0) {
                                countdownText = `${hours}h ${minutes}m ${seconds}s`;
                            } else if (minutes > 0) {
                                countdownText = `${minutes}m ${seconds}s`;
                            } else {
                                countdownText = `${seconds}s`;
                            }

                            document.getElementById('countdown').innerHTML = countdownText;
                        }

                        updateCountdown();
                        setInterval(updateCountdown, 1000);
            </text>
        }

        // Pay from balance function
        async function payFromBalance() {
            const result = await Swal.fire({
                title: 'Confirm Payment from Balance',
                html: `
                    <div style="text-align: left; padding: 20px;">
                        <p style="margin-bottom: 15px;">You are about to pay for accommodation using your account balance:</p>
                        <div style="background: #f0fdf4; padding: 15px; border-radius: 8px; border-left: 4px solid #10b981; margin-bottom: 15px;">
                            <p style="margin: 5px 0;"><strong>Amount to be deducted:</strong> K @calculatedFee.ToString("N2")</p>
                            <p style="margin: 5px 0;"><strong>Current Balance:</strong> K @availableBalance.ToString("N2")</p>
                            <p style="margin: 5px 0;"><strong>Balance after payment:</strong> K @((availableBalance - calculatedFee).ToString("N2"))</p>
        @if (period?.TypeOfPayment == "PerDay")
        {
                                    <p style="margin: 5px 0; font-size: 12px; color: #64748b;"><strong>Fee breakdown:</strong> @feeDisplay</p>
        }
                        </div>
                        <p style="color: #64748b; font-size: 14px;">This will automatically allocate your selected bed space.</p>
                    </div>
                `,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Confirm Payment',
                cancelButtonText: 'Cancel'
            });

            if (!result.isConfirmed) {
                return;
            }

            // Show loading overlay
            document.getElementById('loadingOverlay').classList.add('show');

            const formData = new FormData();
            formData.append('applicationId', @Model.ApplicationId);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

            try {
                const response = await fetch('@Url.Action("PayFromBalance", "StudentAccommodationApplication")', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                document.getElementById('loadingOverlay').classList.remove('show');

                if (data.success) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Payment Successful!',
                        html: `<p>${data.message}</p>`,
                        confirmButtonColor: '#10b981',
                        allowOutsideClick: false
                    });
                    location.reload();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Payment Failed',
                        text: data.message,
                        confirmButtonColor: '#ef4444'
                    });
                }
            } catch (error) {
                document.getElementById('loadingOverlay').classList.remove('show');
                console.error('Error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred while processing your payment. Please try again.',
                    confirmButtonColor: '#ef4444'
                });
            }
        }
    </script>
    @Html.AntiForgeryToken()
}
