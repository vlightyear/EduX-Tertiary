@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var errorMessage = TempData["Error"] as string ?? "You do not have permission to access this page.";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<style>
    :root {
        --danger-color: #ef4444;
        --danger-dark: #dc2626;
        --warning-color: #f59e0b;
        --primary-color: #16697a;
        --light-bg: #f8fafc;
        --border-color: #e2e8f0;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f2 100%);
        color: #334155;
    }

    .container-fluid {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .access-denied-container {
        background: white;
        border-radius: 16px;
        padding: 60px 40px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        text-align: center;
        width: 100%;
        max-width: 800px;
        border-top: 6px solid var(--danger-color);
    }

    .icon-container {
        margin-bottom: 30px;
        position: relative;
        display: inline-block;
    }

    .main-icon {
        font-size: 120px;
        color: #fca5a5;
        animation: shake 0.5s ease-in-out;
    }

    .lock-icon {
        position: absolute;
        bottom: 10px;
        right: 10px;
        font-size: 50px;
        color: var(--danger-color);
        background: white;
        border-radius: 50%;
        padding: 8px;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-10px); }
        75% { transform: translateX(10px); }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.1);
        }
    }

    h1 {
        font-size: 42px;
        color: var(--danger-color);
        margin-bottom: 15px;
        font-weight: 800;
    }

    .error-code {
        font-size: 18px;
        color: #94a3b8;
        font-weight: 600;
        margin-bottom: 25px;
        letter-spacing: 2px;
    }

    .main-message {
        font-size: 20px;
        color: #64748b;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .error-details {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        border: 2px solid #fca5a5;
        border-radius: 12px;
        padding: 25px;
        margin: 30px 0;
        text-align: left;
    }

    .error-details h3 {
        color: var(--danger-color);
        font-size: 20px;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .error-details p {
        color: #991b1b;
        font-size: 16px;
        line-height: 1.6;
        margin: 0;
    }

    .reasons-box {
        background: var(--light-bg);
        border-radius: 12px;
        padding: 25px;
        margin: 30px 0;
        text-align: left;
        border-left: 4px solid var(--warning-color);
    }

    .reasons-box h3 {
        color: var(--primary-color);
        font-size: 20px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .reasons-box ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .reasons-box li {
        padding: 12px 0;
        color: #64748b;
        font-size: 16px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        border-bottom: 1px solid var(--border-color);
    }

    .reasons-box li:last-child {
        border-bottom: none;
    }

    .reasons-box li i {
        color: var(--warning-color);
        font-size: 24px;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .help-section {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        border: 2px solid #93c5fd;
        border-radius: 12px;
        padding: 25px;
        margin: 30px 0;
    }

    .help-section h3 {
        color: #1e40af;
        font-size: 20px;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        justify-content: center;
    }

    .help-section p {
        color: #1e40af;
        font-size: 16px;
        margin-bottom: 15px;
    }

    .contact-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .contact-item {
        background: white;
        padding: 15px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: #64748b;
        font-size: 15px;
    }

    .contact-item i {
        color: #3b82f6;
        font-size: 24px;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin-top: 40px;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 14px 28px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background: var(--primary-color);
        color: white;
        box-shadow: 0 4px 12px rgba(22, 105, 122, 0.3);
    }

    .btn-primary:hover {
        background: #0d4b56;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(22, 105, 122, 0.4);
    }

    .btn-secondary {
        background: white;
        color: var(--primary-color);
        border: 2px solid var(--primary-color);
    }

    .btn-secondary:hover {
        background: var(--light-bg);
        transform: translateY(-2px);
    }

    .btn-danger {
        background: var(--danger-color);
        color: white;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }

    .btn-danger:hover {
        background: var(--danger-dark);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
    }

    .btn i {
        font-size: 20px;
    }

    .security-notice {
        background: #fef3c7;
        border: 2px solid #fbbf24;
        border-radius: 12px;
        padding: 20px;
        margin: 30px 0;
        display: flex;
        align-items: center;
        gap: 15px;
        text-align: left;
    }

    .security-notice i {
        font-size: 40px;
        color: var(--warning-color);
        flex-shrink: 0;
    }

    .security-notice .content {
        flex: 1;
    }

    .security-notice h4 {
        color: #92400e;
        font-size: 18px;
        margin-bottom: 8px;
    }

    .security-notice p {
        color: #78350f;
        font-size: 14px;
        margin: 0;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .container-fluid {
            padding: 15px;
        }

        .access-denied-container {
            padding: 40px 25px;
        }

        .main-icon {
            font-size: 80px;
        }

        .lock-icon {
            font-size: 35px;
        }

        h1 {
            font-size: 32px;
        }

        .main-message {
            font-size: 16px;
        }

        .contact-details {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }

        .security-notice {
            flex-direction: column;
            text-align: center;
        }
    }
</style>

<div class="container-fluid">
    <div class="access-denied-container">
        <!-- Icon -->
        <div class="icon-container">
            <i class="material-icons main-icon">block</i>
            <i class="material-icons lock-icon">lock</i>
        </div>

        <!-- Main Heading -->
        <h1>Access Denied</h1>
        <div class="error-code">ERROR 403 - FORBIDDEN</div>

        <!-- Main Message -->
        <p class="main-message">
            We're sorry, but you don't have permission to access this page or resource.
        </p>

        <!-- Error Details -->
        <div class="error-details">
            <h3>
                <i class="material-icons">error</i>
                Error Details
            </h3>
            <p>@errorMessage</p>
        </div>

        <!-- Possible Reasons -->
        <div class="reasons-box">
            <h3>
                <i class="material-icons">help_outline</i>
                Why Am I Seeing This?
            </h3>
            <ul>
                <li>
                    <i class="material-icons">person_off</i>
                    <span><strong>Account Not Configured:</strong> Your student account may not be properly set up in the system.</span>
                </li>
                <li>
                    <i class="material-icons">admin_panel_settings</i>
                    <span><strong>Insufficient Permissions:</strong> You may not have the required role or permissions to access this resource.</span>
                </li>
                <li>
                    <i class="material-icons">verified_user</i>
                    <span><strong>Authentication Required:</strong> You may need to log in or re-authenticate your session.</span>
                </li>
                <li>
                    <i class="material-icons">warning</i>
                    <span><strong>Account Status:</strong> Your account may be inactive, suspended, or pending verification.</span>
                </li>
                <li>
                    <i class="material-icons">schedule</i>
                    <span><strong>Access Period:</strong> This resource may only be available during specific times or periods.</span>
                </li>
            </ul>
        </div>

        <!-- Security Notice -->
        <div class="security-notice">
            <i class="material-icons">security</i>
            <div class="content">
                <h4>🔒 Security Notice</h4>
                <p>If you believe you should have access to this page, please contact your system administrator or IT support immediately.</p>
            </div>
        </div>

        <!-- Help Section -->
        <div class="help-section">
            <h3>
                <i class="material-icons">contact_support</i>
                Need Help?
            </h3>
            <p>
                If you're experiencing access issues or believe this is an error, please contact support with the error details shown above.
            </p>
            <div class="contact-details">
                <div class="contact-item">
                    <i class="material-icons">email</i>
                    <span>support@university.edu</span>
                </div>
                <div class="contact-item">
                    <i class="material-icons">phone</i>
                    <span>+260-XXX-XXXXXX</span>
                </div>
                <div class="contact-item">
                    <i class="material-icons">location_on</i>
                    <span>IT Support Office</span>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                <i class="material-icons">home</i>
                Go to Dashboard
            </a>

            @if (!string.IsNullOrEmpty(returnUrl))
            {
                <a href="@returnUrl" class="btn btn-secondary">
                    <i class="material-icons">arrow_back</i>
                    Go Back
                </a>
            }
            else
            {
                <button type="button" class="btn btn-secondary" onclick="window.history.back()">
                    <i class="material-icons">arrow_back</i>
                    Go Back
                </button>
            }

            @if (!User.Identity.IsAuthenticated)
            {
                <a href="@Url.Action("Login", "Account")" class="btn btn-danger">
                    <i class="material-icons">login</i>
                    Login
                </a>
            }
        </div>

        <!-- Additional Information -->
        <p style="color: #94a3b8; font-size: 14px; margin-top: 40px; font-style: italic;">
            💡 Tip: Make sure you're logged in with the correct account and have completed all required profile setup steps.
        </p>

        <!-- Incident ID for Support (Optional) -->
        <p style="color: #cbd5e1; font-size: 12px; margin-top: 20px;">
            Incident ID: @DateTime.Now.ToString("yyyyMMddHHmmss")-@Guid.NewGuid().ToString("N").Substring(0, 8).ToUpper()
        </p>
    </div>
</div>

@section Scripts {
    <script>
        // Log access denied event for security audit (optional)
        console.warn('Access Denied: @errorMessage');
        
        // Optional: Send analytics event
        if (typeof gtag !== 'undefined') {
            gtag('event', 'access_denied', {
                'event_category': 'security',
                'event_label': '@errorMessage',
                'value': 1
            });
        }
    </script>
}
