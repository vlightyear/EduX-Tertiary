@model SIS.Models.StudentAccommodation.Allocation
@{
    var config = ViewBag.Config as SIS.Models.StudentAccommodation.AccomodationConfiguration;
    var checkInOutStatus = ViewBag.CheckInOutStatus as string ?? "Not Checked In";
    var checkInOut = ViewBag.CheckInOut as SIS.Models.StudentAccommodation.CheckInOut;
    ViewData["Title"] = "Current Accommodation";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var period = Model.Application?.Period;
    decimal accommodationFee = 0;
    string feeDisplay = "";
    if (period != null)
    {
        if (period.TypeOfPayment == "PerDay")
        {
            var numberOfDays = Model.Application?.NumberOfDays ?? 1;
            accommodationFee = period.TypeOfPaymentAmount * numberOfDays;
            feeDisplay = $"K{period.TypeOfPaymentAmount:N2}/day × {numberOfDays} days = K{accommodationFee:N2}";
        }
        else
        {
            accommodationFee = period.TypeOfPaymentAmount;
            feeDisplay = $"K{accommodationFee:N2} ({period.TypeOfPayment})";
        }
    }
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap');

        :root {
            --coral: #e85c5c;
            --coral-d: #c94040;
            --navy: #1e2d5e;
            --navy-l: #2e3f7a;
            --mist: #f5f7fa;
            --border: #e8ecf2;
            --ink: #1a1f2e;
            --text: #475569;
            --green: #16a34a;
            --greenl: #dcfce7;
        }

        .ca-wrap {
            font-family: 'DM Sans',sans-serif;
        }

        /* ── Hero ──────────────────────────── */
        .ca-hero {
            background: linear-gradient(135deg,var(--navy) 0%,var(--navy-l) 55%,#1a4d3a 100%);
            border-radius: 1.25rem;
            padding: 1.75rem 2rem 4rem;
            position: relative;
            overflow: hidden;
        }

            .ca-hero::before {
                content: '';
                position: absolute;
                top: -50px;
                right: -50px;
                width: 200px;
                height: 200px;
                background: rgba(22,163,74,.18);
                border-radius: 50%;
                pointer-events: none;
            }

            .ca-hero::after {
                content: '';
                position: absolute;
                bottom: -60px;
                left: 25%;
                width: 280px;
                height: 280px;
                background: rgba(255,255,255,.03);
                border-radius: 50%;
                pointer-events: none;
            }

        .hero-inner {
            position: relative;
            z-index: 1;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .hero-eyebrow {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: rgba(255,255,255,.5);
            margin-bottom: .35rem;
        }

        .hero-title {
            font-family: 'DM Serif Display',serif;
            font-size: 1.85rem;
            color: #fff;
            line-height: 1.2;
            margin-bottom: .3rem;
        }

        .hero-sub {
            font-size: .82rem;
            color: rgba(255,255,255,.6);
        }

        .hero-status-pill {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .45rem .9rem;
            border-radius: 2rem;
            font-size: .75rem;
            font-weight: 700;
            align-self: flex-start;
            background: rgba(22,163,74,.25);
            color: #bbf7d0;
            border: 1px solid rgba(22,163,74,.4);
        }

            .hero-status-pill i {
                font-size: .85rem;
            }

        /* ── Two-column layout ─────────────── */
        .ca-cols {
            margin-top: -2.25rem;
            position: relative;
            z-index: 2;
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 1.25rem;
            align-items: start;
        }

        .ca-left, .ca-right {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        /* ── Cards ─────────────────────────── */
        .aa-card {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            box-shadow: 0 2px 12px rgba(30,45,94,.06);
            overflow: hidden;
        }

        .aa-card-head {
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: .5rem;
        }

            .aa-card-head i {
                font-size: 1rem;
                color: var(--coral);
            }

        .aa-card-title {
            font-family: 'DM Serif Display',serif;
            font-size: .95rem;
            color: var(--ink);
        }

        .aa-card-body {
            padding: 1.25rem;
        }

        /* ── Detail grids ──────────────────── */
        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(145px,1fr));
            gap: .5rem;
        }

        .detail-cell {
            background: var(--mist);
            border: 1px solid var(--border);
            border-radius: .55rem;
            padding: .6rem .75rem;
        }

        .detail-lbl {
            font-size: .65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #94a3b8;
            margin-bottom: .15rem;
        }

        .detail-val {
            font-size: .84rem;
            font-weight: 700;
            color: var(--ink);
        }

            .detail-val.green {
                color: var(--green);
            }

            .detail-val.teal {
                color: #0d9488;
            }

            .detail-val.amber {
                color: #d97706;
            }

        .pay-badge {
            display: inline-flex;
            font-size: .68rem;
            font-weight: 700;
            padding: .2rem .5rem;
            border-radius: 2rem;
        }

            .pay-badge.semester {
                background: #dbeafe;
                color: #1d4ed8;
            }

            .pay-badge.year {
                background: var(--greenl);
                color: #166534;
            }

            .pay-badge.perday {
                background: #ffedd5;
                color: #9a3412;
            }

            .pay-badge.fixed {
                background: #f3e8ff;
                color: #7c3aed;
            }

        /* ── Status success banner ─────────── */
        .success-banner {
            display: flex;
            align-items: center;
            gap: .85rem;
            background: linear-gradient(135deg,#f0fdf4,#dcfce7);
            border: 1.5px solid #86efac;
            border-radius: .85rem;
            padding: .9rem 1.1rem;
        }

        .success-icon {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            flex-shrink: 0;
            background: var(--greenl);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .success-icon i {
                font-size: 1.15rem;
                color: var(--green);
            }

        .success-title {
            font-size: .88rem;
            font-weight: 700;
            color: #166534;
        }

        .success-sub {
            font-size: .75rem;
            color: #4ade80;
            margin-top: .1rem;
        }

        /* ── Fee card ──────────────────────── */
        .fee-strip {
            background: linear-gradient(135deg,#fffbeb,#fef3c7);
            border: 1.5px solid #fde68a;
            border-radius: .75rem;
            padding: .9rem 1.1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .fee-strip-lbl {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #a16207;
            margin-bottom: .15rem;
        }

        .fee-strip-amt {
            font-family: 'DM Serif Display',serif;
            font-size: 1.65rem;
            color: #92400e;
        }

        .fee-strip-break {
            font-size: .72rem;
            color: #a16207;
        }

        /* ── Check-in status pill ──────────── */
        .checkin-pill {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            padding: .45rem 1rem;
            border-radius: 2rem;
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: .85rem;
        }

            .checkin-pill i {
                font-size: .85rem;
            }

        .pill-in {
            background: linear-gradient(135deg,var(--green),#15803d);
            color: #fff;
            box-shadow: 0 4px 12px rgba(22,163,74,.25);
        }

        .pill-out {
            background: linear-gradient(135deg,#475569,#334155);
            color: #fff;
            box-shadow: 0 4px 12px rgba(71,85,105,.25);
        }

        .pill-pending {
            background: linear-gradient(135deg,#d97706,#b45309);
            color: #fff;
            box-shadow: 0 4px 12px rgba(217,119,6,.25);
        }

        .pill-none {
            background: linear-gradient(135deg,var(--coral),var(--coral-d));
            color: #fff;
            box-shadow: 0 4px 12px rgba(232,92,92,.25);
        }

        /* checkin detail cells */
        .checkin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(160px,1fr));
            gap: .5rem;
            margin-bottom: .85rem;
        }

        .checkin-cell {
            background: var(--mist);
            border: 1.5px solid var(--border);
            border-radius: .65rem;
            padding: .75rem .9rem;
        }

            .checkin-cell.highlight {
                background: var(--greenl);
                border-color: #86efac;
            }

            .checkin-cell.danger {
                background: #fef2f2;
                border-color: #fecaca;
            }

        .checkin-cell-lbl {
            font-size: .65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #94a3b8;
            margin-bottom: .25rem;
            display: flex;
            align-items: center;
            gap: .25rem;
        }

            .checkin-cell-lbl i {
                font-size: .75rem;
            }

        .checkin-cell.highlight .checkin-cell-lbl {
            color: #166534;
        }

        .checkin-cell.danger .checkin-cell-lbl {
            color: #991b1b;
        }

        .checkin-cell-val {
            font-size: .88rem;
            font-weight: 700;
            color: var(--ink);
        }

        .checkin-cell-sub {
            font-size: .72rem;
            color: var(--text);
            margin-top: .1rem;
        }

        .damage-val {
            font-family: 'DM Serif Display',serif;
            font-size: 1.4rem;
            color: var(--coral);
        }

        .no-damage {
            font-size: .88rem;
            font-weight: 700;
            color: var(--green);
        }

        /* ── Callouts ──────────────────────── */
        .callout {
            display: flex;
            align-items: flex-start;
            gap: .7rem;
            border-radius: .65rem;
            padding: .8rem .95rem;
        }

            .callout i {
                font-size: 1rem;
                flex-shrink: 0;
                margin-top: .05rem;
            }

        .callout-text {
            font-size: .78rem;
            line-height: 1.65;
        }

            .callout-text strong {
                font-weight: 700;
            }

        .callout-info {
            background: #eff6ff;
            border: 1.5px solid #bfdbfe;
            color: #1e40af;
        }

            .callout-info i {
                color: #2563eb;
            }

        .callout-warning {
            background: #fffbeb;
            border: 1.5px solid #fde68a;
            color: #92400e;
        }

            .callout-warning i {
                color: #d97706;
            }

        .callout-danger {
            background: #fef2f2;
            border: 1.5px solid #fecaca;
            color: #991b1b;
        }

            .callout-danger i {
                color: var(--coral);
            }

        .callout-success {
            background: var(--greenl);
            border: 1.5px solid #86efac;
            color: #166534;
        }

            .callout-success i {
                color: var(--green);
            }

        /* ── Timeline ──────────────────────── */
        .timeline {
            padding-left: .85rem;
        }

        .tl-item {
            position: relative;
            padding: .55rem 0 .55rem 1.35rem;
            border-left: 2px solid #e8ecf2;
        }

            .tl-item::before {
                content: '';
                position: absolute;
                left: -5px;
                top: .85rem;
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--green);
                border: 2px solid #fff;
                box-shadow: 0 0 0 2px var(--green);
            }

            .tl-item:last-child {
                border-left-color: transparent;
            }

        .tl-title {
            font-size: .8rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: .1rem;
        }

        .tl-date {
            font-size: .72rem;
            color: var(--text);
        }

        /* ── Dashboard button ──────────────── */
        .btn-dashboard {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: .7rem;
            font-size: .82rem;
            font-weight: 700;
            font-family: inherit;
            padding: .65rem 1.25rem;
            cursor: pointer;
            transition: background .15s;
            text-decoration: none;
            box-shadow: 0 4px 12px rgba(30,45,94,.2);
        }

            .btn-dashboard:hover {
                background: var(--navy-l);
                color: #fff;
            }

            .btn-dashboard i {
                font-size: .9rem;
            }

        @@media (max-width:960px) {
            .ca-cols {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width:540px) {
            .detail-grid {
                grid-template-columns: 1fr 1fr;
            }

            .checkin-grid {
                grid-template-columns: 1fr 1fr;
            }
        }
    </style>
}

<div class="ca-wrap p-4 md:p-6">

    <!-- Hero — green tint to signal active/positive state -->
    <div class="ca-hero mb-6">
        <div class="hero-inner">
            <div>
                <p class="hero-eyebrow">Student Accommodation</p>
                <h1 class="hero-title">Current Accommodation</h1>
                <p class="hero-sub">You have an active bed allocation for this period</p>
            </div>
            <span class="hero-status-pill"><i class="material-icons">check_circle</i> Active</span>
        </div>
    </div>

    <!-- Two-column layout -->
    <div class="ca-cols">

        <!-- ── Left panel ── -->
        <div class="ca-left">

            <!-- Success banner -->
            <div class="success-banner">
                <div class="success-icon"><i class="material-icons">celebration</i></div>
                <div>
                    <p class="success-title">Accommodation Successfully Allocated</p>
                    <p class="success-sub">Your bed space is confirmed and active</p>
                </div>
            </div>

            <!-- Student info -->
            <div class="aa-card">
                <div class="aa-card-head">
                    <i class="material-icons">person</i>
                    <h3 class="aa-card-title">Student Information</h3>
                </div>
                <div class="aa-card-body">
                    <div class="detail-grid">
                        <div class="detail-cell"><p class="detail-lbl">Student ID</p><p class="detail-val">@Model.Application.Student.StudentId_Number</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Full Name</p><p class="detail-val">@Model.Application.Student.FullName</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Programme</p><p class="detail-val">@Model.Application.Student.Programme?.Name</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Email</p><p class="detail-val">@Model.Application.Student.Email</p></div>
                    </div>
                </div>
            </div>

            <!-- Accommodation details -->
            <div class="aa-card">
                <div class="aa-card-head">
                    <i class="material-icons">bed</i>
                    <h3 class="aa-card-title">Accommodation Details</h3>
                </div>
                <div class="aa-card-body" style="display:flex;flex-direction:column;gap:1rem;">
                    <div class="detail-grid">
                        <div class="detail-cell"><p class="detail-lbl">Campus</p><p class="detail-val teal">@Model.Bed.Room.Hostel.Campus.CampusName</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Hostel</p><p class="detail-val teal">@Model.Bed.Room.Hostel.HostelName</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Room</p><p class="detail-val">@Model.Bed.Room.RoomNumber</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Bed</p><p class="detail-val">@Model.Bed.BedIdentifier</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Room Type</p><p class="detail-val">@Model.Bed.Room.RoomType</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Floor</p><p class="detail-val">Floor @Model.Bed.Room.Floor</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Allocated</p><p class="detail-val">@Model.AllocationDate.ToString("MMM dd, yyyy")</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Start Date</p><p class="detail-val">@Model.StartDate.ToString("MMM dd, yyyy")</p></div>
                        <div class="detail-cell">
                            <p class="detail-lbl">End Date</p>
                            <p class="detail-val">
                                @if (Model.IsGraduationBased)
                                {
                                    <span>Until Graduation</span>
                                }
                                else if (Model.EndDate.HasValue)
                                {

                                    @Model.EndDate.Value.ToString("MMM dd, yyyy")
                                }
                                else
                                {

                                    <span>Not Specified</span>
                                }
                            </p>
                        </div>
                        <div class="detail-cell"><p class="detail-lbl">Status</p><p class="detail-val green">@Model.Status</p></div>
                        <div class="detail-cell"><p class="detail-lbl">Period Type</p><p class="detail-val">@period?.Type</p></div>
                        <div class="detail-cell">
                            <p class="detail-lbl">Payment Type</p>
                            <span class="pay-badge @period?.TypeOfPayment?.ToLower()">@period?.TypeOfPayment</span>
                        </div>
                        @if (period?.TypeOfPayment == "PerDay" && Model.Application?.NumberOfDays.HasValue == true)
                        {
                            <div class="detail-cell"><p class="detail-lbl">Days Booked</p><p class="detail-val">@Model.Application.NumberOfDays days</p></div>
                        }
                        <div class="detail-cell"><p class="detail-lbl">Allocated By</p><p class="detail-val">@Model.AllocatedBy?.FullName</p></div>
                    </div>

                    @if (period != null && accommodationFee > 0)
                    {
                        <div class="fee-strip">
                            <div>
                                <p class="fee-strip-lbl">Accommodation Fee</p>
                                <p class="fee-strip-amt">K @accommodationFee.ToString("N2")</p>
                            </div>
                            <p class="fee-strip-break">@feeDisplay</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Check-In/Out Status -->
            <div class="aa-card">
                <div class="aa-card-head">
                    <i class="material-icons">meeting_room</i>
                    <h3 class="aa-card-title">Check-In / Out Status</h3>
                </div>
                <div class="aa-card-body">

                    @if (checkInOutStatus == "Checked In")
                    {
                        <span class="checkin-pill pill-in"><i class="material-icons">check_circle</i> Checked In</span>
                        @if (checkInOut != null)
                        {
                            <div class="checkin-grid">
                                <div class="checkin-cell highlight">
                                    <p class="checkin-cell-lbl"><i class="material-icons">login</i> Check-In Date</p>
                                    <p class="checkin-cell-val">@checkInOut.CheckInDate?.ToString("MMM dd, yyyy")</p>
                                    <p class="checkin-cell-sub">@checkInOut.CheckInDate?.ToString("hh:mm tt")</p>
                                </div>
                                <div class="checkin-cell">
                                    <p class="checkin-cell-lbl"><i class="material-icons">description</i> Room Condition</p>
                                    <p class="checkin-cell-val">@(checkInOut.CheckInCondition ?? "Not Specified")</p>
                                </div>
                                <div class="checkin-cell">
                                    <p class="checkin-cell-lbl"><i class="material-icons">person</i> Checked In By</p>
                                    <p class="checkin-cell-val">@(checkInOut.CheckInStaff?.FullName ?? "N/A")</p>
                                </div>
                            </div>
                            <div class="callout callout-info">
                                <i class="material-icons">info</i>
                                <p class="callout-text"><strong>You are currently checked in.</strong> Please maintain the room in good condition. Damages discovered at check-out may result in additional charges.</p>
                            </div>
                        }
                    }
                    else if (checkInOutStatus == "Checked Out")
                    {
                        <span class="checkin-pill pill-out"><i class="material-icons">logout</i> Checked Out</span>
                        @if (checkInOut != null)
                        {
                            <div class="checkin-grid">
                                <div class="checkin-cell">
                                    <p class="checkin-cell-lbl"><i class="material-icons">login</i> Check-In Date</p>
                                    <p class="checkin-cell-val">@checkInOut.CheckInDate?.ToString("MMM dd, yyyy")</p>
                                    <p class="checkin-cell-sub">@checkInOut.CheckInDate?.ToString("hh:mm tt")</p>
                                </div>
                                <div class="checkin-cell">
                                    <p class="checkin-cell-lbl"><i class="material-icons">description</i> Condition (In)</p>
                                    <p class="checkin-cell-val">@(checkInOut.CheckInCondition ?? "Not Specified")</p>
                                </div>
                                <div class="checkin-cell highlight">
                                    <p class="checkin-cell-lbl"><i class="material-icons">logout</i> Check-Out Date</p>
                                    <p class="checkin-cell-val">@checkInOut.CheckOutDate?.ToString("MMM dd, yyyy")</p>
                                    <p class="checkin-cell-sub">@checkInOut.CheckOutDate?.ToString("hh:mm tt")</p>
                                </div>
                                <div class="checkin-cell">
                                    <p class="checkin-cell-lbl"><i class="material-icons">description</i> Condition (Out)</p>
                                    <p class="checkin-cell-val">@(checkInOut.CheckOutCondition ?? "Not Specified")</p>
                                </div>
                                <div class="checkin-cell">
                                    <p class="checkin-cell-lbl"><i class="material-icons">person</i> Checked Out By</p>
                                    <p class="checkin-cell-val">@(checkInOut.CheckOutStaff?.FullName ?? "N/A")</p>
                                </div>
                                <div class="checkin-cell @(checkInOut.DamageCharges > 0 ? "danger" : "highlight")">
                                    <p class="checkin-cell-lbl"><i class="material-icons">@(checkInOut.DamageCharges > 0 ? "warning" : "check_circle")</i> Damage Charges</p>
                                    @if (checkInOut.DamageCharges > 0)
                                    {
                                        <p class="damage-val">K @checkInOut.DamageCharges.ToString("N2")</p>
                                    }
                                    else
                                    {
                                        <p class="no-damage">K 0.00 — No Charges</p>
                                    }
                                </div>
                            </div>
                            @if (checkInOut.DamageCharges > 0)
                            {
                                <div class="callout callout-danger">
                                    <i class="material-icons">warning</i>
                                    <p class="callout-text"><strong>Damage charges of K @checkInOut.DamageCharges.ToString("N2") have been assessed.</strong> Please contact the accommodation office to settle this amount.</p>
                                </div>
                            }
                            else
                            {
                                <div class="callout callout-success">
                                    <i class="material-icons">check_circle</i>
                                    <p class="callout-text"><strong>Checked out with no damage charges.</strong> Thank you for maintaining the room in good condition.</p>
                                </div>
                            }
                        }
                    }
                    else if (checkInOutStatus == "Pending Check-In")
                    {
                        <span class="checkin-pill pill-pending"><i class="material-icons">pending</i> Pending Check-In</span>
                        <div class="callout callout-warning">
                            <i class="material-icons">schedule</i>
                            <p class="callout-text"><strong>Accommodation allocated but check-in not yet completed.</strong> Please visit the accommodation office at <strong>@Model.Bed.Room.Hostel.HostelName, @Model.Bed.Room.Hostel.Campus.CampusName Campus</strong> with your student ID to check in.</p>
                        </div>
                    }
                    else
                    {
                        <span class="checkin-pill pill-none"><i class="material-icons">block</i> Not Checked In</span>
                        <div class="callout callout-danger">
                            <i class="material-icons">error</i>
                            <p class="callout-text"><strong>No check-in record exists for this allocation.</strong> Please visit the accommodation office immediately at <strong>@Model.Bed.Room.Hostel.HostelName, @Model.Bed.Room.Hostel.Campus.CampusName Campus</strong> to complete your check-in.</p>
                        </div>
                    }

                </div>
            </div>

        </div>

        <!-- ── Right panel ── -->
        <div class="ca-right">

            <!-- Period info -->
            @if (period != null)
            {
                <div class="aa-card">
                    <div class="aa-card-head">
                        <i class="material-icons">date_range</i>
                        <h3 class="aa-card-title">Period Information</h3>
                    </div>
                    <div class="aa-card-body">
                        <div class="detail-grid">
                            <div class="detail-cell"><p class="detail-lbl">Period Type</p><p class="detail-val">@period.Type</p></div>
                            <div class="detail-cell">
                                <p class="detail-lbl">Payment Type</p>
                                <span class="pay-badge @period.TypeOfPayment?.ToLower()">@period.TypeOfPayment</span>
                            </div>
                            <div class="detail-cell"><p class="detail-lbl">Period Start</p><p class="detail-val">@period.StartDate.ToString("MMM dd, yyyy")</p></div>
                            <div class="detail-cell"><p class="detail-lbl">Period End</p><p class="detail-val">@(period.EndDate != null ? period.EndDate.Value.ToString("MMM dd, yyyy") : "Graduation")</p></div>
                            @if (period.TypeOfPayment == "PerDay" && Model.Application?.NumberOfDays.HasValue == true)
                            {
                                <div class="detail-cell"><p class="detail-lbl">Days Booked</p><p class="detail-val green">@Model.Application.NumberOfDays days</p></div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Timeline -->
            <div class="aa-card">
                <div class="aa-card-head">
                    <i class="material-icons">timeline</i>
                    <h3 class="aa-card-title">Accommodation Timeline</h3>
                </div>
                <div class="aa-card-body">
                    <div class="timeline">
                        <div class="tl-item">
                            <p class="tl-title">Application Submitted</p>
                            <p class="tl-date">@Model.Application.ApplicationDate.ToString("MMM dd, yyyy 'at' hh:mm tt")</p>
                        </div>
                        <div class="tl-item">
                            <p class="tl-title">Bed Allocated</p>
                            <p class="tl-date">@Model.AllocationDate.ToString("MMM dd, yyyy 'at' hh:mm tt")</p>
                        </div>
                        <div class="tl-item">
                            <p class="tl-title">Accommodation Period Started</p>
                            <p class="tl-date">@Model.StartDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        @if (Model.EndDate.HasValue && !Model.IsGraduationBased)
                        {
                            <div class="tl-item">
                                <p class="tl-title">Accommodation Period Ends</p>
                                <p class="tl-date">@Model.EndDate.Value.ToString("MMM dd, yyyy")</p>
                            </div>
                        }
                        else if (Model.IsGraduationBased)
                        {
                            <div class="tl-item">
                                <p class="tl-title">Valid Until Graduation</p>
                                <p class="tl-date">Accommodation is valid until completion of studies</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Dashboard button -->
            <a href="/" class="btn-dashboard">
                <i class="material-icons">home</i> Return to Dashboard
            </a>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
}
