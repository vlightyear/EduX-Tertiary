            }

    .payment-notice-banner {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
        padding: 20px 25px;
        border-radius: 12px;
        margin-bottom: 25px;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .payment-notice-banner i {
            font-size: 36px;
            flex-shrink: 0;
        }

        .payment-notice-banner .content {
