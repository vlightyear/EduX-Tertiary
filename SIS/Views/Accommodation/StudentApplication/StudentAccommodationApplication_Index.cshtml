            }

    .btn-actions {
        display: flex;
        gap: 15px;
        margin-top: 20px;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn i {
            font-size: 20px;
        }

    .btn-primary {
        background: var(--primary-color);
        color: white;
    }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(22, 105, 122, 0.3);
        }

    .btn-success {
        background: var(--success-color);
        color: white;
    }

        .btn-success:hover {
            background: #059669;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

    .btn-secondary {
        background: #e2e8f0;
        color: #475569;
    }

        .btn-secondary:hover {
            background: #cbd5e1;
        }

    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
