@section Scripts {
    <script>
        // Global variables
        let currentHostelId = null;
        let currentRoomId = null;
        let currentActiveTab = 'info';
        let bulkResourceCounter = 0;
        let bulkResourceAllCounter = 0;
        let bulkBedCounter = 0;
        let currentHostelRooms = [];

        // LocalStorage Keys
        const STORAGE_KEYS = {
            CAMPUS: 'roomManagement_selectedCampus',
            HOSTEL: 'roomManagement_selectedHostel',
            ROOM_TYPE: 'roomManagement_selectedRoomType'
        };

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('campusFilter').addEventListener('change', handleCampusChange);
            document.getElementById('hostelFilter').addEventListener('change', handleHostelChange);
            document.getElementById('roomTypeFilter').addEventListener('change', handleRoomTypeChange);
            document.getElementById('roomForm').addEventListener('submit', handleRoomSubmit);
            document.getElementById('addBedForm').addEventListener('submit', handleAddBed);
            document.getElementById('editBedForm').addEventListener('submit', handleEditBed);
            document.getElementById('addResourceForm').addEventListener('submit', handleAddResource);
            document.getElementById('maintenanceForm').addEventListener('submit', handleMaintenanceSubmit);

            restoreFilters();
        });

        // LocalStorage Functions
        function saveToLocalStorage(key, value) {
            try {
                localStorage.setItem(key, value);
            } catch (e) {
                console.error('Error saving to localStorage:', e);
            }
        }

        function getFromLocalStorage(key) {
            try {
                return localStorage.getItem(key);
            } catch (e) {
                console.error('Error reading from localStorage:', e);
                return null;
            }
        }

        function clearLocalStorage(key) {
            try {
                localStorage.removeItem(key);
            } catch (e) {
                console.error('Error clearing localStorage:', e);
            }
        }

        async function restoreFilters() {
            const savedCampus = getFromLocalStorage(STORAGE_KEYS.CAMPUS);
            const savedHostel = getFromLocalStorage(STORAGE_KEYS.HOSTEL);
            const savedRoomType = getFromLocalStorage(STORAGE_KEYS.ROOM_TYPE);

            if (savedCampus) {
                document.getElementById('campusFilter').value = savedCampus;
                await loadHostelsByCampus(savedCampus);

                if (savedHostel) {
                    document.getElementById('hostelFilter').value = savedHostel;
                    await loadRooms(parseInt(savedHostel));
                }
            }

            if (savedRoomType) {
                document.getElementById('roomTypeFilter').value = savedRoomType;
                filterRoomsByType();
            }
        }

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        // Show resource type description when selected
        function showResourceTypeInfo(selectElement) {
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            const description = selectedOption.getAttribute('data-description');
            const descriptionDiv = document.getElementById('resourceTypeDescription');

            if (description && description.trim() !== '') {
                descriptionDiv.querySelector('.resource-type-info').textContent = description;
                descriptionDiv.classList.remove('hidden');
            } else {
                descriptionDiv.classList.add('hidden');
            }
        }

        async function loadHostelsByCampus(campusId) {
            try {
                const response = await fetch(`/Room/GetHostelsByCampus/${campusId}`);
                const hostels = await response.json();

                const hostelFilter = document.getElementById('hostelFilter');
                hostelFilter.innerHTML = '<option value="">Select Hostel</option>';

                hostels.forEach(hostel => {
                    const option = document.createElement('option');
                    option.value = hostel.id;
                    option.textContent = hostel.name;
                    hostelFilter.appendChild(option);
                });
            } catch (error) {
                console.error('Error loading hostels:', error);
            }
        }

        async function handleCampusChange(e) {
            const campusId = e.target.value;
            const hostelFilter = document.getElementById('hostelFilter');

            if (campusId) {
                saveToLocalStorage(STORAGE_KEYS.CAMPUS, campusId);
            } else {
                clearLocalStorage(STORAGE_KEYS.CAMPUS);
                clearLocalStorage(STORAGE_KEYS.HOSTEL);
            }

            hostelFilter.innerHTML = '<option value="">Select Hostel</option>';
            document.getElementById('roomsContainer').innerHTML = '';
            document.getElementById('bulkResourceAllBtn').style.display = 'none';
            currentHostelId = null;

            if (!campusId) return;

            await loadHostelsByCampus(campusId);
        }

        async function handleHostelChange(e) {
            const hostelId = e.target.value;

            if (hostelId) {
                saveToLocalStorage(STORAGE_KEYS.HOSTEL, hostelId);
                await loadRooms(parseInt(hostelId));
                document.getElementById('bulkResourceAllBtn').style.display = 'inline-block';
            } else {
                clearLocalStorage(STORAGE_KEYS.HOSTEL);
                document.getElementById('roomsContainer').innerHTML = '';
                document.getElementById('bulkResourceAllBtn').style.display = 'none';
                currentHostelId = null;
            }
        }

        function handleRoomTypeChange(e) {
            const roomType = e.target.value;

            if (roomType) {
                saveToLocalStorage(STORAGE_KEYS.ROOM_TYPE, roomType);
            } else {
                clearLocalStorage(STORAGE_KEYS.ROOM_TYPE);
            }

            filterRoomsByType();
        }

        function filterRoomsByType() {
            const roomType = document.getElementById('roomTypeFilter').value.toLowerCase();
            const roomCards = document.querySelectorAll('.room-card');

            roomCards.forEach(card => {
                const cardType = card.dataset.roomType?.toLowerCase();
                if (!roomType || cardType === roomType) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

