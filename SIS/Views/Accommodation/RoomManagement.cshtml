    function hideEditBedModal() { document.getElementById('editBedModal').classList.add('hidden'); }
    async function editBed(bedId) {
        showLoader();
        try {
            const res  = await fetch(`/Room/GetRoomDetails?id=${currentRoomId}`);
            const room = await res.json();
            const bed  = room.beds.find(b => b.bedId === bedId);
            if (bed) {
                document.getElementById('editBedId').value                   = bed.bedId;
                document.getElementById('editBedIdentifier').value           = bed.bedIdentifier;
                const sm = {'Active':'1','Inactive':'0','Occupied':'1','Available':'1','Reserved':'2'};
                document.getElementById('editBedStatus').value               = sm[bed.status] || '1';
                document.getElementById('editBedIsSpecialReservation').checked = bed.isSpecialReservation;
                document.getElementById('editBedCurrentStudentYear').value   = bed.currentStudentYear;
                document.getElementById('editBedCurrentStudentSemister').value = bed.currentStudentSemister;
                document.getElementById('editBedModal').classList.remove('hidden');
            }
        } catch(e) { showNotification('Error loading bed','error'); }
        finally { hideLoader(); }
    }
