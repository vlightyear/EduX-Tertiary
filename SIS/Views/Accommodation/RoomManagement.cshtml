    function removeBulkBedRow(id) { document.getElementById(`bulkBed_${id}`)?.remove(); }
    async function handleBulkBedSubmit() {
        showLoader();
        try {
            const items = document.querySelectorAll('#bulkBedsList .bulk-item');
            if (!items.length) { showNotification('Add at least one bed','error'); return; }
            const bedSpaces = []; let valid = true;
            items.forEach(i => {
                const id = i.querySelector('.bulk-bed-identifier').value;
                if (!id) { valid = false; return; }
                bedSpaces.push({ BedIdentifier: id, Status: parseInt(i.querySelector('.bulk-bed-status').value), IsSpecialReservation: i.querySelector('.bulk-bed-special').checked, CurrentStudentYear: parseInt(i.querySelector('.bulk-bed-year').value), CurrentStudentSemister: parseInt(i.querySelector('.bulk-bed-semester').value) });
            });
            if (!valid) { showNotification('Fill all required fields','error'); return; }
            const res = await fetch('/Room/AddBulkBedSpaces', { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':getAntiForgeryToken()}, body: JSON.stringify({ RoomId: currentRoomId, BedSpaces: bedSpaces }) });
            if (res.ok) { const r = await res.json(); showNotification(`Added ${r.bedSpacesAdded} bed spaces!`,'success'); hideBulkBedModal(); currentActiveTab = 'beds'; await showRoomDetails(currentRoomId); }
            else { showNotification(await res.text() || 'Error adding beds','error'); }
        } catch(e) { showNotification('Error adding beds','error'); }
        finally { hideLoader(); }
    }

