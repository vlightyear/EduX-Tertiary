                        container.innerHTML = requests.map(request => {
                            const priorityClass = request.priority.toLowerCase();
                            const requestDate = new Date(request.requestDate).toLocaleDateString('en-US', {
                                year: 'numeric',
                                month: 'short',
                                day: 'numeric'
                            });

                            let resolutionDate = null;
                            if (request.resolutionDate) {
                                resolutionDate = new Date(request.resolutionDate).toLocaleDateString('en-US', {
                                    year: 'numeric',
                                    month: 'short',
                                    day: 'numeric'
                                });
                            }

                            return `
