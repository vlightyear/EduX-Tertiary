@model IEnumerable<SIS.Models.StudentAccommodation.Room>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Rooms";
    var resourceTypes = ViewBag.ResourceTypes as List<SIS.Models.StudentAccommodation.ResourceType> ?? new List<SIS.Models.StudentAccommodation.ResourceType>();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Serif+Display&display=swap" rel="stylesheet">

<style>
    /* ════════════════════════════════════════════
       BGS DESIGN SYSTEM — Room Management
    ════════════════════════════════════════════ */
    :root {
        --navy: #1e2d5e;
        --navy-dark: #141c3a;
        --navy-mid: #2e3f7a;
        --coral: #e85c5c;
        --coral-lt: rgba(232,92,92,.1);
        --green: #22c55e;
        --green-lt: rgba(34,197,94,.1);
        --amber: #f59e0b;
        --amber-lt: rgba(245,158,11,.1);
        --purple: #7c3aed;
        --purple-lt: rgba(124,58,237,.1);
        --blue: #3b82f6;
        --blue-lt: rgba(59,130,246,.08);
        --mist: #f0f4f8;
        --border: #e8ecf2;
        --txt: #1e2d5e;
        --sub: #64748b;
        --lbl: #94a3b8;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body, button, input, select, textarea {
        font-family: 'DM Sans',sans-serif;
    }

    /* ── HERO ── */
    .bgs-hero {
        background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 55%, var(--navy-mid) 100%);
        border-radius: 1.25rem;
        padding: 1.75rem 2rem;
        position: relative;
        overflow: hidden;
        margin-bottom: 1.5rem;
        box-shadow: 0 8px 32px rgba(20,28,58,.25);
    }

        .bgs-hero::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: rgba(255,255,255,.04);
        }

        .bgs-hero::after {
            content: '';
            position: absolute;
            bottom: -70px;
            right: 100px;
            width: 240px;
            height: 240px;
            border-radius: 50%;
            background: rgba(232,92,92,.07);
        }

    .hero-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .hero-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .hero-icon {
        width: 52px;
        height: 52px;
        background: rgba(255,255,255,.1);
        backdrop-filter: blur(8px);
        border: 1.5px solid rgba(255,255,255,.2);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: white;
        flex-shrink: 0;
        animation: heroFloat 4s ease-in-out infinite;
    }
    @@keyframes heroFloat {
        0%, 100% {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-4px)
        }
    }

    .hero-title {
        font-family: 'DM Serif Display',serif;
        font-size: 1.65rem;
        color: white;
        line-height: 1.1;
        margin: 0;
    }

    .hero-sub {
        font-size: .82rem;
        color: rgba(255,255,255,.6);
        margin: .25rem 0 0;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .6rem;
        align-items: center;
    }

    /* Stat chips */
    .stat-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .65rem;
        margin-top: 1.25rem;
        position: relative;
        z-index: 1;
    }

    .sc {
        background: rgba(255,255,255,.1);
        backdrop-filter: blur(6px);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: .75rem;
        padding: .45rem .9rem;
        display: flex;
        align-items: center;
        gap: .55rem;
        transition: background .2s;
    }

        .sc:hover {
            background: rgba(255,255,255,.17);
        }

    .sc-icon {
        width: 26px;
        height: 26px;
        border-radius: .4rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .72rem;
    }

        .sc-icon.green {
            background: rgba(34,197,94,.25);
            color: #86efac;
        }

        .sc-icon.coral {
            background: rgba(232,92,92,.25);
            color: #fca5a5;
        }

        .sc-icon.amber {
            background: rgba(245,158,11,.25);
            color: #fcd34d;
        }

        .sc-icon.blue {
            background: rgba(59,130,246,.25);
            color: #93c5fd;
        }

    .sc-info {
        display: flex;
        flex-direction: column;
    }

    .sc-val {
        font-family: 'DM Serif Display',serif;
        font-size: 1.05rem;
        color: white;
        line-height: 1;
    }

    .sc-lbl {
        font-size: .62rem;
        color: rgba(255,255,255,.6);
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    /* ── BUTTONS ── */
    .bbtn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .5rem 1.1rem;
        border-radius: 2rem;
        font-size: .8rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: all .2s;
        white-space: nowrap;
        text-decoration: none;
    }

    .bbtn-coral {
        background: var(--coral);
        color: white;
        box-shadow: 0 3px 12px rgba(232,92,92,.4);
    }

        .bbtn-coral:hover {
            background: #d44f4f;
            transform: translateY(-1px);
        }

    .bbtn-ghost {
        background: rgba(255,255,255,.12);
        color: white;
        border: 1px solid rgba(255,255,255,.25);
    }

        .bbtn-ghost:hover {
            background: rgba(255,255,255,.22);
        }

    .bbtn-amber {
        background: var(--amber);
        color: white;
        box-shadow: 0 3px 12px rgba(245,158,11,.4);
    }

        .bbtn-amber:hover {
            background: #d97706;
            transform: translateY(-1px);
        }

    .bbtn-navy {
        background: var(--navy);
        color: white;
    }

        .bbtn-navy:hover {
            background: var(--navy-dark);
        }

    .bbtn-mist {
        background: var(--mist);
        color: var(--txt);
        border: 1px solid var(--border);
    }

        .bbtn-mist:hover {
            background: #e2e8f0;
        }

    .bbtn-purple {
        background: var(--purple);
        color: white;
        box-shadow: 0 3px 12px rgba(124,58,237,.35);
    }

        .bbtn-purple:hover {
            background: #6d28d9;
            transform: translateY(-1px);
        }

    .bbtn-green {
        background: var(--green);
        color: white;
        box-shadow: 0 3px 12px rgba(34,197,94,.3);
    }

        .bbtn-green:hover {
            background: #16a34a;
            transform: translateY(-1px);
        }

    .bbtn-sm {
        padding: .35rem .8rem;
        font-size: .75rem;
    }

    /* ── COMMAND BAR ── */
    .cmd-bar {
        background: white;
        border: 1.5px solid var(--border);
        border-radius: 1rem;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(30,45,94,.05);
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .cmd-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--lbl);
        white-space: nowrap;
        padding-right: .75rem;
        border-right: 1px solid var(--border);
    }

    .cmd-selects {
        display: flex;
        gap: .7rem;
        flex: 1;
        flex-wrap: wrap;
    }

    .cmd-field {
        position: relative;
        flex: 1;
        min-width: 140px;
    }

        .cmd-field .cf-icon {
            position: absolute;
            left: .65rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: .72rem;
            color: var(--lbl);
            pointer-events: none;
            z-index: 1;
        }

        .cmd-field select {
            width: 100%;
            padding: .52rem .75rem .52rem 2.1rem;
            border: 1.5px solid var(--border);
            border-radius: .65rem;
            font-size: .82rem;
            color: var(--txt);
            background: var(--mist);
            appearance: none;
            -webkit-appearance: none;
            transition: all .2s;
            outline: none;
            cursor: pointer;
        }

            .cmd-field select:focus {
                border-color: var(--navy);
                background: white;
                box-shadow: 0 0 0 3px rgba(30,45,94,.08);
            }

        .cmd-field label {
            position: absolute;
            top: -.45rem;
            left: .75rem;
            font-size: .62rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: var(--lbl);
            background: white;
            padding: 0 .25rem;
            border-radius: 2px;
            z-index: 1;
        }

    .cmd-right {
        display: flex;
        align-items: center;
        gap: .7rem;
        margin-left: auto;
    }

    .room-count-badge {
        background: var(--navy);
        color: white;
        border-radius: 2rem;
        padding: .35rem .9rem;
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
        min-width: 90px;
        text-align: center;
        transition: all .3s;
    }

    /* ── FLOOR SECTIONS ── */
    .floor-section {
        margin-bottom: 2rem;
        animation: fadeUp .35s ease both;
    }
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .floor-header {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: .875rem;
    }

    .floor-badge {
        display: flex;
        align-items: center;
        gap: .45rem;
        background: linear-gradient(135deg, var(--navy-dark), var(--navy));
        color: white;
        border-radius: 2rem;
        padding: .3rem .9rem;
        font-size: .8rem;
        font-weight: 600;
        white-space: nowrap;
        box-shadow: 0 2px 8px rgba(30,45,94,.2);
    }

    .floor-line {
        flex: 1;
        height: 1.5px;
        background: var(--border);
    }

    .floor-count {
        font-size: .7rem;
        font-weight: 700;
        color: var(--lbl);
        text-transform: uppercase;
        letter-spacing: .04em;
        white-space: nowrap;
    }

    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: .875rem;
    }

    /* ── ROOM CARD ── */
    .rc {
        background: white;
        border: 1.5px solid var(--border);
        border-radius: .875rem;
        overflow: hidden;
        cursor: pointer;
        transition: all .25s;
        box-shadow: 0 2px 6px rgba(30,45,94,.05);
        position: relative;
    }

        .rc:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 28px rgba(30,45,94,.13);
            border-color: rgba(30,45,94,.25);
        }

    .rc-topbar {
        height: 4px;
    }

        .rc-topbar.t-green {
            background: var(--green);
        }

        .rc-topbar.t-amber {
            background: var(--amber);
        }

        .rc-topbar.t-slate {
            background: #cbd5e1;
        }

    .rc-body {
        padding: .875rem;
    }

    .rc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: .4rem;
    }

    .rc-num {
        font-family: 'DM Serif Display',serif;
        font-size: 1.5rem;
        color: var(--txt);
        line-height: 1;
    }

    .rc-meta {
        font-size: .7rem;
        color: var(--lbl);
        margin-top: .15rem;
    }

    .rc-special {
        background: var(--amber-lt);
        color: #92400e;
        border: 1px solid rgba(245,158,11,.25);
        border-radius: 2rem;
        padding: .1rem .45rem;
        font-size: .6rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .2rem;
        white-space: nowrap;
    }

    .rc-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .3rem;
        margin: .5rem 0;
    }

    .chip {
        font-size: .65rem;
        font-weight: 700;
        padding: .15rem .5rem;
        border-radius: 2rem;
        border: 1px solid;
        letter-spacing: .02em;
    }

    .chip-green {
        background: var(--green-lt);
        color: #16a34a;
        border-color: rgba(34,197,94,.25);
    }

    .chip-amber {
        background: var(--amber-lt);
        color: #92400e;
        border-color: rgba(245,158,11,.25);
    }

    .chip-coral {
        background: var(--coral-lt);
        color: #991b1b;
        border-color: rgba(232,92,92,.25);
    }

    .chip-slate {
        background: #f1f5f9;
        color: #475569;
        border-color: #e2e8f0;
    }

    .chip-navy {
        background: rgba(30,45,94,.08);
        color: var(--navy);
        border-color: rgba(30,45,94,.18);
    }

    .chip-purple {
        background: var(--purple-lt);
        color: #5b21b6;
        border-color: rgba(124,58,237,.2);
    }

    .chip-blue {
        background: var(--blue-lt);
        color: #1d4ed8;
        border-color: rgba(59,130,246,.2);
    }

    /* Occupancy bar */
    .occ-wrap {
        margin: .55rem 0 .35rem;
    }

    .occ-lbl {
        font-size: .65rem;
        color: var(--lbl);
        margin-bottom: .25rem;
        display: flex;
        justify-content: space-between;
    }

    .occ-track {
        height: 5px;
        background: var(--mist);
        border-radius: 3px;
        overflow: hidden;
    }

    .occ-fill {
        height: 100%;
        border-radius: 3px;
        transition: width .5s ease;
    }

    .rc-actions {
        display: flex;
        padding: .55rem .875rem;
        background: var(--mist);
        border-top: 1px solid var(--border);
        gap: .4rem;
    }

    .rc-act {
        flex: 1;
        padding: .32rem;
        border-radius: .4rem;
        background: none;
        border: none;
        cursor: pointer;
        font-size: .72rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
        transition: all .15s;
    }

        .rc-act:hover {
            background: white;
        }

    .rc-act-edit {
        color: var(--navy);
    }

    .rc-act-del {
        color: var(--coral);
    }

    /* ── WELCOME / EMPTY ── */
    .welcome-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border: 2px dashed var(--border);
        border-radius: 1.25rem;
    }

    .welcome-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--navy-dark), var(--navy));
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
        margin: 0 auto 1.25rem;
        box-shadow: 0 8px 24px rgba(30,45,94,.2);
    }

    .welcome-title {
        font-family: 'DM Serif Display',serif;
        font-size: 1.35rem;
        color: var(--txt);
    }

    .welcome-sub {
        font-size: .85rem;
        color: var(--sub);
        margin: .35rem 0 0;
    }

    /* ── LOADING ── */
    #loadingIndicator {
        position: fixed !important;
        inset: 0 !important;
        z-index: 10000 !important;
        background: rgba(15,20,40,.55) !important;
        backdrop-filter: blur(4px) !important;
        display: none !important;
        align-items: center !important;
        justify-content: center !important;
    }

        #loadingIndicator[style*="display: flex"] {
            display: flex !important;
        }

    .ld-spinner {
        width: 50px;
        height: 50px;
        border: 3px solid rgba(255,255,255,.15);
        border-top-color: var(--coral);
        border-radius: 50%;
        animation: spin .7s linear infinite;
    }
    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ══════════════════════════════════════
       MODALS
    ══════════════════════════════════════ */
    .bgs-overlay {
        position: fixed;
        inset: 0;
        z-index: 9998;
        background: rgba(15,20,40,.55);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

        .bgs-overlay.hidden {
            display: none !important;
        }

    .bgs-modal {
        background: white;
        border-radius: 1.25rem;
        overflow: hidden;
        width: 100%;
        max-height: 92vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 25px 60px rgba(10,15,30,.35);
        animation: mfadeUp .25s ease both;
    }
    @@keyframes mfadeUp {
        from {
            opacity: 0;
            transform: translateY(18px) scale(.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .modal-head {
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

        .modal-head.navy {
            background: linear-gradient(135deg,var(--navy-dark),var(--navy));
        }

        .modal-head.purple {
            background: linear-gradient(135deg,#4c1d95,var(--purple));
        }

        .modal-head.amber {
            background: linear-gradient(135deg,#92400e,#d97706);
        }

        .modal-head.coral {
            background: linear-gradient(135deg,#991b1b,var(--coral));
        }

    .modal-title {
        font-family: 'DM Serif Display',serif;
        font-size: 1.1rem;
        color: white;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .modal-x {
        width: 30px;
        height: 30px;
        background: rgba(255,255,255,.15);
        border: 1px solid rgba(255,255,255,.2);
        border-radius: .5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        font-size: .85rem;
        transition: background .2s;
    }

        .modal-x:hover {
            background: rgba(255,255,255,.25);
        }

    .modal-body {
        padding: 1.4rem;
        overflow-y: auto;
        flex: 1;
    }

    .modal-footer {
        padding: .875rem 1.4rem;
        background: var(--mist);
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        flex-shrink: 0;
    }

    /* ── TABS (inside modal) ── */
    .bgs-tabs {
        display: flex;
        border-bottom: 2px solid var(--border);
        margin-bottom: 1.1rem;
        gap: 0;
    }

    .bgs-tab {
        padding: .6rem 1rem;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: none;
        color: var(--lbl);
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        display: flex;
        align-items: center;
        gap: .35rem;
        transition: all .2s;
        white-space: nowrap;
    }

        .bgs-tab:hover {
            color: var(--txt);
            background: rgba(30,45,94,.03);
            border-radius: .4rem .4rem 0 0;
        }

        .bgs-tab.active {
            color: var(--navy);
            border-bottom-color: var(--navy);
        }

    .tab-pane {
        display: none;
    }

        .tab-pane.active {
            display: block;
        }

    /* ── FORM ── */
    .fg {
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

        .fg + .fg {
            margin-top: .75rem;
        }

    .fg-label {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--lbl);
    }

    .fg-input, .fg-select, .fg-textarea {
        padding: .55rem .8rem;
        border: 1.5px solid var(--border);
        border-radius: .6rem;
        font-size: .85rem;
        color: var(--txt);
        background: var(--mist);
        outline: none;
        transition: all .2s;
        font-family: 'DM Sans',sans-serif;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--navy);
            background: white;
            box-shadow: 0 0 0 3px rgba(30,45,94,.08);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 88px;
    }

    .fg-check {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .4rem 0;
    }

        .fg-check input[type=checkbox] {
            accent-color: var(--navy);
            width: 14px;
            height: 14px;
            flex-shrink: 0;
        }

        .fg-check span {
            font-size: .83rem;
            color: var(--txt);
            font-weight: 500;
        }

    .form-grid {
        display: grid;
        gap: .75rem;
    }

    .form-grid-2 {
        grid-template-columns: 1fr 1fr;
    }

    .form-grid-3 {
        grid-template-columns: 1fr 1fr 1fr;
    }

    .span-2 {
        grid-column: 1/-1;
    }

    /* ── Detail cells ── */
    .dc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
    }

    .dc {
        background: var(--mist);
        border: 1px solid var(--border);
        border-radius: .6rem;
        padding: .6rem .8rem;
    }

        .dc.span-2 {
            grid-column: 1/-1;
        }

    .dc-lbl {
        font-size: .62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--lbl);
        margin-bottom: .2rem;
    }

    .dc-val {
        font-size: .9rem;
        font-weight: 600;
        color: var(--txt);
    }

    /* ── Bed cards ── */
    .bc {
        background: white;
        border: 1.5px solid var(--border);
        border-radius: .75rem;
        padding: .875rem;
        margin-bottom: .6rem;
        transition: all .2s;
    }

        .bc:hover {
            border-color: rgba(30,45,94,.3);
            box-shadow: 0 3px 12px rgba(30,45,94,.08);
        }

        .bc.occupied {
            border-left: 3px solid var(--green);
        }

        .bc.available {
            border-left: 3px solid var(--blue);
        }

        .bc.reserved {
            border-left: 3px solid var(--amber);
        }

    .bc-student {
        background: linear-gradient(135deg,var(--navy-dark),var(--navy-mid));
        color: white;
        padding: .6rem .8rem;
        border-radius: .5rem;
        margin-top: .5rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .bc-available {
        background: var(--blue-lt);
        border: 1px solid rgba(59,130,246,.2);
        border-radius: .4rem;
        padding: .4rem .65rem;
        font-size: .75rem;
        color: #1d4ed8;
        margin-top: .5rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .bc-act {
        display: flex;
        gap: .35rem;
        flex-shrink: 0;
    }

    .bc-btn {
        width: 30px;
        height: 30px;
        border-radius: .45rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
        cursor: pointer;
        border: 1px solid;
        background: white;
        transition: all .15s;
    }

        .bc-btn:hover {
            transform: scale(1.08);
        }

    .bc-btn-edit {
        color: var(--navy);
        border-color: rgba(30,45,94,.25);
    }

    .bc-btn-del {
        color: var(--coral);
        border-color: rgba(232,92,92,.25);
    }

    /* ── Resource items ── */
    .res-item {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .75rem .875rem;
        background: white;
        border: 1.5px solid var(--border);
        border-radius: .75rem;
        margin-bottom: .5rem;
        transition: all .2s;
    }

        .res-item:hover {
            border-color: rgba(30,45,94,.25);
            background: var(--mist);
        }

    .res-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg,var(--navy-dark),var(--navy));
        border-radius: .55rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: .8rem;
        flex-shrink: 0;
    }

    .res-body {
        flex: 1;
        min-width: 0;
    }

    .res-name {
        font-size: .88rem;
        font-weight: 600;
        color: var(--txt);
    }

    .res-desc {
        font-size: .75rem;
        color: var(--sub);
    }

    .res-meta {
        font-size: .7rem;
        color: var(--lbl);
        margin-top: .1rem;
    }

    .res-acts {
        display: flex;
        gap: .3rem;
        flex-shrink: 0;
    }

    /* ── Maintenance cards ── */
    .mc {
        background: white;
        border: 1.5px solid var(--border);
        border-radius: .75rem;
        padding: .875rem;
        margin-bottom: .6rem;
        transition: all .2s;
    }

        .mc:hover {
            border-color: rgba(30,45,94,.25);
            box-shadow: 0 3px 12px rgba(30,45,94,.08);
        }

        .mc.low {
            border-left: 3px solid var(--green);
        }

        .mc.medium {
            border-left: 3px solid var(--amber);
        }

        .mc.high {
            border-left: 3px solid var(--coral);
        }

    .mc-desc {
        background: var(--mist);
        border: 1px solid var(--border);
        border-radius: .4rem;
        padding: .5rem .65rem;
        font-size: .8rem;
        color: var(--sub);
        margin-top: .5rem;
    }

    .mc-resolution {
        background: rgba(34,197,94,.06);
        border: 1px solid rgba(34,197,94,.2);
        border-radius: .4rem;
        padding: .45rem .65rem;
        font-size: .78rem;
        color: #15803d;
        margin-top: .4rem;
    }

    /* Pills */
    .pill {
        display: inline-flex;
        align-items: center;
        padding: .18rem .6rem;
        border-radius: 2rem;
        font-size: .67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .03em;
    }

    .pill-green {
        background: var(--green-lt);
        color: #16a34a;
    }

    .pill-amber {
        background: var(--amber-lt);
        color: #92400e;
    }

    .pill-coral {
        background: var(--coral-lt);
        color: #991b1b;
    }

    .pill-slate {
        background: #f1f5f9;
        color: #475569;
    }

    .pill-navy {
        background: rgba(30,45,94,.1);
        color: var(--navy);
    }

    .pill-purple {
        background: var(--purple-lt);
        color: #5b21b6;
    }

    /* Callout */
    .callout {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        padding: .7rem .875rem;
        border-radius: .6rem;
        border-left: 2.5px solid;
        font-size: .79rem;
        margin-bottom: .75rem;
    }

    .callout-info {
        background: var(--blue-lt);
        border-color: var(--blue);
        color: #1d4ed8;
    }

    .callout-warning {
        background: var(--amber-lt);
        border-color: var(--amber);
        color: #92400e;
    }

    /* Bulk items */
    .bulk-item {
        background: var(--mist);
        border: 1.5px solid var(--border);
        border-radius: .75rem;
        padding: .875rem;
        margin-bottom: .6rem;
    }

    .bulk-item-hd {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .65rem;
    }

    .bulk-item-title {
        font-size: .8rem;
        font-weight: 700;
        color: var(--txt);
    }

    .bulk-rm {
        width: 26px;
        height: 26px;
        border-radius: .4rem;
        background: var(--coral-lt);
        border: none;
        color: var(--coral);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
        transition: all .15s;
    }

        .bulk-rm:hover {
            background: rgba(232,92,92,.2);
        }

    .bulk-add-btn {
        width: 100%;
        padding: .65rem;
        border: 2px dashed var(--border);
        border-radius: .75rem;
        background: none;
        cursor: pointer;
        font-size: .8rem;
        color: var(--lbl);
        transition: all .2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        margin-top: .5rem;
    }

        .bulk-add-btn:hover {
            border-color: var(--navy);
            color: var(--navy);
            background: rgba(30,45,94,.03);
        }

    /* Room selector (bulk all-rooms modal) */
    .room-sel {
        padding: .55rem .75rem;
        border: 1.5px solid var(--border);
        border-radius: .6rem;
        margin-bottom: .4rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        cursor: pointer;
        transition: all .15s;
    }

        .room-sel:hover {
            background: var(--mist);
            border-color: rgba(30,45,94,.3);
        }

        .room-sel input[type=checkbox] {
            accent-color: var(--navy);
            width: 14px;
            height: 14px;
            flex-shrink: 0;
        }

        .room-sel label {
            cursor: pointer;
            flex: 1;
            font-size: .82rem;
            color: var(--txt);
            font-weight: 500;
        }

    /* Res type desc */
    .rt-desc {
        background: var(--blue-lt);
        border: 1px solid rgba(59,130,246,.2);
        border-radius: .4rem;
        padding: .4rem .65rem;
        font-size: .76rem;
        color: #1d4ed8;
        margin-top: .3rem;
    }

    /* Occupied beds table */
    .occ-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

        .occ-table thead tr {
            background: var(--mist);
        }

        .occ-table th {
            padding: .6rem .8rem;
            text-align: left;
            font-size: .65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: var(--lbl);
            border-bottom: 2px solid var(--border);
        }

        .occ-table td {
            padding: .7rem .8rem;
            border-bottom: 1px solid var(--border);
        }

        .occ-table tr:hover td {
            background: var(--mist);
        }

    .occ-avatar {
        width: 32px;
        height: 32px;
        border-radius: .55rem;
        background: linear-gradient(135deg,var(--navy-dark),var(--navy));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: .78rem;
        flex-shrink: 0;
    }

    /* BGS toast */
    .bgs-toast {
        position: fixed;
        top: 1.2rem;
        right: 1.2rem;
        z-index: 99999;
        padding: .7rem 1rem;
        border-radius: .75rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        font-weight: 600;
        box-shadow: 0 8px 24px rgba(0,0,0,.18);
        max-width: 320px;
        animation: toastIn .3s ease both;
    }

        .bgs-toast.success {
            background: #16a34a;
            color: white;
        }

        .bgs-toast.error {
            background: var(--coral);
            color: white;
        }

        .bgs-toast.warning {
            background: var(--amber);
            color: white;
        }
    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateX(40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    @@keyframes toastOut {
        to {
            opacity: 0;
            transform: translateX(40px);
        }
    }

    /* Responsive */
    @@media (max-width:768px) {
        .form-grid-2, .form-grid-3 {
            grid-template-columns: 1fr;
        }

        .dc-grid {
            grid-template-columns: 1fr;
        }

        .rooms-grid {
            grid-template-columns: repeat(auto-fill,minmax(160px,1fr));
        }

        .bgs-tabs {
            overflow-x: auto;
        }

        .hero-top {
            flex-direction: column;
        }
    }

    @@media (max-width:480px) {
        .rooms-grid {
            grid-template-columns: 1fr 1fr;
        }

        .bgs-hero {
            padding: 1.25rem;
        }

        .cmd-bar {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

<div style="padding:0 1rem 2rem;">
    @Html.AntiForgeryToken()

    <!-- ══ HERO ══ -->
    <div class="bgs-hero">
        <div class="hero-top">
            <div class="hero-left">
                <div class="hero-icon"><i class="fas fa-door-open"></i></div>
                <div>
                    <h1 class="hero-title">Room Management</h1>
                    <p class="hero-sub">Browse by floor · Manage beds, resources &amp; maintenance</p>
                </div>
            </div>
            <div class="hero-actions">
                <button class="bbtn bbtn-ghost" onclick="showOccupiedBedsModal()">
                    <i class="fas fa-users"></i> Occupants
                </button>
                <button id="bulkResourceAllBtn" class="bbtn bbtn-amber" onclick="showBulkResourceAllRoomsModal()" style="display:none;">
                    <i class="fas fa-layer-group"></i> Bulk Resources
                </button>
                <button class="bbtn bbtn-coral" onclick="showCreateRoomModal()">
                    <i class="fas fa-plus"></i> Add Room
                </button>
            </div>
        </div>

        <!-- Live stat chips -->
        <div class="stat-chips">
            <div class="sc">
                <div class="sc-icon navy" style="background:rgba(255,255,255,.15);color:white;"><i class="fas fa-door-closed"></i></div>
                <div class="sc-info">
                    <span class="sc-val" id="chipRooms">—</span>
                    <span class="sc-lbl">Rooms</span>
                </div>
            </div>
            <div class="sc">
                <div class="sc-icon green"><i class="fas fa-bed"></i></div>
                <div class="sc-info">
                    <span class="sc-val" id="chipOccupied">—</span>
                    <span class="sc-lbl">Occupied Beds</span>
                </div>
            </div>
            <div class="sc">
                <div class="sc-icon amber"><i class="fas fa-tools"></i></div>
                <div class="sc-info">
                    <span class="sc-val" id="chipMaintenance">—</span>
                    <span class="sc-lbl">Maintenance</span>
                </div>
            </div>
            <div class="sc">
                <div class="sc-icon blue"><i class="fas fa-couch"></i></div>
                <div class="sc-info">
                    <span class="sc-val" id="chipResources">—</span>
                    <span class="sc-lbl">Resources</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ COMMAND BAR ══ -->
    <div class="cmd-bar">
        <span class="cmd-label"><i class="fas fa-sliders-h" style="margin-right:.35rem;"></i>Filter</span>
        <div class="cmd-selects">
            <div class="cmd-field">
                <label>Campus</label>
                <i class="fas fa-university cf-icon"></i>
                <select id="campusFilter">
                    <option value="">Select Campus</option>
                    @if (ViewBag.Campuses != null)
                    {
                        foreach (var campus in ViewBag.Campuses)
                        {
                            <option value="@campus.CampusId">@campus.CampusName</option>
                        }
                    }
                </select>
            </div>
            <div class="cmd-field">
                <label>Hostel</label>
                <i class="fas fa-building cf-icon"></i>
                <select id="hostelFilter">
                    <option value="">Select Hostel</option>
                </select>
            </div>
            <div class="cmd-field">
                <label>Room Type</label>
                <i class="fas fa-layer-group cf-icon"></i>
                <select id="roomTypeFilter">
                    <option value="">All Types</option>
                    <option value="Single">Single</option>
                    <option value="Double">Double</option>
                    <option value="Triple">Triple</option>
                    <option value="Quad">Quad</option>
                    <option value="Suite">Suite</option>
                </select>
            </div>
        </div>
        <div class="cmd-right">
            <span class="room-count-badge" id="roomCountBadge">Select a hostel</span>
        </div>
    </div>

    <!-- ══ ROOMS CONTAINER (floor sections) ══ -->
    <div id="roomsContainer">
        <!-- Welcome state -->
        <div class="welcome-state" id="welcomeState">
            <div class="welcome-icon"><i class="fas fa-building"></i></div>
            <div class="welcome-title">Select a Hostel to Begin</div>
            <p class="welcome-sub">Choose a campus and hostel above to view rooms grouped by floor</p>
        </div>
    </div>

    <!-- ══ LOADING ══ -->
    <div id="loadingIndicator">
        <div style="text-align:center;">
            <div class="ld-spinner"></div>
            <p style="color:rgba(255,255,255,.7);margin-top:.75rem;font-size:.85rem;">Loading…</p>
        </div>
    </div>

    <!-- ════════════════════════════════
         ROOM DETAILS MODAL
    ════════════════════════════════ -->
    <div id="roomDetailsModal" class="bgs-overlay hidden">
        <div class="bgs-modal" style="max-width:860px;">
            <div class="modal-head navy">
                <span class="modal-title"><i class="fas fa-door-open"></i> <span id="rdmTitle">Room Details</span></span>
                <button class="modal-x" onclick="closeRoomDetailsModal()"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <!-- Tabs -->
                <div class="bgs-tabs">
                    <button class="bgs-tab active" onclick="switchTab('info')"><i class="fas fa-info-circle"></i> Info</button>
                    <button class="bgs-tab" onclick="switchTab('beds')"><i class="fas fa-bed"></i> Bed Spaces</button>
                    <button class="bgs-tab" onclick="switchTab('resources')"><i class="fas fa-couch"></i> Resources</button>
                    <button class="bgs-tab" onclick="switchTab('maintenance')"><i class="fas fa-tools"></i> Maintenance</button>
                </div>

                <div id="infoTab" class="tab-pane active">
                    <div id="roomInfoContent"></div>
                </div>

                <div id="bedsTab" class="tab-pane">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.875rem;flex-wrap:wrap;gap:.5rem;">
                        <span style="font-size:.88rem;font-weight:700;color:var(--txt);">Bed Spaces</span>
                        <div style="display:flex;gap:.5rem;">
                            <button class="bbtn bbtn-purple bbtn-sm" onclick="showBulkBedModal()"><i class="fas fa-layer-group"></i> Bulk Add</button>
                            <button class="bbtn bbtn-navy bbtn-sm" onclick="showAddBedModal()"><i class="fas fa-plus"></i> Add Bed</button>
                        </div>
                    </div>
                    <div id="bedSpacesContent"></div>
                </div>

                <div id="resourcesTab" class="tab-pane">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.875rem;flex-wrap:wrap;gap:.5rem;">
                        <span style="font-size:.88rem;font-weight:700;color:var(--txt);">Room Resources</span>
                        <div style="display:flex;gap:.5rem;">
                            <button class="bbtn bbtn-purple bbtn-sm" onclick="showBulkResourceModal()"><i class="fas fa-layer-group"></i> Bulk Add</button>
                            <button class="bbtn bbtn-navy bbtn-sm" onclick="showAddResourceModal()"><i class="fas fa-plus"></i> Add Resource</button>
                        </div>
                    </div>
                    <div id="resourcesContent"></div>
                </div>

                <div id="maintenanceTab" class="tab-pane">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.875rem;flex-wrap:wrap;gap:.5rem;">
                        <span style="font-size:.88rem;font-weight:700;color:var(--txt);">Maintenance Requests</span>
                        <button class="bbtn bbtn-coral bbtn-sm" onclick="showAddMaintenanceModal()"><i class="fas fa-plus"></i> Add Request</button>
                    </div>
                    <div id="maintenanceContent"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="bbtn bbtn-mist" onclick="closeRoomDetailsModal()"><i class="fas fa-times"></i> Close</button>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════
         CREATE/EDIT ROOM MODAL
    ════════════════════════════════ -->
    <div id="roomModal" class="bgs-overlay hidden">
        <div class="bgs-modal" style="max-width:600px;">
            <div class="modal-head navy">
                <span class="modal-title" id="roomModalTitle"><i class="fas fa-door-open"></i> Add New Room</span>
                <button class="modal-x" onclick="hideRoomModal()"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <form id="roomForm">
                    <input type="hidden" id="roomId" name="RoomId" value="0">
                    <div class="form-grid form-grid-2">
                        <div class="fg span-2">
                            <label class="fg-label">Hostel *</label>
                            <select id="roomHostelId" name="HostelId" class="fg-select" required>
                                <option value="">Select Hostel</option>
                                @if (ViewBag.Hostels != null)
                                {
                                    foreach (var hostel in ViewBag.Hostels)
                                    {
                                        <option value="@hostel.HostelId">@hostel.HostelName (@hostel.Campus.CampusName)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="fg">
                            <label class="fg-label">Room Number *</label>
                            <input type="text" id="roomNumber" name="RoomNumber" class="fg-input" required>
                        </div>
                        <div class="fg">
                            <label class="fg-label">Floor *</label>
                            <input type="number" id="roomFloor" name="Floor" class="fg-input" required>
                        </div>
                        <div class="fg">
                            <label class="fg-label">Room Type *</label>
                            <select id="roomType" name="RoomType" class="fg-select" required>
                                <option value="">Select Type</option>
                                <option value="Single">Single</option>
                                <option value="Double">Double</option>
                                <option value="Triple">Triple</option>
                                <option value="Quad">Quad</option>
                                <option value="Suite">Suite</option>
                            </select>
                        </div>
                        <div class="fg">
                            <label class="fg-label">Capacity *</label>
                            <input type="number" id="roomCapacity" name="Capacity" min="1" class="fg-input" required>
                        </div>
                        <div class="fg">
                            <label class="fg-label">Gender *</label>
                            <select id="roomGender" name="Gender" class="fg-select" required>
                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Any">Any</option>
                            </select>
                        </div>
                        <div class="fg">
                            <label class="fg-label">Status *</label>
                            <select id="roomStatus" name="Status" class="fg-select" required>
                                @if (ViewBag.StatusOptions != null)
                                {
                                    foreach (var status in ViewBag.StatusOptions)
                                    {
                                        <option value="@status.Value">@status.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="fg span-2">
                            <div class="fg-check">
                                <input type="checkbox" id="roomIsSpecialReservation" name="IsSpecialReservation">
                                <span>Special Reservation Room</span>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="bbtn bbtn-mist" onclick="hideRoomModal()">Cancel</button>
                <button class="bbtn bbtn-coral" onclick="document.getElementById('roomForm').requestSubmit()">
                    <i class="fas fa-save"></i> Save Room
                </button>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════
         ADD BED MODAL
    ════════════════════════════════ -->
    <div id="addBedModal" class="bgs-overlay hidden">
        <div class="bgs-modal" style="max-width:420px;">
            <div class="modal-head navy">
                <span class="modal-title"><i class="fas fa-bed"></i> Add Bed Space</span>
                <button class="modal-x" onclick="hideAddBedModal()"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <form id="addBedForm">
                    <div class="fg">
