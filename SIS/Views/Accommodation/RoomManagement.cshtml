        document.getElementById('bulkResourceAllRoomsModal').classList.remove('hidden');
    }
    function hideBulkResourceAllRoomsModal() { document.getElementById('bulkResourceAllRoomsModal').classList.add('hidden'); }
    function selectAllRooms()   { document.querySelectorAll('.room-checkbox').forEach(c => c.checked = true); }
    function deselectAllRooms() { document.querySelectorAll('.room-checkbox').forEach(c => c.checked = false); }
    function addBulkResourceAllRow() {
        const id  = bulkResourceAllCounter++;
        const div = document.createElement('div');
        div.className = 'bulk-item'; div.id = `bulkResourceAll_${id}`;
        div.innerHTML = `
            <div class="bulk-item-hd">
                <span class="bulk-item-title">Resource #${id + 1}</span>
                <button class="bulk-rm" onclick="document.getElementById('bulkResourceAll_${id}').remove()"><i class="fas fa-times"></i></button>
            </div>
            <div class="form-grid form-grid-3" style="gap:.6rem;">
                <div class="fg"><label class="fg-label">Type *</label>
                    <select class="bulk-resource-all-type-id fg-select" required>
                        <option value="">Select</option>${RESOURCE_TYPE_OPTIONS_HTML}
                    </select></div>
                <div class="fg"><label class="fg-label">Quantity *</label>
                    <input type="number" min="1" value="1" class="bulk-resource-all-quantity fg-input" required></div>
                <div class="fg"><label class="fg-label">Status *</label>
                    <select class="bulk-resource-all-status fg-select" required>${STATUS_OPTIONS_HTML}</select></div>
            </div>`;
        document.getElementById('bulkResourcesAllList').appendChild(div);
    }
    function removeBulkResourceAllRow(id) { document.getElementById(`bulkResourceAll_${id}`)?.remove(); }
    async function handleBulkResourceAllRoomsSubmit() {
        showLoader();
        try {
            const rooms = Array.from(document.querySelectorAll('.room-checkbox:checked')).map(c => parseInt(c.value));
            if (!rooms.length) { showNotification('Select at least one room','error'); return; }
            const items = document.querySelectorAll('#bulkResourcesAllList .bulk-item');
            if (!items.length) { showNotification('Add at least one resource','error'); return; }
            const resources = []; let valid = true;
            items.forEach(i => {
                const t = i.querySelector('.bulk-resource-all-type-id').value;
                const q = i.querySelector('.bulk-resource-all-quantity').value;
                if (!t || !q) { valid = false; return; }
                resources.push({ ResourceTypeId: parseInt(t), Quantity: parseInt(q), Status: parseInt(i.querySelector('.bulk-resource-all-status').value) });
            });
            if (!valid) { showNotification('Fill all required fields','error'); return; }
            const res = await fetch('/Room/ApplyResourcesToRooms', { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':getAntiForgeryToken()}, body: JSON.stringify({ RoomIds: rooms, Resources: resources }) });
            if (res.ok) { const r = await res.json(); showNotification(`Added ${r.resourcesAdded} resources to ${r.roomsAffected} rooms!`,'success'); hideBulkResourceAllRoomsModal(); await loadRooms(currentHostelId); }
            else { showNotification(await res.text() || 'Error applying resources','error'); }
        } catch(e) { showNotification('Error applying resources','error'); }
        finally { hideLoader(); }
    }

    // ── Copy resource to all rooms ──
    async function applyResourceToAllRooms(resourceId) {
        if (!currentHostelId || !currentHostelRooms.length) { showNotification('Select a hostel first','error'); return; }
        showLoader();
        try {
            const res  = await fetch(`/Room/GetRoomDetails?id=${currentRoomId}`);
            const room = await res.json();
            const r    = room.resources.find(x => x.resourceId === resourceId);
            if (!r) { showNotification('Resource not found','error'); return; }
            const otherIds = currentHostelRooms.filter(x => x.id !== currentRoomId).map(x => x.id);
            if (!otherIds.length) { showNotification('No other rooms to apply to','error'); return; }
            if (!await window.showAppConfirm(`Add "${r.name}" (Qty: ${r.quantity}) to all ${otherIds.length} other rooms?`, {
                title: 'Apply Resource',
                icon: 'question',
                confirmButtonText: 'Apply'
            })) return;
            const apply = await fetch('/Room/ApplyResourcesToRooms', { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':getAntiForgeryToken()}, body: JSON.stringify({ RoomIds: otherIds, Resources: [{ ResourceTypeId: r.resourceTypeId, Quantity: r.quantity, Status: r.status === 'Active' ? 1 : r.status === 'Inactive' ? 0 : 2 }] }) });
            if (apply.ok) { const result = await apply.json(); showNotification(`"${r.name}" added to ${result.roomsAffected} rooms!`,'success'); await loadRooms(currentHostelId); }
            else { showNotification(await apply.text() || 'Error applying resource','error'); }
        } catch(e) { showNotification('Error applying resource','error'); }
        finally { hideLoader(); }
    }

    // ── Occupied beds ──
    async function showOccupiedBedsModal() {
        showLoader();
        try {
            const url = currentHostelId ? `/Room/GetOccupiedBeds?hostelId=${currentHostelId}` : '/Room/GetOccupiedBeds';
            const res  = await fetch(url);
            const beds = await res.json();
            const c    = document.getElementById('occupiedBedsContainer');
            if (!beds.length) {
                c.innerHTML = emptyState('fa-bed','No Occupied Beds','No beds are currently occupied');
            } else {
                c.innerHTML = `<div style="overflow-x:auto;">
                    <table class="occ-table">
                        <thead><tr>
                            <th>Student</th><th>ID</th><th>Room</th><th>Bed</th><th>Hostel</th><th>Contact</th>
                        </tr></thead>
                        <tbody>
                            ${beds.map(b => `<tr>
                                <td><div style="display:flex;align-items:center;gap:.5rem;">
                                    <div class="occ-avatar"><i class="fas fa-user"></i></div>
                                    <span style="font-weight:600;">${b.studentName}</span>
                                </div></td>
                                <td style="color:var(--sub);">${b.studentNumber}</td>
                                <td style="color:var(--sub);">Room ${b.roomNumber} · Fl ${b.floor}</td>
                                <td style="color:var(--sub);">Bed ${b.bedIdentifier}</td>
                                <td style="color:var(--sub);">${b.hostelName}</td>
                                <td><div style="font-size:.75rem;color:var(--sub);">
                                    <div style="display:flex;align-items:center;gap:.3rem;margin-bottom:.2rem;"><i class="fas fa-envelope"></i>${b.email}</div>
                                    <div style="display:flex;align-items:center;gap:.3rem;"><i class="fas fa-phone"></i>${b.phone}</div>
                                </div></td>
                            </tr>`).join('')}
                        </tbody>
                    </table></div>`;
            }
            document.getElementById('occupiedBedsModal').classList.remove('hidden');
        } catch(e) { showNotification('Error loading occupied beds','error'); }
        finally { hideLoader(); }
    }
    function hideOccupiedBedsModal() { document.getElementById('occupiedBedsModal').classList.add('hidden'); }

    // ── Delete ──
    function deleteRoom(roomId, roomNumber) {
        showDeleteConfirmation(`Delete Room ${roomNumber}? All bed spaces and resources will also be deleted.`, async () => {
            await performDelete(`/Room/DeleteRoom/${roomId}`, 'Room');
            await loadRooms(currentHostelId);
        });
    }
    function deleteBed(bedId, bedIdentifier) {
        showDeleteConfirmation(`Delete Bed ${bedIdentifier}?`, async () => {
            await performDelete(`/Room/DeleteBedSpace/${bedId}`, 'Bed space');
            currentActiveTab = 'beds'; await showRoomDetails(currentRoomId);
        });
    }
    function deleteResource(resourceId, resourceName) {
        showDeleteConfirmation(`Delete resource "${resourceName}"?`, async () => {
            await performDelete(`/Room/DeleteRoomResource/${resourceId}`, 'Resource');
            currentActiveTab = 'resources'; await showRoomDetails(currentRoomId);
        });
    }
    function showDeleteConfirmation(message, onConfirm) {
        document.getElementById('deleteMessage').textContent = message;
        document.getElementById('deleteModal').classList.remove('hidden');
        document.getElementById('confirmDeleteBtn').onclick = async () => { await onConfirm(); hideDeleteModal(); };
    }
    function hideDeleteModal() { document.getElementById('deleteModal').classList.add('hidden'); }
    async function performDelete(url, label) {
        showLoader();
        try {
            const res = await fetch(url, { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded','RequestVerificationToken':getAntiForgeryToken()} });
            if (res.ok) showNotification(`${label} deleted!`,'success');
            else showNotification(await res.text() || `Error deleting ${label}`,'error');
        } catch(e) { showNotification(`Error deleting ${label}`,'error'); }
        finally { hideLoader(); }
    }

    // ── Maintenance ──
    async function loadMaintenanceRequests(roomId) {
        try {
            const res      = await fetch(`/Room/GetMaintenanceRequests?roomId=${roomId}`);
            const requests = await res.json();
            const c        = document.getElementById('maintenanceContent');
            if (!requests.length) { c.innerHTML = emptyState('fa-tools','No Maintenance Requests','Click Add Request to log a new maintenance issue'); return; }
            c.innerHTML = requests.map(req => {
                const pLc  = req.priority.toLowerCase();
                const pCls = pLc === 'high' ? 'pill-coral' : pLc === 'medium' ? 'pill-amber' : 'pill-green';
                const sCls = req.status === 'Active' ? 'pill-green' : req.status === 'Inactive' ? 'pill-slate' : 'pill-amber';
                const rDate = new Date(req.requestDate).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'});
                const resDate = req.resolutionDate ? new Date(req.resolutionDate).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) : null;
                return `<div class="mc ${pLc}">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                        <div style="flex:1;">
                            <div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;margin-bottom:.3rem;">
                                <span class="pill ${pCls}">${req.priority}</span>
                                <span class="pill ${sCls}">${req.status}</span>
                            </div>
                            <div style="font-size:.73rem;color:var(--lbl);">
                                ${rDate} · by ${req.requestedBy} (${req.requesterType})
                            </div>
                            <div class="mc-desc">${req.description || 'No description'}</div>
                            ${req.resolutionNotes?.trim() ? `<div class="mc-resolution"><i class="fas fa-check-circle" style="margin-right:.3rem;"></i><strong>Resolved${resDate ? ' ' + resDate : ''}:</strong> ${req.resolutionNotes}</div>` : ''}
                        </div>
                        <div style="display:flex;gap:.3rem;margin-left:.75rem;">
                            <button class="bc-btn bc-btn-edit" onclick="editMaintenanceRequest(${req.requestId})"><i class="fas fa-pen"></i></button>
                            <button class="bc-btn bc-btn-del"  onclick="deleteMaintenanceRequest(${req.requestId})"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>`;
            }).join('');
        } catch(e) { console.error('loadMaintenanceRequests:', e); }
    }
    function showAddMaintenanceModal() {
        document.getElementById('maintenanceModalTitle').innerHTML = '<i class="fas fa-tools"></i> Add Maintenance Request';
        document.getElementById('maintenanceForm').reset();
        document.getElementById('maintenanceRequestId').value = '0';
        document.getElementById('resolutionNotesContainer').style.display = 'none';
        document.getElementById('maintenanceModal').classList.remove('hidden');
    }
    function hideMaintenanceModal() { document.getElementById('maintenanceModal').classList.add('hidden'); }
    async function editMaintenanceRequest(requestId) {
        showLoader();
        try {
            const res      = await fetch(`/Room/GetMaintenanceRequests?roomId=${currentRoomId}`);
            const requests = await res.json();
            const req      = requests.find(r => r.requestId === requestId);
            if (req) {
                document.getElementById('maintenanceModalTitle').innerHTML = '<i class="fas fa-pen"></i> Edit Maintenance Request';
                document.getElementById('maintenanceRequestId').value      = req.requestId;
                document.getElementById('maintenanceRequestedBy').value    = req.requestedBy || '';
                document.getElementById('maintenanceRequesterType').value  = req.requesterType || '';
                document.getElementById('maintenanceDescription').value    = req.description || '';
                document.getElementById('maintenancePriority').value       = req.priority || '';
                const sm = {'Active':'1','Inactive':'0','Maintenance':'2'};
                document.getElementById('maintenanceStatus').value         = sm[req.status] || '0';
                document.getElementById('resolutionNotesContainer').style.display = '';
                document.getElementById('maintenanceResolutionNotes').value = req.resolutionNotes || '';
                document.getElementById('maintenanceModal').classList.remove('hidden');
            }
        } catch(e) { showNotification('Error loading request','error'); }
        finally { hideLoader(); }
    }
    async function handleMaintenanceSubmit(e) {
        e.preventDefault(); showLoader();
        try {
            const fd  = new FormData(e.target); const rid = parseInt(fd.get('RequestId'));
            fd.append('RoomId', currentRoomId);
            const url = rid > 0 ? '/Room/UpdateMaintenanceRequest' : '/Room/AddMaintenanceRequest';
            const res = await fetch(url, { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded','RequestVerificationToken':getAntiForgeryToken()}, body: new URLSearchParams(fd) });
            if (res.ok) { showNotification(rid > 0 ? 'Request updated!' : 'Request created!','success'); hideMaintenanceModal(); currentActiveTab = 'maintenance'; await showRoomDetails(currentRoomId); }
            else { showNotification(await res.text() || 'Error saving request','error'); }
        } catch(e) { showNotification('Error saving request','error'); }
        finally { hideLoader(); }
    }
    function deleteMaintenanceRequest(requestId) {
        showDeleteConfirmation('Delete this maintenance request?', async () => {
            await performDelete(`/Room/DeleteMaintenanceRequest/${requestId}`, 'Request');
            currentActiveTab = 'maintenance'; await showRoomDetails(currentRoomId);
        });
    }

    // ── Loading ──
    function showLoader() { document.getElementById('loadingIndicator').style.display = 'flex'; }
    function hideLoader() { document.getElementById('loadingIndicator').style.display = 'none'; }

    // ── Toast notifications ──
    function showNotification(message, type = 'success') {
        const t = document.createElement('div');
        t.className = `bgs-toast ${type}`;
        const icon = type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle';
        t.innerHTML = `<i class="fas ${icon}"></i><span>${message}</span>`;
        document.body.appendChild(t);
        setTimeout(() => { t.style.animation = 'toastOut .3s ease forwards'; setTimeout(() => t.remove(), 300); }, 3200);
    }

    // ── Window exports ──
    Object.assign(window, {
        loadRooms, showRoomDetails, closeRoomDetailsModal,
        showCreateRoomModal, editRoom, hideRoomModal, switchTab,
        showAddBedModal, hideAddBedModal, editBed, hideEditBedModal,
        showBulkBedModal, hideBulkBedModal, addBulkBedRow, removeBulkBedRow, handleBulkBedSubmit,
        showAddResourceModal, hideAddResourceModal, editResource,
        showBulkResourceModal, hideBulkResourceModal, addBulkResourceRow, removeBulkResourceRow, handleBulkResourceSubmit,
        showBulkResourceAllRoomsModal, hideBulkResourceAllRoomsModal,
        addBulkResourceAllRow, removeBulkResourceAllRow,
        selectAllRooms, deselectAllRooms, handleBulkResourceAllRoomsSubmit,
        applyResourceToAllRooms, showResourceTypeInfo,
        showOccupiedBedsModal, hideOccupiedBedsModal,
        deleteRoom, deleteBed, deleteResource, hideDeleteModal,
        showAddMaintenanceModal, hideMaintenanceModal,
        editMaintenanceRequest, deleteMaintenanceRequest, loadMaintenanceRequests
    });
</script>
}
