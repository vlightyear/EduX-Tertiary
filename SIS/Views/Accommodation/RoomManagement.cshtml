            async function handleBulkBedSubmit() {
                const loadingIndicator = document.getElementById('loadingIndicator');
                loadingIndicator.style.display = 'flex';

                try {
                    const container = document.getElementById('bulkBedsList');
                    const bedItems = container.querySelectorAll('.bulk-bed-item');

                    if (bedItems.length === 0) {
                        showNotification('Please add at least one bed', 'error');
                        loadingIndicator.style.display = 'none';
                        return;
                    }

                    const bedSpaces = [];
                    let isValid = true;

                    bedItems.forEach(item => {
                        const bedIdentifier = item.querySelector('.bulk-bed-identifier').value;
                        const status = item.querySelector('.bulk-bed-status').value;
                        const year = item.querySelector('.bulk-bed-year').value;
                        const semester = item.querySelector('.bulk-bed-semester').value;
                        const isSpecial = item.querySelector('.bulk-bed-special').checked;

                        if (!bedIdentifier) {
                            isValid = false;
                            return;
                        }

                        bedSpaces.push({
                            BedIdentifier: bedIdentifier,
                            Status: parseInt(status),
                            IsSpecialReservation: isSpecial,
                            CurrentStudentYear: parseInt(year),
                            CurrentStudentSemister: parseInt(semester)
                        });
                    });

                    if (!isValid) {
                        showNotification('Please fill in all required fields', 'error');
                        loadingIndicator.style.display = 'none';
                        return;
                    }

                    const payload = {
                        RoomId: currentRoomId,
                        BedSpaces: bedSpaces
                    };

                    const response = await fetch('/Room/AddBulkBedSpaces', {
                        method: 'POST',
