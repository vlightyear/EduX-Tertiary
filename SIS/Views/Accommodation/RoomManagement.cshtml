                    e.preventDefault();
                    const loadingIndicator = document.getElementById('loadingIndicator');
                    loadingIndicator.style.display = 'flex';

                    try {
                        const formData = new FormData(e.target);
                        const roomId = parseInt(formData.get('RoomId'));

                        const url = roomId > 0 ? '/Room/UpdateRoom' : '/Room/CreateRoom';

                        const response = await fetch(url, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'RequestVerificationToken': getAntiForgeryToken()
                            },
                            body: new URLSearchParams(formData)
                        });

                        if (response.ok) {
                            showNotification(roomId > 0 ? 'Room updated successfully!' : 'Room created successfully!', 'success');
                            hideRoomModal();
                            if (currentHostelId) {
                                await loadRooms(currentHostelId);
                            }
                        } else {
                            const error = await response.text();
                            showNotification(error || 'Error saving room', 'error');
                        }
                    } catch (error) {
                        console.error('Error saving room:', error);
                        showNotification('Error saving room', 'error');
                    } finally {
                        loadingIndicator.style.display = 'none';
                    }
                }

