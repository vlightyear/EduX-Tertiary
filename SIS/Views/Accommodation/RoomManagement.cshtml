@model IEnumerable<SIS.Models.StudentAccommodation.Room>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Room Management";
    var resourceTypes = ViewBag.ResourceTypes as List<SIS.Models.StudentAccommodation.ResourceType> ?? new List<SIS.Models.StudentAccommodation.ResourceType>();
}

<!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    /* Teal Theme Colors matching sidebar */
    :root {
        --teal-primary: #0d9488;
        --teal-hover: #0f766e;
        --teal-light: #5eead4;
    }

    /* Loading Indicator */
    #loadingIndicator {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        z-index: 10000 !important;
        background-color: rgba(0, 0, 0, 0.6) !important;
        display: none !important;
        align-items: center !important;
        justify-content: center !important;
    }

        #loadingIndicator[style*="display: flex"] {
            display: flex !important;
        }

    /* Modal fixes */
    .modal-overlay {
        position: fixed !important;
        inset: 0 !important;
        z-index: 9998 !important;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

        .modal-overlay.hidden {
            display: none !important;
        }

    /* Room card styling */
    .room-card {
        transition: all 0.3s ease;
        cursor: pointer;
        border-left: 4px solid transparent;
    }

        .room-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(13, 148, 136, 0.2);
            border-left-color: var(--teal-primary);
        }

        .room-card.active {
            border-left-color: #10b981;
        }

        .room-card.inactive {
            border-left-color: #6b7280;
        }

        .room-card.maintenance {
            border-left-color: #f59e0b;
        }

    /* Bed card styling */
    .bed-card {
        border: 2px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
        transition: all 0.3s;
        background: white;
    }

        .bed-card:hover {
            border-color: var(--teal-primary);
            box-shadow: 0 4px 12px rgba(13, 148, 136, 0.15);
        }

        .bed-card.occupied {
            border-left: 4px solid #10b981;
            background: rgba(16, 185, 129, 0.02);
        }

        .bed-card.available {
            border-left: 4px solid #0ea5e9;
            background: rgba(14, 165, 233, 0.02);
        }

        .bed-card.reserved {
            border-left: 4px solid #f59e0b;
            background: rgba(245, 158, 11, 0.02);
        }

    /* Resource item */
    .resource-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        margin-bottom: 0.5rem;
    }

        .resource-item:hover {
            background: #f9fafb;
            border-color: var(--teal-primary);
        }

        .resource-item button {
            padding: 0.5rem;
            border-radius: 0.375rem;
            transition: all 0.2s;
            min-width: 36px;
            min-height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid currentColor;
            background: white;
        }

            .resource-item button:hover {
                background: rgba(0, 0, 0, 0.05);
                transform: scale(1.1);
            }

            .resource-item button i {
                font-size: 1rem;
            }

    /* Bed card buttons */
    .bed-card button {
        padding: 0.5rem;
        border-radius: 0.375rem;
        transition: all 0.2s;
        min-width: 36px;
        min-height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid currentColor;
        background: white;
    }

        .bed-card button:hover {
            background: rgba(0, 0, 0, 0.05);
            transform: scale(1.1);
        }

        .bed-card button i {
            font-size: 1rem;
        }

    /* Button styles */
    .btn-teal {
        background-color: var(--teal-primary);
        color: white;
        padding: 0.5rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn-teal:hover {
            background-color: var(--teal-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(13, 148, 136, 0.3);
        }

    .btn-purple {
        background-color: #7c3aed;
        color: white;
        padding: 0.5rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn-purple:hover {
            background-color: #6d28d9;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
        }

    .btn-orange {
        background-color: #f59e0b;
        color: white;
        padding: 0.5rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn-orange:hover {
            background-color: #d97706;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
        }

    /* Resource Type Info Badge */
    .resource-type-info {
        display: inline-block;
        padding: 0.375rem 0.75rem;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 0.375rem;
        font-size: 0.875rem;
        color: #1e40af;
        line-height: 1.25rem;
    }

    /* Tab styling */
    .tab-button {
        padding: 1rem 1.5rem;
        border-bottom: 2px solid transparent;
        font-weight: 500;
        transition: all 0.2s;
        cursor: pointer;
    }

        .tab-button.active {
            border-bottom-color: var(--teal-primary);
            color: var(--teal-primary);
        }

        .tab-button:not(.active) {
            color: #6b7280;
        }

            .tab-button:not(.active):hover {
                color: #374151;
                background: #f9fafb;
            }

    /* Student info card */
    .student-info-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem;
        border-radius: 0.5rem;
        margin-top: 0.5rem;
    }

    /* Bulk resource item */
    .bulk-resource-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
    }

    /* Bulk bed space item */
    .bulk-bed-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
    }

    /* Room selector checkbox */
    .room-selector-item {
        padding: 0.75rem;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        margin-bottom: 0.5rem;
        transition: all 0.2s;
    }

        .room-selector-item:hover {
            background: #f9fafb;
            border-color: var(--teal-primary);
        }

        .room-selector-item input:checked ~ label {
            color: var(--teal-primary);
            font-weight: 600;
        }

    /* Maintenance request card */
    .maintenance-card {
        border: 2px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
        transition: all 0.3s;
        background: white;
    }

        .maintenance-card:hover {
            border-color: var(--teal-primary);
            box-shadow: 0 4px 12px rgba(13, 148, 136, 0.15);
        }

        .maintenance-card.low-priority {
            border-left: 4px solid #10b981;
            background: rgba(16, 185, 129, 0.02);
        }

        .maintenance-card.medium-priority {
            border-left: 4px solid #f59e0b;
            background: rgba(245, 158, 11, 0.02);
        }

        .maintenance-card.high-priority {
            border-left: 4px solid #ef4444;
            background: rgba(239, 68, 68, 0.02);
        }

    .priority-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .priority-low {
        background-color: #d1fae5;
        color: #065f46;
    }

    .priority-medium {
        background-color: #fef3c7;
        color: #92400e;
    }

    .priority-high {
        background-color: #fee2e2;
        color: #991b1b;
    }

    /* Special reservation badge */
    .special-reservation-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        background-color: #fef3c7;
        color: #92400e;
    }

    /* Year/Semester badge */
    .year-semester-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-weight: 600;
        background-color: #e0e7ff;
        color: #3730a3;
    }
</style>

<div class="container mx-auto px-4 py-6">
    @Html.AntiForgeryToken()

    <!-- Header -->
    <div class="mb-6">
        <div class="bg-gradient-to-r from-teal-600 to-cyan-600 rounded-xl shadow-lg p-6 text-white">
            <div class="flex justify-between items-center flex-wrap gap-4">
                <div>
                    <h4 class="text-2xl font-bold mb-2">
                        <i class="fas fa-door-open me-2"></i>Room Management
                    </h4>
                    <p class="text-teal-100">Manage hostel rooms, beds, and resources</p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <button class="bg-white text-teal-700 hover:bg-teal-50 px-6 py-3 rounded-lg font-semibold shadow-md transition" onclick="showOccupiedBedsModal()">
                        <i class="fas fa-users me-2"></i>View Occupants
                    </button>
                    <button id="bulkResourceAllBtn" class="bg-orange-500 text-white hover:bg-orange-600 px-6 py-3 rounded-lg font-semibold shadow-md transition" onclick="showBulkResourceAllRoomsModal()" style="display: none;">
                        <i class="fas fa-layer-group me-2"></i>Add Resources to All
                    </button>
                    <button class="bg-white text-teal-700 hover:bg-teal-50 px-6 py-3 rounded-lg font-semibold shadow-md transition" onclick="showCreateRoomModal()">
                        <i class="fas fa-plus-circle me-2"></i>Add Room
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-6">
        <h6 class="text-lg font-semibold text-gray-800 mb-4">
            <i class="fas fa-filter me-2 text-teal-600"></i>Filter Rooms
        </h6>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Campus</label>
                <select id="campusFilter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent">
                    <option value="">Select Campus</option>
                    @if (ViewBag.Campuses != null)
                    {
                        foreach (var campus in ViewBag.Campuses)
                        {
                            <option value="@campus.CampusId">@campus.CampusName</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Hostel</label>
                <select id="hostelFilter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent">
                    <option value="">Select Hostel</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Room Type</label>
                <select id="roomTypeFilter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent">
                    <option value="">All Types</option>
                    <option value="Single">Single</option>
                    <option value="Double">Double</option>
                    <option value="Triple">Triple</option>
                    <option value="Quad">Quad</option>
                    <option value="Suite">Suite</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Rooms Grid -->
    <div id="roomsContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>

    <!-- Loading Indicator -->
    <div id="loadingIndicator">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-16 w-16 border-t-4 border-b-4 border-white"></div>
            <p class="text-white mt-4 text-lg">Processing...</p>
        </div>
    </div>

    <!-- Room Details Modal -->
    <div id="roomDetailsModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
            <div class="bg-gradient-to-r from-teal-600 to-cyan-600 px-6 py-4 flex justify-between items-center">
                <h5 class="text-xl font-bold text-white">
                    <i class="fas fa-door-open me-2"></i>Room Details
                </h5>
                <button onclick="closeRoomDetailsModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
                <!-- Tabs -->
                <div class="border-b mb-6">
                    <div class="flex space-x-1">
                        <button class="tab-button active" onclick="switchTab('info')">
                            <i class="fas fa-info-circle me-2"></i>Room Info
                        </button>
                        <button class="tab-button" onclick="switchTab('beds')">
                            <i class="fas fa-bed me-2"></i>Bed Spaces
                        </button>
                        <button class="tab-button" onclick="switchTab('resources')">
                            <i class="fas fa-couch me-2"></i>Resources
                        </button>
                        <button class="tab-button" onclick="switchTab('maintenance')">
                            <i class="fas fa-tools me-2"></i>Maintenance
                        </button>
                    </div>
                </div>

                <!-- Tab Content -->
                <div id="infoTab" class="tab-content">
                    <div id="roomInfoContent"></div>
                </div>

                <div id="bedsTab" class="tab-content hidden">
                    <div class="flex justify-between items-center mb-4">
                        <h6 class="text-lg font-semibold">Bed Spaces</h6>
                        <div class="flex gap-2">
                            <button class="btn-purple" onclick="showBulkBedModal()">
                                <i class="fas fa-layer-group me-2"></i>Bulk Add Beds
                            </button>
                            <button class="btn-teal" onclick="showAddBedModal()">
                                <i class="fas fa-plus me-2"></i>Add Bed
                            </button>
                        </div>
                    </div>
                    <div id="bedSpacesContent"></div>
                </div>

                <div id="resourcesTab" class="tab-content hidden">
                    <div class="flex justify-between items-center mb-4">
                        <h6 class="text-lg font-semibold">Room Resources</h6>
                        <div class="flex gap-2">
                            <button class="btn-purple" onclick="showBulkResourceModal()">
                                <i class="fas fa-layer-group me-2"></i>Bulk Add
                            </button>
                            <button class="btn-teal" onclick="showAddResourceModal()">
                                <i class="fas fa-plus me-2"></i>Add Resource
                            </button>
                        </div>
                    </div>
                    <div id="resourcesContent"></div>
                </div>

                <div id="maintenanceTab" class="tab-content hidden">
                    <div class="flex justify-between items-center mb-4">
                        <h6 class="text-lg font-semibold">Maintenance Requests</h6>
                        <button class="btn-teal" onclick="showAddMaintenanceModal()">
                            <i class="fas fa-plus me-2"></i>Add Request
                        </button>
                    </div>
                    <div id="maintenanceContent"></div>
                </div>

            </div>
            <div class="bg-gray-50 px-6 py-4 flex justify-end">
                <button onclick="closeRoomDetailsModal()" class="px-6 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-times me-2"></i>Close
                </button>
            </div>
        </div>
    </div>
    <!-- Create/Edit Room Modal -->
    <div id="roomModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-hidden">
            <div class="bg-gradient-to-r from-teal-600 to-cyan-600 px-6 py-4 flex justify-between items-center">
                <h5 id="roomModalTitle" class="text-xl font-bold text-white">Add New Room</h5>
                <button onclick="hideRoomModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
                <form id="roomForm">
                    <input type="hidden" id="roomId" name="RoomId" value="0">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Hostel *</label>
                            <select id="roomHostelId" name="HostelId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                <option value="">Select Hostel</option>
                                @if (ViewBag.Hostels != null)
                                {
                                    foreach (var hostel in ViewBag.Hostels)
                                    {
                                        <option value="@hostel.HostelId">@hostel.HostelName (@hostel.Campus.CampusName)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Room Number *</label>
                            <input type="text" id="roomNumber" name="RoomNumber" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Floor *</label>
                            <input type="number" id="roomFloor" name="Floor" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Room Type *</label>
                            <select id="roomType" name="RoomType" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                <option value="">Select Type</option>
                                <option value="Single">Single</option>
                                <option value="Double">Double</option>
                                <option value="Triple">Triple</option>
                                <option value="Quad">Quad</option>
                                <option value="Suite">Suite</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Capacity *</label>
                            <input type="number" id="roomCapacity" name="Capacity" min="1" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Gender *</label>
                            <select id="roomGender" name="Gender" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Any">Any</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Status *</label>
                            <select id="roomStatus" name="Status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                @if (ViewBag.StatusOptions != null)
                                {
                                    foreach (var status in ViewBag.StatusOptions)
                                    {
                                        <option value="@status.Value">@status.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="md:col-span-2">
                            <label class="flex items-center space-x-2">
                                <input type="checkbox" id="roomIsSpecialReservation" name="IsSpecialReservation" class="rounded border-gray-300 text-teal-600 focus:ring-teal-500">
                                <span class="text-sm font-medium text-gray-700">Special Reservation Room</span>
                            </label>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end space-x-3">
                        <button type="button" onclick="hideRoomModal()" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                            Cancel
                        </button>
                        <button type="submit" class="btn-teal">
                            <i class="fas fa-save me-2"></i>Save Room
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Add Bed Modal -->
    <div id="addBedModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full">
            <div class="bg-gradient-to-r from-teal-600 to-cyan-600 px-6 py-4 flex justify-between items-center">
                <h5 class="text-xl font-bold text-white">Add Bed Space</h5>
                <button onclick="hideAddBedModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6">
                <form id="addBedForm">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Bed Identifier *</label>
                            <input type="text" id="bedIdentifier" name="BedIdentifier" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" placeholder="e.g., A, B, 1, 2" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Status *</label>
                            <select id="bedStatus" name="Status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                @if (ViewBag.StatusOptions != null)
                                {
                                    foreach (var status in ViewBag.StatusOptions)
                                    {
                                        <option value="@status.Value">@status.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="flex items-center space-x-2">
                                <input type="checkbox" id="bedIsSpecialReservation" name="IsSpecialReservation" class="rounded border-gray-300 text-teal-600 focus:ring-teal-500">
                                <span class="text-sm font-medium text-gray-700">Special Reservation</span>
                            </label>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Student Year</label>
                            <select id="bedCurrentStudentYear" name="CurrentStudentYear" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500">
                                <option value="0">All Years</option>
                                <option value="1">Year 1</option>
                                <option value="2">Year 2</option>
                                <option value="3">Year 3</option>
                                <option value="4">Year 4</option>
                                <option value="5">Year 5</option>
                            </select>
                        </div>
                        <div>
