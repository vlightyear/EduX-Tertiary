            // Apply single resource to all rooms
            async function applyResourceToAllRooms(resourceId) {
                if (!currentHostelId) {
                    showNotification('Please select a hostel first', 'error');
                    return;
                }

                if (currentHostelRooms.length === 0) {
                    showNotification('No rooms available in this hostel', 'error');
                    return;
                }

                const loadingIndicator = document.getElementById('loadingIndicator');
                loadingIndicator.style.display = 'flex';

                try {
                    // Get the resource details
                    const response = await fetch(`/Room/GetRoomDetails?id=${currentRoomId}`);
                    const room = await response.json();

                    const resource = room.resources.find(r => r.resourceId === resourceId);

                    if (!resource) {
                        showNotification('Resource not found', 'error');
                        loadingIndicator.style.display = 'none';
                        return;
                    }

                    // Get all room IDs except the current room
                    const allRoomIds = currentHostelRooms
                        .filter(r => r.id !== currentRoomId)
                        .map(r => r.id);

                    if (allRoomIds.length === 0) {
                        showNotification('No other rooms in this hostel to apply resource to', 'error');
                        loadingIndicator.style.display = 'none';
                        return;
                    }

                    // Confirm with user
                    const confirmMessage = `Add "${resource.name}" (Qty: ${resource.quantity}) to all ${allRoomIds.length} other rooms in this hostel?`;
                    if (!confirm(confirmMessage)) {
                        loadingIndicator.style.display = 'none';
                        return;
                    }

                    // Prepare payload
                    const payload = {
                        RoomIds: allRoomIds,
                        Resources: [{
                            ResourceTypeId: resource.resourceTypeId,
                            Quantity: resource.quantity,
                            Status: resource.status === 'Active' ? 1 : resource.status === 'Inactive' ? 0 : 2
                        }]
                    };

                    const applyResponse = await fetch('/Room/ApplyResourcesToRooms', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': getAntiForgeryToken()
                        },
                        body: JSON.stringify(payload)
                    });

                    if (applyResponse.ok) {
                        const result = await applyResponse.json();
                        showNotification(`Successfully added "${resource.name}" to ${result.roomsAffected} rooms!`, 'success');
                        await loadRooms(currentHostelId);
                    } else {
                        const error = await applyResponse.text();
                        showNotification(error || 'Error applying resource to rooms', 'error');
                    }
                } catch (error) {
                    console.error('Error applying resource to all rooms:', error);
                    showNotification('Error applying resource to rooms', 'error');
                } finally {
                    loadingIndicator.style.display = 'none';
                }
            }

