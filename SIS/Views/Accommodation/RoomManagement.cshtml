                                            <div class="mt-2 p-3 bg-gray-50 rounded border border-gray-200">
                                                <p class="text-sm text-gray-700 font-medium mb-1">Issue Description:</p>
                                                <p class="text-sm text-gray-600">${request.description || 'No description provided'}</p>
                                            </div>
                                            ${request.resolutionNotes && request.resolutionNotes.trim() !== '' ? `
                                                <div class="mt-2 p-3 bg-green-50 rounded border border-green-200">
                                                    <p class="text-xs font-semibold text-green-800 mb-1">
                                                        <i class="fas fa-check-circle me-1"></i>Resolution Notes
                                                        ${resolutionDate ? `<span class="font-normal">(Resolved: ${resolutionDate})</span>` : ''}
                                                    </p>
                                                    <p class="text-sm text-green-700">${request.resolutionNotes}</p>
                                                </div>
                                            ` : ''}
                                        </div>
                                        <div class="flex gap-2 items-center ml-3">
                                            <button type="button" class="text-teal-600 hover:text-teal-800 transition"
                                                    onclick="editMaintenanceRequest(${request.requestId})" title="Edit request">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button type="button" class="text-red-600 hover:text-red-800 transition"
                                                    onclick="deleteMaintenanceRequest(${request.requestId})" title="Delete request">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            `;
                        }).join('');
                    }
                } catch (error) {
                    console.error('Error loading maintenance requests:', error);
                    showNotification('Error loading maintenance requests', 'error');
                }
            }

            function showAddMaintenanceModal() {
                document.getElementById('maintenanceModalTitle').textContent = 'Add Maintenance Request';
                document.getElementById('maintenanceForm').reset();
                document.getElementById('maintenanceRequestId').value = '0';
                document.getElementById('resolutionNotesContainer').classList.add('hidden');
                document.getElementById('maintenanceModal').classList.remove('hidden');
            }

            function hideMaintenanceModal() {
                document.getElementById('maintenanceModal').classList.add('hidden');
            }

            async function editMaintenanceRequest(requestId) {
                const loadingIndicator = document.getElementById('loadingIndicator');
                loadingIndicator.style.display = 'flex';

                try {
                    const response = await fetch(`/Room/GetMaintenanceRequests?roomId=${currentRoomId}`);
                    const requests = await response.json();

                    const request = requests.find(r => r.requestId === requestId);

                    if (request) {
                        document.getElementById('maintenanceModalTitle').textContent = 'Edit Maintenance Request';
                        document.getElementById('maintenanceRequestId').value = request.requestId;
                        document.getElementById('maintenanceRequestedBy').value = request.requestedBy || '';
                        document.getElementById('maintenanceRequesterType').value = request.requesterType || '';
                        document.getElementById('maintenanceDescription').value = request.description || '';
                        document.getElementById('maintenancePriority').value = request.priority || '';

                        const statusMap = {
                            'Active': '1',
                            'Inactive': '0',
                            'Maintenance': '2'
                        };
                        document.getElementById('maintenanceStatus').value = statusMap[request.status] || '0';

                        // Always show resolution notes container when editing
                        document.getElementById('resolutionNotesContainer').classList.remove('hidden');
                        document.getElementById('maintenanceResolutionNotes').value = request.resolutionNotes || '';

                        document.getElementById('maintenanceModal').classList.remove('hidden');
                    }
                } catch (error) {
                    console.error('Error loading maintenance request:', error);
                    showNotification('Error loading maintenance request', 'error');
                } finally {
                    loadingIndicator.style.display = 'none';
                }
            }

            async function handleMaintenanceSubmit(e) {
                e.preventDefault();
                const loadingIndicator = document.getElementById('loadingIndicator');
                loadingIndicator.style.display = 'flex';

                try {
                    const formData = new FormData(e.target);
                    const requestId = parseInt(formData.get('RequestId'));
                    formData.append('RoomId', currentRoomId);

                    const url = requestId > 0 ? '/Room/UpdateMaintenanceRequest' : '/Room/AddMaintenanceRequest';

                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': getAntiForgeryToken()
                        },
                        body: new URLSearchParams(formData)
                    });

                    if (response.ok) {
                        showNotification(requestId > 0 ? 'Request updated successfully!' : 'Request created successfully!', 'success');
                        hideMaintenanceModal();
                        currentActiveTab = 'maintenance';
                        await showRoomDetails(currentRoomId);
                    } else {
                        const error = await response.text();
                        showNotification(error || 'Error saving request', 'error');
                    }
                } catch (error) {
                    console.error('Error saving maintenance request:', error);
                    showNotification('Error saving maintenance request', 'error');
                } finally {
                    loadingIndicator.style.display = 'none';
                }
            }

            function deleteMaintenanceRequest(requestId) {
                showDeleteConfirmation(
                    'Are you sure you want to delete this maintenance request?',
                    async function() {
                        await performDelete(`/Room/DeleteMaintenanceRequest/${requestId}`, 'maintenance request');
                        currentActiveTab = 'maintenance';
                        await showRoomDetails(currentRoomId);
                    }
                );
            }

            // Notification function
            function showNotification(message, type) {
                type = type || 'success';
                const notification = document.createElement('div');
                notification.className = `fixed top-4 right-4 z-50 px-6 py-4 rounded-lg shadow-lg transition-all transform ${
                    type === 'success' ? 'bg-green-500 text-white' :
                    type === 'error' ? 'bg-red-500 text-white' :
                    'bg-yellow-500 text-white'
                }`;
                notification.innerHTML = `
                    <div class="flex items-center space-x-2">
                        <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
                        <span>${message}</span>
                    </div>
                `;
                document.body.appendChild(notification);

                setTimeout(function() {
                    notification.style.transform = 'translateX(400px)';
                    setTimeout(function() { notification.remove(); }, 300);
                }, 3000);
            }

            // Global functions - exposing to window object
            window.loadRooms = loadRooms;
            window.showRoomDetails = showRoomDetails;
            window.closeRoomDetailsModal = closeRoomDetailsModal;
            window.showCreateRoomModal = showCreateRoomModal;
            window.editRoom = editRoom;
            window.hideRoomModal = hideRoomModal;
            window.switchTab = switchTab;
            window.showAddBedModal = showAddBedModal;
            window.hideAddBedModal = hideAddBedModal;
            window.editBed = editBed;
            window.hideEditBedModal = hideEditBedModal;
            window.showBulkBedModal = showBulkBedModal;
            window.hideBulkBedModal = hideBulkBedModal;
            window.addBulkBedRow = addBulkBedRow;
            window.removeBulkBedRow = removeBulkBedRow;
            window.handleBulkBedSubmit = handleBulkBedSubmit;
            window.showAddResourceModal = showAddResourceModal;
            window.hideAddResourceModal = hideAddResourceModal;
            window.editResource = editResource;
            window.showBulkResourceModal = showBulkResourceModal;
            window.hideBulkResourceModal = hideBulkResourceModal;
            window.addBulkResourceRow = addBulkResourceRow;
            window.removeBulkResourceRow = removeBulkResourceRow;
            window.handleBulkResourceSubmit = handleBulkResourceSubmit;
            window.showBulkResourceAllRoomsModal = showBulkResourceAllRoomsModal;
            window.hideBulkResourceAllRoomsModal = hideBulkResourceAllRoomsModal;
            window.addBulkResourceAllRow = addBulkResourceAllRow;
            window.removeBulkResourceAllRow = removeBulkResourceAllRow;
            window.selectAllRooms = selectAllRooms;
            window.deselectAllRooms = deselectAllRooms;
            window.handleBulkResourceAllRoomsSubmit = handleBulkResourceAllRoomsSubmit;
            window.applyResourceToAllRooms = applyResourceToAllRooms;
            window.showResourceTypeInfo = showResourceTypeInfo;
            window.showOccupiedBedsModal = showOccupiedBedsModal;
            window.hideOccupiedBedsModal = hideOccupiedBedsModal;
            window.deleteRoom = deleteRoom;
            window.deleteBed = deleteBed;
            window.deleteResource = deleteResource;
            window.hideDeleteModal = hideDeleteModal;
            window.showAddMaintenanceModal = showAddMaintenanceModal;
            window.hideMaintenanceModal = hideMaintenanceModal;
            window.editMaintenanceRequest = editMaintenanceRequest;
            window.deleteMaintenanceRequest = deleteMaintenanceRequest;
            window.loadMaintenanceRequests = loadMaintenanceRequests;
    </script>
}