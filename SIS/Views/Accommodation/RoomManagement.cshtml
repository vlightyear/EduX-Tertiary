@section Scripts {
    <script>
        // ══════════════════════════════════════════
        //  BGS Room Management — JavaScript
        // ══════════════════════════════════════════

        // Pre-render Razor lists as JS constants for dynamic row generation
        const STATUS_OPTIONS_HTML = `@if (ViewBag.StatusOptions != null) { foreach (var s in ViewBag.StatusOptions) {
        <text><option value="@s.Value">@s.Text</option></text>
    } }
`;
    const RESOURCE_TYPE_OPTIONS_HTML = `@foreach (var rt in resourceTypes) {
    <text><option value="@rt.ResourceTypeId">@rt.Name</option></text>
        }
`;

    // ── Globals ──
    let currentHostelId  = null;
    let currentRoomId    = null;
    let currentActiveTab = 'info';
    let bulkResourceCounter    = 0;
    let bulkResourceAllCounter = 0;
    let bulkBedCounter         = 0;
    let currentHostelRooms     = [];

    const STORAGE_KEYS = {
        CAMPUS:    'rm_campus',
        HOSTEL:    'rm_hostel',
        ROOM_TYPE: 'rm_roomType'
    };

    // ── Init ──
    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('campusFilter').addEventListener('change', handleCampusChange);
        document.getElementById('hostelFilter').addEventListener('change', handleHostelChange);
        document.getElementById('roomTypeFilter').addEventListener('change', handleRoomTypeChange);
        document.getElementById('roomForm').addEventListener('submit', handleRoomSubmit);
        document.getElementById('addBedForm').addEventListener('submit', handleAddBed);
        document.getElementById('editBedForm').addEventListener('submit', handleEditBed);
        document.getElementById('addResourceForm').addEventListener('submit', handleAddResource);
        document.getElementById('maintenanceForm').addEventListener('submit', handleMaintenanceSubmit);
        restoreFilters();
    });

    // ── localStorage helpers ──
    const lsSet   = (k, v) => { try { localStorage.setItem(k, v); } catch(e){} };
    const lsGet   = (k)    => { try { return localStorage.getItem(k); } catch(e){ return null; } };
    const lsClear = (k)    => { try { localStorage.removeItem(k); } catch(e){} };

    async function restoreFilters() {
        const camp = lsGet(STORAGE_KEYS.CAMPUS);
        const host = lsGet(STORAGE_KEYS.HOSTEL);
        const type = lsGet(STORAGE_KEYS.ROOM_TYPE);
        if (camp) {
            document.getElementById('campusFilter').value = camp;
            await loadHostelsByCampus(camp);
            if (host) {
                document.getElementById('hostelFilter').value = host;
                await loadRooms(parseInt(host));
            }
        }
        if (type) {
            document.getElementById('roomTypeFilter').value = type;
            filterRoomsByType();
        }
    }

    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]').value;
    }

    // ── Resource type description ──
    function showResourceTypeInfo(sel) {
        const desc = sel.options[sel.selectedIndex]?.getAttribute('data-description');
        const div  = document.getElementById('resourceTypeDescription');
        if (desc && desc.trim()) { div.textContent = desc; div.style.display = 'block'; }
        else { div.style.display = 'none'; }
    }

    // ── Hostels by campus ──
    async function loadHostelsByCampus(campusId) {
        try {
            const res     = await fetch(`/Room/GetHostelsByCampus/${campusId}`);
            const hostels = await res.json();
            const sel     = document.getElementById('hostelFilter');
            sel.innerHTML = '<option value="">Select Hostel</option>';
            hostels.forEach(h => {
                const o = document.createElement('option');
                o.value = h.id; o.textContent = h.name;
                sel.appendChild(o);
            });
        } catch(e) { console.error('loadHostelsByCampus:', e); }
    }

    // ── Filter handlers ──
    async function handleCampusChange(e) {
        const campusId = e.target.value;
        campusId ? lsSet(STORAGE_KEYS.CAMPUS, campusId) : (lsClear(STORAGE_KEYS.CAMPUS), lsClear(STORAGE_KEYS.HOSTEL));
        document.getElementById('hostelFilter').innerHTML = '<option value="">Select Hostel</option>';
        resetRoomsView();
        if (!campusId) return;
        await loadHostelsByCampus(campusId);
    }

    async function handleHostelChange(e) {
        const hostelId = e.target.value;
        if (hostelId) {
            lsSet(STORAGE_KEYS.HOSTEL, hostelId);
            await loadRooms(parseInt(hostelId));
            document.getElementById('bulkResourceAllBtn').style.display = 'inline-flex';
        } else {
            lsClear(STORAGE_KEYS.HOSTEL);
            resetRoomsView();
        }
    }

    function handleRoomTypeChange(e) {
        const t = e.target.value;
        t ? lsSet(STORAGE_KEYS.ROOM_TYPE, t) : lsClear(STORAGE_KEYS.ROOM_TYPE);
        filterRoomsByType();
    }

    function resetRoomsView() {
        document.getElementById('roomsContainer').innerHTML = `
            <div class="welcome-state" id="welcomeState">
                <div class="welcome-icon"><i class="fas fa-building"></i></div>
                <div class="welcome-title">Select a Hostel to Begin</div>
                <p class="welcome-sub">Choose a campus and hostel above to view rooms grouped by floor</p>
            </div>`;
        document.getElementById('bulkResourceAllBtn').style.display = 'none';
        document.getElementById('roomCountBadge').textContent = 'Select a hostel';
        setChips([]);
        currentHostelId = null;
    }

    function filterRoomsByType() {
        const t = document.getElementById('roomTypeFilter').value.toLowerCase();
        document.querySelectorAll('.rc').forEach(c => {
            c.style.display = (!t || c.dataset.roomType?.toLowerCase() === t) ? '' : 'none';
        });
        // hide floor sections if all rooms filtered out
        document.querySelectorAll('.floor-section').forEach(sec => {
            const visible = [...sec.querySelectorAll('.rc')].some(c => c.style.display !== 'none');
            sec.style.display = visible ? '' : 'none';
        });
        updateRoomCountBadge();
    }

    function updateRoomCountBadge() {
        const visible = document.querySelectorAll('.rc:not([style*="display: none"])').length;
        const total   = currentHostelRooms.length;
        document.getElementById('roomCountBadge').textContent =
            visible === total ? `${total} Room${total !== 1 ? 's' : ''}` : `${visible} / ${total} Rooms`;
    }

    // ── Stat chips ──
    function setChips(rooms) {
        document.getElementById('chipRooms').textContent       = rooms.length || '0';
        document.getElementById('chipOccupied').textContent    = rooms.reduce((s, r) => s + (r.occupiedBeds || 0), 0);
        document.getElementById('chipMaintenance').textContent = rooms.filter(r => r.status === 'Maintenance').length;
        document.getElementById('chipResources').textContent   = rooms.reduce((s, r) => s + (r.resourceCount || 0), 0);
    }

    // ── Load & render rooms ──
    async function loadRooms(hostelId) {
        showLoader();
        currentHostelId = hostelId;
        try {
            const res   = await fetch(`/Room/GetRoomsByHostel/${hostelId}`);
            const rooms = await res.json();
            currentHostelRooms = rooms;
            setChips(rooms);

            const container = document.getElementById('roomsContainer');
            if (!rooms.length) {
                container.innerHTML = `
                    <div class="welcome-state">
                        <div class="welcome-icon"><i class="fas fa-inbox"></i></div>
                        <div class="welcome-title">No Rooms Found</div>
                        <p class="welcome-sub">No rooms have been added to this hostel yet</p>
                        <button class="bbtn bbtn-coral" style="margin-top:1rem;" onclick="showCreateRoomModal()">
                            <i class="fas fa-plus"></i> Add First Room
                        </button>
                    </div>`;
                document.getElementById('roomCountBadge').textContent = '0 Rooms';
            } else {
                // Group by floor
                const byFloor = {};
                rooms.forEach(r => { (byFloor[r.floor] = byFloor[r.floor] || []).push(r); });
                const floors  = Object.keys(byFloor).sort((a, b) => parseInt(a) - parseInt(b));

                container.innerHTML = floors.map((floor, idx) => {
                    const floorRooms = byFloor[floor];
                    const label = parseInt(floor) === 0 ? 'Ground Floor' : `Floor ${floor}`;
                    return `
                    <div class="floor-section" style="animation-delay:${idx * 0.08}s;">
                        <div class="floor-header">
                            <div class="floor-badge"><i class="fas fa-layer-group"></i> ${label}</div>
                            <div class="floor-line"></div>
                            <div class="floor-count">${floorRooms.length} room${floorRooms.length !== 1 ? 's' : ''}</div>
                        </div>
                        <div class="rooms-grid">
                            ${floorRooms.map(r => renderRoomCard(r)).join('')}
                        </div>
                    </div>`;
                }).join('');

                document.getElementById('roomCountBadge').textContent = `${rooms.length} Room${rooms.length !== 1 ? 's' : ''}`;
                filterRoomsByType();
            }
        } catch(e) {
            console.error('loadRooms:', e);
            showNotification('Error loading rooms', 'error');
        } finally { hideLoader(); }
    }

    function renderRoomCard(r) {
        const statusKey = r.status?.toLowerCase();
        const barClass  = statusKey === 'active' ? 't-green' : statusKey === 'maintenance' ? 't-amber' : 't-slate';
        const occ       = r.bedCount > 0 ? Math.round((r.occupiedBeds / r.bedCount) * 100) : 0;
        const occColor  = occ === 0 ? '#22c55e' : occ < 90 ? '#f59e0b' : '#e85c5c';
        const statusChip = statusKey === 'active'
            ? `<span class="chip chip-green">Active</span>`
            : statusKey === 'maintenance'
            ? `<span class="chip chip-amber">Maintenance</span>`
            : `<span class="chip chip-slate">Inactive</span>`;
        const genderChip = r.gender === 'Male'
            ? `<span class="chip chip-navy"><i class="fas fa-mars"></i> Male</span>`
            : r.gender === 'Female'
            ? `<span class="chip chip-purple"><i class="fas fa-venus"></i> Female</span>`
            : `<span class="chip chip-slate">Any</span>`;
        const typeChip  = `<span class="chip chip-blue">${r.roomType}</span>`;
        const special   = r.isSpecialReservation ? `<span class="rc-special"><i class="fas fa-star"></i> Special</span>` : '';

        return `
        <div class="rc" data-room-type="${r.roomType}" onclick="showRoomDetails(${r.id})">
            <div class="rc-topbar ${barClass}"></div>
            <div class="rc-body">
                <div class="rc-header">
                    <div>
                        <div class="rc-num">${r.roomNumber}</div>
                        <div class="rc-meta">Floor ${r.floor}</div>
                    </div>
                    ${special}
                </div>
                <div class="rc-chips">${statusChip}${genderChip}${typeChip}</div>
                <div class="occ-wrap">
                    <div class="occ-lbl">
                        <span>Occupancy</span>
                        <span style="font-weight:700;color:${occColor};">${r.occupiedBeds}/${r.bedCount}</span>
                    </div>
                    <div class="occ-track">
                        <div class="occ-fill" style="width:${occ}%;background:${occColor};"></div>
                    </div>
                </div>
                <div style="font-size:.7rem;color:var(--lbl);margin-top:.35rem;">
                    <i class="fas fa-couch" style="margin-right:.3rem;"></i>${r.resourceCount} resource${r.resourceCount !== 1 ? 's' : ''}
                </div>
            </div>
            <div class="rc-actions">
                <button class="rc-act rc-act-edit" onclick="event.stopPropagation();editRoom(${r.id})">
                    <i class="fas fa-pen"></i> Edit
                </button>
                <button class="rc-act rc-act-del" onclick="event.stopPropagation();deleteRoom(${r.id},'${r.roomNumber}')">
                    <i class="fas fa-trash"></i> Delete
                </button>
            </div>
        </div>`;
    }

    // ── Room Details Modal ──
    async function showRoomDetails(roomId) {
        showLoader();
        currentRoomId = roomId;
        try {
            const res  = await fetch(`/Room/GetRoomDetails?id=${roomId}`);
            const room = await res.json();

            document.getElementById('rdmTitle').textContent = `Room ${room.roomNumber}`;

            // Info tab
            const specialRow = room.isSpecialReservation
                ? `<div class="dc span-2" style="background:var(--amber-lt);border-color:rgba(245,158,11,.25);">
                    <div class="dc-lbl">Reservation</div>
                    <div class="dc-val" style="color:#92400e;"><i class="fas fa-star" style="margin-right:.3rem;"></i>Special Reservation Room</div>
                   </div>` : '';
            document.getElementById('roomInfoContent').innerHTML = `
                <div class="dc-grid">
                    <div class="dc"><div class="dc-lbl">Room Number</div><div class="dc-val">${room.roomNumber}</div></div>
                    <div class="dc"><div class="dc-lbl">Floor</div><div class="dc-val">${room.floor === 0 ? 'Ground' : room.floor}</div></div>
                    <div class="dc"><div class="dc-lbl">Type</div><div class="dc-val">${room.roomType}</div></div>
                    <div class="dc"><div class="dc-lbl">Capacity</div><div class="dc-val">${room.capacity} person${room.capacity !== 1 ? 's' : ''}</div></div>
                    <div class="dc"><div class="dc-lbl">Gender</div><div class="dc-val">${room.gender}</div></div>
                    <div class="dc"><div class="dc-lbl">Status</div><div class="dc-val">${room.status}</div></div>
                    <div class="dc span-2"><div class="dc-lbl">Hostel</div><div class="dc-val">${room.hostelName} · ${room.campusName}</div></div>
                    ${specialRow}
                </div>`;

            // Beds tab
            if (room.beds?.length) {
                document.getElementById('bedSpacesContent').innerHTML = room.beds.map(b => {
                    const statusLc = b.status.toLowerCase();
                    const icon  = b.status === 'Occupied' ? '#22c55e' : b.status === 'Available' ? '#3b82f6' : '#f59e0b';
                    const yrSem = (b.currentStudentYear > 0 || b.currentStudentSemister > 0)
                        ? `<div style="display:flex;gap:.3rem;margin-top:.35rem;">
                            ${b.currentStudentYear > 0 ? `<span class="chip chip-navy">Yr ${b.currentStudentYear}</span>` : ''}
                            ${b.currentStudentSemister > 0 ? `<span class="chip chip-blue">Sem ${b.currentStudentSemister}</span>` : ''}
                           </div>` : '';
                    const student = b.studentName
                        ? `<div class="bc-student">
                            <i class="fas fa-user-circle" style="font-size:1.5rem;opacity:.85;"></i>
                            <div><div style="font-weight:600;font-size:.88rem;">${b.studentName}</div><div style="font-size:.75rem;opacity:.8;">ID: ${b.studentNumber}</div></div>
                           </div>`
                        : `<div class="bc-available"><i class="fas fa-info-circle"></i> Available for allocation</div>`;
                    return `
                    <div class="bc ${statusLc}">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                            <div style="flex:1;">
                                <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.2rem;">
                                    <i class="fas fa-bed" style="color:${icon};font-size:1.15rem;"></i>
                                    <span style="font-family:'DM Serif Display',serif;font-size:1.1rem;color:var(--txt);">Bed ${b.bedIdentifier}</span>
                                    ${b.isSpecialReservation ? '<span class="chip chip-amber"><i class="fas fa-star"></i> Special</span>' : ''}
                                    <span class="chip ${b.status === 'Occupied' ? 'chip-green' : b.status === 'Available' ? 'chip-blue' : 'chip-amber'}">${b.status}</span>
                                </div>
                                ${yrSem}
                                ${student}
                            </div>
                            <div class="bc-act">
                                <button class="bc-btn bc-btn-edit" onclick="editBed(${b.bedId})" title="Edit"><i class="fas fa-pen"></i></button>
                                <button class="bc-btn bc-btn-del"  onclick="deleteBed(${b.bedId},'${b.bedIdentifier}')" title="Delete"><i class="fas fa-trash"></i></button>
                            </div>
                        </div>
                    </div>`;
                }).join('');
            } else {
                document.getElementById('bedSpacesContent').innerHTML = emptyState('fa-bed','No Bed Spaces Yet','Use Add Bed or Bulk Add to create bed spaces for this room');
            }

            // Resources tab
            if (room.resources?.length) {
                document.getElementById('resourcesContent').innerHTML = room.resources.map(r => {
                    const en = (r.name||'').replace(/'/g,"\\'");
                    return `
                    <div class="res-item">
                        <div class="res-icon"><i class="fas fa-couch"></i></div>
                        <div class="res-body">
                            <div class="res-name">${r.name}</div>
                            <div class="res-desc">${r.description||'No description'}</div>
                            <div class="res-meta">Qty: <strong>${r.quantity}</strong> &nbsp;·&nbsp; Status: <strong>${r.status}</strong></div>
                        </div>
                        <div class="res-acts">
                            <button class="bc-btn" style="color:var(--amber);border-color:rgba(245,158,11,.3);" onclick="applyResourceToAllRooms(${r.resourceId})" title="Copy to all rooms"><i class="fas fa-copy"></i></button>
                            <button class="bc-btn bc-btn-edit" onclick="editResource(${r.resourceId})" title="Edit"><i class="fas fa-pen"></i></button>
                            <button class="bc-btn bc-btn-del"  onclick="deleteResource(${r.resourceId},'${en}')" title="Delete"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>`;
                }).join('');
            } else {
                document.getElementById('resourcesContent').innerHTML = emptyState('fa-couch','No Resources Yet','Use Add Resource or Bulk Add to equip this room');
            }

            document.getElementById('roomDetailsModal').classList.remove('hidden');
            switchTabProgrammatically(currentActiveTab);
        } catch(e) {
            console.error('showRoomDetails:', e);
            showNotification('Error loading room details','error');
        } finally { hideLoader(); }
    }

    function emptyState(icon, title, sub) {
        return `<div style="text-align:center;padding:2.5rem 1rem;color:var(--sub);">
            <i class="fas ${icon}" style="font-size:2.5rem;opacity:.25;margin-bottom:.75rem;display:block;"></i>
            <div style="font-weight:700;font-size:.9rem;">${title}</div>
            <div style="font-size:.78rem;margin-top:.3rem;">${sub}</div>
        </div>`;
    }

    function closeRoomDetailsModal() { document.getElementById('roomDetailsModal').classList.add('hidden'); }

    // ── Tabs ──
    function switchTab(name) { currentActiveTab = name; switchTabProgrammatically(name); }
    function switchTabProgrammatically(name) {
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.bgs-tab').forEach(b => b.classList.remove('active'));
        document.getElementById(name + 'Tab').classList.add('active');
        const idx = { info:0, beds:1, resources:2, maintenance:3 }[name] ?? 0;
        document.querySelectorAll('.bgs-tab')[idx].classList.add('active');
        if (name === 'maintenance') loadMaintenanceRequests(currentRoomId);
    }

    // ── Room CRUD ──
    function showCreateRoomModal() {
        document.getElementById('roomModalTitle').innerHTML = '<i class="fas fa-door-open"></i> Add New Room';
        document.getElementById('roomForm').reset();
        document.getElementById('roomId').value = '0';
        document.getElementById('roomModal').classList.remove('hidden');
    }
    async function editRoom(roomId) {
        showLoader();
        try {
            const res  = await fetch(`/Room/GetRoom?id=${roomId}`);
            const room = await res.json();
            document.getElementById('roomModalTitle').innerHTML = '<i class="fas fa-pen"></i> Edit Room';
            document.getElementById('roomId').value       = room.id;
            document.getElementById('roomHostelId').value = room.hostelId;
            document.getElementById('roomNumber').value   = room.roomNumber;
            document.getElementById('roomFloor').value    = room.floor;
            document.getElementById('roomType').value     = room.roomType;
            document.getElementById('roomCapacity').value = room.capacity;
            document.getElementById('roomGender').value   = room.gender;
            const statusMap = { 'Active':'1','Inactive':'0','Maintenance':'2' };
            document.getElementById('roomStatus').value = statusMap[room.status] || '1';
            document.getElementById('roomIsSpecialReservation').checked = room.isSpecialReservation;
            document.getElementById('roomModal').classList.remove('hidden');
        } catch(e) { console.error('editRoom:', e); showNotification('Error loading room','error'); }
        finally { hideLoader(); }
    }
    function hideRoomModal() { document.getElementById('roomModal').classList.add('hidden'); }
    async function handleRoomSubmit(e) {
        e.preventDefault(); showLoader();
        try {
            const fd     = new FormData(e.target);
            const roomId = parseInt(fd.get('RoomId'));
            const url    = roomId > 0 ? '/Room/UpdateRoom' : '/Room/CreateRoom';
            const res    = await fetch(url, { method:'POST', headers:{ 'Content-Type':'application/x-www-form-urlencoded','RequestVerificationToken':getAntiForgeryToken() }, body: new URLSearchParams(fd) });
            if (res.ok) {
                showNotification(roomId > 0 ? 'Room updated!' : 'Room created!','success');
                hideRoomModal();
                if (currentHostelId) await loadRooms(currentHostelId);
            } else { showNotification(await res.text() || 'Error saving room','error'); }
        } catch(e) { showNotification('Error saving room','error'); }
        finally { hideLoader(); }
    }

