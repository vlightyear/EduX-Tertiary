@model SIS.Controllers.AccomodationControllers.BedAllocationIndexViewModel
@{
    ViewData["Title"] = "Bed Allocation Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    console.log('=== Bed Allocation Scripts Loading ===');

    // Store current student data
    let currentStudentData = null;

    // ===================================
    // ALLOCATION MODAL
    // ===================================

    window.openAllocationModal = function(studentId, gender) {
        console.log('Opening allocation modal for student:', studentId, 'gender:', gender);

        // Get student data from the details panel
        const detailsScroll = document.querySelector('.details-scroll');
        if (detailsScroll && detailsScroll.dataset.studentData) {
            currentStudentData = JSON.parse(detailsScroll.dataset.studentData);
        }

        const isAdmin = currentStudentData?.isAdmin || false;
        const isHostelManager = currentStudentData?.isHostelManager || false;
        const campusesJson = currentStudentData?.campuses || [];

        Swal.fire({
            title: 'Allocate Bed Space',
            html: `
                <div style="text-align: left;">
                    ${!isHostelManager ? `
                    <div style="margin-bottom: 15px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 600;">Campus *</label>
                        <select id="campusSelect" class="swal2-input" style="width: 100%;" onchange="loadHostelsByCampus(${studentId}, '${gender}')">
                            <option value="">Select Campus</option>
                        </select>
                    </div>
                    ` : ''}
                    <div style="margin-bottom: 15px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 600;">Hostel *</label>
                        <select id="hostelSelect" class="swal2-input" style="width: 100%;" onchange="loadRoomsByHostel(${studentId}, '${gender}')" ${isHostelManager ? 'disabled' : ''}>
                            <option value="">Select Hostel</option>
                        </select>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 600;">Room *</label>
                        <select id="roomSelect" class="swal2-input" style="width: 100%;" onchange="loadBedsByRoom()">
                            <option value="">Select Room</option>
                        </select>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 600;">Bed *</label>
                        <select id="bedSelect" class="swal2-input" style="width: 100%;">
                            <option value="">Select Bed</option>
                        </select>
                    </div>
                </div>
            `,
            showCancelButton: true,
            confirmButtonText: '<i class="fas fa-check mr-2"></i>Allocate',
            cancelButtonText: '<i class="fas fa-times mr-2"></i>Cancel',
            confirmButtonColor: '#17a2b8',
            cancelButtonColor: '#6c757d',
            width: '500px',
            didOpen: () => {
                // Populate campus dropdown for admins
                if (!isHostelManager && campusesJson.length > 0) {
                    const campusSelect = document.getElementById('campusSelect');
                    campusesJson.forEach(campus => {
                        const option = document.createElement('option');
                        option.value = campus.campusId;
                        option.textContent = campus.campusName;
                        campusSelect.appendChild(option);
                    });
                }

                if (isHostelManager) {
                    window.loadHostelsForManager(studentId, gender);
                }
            },
            preConfirm: () => {
                const bedId = document.getElementById('bedSelect').value;
                if (!bedId) {
                    Swal.showValidationMessage('Please select a bed');
                    return false;
                }
                return { studentId: studentId, bedId: parseInt(bedId) };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.allocateBed(result.value.studentId, result.value.bedId);
            }
        });
    };

    // ===================================
    // DEALLOCATION MODAL
    // ===================================

    window.openDeallocationModal = function(studentId) {
        console.log('Opening deallocation modal for student:', studentId);

        Swal.fire({
            title: 'Deallocate Bed Space',
            html: `
                <div style="text-align: left;">
                    <div style="margin-bottom: 15px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 600;">Reason for Deallocation *</label>
                        <textarea id="deallocationReason" class="swal2-textarea" style="width: 100%; height: 100px;" placeholder="Enter reason for deallocating this student..."></textarea>
                    </div>
                </div>
            `,
            showCancelButton: true,
            confirmButtonText: '<i class="fas fa-times-circle mr-2"></i>Deallocate',
            cancelButtonText: '<i class="fas fa-times mr-2"></i>Cancel',
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            width: '500px',
            preConfirm: () => {
                const reason = document.getElementById('deallocationReason').value.trim();
                if (!reason) {
                    Swal.showValidationMessage('Please provide a reason for deallocation');
                    return false;
                }
                return { studentId: studentId, reason: reason };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.deallocateBed(result.value.studentId, result.value.reason);
            }
        });
    };

    // ===================================
    // LOAD FUNCTIONS
    // ===================================

    window.loadHostelsByCampus = function(studentId, gender) {
        const campusId = document.getElementById('campusSelect')?.value;
        const hostelSelect = document.getElementById('hostelSelect');
        const roomSelect = document.getElementById('roomSelect');
        const bedSelect = document.getElementById('bedSelect');

        if (!hostelSelect) return;

        hostelSelect.innerHTML = '<option value="">Loading...</option>';
        if (roomSelect) roomSelect.innerHTML = '<option value="">Select Room</option>';
        if (bedSelect) bedSelect.innerHTML = '<option value="">Select Bed</option>';

        if (!campusId) {
            hostelSelect.innerHTML = '<option value="">Select Campus first</option>';
            return;
        }

        // Get selected hostel ID from URL if available (for hostel managers)
        const urlParams = new URLSearchParams(window.location.search);
        const selectedHostelId = urlParams.get('selectedHostelId');

        let url = `@Url.Action("GetHostelsByCampus", "BedAllocation")?campusId=${campusId}&gender=${gender}`;
        if (selectedHostelId) {
            url += `&selectedHostelId=${selectedHostelId}`;
        }

        fetch(url)
            .then(response => response.json())
            .then(data => {
                hostelSelect.innerHTML = '<option value="">Select Hostel</option>';
                if (data.success && data.hostels.length > 0) {
                    data.hostels.forEach(hostel => {
                        const option = document.createElement('option');
                        option.value = hostel.hostelId;
                        option.textContent = `${hostel.hostelName} (${hostel.availableBeds} beds available)`;
                        hostelSelect.appendChild(option);
                    });
                } else {
                    hostelSelect.innerHTML = '<option value="">No hostels available</option>';
                    Swal.showValidationMessage('No hostels available for this campus and gender');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                hostelSelect.innerHTML = '<option value="">Error loading</option>';
                Swal.showValidationMessage('Error loading hostels');
            });
    };

    window.loadHostelsForManager = function(studentId, gender) {
        const hostelSelect = document.getElementById('hostelSelect');
        if (!hostelSelect) return;

        hostelSelect.innerHTML = '<option value="">Loading...</option>';

        // Get selected hostel ID from URL
        const urlParams = new URLSearchParams(window.location.search);
        const selectedHostelId = urlParams.get('selectedHostelId');

        let url = `@Url.Action("GetHostelsByCampus", "BedAllocation")?campusId=0&gender=${gender}`;
        if (selectedHostelId) {
            url += `&selectedHostelId=${selectedHostelId}`;
        }

        fetch(url)
            .then(response => response.json())
            .then(data => {
                if (data.success && data.hostels.length > 0) {
                    const hostel = data.hostels[0];
                    hostelSelect.innerHTML = `<option value="${hostel.hostelId}">${hostel.hostelName} (${hostel.availableBeds} beds available)</option>`;
                    hostelSelect.value = hostel.hostelId;
                    window.loadRoomsByHostel(studentId, gender);
                } else {
                    hostelSelect.innerHTML = '<option value="">No hostel assigned</option>';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                hostelSelect.innerHTML = '<option value="">Error loading</option>';
            });
    };

    window.loadRoomsByHostel = function(studentId, gender) {
        const hostelId = document.getElementById('hostelSelect')?.value;
        const roomSelect = document.getElementById('roomSelect');
        const bedSelect = document.getElementById('bedSelect');

        if (!roomSelect) return;

        roomSelect.innerHTML = '<option value="">Loading...</option>';
        if (bedSelect) bedSelect.innerHTML = '<option value="">Select Bed</option>';

        if (!hostelId) {
            roomSelect.innerHTML = '<option value="">Select Hostel first</option>';
            return;
        }

        fetch(`@Url.Action("GetRoomsByHostel", "BedAllocation")?hostelId=${hostelId}&gender=${gender}`)
            .then(response => response.json())
            .then(data => {
                roomSelect.innerHTML = '<option value="">Select Room</option>';
                if (data.success && data.rooms.length > 0) {
                    data.rooms.forEach(room => {
                        const option = document.createElement('option');
                        option.value = room.roomId;
                        option.textContent = `Room ${room.roomNumber} - Floor ${room.floor} (${room.availableBeds}/${room.totalBeds} available)`;
                        roomSelect.appendChild(option);
                    });
                } else {
                    roomSelect.innerHTML = '<option value="">No rooms available</option>';
                    Swal.showValidationMessage('No rooms available in this hostel');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                roomSelect.innerHTML = '<option value="">Error loading</option>';
                Swal.showValidationMessage('Error loading rooms');
            });
    };

    window.loadBedsByRoom = function() {
        const roomId = document.getElementById('roomSelect')?.value;
        const bedSelect = document.getElementById('bedSelect');

        if (!bedSelect) return;

        bedSelect.innerHTML = '<option value="">Loading...</option>';

        if (!roomId) {
            bedSelect.innerHTML = '<option value="">Select Room first</option>';
            return;
        }

        fetch(`@Url.Action("GetBedsByRoom", "BedAllocation")?roomId=${roomId}`)
            .then(response => response.json())
            .then(data => {
                bedSelect.innerHTML = '<option value="">Select Bed</option>';
                if (data.success && data.beds.length > 0) {
                    data.beds.forEach(bed => {
                        const option = document.createElement('option');
                        option.value = bed.bedId;
                        option.textContent = `Bed ${bed.bedIdentifier}`;
                        bedSelect.appendChild(option);
                    });
                } else {
                    bedSelect.innerHTML = '<option value="">No beds available</option>';
                    Swal.showValidationMessage('No beds available in this room');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                bedSelect.innerHTML = '<option value="">Error loading</option>';
                Swal.showValidationMessage('Error loading beds');
            });
    };

    // ===================================
    // ALLOCATION ACTIONS
    // ===================================

    window.allocateBed = function(studentId, bedId) {
        console.log('Allocating bed:', bedId, 'to student:', studentId);

        Swal.fire({
            title: 'Processing...',
            text: 'Allocating bed space',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        const token = document.querySelector('input[name="__RequestVerificationToken"]');

        fetch('@Url.Action("AllocateBed", "BedAllocation")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token ? token.value : ''
            },
            body: JSON.stringify({ studentId: studentId, bedId: bedId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    html: `<p>${data.message}</p><p style="margin-top: 10px;"><strong>${data.data.bedLocation}</strong></p>`,
                    confirmButtonColor: '#28a745'
                }).then(() => {
                    window.location.reload();
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: data.message,
                    confirmButtonColor: '#dc3545'
                });
            }
        })
        .catch(error => {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Error: ' + error.message,
                confirmButtonColor: '#dc3545'
            });
            console.error('Error:', error);
        });
    };

    window.deallocateBed = function(studentId, reason) {
        console.log('Deallocating bed for student:', studentId, 'reason:', reason);

        Swal.fire({
            title: 'Processing...',
            text: 'Deallocating bed space',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        const token = document.querySelector('input[name="__RequestVerificationToken"]');

        fetch('@Url.Action("DeallocateBed", "BedAllocation")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token ? token.value : ''
            },
            body: JSON.stringify({ studentId: studentId, reason: reason })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: data.message,
                    confirmButtonColor: '#28a745'
                }).then(() => {
                    window.location.reload();
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: data.message,
                    confirmButtonColor: '#dc3545'
                });
            }
        })
        .catch(error => {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Error: ' + error.message,
                confirmButtonColor: '#dc3545'
            });
            console.error('Error:', error);
        });
    };

    // ===================================
    // STUDENT DETAILS LOADER
    // ===================================

    window.loadStudentDetails = function(studentId) {
        console.log('Loading details for student:', studentId);

        document.querySelectorAll('.student-card').forEach(card => {
            card.classList.remove('selected');
        });

        const clickedCard = document.querySelector(`[data-student-id="${studentId}"]`);
        if (clickedCard) {
            clickedCard.classList.add('selected');
        }

        fetch('@Url.Action("GetStudentDetails", "BedAllocation")?studentId=' + studentId)
            .then(response => response.text())
            .then(html => {
                document.getElementById('studentDetailsContainer').innerHTML = html;
            })
            .catch(error => {
                console.error('Error:', error);
                document.getElementById('studentDetailsContainer').innerHTML =
                    '<div class="no-selection"><i class="fas fa-exclamation-triangle"></i><h3>Error</h3><p>Please try again</p></div>';
            });
    };

    console.log('=== All functions defined successfully ===');
</script>

<style>
