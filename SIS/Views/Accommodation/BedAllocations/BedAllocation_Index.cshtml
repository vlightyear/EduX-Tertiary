    }

    .student-name {
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 3px;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
