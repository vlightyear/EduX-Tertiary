    }

        .card-info i {
            font-size: 14px;
            color: #999;
            width: 16px;
        }

    /* Details Panel */
    .details-panel {
        flex: 1;
        background: #fafafa;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        height: 100%;
    }

    .no-selection {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #999;
    }

        .no-selection i {
            font-size: 80px;
            color: #ddd;
            margin-bottom: 20px;
        }

        .no-selection h3 {
            color: #666;
            font-weight: 500;
            margin-bottom: 10px;
        }

        .no-selection p {
            color: #999;
            font-size: 14px;
        }

    .details-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 0;
        height: 100%;
    }

        /* Scrollbar styling */
        .students-list::-webkit-scrollbar,
        .details-content::-webkit-scrollbar {
            width: 8px;
        }

        .students-list::-webkit-scrollbar-track,
        .details-content::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        .students-list::-webkit-scrollbar-thumb,
        .details-content::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 4px;
        }

            .students-list::-webkit-scrollbar-thumb:hover,
            .details-content::-webkit-scrollbar-thumb:hover {
                background: #555;
            }

    /* Responsive */
    @@media (max-width: 1200px) {
        .search-form {
            grid-template-columns: 1fr;
        }

        .students-panel {
            flex: 0 0 350px;
        }
    }

    @@media (max-width: 768px) {
        .allocation-container {
            flex-direction: column;
            height: auto;
        }

        .students-panel {
            flex: 0 0 auto;
            max-height: 400px;
        }

        .statistics-bar {
            flex-direction: column;
        }
    }
</style>

<!-- Header -->
<div class="allocation-header">
    <div class="header-top">
        <div class="header-title">
            <i class="fas fa-bed"></i>
            <div>
                <h2>Bed Allocation Management</h2>
                <p class="header-subtitle">Allocate and manage student accommodation</p>
            </div>
        </div>
        <div>
            <span class="role-badge">
                <i class="fas fa-user-shield"></i>
                Role: @(Model.IsAdmin ? "Admin" : Model.IsHostelManager ? "Hostel Manager" : "Staff")
            </span>
        </div>
    </div>
</div>

<!-- Hostel Manager Notice/Selector -->
@if (Model.IsHostelManager)
{
    @if (Model.AssignedHostels != null && Model.AssignedHostels.Count > 1)
    {
        <!-- Multiple Hostels - Show Selector -->
        <div class="hostel-selector-bar">
            <div class="hostel-selector-content">
                <i class="fas fa-hotel"></i>
                <span style="margin-right: 15px;">Managing Multiple Hostels:</span>
                <select id="hostelSelector" class="hostel-select" onchange="switchHostel(this.value)">
                    @foreach (var hostel in Model.AssignedHostels)
                    {
                        <option value="@hostel.HostelId" selected="@(hostel.HostelId == Model.AssignedHostel.HostelId)">
                            @hostel.HostelName - @hostel.Campus.CampusName
                        </option>
                    }
                </select>
                <span class="hostel-count-badge">@Model.AssignedHostels.Count hostels</span>
            </div>
        </div>
    }
    else if (Model.AssignedHostel != null)
    {
        <!-- Single Hostel - Show Info -->
        <div class="hostel-notice">
            <i class="fas fa-info-circle"></i>
            <span>You are managing: <strong>@Model.AssignedHostel.HostelName</strong> at <strong>@Model.AssignedHostel.Campus.CampusName Campus</strong></span>
        </div>
    }
}

<!-- Statistics Bar -->
<div class="statistics-bar">
    <div class="stat-card blue">
        <i class="fas fa-users"></i>
        <div class="stat-info">
            <h6>Total Students</h6>
            <p>@Model.TotalStudents</p>
        </div>
    </div>
    <div class="stat-card green">
        <i class="fas fa-user-check"></i>
        <div class="stat-info">
            <h6>Accommodated</h6>
            <p>@Model.AccommodatedCount</p>
        </div>
    </div>
    <div class="stat-card orange">
        <i class="fas fa-user-clock"></i>
        <div class="stat-info">
            <h6>Not Accommodated</h6>
            <p>@Model.NotAccommodatedCount</p>
        </div>
    </div>
    <div class="stat-card cyan">
        <i class="fas fa-bed"></i>
        <div class="stat-info">
            <h6>Available Beds</h6>
            <p>@Model.AvailableBeds / @Model.TotalBeds</p>
        </div>
    </div>
</div>

<!-- Search Section -->
<div class="search-section">
    <div class="search-title">
        <i class="fas fa-search"></i>
        <span>Search Students</span>
    </div>
    <form asp-action="Index" method="get" class="search-form">
        <div class="form-group">
            <label for="searchTerm">Search Term</label>
            <input type="text"
                   class="form-control"
                   id="searchTerm"
                   name="searchTerm"
                   placeholder="Search by student name, number, or email..."
                   value="@Model.SearchTerm" />
        </div>
        <div class="form-group">
            <label for="searchBy">Search By</label>
            <select class="form-control" id="searchBy" name="searchBy">
                <option value="AllFields" selected="@(Model.SearchBy == "AllFields")">All Fields</option>
                <option value="StudentNumber" selected="@(Model.SearchBy == "StudentNumber")">Student Number</option>
                <option value="StudentName" selected="@(Model.SearchBy == "StudentName")">Student Name</option>
                <option value="Email" selected="@(Model.SearchBy == "Email")">Email</option>
            </select>
        </div>
        <input type="hidden" name="filterStatus" value="@Model.FilterStatus" />
        @if (Model.AssignedHostel != null)
        {
            <input type="hidden" name="selectedHostelId" value="@Model.AssignedHostel.HostelId" />
        }
        <button type="submit" class="search-btn">
            <i class="fas fa-search"></i>
            Search
        </button>
        <a asp-action="Index" class="clear-btn">
            <i class="fas fa-times"></i>
        </a>
    </form>
</div>

<!-- Filter Tabs -->
<div class="filter-tabs">
    <a href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, searchBy = Model.SearchBy, filterStatus = "NotAccommodated", selectedHostelId = Model.AssignedHostel?.HostelId })"
       class="filter-tab @(Model.FilterStatus == "NotAccommodated" ? "active" : "")">
        <i class="fas fa-user-clock"></i>
        Not Accommodated
        <span class="count">@Model.NotAccommodatedCount</span>
    </a>
    <a href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, searchBy = Model.SearchBy, filterStatus = "Accommodated", selectedHostelId = Model.AssignedHostel?.HostelId })"
       class="filter-tab @(Model.FilterStatus == "Accommodated" ? "active" : "")">
        <i class="fas fa-user-check"></i>
        Accommodated
        <span class="count">@Model.AccommodatedCount</span>
    </a>
</div>

<!-- Main Container -->
<div class="allocation-container">
    <!-- Students Panel -->
    <div class="students-panel">
        <div class="students-header">
            <h3>Students</h3>
            <span class="students-count">@Model.Students.Count results</span>
        </div>
        <div class="students-list">
            @if (Model.Students.Any())
            {
                foreach (var student in Model.Students)
                {
                    var statusClass = student.BedId.HasValue ? "accommodated" : "not-accommodated";
                    var statusText = student.BedId.HasValue ? "Accommodated" : "Not Accommodated";

                    <div class="student-card"
                         data-student-id="@student.Id">
                        <div class="student-header">
                            <div>
                                <div class="student-name">@student.FullName</div>
                                <div class="card-info">
                                    <i class="fas fa-id-card"></i>
                                    <span>@student.StudentId_Number</span>
                                </div>
                            </div>
                            <span class="status-badge @statusClass">@statusText</span>
                        </div>

                        <div class="card-info">
                            <i class="fas fa-graduation-cap"></i>
                            <span>@student.Programme?.Name</span>
                        </div>

                        <div class="card-info">
                            <i class="fas fa-school"></i>
                            <span>@student.Programme?.Department?.School?.Name</span>
                        </div>

                        @if (student.BedSpace != null)
                        {
                            <div class="card-info" style="margin-top: 8px; color: #17a2b8;">
                                <i class="fas fa-bed"></i>
                                <span>@student.BedSpace.Room.Hostel.HostelName - Room @student.BedSpace.Room.RoomNumber</span>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 40px; color: #999;">
                    <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 15px;"></i>
                    <p>No students found</p>
                </div>
            }
        </div>
    </div>

    <!-- Details Panel -->
    <div class="details-panel">
        <div id="studentDetailsContainer" class="details-content">
            <div class="no-selection">
                <i class="fas fa-user-circle"></i>
                <h3>No Student Selected</h3>
                <p>Select a student from the list to view details and manage allocation</p>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<script>
    // ===================================
    // MULTI-HOSTEL MANAGEMENT WITH LOCALSTORAGE
    // ===================================

    // LocalStorage key for selected hostel
    const HOSTEL_STORAGE_KEY = 'bedAllocation_selectedHostelId';

    // Switch hostel and reload
    window.switchHostel = function(hostelId) {
        console.log('Switching to hostel:', hostelId);

        // Save to localStorage
        localStorage.setItem(HOSTEL_STORAGE_KEY, hostelId);

        // Build URL with all current parameters plus new hostel
        const url = new URL(window.location);
        url.searchParams.set('selectedHostelId', hostelId);

        // Keep existing search parameters
        const searchTerm = url.searchParams.get('searchTerm');
        const searchBy = url.searchParams.get('searchBy');
        const filterStatus = url.searchParams.get('filterStatus');

        if (searchTerm) url.searchParams.set('searchTerm', searchTerm);
        if (searchBy) url.searchParams.set('searchBy', searchBy);
        if (filterStatus) url.searchParams.set('filterStatus', filterStatus);

        window.location.href = url.toString();
    };

    // Clear hostel preference (optional - for logout)
    window.clearHostelPreference = function() {
        localStorage.removeItem(HOSTEL_STORAGE_KEY);
    };

    // ===================================
    // EVENT DELEGATION FOR ALL CLICKS
    // ===================================

    document.addEventListener('click', function(e) {
        // Handle Student Card clicks
        const studentCard = e.target.closest('.student-card');
        if (studentCard && !e.target.closest('.btn-allocate') && !e.target.closest('.btn-deallocate')) {
            const studentId = parseInt(studentCard.dataset.studentId);
            if (typeof window.loadStudentDetails === 'function') {
                window.loadStudentDetails(studentId);
            }
            return;
        }

        // Handle Allocate button clicks
        const allocateBtn = e.target.closest('.btn-allocate');
        if (allocateBtn) {
            e.preventDefault();
            e.stopPropagation();
            const studentId = parseInt(allocateBtn.dataset.studentId);
            const gender = allocateBtn.dataset.gender;
            if (typeof window.openAllocationModal === 'function') {
                window.openAllocationModal(studentId, gender);
            }
            return;
        }

        // Handle Deallocate button clicks
        const deallocateBtn = e.target.closest('.btn-deallocate');
        if (deallocateBtn) {
            e.preventDefault();
            e.stopPropagation();
            const studentId = parseInt(deallocateBtn.dataset.studentId);
            if (typeof window.openDeallocationModal === 'function') {
                window.openDeallocationModal(studentId);
            }
            return;
        }
    }, true);

    // ===================================
    // PAGE INITIALIZATION
    // ===================================

    document.addEventListener('DOMContentLoaded', function() {
        console.log('=== DOM Content Loaded ===');

        // Handle hostel selector localStorage persistence
        const hostelSelector = document.getElementById('hostelSelector');
        if (hostelSelector) {
            const urlParams = new URLSearchParams(window.location.search);
            const urlHostelId = urlParams.get('selectedHostelId');
            const storedHostelId = localStorage.getItem(HOSTEL_STORAGE_KEY);

            // If no URL parameter but we have stored preference
            if (!urlHostelId && storedHostelId) {
                // Check if stored hostel is in the dropdown
                const options = Array.from(hostelSelector.options);
                const matchingOption = options.find(opt => opt.value === storedHostelId);

                if (matchingOption) {
                    // Redirect with stored hostel
                    const url = new URL(window.location);
                    url.searchParams.set('selectedHostelId', storedHostelId);
                    window.location.href = url.toString();
                    return; // Stop execution
                }
            }

            // Update localStorage with current selection
            if (hostelSelector.value) {
                localStorage.setItem(HOSTEL_STORAGE_KEY, hostelSelector.value);
            }
        }

        // Load first student after a brief delay
        setTimeout(function() {
            const firstCard = document.querySelector('.student-card');
            if (firstCard) {
                const studentId = firstCard.getAttribute('data-student-id');
                if (studentId && typeof window.loadStudentDetails === 'function') {
                    window.loadStudentDetails(parseInt(studentId));
                }
            }
        }, 200);
    });

    console.log('=== All initialization complete ===');
</script>