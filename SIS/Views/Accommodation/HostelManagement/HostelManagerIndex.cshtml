@model SIS.Controllers.AccommodationControllers.HostelManagerDashboardViewModel

@{
    ViewData["Title"] = "Hostel Manager Dashboard";
}

<!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --teal-primary: #0d9488;
        --teal-hover: #0f766e;
    }

    .stat-card {
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(13, 148, 136, 0.2);
    }

    .recent-activity-item {
        border-left: 3px solid var(--teal-primary);
        transition: all 0.2s;
    }

    .recent-activity-item:hover {
        background: #f9fafb;
        border-left-width: 5px;
    }
</style>

<div class="container mx-auto px-4 py-6">
    <!-- Header -->
    <div class="mb-6">
        <div class="bg-gradient-to-r from-teal-600 to-cyan-600 rounded-xl shadow-lg p-6 text-white">
            <div class="flex justify-between items-center flex-wrap gap-4">
                <div>
                    <h4 class="text-2xl font-bold mb-2">
                        <i class="fas fa-building me-2"></i>@Model.Hostel.HostelName
                    </h4>
                    <p class="text-teal-100">
                        <i class="fas fa-map-marker-alt me-2"></i>@Model.Hostel.Campus.CampusName
                    </p>
                    <p class="text-teal-100 mt-1">
                        <i class="fas fa-users me-2"></i>Gender: @Model.Hostel.Gender
                    </p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a href="@Url.Action("Rooms", "HostelManagement")" class="bg-white text-teal-700 hover:bg-teal-50 px-6 py-3 rounded-lg font-semibold shadow-md transition">
                        <i class="fas fa-door-open me-2"></i>Manage Rooms
                    </a>
                    <a href="@Url.Action("CheckInOut", "HostelManagement")" class="bg-white text-teal-700 hover:bg-teal-50 px-6 py-3 rounded-lg font-semibold shadow-md transition">
                        <i class="fas fa-user-check me-2"></i>Check-In/Out
                    </a>
                    <a href="@Url.Action("Maintenance", "HostelManagement")" class="bg-white text-teal-700 hover:bg-teal-50 px-6 py-3 rounded-lg font-semibold shadow-md transition">
                        <i class="fas fa-tools me-2"></i>Maintenance
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <!-- Total Rooms -->
        <div class="stat-card bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600 mb-1">Total Rooms</p>
                    <p class="text-3xl font-bold text-gray-800">@Model.TotalRooms</p>
                </div>
                <div class="bg-blue-100 rounded-full p-4">
                    <i class="fas fa-door-closed text-3xl text-blue-600"></i>
                </div>
            </div>
        </div>

        <!-- Total Beds -->
        <div class="stat-card bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600 mb-1">Total Beds</p>
                    <p class="text-3xl font-bold text-gray-800">@Model.TotalBeds</p>
                </div>
                <div class="bg-purple-100 rounded-full p-4">
                    <i class="fas fa-bed text-3xl text-purple-600"></i>
                </div>
            </div>
        </div>

        <!-- Occupied Beds -->
        <div class="stat-card bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600 mb-1">Occupied Beds</p>
                    <p class="text-3xl font-bold text-green-600">@Model.OccupiedBeds</p>
                    <p class="text-xs text-gray-500 mt-1">@Model.OccupancyRate.ToString("F1")% occupancy</p>
                </div>
                <div class="bg-green-100 rounded-full p-4">
                    <i class="fas fa-user-check text-3xl text-green-600"></i>
                </div>
            </div>
        </div>

        <!-- Available Beds -->
        <div class="stat-card bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600 mb-1">Available Beds</p>
                    <p class="text-3xl font-bold text-teal-600">@Model.AvailableBeds</p>
                </div>
                <div class="bg-teal-100 rounded-full p-4">
                    <i class="fas fa-bed text-3xl text-teal-600"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Pending Maintenance -->
        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex justify-between items-center mb-4">
                <h5 class="text-lg font-bold text-gray-800">
                    <i class="fas fa-tools me-2 text-orange-600"></i>Pending Maintenance
                </h5>
                <a href="@Url.Action("Maintenance", "HostelManagement")" class="text-sm text-teal-600 hover:text-teal-800 font-medium">
                    View All <i class="fas fa-arrow-right ml-1"></i>
                </a>
            </div>
            @if (Model.PendingMaintenanceCount > 0)
            {
                <div class="bg-orange-50 border-l-4 border-orange-500 p-4 rounded">
                    <p class="text-orange-800 font-semibold">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        @Model.PendingMaintenanceCount pending maintenance request@(Model.PendingMaintenanceCount != 1 ? "s" : "")
                    </p>
                    <p class="text-sm text-orange-700 mt-1">Click "View All" to manage maintenance requests</p>
                </div>
            }
            else
            {
                <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                    <p class="text-green-800 font-semibold">
                        <i class="fas fa-check-circle me-2"></i>
                        No pending maintenance requests
                    </p>
                    <p class="text-sm text-green-700 mt-1">All maintenance requests are up to date</p>
                </div>
            }
        </div>

        <!-- Occupancy Chart -->
        <div class="bg-white rounded-lg shadow-md p-6">
            <h5 class="text-lg font-bold text-gray-800 mb-4">
                <i class="fas fa-chart-pie me-2 text-teal-600"></i>Occupancy Overview
            </h5>
            <div class="flex items-center justify-center">
                <div class="relative w-48 h-48">
                    <svg class="transform -rotate-90 w-48 h-48">
                        <circle cx="96" cy="96" r="80" stroke="#e5e7eb" stroke-width="20" fill="none"></circle>
                        <circle cx="96" cy="96" r="80" stroke="#0d9488" stroke-width="20" fill="none"
                                stroke-dasharray="@(502.4m * Model.OccupancyRate / 100) 502.4"
                                stroke-linecap="round"></circle>
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center flex-col">
                        <span class="text-3xl font-bold text-gray-800">@Model.OccupancyRate.ToString("F1")%</span>
                        <span class="text-sm text-gray-600">Occupied</span>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4 mt-6">
                <div class="text-center">
                    <p class="text-2xl font-bold text-green-600">@Model.OccupiedBeds</p>
                    <p class="text-sm text-gray-600">Occupied</p>
                </div>
                <div class="text-center">
                    <p class="text-2xl font-bold text-teal-600">@Model.AvailableBeds</p>
                    <p class="text-sm text-gray-600">Available</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Check-Ins -->
    <div class="bg-white rounded-lg shadow-md p-6 mt-6">
        <div class="flex justify-between items-center mb-4">
            <h5 class="text-lg font-bold text-gray-800">
                <i class="fas fa-clock me-2 text-teal-600"></i>Recent Check-Ins (Last 7 Days)
            </h5>
            <a href="@Url.Action("CheckInOut", "HostelManagement")" class="text-sm text-teal-600 hover:text-teal-800 font-medium">
                View All <i class="fas fa-arrow-right ml-1"></i>
            </a>
        </div>
        @if (Model.RecentCheckIns != null && Model.RecentCheckIns.Any())
        {
            <div class="space-y-3">
                @foreach (var checkIn in Model.RecentCheckIns)
                {
                    <div class="recent-activity-item bg-white border border-gray-200 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <div class="bg-teal-100 rounded-full p-3">
                                    <i class="fas fa-user-check text-teal-600"></i>
                                </div>
                                <div>
                                    <p class="font-semibold text-gray-800">@checkIn.Allocation.Application.Student.FullName</p>
                                    <p class="text-sm text-gray-600">
                                        @checkIn.Allocation.Application.Student.StudentId_Number •
                                        Room @checkIn.Allocation.Bed.Room.RoomNumber •
                                        Bed @checkIn.Allocation.Bed.BedIdentifier
                                    </p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-sm text-gray-600">@checkIn.CheckInDate?.ToString("MMM dd, yyyy")</p>
                                <p class="text-xs text-gray-500">@checkIn.CheckInDate?.ToString("h:mm tt")</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-500">
                <i class="fas fa-inbox text-5xl mb-4 opacity-50"></i>
                <p class="text-lg">No recent check-ins</p>
                <p class="text-sm">Check-ins from the last 7 days will appear here</p>
            </div>
        }
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
        <a href="@Url.Action("Rooms", "HostelManagement")" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition">
            <div class="flex items-center gap-4">
                <div class="bg-blue-100 rounded-full p-4">
                    <i class="fas fa-door-open text-2xl text-blue-600"></i>
                </div>
                <div>
                    <h6 class="font-semibold text-gray-800">View Rooms</h6>
                    <p class="text-sm text-gray-600">Manage room details</p>
                </div>
            </div>
        </a>

        <a href="@Url.Action("CheckInOut", "HostelManagement")" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition">
            <div class="flex items-center gap-4">
                <div class="bg-green-100 rounded-full p-4">
                    <i class="fas fa-user-check text-2xl text-green-600"></i>
                </div>
                <div>
                    <h6 class="font-semibold text-gray-800">Check-In/Out</h6>
                    <p class="text-sm text-gray-600">Process student arrivals</p>
                </div>
            </div>
        </a>

        <a href="@Url.Action("Reports", "HostelManagement")" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition">
            <div class="flex items-center gap-4">
                <div class="bg-purple-100 rounded-full p-4">
                    <i class="fas fa-chart-bar text-2xl text-purple-600"></i>
                </div>
                <div>
                    <h6 class="font-semibold text-gray-800">Reports</h6>
                    <p class="text-sm text-gray-600">View hostel statistics</p>
                </div>
            </div>
        </a>
    </div>
</div>
