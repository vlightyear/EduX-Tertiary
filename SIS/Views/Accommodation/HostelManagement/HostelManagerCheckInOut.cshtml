@{
    ViewData["Title"] = "Check-In / Check-Out Management";
    var hostel = ViewBag.Hostel as SIS.Models.StudentAccommodation.Hostel;
}

<!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --teal-primary: #0d9488;
        --teal-hover: #0f766e;
    }

    .tab-button {
        padding: 1rem 1.5rem;
        border-bottom: 2px solid transparent;
        font-weight: 500;
        transition: all 0.2s;
        cursor: pointer;
    }

    .tab-button.active {
        border-bottom-color: var(--teal-primary);
        color: var(--teal-primary);
    }

    .modal-overlay {
        position: fixed !important;
        inset: 0 !important;
        z-index: 9998 !important;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .modal-overlay.hidden {
        display: none !important;
    }
</style>

<div class="container mx-auto px-4 py-6">
    @Html.AntiForgeryToken()

    <!-- Header -->
    <div class="mb-6">
        <div class="bg-gradient-to-r from-teal-600 to-cyan-600 rounded-xl shadow-lg p-6 text-white">
            <div class="flex justify-between items-center flex-wrap gap-4">
                <div>
                    <h4 class="text-2xl font-bold mb-2">
                        <i class="fas fa-user-check me-2"></i>Check-In / Check-Out Management
                    </h4>
                    <p class="text-teal-100">@hostel.HostelName - @hostel.Campus.CampusName</p>
                </div>
                <div>
                    <a href="@Url.Action("Index", "HostelManagement")" class="bg-white text-teal-700 hover:bg-teal-50 px-6 py-3 rounded-lg font-semibold shadow-md transition">
                        <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="bg-white rounded-lg shadow-md mb-6">
        <div class="border-b">
            <div class="flex space-x-1">
                <button class="tab-button active" onclick="switchTab('pending')">
                    <i class="fas fa-clock me-2"></i>Pending Check-Ins
                </button>
                <button class="tab-button" onclick="switchTab('occupied')">
                    <i class="fas fa-users me-2"></i>Occupied Beds
                </button>
            </div>
        </div>

        <!-- Pending Check-Ins Tab -->
        <div id="pendingTab" class="tab-content p-6">
            <div class="mb-4">
                <p class="text-gray-600">Students who have been allocated beds but have not yet checked in</p>
            </div>
            <div id="pendingCheckInsContainer"></div>
        </div>

        <!-- Occupied Beds Tab -->
        <div id="occupiedTab" class="tab-content p-6 hidden">
            <div class="mb-4">
                <p class="text-gray-600">Students currently occupying beds in the hostel</p>
            </div>
            <div id="occupiedBedsContainer"></div>
        </div>
    </div>

    <!-- Check-In Modal -->
    <div id="checkInModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-2xl w-full">
            <div class="bg-gradient-to-r from-green-600 to-green-500 px-6 py-4 flex justify-between items-center">
                <h5 class="text-xl font-bold text-white">
                    <i class="fas fa-sign-in-alt me-2"></i>Student Check-In
                </h5>
                <button onclick="hideCheckInModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6">
                <form id="checkInForm">
                    <input type="hidden" id="checkInAllocationId" name="AllocationId">
                    <div id="checkInStudentInfo" class="mb-4"></div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Room Condition *</label>
                        <textarea id="checkInCondition" name="CheckInCondition" rows="3" 
                                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500"
                                  placeholder="Document the condition of the room and its contents..." required></textarea>
                    </div>
                    <div class="mt-6 flex justify-end space-x-3">
                        <button type="button" onclick="hideCheckInModal()" 
                                class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                            Cancel
                        </button>
                        <button type="submit" class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">
                            <i class="fas fa-check me-2"></i>Complete Check-In
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Check-Out Modal -->
    <div id="checkOutModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-2xl w-full">
            <div class="bg-gradient-to-r from-red-600 to-red-500 px-6 py-4 flex justify-between items-center">
                <h5 class="text-xl font-bold text-white">
                    <i class="fas fa-sign-out-alt me-2"></i>Student Check-Out
                </h5>
                <button onclick="hideCheckOutModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6">
                <form id="checkOutForm">
                    <input type="hidden" id="checkOutAllocationId" name="AllocationId">
                    <div id="checkOutStudentInfo" class="mb-4"></div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Room Condition *</label>
                            <textarea id="checkOutCondition" name="CheckOutCondition" rows="3" 
                                      class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500"
                                      placeholder="Document the condition of the room upon departure..." required></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Damage Charges (if any)</label>
                            <input type="number" id="checkOutDamageCharges" name="DamageCharges" min="0" step="0.01" value="0"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500">
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end space-x-3">
                        <button type="button" onclick="hideCheckOutModal()" 
                                class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                            Cancel
                        </button>
                        <button type="submit" class="px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                            <i class="fas fa-sign-out-alt me-2"></i>Complete Check-Out
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentTab = 'pending';

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('checkInForm').addEventListener('submit', handleCheckIn);
            document.getElementById('checkOutForm').addEventListener('submit', handleCheckOut);
            loadPendingCheckIns();
        });

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function switchTab(tabName) {
            currentTab = tabName;
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.add('hidden'));
            document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
            
            if (tabName === 'pending') {
                document.getElementById('pendingTab').classList.remove('hidden');
                document.querySelectorAll('.tab-button')[0].classList.add('active');
                loadPendingCheckIns();
            } else {
                document.getElementById('occupiedTab').classList.remove('hidden');
                document.querySelectorAll('.tab-button')[1].classList.add('active');
                loadOccupiedBeds();
            }
        }

        async function loadPendingCheckIns() {
            try {
                const response = await fetch('/HostelManagement/GetPendingCheckIns');
                const students = await response.json();

                const container = document.getElementById('pendingCheckInsContainer');

                if (students.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-12 text-gray-500">
                            <i class="fas fa-inbox text-5xl mb-4 opacity-50"></i>
                            <p class="text-lg">No pending check-ins</p>
                            <p class="text-sm">All allocated students have checked in</p>
                        </div>
                    `;
                } else {
                    container.innerHTML = `
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-teal-50">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-teal-800 uppercase">Student</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-teal-800 uppercase">Room/Bed</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-teal-800 uppercase">Contact</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-teal-800 uppercase">Allocation Date</th>
                                        <th class="px-6 py-3 text-center text-xs font-medium text-teal-800 uppercase">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    ${students.map(student => `
                                        <tr class="hover:bg-gray-50 transition">
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div>
                                                    <div class="font-medium text-gray-900">${student.studentName}</div>
                                                    <div class="text-sm text-gray-500">${student.studentNumber}</div>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div class="text-sm text-gray-900">Room ${student.roomNumber}</div>
                                                <div class="text-xs text-gray-500">Floor ${student.floor} • Bed ${student.bedIdentifier}</div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <div>${student.studentPhone}</div>
                                                <div>${student.studentEmail}</div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                ${new Date(student.allocationDate).toLocaleDateString()}
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                                <button onclick="showCheckInModal(${student.allocationId}, '${student.studentName}', '${student.studentNumber}', '${student.roomNumber}', '${student.bedIdentifier}')"
                                                        class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">
                                                    <i class="fas fa-sign-in-alt me-1"></i>Check In
                                                </button>
                                            </td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error loading pending check-ins:', error);
                showNotification('Error loading pending check-ins', 'error');
            }
        }

        async function loadOccupiedBeds() {
            try {
                const response = await fetch('/HostelManagement/GetOccupiedBeds');
                const students = await response.json();

                const container = document.getElementById('occupiedBedsContainer');

                if (students.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-12 text-gray-500">
                            <i class="fas fa-inbox text-5xl mb-4 opacity-50"></i>
                            <p class="text-lg">No occupied beds</p>
                        </div>
                    `;
                } else {
                    container.innerHTML = `
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-teal-50">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-teal-800 uppercase">Student</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-teal-800 uppercase">Room/Bed</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-teal-800 uppercase">Contact</th>
                                        <th class="px-6 py-3 text-center text-xs font-medium text-teal-800 uppercase">Status</th>
                                        <th class="px-6 py-3 text-center text-xs font-medium text-teal-800 uppercase">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    ${students.map(student => `
                                        <tr class="hover:bg-gray-50 transition">
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div>
                                                    <div class="font-medium text-gray-900">${student.studentName}</div>
                                                    <div class="text-sm text-gray-500">${student.studentNumber}</div>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div class="text-sm text-gray-900">Room ${student.roomNumber}</div>
                                                <div class="text-xs text-gray-500">Floor ${student.floor} • Bed ${student.bedIdentifier}</div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <div>${student.studentPhone}</div>
                                                <div>${student.studentEmail}</div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                                ${student.hasCheckedIn ? 
                                                    '<span class="px-2 py-1 text-xs font-semibold rounded bg-green-100 text-green-800">Checked In</span>' :
                                                    '<span class="px-2 py-1 text-xs font-semibold rounded bg-yellow-100 text-yellow-800">Pending</span>'}
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                                ${student.hasCheckedIn && !student.hasCheckedOut ? `
                                                    <button onclick="showCheckOutModal(${student.allocationId}, '${student.studentName}', '${student.studentNumber}', '${student.roomNumber}', '${student.bedIdentifier}')"
                                                            class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                                                        <i class="fas fa-sign-out-alt me-1"></i>Check Out
                                                    </button>
                                                ` : student.hasCheckedOut ? 
                                                    '<span class="text-gray-500">Checked Out</span>' :
                                                    '<span class="text-gray-500">Awaiting Check-In</span>'}
                                            </td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error loading occupied beds:', error);
                showNotification('Error loading occupied beds', 'error');
            }
        }

        function showCheckInModal(allocationId, studentName, studentNumber, roomNumber, bedIdentifier) {
            document.getElementById('checkInAllocationId').value = allocationId;
            document.getElementById('checkInStudentInfo').innerHTML = `
                <div class="bg-teal-50 border-l-4 border-teal-500 p-4 rounded">
                    <p class="font-semibold text-teal-800 mb-1">${studentName}</p>
                    <p class="text-sm text-teal-700">ID: ${studentNumber} • Room ${roomNumber} • Bed ${bedIdentifier}</p>
                </div>
            `;
            document.getElementById('checkInCondition').value = '';
            document.getElementById('checkInModal').classList.remove('hidden');
        }

        function hideCheckInModal() {
            document.getElementById('checkInModal').classList.add('hidden');
        }

         async function handleCheckIn(e) {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const response = await fetch('/HostelManagement/CheckIn', {  
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: new URLSearchParams(formData)
                });

                if (response.ok) {
                    showNotification('Student checked in successfully!', 'success');
                    hideCheckInModal();
                    loadPendingCheckIns();
                } else {
                    const error = await response.text();
                    showNotification(error || 'Error during check-in', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showNotification('Error during check-in', 'error');
            }
        }

        function showCheckOutModal(allocationId, studentName, studentNumber, roomNumber, bedIdentifier) {
            document.getElementById('checkOutAllocationId').value = allocationId;
            document.getElementById('checkOutStudentInfo').innerHTML = `
                <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded">
                    <p class="font-semibold text-red-800 mb-1">${studentName}</p>
                    <p class="text-sm text-red-700">ID: ${studentNumber} • Room ${roomNumber} • Bed ${bedIdentifier}</p>
                </div>
            `;
            document.getElementById('checkOutCondition').value = '';
            document.getElementById('checkOutDamageCharges').value = '0';
            document.getElementById('checkOutModal').classList.remove('hidden');
        }

        function hideCheckOutModal() {
            document.getElementById('checkOutModal').classList.add('hidden');
        }

        async function handleCheckOut(e) {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const response = await fetch('/HostelManagement/CheckOut', {  // ← FIXED URL
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: new URLSearchParams(formData)
                });

                if (response.ok) {
                    showNotification('Student checked out successfully!', 'success');
                    hideCheckOutModal();
                    loadOccupiedBeds();
                } else {
                    const error = await response.text();
                    showNotification(error || 'Error during check-out', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showNotification('Error during check-out', 'error');
            }
        }

        function showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 z-50 px-6 py-4 rounded-lg shadow-lg transition-all transform ${
                type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
            }`;
            notification.innerHTML = `
                <div class="flex items-center space-x-2">
                    <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i>
                    <span>${message}</span>
                </div>
            `;
            document.body.appendChild(notification);
            setTimeout(() => {
                notification.style.transform = 'translateX(400px)';
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }

        window.switchTab = switchTab;
        window.showCheckInModal = showCheckInModal;
        window.hideCheckInModal = hideCheckInModal;
        window.showCheckOutModal = showCheckOutModal;
        window.hideCheckOutModal = hideCheckOutModal;
    </script>
}
