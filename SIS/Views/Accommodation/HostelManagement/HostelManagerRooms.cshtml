        }

        async function handleBulkResourceSubmit() {
            try {
                const container = document.getElementById('bulkResourcesList');
                const resourceItems = container.querySelectorAll('.bulk-resource-item');

                if (resourceItems.length === 0) {
                    showNotification('Please add at least one resource', 'error');
                    return;
                }

                const resources = [];
                let isValid = true;

                resourceItems.forEach(item => {
                    const resourceTypeId = item.querySelector('.bulk-resource-type-id').value;
                    const quantity = item.querySelector('.bulk-resource-quantity').value;
                    const status = item.querySelector('.bulk-resource-status').value;

                    if (!resourceTypeId || !quantity) {
                        isValid = false;
                        return;
                    }

                    resources.push({
                        ResourceTypeId: parseInt(resourceTypeId),
                        Quantity: parseInt(quantity),
                        Status: parseInt(status)
                    });
                });

                if (!isValid) {
                    showNotification('Please fill in all required fields', 'error');
                    return;
                }

                const payload = {
                    RoomId: currentRoomId,
                    Resources: resources
                };

                const response = await fetch('/HostelManagement/AddBulkResources', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    const result = await response.json();
                    showNotification(`Successfully added ${result.resourcesAdded} resources!`, 'success');
                    hideBulkResourceModal();
                    currentActiveTab = 'resources';
                    await showRoomDetails(currentRoomId);
                } else {
                    const error = await response.text();
                    showNotification(error || 'Error adding bulk resources', 'error');
                }
            } catch (error) {
                console.error('Error adding bulk resources:', error);
                showNotification('Error adding bulk resources', 'error');
            }
        }

        // Maintenance Management
        async function loadMaintenanceRequests(roomId) {
            try {
                const response = await fetch(`/HostelManagement/GetRoomMaintenanceRequests?roomId=${roomId}`);
                const requests = await response.json();

                const container = document.getElementById('maintenanceContent');

                if (requests.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-12 text-gray-500">
                            <i class="fas fa-tools text-5xl mb-4 opacity-50"></i>
                            <p class="text-lg mb-2">No maintenance requests</p>
                            <p class="text-sm">Click "Add Request" above to create one</p>
                        </div>
                    `;
                } else {
                    container.innerHTML = requests.map(request => {
                        const priorityClass = request.priority.toLowerCase();
                        const requestDate = new Date(request.requestDate).toLocaleDateString();
                        const resolutionDate = request.resolutionDate ? new Date(request.resolutionDate).toLocaleDateString() : null;

                        return `
                            <div class="maintenance-card ${priorityClass}-priority">
                                <div class="flex justify-between items-start">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-3 mb-2">
                                            <i class="fas fa-tools text-2xl text-teal-600"></i>
                                            <div class="flex-1">
                                                <div class="flex items-center gap-2 mb-1">
                                                    <span class="px-3 py-1 rounded-full text-xs font-semibold uppercase ${
                                                        priorityClass === 'low' ? 'bg-green-100 text-green-700' :
                                                        priorityClass === 'medium' ? 'bg-yellow-100 text-yellow-700' :
                                                        'bg-red-100 text-red-700'
                                                    }">
                                                        ${request.priority}
                                                    </span>
                                                    <span class="px-2 py-1 rounded text-xs font-semibold ${
                                                        request.status === 'Active' ? 'bg-green-100 text-green-700' :
                                                        request.status === 'Inactive' ? 'bg-gray-100 text-gray-700' :
                                                        'bg-yellow-100 text-yellow-700'
                                                    }">
                                                        ${request.status}
                                                    </span>
                                                </div>
                                                <p class="text-xs text-gray-500">
                                                    Requested on ${requestDate} by ${request.requestedBy} (${request.requesterType})
                                                </p>
                                            </div>
                                        </div>
                                        <div class="mt-2 p-3 bg-gray-50 rounded border border-gray-200">
                                            <p class="text-sm text-gray-700 font-medium mb-1">Issue Description:</p>
                                            <p class="text-sm text-gray-600">${request.description || 'No description provided'}</p>
                                        </div>
                                        ${request.resolutionNotes && request.resolutionNotes.trim() !== '' ? `
                                            <div class="mt-2 p-3 bg-green-50 rounded border border-green-200">
                                                <p class="text-xs font-semibold text-green-800 mb-1">
                                                    <i class="fas fa-check-circle me-1"></i>Resolution Notes
                                                    ${resolutionDate ? `<span class="font-normal">(Resolved: ${resolutionDate})</span>` : ''}
                                                </p>
                                                <p class="text-sm text-green-700">${request.resolutionNotes}</p>
                                            </div>
                                        ` : ''}
                                    </div>
                                    <div class="flex gap-2 items-center ml-3">
                                        <button type="button" class="text-teal-600 hover:text-teal-800 transition"
                                                onclick="editMaintenanceRequest(${request.requestId})" title="Edit request">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button type="button" class="text-red-600 hover:text-red-800 transition"
                                                onclick="deleteMaintenanceRequest(${request.requestId})" title="Delete request">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        `;
                    }).join('');
                }
            } catch (error) {
                console.error('Error loading maintenance requests:', error);
                showNotification('Error loading maintenance requests', 'error');
            }
        }

