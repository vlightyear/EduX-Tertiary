        }

        async function handleAddBed(e) {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                formData.append('RoomId', currentRoomId);

                const response = await fetch('/HostelManagement/AddBedSpace', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: new URLSearchParams(formData)
                });

                if (response.ok) {
                    showNotification('Bed space added successfully!', 'success');
                    hideAddBedModal();
                    currentActiveTab = 'beds';
                    await showRoomDetails(currentRoomId);
                } else {
                    const error = await response.text();
                    showNotification(error || 'Error adding bed space', 'error');
                }
            } catch (error) {
                console.error('Error adding bed:', error);
                showNotification('Error adding bed space', 'error');
            }
        }

