        async function editMaintenanceRequest(requestId) {
            try {
                const response = await fetch(`/HostelManagement/GetRoomMaintenanceRequests?roomId=${currentRoomId}`);
                const requests = await response.json();

                const request = requests.find(r => r.requestId === requestId);

                if (request) {
                    document.getElementById('maintenanceModalTitle').textContent = 'Edit Maintenance Request';
                    document.getElementById('maintenanceRequestId').value = request.requestId;
                    document.getElementById('maintenanceRequestedBy').value = request.requestedBy || '';
                    document.getElementById('maintenanceRequesterType').value = request.requesterType || '';
                    document.getElementById('maintenanceDescription').value = request.description || '';
                    document.getElementById('maintenancePriority').value = request.priority || '';

                    const statusMap = {
                        'Active': '1',
                        'Inactive': '0',
                        'Maintenance': '2'
                    };
                    document.getElementById('maintenanceStatus').value = statusMap[request.status] || '0';

                    document.getElementById('resolutionNotesContainer').classList.remove('hidden');
                    document.getElementById('maintenanceResolutionNotes').value = request.resolutionNotes || '';

                    document.getElementById('maintenanceModal').classList.remove('hidden');
                }
            } catch (error) {
                console.error('Error loading maintenance request:', error);
                showNotification('Error loading maintenance request', 'error');
            }
        }

        async function handleMaintenanceSubmit(e) {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const requestId = parseInt(formData.get('RequestId'));
                formData.append('RoomId', currentRoomId);

                const url = requestId > 0 ? '/HostelManagement/UpdateRoomMaintenanceRequest' : '/HostelManagement/AddMaintenanceRequest';

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: new URLSearchParams(formData)
                });

                if (response.ok) {
                    showNotification(requestId > 0 ? 'Request updated successfully!' : 'Request created successfully!', 'success');
                    hideMaintenanceModal();
                    currentActiveTab = 'maintenance';
                    await showRoomDetails(currentRoomId);
                } else {
                    const error = await response.text();
                    showNotification(error || 'Error saving request', 'error');
                }
            } catch (error) {
                console.error('Error saving maintenance request:', error);
                showNotification('Error saving maintenance request', 'error');
            }
        }

        function deleteMaintenanceRequest(requestId) {
            showDeleteConfirmation(
                'Are you sure you want to delete this maintenance request?',
                async function() {
                    await performDelete(`/HostelManagement/DeleteMaintenanceRequest/${requestId}`, 'maintenance request');
                    currentActiveTab = 'maintenance';
                    await showRoomDetails(currentRoomId);
                }
            );
        }

        // Delete Modal
        function showDeleteConfirmation(message, onConfirm) {
            document.getElementById('deleteMessage').textContent = message;
            document.getElementById('deleteModal').classList.remove('hidden');

            const confirmBtn = document.getElementById('confirmDeleteBtn');
            confirmBtn.onclick = async function() {
                await onConfirm();
                hideDeleteModal();
            };
        }

        function hideDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        async function performDelete(url, itemType) {
            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getAntiForgeryToken()
                    }
                });

                if (response.ok) {
                    showNotification(`${itemType} deleted successfully!`, 'success');
                } else {
                    const error = await response.text();
                    showNotification(error || `Error deleting ${itemType}`, 'error');
                }
            } catch (error) {
                console.error(`Error deleting ${itemType}:`, error);
                showNotification(`Error deleting ${itemType}`, 'error');
            }
        }

        function showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 z-50 px-6 py-4 rounded-lg shadow-lg transition-all transform ${
                type === 'success' ? 'bg-green-500 text-white' :
                type === 'error' ? 'bg-red-500 text-white' :
                'bg-yellow-500 text-white'
            }`;
            notification.innerHTML = `
                <div class="flex items-center space-x-2">
                    <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
                    <span>${message}</span>
                </div>
            `;
            document.body.appendChild(notification);

            setTimeout(() => {
                notification.style.transform = 'translateX(400px)';
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }

        // Global functions
        window.showRoomDetails = showRoomDetails;
        window.closeRoomDetailsModal = closeRoomDetailsModal;
        window.switchTab = switchTab;
        window.showAddBedModal = showAddBedModal;
        window.hideAddBedModal = hideAddBedModal;
        window.editBed = editBed;
        window.hideEditBedModal = hideEditBedModal;
        window.deleteBed = deleteBed;
        window.showAddResourceModal = showAddResourceModal;
        window.hideAddResourceModal = hideAddResourceModal;
        window.editResource = editResource;
        window.deleteResource = deleteResource;
        window.showBulkResourceModal = showBulkResourceModal;
        window.hideBulkResourceModal = hideBulkResourceModal;
        window.addBulkResourceRow = addBulkResourceRow;
        window.removeBulkResourceRow = removeBulkResourceRow;
        window.handleBulkResourceSubmit = handleBulkResourceSubmit;
        window.showAddMaintenanceModal = showAddMaintenanceModal;
        window.hideMaintenanceModal = hideMaintenanceModal;
        window.editMaintenanceRequest = editMaintenanceRequest;
        window.deleteMaintenanceRequest = deleteMaintenanceRequest;
        window.loadMaintenanceRequests = loadMaintenanceRequests;
        window.hideDeleteModal = hideDeleteModal;
        window.showResourceTypeInfo = showResourceTypeInfo;
    </script>
}
