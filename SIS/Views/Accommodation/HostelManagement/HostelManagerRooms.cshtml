        async function editResource(resourceId) {
            try {
                const response = await fetch(`/HostelManagement/GetRoomDetails?id=${currentRoomId}`);
                const room = await response.json();

                const resource = room.resources.find(r => r.resourceId === resourceId);

                if (resource) {
                    document.getElementById('resourceModalTitle').textContent = 'Edit Resource';
                    document.getElementById('resourceId').value = resource.resourceId;
                    document.getElementById('resourceTypeId').value = resource.resourceTypeId;
                    document.getElementById('resourceQuantity').value = resource.quantity;

                    const statusMap = {
                        'Active': '1',
                        'Inactive': '0',
                        'Maintenance': '2'
                    };
                    document.getElementById('resourceStatus').value = statusMap[resource.status] || '1';

                    const selectElement = document.getElementById('resourceTypeId');
                    showResourceTypeInfo(selectElement);

                    document.getElementById('addResourceModal').classList.remove('hidden');
                }
            } catch (error) {
                console.error('Error loading resource:', error);
                showNotification('Error loading resource details', 'error');
            }
        }

        async function handleAddResource(e) {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const resourceId = parseInt(formData.get('ResourceId'));
                formData.append('RoomId', currentRoomId);

                const url = resourceId > 0 ? '/HostelManagement/UpdateRoomResource' : '/HostelManagement/AddRoomResource';

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: new URLSearchParams(formData)
                });

                if (response.ok) {
                    showNotification(resourceId > 0 ? 'Resource updated successfully!' : 'Resource added successfully!', 'success');
                    hideAddResourceModal();
                    currentActiveTab = 'resources';
                    await showRoomDetails(currentRoomId);
                } else {
                    const error = await response.text();
                    showNotification(error || 'Error saving resource', 'error');
                }
            } catch (error) {
                console.error('Error saving resource:', error);
                showNotification('Error saving resource', 'error');
            }
        }

