@{
    ViewData["Title"] = "Room Management";
    var hostel = ViewBag.Hostel as SIS.Models.StudentAccommodation.Hostel;
    var resourceTypes = ViewBag.ResourceTypes as List<SIS.Models.StudentAccommodation.ResourceType> ?? new List<SIS.Models.StudentAccommodation.ResourceType>();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --teal-primary: #0d9488;
        --teal-hover: #0f766e;
    }

    .room-card {
        transition: all 0.3s ease;
        cursor: pointer;
        border-left: 4px solid transparent;
    }

        .room-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(13, 148, 136, 0.2);
            border-left-color: var(--teal-primary);
        }

        .room-card.active {
            border-left-color: #10b981;
        }

        .room-card.inactive {
            border-left-color: #6b7280;
        }

        .room-card.maintenance {
            border-left-color: #f59e0b;
        }

    .bed-card {
        border: 2px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
        transition: all 0.3s;
        background: white;
    }

        .bed-card:hover {
            border-color: var(--teal-primary);
            box-shadow: 0 4px 12px rgba(13, 148, 136, 0.15);
        }

        .bed-card.occupied {
            border-left: 4px solid #10b981;
            background: rgba(16, 185, 129, 0.02);
        }

        .bed-card.available, .bed-card.active {
            border-left: 4px solid #0ea5e9;
            background: rgba(14, 165, 233, 0.02);
        }

    .modal-overlay {
        position: fixed !important;
        inset: 0 !important;
        z-index: 9998 !important;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

        .modal-overlay.hidden {
            display: none !important;
        }

    .student-info-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem;
        border-radius: 0.5rem;
        margin-top: 0.5rem;
    }

    .tab-button {
        padding: 1rem 1.5rem;
        border-bottom: 2px solid transparent;
        font-weight: 500;
        transition: all 0.2s;
        cursor: pointer;
    }

        .tab-button.active {
            border-bottom-color: var(--teal-primary);
            color: var(--teal-primary);
        }

        .tab-button:not(.active) {
            color: #6b7280;
        }

            .tab-button:not(.active):hover {
                color: #374151;
                background: #f9fafb;
            }

    .resource-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        margin-bottom: 0.5rem;
    }

        .resource-item:hover {
            background: #f9fafb;
            border-color: var(--teal-primary);
        }

        .resource-item button {
            padding: 0.5rem;
            border-radius: 0.375rem;
            transition: all 0.2s;
            min-width: 36px;
            min-height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid currentColor;
            background: white;
        }

            .resource-item button:hover {
                background: rgba(0, 0, 0, 0.05);
                transform: scale(1.1);
            }

    .bed-card button {
        padding: 0.5rem;
        border-radius: 0.375rem;
        transition: all 0.2s;
        min-width: 36px;
        min-height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid currentColor;
        background: white;
    }

        .bed-card button:hover {
            background: rgba(0, 0, 0, 0.05);
            transform: scale(1.1);
        }

    .bulk-resource-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
    }

    .resource-type-info {
        display: inline-block;
        padding: 0.375rem 0.75rem;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 0.375rem;
        font-size: 0.875rem;
        color: #1e40af;
    }

    .maintenance-card {
        border: 2px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
        transition: all 0.3s;
    }

        .maintenance-card:hover {
            border-color: var(--teal-primary);
            box-shadow: 0 4px 12px rgba(13, 148, 136, 0.15);
        }

        .maintenance-card.low-priority {
            border-left: 4px solid #10b981;
        }

        .maintenance-card.medium-priority {
            border-left: 4px solid #f59e0b;
        }

        .maintenance-card.high-priority {
            border-left: 4px solid #ef4444;
        }
</style>

<div class="container mx-auto px-4 py-6">
    @Html.AntiForgeryToken()

    <!-- Header -->
    <div class="mb-6">
        <div class="bg-gradient-to-r from-teal-600 to-cyan-600 rounded-xl shadow-lg p-6 text-white">
            <div class="flex justify-between items-center flex-wrap gap-4">
                <div>
                    <h4 class="text-2xl font-bold mb-2">
                        <i class="fas fa-door-open me-2"></i>Room Management
                    </h4>
                    <p class="text-teal-100">@hostel.HostelName - @hostel.Campus.CampusName</p>
                </div>
                <div>
                    <a href="@Url.Action("Index", "HostelManagement")" class="bg-white text-teal-700 hover:bg-teal-50 px-6 py-3 rounded-lg font-semibold shadow-md transition">
                        <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Rooms Grid -->
    <div id="roomsContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>

    <!-- Room Details Modal -->
    <div id="roomDetailsModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
            <div class="bg-gradient-to-r from-teal-600 to-cyan-600 px-6 py-4 flex justify-between items-center">
                <h5 class="text-xl font-bold text-white">
                    <i class="fas fa-door-open me-2"></i>Room Details
                </h5>
                <button onclick="closeRoomDetailsModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
                <!-- Tabs -->
                <div class="border-b mb-6">
                    <div class="flex space-x-1">
                        <button class="tab-button active" onclick="switchTab('info')">
                            <i class="fas fa-info-circle me-2"></i>Room Info
                        </button>
                        <button class="tab-button" onclick="switchTab('beds')">
                            <i class="fas fa-bed me-2"></i>Bed Spaces
                        </button>
                        <button class="tab-button" onclick="switchTab('resources')">
                            <i class="fas fa-couch me-2"></i>Resources
                        </button>
                        <button class="tab-button" onclick="switchTab('maintenance')">
                            <i class="fas fa-tools me-2"></i>Maintenance
                        </button>
                    </div>
                </div>

                <!-- Tab Content -->
                <div id="infoTab" class="tab-content">
                    <div id="roomInfoContent"></div>
                </div>

                <div id="bedsTab" class="tab-content hidden">
                    <div class="flex justify-between items-center mb-4">
                        <h6 class="text-lg font-semibold">Bed Spaces</h6>
                        <button class="bg-teal-600 text-white hover:bg-teal-700 px-4 py-2 rounded-lg transition" onclick="showAddBedModal()">
                            <i class="fas fa-plus me-2"></i>Add Bed
                        </button>
                    </div>
                    <div id="bedSpacesContent"></div>
                </div>

                <div id="resourcesTab" class="tab-content hidden">
                    <div class="flex justify-between items-center mb-4">
                        <h6 class="text-lg font-semibold">Room Resources</h6>
                        <div class="flex gap-2">
                            <button class="bg-purple-600 text-white hover:bg-purple-700 px-4 py-2 rounded-lg transition" onclick="showBulkResourceModal()">
                                <i class="fas fa-layer-group me-2"></i>Bulk Add
                            </button>
                            <button class="bg-teal-600 text-white hover:bg-teal-700 px-4 py-2 rounded-lg transition" onclick="showAddResourceModal()">
                                <i class="fas fa-plus me-2"></i>Add Resource
                            </button>
                        </div>
                    </div>
                    <div id="resourcesContent"></div>
                </div>

                <div id="maintenanceTab" class="tab-content hidden">
                    <div class="flex justify-between items-center mb-4">
                        <h6 class="text-lg font-semibold">Maintenance Requests</h6>
                        <button class="bg-teal-600 text-white hover:bg-teal-700 px-4 py-2 rounded-lg transition" onclick="showAddMaintenanceModal()">
                            <i class="fas fa-plus me-2"></i>Add Request
                        </button>
                    </div>
                    <div id="maintenanceContent"></div>
                </div>
            </div>
            <div class="bg-gray-50 px-6 py-4 flex justify-end">
                <button onclick="closeRoomDetailsModal()" class="px-6 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition">
                    <i class="fas fa-times me-2"></i>Close
                </button>
            </div>
        </div>
    </div>

    <!-- Add Bed Modal -->
    <div id="addBedModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full">
            <div class="bg-gradient-to-r from-teal-600 to-cyan-600 px-6 py-4 flex justify-between items-center">
                <h5 class="text-xl font-bold text-white">Add Bed Space</h5>
                <button onclick="hideAddBedModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6">
                <form id="addBedForm">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Bed Identifier *</label>
                            <input type="text" id="bedIdentifier" name="BedIdentifier" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" placeholder="e.g., A, B, 1, 2" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Status *</label>
                            <select id="bedStatus" name="Status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                @if (ViewBag.StatusOptions != null)
                                {
                                    foreach (var status in ViewBag.StatusOptions)
                                    {
                                        <option value="@status.Value">@status.Text</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end space-x-3">
                        <button type="button" onclick="hideAddBedModal()" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                            Cancel
                        </button>
                        <button type="submit" class="px-6 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition">
                            <i class="fas fa-plus me-2"></i>Add Bed
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Bed Modal -->
    <div id="editBedModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full">
            <div class="bg-gradient-to-r from-teal-600 to-cyan-600 px-6 py-4 flex justify-between items-center">
                <h5 class="text-xl font-bold text-white">Edit Bed Space</h5>
                <button onclick="hideEditBedModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6">
                <form id="editBedForm">
                    <input type="hidden" id="editBedId" name="BedId">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Bed Identifier *</label>
                            <input type="text" id="editBedIdentifier" name="BedIdentifier" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Status *</label>
                            <select id="editBedStatus" name="Status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                @if (ViewBag.StatusOptions != null)
                                {
                                    foreach (var status in ViewBag.StatusOptions)
                                    {
                                        <option value="@status.Value">@status.Text</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end space-x-3">
                        <button type="button" onclick="hideEditBedModal()" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                            Cancel
                        </button>
                        <button type="submit" class="px-6 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition">
                            <i class="fas fa-save me-2"></i>Update Bed
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Add/Edit Resource Modal -->
    <div id="addResourceModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full">
            <div class="bg-gradient-to-r from-teal-600 to-cyan-600 px-6 py-4 flex justify-between items-center">
                <h5 id="resourceModalTitle" class="text-xl font-bold text-white">Add Resource</h5>
                <button onclick="hideAddResourceModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6">
                <form id="addResourceForm">
                    <input type="hidden" id="resourceId" name="ResourceId" value="0">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Resource Type *</label>
                            <select id="resourceTypeId" name="ResourceTypeId" onchange="showResourceTypeInfo(this)" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                <option value="">Select Resource Type</option>
                                @foreach (var rt in resourceTypes)
                                {
                                    <option value="@rt.ResourceTypeId" data-description="@rt.Description">@rt.Name</option>
                                }
                            </select>
                            <div id="resourceTypeDescription" class="mt-2 hidden">
                                <span class="resource-type-info"></span>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Quantity *</label>
                            <input type="number" id="resourceQuantity" name="Quantity" min="1" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Status *</label>
                            <select id="resourceStatus" name="Status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                @if (ViewBag.StatusOptions != null)
                                {
                                    foreach (var status in ViewBag.StatusOptions)
                                    {
                                        <option value="@status.Value">@status.Text</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end space-x-3">
                        <button type="button" onclick="hideAddResourceModal()" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                            Cancel
                        </button>
                        <button type="submit" class="px-6 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition">
                            <i class="fas fa-save me-2"></i>Save Resource
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Bulk Resource Modal -->
    <div id="bulkResourceModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-3xl w-full max-h-[90vh] overflow-hidden">
            <div class="bg-gradient-to-r from-purple-600 to-purple-500 px-6 py-4 flex justify-between items-center">
                <h5 class="text-xl font-bold text-white">
                    <i class="fas fa-layer-group me-2"></i>Bulk Add Resources
                </h5>
                <button onclick="hideBulkResourceModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6 overflow-y-auto max-h-[calc(90vh-200px)]">
                <div class="mb-4 p-4 bg-blue-50 border border-blue-200 rounded-lg">
                    <p class="text-sm text-blue-800">
                        <i class="fas fa-info-circle me-2"></i>Add multiple resources at once to the current room.
                    </p>
                </div>
                <div id="bulkResourcesList"></div>
                <button type="button" onclick="addBulkResourceRow()" class="w-full mt-4 px-4 py-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-600 hover:border-purple-500 hover:text-purple-600 transition">
                    <i class="fas fa-plus-circle me-2"></i>Add Another Resource
                </button>
            </div>
            <div class="bg-gray-50 px-6 py-4 flex justify-end space-x-3">
                <button onclick="hideBulkResourceModal()" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                    Cancel
                </button>
                <button onclick="handleBulkResourceSubmit()" class="px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">
                    <i class="fas fa-save me-2"></i>Save All Resources
                </button>
            </div>
        </div>
    </div>

    <!-- Add/Edit Maintenance Modal -->
    <div id="maintenanceModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-hidden">
            <div class="bg-gradient-to-r from-teal-600 to-cyan-600 px-6 py-4 flex justify-between items-center">
                <h5 id="maintenanceModalTitle" class="text-xl font-bold text-white">Add Maintenance Request</h5>
                <button onclick="hideMaintenanceModal()" class="text-white hover:text-gray-200 transition">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
                <form id="maintenanceForm">
                    <input type="hidden" id="maintenanceRequestId" name="RequestId" value="0">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Requested By *</label>
                            <input type="text" id="maintenanceRequestedBy" name="RequestedBy" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" placeholder="Student ID or Staff ID" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Requester Type *</label>
                            <select id="maintenanceRequesterType" name="RequesterType" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                <option value="">Select Type</option>
                                <option value="Student">Student</option>
                                <option value="Staff">Staff</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Description *</label>
                            <textarea id="maintenanceDescription" name="Description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" placeholder="Describe the maintenance issue..." required></textarea>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Priority *</label>
                                <select id="maintenancePriority" name="Priority" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                    <option value="">Select Priority</option>
                                    <option value="Low">Low</option>
                                    <option value="Medium">Medium</option>
                                    <option value="High">High</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Status *</label>
                                <select id="maintenanceStatus" name="Status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" required>
                                    @if (ViewBag.StatusOptions != null)
                                    {
                                        foreach (var status in ViewBag.StatusOptions)
                                        {
                                            <option value="@status.Value">@status.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div id="resolutionNotesContainer" class="hidden">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Resolution Notes</label>
                            <textarea id="maintenanceResolutionNotes" name="ResolutionNotes" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500" placeholder="Add resolution notes..."></textarea>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end space-x-3">
                        <button type="button" onclick="hideMaintenanceModal()" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                            Cancel
                        </button>
                        <button type="submit" class="px-6 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition">
                            <i class="fas fa-save me-2"></i>Save Request
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="modal-overlay hidden">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full">
            <div class="bg-gradient-to-r from-red-600 to-red-500 px-6 py-4">
                <h5 class="text-xl font-bold text-white">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirm Delete
                </h5>
            </div>
            <div class="p-6">
                <p id="deleteMessage" class="text-gray-700 mb-6"></p>
                <div class="flex justify-end space-x-3">
                    <button onclick="hideDeleteModal()" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                        Cancel
                    </button>
                    <button id="confirmDeleteBtn" class="px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                        <i class="fas fa-trash me-2"></i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Global variables
        let currentRoomId = null;
        let currentActiveTab = 'info';
        let bulkResourceCounter = 0;

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('addBedForm').addEventListener('submit', handleAddBed);
            document.getElementById('editBedForm').addEventListener('submit', handleEditBed);
            document.getElementById('addResourceForm').addEventListener('submit', handleAddResource);
            document.getElementById('maintenanceForm').addEventListener('submit', handleMaintenanceSubmit);

            loadRooms();
        });

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function showResourceTypeInfo(selectElement) {
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            const description = selectedOption.getAttribute('data-description');
            const descriptionDiv = document.getElementById('resourceTypeDescription');

            if (description && description.trim() !== '') {
                descriptionDiv.querySelector('.resource-type-info').textContent = description;
