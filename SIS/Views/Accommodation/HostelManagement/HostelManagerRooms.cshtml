        function switchTab(tabName) {
            currentActiveTab = tabName;
            switchTabProgrammatically(tabName);
        }

        function switchTabProgrammatically(tabName) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.add('hidden');
            });

            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });

            document.getElementById(tabName + 'Tab').classList.remove('hidden');

            const buttons = document.querySelectorAll('.tab-button');
            if (tabName === 'info') buttons[0].classList.add('active');
            if (tabName === 'beds') buttons[1].classList.add('active');
            if (tabName === 'resources') buttons[2].classList.add('active');
            if (tabName === 'maintenance') {
                buttons[3].classList.add('active');
                loadMaintenanceRequests(currentRoomId);
            }
        }

