@{
    ViewData["Title"] = "No Hostel Assigned";
}

<!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mx-auto px-4 py-12">
    <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <!-- Header -->
            <div class="bg-gradient-to-r from-orange-500 to-red-500 p-6 text-center">
                <i class="fas fa-exclamation-triangle text-6xl text-white mb-4"></i>
                <h2 class="text-3xl font-bold text-white">No Hostel Assigned</h2>
            </div>

            <!-- Content -->
            <div class="p-8">
                <div class="text-center mb-6">
                    <p class="text-lg text-gray-700 mb-4">
                        You are not currently assigned to manage any hostel.
                    </p>
                    <p class="text-gray-600">
                        Please contact the system administrator to be assigned to a hostel as a warden/manager.
                    </p>
                </div>

                <!-- Information Box -->
                <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded mb-6">
                    <div class="flex items-start">
                        <i class="fas fa-info-circle text-blue-500 text-xl mt-1 mr-3"></i>
                        <div>
                            <h6 class="font-semibold text-blue-800 mb-2">What you need:</h6>
                            <ul class="text-sm text-blue-700 space-y-1">
                                <li><i class="fas fa-check-circle mr-2"></i>A hostel must be created in the system</li>
                                <li><i class="fas fa-check-circle mr-2"></i>You must be assigned as the warden/manager of that hostel</li>
                                <li><i class="fas fa-check-circle mr-2"></i>Assignment is done by system administrators</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Contact Information -->
                <div class="bg-gray-50 rounded-lg p-6">
                    <h6 class="font-semibold text-gray-800 mb-3">
                        <i class="fas fa-headset mr-2 text-teal-600"></i>Need Help?
                    </h6>
                    <p class="text-gray-700 mb-3">
                        Please reach out to your system administrator or IT support team to:
                    </p>
                    <ul class="text-gray-600 space-y-2 mb-4">
                        <li><i class="fas fa-arrow-right mr-2 text-teal-600"></i>Verify your hostel manager role</li>
                        <li><i class="fas fa-arrow-right mr-2 text-teal-600"></i>Request hostel assignment</li>
                        <li><i class="fas fa-arrow-right mr-2 text-teal-600"></i>Report any access issues</li>
                    </ul>
                </div>

                <!-- Actions -->
                <div class="mt-8 text-center space-y-3">
                    <a href="@Url.Action("Index", "Home")" class="inline-block bg-gradient-to-r from-teal-600 to-cyan-600 text-white px-8 py-3 rounded-lg font-semibold shadow-md hover:shadow-lg transition">
                        <i class="fas fa-home mr-2"></i>Return to Home
                    </a>
                    <p class="text-sm text-gray-500">
                        <i class="fas fa-shield-alt mr-1"></i>
                        If you believe this is an error, please contact support immediately
                    </p>
                </div>
            </div>
        </div>

        <!-- Additional Resources -->
        <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <i class="fas fa-book text-3xl text-blue-600 mb-2"></i>
                <h6 class="font-semibold text-gray-800">Documentation</h6>
                <p class="text-sm text-gray-600 mt-1">View user guides</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <i class="fas fa-question-circle text-3xl text-green-600 mb-2"></i>
                <h6 class="font-semibold text-gray-800">FAQ</h6>
                <p class="text-sm text-gray-600 mt-1">Common questions</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <i class="fas fa-phone text-3xl text-purple-600 mb-2"></i>
                <h6 class="font-semibold text-gray-800">Support</h6>
                <p class="text-sm text-gray-600 mt-1">Contact IT help desk</p>
            </div>
        </div>
    </div>
</div>

<style>
    .container {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
    }
</style>
