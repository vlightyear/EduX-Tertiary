@model SIS.Models.StudentAccommodation.AccomodationConfiguration

@{
    ViewData["Title"] = "Accommodation Configuration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .bg-primary-teal {
        background: linear-gradient(135deg, #1a5c73 0%, #1e5a6e 100%);
    }

    .bg-primary-teal-solid {
        background-color: #1a5c73;
    }

    .text-primary-teal {
        color: #1a5c73;
    }

    .border-primary-teal {
        border-color: #1a5c73;
    }

    .hover\:bg-primary-teal-dark:hover {
        background-color: #134654;
    }

    .focus\:ring-primary-teal:focus {
        --tw-ring-color: rgba(26, 92, 115, 0.5);
    }

    .focus\:border-primary-teal:focus {
        border-color: #1a5c73;
    }

    /* Toggle Switch Styles */
    .toggle-checkbox:checked {
        right: 0;
        border-color: #1a5c73;
    }

        .toggle-checkbox:checked + .toggle-label {
            background-color: #1a5c73;
        }
</style>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 p-4 md:p-6">
    <!-- Header Section -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 md:p-6 mb-6">
        <div class="flex items-center">
            <div class="bg-primary-teal rounded-lg p-3 mr-4">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
            </div>
            <div>
                <nav class="text-sm text-slate-500 mb-1">
                    <a href="@Url.Action("Index", "Home")" class="text-primary-teal hover:underline">Home</a>
                    <span class="mx-2">/</span>
                    <span class="text-slate-800">Accommodation Configuration</span>
                </nav>
                <h1 class="text-2xl md:text-3xl font-bold text-slate-800">Accommodation Configuration</h1>
                <p class="text-sm text-slate-600 mt-1">Manage system settings, fees, account codes, and view statistics</p>
            </div>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mb-6 flex items-center shadow-sm" role="alert">
            <svg class="w-5 h-5 mr-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div class="flex-1">
                <strong class="font-semibold">Success!</strong>
                <span class="block sm:inline">@TempData["SuccessMessage"]</span>
            </div>
            <button onclick="this.parentElement.remove()" class="ml-4 text-green-600 hover:text-green-800">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-6 flex items-center shadow-sm" role="alert">
            <svg class="w-5 h-5 mr-3 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
            <div class="flex-1">
                <strong class="font-semibold">Error!</strong>
                <span class="block sm:inline">@TempData["ErrorMessage"]</span>
            </div>
            <button onclick="this.parentElement.remove()" class="ml-4 text-red-600 hover:text-red-800">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Total Applications -->
        <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <p class="text-xs text-slate-500 font-semibold uppercase tracking-wide mb-2">Total Applications</p>
                    <p class="text-2xl font-bold text-slate-800" id="totalApplications">--</p>
                </div>
                <div class="bg-blue-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Pending Applications -->
        <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <p class="text-xs text-slate-500 font-semibold uppercase tracking-wide mb-2">Pending</p>
                    <p class="text-2xl font-bold text-slate-800" id="pendingApplications">--</p>
                </div>
                <div class="bg-yellow-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Active Allocations -->
        <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <p class="text-xs text-slate-500 font-semibold uppercase tracking-wide mb-2">Active Allocations</p>
                    <p class="text-2xl font-bold text-slate-800" id="totalAllocations">--</p>
                </div>
                <div class="bg-green-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Total Revenue -->
        <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <p class="text-xs text-slate-500 font-semibold uppercase tracking-wide mb-2">Total Revenue</p>
                    <p class="text-2xl font-bold text-slate-800" id="totalRevenue">--</p>
                </div>
                <div class="bg-purple-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Configuration Form Card -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <!-- Form Header with Dark Teal Theme -->
        <div class="bg-primary-teal text-white p-5">
            <div class="flex items-center">
                <svg class="w-7 h-7 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                </svg>
                <div>
                    <h2 class="text-xl font-semibold">System Settings</h2>
                    <p class="text-sm text-white/80 mt-1">Configure accommodation fees, account codes, and reservation settings</p>
                </div>
            </div>
        </div>

        <!-- Form Content -->
        <form id="configForm" class="p-6 md:p-8">
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Credit Code -->
                <div>
                    <label for="CreditCode" class="block text-sm font-semibold text-slate-700 mb-2">
                        Credit Code (N-Code) <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                        </div>
                        <input type="text"
                               class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-primary-teal transition-colors"
                               id="CreditCode"
                               name="CreditCode"
                               value="@Model?.CreditCode"
                               placeholder="ACC-CR-001"
                               required>
                    </div>
                    <p class="mt-1.5 text-xs text-slate-500 flex items-center">
                        <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                        </svg>
                        Credit account code for revenue recognition
                    </p>
                </div>

                <!-- Debit Code -->
                <div>
                    <label for="DebitCode" class="block text-sm font-semibold text-slate-700 mb-2">
                        Debit Code (N-Code) <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                            </svg>
                        </div>
                        <input type="text"
                               class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-primary-teal transition-colors"
                               id="DebitCode"
                               name="DebitCode"
                               value="@Model?.DebitCode"
                               placeholder="ACC-DR-001"
                               required>
                    </div>
                    <p class="mt-1.5 text-xs text-slate-500 flex items-center">
                        <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                        </svg>
                        Debit account code for student receivables
                    </p>
                </div>

                <!-- Reservation Hours -->
                <div>
                    <label for="ReservationHoursValidity" class="block text-sm font-semibold text-slate-700 mb-2">
                        Reservation Validity (Hours) <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <input type="number"
                               class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-primary-teal transition-colors"
                               id="ReservationHoursValidity"
                               name="ReservationHoursValidity"
                               value="@Model?.ReservationHoursValidity"
                               min="1"
                               max="168"
                               placeholder="48"
                               required>
                    </div>
                    <p class="mt-1.5 text-xs text-slate-500 flex items-center">
                        <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                        </svg>
                        Duration a reservation remains valid (1-168 hours)
                    </p>
                </div>

                <!-- Accommodation Fee -->
                <div>
                    <label for="AccommodationFee" class="block text-sm font-semibold text-slate-700 mb-2">
                        Accommodation Fee (ZMW) <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="text-slate-600 font-semibold text-sm">K</span>
                        </div>
                        <input type="number"
                               step="0.01"
                               class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-primary-teal transition-colors"
                               id="AccommodationFee"
                               name="AccommodationFee"
                               value="@Model?.AccommodationFee"
                               min="0"
                               placeholder="2500.00"
                               required>
                    </div>
                    <p class="mt-1.5 text-xs text-slate-500 flex items-center">
                        <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                        </svg>
                        Standard accommodation fee per period
                    </p>
                </div>
            </div>

            <!-- Payment Receipt Location (Full Width) -->
            <div class="mt-6">
                <label for="LocationToTakeAccommodationPaymentReceipt" class="block text-sm font-semibold text-slate-700 mb-2">
                    Payment Receipt Location <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <input type="text"
                           class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-teal focus:border-primary-teal transition-colors"
                           id="LocationToTakeAccommodationPaymentReceipt"
                           name="LocationToTakeAccommodationPaymentReceipt"
                           value="@Model?.LocationToTakeAccommodationPaymentReceipt"
                           placeholder="Accommodation Office"
                           required>
                </div>
                <p class="mt-1.5 text-xs text-slate-500 flex items-center">
                    <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                    </svg>
                    Physical location where students collect receipts
                </p>
            </div>

            <!-- DeAllocate Bed Space Upon Check Out Toggle -->
            <div class="mt-6 p-4 bg-slate-50 rounded-lg border border-slate-200">
                <div class="flex items-start justify-between">
                    <div class="flex-1 mr-4">
                        <label for="DeAllocateBedSpaceUponCheckOut" class="block text-sm font-semibold text-slate-700 mb-1">
                            Auto-Deallocate Bed Space on Check-Out
                        </label>
                        <p class="text-xs text-slate-600">
                            When enabled, the system will automatically free up bed spaces and mark them as available when students check out.
                            This allows immediate reallocation without manual intervention.
                        </p>
                    </div>
                    <div class="flex items-center">
                        <div class="relative inline-block w-12 mr-2 align-middle select-none">
                            <input type="checkbox"
                                   name="DeAllocateBedSpaceUponCheckOut"
                                   id="DeAllocateBedSpaceUponCheckOut"
                            @(Model?.DeAllocateBedSpaceUponCheckOut == true ? "checked" : "")
                                   class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all duration-200"
                                   style="right: 0;" />
                            <label for="DeAllocateBedSpaceUponCheckOut"
                                   class="toggle-label block overflow-hidden h-6 rounded-full bg-slate-300 cursor-pointer transition-all duration-200"></label>
                        </div>
                    </div>
                </div>
                <div class="mt-3 flex items-center text-xs">
                    <svg class="w-4 h-4 mr-1.5 text-amber-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-slate-600">
                        <strong>Recommended:</strong> Enable this for automated bed space management
                    </span>
                </div>
            </div>

            <!-- Action Buttons with Dark Teal Theme -->
            <div class="mt-8 pt-6 border-t border-slate-200 flex flex-col sm:flex-row gap-3">
                <button type="submit"
                        class="flex-1 sm:flex-none px-6 py-2.5 bg-primary-teal-solid text-white text-sm font-medium rounded-lg hover:bg-primary-teal-dark transition-all shadow-sm flex items-center justify-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                    </svg>
                    Save Configuration
                </button>
                <button type="button"
                        id="resetBtn"
                        class="flex-1 sm:flex-none px-6 py-2.5 bg-slate-600 text-white text-sm font-medium rounded-lg hover:bg-slate-700 transition-all shadow-sm flex items-center justify-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    Reset to Defaults
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Load statistics
            loadStatistics();

            // Auto-refresh statistics every 30 seconds
            setInterval(loadStatistics, 30000);

            // Form submission
            document.getElementById('configForm').addEventListener('submit', function(e) {
                e.preventDefault();

                const submitBtn = this.querySelector('button[type="submit"]');
                const originalHTML = submitBtn.innerHTML;
                submitBtn.innerHTML = '<svg class="animate-spin h-4 w-4 mr-2 inline-block" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Saving...';
                submitBtn.disabled = true;

                const formData = new FormData(this);

                // Handle checkbox manually - if not checked, FormData won't include it
                const checkbox = document.getElementById('DeAllocateBedSpaceUponCheckOut');
                if (!checkbox.checked) {
                    // Remove any existing value and add false
                    formData.delete('DeAllocateBedSpaceUponCheckOut');
                    formData.append('DeAllocateBedSpaceUponCheckOut', 'false');
                } else {
                    // Ensure it's set to true
                    formData.set('DeAllocateBedSpaceUponCheckOut', 'true');
                }

                fetch('@Url.Action("SaveConfiguration", "AccommodationConfiguration")', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    submitBtn.innerHTML = originalHTML;
                    submitBtn.disabled = false;

                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false,
                            confirmButtonColor: '#1a5c73'
                        });
                        loadStatistics();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.message,
                            confirmButtonColor: '#1a5c73'
                        });
                    }
                })
                .catch(error => {
                    submitBtn.innerHTML = originalHTML;
                    submitBtn.disabled = false;
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'An error occurred while saving configuration',
                        confirmButtonColor: '#1a5c73'
                    });
                });
            });

            // Reset button
            document.getElementById('resetBtn').addEventListener('click', function() {
                Swal.fire({
                    title: 'Reset Configuration?',
                    html: '<div class="text-left text-sm"><p class="mb-3 text-slate-700">This will reset all settings to default values:</p>' +
                          '<ul class="space-y-1 text-slate-600">' +
                          '<li>• Credit Code: <strong>ACC-CR-001</strong></li>' +
                          '<li>• Debit Code: <strong>ACC-DR-001</strong></li>' +
                          '<li>• Reservation Hours: <strong>48</strong></li>' +
                          '<li>• Fee: <strong>K2,500.00</strong></li>' +
                          '<li>• Location: <strong>Accommodation Office</strong></li>' +
                          '<li>• Auto-Deallocate: <strong>Disabled</strong></li>' +
                          '</ul></div>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#1a5c73',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Yes, reset it!',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                        Swal.fire({
                            title: 'Resetting...',
                            text: 'Please wait',
                            allowOutsideClick: false,
                            showConfirmButton: false,
                            willOpen: () => {
                                Swal.showLoading();
                            }
                        });

                        fetch('@Url.Action("ResetToDefaults", "AccommodationConfiguration")', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                            },
                            body: '__RequestVerificationToken=' + encodeURIComponent(token)
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Reset Complete!',
                                    text: data.message,
                                    showConfirmButton: false,
                                    timer: 1500,
                                    confirmButtonColor: '#1a5c73'
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: data.message,
                                    confirmButtonColor: '#1a5c73'
                                });
                            }
                        });
                    }
                });
            });

            // Load statistics
            function loadStatistics() {
                fetch('@Url.Action("GetStatistics", "AccommodationConfiguration")')
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById('totalApplications').textContent = data.data.totalApplications;
                            document.getElementById('pendingApplications').textContent = data.data.pendingApplications;
                            document.getElementById('totalAllocations').textContent = data.data.totalAllocations;
                            document.getElementById('totalRevenue').textContent = 'K ' + data.data.totalRevenue.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
                        }
                    })
                    .catch(error => {
                        console.error('Error loading statistics:', error);
                    });
            }

            // Auto-dismiss alerts
            setTimeout(function() {
                const alerts = document.querySelectorAll('[role="alert"]');
                alerts.forEach(alert => {
                    alert.style.transition = 'opacity 0.5s';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.remove(), 500);
                });
            }, 5000);
        });
    </script>
}
