@model IEnumerable<SIS.Models.StudentAccommodation.AccommodationPeriod>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Accommodation Periods";
    var totalPeriods = Model.Count();
    var activePeriods = Model.Count(p => p.Status == SIS.Enums.Status.Active);
    var totalApps = Model.Sum(p => p.Applications?.Count ?? 0);
}

<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<style>
    :root {
        --coral: #e85c5c;
        --coral-d: #c94040;
        --navy: #1e2d5e;
        --navy-l: #2e3f7a;
        --mist: #f5f7fa;
        --border: #e8ecf2;
        --ink: #1a1f2e;
        --text: #475569;
        --green: #16a34a;
        --greenl: #dcfce7;
        --amber: #d97706;
        --amberl: #fffbeb;
    }

    * {
        font-family: 'DM Sans', sans-serif;
        box-sizing: border-box;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: .55;
        }
    }

    /* ── Page shell ─────────────────────── */
    .ap-page {
        background: var(--mist);
        min-height: 100vh;
    }

    /* ── Hero ──────────────────────────── */
    .ap-hero {
        background: linear-gradient(135deg, #141c3a 0%, var(--navy) 40%, var(--navy-l) 75%, #2a1a5e 100%);
        padding: 1.75rem 2rem 4.25rem;
        position: relative;
        overflow: hidden;
    }
        /* decorative spheres */
        .ap-hero::before {
            content: '';
            position: absolute;
            top: -70px;
            right: -50px;
            width: 260px;
            height: 260px;
            background: radial-gradient(circle, rgba(232,92,92,.18) 0%, transparent 70%);
            pointer-events: none;
        }

        .ap-hero::after {
            content: '';
            position: absolute;
            bottom: -90px;
            left: 12%;
            width: 340px;
            height: 340px;
            background: radial-gradient(circle, rgba(255,255,255,.04) 0%, transparent 70%);
            pointer-events: none;
        }

    .ap-hero-inner {
        position: relative;
        z-index: 1;
    }

    /* top row */
    .ap-hero-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .ap-hero-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .ap-hero-icon {
        width: 58px;
        height: 58px;
        border-radius: 1rem;
        flex-shrink: 0;
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.2);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px rgba(0,0,0,.2);
    }

        .ap-hero-icon i {
            font-size: 1.85rem;
            color: #fff;
        }

    .ap-hero-eyebrow {
        font-size: .67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: rgba(255,255,255,.4);
        margin-bottom: .25rem;
    }

    .ap-hero-title {
        font-family: 'DM Serif Display', serif;
        font-size: 1.7rem;
        color: #fff;
        margin: 0;
        line-height: 1.15;
    }

    .ap-hero-sub {
        font-size: .78rem;
        color: rgba(255,255,255,.5);
        margin-top: .2rem;
    }

    /* stats row inside hero */
    .ap-hero-stats {
        display: flex;
        gap: 2rem;
        margin-top: 1.35rem;
        flex-wrap: wrap;
    }

    .ap-stat {
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .ap-stat-ring {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.18);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .ap-stat-ring i {
            font-size: .95rem;
            color: rgba(255,255,255,.75);
        }

    .ap-stat-val {
        font-family: 'DM Serif Display', serif;
        font-size: 1.35rem;
        color: #fff;
        line-height: 1;
    }

    .ap-stat-lbl {
        font-size: .66rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: rgba(255,255,255,.4);
    }

    /* create button */
    .btn-hero-create {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: var(--coral);
        color: #fff;
        border: none;
        font-size: .82rem;
        font-weight: 700;
        font-family: inherit;
        padding: .7rem 1.35rem;
        border-radius: .7rem;
        cursor: pointer;
        box-shadow: 0 4px 18px rgba(232,92,92,.4);
        transition: background .15s, transform .1s;
        flex-shrink: 0;
        white-space: nowrap;
    }

        .btn-hero-create:hover {
            background: var(--coral-d);
            transform: translateY(-1px);
        }

        .btn-hero-create i {
            font-size: 1rem;
        }

    /* ── Floating strip (alerts) ───────── */
    .ap-strip {
        margin: -2.35rem 2rem 0;
        position: relative;
        z-index: 3;
        display: flex;
        flex-direction: column;
        gap: .65rem;
    }

    .strip-alert {
        display: flex;
        align-items: center;
        gap: .75rem;
        border-radius: .75rem;
        padding: .85rem 1rem;
        font-size: .8rem;
        box-shadow: 0 4px 20px rgba(30,45,94,.12);
        background: #fff;
        animation: fadeUp .25s ease-out;
    }

        .strip-alert i {
            font-size: 1.05rem;
            flex-shrink: 0;
        }

    .strip-success {
        border-left: 4px solid var(--green);
        color: #166534;
    }

        .strip-success i {
            color: var(--green);
        }

    .strip-error {
        border-left: 4px solid var(--coral);
        color: #991b1b;
    }

        .strip-error i {
            color: var(--coral);
        }

    /* ── Periods grid ──────────────────── */
    .ap-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.15rem;
        padding: 1.85rem 2rem 2.5rem;
        margin-top: 1.35rem;
    }

    /* ── Period card ───────────────────── */
    .period-card {
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 1.1rem;
        padding: 1.1rem;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0 2px 10px rgba(30,45,94,.06);
        transition: border-color .15s, box-shadow .15s, transform .12s;
        animation: fadeUp .35s ease-out both;
    }

        .period-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--navy), var(--navy-l));
            opacity: 0;
            transition: opacity .2s;
        }

        .period-card:hover {
            border-color: #c4cfe2;
            box-shadow: 0 8px 28px rgba(30,45,94,.13);
            transform: translateY(-3px);
        }

            .period-card:hover::before {
                opacity: 1;
            }

        .period-card.selected {
            border-color: var(--coral);
            box-shadow: 0 0 0 3px rgba(232,92,92,.15), 0 8px 28px rgba(30,45,94,.1);
        }

            .period-card.selected::before {
                background: linear-gradient(90deg, var(--coral), var(--coral-d));
                opacity: 1;
            }

        /* stagger animation delays */
        .period-card:nth-child(1) {
            animation-delay: .05s;
        }

        .period-card:nth-child(2) {
            animation-delay: .1s;
        }

        .period-card:nth-child(3) {
            animation-delay: .15s;
        }

        .period-card:nth-child(4) {
            animation-delay: .2s;
        }

        .period-card:nth-child(5) {
            animation-delay: .25s;
        }

        .period-card:nth-child(6) {
            animation-delay: .3s;
        }

    /* ── Card header ───────────────────── */
    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: .85rem;
        gap: .5rem;
    }

    .card-title {
        font-family: 'DM Serif Display', serif;
        font-size: 1.05rem;
        color: var(--ink);
        margin: 0 0 .45rem;
        line-height: 1.2;
    }

    .card-badges {
        display: flex;
        gap: .35rem;
        flex-wrap: wrap;
    }

    /* status pills */
    .sp {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        font-size: .65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
        padding: .22rem .55rem;
        border-radius: 2rem;
    }

        .sp i {
            font-size: .75rem;
        }

    .sp-active {
        background: var(--greenl);
        color: #166534;
    }

    .sp-inactive {
        background: var(--mist);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .sp-upcoming {
        background: #eff6ff;
        color: #1e40af;
    }

    .sp-closed {
        background: #fee2e2;
        color: #991b1b;
    }

    .sp-payment {
        background: var(--amberl);
        color: var(--amber);
        border: 1px solid #fde68a;
    }

    /* ── Three-dot menu ─────────────────── */
    .card-menu-wrap {
        position: relative;
        flex-shrink: 0;
    }

    .card-menu-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: .3rem;
        border-radius: .45rem;
        color: #94a3b8;
        display: flex;
        align-items: center;
        transition: all .15s;
    }

        .card-menu-btn:hover {
            background: var(--mist);
            color: var(--ink);
        }

        .card-menu-btn i {
            font-size: 1.1rem;
        }

    .drop-menu {
        position: absolute;
        right: 0;
        top: calc(100% + .35rem);
        width: 12rem;
        background: #fff;
        border-radius: .8rem;
        border: 1.5px solid var(--border);
        box-shadow: 0 10px 30px rgba(30,45,94,.15);
        z-index: 30;
        overflow: hidden;
    }

        .drop-menu a {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: .65rem .9rem;
            font-size: .8rem;
            color: var(--text);
            text-decoration: none;
            transition: background .12s;
        }

            .drop-menu a i {
                font-size: .9rem;
            }

            .drop-menu a:hover {
                background: var(--mist);
                color: var(--ink);
            }

            .drop-menu a.dm-del {
                color: var(--coral);
            }

                .drop-menu a.dm-del:hover {
                    background: #fef2f2;
                }

        .drop-menu hr {
            margin: .2rem 0;
            border: none;
            border-top: 1px solid var(--border);
        }

    /* ── Detail cells ──────────────────── */
    .dc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .45rem;
        margin: .5rem 0 .7rem;
    }

    .dc {
        background: var(--mist);
        border: 1px solid var(--border);
        border-radius: .55rem;
        padding: .5rem .65rem;
    }

        .dc.full {
            grid-column: 1 / -1;
        }

        .dc.amber-dc {
            background: var(--amberl);
            border-color: #fde68a;
        }

    .dc-lbl {
        font-size: .6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #94a3b8;
        margin-bottom: .18rem;
        display: flex;
        align-items: center;
        gap: .2rem;
    }

        .dc-lbl i {
            font-size: .68rem;
        }

    .dc.amber-dc .dc-lbl {
        color: #a16207;
    }

    .dc-val {
        font-size: .78rem;
        font-weight: 700;
        color: var(--ink);
    }

    .dc.amber-dc .dc-val {
        color: var(--amber);
    }

    /* ── App count bar ─────────────────── */
    .app-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--mist);
        border: 1px solid var(--border);
        border-radius: .55rem;
        padding: .42rem .7rem;
        margin-bottom: .6rem;
    }

    .app-bar-left {
        display: flex;
        align-items: center;
        gap: .3rem;
        font-size: .76rem;
        font-weight: 700;
        color: var(--ink);
    }

        .app-bar-left i {
            font-size: .85rem;
            color: var(--navy);
        }

    .app-bar-right {
        display: flex;
        gap: .55rem;
        font-size: .67rem;
        font-weight: 700;
    }

    .app-bar-approved {
        color: var(--green);
    }

    .app-bar-pending {
        color: var(--amber);
    }

    /* ── Eligibility tag ───────────────── */
    .elig-tag {
        display: flex;
        align-items: center;
        gap: .4rem;
        border-radius: .55rem;
        padding: .45rem .7rem;
        font-size: .73rem;
        font-weight: 600;
        margin-bottom: .7rem;
    }

        .elig-tag i {
            font-size: .85rem;
        }

    .elig-universal {
        background: #ecfeff;
        border: 1px solid #a5f3fc;
        color: #0e7490;
    }

    .elig-restricted {
        background: var(--mist);
        border: 1px solid var(--border);
        color: var(--text);
    }

    /* ── Card action buttons ───────────── */
    .card-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
        margin-top: .4rem;
    }

    .btn-select {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        background: var(--navy);
        color: #fff;
        border: none;
        font-size: .76rem;
        font-weight: 700;
        font-family: inherit;
        padding: .55rem;
        border-radius: .55rem;
        cursor: pointer;
        transition: background .15s;
    }

        .btn-select:hover {
            background: var(--navy-l);
        }

        .btn-select.selected {
            background: var(--green);
        }

            .btn-select.selected:hover {
                background: #15803d;
            }

        .btn-select i {
            font-size: .85rem;
        }

    .btn-del-outline {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        background: transparent;
        color: var(--coral);
        border: 1.5px solid rgba(232,92,92,.3);
        font-size: .76rem;
        font-weight: 700;
        font-family: inherit;
        padding: .55rem;
        border-radius: .55rem;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-del-outline:hover {
            background: var(--coral);
            color: #fff;
            border-color: var(--coral);
        }

        .btn-del-outline i {
            font-size: .85rem;
        }

    /* ── Empty state ───────────────────── */
    .ap-empty {
        grid-column: 1 / -1;
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 1.25rem;
        padding: 4rem 2rem;
        text-align: center;
        box-shadow: 0 2px 12px rgba(30,45,94,.06);
    }

    .empty-ring {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        margin: 0 auto 1.35rem;
        background: linear-gradient(135deg, var(--navy), var(--navy-l));
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 28px rgba(30,45,94,.28);
    }

        .empty-ring i {
            font-size: 2.4rem;
            color: #fff;
        }

    .ap-empty h4 {
        font-family: 'DM Serif Display', serif;
        font-size: 1.4rem;
        color: var(--ink);
        margin: 0 0 .55rem;
    }

    .ap-empty p {
        font-size: .8rem;
        color: var(--text);
        max-width: 22rem;
        margin: 0 auto 1.75rem;
        line-height: 1.65;
    }

    /* ── Loading overlay ───────────────── */
    #loadingIndicator {
        position: fixed;
        inset: 0;
        background: rgba(15,20,40,.55);
        backdrop-filter: blur(4px);
        z-index: 10000;
        display: none;
        align-items: center;
        justify-content: center;
    }

        #loadingIndicator[style*="display: flex"] {
            display: flex !important;
        }

    .li-box {
        background: #fff;
        border-radius: 1rem;
        padding: 1.4rem 2rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        box-shadow: 0 20px 40px rgba(15,20,40,.22);
    }

    .li-spin {
        animation: spin 1s linear infinite;
        font-size: 1.5rem;
        color: var(--coral);
    }

    .li-txt {
        font-size: .85rem;
        font-weight: 700;
        color: var(--ink);
    }

    /* ── Modals ────────────────────────── */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,20,40,.55);
        backdrop-filter: blur(4px);
        z-index: 9998;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        overflow-y: auto;
    }

        .modal-overlay.hidden {
            display: none !important;
        }

    .modal-box {
        background: #fff;
        border-radius: 1.25rem;
        width: 100%;
        max-height: 90vh;
        overflow-y: auto;
        margin: auto;
        box-shadow: 0 24px 60px rgba(15,20,40,.3);
        animation: fadeUp .22s ease-out;
    }

    .modal-head {
        background: linear-gradient(135deg, var(--navy), var(--navy-l));
        padding: 1.1rem 1.4rem;
        border-radius: 1.25rem 1.25rem 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .modal-head-title {
        font-family: 'DM Serif Display', serif;
        font-size: 1.05rem;
        color: #fff;
        display: flex;
        align-items: center;
        gap: .5rem;
        margin: 0;
    }

        .modal-head-title i {
            font-size: 1.05rem;
            color: rgba(255,255,255,.65);
        }

    .modal-close {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.22);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        flex-shrink: 0;
    }

        .modal-close:hover {
            background: rgba(255,255,255,.24);
        }

        .modal-close i {
            font-size: .9rem;
        }

    /* modal body */
    .modal-body {
        padding: 1.5rem;
    }

    /* form sections */
    .form-sec {
        margin-bottom: 1.5rem;
    }

    .form-sec-title {
        font-size: .71rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--navy);
        display: flex;
        align-items: center;
        gap: .4rem;
        padding-bottom: .6rem;
        border-bottom: 1.5px solid var(--border);
        margin-bottom: 1rem;
    }

        .form-sec-title i {
            font-size: .85rem;
        }

    /* form grids */
    .fg2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .fg3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .85rem;
    }

    @@media (max-width: 580px) {
        .fg2, .fg3 {
            grid-template-columns: 1fr;
        }
    }

    .ff {
        display: flex;
        flex-direction: column;
        gap: .35rem;
    }

        .ff label {
            font-size: .71rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: var(--ink);
        }

            .ff label .req {
                color: var(--coral);
            }

            .ff label .opt {
                font-weight: 400;
                text-transform: none;
                color: #94a3b8;
                font-size: .66rem;
                letter-spacing: 0;
            }

        .ff input[type=date], .ff input[type=number], .ff select {
            padding: .55rem .75rem;
            border: 1.5px solid var(--border);
            border-radius: .55rem;
            font-family: inherit;
            font-size: .82rem;
            color: var(--ink);
            background: #fff;
            transition: border-color .15s, box-shadow .15s;
            width: 100%;
        }

            .ff input:focus, .ff select:focus {
                outline: none;
                border-color: var(--navy);
                box-shadow: 0 0 0 3px rgba(30,45,94,.1);
            }

            .ff input.err, .ff select.err {
                border-color: var(--coral);
            }

        .ff .ferr {
            font-size: .68rem;
            color: var(--coral);
            display: none;
        }

            .ff .ferr.show {
                display: block;
            }

    /* checkbox row */
    .chk-row {
        display: flex;
        align-items: flex-start;
        gap: .65rem;
        background: var(--mist);
        border: 1.5px solid var(--border);
        border-radius: .65rem;
        padding: .75rem .9rem;
    }

        .chk-row input[type=checkbox] {
            accent-color: var(--navy);
            width: 1rem;
            height: 1rem;
            margin-top: .1rem;
            flex-shrink: 0;
            cursor: pointer;
        }

    .chk-row-title {
