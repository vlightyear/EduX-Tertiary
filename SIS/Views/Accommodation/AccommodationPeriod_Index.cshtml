<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@section Scripts {
    <script>
        let dropdownsLoaded = false;
        let currentPeriodId = 0;

        document.addEventListener('DOMContentLoaded', () => {
            loadDropdowns();
            loadSelectedPeriod();

            @if (TempData["SuccessMessage"] != null)
            {
                    <text>showToast('@TempData["SuccessMessage"]','success');</text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                    <text>showToast('@TempData["ErrorMessage"]','error');</text>
            }

            document.addEventListener('click', e => {
                if (!e.target.closest('.card-menu-wrap'))
                    document.querySelectorAll('[id^="dropdown-"]').forEach(d => d.style.display = 'none');
            });
        });

        /* ── Dropdown ── */
        function toggleDropdown(e, id) {
            e.stopPropagation();
            const dd = document.getElementById(`dropdown-${id}`);
            document.querySelectorAll('[id^="dropdown-"]').forEach(d => { if (d !== dd) d.style.display = 'none'; });
            dd.style.display = dd.style.display === 'none' ? 'block' : 'none';
        }

        /* ── Select period ── */
        function selectPeriod(e, periodId, type, payType) {
            e.stopPropagation();
            document.querySelectorAll('.period-card').forEach(c => c.classList.remove('selected'));
            document.querySelectorAll('.btn-select').forEach(b => {
                b.classList.remove('selected');
                b.innerHTML = '<i class="material-icons">check_circle</i><span>Select</span>';
            });
            e.target.closest('.period-card')?.classList.add('selected');
            const btn = document.getElementById(`selectBtn-${periodId}`);
            if (btn) { btn.classList.add('selected'); btn.innerHTML = '<i class="material-icons">check_circle</i><span>Selected</span>'; }
            sessionStorage.setItem('selectedPeriodId', periodId);
            sessionStorage.setItem('selectedPeriodInfo', JSON.stringify({ periodId, type, payType, selectedAt: new Date().toISOString() }));
            showToast(`"${type} – ${payType}" selected!`, 'success');
        }

        function loadSelectedPeriod() {
            const id = sessionStorage.getItem('selectedPeriodId');
            if (!id) return;
            const btn = document.getElementById(`selectBtn-${id}`);
            if (btn) {
                btn.classList.add('selected');
                btn.innerHTML = '<i class="material-icons">check_circle</i><span>Selected</span>';
                btn.closest('.period-card')?.classList.add('selected');
            }
        }

        /* ── Load dropdowns ── */
        async function loadDropdowns() {
            if (dropdownsLoaded) return;
            showLoader();
            try {
                const [schools, modes, levels] = await Promise.all([
                    fetch('/AccommodationPeriod/GetSchools').then(r => r.json()),
                    fetch('/AccommodationPeriod/GetModesOfStudy').then(r => r.json()),
                    fetch('/AccommodationPeriod/GetProgramLevels').then(r => r.json())
                ]);
                populateDrop('schoolId', schools);
                populateDrop('modeOfStudyId', modes);
                populateDrop('programLevelId', levels);
                dropdownsLoaded = true;
            } catch { showToast('Error loading form data', 'error'); }
            finally { hideLoader(); }
        }

        function populateDrop(id, items) {
            const s = document.getElementById(id), cur = s.value;
            while (s.options.length > 1) s.remove(1);
            items.forEach(i => s.add(new Option(i.text || i.name, i.value || i.id)));
            if (cur) s.value = cur;
        }

        async function loadProgrammes() {
            const sid = document.getElementById('schoolId').value;
            if (!sid) { populateDrop('programmeId', []); return; }
            try { populateDrop('programmeId', await fetch(`/AccommodationPeriod/GetProgrammes?schoolId=${sid}`).then(r => r.json())); }
            catch (e) { console.error(e); }
        }

        /* ── Create modal ── */
        function showCreateModal() {
            currentPeriodId = 0;
            document.getElementById('periodId').value = '0';
            document.getElementById('periodForm').action = '/AccommodationPeriod/Create';
            document.getElementById('periodModalTitle').innerHTML = '<i class="material-icons">add_circle</i>Create Accommodation Period';
            document.getElementById('submitButtonText').textContent = 'Create Period';
            document.getElementById('periodForm').reset();
            setEligibilityState(false);
            document.getElementById('periodModal').classList.remove('hidden');
        }

        /* ── Edit modal ── */
        async function showEditModal(periodId) {
            currentPeriodId = periodId;
            document.getElementById('periodId').value = periodId;
            document.getElementById('periodForm').action = '/AccommodationPeriod/Edit';
            document.getElementById('periodModalTitle').innerHTML = '<i class="material-icons">edit</i>Edit Accommodation Period';
            document.getElementById('submitButtonText').textContent = 'Update Period';
            showLoader();
            try {
                const r = await fetch(`/AccommodationPeriod/GetPeriod/${periodId}`);
                if (!r.ok) throw new Error(`HTTP ${r.status}`);
                const p = await r.json();
                const g = (k1, k2) => p[k1] !== undefined ? p[k1] : p[k2];
                document.getElementById('type').value                 = g('Type','type') || '';
                document.getElementById('typeOfPayment').value        = g('TypeOfPayment','typeOfPayment') || '';
                document.getElementById('typeOfPaymentAmount').value  = g('TypeOfPaymentAmount','typeOfPaymentAmount') || 0;
                document.getElementById('startDate').value            = fmtDateIn(g('StartDate','startDate'));
                document.getElementById('endDate').value              = fmtDateIn(g('EndDate','endDate'));
                document.getElementById('isPermanent').checked        = g('IsPermanentUntilGraduation','isPermanentUntilGraduation') || false;
                document.getElementById('applicationStartDate').value = fmtDateIn(g('ApplicationStartDate','applicationStartDate'));
                document.getElementById('applicationEndDate').value   = fmtDateIn(g('ApplicationEndDate','applicationEndDate'));
                document.getElementById('status').value               = g('Status','status') !== undefined ? g('Status','status') : '';
                document.getElementById('appliesUniversally').checked = g('AppliesUniversally','appliesUniversally') || false;
                document.getElementById('schoolId').value             = g('SchoolId','schoolId') || '';
                if (g('SchoolId','schoolId')) await loadProgrammes();
                document.getElementById('programmeId').value    = g('ProgrammeId','programmeId') || '';
                document.getElementById('modeOfStudyId').value  = g('ModeOfStudyId','modeOfStudyId') || '';
                document.getElementById('yearOfStudy').value    = g('YearOfStudy','yearOfStudy') || '';
                document.getElementById('programLevelId').value = g('ProgramLevelId','programLevelId') || '';
                toggleEndDate();
                setEligibilityState(document.getElementById('appliesUniversally').checked);
                document.getElementById('periodModal').classList.remove('hidden');
            } catch (e) { showToast(`Error loading period: ${e.message}`, 'error'); }
            finally { hideLoader(); }
        }

        /* ── View modal ── */
        async function showViewModal(periodId) {
            showLoader();
            try {
                const r = await fetch(`/AccommodationPeriod/GetPeriod/${periodId}`);
                if (!r.ok) throw new Error(`HTTP ${r.status}`);
                const p = await r.json();
                currentPeriodId = periodId;
                const g = (k1, k2) => p[k1] !== undefined ? p[k1] : p[k2];

                const status = g('Status','status');
                const sCls  = status===0?'sp-inactive':status===1?'sp-active':status===2?'sp-upcoming':'sp-closed';
                const sTxt  = status===0?'Inactive':status===1?'Active':status===2?'Upcoming':'Closed';
                const sIcon = status===0?'remove_circle':status===1?'check_circle':status===2?'schedule':'cancel';
                const pType = g('Type','type')||'N/A', pyType=g('TypeOfPayment','typeOfPayment')||'N/A';
                const pyAmt = g('TypeOfPaymentAmount','typeOfPaymentAmount')||0;
                const isPerm= g('IsPermanentUntilGraduation','isPermanentUntilGraduation');
                const univ  = g('AppliesUniversally','appliesUniversally');

                const strObj = (obj, keys) => !obj ? null : (typeof obj==='object' ? keys.reduce((acc,k)=>acc||obj[k],null) : obj);
                const school  = strObj(g('School','school'),   ['SchoolName','Name','name','schoolName']);
                const prog    = strObj(g('Programme','programme'), ['ProgrammeName','Name','name']);
                const mode    = strObj(g('ModeOfStudy','modeOfStudy'), ['ModeName','Name','name','modeName']);
                const level   = strObj(g('ProgramLevel','programLevel'), ['LevelName','Name','name']);
                const yearOS  = g('YearOfStudy','yearOfStudy');
                const createdBy=g('CreatedBy','createdBy'), createdAt=g('CreatedAt','createdAt');
                const updatedBy=g('UpdatedBy','updatedBy'), updatedAt=g('UpdatedAt','updatedAt');

                document.getElementById('viewModalContent').innerHTML = `
                    <div style="margin-bottom:1rem;">
                        <h3 style="font-family:'DM Serif Display',serif;font-size:1.25rem;color:var(--ink);margin:0 0 .5rem;">${pType} Period</h3>
                        <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
                            <span class="sp ${sCls}"><i class="material-icons">${sIcon}</i>${sTxt}</span>
                            <span class="sp sp-payment"><i class="material-icons">payments</i>${pyType}</span>
                        </div>
                    </div>

                    <p class="vsec-title"><i class="material-icons">payments</i>Payment Information</p>
                    <div class="vdc-grid">
                        <div class="vdc amber-vdc"><p class="vdc-lbl">Type of Payment</p><p class="vdc-val">${pyType}</p></div>
                        <div class="vdc amber-vdc"><p class="vdc-lbl">Amount</p><p class="vdc-val">K ${parseFloat(pyAmt).toFixed(2)}</p></div>
                    </div>

                    <p class="vsec-title"><i class="material-icons">info</i>Period Information</p>
                    <div class="vdc-grid">
                        <div class="vdc"><p class="vdc-lbl">Type</p><p class="vdc-val">${pType}</p></div>
                        <div class="vdc"><p class="vdc-lbl">Status</p><p class="vdc-val">${sTxt}</p></div>
                        <div class="vdc full"><p class="vdc-lbl">Period</p><p class="vdc-val">${fmtDate(g('StartDate','startDate'))} — ${isPerm?'Until Graduation':fmtDate(g('EndDate','endDate'))}</p></div>
                        <div class="vdc"><p class="vdc-lbl">Application Start</p><p class="vdc-val">${fmtDate(g('ApplicationStartDate','applicationStartDate'))}</p></div>
                        <div class="vdc"><p class="vdc-lbl">Application End</p><p class="vdc-val">${fmtDate(g('ApplicationEndDate','applicationEndDate'))}</p></div>
                    </div>

                    <p class="vsec-title"><i class="material-icons">filter_alt</i>Eligibility</p>
                    ${univ ? `
                        <div class="elig-tag elig-universal" style="margin-bottom:.75rem;">
                            <i class="material-icons">public</i>
                            <span><strong>Universal</strong> — applies to all students</span>
                        </div>
                    ` : `
                        <div class="elig-tag elig-restricted" style="margin-bottom:.75rem;">
                            <i class="material-icons">filter_alt</i>
                            <span><strong>Restricted</strong> — specific eligibility criteria</span>
                        </div>
                        <div class="vdc-grid">
                            <div class="vdc"><p class="vdc-lbl">School</p><p class="vdc-val">${school||'All Schools'}</p></div>
                            <div class="vdc"><p class="vdc-lbl">Programme</p><p class="vdc-val">${prog||'All Programmes'}</p></div>
                            <div class="vdc"><p class="vdc-lbl">Mode of Study</p><p class="vdc-val">${mode||'All Modes'}</p></div>
                            <div class="vdc"><p class="vdc-lbl">Year of Study</p><p class="vdc-val">${yearOS||'All Years'}</p></div>
                            <div class="vdc full"><p class="vdc-lbl">Programme Level</p><p class="vdc-val">${level||'All Levels'}</p></div>
                        </div>
                    `}

                    <p class="vsec-title"><i class="material-icons">history</i>Audit</p>
                    <div class="vdc-grid">
                        <div class="vdc"><p class="vdc-lbl">Created By</p><p class="vdc-val">${createdBy||'—'}</p></div>
                        <div class="vdc"><p class="vdc-lbl">Created At</p><p class="vdc-val">${fmtDate(createdAt)}</p></div>
                        <div class="vdc"><p class="vdc-lbl">Updated By</p><p class="vdc-val">${updatedBy||'—'}</p></div>
                        <div class="vdc"><p class="vdc-lbl">Updated At</p><p class="vdc-val">${fmtDate(updatedAt)}</p></div>
                    </div>
                `;
                document.getElementById('viewModal').classList.remove('hidden');
            } catch (e) { showToast(`Error: ${e.message}`, 'error'); }
            finally { hideLoader(); }
        }

        function editFromView() { hideViewModal(); setTimeout(() => showEditModal(currentPeriodId), 280); }

        /* ── Delete ── */
        function showDeleteModal(periodId, name) {
            Swal.fire({
                title: 'Confirm Deletion',
                html: `Delete the period <strong>${name}</strong>?<br><small style="color:#6b7280;">This action cannot be undone.</small>`,
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#e85c5c', cancelButtonColor: '#94a3b8',
                confirmButtonText: '<i class="material-icons" style="font-size:15px;vertical-align:middle;">delete</i> Delete',
                cancelButtonText: 'Cancel', reverseButtons: true
            }).then(r => { if (r.isConfirmed) performDelete(periodId); });
        }

        async function performDelete(periodId) {
            showLoader();
            try {
                const fd = new FormData();
                fd.append('__RequestVerificationToken', getToken());
                const r = await fetch(`/AccommodationPeriod/Delete/${periodId}`, { method: 'POST', body: fd });
                if (r.ok) { showToast('Period deleted!', 'success'); setTimeout(() => location.reload(), 1500); }
                else showToast(await r.text() || 'Error deleting', 'error');
            } catch { showToast('Error deleting period', 'error'); }
            finally { hideLoader(); }
        }

        /* ── Hide modals ── */
        function hideModal()     { document.getElementById('periodModal').classList.add('hidden'); }
        function hideViewModal() { document.getElementById('viewModal').classList.add('hidden');   }

        /* ── Toggles ── */
        function toggleEndDate() {
            const perm = document.getElementById('isPermanent').checked;
            const ed   = document.getElementById('endDate');
            ed.disabled = perm;
            if (perm) ed.value = '';
        }

        function toggleEligibilityCriteria() {
            setEligibilityState(document.getElementById('appliesUniversally').checked);
        }

        function setEligibilityState(disabled) {
            const div = document.getElementById('eligibilityCriteria');
            div.style.opacity       = disabled ? '.4'   : '1';
            div.style.pointerEvents = disabled ? 'none' : 'auto';
            if (disabled) ['schoolId','programmeId','modeOfStudyId','yearOfStudy','programLevelId'].forEach(id => document.getElementById(id).value = '');
        }

        /* ── Validation ── */
        function validateForm(event) {
            let ok = true;
            document.querySelectorAll('.ferr').forEach(e => e.classList.remove('show'));
            document.querySelectorAll('.ff input.err,.ff select.err').forEach(e => e.classList.remove('err'));

            ['type','typeOfPayment','typeOfPaymentAmount','startDate','applicationStartDate','applicationEndDate','status'].forEach(id => {
                const el = document.getElementById(id);
                if (!el.value && el.value !== '0') {
                    el.classList.add('err');
                    document.getElementById(id+'Error')?.classList.add('show');
                    ok = false;
                }
            });

            const perm = document.getElementById('isPermanent').checked;
            const ed   = document.getElementById('endDate');
            if (!perm && !ed.value) {
                ed.classList.add('err');
                showToast('Provide an End Date or check "Permanent until graduation"', 'error');
                ok = false;
            }

            const sd = document.getElementById('startDate').value;
            if (ok && sd && ed.value && !perm && new Date(ed.value) <= new Date(sd)) {
                showToast('End date must be after start date', 'error'); ok = false;
            }
            const asd = document.getElementById('applicationStartDate').value;
            const aed = document.getElementById('applicationEndDate').value;
            if (ok && asd && aed && new Date(aed) <= new Date(asd)) {
                showToast('Application end date must be after start date', 'error'); ok = false;
            }

            if (!ok) { event.preventDefault(); return false; }
            showLoader();
            event.target.disabled = true;
            event.target.innerHTML = '<i class="material-icons">hourglass_empty</i><span>Saving…</span>';
            return true;
        }

        /* ── Helpers ── */
        function fmtDate(s)  { return s ? new Date(s).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) : '—'; }
        function fmtDateIn(s){ return s ? new Date(s).toISOString().split('T')[0] : ''; }
        function getToken()  { return document.querySelector('input[name="__RequestVerificationToken"]').value; }
        function showLoader(){ document.getElementById('loadingIndicator').style.display = 'flex'; }
        function hideLoader(){ document.getElementById('loadingIndicator').style.display = 'none';  }
        function showToast(msg, type='success') {
            Swal.fire({ toast:true, position:'top-end', showConfirmButton:false, timer:3000, timerProgressBar:true, icon:type, title:msg,
                didOpen:t=>{ t.addEventListener('mouseenter',Swal.stopTimer); t.addEventListener('mouseleave',Swal.resumeTimer); } });
        }
    </script>
}
