</style>

<!-- Loading overlay -->
<div id="loadingIndicator">
    <div class="li-box">
        <i class="material-icons li-spin">refresh</i>
        <span class="li-txt">Loading…</span>
    </div>
</div>

<div class="ap-page">

    <!-- ── Hero ── -->
    <div class="ap-hero">
        <div class="ap-hero-inner">
            <div class="ap-hero-row">
                <div class="ap-hero-left">
                    <div class="ap-hero-icon"><i class="material-icons">event_available</i></div>
                    <div>
                        <p class="ap-hero-eyebrow">Administration</p>
                        <h1 class="ap-hero-title">Accommodation Periods</h1>
                        <p class="ap-hero-sub">Manage periods, payment types &amp; eligibility criteria</p>
                    </div>
                </div>
                <button type="button" class="btn-hero-create" onclick="showCreateModal()">
                    <i class="material-icons">add</i> Create New Period
                </button>
            </div>
            @if (totalPeriods > 0)
            {
                <div class="ap-hero-stats">
                    <div class="ap-stat">
                        <div class="ap-stat-ring"><i class="material-icons">event_note</i></div>
                        <div>
                            <div class="ap-stat-val">@totalPeriods</div>
                            <div class="ap-stat-lbl">Total Periods</div>
                        </div>
                    </div>
                    <div class="ap-stat">
                        <div class="ap-stat-ring"><i class="material-icons">check_circle</i></div>
                        <div>
                            <div class="ap-stat-val">@activePeriods</div>
                            <div class="ap-stat-lbl">Active</div>
                        </div>
                    </div>
                    <div class="ap-stat">
                        <div class="ap-stat-ring"><i class="material-icons">people</i></div>
                        <div>
                            <div class="ap-stat-val">@totalApps</div>
                            <div class="ap-stat-lbl">Applications</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ── TempData alerts strip ── -->
    <div class="ap-strip">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="strip-alert strip-success">
                <i class="material-icons">check_circle</i>
                <span>@TempData["SuccessMessage"]</span>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="strip-alert strip-error">
                <i class="material-icons">error</i>
                <span>@TempData["ErrorMessage"]</span>
            </div>
        }
    </div>

    <!-- ── Periods grid ── -->
    <div class="ap-grid">
        @foreach (var period in Model)
        {
            var statusClass = period.Status switch
            {
                SIS.Enums.Status.Active => "sp-active",
                SIS.Enums.Status.Upcoming => "sp-upcoming",
                SIS.Enums.Status.Closed => "sp-closed",
                _ => "sp-inactive"
            };
            var statusIcon = period.Status switch
            {
                SIS.Enums.Status.Active => "check_circle",
                SIS.Enums.Status.Upcoming => "schedule",
                SIS.Enums.Status.Closed => "cancel",
                _ => "remove_circle"
            };
            var appCount = period.Applications?.Count ?? 0;
            var appApproved = period.Applications?.Count(a => a.Status == SIS.Enums.Status.Active) ?? 0;
            var appPending = period.Applications?.Count(a => a.Status == SIS.Enums.Status.Upcoming) ?? 0;

            <div class="period-card" onclick="showViewModal(@period.PeriodId)">

                <!-- top row -->
                <div class="card-top">
                    <div>
                        <h3 class="card-title">@period.Type Period</h3>
                        <div class="card-badges">
                            <span class="sp @statusClass">
                                <i class="material-icons">@statusIcon</i>@period.Status.ToString()
                            </span>
                            @if (!string.IsNullOrEmpty(period.TypeOfPayment))
                            {
                                <span class="sp sp-payment"><i class="material-icons">payments</i>@period.TypeOfPayment</span>
                            }
                        </div>
                    </div>
                    <div class="card-menu-wrap" onclick="event.stopPropagation()">
                        <button class="card-menu-btn" type="button" onclick="toggleDropdown(event,@period.PeriodId)">
                            <i class="material-icons">more_vert</i>
                        </button>
                        <div id="dropdown-@period.PeriodId" class="drop-menu" style="display:none;">
                            <a href="#" onclick="event.preventDefault();event.stopPropagation();showViewModal(@period.PeriodId)">
                                <i class="material-icons">visibility</i>View Details
                            </a>
                            <a href="#" onclick="event.preventDefault();event.stopPropagation();showEditModal(@period.PeriodId)">
                                <i class="material-icons">edit</i>Edit Period
                            </a>
                            <hr>
                            <a href="#" class="dm-del" onclick="event.preventDefault();event.stopPropagation();showDeleteModal(@period.PeriodId,'@period.Type')">
                                <i class="material-icons">delete</i>Delete
                            </a>
                        </div>
                    </div>
                </div>

                <!-- payment cell -->
                @if (!string.IsNullOrEmpty(period.TypeOfPayment))
                {
                    <div class="dc-grid" style="margin-bottom:0;">
                        <div class="dc amber-dc full">
                            <p class="dc-lbl"><i class="material-icons">payments</i>Payment</p>
                            <p class="dc-val">@period.TypeOfPayment — K @period.TypeOfPaymentAmount.ToString("N2")</p>
                        </div>
                    </div>
                }

                <!-- detail cells -->
                <div class="dc-grid">
                    <div class="dc">
                        <p class="dc-lbl"><i class="material-icons">category</i>Type</p>
                        <p class="dc-val">@period.Type</p>
                    </div>
                    <div class="dc">
                        <p class="dc-lbl"><i class="material-icons">schedule</i>Applications</p>
                        <p class="dc-val">@period.ApplicationStartDate.ToString("MMM dd") – @period.ApplicationEndDate.ToString("MMM dd")</p>
                    </div>
                    <div class="dc full">
                        <p class="dc-lbl"><i class="material-icons">date_range</i>Period</p>
                        <p class="dc-val">@period.StartDate.ToString("MMM dd, yyyy") – @(period.IsPermanentUntilGraduation ? "Until Graduation" : period.EndDate?.ToString("MMM dd, yyyy"))</p>
                    </div>
                </div>

                <!-- applications bar -->
                <div class="app-bar">
                    <span class="app-bar-left"><i class="material-icons">people</i>@appCount Application@(appCount != 1 ? "s" : "")</span>
                    @if (appCount > 0)
                    {
                        <span class="app-bar-right">
                            <span class="app-bar-approved">✓ @appApproved</span>
                            <span class="app-bar-pending">⏳ @appPending</span>
                        </span>
                    }
                </div>

                <!-- eligibility tag -->
                @if (period.AppliesUniversally)
                {
                    <div class="elig-tag elig-universal">
                        <i class="material-icons">public</i>
                        <span><strong>Universal</strong> — all students</span>
                    </div>
                }
                else
                {
                    <div class="elig-tag elig-restricted">
                        <i class="material-icons">filter_alt</i>
                        <span><strong>Restricted</strong> — specific criteria</span>
                    </div>
                }

                <!-- action buttons -->
                <div class="card-actions" onclick="event.stopPropagation()">
                    <button type="button" id="selectBtn-@period.PeriodId" class="btn-select"
                            onclick="selectPeriod(event,@period.PeriodId,'@period.Type','@period.TypeOfPayment')">
                        <i class="material-icons">check_circle</i><span>Select</span>
                    </button>
                    <button type="button" class="btn-del-outline"
                            onclick="event.stopPropagation();showDeleteModal(@period.PeriodId,'@period.Type')">
                        <i class="material-icons">delete</i><span>Delete</span>
                    </button>
                </div>

            </div>
        }

        @if (!Model.Any())
        {
            <div class="ap-empty">
                <div class="empty-ring"><i class="material-icons">event_busy</i></div>
                <h4>No Accommodation Periods Found</h4>
                <p>Create your first accommodation period to start managing student applications.</p>
                <button type="button" class="btn-coral" onclick="showCreateModal()">
                    <i class="material-icons">add</i> Create First Period
                </button>
            </div>
        }
    </div>

</div>

<!-- ══ Create / Edit Modal ══ -->
<div id="periodModal" class="modal-overlay hidden">
    <div class="modal-box" style="max-width:900px;">
        <div class="modal-head">
