@model SIS.Models.ViewModels.StudentAdministrationViewModel

@{
    ViewData["Title"] = "Student Administration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-slate-50 p-6">
    @Html.AntiForgeryToken()

    <!-- Header Section -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-6 bg-white rounded-xl shadow-sm p-6">
        <div class="flex items-start lg:items-center space-x-4">
            <!-- Student Photo -->
            <div class="flex-shrink-0 w-16 h-16 rounded-lg bg-gradient-to-r from-red-500 to-orange-600 flex items-center justify-center overflow-hidden border-2 border-white border-opacity-30">
                @if (!string.IsNullOrEmpty(Model.PassportPhotoPath))
                {
                    <img src="/uploads/student-photos/@($"{Model.StudentNumber}.png")"
                         alt="@Model.FullName"
                         class="w-full h-full object-cover"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                    <div class="w-full h-full flex items-center justify-center text-white text-xl font-bold" style="display: none;">
                        @if (!string.IsNullOrEmpty(Model.FullName))
                        {
                            @Model.FullName.Split(' ').Select(n => n.FirstOrDefault()).Take(2).Aggregate("", (a, c) => a + c)
                        }
                        else
                        {
                            <i class="material-icons text-2xl">person</i>
                        }
                    </div>
                }
                else
                {
                    <div class="text-white text-xl font-bold">
                        @if (!string.IsNullOrEmpty(Model.FullName))
                        {
                            @Model.FullName.Split(' ').Select(n => n.FirstOrDefault()).Take(2).Aggregate("", (a, c) => a + c)
                        }
                        else
                        {
                            <i class="material-icons text-2xl">person</i>
                        }
                    </div>
                }
            </div>

            <div>
                <div class="flex items-center space-x-3 mb-2">
                    <h1 class="text-2xl font-bold text-slate-800">@Model.FullName</h1>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
                        <i class="material-icons text-sm mr-1">admin_panel_settings</i>
                        Administration Mode
                    </span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-slate-600">
                    <div class="flex items-center">
                        <i class="material-icons text-sm mr-1">badge</i>
                        <span>@Model.StudentNumber</span>
                    </div>
                    <div class="flex items-center">
                        <i class="material-icons text-sm mr-1">school</i>
                        <span>@Model.ProgrammeName</span>
                    </div>
                    <div class="flex items-center">
                        <i class="material-icons text-sm mr-1">calendar_today</i>
                        <span>Year @Model.CurrentYear • @Model.CurrentPeriodLabel</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 lg:mt-0 flex items-center space-x-3">
            <div class="text-right text-sm">
                <p class="text-slate-600">Administered by</p>
                <p class="font-medium text-slate-800">@Model.AdminName (@Model.UserRole)</p>
            </div>
            <a href="@Url.Action("Index", "StudentLookup")" class="inline-flex items-center px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition-colors">
                <i class="material-icons text-sm mr-1">arrow_back</i>
                Back to Lookup
            </a>
        </div>
    </div>

    <!-- Quick Status Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow-sm p-4">
            <div class="flex items-center">
                <div class="p-2 bg-blue-100 rounded-lg">
                    <i class="material-icons text-blue-600">how_to_reg</i>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-slate-500">Registration Status</p>
                    <p class="text-lg font-bold text-slate-900">@Model.RegistrationStatus</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-4">
            <div class="flex items-center">
                <div class="p-2 bg-green-100 rounded-lg">
                    <i class="material-icons text-green-600">book</i>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-slate-500">Courses Registered</p>
                    <p class="text-lg font-bold text-slate-900">@Model.RegisteredCoursesCount</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-4">
            <div class="flex items-center">
                <div class="p-2 @(Model.OutstandingFees > 0 ? "bg-red-100" : "bg-green-100") rounded-lg">
                    <i class="material-icons @(Model.OutstandingFees > 0 ? "text-red-600" : "text-green-600")">account_balance</i>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-slate-500">Outstanding Fees</p>
                    <p class="text-lg font-bold @(Model.OutstandingFees > 0 ? "text-red-600" : "text-green-600")">
                        K @Model.OutstandingFees.ToString("N2")
                    </p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-4">
            <div class="flex items-center">
                <div class="p-2 bg-purple-100 rounded-lg">
                    <i class="material-icons text-purple-600">person</i>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-slate-500">Student Status</p>
                    <p class="text-lg font-bold text-slate-900">@Model.StudentStatus</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Tabs -->
    <div class="bg-white rounded-xl shadow-sm">
        <!-- Tab Navigation -->
        <div class="border-b border-slate-200">
            <nav class="flex space-x-8 px-6" aria-label="Tabs">
                <button class="admin-tab-button active py-4 px-1 border-b-2 border-red-500 font-medium text-sm text-red-600" data-tab="profile">
                    <i class="material-icons text-sm mr-1">person</i>
                    Profile Management
                </button>
                <button class="admin-tab-button py-4 px-1 border-b-2 border-transparent font-medium text-sm text-slate-500 hover:text-slate-700 hover:border-slate-300" data-tab="academic">
                    <i class="material-icons text-sm mr-1">school</i>
                    Academic Management
                </button>
                <button class="admin-tab-button py-4 px-1 border-b-2 border-transparent font-medium text-sm text-slate-500 hover:text-slate-700 hover:border-slate-300" data-tab="registration">
                    <i class="material-icons text-sm mr-1">how_to_reg</i>
                    Registration Management
                </button>
                <button class="admin-tab-button py-4 px-1 border-b-2 border-transparent font-medium text-sm text-slate-500 hover:text-slate-700 hover:border-slate-300" data-tab="security">
                    <i class="material-icons text-sm mr-1">security</i>
                    Security Management
                </button>
            </nav>
        </div>

        <!-- Tab Content Container -->
        <div id="adminTabContent" class="p-6">
            <!-- Content will be loaded here dynamically -->
            <div class="text-center py-8">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-red-600 mx-auto"></div>
                <p class="text-slate-600 mt-2">Loading...</p>
            </div>
        </div>
    </div>
</div>

<!-- Profile Management Modal -->
<div id="profileModal" class="hidden fixed inset-0 bg-gray-500 bg-opacity-75 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl max-w-4xl w-full mx-4 p-6 max-h-[95vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-semibold text-gray-900">Edit Student Profile</h3>
            <button type="button" onclick="closeModal('profileModal')" class="text-gray-400 hover:text-gray-500">
                <i class="material-icons">close</i>
            </button>
        </div>

        <form id="profileForm" class="space-y-6" enctype="multipart/form-data">
            <input type="hidden" id="studentId" name="StudentId" value="@Model.StudentId" />

            <!-- Photo Upload Section -->
            <div class="border-b border-gray-200 pb-6">
                <h4 class="text-md font-semibold text-secondary-800 mb-4">Student Photo</h4>
                <div class="flex items-start space-x-6">
                    <div class="w-24 h-24 rounded-lg bg-gray-200 flex items-center justify-center overflow-hidden border-2 border-gray-300">
                        <img id="photoPreview" src="" alt="Student Photo" class="w-full h-full object-cover hidden">
                        <div id="photoPlaceholder" class="text-gray-400">
                            <i class="material-icons text-3xl">person</i>
                        </div>
                    </div>
                    <div class="flex-1">
                        <label for="passportPhoto" class="block text-sm font-medium text-gray-700 mb-2">Upload New Photo</label>
                        <input type="file" id="passportPhoto" name="PassportPhoto" accept="image/*"
                               class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
                               onchange="previewPhoto(this)">
                        <p class="text-xs text-gray-500 mt-1">JPG, PNG, or GIF. Max file size 5MB.</p>
                        <button type="button" onclick="removePhoto()" class="mt-2 text-sm text-red-600 hover:text-red-700">
                            Remove Current Photo
                        </button>
                    </div>
                </div>
            </div>

            <!-- Personal Information Section -->
            <div>
                <h4 class="text-md font-semibold text-secondary-800 mb-4">Personal Information</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="fullName" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                        <input type="text" id="fullName" name="FullName" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500" />
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                        <input type="email" id="email" name="Email" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500" />
                    </div>

                    <div>
                        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                        <input type="tel" id="phone" name="Phone" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500" />
                    </div>

                    <div>
                        <label for="nrcOrPassport" class="block text-sm font-medium text-gray-700 mb-1">NRC/Passport Number</label>
                        <input type="text" id="nrcOrPassport" name="NrcOrPassportNumber" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500" />
                    </div>

                    <div>
                        <label for="dateOfBirth" class="block text-sm font-medium text-gray-700 mb-1">Date of Birth</label>
                        <input type="date" id="dateOfBirth" name="DateOfBirth" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500" />
                    </div>

                    <div>
                        <label for="gender" class="block text-sm font-medium text-gray-700 mb-1">Gender</label>
                        <select id="gender" name="Gender" required
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
