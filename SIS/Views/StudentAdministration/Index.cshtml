               mandatoryCourses.filter(c => !c.isCarryover).forEach(course => {
                   html += createCourseCheckbox(course, false);
               });
               html += '</div></div>';
           }

           // Elective courses
           if (electiveCourses.length > 0) {
               html += `
                   <div class="border-l-4 border-blue-500 pl-4">
                       <h5 class="font-medium text-blue-800 mb-2">Elective Courses (${electiveCourses.length})</h5>
                       <div class="space-y-2">
               `;
               electiveCourses.forEach(course => {
                   html += createCourseCheckbox(course, false);
               });
               html += '</div></div>';
           }

           html += '</div>';
