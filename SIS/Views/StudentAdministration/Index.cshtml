        // Load dropdown options
        async function loadDropdownOptions() {
            try {
                const [schools, modes, levels, years, periods] = await Promise.all([
                    fetch('/StudentAdministration/GetSchools').then(r => r.json()),
                    fetch('/StudentAdministration/GetAllModes').then(r => r.json()),
                    fetch('/StudentAdministration/GetProgrammeLevels').then(r => r.json()),
                    fetch('/StudentAdministration/GetAcademicYears').then(r => r.json()),
                    fetch('/StudentAdministration/GetYearPeriods').then(r => r.json())
                ]);

                // if (programmes.success) {
                //     const programmeSelect = document.getElementById('programmeSelect');
                //     programmeSelect.innerHTML = '<option value="">Select Programme</option>';
                //     programmes.data.forEach(p => {
                //         programmeSelect.innerHTML += `<option value="${p.id}">${p.name}</option>`;
                //     });
                // }

                if (schools.success) {
                    const schoolSelect = document.getElementById('schoolSelect');
                    schoolSelect.innerHTML = '<option value="">Select School</option>';
                    schools.data.forEach(s => {
                        schoolSelect.innerHTML += `<option value="${s.id}">${s.name}</option>`;
                    });
                }

                if (levels.success) {
                    const levelSelect = document.getElementById('levelSelect');
                    levelSelect.innerHTML = '<option value="">Select Level</option>';
                    levels.data.forEach(l => {
                        levelSelect.innerHTML += `<option value="${l.id}">${l.name}</option>`;
                    });
                }

                if (modes.success) {
                    const modeSelect = document.getElementById('modeSelect');
                    modeSelect.innerHTML = '<option value="">Select Mode</option>';
                    modes.data.forEach(m => {
                        modeSelect.innerHTML += `<option value="${m.id}">${m.name}</option>`;
                    });
                }

                if (years.success) {
                    const yearSelect = document.getElementById('academicYearSelect');
                    yearSelect.innerHTML = '<option value="">Select Academic Year</option>';
                    years.data.forEach(y => {
                        yearSelect.innerHTML += `<option value="${y.id}">${y.name}</option>`;
                    });
                }

                if (periods.success) {
                    const periodSelect = document.getElementById('currentPeriodId');
                    periodSelect.innerHTML = '<option value="">Select Academic Period</option>';
                    periods.data.forEach(p => {
                        periodSelect.innerHTML += `<option value="${p.id}">${p.name}</option>`;
                    });
                }

                // Add school change handler for programmes
                document.getElementById('schoolSelect').addEventListener('change', async function() {
                    const schoolId = this.value;
                    const programmeSelect = document.getElementById('programmeSelect');

                    programmeSelect.innerHTML = '<option value="">Select Programme</option>';

                    if (schoolId) {
                        const response = await fetch(`/StudentAdministration/GetProgrammesBySchool?schoolId=${schoolId}`);
                        const result = await response.json();

                        if (result.success && result.data.length > 0) {
                            result.data.forEach(p => {
                                const option = document.createElement('option');
                                option.value = p.id;
                                option.textContent = p.name;

                                if (p.id === currentStudentData.programmeId) {
                                    option.selected = true;
                                }

                                programmeSelect.appendChild(option);
                            });
                        }
                    }
                });

                schoolSelect.value = currentStudentData.schoolId;
                schoolSelect.dispatchEvent(new Event('change'));

            } catch (error) {
                console.error('Error loading dropdown options:', error);
                showToast('Error loading form options', 'error');
            }
        }

        // Registration toggle
        function toggleRegistration(enable) {
            const action = enable ? 'enable' : 'disable';
            const title = enable ? 'Enable Registration' : 'Disable Registration';
            const message = enable ?
                'Are you sure you want to enable registration for this student?' :
                'Are you sure you want to disable registration? This will remove all current course registrations and invoices.';

            showConfirmModal(title, message, 'warning', () => {
                performRegistrationToggle(enable);
            });
        }

        async function performRegistrationToggle(enable) {
            try {
                const reason = `Registration ${enable ? 'enabled' : 'disabled'} by admin`;
                const response = await fetch('/StudentAdministration/ToggleRegistration', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        StudentId: @Model.StudentId,
                        EnableRegistration: enable,
                        Reason: reason
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showToast(result.message, 'success');
                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    showToast(result.message || 'Operation failed', 'error');
                }
            } catch (error) {
                console.error('Error toggling registration:', error);
                showToast('An error occurred', 'error');
            }
        }

        // Password reset
        async function resetStudentPassword() {
            const btn = document.getElementById('resetPasswordBtn');
            const icon = document.getElementById('resetPasswordIcon');
            const text = document.getElementById('resetPasswordText');

            try {
                // Show loading state
                btn.disabled = true;
                icon.classList.add('animate-spin');
                text.textContent = 'Generating...';

                const response = await fetch(`/StudentAdministration/ResetPassword?studentId=@Model.StudentId`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();

                if (result.success) {
                    // Hide reset form and show result
                    document.getElementById('passwordResetContent').classList.add('hidden');
                    document.getElementById('passwordResult').classList.remove('hidden');

                    // Set the temporary password
                    document.getElementById('tempPassword').value = result.temporaryPassword;

                    // Start countdown timer
                    startPasswordTimer();

                    showToast('Password reset successfully', 'success');
                } else {
                    showToast(result.message || 'Password reset failed', 'error');
                }
            } catch (error) {
                console.error('Error resetting password:', error);
                showToast('An error occurred while resetting password', 'error');
            } finally {
                // Reset button state
                btn.disabled = false;
                icon.classList.remove('animate-spin');
                text.textContent = 'Generate New Password';
            }
        }

        function startPasswordTimer() {
            let seconds = 60;
            const countdownElement = document.getElementById('countdown');
            const timerElement = document.getElementById('passwordTimer');

            countdownTimer = setInterval(() => {
                seconds--;
                countdownElement.textContent = seconds;

                if (seconds <= 0) {
                    clearInterval(countdownTimer);
                    document.getElementById('tempPassword').value = '••••••••';
                    timerElement.innerHTML = '<span class="text-red-600">Password hidden for security</span>';
                }
            }, 1000);
        }

        function copyPassword() {
            const passwordField = document.getElementById('tempPassword');
            passwordField.select();
            document.execCommand('copy');
            showToast('Password copied to clipboard', 'success');
        }

