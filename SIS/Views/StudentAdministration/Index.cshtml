                if (result.success) {
                    showToast('Academic details updated successfully', 'success');
                    closeModal('academicModal');
                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    showToast(result.message || 'Update failed', 'error');
                }
            } catch (error) {
                console.error('Error updating academic details:', error);
                showToast('An error occurred while updating academic details', 'error');
