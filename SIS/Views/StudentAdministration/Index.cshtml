        // Create course checkbox HTML
        function createCourseCheckbox(course, isDisabled = false) {
           const isChecked = selectedCourseIds.has(course.id) || course.isSelected;
           const disabledAttr = isDisabled ? 'disabled' : '';
           const disabledClass = isDisabled ? 'opacity-60 cursor-not-allowed' : '';

           return `
               <div class="flex items-start space-x-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 ${disabledClass}">
                   <input type="checkbox"
                          id="course_${course.id}"
                          value="${course.id}"
                          ${isChecked ? 'checked' : ''}
                          ${disabledAttr}
                          onchange="toggleCourseSelection(${course.id})"
                          class="mt-1 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                   <div class="flex-1 min-w-0">
                       <label for="course_${course.id}" class="flex items-start justify-between cursor-pointer">
                           <div class="flex-1">
                               <div class="flex items-center space-x-2 mb-1">
                                   <span class="font-medium text-gray-900">${course.courseCode}</span>
                                   ${course.isCarryover ? '<span class="px-2 py-1 text-xs bg-red-100 text-red-800 rounded-full">Carryover</span>' : ''}
                                   ${course.isMandatory ? '<span class="px-2 py-1 text-xs bg-orange-100 text-orange-800 rounded-full">Mandatory</span>' : ''}
                                   ${course.isExaminable ? '<span class="px-2 py-1 text-xs bg-green-100 text-green-800 rounded-full">Examinable</span>' : ''}
                               </div>
                               <p class="text-sm font-medium text-secondary-800">${course.courseName}</p>
                               <p class="text-xs text-secondary-600 mt-1">${course.courseDescription}</p>
                               ${course.carryoverReason ? `<p class="text-xs text-red-600 mt-1"><em>Reason: ${course.carryoverReason}</em></p>` : ''}
                           </div>
                           <div class="text-right text-xs text-gray-500 ml-4">
                               <div>Year ${course.yearTaken}</div>
                               ${studentRegistrationInfo.isSemesterBased ? `<div>Sem ${course.semesterTaken}</div>` : ''}
                           </div>
                       </label>
                   </div>
               </div>
           `;
        }

        // Track photo validation state globally
        let hasPhotoWarnings = false;

        function previewPhoto(input) {
            const file = input.files[0];
            const photoPreview = document.getElementById('photoPreview');
            const photoPlaceholder = document.getElementById('photoPlaceholder');

            if (file) {
                // Basic validation first
                const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png'];
                if (!allowedTypes.includes(file.type)) {
                    showToast('Please select a valid image file (JPG or PNG)', 'error');
                    input.value = '';
                    return;
                }

                if (file.size > 5 * 1024 * 1024) {
                    showToast('File size must be less than 5MB', 'error');
                    input.value = '';
                    return;
                }

                // Show preview immediately
                const reader = new FileReader();
                reader.onload = function(e) {
                    photoPreview.src = e.target.result;
                    photoPreview.classList.remove('hidden');
                    photoPlaceholder.classList.add('hidden');
                };
                reader.readAsDataURL(file);

                // Validate photo with server
                validatePhotoServerSide(file);
            } else {
                photoPreview.classList.add('hidden');
                photoPlaceholder.classList.remove('hidden');
                clearPhotoValidationState();
            }
        }

        // Add server-side photo validation
        async function validatePhotoServerSide(file) {
            const validationDiv = getOrCreateValidationDiv();

            // Show loading state
            validationDiv.innerHTML = `
                <div class="flex items-center text-blue-600 text-sm mt-2">
                    <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-blue-600 mr-2"></div>
                    Validating photo...
                </div>
            `;

            try {
                const formData = new FormData();
                formData.append('passportPhoto', file);

                const response = await fetch('/StudentAdministration/ValidatePassportPhoto', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();
                displayValidationResult(result, validationDiv);
            } catch (error) {
                console.error('Photo validation error:', error);
                hasPhotoWarnings = true;
                validationDiv.innerHTML = `
                    <div class="text-red-600 text-sm mt-2 p-2 bg-red-50 border border-red-200 rounded">
                        Unable to validate photo. Please try again.
                    </div>
                `;
                updateSubmitButtonState();
            }
        }

        function getOrCreateValidationDiv() {
            let validationDiv = document.getElementById('photo-validation-feedback');
            if (!validationDiv) {
                validationDiv = document.createElement('div');
                validationDiv.id = 'photo-validation-feedback';

                // Insert after the photo preview section
                const photoSection = document.querySelector('#photoPreview').parentElement.parentElement;
                photoSection.appendChild(validationDiv);
            }
            return validationDiv;
        }

        function displayValidationResult(result, validationDiv) {
            validationDiv.innerHTML = '';

            if (result.success) {
                hasPhotoWarnings = result.warnings && result.warnings.length > 0;

                if (hasPhotoWarnings) {
                    validationDiv.innerHTML = `
                        <div class="mt-2 p-3 bg-amber-50 border border-amber-200 rounded">
                            <div class="text-amber-800 text-sm font-medium flex items-center mb-2">
                                <i class="material-icons text-sm mr-1">warning</i>
                                Photo uploaded with recommendations
                            </div>
                            ${result.warnings.map(warning =>
                                `<div class="text-amber-700 text-xs mt-1">• ${warning}</div>`
                            ).join('')}
                            <div class="text-amber-700 text-xs mt-2 font-medium">
                                Consider uploading a better quality photo for best results.
                            </div>
                        </div>
                    `;
                    showToast('Photo uploaded with recommendations', 'warning');
                } else {
                    validationDiv.innerHTML = `
                        <div class="text-green-600 text-sm flex items-center mt-2">
                            <i class="material-icons text-sm mr-1">check_circle</i>
                            ${result.message}
                        </div>
                    `;
                }
            } else {
                hasPhotoWarnings = true;
                const errorsHtml = result.errors.map(error =>
                    `<div class="text-red-600 text-sm flex items-center mt-1">
                        <i class="material-icons text-sm mr-1">error</i>
                        ${error}
                    </div>`
                ).join('');

                validationDiv.innerHTML = `
                    <div class="mt-2 p-3 bg-red-50 border border-red-200 rounded">
                        <div class="text-red-800 text-sm font-medium mb-1">Photo validation failed:</div>
                        ${errorsHtml}
                    </div>
                `;
                showToast('Photo validation failed - please upload a different photo', 'error');
            }

            updateSubmitButtonState();
        }

        function clearPhotoValidationState() {
            hasPhotoWarnings = false;
            const validationDiv = document.getElementById('photo-validation-feedback');
            if (validationDiv) {
                validationDiv.innerHTML = '';
            }
            updateSubmitButtonState();
        }

        function updateSubmitButtonState() {
            const submitButton = document.querySelector('#profileForm button[type="submit"]');
            if (!submitButton) return;

            if (hasPhotoWarnings) {
                submitButton.disabled = true;
                submitButton.classList.add('opacity-50');
                submitButton.innerHTML = `
                    <span class="flex items-center">
                        <i class="material-icons text-sm mr-1">warning</i>
                        Photo Issues - Fix to Continue
                    </span>
                `;
            } else {
                submitButton.disabled = false;
                submitButton.classList.remove('opacity-50');
                submitButton.innerHTML = `
                    <span class="flex items-center">
                        <i class="material-icons text-sm mr-1 hidden" id="profileLoader">refresh</i>
                        Update Profile
                    </span>
                `;
            }
        }

        function removePhoto() {
            const photoInput = document.getElementById('passportPhoto');
            const photoPreview = document.getElementById('photoPreview');
            const photoPlaceholder = document.getElementById('photoPlaceholder');

            photoInput.value = '';
            photoPreview.src = '';
            photoPreview.classList.add('hidden');
            photoPlaceholder.classList.remove('hidden');
            clearPhotoValidationState();
        }

        // Toggle course selection
        function toggleCourseSelection(courseId) {
           const checkbox = document.getElementById(`course_${courseId}`);

           if (checkbox.checked) {
               selectedCourseIds.add(courseId);
           } else {
               selectedCourseIds.delete(courseId);
           }

           updateRegistrationSummary();
        }

        // Search for additional courses
        let searchTimeout;
        async function searchCourses() {
           const searchInput = document.getElementById('courseSearchInput');
           const searchTerm = searchInput.value.trim();
           const StudentId = @Model.StudentId;

           if (searchTerm.length < 2) {
               document.getElementById('courseSearchResults').innerHTML = `
                   <div class="text-center py-4 text-gray-500 text-sm">
                       Enter at least 2 characters to search
                   </div>
               `;
               return;
           }

           // Clear existing timeout
           if (searchTimeout) {
               clearTimeout(searchTimeout);
           }

           // Set loading state
           document.getElementById('courseSearchResults').innerHTML = `
               <div class="text-center py-4">
                   <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-blue-600 mx-auto"></div>
                   <p class="text-secondary-600 text-sm mt-2">Searching...</p>
               </div>
           `;

           // Debounce search
           searchTimeout = setTimeout(async () => {
               try {
                        const formData = new FormData();
                        formData.append('studentId', @Model.StudentId);
                        formData.append('searchTerm', searchTerm);

                        console.log(formData);

                        const response = await fetch('/StudentAdministration/SearchCoursesToAdd', {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: formData
                        });

                   const result = await response.json();
                   displaySearchResults(result);
               } catch (error) {
                   console.error('Error searching courses:', error);
                   document.getElementById('courseSearchResults').innerHTML = `
                       <div class="text-center py-4 text-red-500 text-sm">
                           Error searching courses
                       </div>
                   `;
               }
           }, 300);
        }

        // Display search results
        function displaySearchResults(result) {
            const container = document.getElementById('courseSearchResults');

            if (!result.success) {
                container.innerHTML = `
                    <div class="text-center py-4 text-red-500 text-sm">
                        ${result.message || 'Search failed'}
                    </div>
                `;
                return;
            }

            if (result.data.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-4 text-gray-500 text-sm">
                        No courses found matching your search
                    </div>
                `;
                return;
            }

            let html = '<div class="space-y-2">';
            result.data.forEach(course => {
                const isAlreadySelected = selectedCourseIds.has(course.id);
                const isInAvailable = availableCourses.some(c => c.id === course.id);

                // Determine if this is from student's programme
                const isFromStudentProgramme = course.isFromStudentProgramme || false;
                const programmeInfo = course.programmeName || 'Unknown Programme';
                const schoolInfo = course.schoolName || '';

                html += `
                    <div class="border border-gray-200 rounded-lg p-3 ${isFromStudentProgramme ? 'bg-blue-50 border-blue-200' : ''}">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <div class="flex items-center space-x-2 mb-1">
                                    <span class="font-medium text-gray-900">${course.courseCode}</span>
                                    ${course.isMandatory ? '<span class="px-2 py-1 text-xs bg-orange-100 text-orange-800 rounded-full">Mandatory</span>' : ''}
                                    ${course.isExaminable ? '<span class="px-2 py-1 text-xs bg-green-100 text-green-800 rounded-full">Examinable</span>' : ''}
                                    ${isFromStudentProgramme ? '<span class="px-2 py-1 text-xs bg-blue-100 text-blue-800 rounded-full">Student\'s Programme</span>' : ''}
                                </div>
                                <p class="text-sm font-medium text-secondary-800">${course.courseName}</p>
                                <p class="text-xs text-secondary-600">${course.courseDescription}</p>
                                <div class="flex items-center justify-between mt-1">
                                    <p class="text-xs text-gray-500">Year ${course.yearTaken} • Semester ${course.semesterTaken}</p>
                                    <p class="text-xs text-gray-500">${programmeInfo}${schoolInfo ? ` (${schoolInfo})` : ''}</p>
                                </div>
                            </div>
                            <div class="ml-4">
                                ${isInAvailable ?
                                    '<span class="text-xs text-blue-600">Available</span>' :
                                    isAlreadySelected ?
                                        `<button onclick="removeCourseFromSelection(${course.id})"
                                                class="px-3 py-1 bg-red-100 text-red-700 text-xs rounded hover:bg-red-200">
                                            Remove
                                        </button>` :
                                        `<button onclick="addCourseToSelection(${course.id}, '${course.courseCode}', '${course.courseName}', '${course.courseDescription}', ${course.isMandatory}, ${course.isExaminable}, ${course.yearTaken}, ${course.semesterTaken})"
                                                class="px-3 py-1 bg-blue-600 text-white text-xs rounded hover:bg-blue-700">
                                            Add
                                        </button>`
                                }
                            </div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';

            container.innerHTML = html;
        }

        // Add course to selection
        function addCourseToSelection(id, courseCode, courseName, courseDescription, isMandatory, isExaminable, yearTaken, semesterTaken) {
           // Add to available courses array
           const newCourse = {
               id: id,
               courseCode: courseCode,
               courseName: courseName,
               courseDescription: courseDescription + ' (Added by Admin)',
               isMandatory: isMandatory,
               isExaminable: isExaminable,
               isSelected: true,
               isCarryover: false,
               yearTaken: yearTaken,
               semesterTaken: semesterTaken
           };

           availableCourses.push(newCourse);
           selectedCourseIds.add(id);

           // Refresh displays
           displayAvailableCourses();
           updateRegistrationSummary();

           // Clear search and show success
           document.getElementById('courseSearchInput').value = '';
           document.getElementById('courseSearchResults').innerHTML = `
               <div class="text-center py-4 text-green-600 text-sm">
                   <i class="material-icons text-lg mb-1">check_circle</i>
                   <p>Course added successfully</p>
               </div>
           `;

           showToast(`${courseCode} added to selection`, 'success');
        }

        // Remove course from selection
        function removeCourseFromSelection(courseId) {
           // Remove from available courses if it was added via search
           availableCourses = availableCourses.filter(c =>
               !(c.id === courseId && c.courseDescription.includes('Added by Admin'))
           );

           selectedCourseIds.delete(courseId);

           // Uncheck checkbox if it exists
           const checkbox = document.getElementById(`course_${courseId}`);
           if (checkbox) {
               checkbox.checked = false;
           }

           // Refresh displays
           displayAvailableCourses();
           updateRegistrationSummary();

           showToast('Course removed from selection', 'info');
        }

        // Update registration summary
        function updateRegistrationSummary() {
           const selectedCourses = availableCourses.filter(c => selectedCourseIds.has(c.id));
           const mandatoryCount = selectedCourses.filter(c => c.isMandatory).length;
           const electiveCount = selectedCourses.filter(c => !c.isMandatory).length;
           const carryoverCount = selectedCourses.filter(c => c.isCarryover).length;
           const totalCount = selectedCourses.length;

           const summaryDiv = document.getElementById('registrationSummary');

           let validationMessages = [];
           let isValid = true;

           // Check requirements if they exist
           if (courseRequirements.totalRequired > 0) {
               if (totalCount > courseRequirements.totalRequired) {
                   validationMessages.push(`⚠️ Too many courses selected (${totalCount}/${courseRequirements.totalRequired})`);
                   isValid = false;
               }

               const regularElectives = electiveCount - carryoverCount;
               if (regularElectives < courseRequirements.minimumElectives) {
                   validationMessages.push(`⚠️ Need ${courseRequirements.minimumElectives - regularElectives} more elective(s)`);
                   isValid = false;
               }
           }

           summaryDiv.innerHTML = `
               <div class="space-y-2">
                   <div><strong>Total Selected:</strong> ${totalCount} course${totalCount !== 1 ? 's' : ''}</div>
                   <div class="text-sm text-secondary-600">
                       • Mandatory: ${mandatoryCount} (includes ${carryoverCount} carryover${carryoverCount !== 1 ? 's' : ''})<br>
                       • Electives: ${electiveCount}
                   </div>
                   ${validationMessages.length > 0 ? `
                       <div class="mt-2 p-2 bg-yellow-50 border border-yellow-200 rounded text-sm">
                           ${validationMessages.join('<br>')}
                       </div>
                   ` : isValid ? `
                       <div class="mt-2 p-2 bg-green-50 border border-green-200 rounded text-sm text-green-800">
                           ✅ Selection looks good!
                       </div>
                   ` : ''}
               </div>
           `;

           // Update register button state
           const registerBtn = document.getElementById('registerStudentBtn');
           if (totalCount === 0) {
               registerBtn.disabled = true;
               registerBtn.classList.add('opacity-50', 'cursor-not-allowed');
           } else {
               registerBtn.disabled = false;
               registerBtn.classList.remove('opacity-50', 'cursor-not-allowed');
           }
        }

        // Reset course selection
        function resetCourseSelection() {
           selectedCourseIds.clear();

           // Reset to original selection (mandatory and carryover courses)
           availableCourses.forEach(course => {
               if (course.isMandatory || course.isCarryover) {
                   selectedCourseIds.add(course.id);
               }
           });

           // Remove courses added by admin
           availableCourses = availableCourses.filter(c =>
               !c.courseDescription.includes('Added by Admin')
           );

           // Refresh displays
           displayAvailableCourses();
           updateRegistrationSummary();

           // Clear search
           document.getElementById('courseSearchInput').value = '';
           document.getElementById('courseSearchResults').innerHTML = `
               <div class="text-center py-4 text-gray-500 text-sm">
                   Enter search terms to find additional courses
               </div>
           `;
        }

        // Execute student registration
        async function executeStudentRegistration() {
           const reason = 'Course registration executed by admin';

           const selectedCoursesList = Array.from(selectedCourseIds);

           if (selectedCoursesList.length === 0) {
               showToast('Please select at least one course', 'warning');
               return;
           }

           const registerBtn = document.getElementById('registerStudentBtn');
           const loader = document.getElementById('registrationLoader');

           try {
               registerBtn.disabled = true;
               loader.classList.remove('hidden');
               loader.classList.add('animate-spin');

               const response = await fetch('/StudentAdministration/ExecuteStudentRegistration', {
                   method: 'POST',
                   headers: {
                       'Content-Type': 'application/json',
                       'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                   },
                   body: JSON.stringify({
                       StudentId: @Model.StudentId,
                       SelectedCourseIds: selectedCoursesList,
                       Reason: reason.trim()
                   })
               });

               const result = await response.json();

               if (result.success) {
                   showToast(result.message, 'success');
                   closeModal('registrationModal');
                   // Refresh the page to show updated registration status
                   setTimeout(() => {
                       window.location.reload();
                   }, 2000);
               } else {
                   showToast(result.message || 'Registration failed', 'error');
               }
           } catch (error) {
               console.error('Error executing registration:', error);
               showToast('An error occurred during registration', 'error');
           } finally {
               registerBtn.disabled = false;
               loader.classList.add('hidden');
               loader.classList.remove('animate-spin');
           }
        }

        // Add event listener for course search input
        document.addEventListener('DOMContentLoaded', function() {
           // Add the existing DOMContentLoaded content here, then add:

           // Course search input event listener
           document.addEventListener('keyup', function(e) {
               if (e.target && e.target.id === 'courseSearchInput') {
                   if (e.key === 'Enter') {
                       searchCourses();
                   }
               }
           });
        });







        // Close modals when clicking outside
        window.addEventListener('click', function(e) {
            const modals = ['profileModal', 'academicModal', 'passwordModal', 'confirmModal', 'registrationModal'];
            modals.forEach(modalId => {
                const modal = document.getElementById(modalId);
                if (e.target === modal) {
                    closeModal(modalId);
                }
            });
        });

        // Close modals with Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                const modals = ['profileModal', 'academicModal', 'passwordModal', 'confirmModal', 'registrationModal'];
                modals.forEach(modalId => {
                    closeModal(modalId);
                });
            }
        });

        console.log('Student Administration');
    </script>
}
