        // Registration Management Variables
        let availableCourses = [];
        let selectedCourseIds = new Set();
        let courseRequirements = {};
        let studentRegistrationInfo = {};

        // Open Registration Modal
        async function openRegistrationModal() {
            document.getElementById('registrationModal').classList.remove('hidden');
            await loadStudentRegistrationData();
        }

        // Load student registration data
        async function loadStudentRegistrationData() {
            try {
                const response = await fetch(`/StudentAdministration/GetStudentAvailableCourses?studentId=@Model.StudentId`);
                const result = await response.json();

                if (result.success) {
                    availableCourses = result.data.courses;
                    courseRequirements = result.data.requirements;
                    studentRegistrationInfo = result.data.studentInfo;

                    // Update info panel
                    updateRegistrationInfo(result.data);

                    // Display courses
                    displayAvailableCourses();

                    // Initialize selected courses
                    selectedCourseIds.clear();
                    availableCourses.filter(c => c.isSelected).forEach(c => selectedCourseIds.add(c.id));

                    // Update summary
                    updateRegistrationSummary();
                } else {
                    showToast(result.message || 'Error loading student data', 'error');
                }
            } catch (error) {
                console.error('Error loading registration data:', error);
                showToast('Error loading registration data', 'error');
            }
        }



