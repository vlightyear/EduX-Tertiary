        // Display available courses
        function displayAvailableCourses() {
           const container = document.getElementById('availableCourses');

           if (availableCourses.length === 0) {
               container.innerHTML = `
                   <div class="text-center py-8 text-gray-500">
                       <i class="material-icons text-4xl mb-2">school</i>
                       <p>No courses available for this student</p>
                   </div>
               `;
               return;
           }

           const mandatoryCourses = availableCourses.filter(c => c.isMandatory);
           const electiveCourses = availableCourses.filter(c => !c.isMandatory);
           const carryoverCourses = availableCourses.filter(c => c.isCarryover);

           let html = '<div class="space-y-4">';

           // Carryover courses
           if (carryoverCourses.length > 0) {
               html += `
                   <div class="border-l-4 border-red-500 pl-4">
                       <h5 class="font-medium text-red-800 mb-2">Carryover Courses (${carryoverCourses.length})</h5>
                       <div class="space-y-2">
               `;
               carryoverCourses.forEach(course => {
                   html += createCourseCheckbox(course, true); // Carryovers are mandatory
               });
               html += '</div></div>';
           }

           // Mandatory courses
           if (mandatoryCourses.filter(c => !c.isCarryover).length > 0) {
               html += `
                   <div class="border-l-4 border-orange-500 pl-4">
                       <h5 class="font-medium text-orange-800 mb-2">Mandatory Courses (${mandatoryCourses.filter(c => !c.isCarryover).length})</h5>
                       <div class="space-y-2">
