            // Tab click handlers
            document.addEventListener('click', function(e) {
                if (e.target.classList.contains('admin-tab-button') || e.target.closest('.admin-tab-button')) {
                    const tabButton = e.target.classList.contains('admin-tab-button') ? e.target : e.target.closest('.admin-tab-button');
                    const tabName = tabButton.dataset.tab;
                    loadAdminTab(tabName);
                }
            });
        }

        async function submitProfileForm() {
            const loader = document.getElementById('profileLoader');
            const submitBtn = document.querySelector('#profileForm button[type="submit"]');

            // Check for photo warnings before submitting
            if (hasPhotoWarnings) {
                showToast('Please resolve photo validation issues before submitting', 'error');
                return;
            }

            try {
                loader.classList.remove('hidden');
                loader.classList.add('animate-spin');
                submitBtn.disabled = true;

                const formData = new FormData(document.getElementById('profileForm'));

                const response = await fetch('/StudentAdministration/UpdateStudentProfile', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const contentType = response.headers.get('content-type');
                if (!contentType || !contentType.includes('application/json')) {
                    const text = await response.text();
                    throw new Error(`Expected JSON response, got: ${text}`);
                }

                const result = await response.json();

                if (result.success) {
                    showToast('Profile updated successfully', 'success');
                    closeModal('profileModal');
                    await loadStudentDetails();
                    loadAdminTab('profile');
                    // Reload page to show updated photo in header
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                } else {
                    showToast(result.message || 'Update failed', 'error');
                }
            } catch (error) {
                console.error('Error updating profile:', error);
                showToast('An error occurred while updating profile', 'error');
            } finally {
                loader.classList.add('hidden');
                loader.classList.remove('animate-spin');
                submitBtn.disabled = false;
            }
        }


        async function submitAcademicForm() {
            const loader = document.getElementById('academicLoader');
            const submitBtn = document.querySelector('#academicForm button[type="submit"]');

            try {
                loader.classList.remove('hidden');
                loader.classList.add('animate-spin');
                submitBtn.disabled = true;

                const formData = new FormData(document.getElementById('academicForm'));
                const data = Object.fromEntries(formData.entries());

                const response = await fetch('/StudentAdministration/ChangeProgramme', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(data)
                });

