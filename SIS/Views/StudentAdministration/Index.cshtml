@section Scripts {
    <script>
        let currentStudentData = {};
        let countdownTimer = null;

        document.addEventListener('DOMContentLoaded', function() {
            loadStudentDetails().then(() => {
                loadAdminTab('profile');
            });
            initializeFormHandlers();
        });

        // Load student details
        async function loadStudentDetails() {
            try {
                const response = await fetch(`/StudentAdministration/GetStudentDetails?studentId=@Model.StudentId`);
                const result = await response.json();

                if (result.success) {
                    currentStudentData = result.data;
                    return true; // Return success
                } else {
                    showToast(result.message || 'Error loading student details', 'error');
                    return false;
                }
            } catch (error) {
                console.error('Error loading student details:', error);
                showToast('Error loading student details', 'error');
                return false;
            }
        }

        // Tab management
        function loadAdminTab(tabName) {
            // Update tab buttons
            document.querySelectorAll('.admin-tab-button').forEach(button => {
                button.classList.remove('active', 'border-red-500', 'text-red-600');
                button.classList.add('border-transparent', 'text-slate-500');
            });

            const activeTab = document.querySelector(`[data-tab="${tabName}"]`);
            if (activeTab) {
                activeTab.classList.add('active', 'border-red-500', 'text-red-600');
                activeTab.classList.remove('border-transparent', 'text-slate-500');
            }

            // Load tab content
            const tabContent = document.getElementById('adminTabContent');

            switch(tabName) {
                case 'profile':
                    loadProfileTab(tabContent);
                    break;
                case 'academic':
                    loadAcademicTab(tabContent);
                    break;
                case 'registration':
                    loadRegistrationTab(tabContent);
                    break;
                case 'security':
                    loadSecurityTab(tabContent);
                    break;
            }
        }

        function loadProfileTab(container) {
            container.innerHTML = `
                <div class="space-y-6">
                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-semibold text-slate-800">Student Profile Management</h3>
                        <button onclick="openProfileModal()"
                                class="inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                            <i class="material-icons text-sm mr-1">edit</i>
                            Edit Profile
                        </button>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
                            <p class="text-slate-900 font-medium">${currentStudentData.fullName || 'N/A'}</p>
                        </div>
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
                            <p class="text-slate-900">${currentStudentData.email || 'N/A'}</p>
                        </div>
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
                            <p class="text-slate-900">${currentStudentData.phone || 'N/A'}</p>
                        </div>
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">NRC/Passport Number</label>
                            <p class="text-slate-900">${currentStudentData.nrcOrPassportNumber || 'N/A'}</p>
                        </div>
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">Date of Birth</label>
                            <p class="text-slate-900">${currentStudentData.dateOfBirth ? new Date(currentStudentData.dateOfBirth).toLocaleDateString() : 'N/A'}</p>
                        </div>
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">Gender</label>
                            <p class="text-slate-900">${currentStudentData.gender || 'N/A'}</p>
                        </div>
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">Nationality</label>
                            <p class="text-slate-900">${currentStudentData.nationality || 'N/A'}</p>
                        </div>
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">Marital Status</label>
                            <p class="text-slate-900">${currentStudentData.maritalStatus || 'N/A'}</p>
                        </div>
                        <div class="bg-slate-50 rounded-lg p-4">
                            <label class="block text-sm font-medium text-slate-700 mb-1">Religion</label>
                            <p class="text-slate-900">${currentStudentData.religion || 'N/A'}</p>
                        </div>
                    </div>

                    ${currentStudentData.address ? `
                    <div class="border-t pt-6">
                        <h4 class="text-md font-semibold text-slate-800 mb-4">Address Information</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            <div class="bg-slate-50 rounded-lg p-4">
                                <label class="block text-sm font-medium text-slate-700 mb-1">Address Line 1</label>
                                <p class="text-slate-900">${currentStudentData.address.addressLine1 || 'N/A'}</p>
                            </div>
                            <div class="bg-slate-50 rounded-lg p-4">
                                <label class="block text-sm font-medium text-slate-700 mb-1">City</label>
                                <p class="text-slate-900">${currentStudentData.address.city || 'N/A'}</p>
                            </div>
                            <div class="bg-slate-50 rounded-lg p-4">
                                <label class="block text-sm font-medium text-slate-700 mb-1">Country</label>
                                <p class="text-slate-900">${currentStudentData.address.country || 'N/A'}</p>
                            </div>
                        </div>
                    </div>
                    ` : ''}

                    ${currentStudentData.nextOfKin ? `
