@model SIS.Models.Accounts.AccountType

@{
    ViewData["Title"] = "Create Accounts";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow p-3 mb-5 bg-white rounded">
                <div class="card-body" style="height: 75vh;">
                    <h2 class="text-center mb-4">Create Account</h2>
                    <form asp-action="CreateAccountType" method="post">
                        <div class="form-group">
                            <label asp-for="Name">Account Name:</label>
                            <input asp-for="Name" class="form-control" placeholder="(e.g., Tuition Fees, Library Fees, Research Fund)"/>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Description">Account Description:</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Type">Account Type:</label>
                            <input asp-for="Type" class="form-control" rows="5" placeholder="(e.g., Revenue, Expense, Asset, Liability, or Equity)"/>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Code">Account Code:</label>
                            <input asp-for="Code" class="form-control" rows="5" placeholder="(e.g., TF for Tuition Fees, or LF for Library Fees)"/>
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block mt-4">Create Account</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>