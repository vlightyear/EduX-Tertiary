@using SIS.Controllers
@model ManageRolePermissionsViewModel

@{
    ViewData["Title"] = $"Manage Permissions - {Model.RoleName}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Permissions for Role: <span class="text-primary">@Model.RoleName</span></h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="material-icons">arrow_back</i> Back to Permissions
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="material-icons">check_circle</i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="material-icons">error</i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="UpdateRolePermissions" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="roleId" value="@Model.RoleId" />

        @foreach (var category in Model.AllPermissions.GroupBy(p => p.Category))
        {
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">@category.Key</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var permission in category)
                        {
                            <div class="col-md-6 col-lg-4 mb-3">
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="permissionIds"
                                           value="@permission.Id"
                                           id="permission_@permission.Id"
                                           @(Model.AssignedPermissionIds.Contains(permission.Id) ? "checked" : "")>
                                    <label class="form-check-label" for="permission_@permission.Id">
                                        <strong>@permission.Name</strong>
                                        <br>
                                        <small class="text-muted">@permission.Description</small>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">
                <i class="material-icons">save</i> Save Permissions
            </button>
        </div>
    </form>
</div>
