@model SIS.Models.ProgramCoordinator.LecturerDetailsViewModel
@{
    ViewData["Title"] = "Lecturer Details - " + Model.FullName;
}

<div class="min-h-[88vh] bg-slate-50">
    <!-- Header Banner -->
    <div class="bg-primary-700 text-white">
        <div class="container mx-auto px-6 py-6">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div class="flex items-center gap-4">
                    <!-- Profile Image -->
                    <div class="flex-shrink-0">
                        @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                        {
                            <img src="@Model.ProfileImageUrl" alt="@Model.FullName" 
                                 class="w-20 h-20 rounded-full object-cover border-4 border-white/20">
                        }
                        else
                        {
                            <div class="w-20 h-20 rounded-full bg-white/20 flex items-center justify-center border-4 border-white/20">
                                <span class="text-white font-bold text-2xl">
                                    @(Model.FullName?.Split(' ').Select(n => n.FirstOrDefault()).Take(2).Aggregate("", (acc, c) => acc + c))
                                </span>
                            </div>
                        }
                    </div>
                    
                    <div>
                        <h1 class="text-2xl font-bold">@Model.FullName</h1>
                        <p class="mt-1 text-primary-100">Lecturer Details & Course Assignments</p>
                    </div>
                </div>
                
                <div class="flex gap-2">
                    <a href="mailto:@Model.Email"
                       class="bg-white bg-opacity-20 hover:bg-opacity-30 transition-colors px-4 py-2 rounded-lg text-sm flex items-center">
                        <i class="material-icons text-sm mr-1">email</i>
                        Contact
                    </a>
                    <a href="@Url.Action("LecturerManagement")"
                       class="bg-white bg-opacity-20 hover:bg-opacity-30 transition-colors px-4 py-2 rounded-lg text-sm flex items-center">
                        <i class="material-icons text-sm mr-1">arrow_back</i>
                        Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container mx-auto px-6 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left Column - Profile Information -->
            <div class="lg:col-span-1 space-y-6">
                <!-- Personal Information Card -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h2 class="text-lg font-semibold text-slate-800 flex items-center">
                            <i class="material-icons text-slate-600 mr-2">person</i>
                            Personal Information
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
                            <p class="text-slate-900">@Model.FullName</p>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
                            <p class="text-slate-900">
                                <a href="mailto:@Model.Email" class="text-primary-600 hover:text-primary-800">
                                    @Model.Email
                                </a>
                            </p>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
                                <p class="text-slate-900">@Model.PhoneNumber</p>
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(Model.Office))
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Office</label>
                                <p class="text-slate-900">@Model.Office</p>
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(Model.OfficeHours))
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Office Hours</label>
                                <p class="text-slate-900">@Model.OfficeHours</p>
                            </div>
                        }
                        
                        @if (Model.JoinDate.HasValue)
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Join Date</label>
                                <p class="text-slate-900">@Model.JoinDate.Value.ToString("MMMM dd, yyyy")</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Academic Information Card -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h2 class="text-lg font-semibold text-slate-800 flex items-center">
                            <i class="material-icons text-slate-600 mr-2">school</i>
                            Academic Information
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        @if (!string.IsNullOrEmpty(Model.Qualifications))
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Qualifications</label>
                                <p class="text-slate-900">@Model.Qualifications</p>
                            </div>
                        }
                        else
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Qualifications</label>
                                <p class="text-slate-500 italic">Not specified</p>
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(Model.Specialization))
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Specialization</label>
                                <p class="text-slate-900">@Model.Specialization</p>
                            </div>
                        }
                        else
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Specialization</label>
                                <p class="text-slate-500 italic">Not specified</p>
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(Model.Biography))
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Biography</label>
                                <p class="text-slate-900 text-sm leading-relaxed">@Model.Biography</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Teaching Load Summary Card -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h2 class="text-lg font-semibold text-slate-800 flex items-center">
                            <i class="material-icons text-slate-600 mr-2">assignment</i>
                            Teaching Load Summary
                        </h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <div class="text-center">
                            <div class="text-3xl font-bold text-primary-600">@Model.TeachingLoad.TotalCourses</div>
                            <div class="text-sm text-slate-600">Total Courses</div>
                        </div>
                        
                        <div class="space-y-3">
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-slate-600">By Year</span>
                                </div>
                                @foreach (var yearGroup in Model.TeachingLoad.CoursesByYear.OrderBy(x => x.Key))
                                {
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm text-slate-700">Year @yearGroup.Key</span>
                                        <span class="text-sm font-medium text-slate-900">@yearGroup.Value courses</span>
                                    </div>
                                }
                            </div>
                            
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-slate-600">By Semester</span>
                                </div>
                                @foreach (var semesterGroup in Model.TeachingLoad.CoursesBySemester.OrderBy(x => x.Key))
                                {
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm text-slate-700">Semester @semesterGroup.Key</span>
                                        <span class="text-sm font-medium text-slate-900">@semesterGroup.Value courses</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Course Assignments -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Course Assignments Card -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <div class="flex justify-between items-center">
                            <h2 class="text-lg font-semibold text-slate-800 flex items-center">
                                <i class="material-icons text-slate-600 mr-2">class</i>
                                Course Assignments (@Model.CourseAssignments.Count)
                            </h2>
                            
                            <div class="flex gap-2">
                                <select id="yearFilter" class="text-sm border border-slate-300 rounded-lg px-3 py-1">
                                    <option value="">All Years</option>
                                    @foreach (var year in Model.CourseAssignments.Select(c => c.YearTaken).Distinct().OrderBy(y => y))
                                    {
                                        <option value="@year">Year @year</option>
                                    }
                                </select>
                                
                                <select id="semesterFilter" class="text-sm border border-slate-300 rounded-lg px-3 py-1">
                                    <option value="">All Semesters</option>
                                    @foreach (var semester in Model.CourseAssignments.Select(c => c.SemesterTaken).Distinct().OrderBy(s => s))
                                    {
                                        <option value="@semester">Semester @semester</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-6">
                        @if (Model.CourseAssignments.Any())
                        {
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" id="courseAssignmentsList">
                                @foreach (var course in Model.CourseAssignments.OrderBy(c => c.YearTaken).ThenBy(c => c.SemesterTaken))
                                {
                                    <div class="course-assignment-card border border-slate-200 rounded-lg p-4 hover:border-primary-300 transition-colors"
                                         data-year="@course.YearTaken" data-semester="@course.SemesterTaken">
                                        <div class="flex justify-between items-start mb-3">
                                            <div>
                                                <h3 class="font-semibold text-slate-800">@course.CourseName</h3>
                                                <p class="text-sm text-slate-600">@course.CourseCode</p>
                                            </div>
                                            <div class="text-right">
                                                <span class="text-xs font-medium text-primary-600 bg-primary-50 px-2 py-1 rounded">
                                                    Year @course.YearTaken, Sem @course.SemesterTaken
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="text-sm text-slate-600">
                                            <div class="flex items-center mb-1">
                                                <i class="material-icons text-xs mr-2">school</i>
                                                <span>@course.ProgramName</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-8">
                                <i class="material-icons text-4xl text-slate-400 mb-4">class</i>
                                <h3 class="text-lg font-medium text-slate-800 mb-2">No Course Assignments</h3>
                                <p class="text-slate-600">This lecturer has no course assignments in your coordinated programs.</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Teaching Load Distribution Chart -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h2 class="text-lg font-semibold text-slate-800 flex items-center">
                            <i class="material-icons text-slate-600 mr-2">bar_chart</i>
                            Teaching Load Distribution
                        </h2>
                    </div>
                    
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Courses by Program -->
                            <div>
                                <h3 class="text-sm font-medium text-slate-700 mb-3">Courses by Program</h3>
                                <div class="space-y-2">
                                    @foreach (var programGroup in Model.TeachingLoad.CoursesByProgram.OrderByDescending(x => x.Value))
                                    {
                                            var percentage = Model.TeachingLoad.TotalCourses > 0 ? (programGroup.Value * 100.0 / Model.TeachingLoad.TotalCourses) : 0;
                                        
                                        <div>
                                            <div class="flex justify-between text-sm mb-1">
                                                <span class="text-slate-700 truncate">@programGroup.Key</span>
                                                <span class="text-slate-900 font-medium">@programGroup.Value</span>
                                            </div>
                                            <div class="w-full bg-slate-200 rounded-full h-2">
                                                <div class="bg-primary-600 h-2 rounded-full transition-all duration-300" 
                                                     style="width: @(percentage)%"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            
                            <!-- Courses by Year -->
                            <div>
                                <h3 class="text-sm font-medium text-slate-700 mb-3">Courses by Academic Year</h3>
                                <div class="space-y-2">
                                    @foreach (var yearGroup in Model.TeachingLoad.CoursesByYear.OrderBy(x => x.Key))
                                    {
                                        
                                        var percentage = Model.TeachingLoad.TotalCourses > 0 ? (yearGroup.Value * 100.0 / Model.TeachingLoad.TotalCourses) : 0;
                                        
                                        <div>
                                            <div class="flex justify-between text-sm mb-1">
                                                <span class="text-slate-700">Year @yearGroup.Key</span>
                                                <span class="text-slate-900 font-medium">@yearGroup.Value courses</span>
                                            </div>
                                            <div class="w-full bg-slate-200 rounded-full h-2">
                                                <div class="bg-blue-600 h-2 rounded-full transition-all duration-300" 
                                                     style="width: @(percentage)%"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            initCourseFiltering();
        });

        function initCourseFiltering() {
            const yearFilter = document.getElementById('yearFilter');
            const semesterFilter = document.getElementById('semesterFilter');
            const courseCards = document.querySelectorAll('.course-assignment-card');

            function filterCourses() {
                const selectedYear = yearFilter.value;
                const selectedSemester = semesterFilter.value;

                courseCards.forEach(card => {
                    const cardYear = card.getAttribute('data-year');
                    const cardSemester = card.getAttribute('data-semester');

                    const yearMatch = !selectedYear || cardYear === selectedYear;
                    const semesterMatch = !selectedSemester || cardSemester === selectedSemester;

                    if (yearMatch && semesterMatch) {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });

                // Update visible count
                const visibleCards = Array.from(courseCards).filter(card => card.style.display !== 'none');
                const countElement = document.querySelector('h2 i + text()');
                if (countElement) {
                    countElement.textContent = `Course Assignments (${visibleCards.length})`;
                }
            }

            yearFilter.addEventListener('change', filterCourses);
            semesterFilter.addEventListener('change', filterCourses);
        }
    </script>
}