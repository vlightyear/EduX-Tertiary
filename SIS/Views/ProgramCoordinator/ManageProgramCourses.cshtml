@model SIS.Models.ProgramCoordinator.ManageProgramCoursesViewModel
@{
    ViewData["Title"] = "Manage Program Courses";
}

<div class="min-h-[88vh] bg-slate-50">
    <!-- Header Banner -->
    <div class="bg-primary-700 text-white">
        <div class="container mx-auto px-6 py-6">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h1 class="text-2xl font-bold">Manage Program Courses</h1>
                    <p class="mt-1 text-primary-100">@Model.Program.Name</p>
                </div>
                <div class="flex gap-2">
                    <a href="@Url.Action("ProgramDetails", new { id = Model.Program.Id })"
                       class="bg-white bg-opacity-20 hover:bg-opacity-30 transition-colors px-4 py-2 rounded-lg text-sm flex items-center">
                        <i class="material-icons text-sm mr-1">arrow_back</i>
                        Back to Details
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container mx-auto px-6 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
            <!-- Main Content Area -->
            <div class="lg:col-span-3 space-y-6">
                <!-- Course Structure Section -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200 flex justify-between items-center">
                        <h2 class="text-lg font-semibold text-slate-800">Program Course Structure</h2>
                        <button type="button" id="saveStructureBtn" class="px-4 py-2 text-sm text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors flex items-center">
                            <i class="material-icons text-sm mr-1">save</i>
                            Save Changes
                        </button>
                    </div>

                    <!-- Year and Semester Structure -->
                    <div class="p-6">
                        <div class="mb-6">
                            <div class="flex text-sm font-medium text-slate-500 mb-2">
                                <span class="w-1/2 pl-3">Year 1</span>
                                <span class="w-1/2 pl-3">Year 2</span>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <!-- Year 1 -->
                                <div class="space-y-4">
                                    <!-- Semester 1 -->
                                    <div>
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="text-sm font-medium text-slate-700">Semester 1</h4>
                                            <button type="button" class="add-course-btn px-2 py-1 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors"
                                                    data-year="1" data-semester="1">
                                                <i class="material-icons text-xs">add</i>
                                                Add Course
                                            </button>
                                        </div>
                                        <div class="course-container border border-slate-200 rounded-lg min-h-[150px] bg-slate-50 p-2"
                                             id="course-container-1-1" data-year="1" data-semester="1">
                                            @foreach (var course in Model.CourseStructure.GetValueOrDefault(1, new List<SIS.Models.ProgramCoordinator.CourseViewModel>()).Where(c => c.Semester == 1))
                                            {
                                                <div class="course-item bg-white border border-slate-200 rounded-lg p-3 mb-2 cursor-move"
                                                     data-course-id="@course.Course.Id" data-mandatory="@course.IsMandatory.ToString().ToLower()">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h5 class="text-sm font-medium text-slate-800">@course.Course.CourseName</h5>
                                                            <p class="text-xs text-slate-500 mt-0.5">@course.Course.CourseCode</p>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            @if (course.IsMandatory)
                                                            {
                                                                <span class="bg-secondary-100 text-secondary-800 text-xs px-2 py-0.5 rounded">Mandatory</span>
                                                            }
                                                            <button type="button" class="remove-course-btn text-red-500 hover:text-red-700 transition-colors">
                                                                <i class="material-icons text-sm">close</i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Semester 2 -->
                                    <div>
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="text-sm font-medium text-slate-700">Semester 2</h4>
                                            <button type="button" class="add-course-btn px-2 py-1 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors"
                                                    data-year="1" data-semester="2">
                                                <i class="material-icons text-xs">add</i>
                                                Add Course
                                            </button>
                                        </div>
                                        <div class="course-container border border-slate-200 rounded-lg min-h-[150px] bg-slate-50 p-2"
                                             id="course-container-1-2" data-year="1" data-semester="2">
                                            @foreach (var course in Model.CourseStructure.GetValueOrDefault(1, new List<SIS.Models.ProgramCoordinator.CourseViewModel>()).Where(c => c.Semester == 2))
                                            {
                                                <div class="course-item bg-white border border-slate-200 rounded-lg p-3 mb-2 cursor-move"
                                                     data-course-id="@course.Course.Id" data-mandatory="@course.IsMandatory.ToString().ToLower()">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h5 class="text-sm font-medium text-slate-800">@course.Course.CourseName</h5>
                                                            <p class="text-xs text-slate-500 mt-0.5">@course.Course.CourseCode</p>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            @if (course.IsMandatory)
                                                            {
                                                                <span class="bg-secondary-100 text-secondary-800 text-xs px-2 py-0.5 rounded">Mandatory</span>
                                                            }
                                                            <button type="button" class="remove-course-btn text-red-500 hover:text-red-700 transition-colors">
                                                                <i class="material-icons text-sm">close</i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- Year 2 -->
                                <div class="space-y-4">
                                    <!-- Semester 1 -->
                                    <div>
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="text-sm font-medium text-slate-700">Semester 1</h4>
                                            <button type="button" class="add-course-btn px-2 py-1 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors"
                                                    data-year="2" data-semester="1">
                                                <i class="material-icons text-xs">add</i>
                                                Add Course
                                            </button>
                                        </div>
                                        <div class="course-container border border-slate-200 rounded-lg min-h-[150px] bg-slate-50 p-2"
                                             id="course-container-2-1" data-year="2" data-semester="1">
                                            @foreach (var course in Model.CourseStructure.GetValueOrDefault(2, new List<SIS.Models.ProgramCoordinator.CourseViewModel>()).Where(c => c.Semester == 1))
                                            {
                                                <div class="course-item bg-white border border-slate-200 rounded-lg p-3 mb-2 cursor-move"
                                                     data-course-id="@course.Course.Id" data-mandatory="@course.IsMandatory.ToString().ToLower()">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h5 class="text-sm font-medium text-slate-800">@course.Course.CourseName</h5>
                                                            <p class="text-xs text-slate-500 mt-0.5">@course.Course.CourseCode</p>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            @if (course.IsMandatory)
                                                            {
                                                                <span class="bg-secondary-100 text-secondary-800 text-xs px-2 py-0.5 rounded">Mandatory</span>
                                                            }
                                                            <button type="button" class="remove-course-btn text-red-500 hover:text-red-700 transition-colors">
                                                                <i class="material-icons text-sm">close</i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Semester 2 -->
                                    <div>
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="text-sm font-medium text-slate-700">Semester 2</h4>
                                            <button type="button" class="add-course-btn px-2 py-1 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors"
                                                    data-year="2" data-semester="2">
                                                <i class="material-icons text-xs">add</i>
                                                Add Course
                                            </button>
                                        </div>
                                        <div class="course-container border border-slate-200 rounded-lg min-h-[150px] bg-slate-50 p-2"
                                             id="course-container-2-2" data-year="2" data-semester="2">
                                            @foreach (var course in Model.CourseStructure.GetValueOrDefault(2, new List<SIS.Models.ProgramCoordinator.CourseViewModel>()).Where(c => c.Semester == 2))
                                            {
                                                <div class="course-item bg-white border border-slate-200 rounded-lg p-3 mb-2 cursor-move"
                                                     data-course-id="@course.Course.Id" data-mandatory="@course.IsMandatory.ToString().ToLower()">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h5 class="text-sm font-medium text-slate-800">@course.Course.CourseName</h5>
                                                            <p class="text-xs text-slate-500 mt-0.5">@course.Course.CourseCode</p>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            @if (course.IsMandatory)
                                                            {
                                                                <span class="bg-secondary-100 text-secondary-800 text-xs px-2 py-0.5 rounded">Mandatory</span>
                                                            }
                                                            <button type="button" class="remove-course-btn text-red-500 hover:text-red-700 transition-colors">
                                                                <i class="material-icons text-sm">close</i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-6">
                            <div class="flex text-sm font-medium text-slate-500 mb-2">
                                <span class="w-1/2 pl-3">Year 3</span>
                                <span class="w-1/2 pl-3">Year 4</span>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <!-- Year 3 -->
                                <div class="space-y-4">
                                    <!-- Semester 1 -->
                                    <div>
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="text-sm font-medium text-slate-700">Semester 1</h4>
                                            <button type="button" class="add-course-btn px-2 py-1 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors"
                                                    data-year="3" data-semester="1">
                                                <i class="material-icons text-xs">add</i>
                                                Add Course
                                            </button>
                                        </div>
                                        <div class="course-container border border-slate-200 rounded-lg min-h-[150px] bg-slate-50 p-2"
                                             id="course-container-3-1" data-year="3" data-semester="1">
                                            @foreach (var course in Model.CourseStructure.GetValueOrDefault(3, new List<SIS.Models.ProgramCoordinator.CourseViewModel>()).Where(c => c.Semester == 1))
                                            {
                                                <div class="course-item bg-white border border-slate-200 rounded-lg p-3 mb-2 cursor-move"
                                                     data-course-id="@course.Course.Id" data-mandatory="@course.IsMandatory.ToString().ToLower()">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h5 class="text-sm font-medium text-slate-800">@course.Course.CourseName</h5>
                                                            <p class="text-xs text-slate-500 mt-0.5">@course.Course.CourseCode</p>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            @if (course.IsMandatory)
                                                            {
                                                                <span class="bg-secondary-100 text-secondary-800 text-xs px-2 py-0.5 rounded">Mandatory</span>
                                                            }
                                                            <button type="button" class="remove-course-btn text-red-500 hover:text-red-700 transition-colors">
                                                                <i class="material-icons text-sm">close</i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Semester 2 -->
                                    <div>
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="text-sm font-medium text-slate-700">Semester 2</h4>
                                            <button type="button" class="add-course-btn px-2 py-1 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors"
                                                    data-year="3" data-semester="2">
                                                <i class="material-icons text-xs">add</i>
                                                Add Course
                                            </button>
                                        </div>
                                        <div class="course-container border border-slate-200 rounded-lg min-h-[150px] bg-slate-50 p-2"
                                             id="course-container-3-2" data-year="3" data-semester="2">
                                            @foreach (var course in Model.CourseStructure.GetValueOrDefault(3, new List<SIS.Models.ProgramCoordinator.CourseViewModel>()).Where(c => c.Semester == 2))
                                            {
                                                <div class="course-item bg-white border border-slate-200 rounded-lg p-3 mb-2 cursor-move"
                                                     data-course-id="@course.Course.Id" data-mandatory="@course.IsMandatory.ToString().ToLower()">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h5 class="text-sm font-medium text-slate-800">@course.Course.CourseName</h5>
                                                            <p class="text-xs text-slate-500 mt-0.5">@course.Course.CourseCode</p>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            @if (course.IsMandatory)
                                                            {
                                                                <span class="bg-secondary-100 text-secondary-800 text-xs px-2 py-0.5 rounded">Mandatory</span>
                                                            }
                                                            <button type="button" class="remove-course-btn text-red-500 hover:text-red-700 transition-colors">
                                                                <i class="material-icons text-sm">close</i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- Year 4 -->
                                <div class="space-y-4">
                                    <!-- Semester 1 -->
                                    <div>
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="text-sm font-medium text-slate-700">Semester 1</h4>
                                            <button type="button" class="add-course-btn px-2 py-1 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors"
                                                    data-year="4" data-semester="1">
                                                <i class="material-icons text-xs">add</i>
                                                Add Course
                                            </button>
                                        </div>
                                        <div class="course-container border border-slate-200 rounded-lg min-h-[150px] bg-slate-50 p-2"
                                             id="course-container-4-1" data-year="4" data-semester="1">
                                            @foreach (var course in Model.CourseStructure.GetValueOrDefault(4, new List<SIS.Models.ProgramCoordinator.CourseViewModel>()).Where(c => c.Semester == 1))
                                            {
                                                <div class="course-item bg-white border border-slate-200 rounded-lg p-3 mb-2 cursor-move"
                                                     data-course-id="@course.Course.Id" data-mandatory="@course.IsMandatory.ToString().ToLower()">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h5 class="text-sm font-medium text-slate-800">@course.Course.CourseName</h5>
                                                            <p class="text-xs text-slate-500 mt-0.5">@course.Course.CourseCode</p>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            @if (course.IsMandatory)
                                                            {
                                                                <span class="bg-secondary-100 text-secondary-800 text-xs px-2 py-0.5 rounded">Mandatory</span>
                                                            }
                                                            <button type="button" class="remove-course-btn text-red-500 hover:text-red-700 transition-colors">
                                                                <i class="material-icons text-sm">close</i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Semester 2 -->
                                    <div>
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="text-sm font-medium text-slate-700">Semester 2</h4>
                                            <button type="button" class="add-course-btn px-2 py-1 text-xs text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors"
                                                    data-year="4" data-semester="2">
                                                <i class="material-icons text-xs">add</i>
                                                Add Course
                                            </button>
                                        </div>
                                        <div class="course-container border border-slate-200 rounded-lg min-h-[150px] bg-slate-50 p-2"
                                             id="course-container-4-2" data-year="4" data-semester="2">
                                            @foreach (var course in Model.CourseStructure.GetValueOrDefault(4, new List<SIS.Models.ProgramCoordinator.CourseViewModel>()).Where(c => c.Semester == 2))
                                            {
                                                <div class="course-item bg-white border border-slate-200 rounded-lg p-3 mb-2 cursor-move"
                                                     data-course-id="@course.Course.Id" data-mandatory="@course.IsMandatory.ToString().ToLower()">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h5 class="text-sm font-medium text-slate-800">@course.Course.CourseName</h5>
                                                            <p class="text-xs text-slate-500 mt-0.5">@course.Course.CourseCode</p>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            @if (course.IsMandatory)
                                                            {
                                                                <span class="bg-secondary-100 text-secondary-800 text-xs px-2 py-0.5 rounded">Mandatory</span>
                                                            }
