@using SIS.Services.StudentImport
@using SIS.Controllers
@model SIS.Services.StudentImport.ImportProcessResult

<div class="min-h-screen bg-slate-50 p-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-center h-24 mb-4">
        <div class="flex items-center text-slate-800">
            @if (Model.Success)
            {
                <i class="material-icons text-3xl mr-2 text-green-600">check_circle</i>
            }
            else
            {
                <i class="material-icons text-3xl mr-2 text-red-600">error</i>
            }
            <div>
                <h1 class="text-2xl font-bold">Import Results</h1>
                <p class="text-sm text-slate-600">Student import process completed</p>
            </div>
        </div>
        <div class="mt-4 md:mt-0 flex gap-2">
            <a asp-action="Index"
               class="inline-flex items-center px-4 py-2 text-cyan-600 bg-transparent border border-cyan-600 rounded-lg hover:bg-cyan-600 hover:text-white transition-colors">
                <i class="material-icons text-sm mr-1">upload</i>
                <span>Import More Students</span>
            </a>
        </div>
    </div>

    <!-- Overall Status Card -->
    <div class="mb-6">
        @if (Model.Success)
        {
            <div class="bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-xl p-6">
                <div class="flex items-center">
                    <div class="bg-green-100 rounded-full p-4 mr-4">
                        <i class="material-icons text-green-600 text-2xl">check_circle</i>
                    </div>
                    <div class="flex-1">
                        <h2 class="text-xl font-bold text-green-800 mb-2">Import Completed Successfully!</h2>
                        <p class="text-green-700 mb-2">@Model.Message</p>
                        <div class="flex items-center text-sm text-green-600">
                            <i class="material-icons text-sm mr-1">schedule</i>
                            <span>Processing time: @Model.ProcessingTime.TotalSeconds.ToString("F1") seconds</span>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="bg-gradient-to-r from-red-50 to-rose-50 border border-red-200 rounded-xl p-6">
                <div class="flex items-center">
                    <div class="bg-red-100 rounded-full p-4 mr-4">
                        <i class="material-icons text-red-600 text-2xl">error</i>
                    </div>
                    <div class="flex-1">
                        <h2 class="text-xl font-bold text-red-800 mb-2">Import Failed</h2>
                        <p class="text-red-700 mb-2">@Model.Message</p>
                        <div class="flex items-center text-sm text-red-600">
                            <i class="material-icons text-sm mr-1">schedule</i>
                            <span>Processing time: @Model.ProcessingTime.TotalSeconds.ToString("F1") seconds</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <!-- Total Processed -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <div class="flex items-center">
                    <div class="bg-blue-100 rounded-full p-3 mr-4">
                        <i class="material-icons text-blue-600 text-xl">people</i>
                    </div>
                    <div>
                        <p class="text-sm text-slate-600 font-medium">Total Processed</p>
                        <h3 class="text-2xl font-bold text-slate-800">@Model.TotalProcessed</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Successful Imports -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <div class="flex items-center">
                    <div class="bg-green-100 rounded-full p-3 mr-4">
                        <i class="material-icons text-green-600 text-xl">check_circle</i>
                    </div>
                    <div>
                        <p class="text-sm text-slate-600 font-medium">Successful Imports</p>
                        <h3 class="text-2xl font-bold text-slate-800">@Model.SuccessfulImports</h3>
                        <p class="text-xs text-green-600 mt-1">Accounts created</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Failed Imports -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <div class="flex items-center">
                    <div class="bg-red-100 rounded-full p-3 mr-4">
                        <i class="material-icons text-red-600 text-xl">error</i>
                    </div>
                    <div>
                        <p class="text-sm text-slate-600 font-medium">Failed Imports</p>
                        <h3 class="text-2xl font-bold text-slate-800">@Model.FailedImports</h3>
                        <p class="text-xs text-red-600 mt-1">Errors encountered</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Emails Sent -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <div class="flex items-center">
                    <div class="bg-purple-100 rounded-full p-3 mr-4">
                        <i class="material-icons text-purple-600 text-xl">email</i>
                    </div>
                    <div>
                        <p class="text-sm text-slate-600 font-medium">Welcome Emails</p>
                        <h3 class="text-2xl font-bold text-slate-800">@Model.EmailsSent</h3>
                        <p class="text-xs text-purple-600 mt-1">Notifications sent</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Detailed Import Summary -->
    @if (Model.ImportSummary != null)
    {
        <div class="bg-white rounded-xl shadow-sm mb-6">
            <div class="p-6">
                <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                    <i class="material-icons text-blue-600 mr-2">analytics</i>
                    Import Summary
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div class="bg-slate-50 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-medium text-slate-600">Rows in File</span>
                            <span class="text-lg font-bold text-slate-800">@Model.ImportSummary.TotalRowsInFile</span>
                        </div>
                    </div>
                    <div class="bg-green-50 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-medium text-green-700">Valid for Import</span>
                            <span class="text-lg font-bold text-green-800">@Model.ImportSummary.ValidRowsForImport</span>
                        </div>
                    </div>
                    <div class="bg-amber-50 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-medium text-amber-700">Skipped (Invalid)</span>
                            <span class="text-lg font-bold text-amber-800">@Model.ImportSummary.InvalidRowsSkipped</span>
                        </div>
                    </div>
                    <div class="bg-blue-50 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-medium text-blue-700">Users Created</span>
                            <span class="text-lg font-bold text-blue-800">@Model.ImportSummary.UsersCreated</span>
                        </div>
                    </div>
                    <div class="bg-purple-50 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-medium text-purple-700">Emails Sent</span>
                            <span class="text-lg font-bold text-purple-800">@Model.ImportSummary.EmailsSent</span>
                        </div>
                    </div>
                    <div class="bg-red-50 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-medium text-red-700">Errors</span>
                            <span class="text-lg font-bold text-red-800">@Model.ImportSummary.ErrorsEncountered</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Tab Navigation for Results -->
    <div class="bg-white rounded-xl shadow-sm mb-6">
        <div class="border-b border-slate-200">
            <nav class="flex">
                @if (Model.ImportedStudents.Any())
                {
                    <button type="button"
                            class="px-6 py-4 text-sm font-medium border-b-2 border-cyan-600 text-cyan-600 whitespace-nowrap"
                            id="success-tab"
                            onclick="switchTab('success')"
                            aria-selected="true">
                        <i class="material-icons text-sm mr-1">check_circle</i>
                        Successful Imports (@Model.ImportedStudents.Count)
                    </button>
                }
                @if (Model.FailedRows.Any())
                {
                    <button type="button"
                            class="px-6 py-4 text-sm font-medium border-b-2 @(Model.ImportedStudents.Any() ? "border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300" : "border-cyan-600 text-cyan-600") whitespace-nowrap"
                            id="failed-tab"
                            onclick="switchTab('failed')"
                            aria-selected="@(Model.ImportedStudents.Any() ? "false" : "true")">
                        <i class="material-icons text-sm mr-1">error</i>
                        Failed Imports (@Model.FailedRows.Count)
                    </button>
                }
            </nav>
        </div>

        <!-- Successful Imports Table -->
        @if (Model.ImportedStudents.Any())
        {
            <div id="success-content" class="tab-content">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-semibold text-slate-800">Successfully Imported Students</h3>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <i class="material-icons text-slate-400 text-sm">search</i>
                            </div>
                            <input type="text" id="successSearch"
                                   class="block w-60 pl-10 pr-4 py-2 text-sm border border-slate-200 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                   placeholder="Search students..."
                                   onkeyup="searchTable('successTable')">
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200" id="successTable">
                            <thead class="bg-green-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Row</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Student ID</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Full Name</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Email</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Programme</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">School</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-green-700 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-slate-200">
                                @foreach (var student in Model.ImportedStudents)
                                {
                                    <tr class="hover:bg-green-50">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">@student.RowNumber</td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="text-sm font-mono font-medium text-slate-900">@student.StudentId</span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="flex items-center">
                                                <div class="bg-green-100 rounded-full p-1 mr-3">
                                                    <i class="material-icons text-green-600 text-sm">person</i>
                                                </div>
                                                <span class="text-sm font-medium text-slate-900">@student.FullName</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-700">@student.Email</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-700">@student.ProgrammeName</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-700">@student.SchoolName</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                                            <div class="flex items-center space-x-2">
                                                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                    <i class="material-icons text-xs mr-1">check</i>
                                                    Created
                                                </span>
                                                <a href="mailto:@student.Email" class="text-cyan-600 hover:text-cyan-800" title="Send Email">
                                                    <i class="material-icons text-sm">email</i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Failed Imports Table -->
        @if (Model.FailedRows.Any())
        {
            <div id="failed-content" class="tab-content @(Model.ImportedStudents.Any() ? "hidden" : "")">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-semibold text-slate-800">Failed Imports</h3>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <i class="material-icons text-slate-400 text-sm">search</i>
                            </div>
                            <input type="text" id="failedSearch"
                                   class="block w-60 pl-10 pr-4 py-2 text-sm border border-slate-200 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                   placeholder="Search students..."
                                   onkeyup="searchTable('failedTable')">
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200" id="failedTable">
                            <thead class="bg-red-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase tracking-wider">Row</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase tracking-wider">Full Name</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase tracking-wider">Email</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase tracking-wider">Student ID</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase tracking-wider">Error Message</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-slate-200">
                                @foreach (var failedRow in Model.FailedRows)
                                {
                                    <tr class="hover:bg-red-50">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">@failedRow.RowNumber</td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="flex items-center">
                                                <div class="bg-red-100 rounded-full p-1 mr-3">
                                                    <i class="material-icons text-red-600 text-sm">person</i>
                                                </div>
                                                <span class="text-sm font-medium text-slate-900">@(failedRow.StudentData.FullName ?? "N/A")</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-700">@(failedRow.StudentData.Email ?? "N/A")</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-slate-700">@(failedRow.StudentData.StudentId_Number ?? "N/A")</td>
                                        <td class="px-6 py-4">
                                            <div class="flex items-start">
                                                <i class="material-icons text-red-500 text-sm mr-1 mt-0.5">error</i>
                                                <span class="text-sm text-red-700">@failedRow.ErrorMessage</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Next Steps Card -->
    <div class="bg-white rounded-xl shadow-sm">
        <div class="p-6">
            <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                <i class="material-icons text-cyan-600 mr-2">lightbulb</i>
                Next Steps
            </h3>

            @if (Model.Success && Model.SuccessfulImports > 0)
            {
                <div class="space-y-4">
                    <div class="flex items-start">
                        <div class="bg-cyan-100 rounded-full p-2 mr-4 mt-1">
                            <i class="material-icons text-cyan-600 text-sm">email</i>
                        </div>
                        <div>
                            <h4 class="font-medium text-slate-800">Welcome Emails Sent</h4>
                            <p class="text-sm text-slate-600 mt-1">
                                @Model.EmailsSent welcome emails have been sent to the newly created student accounts.
                                Students can now log in using their email and the temporary password provided.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start">
                        <div class="bg-green-100 rounded-full p-2 mr-4 mt-1">
                            <i class="material-icons text-green-600 text-sm">people</i>
                        </div>
                        <div>
                            <h4 class="font-medium text-slate-800">Student Records Created</h4>
                            <p class="text-sm text-slate-600 mt-1">
                                All student records have been created with default status "Admitted".
                                Students will need to complete their registration when the registration period opens.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start">
                        <div class="bg-purple-100 rounded-full p-2 mr-4 mt-1">
                            <i class="material-icons text-purple-600 text-sm">settings</i>
                        </div>
                        <div>
                            <h4 class="font-medium text-slate-800">Student Onboarding</h4>
                            <p class="text-sm text-slate-600 mt-1">
                                Students can update their profiles and complete missing information through the student portal.
                                Consider setting up orientation sessions for new students.
                            </p>
                        </div>
                    </div>
                </div>
            }
            else if (Model.FailedImports > 0 && Model.SuccessfulImports == 0)
            {
                <div class="space-y-4">
                    <div class="flex items-start">
                        <div class="bg-red-100 rounded-full p-2 mr-4 mt-1">
                            <i class="material-icons text-red-600 text-sm">error</i>
                        </div>
                        <div>
                            <h4 class="font-medium text-slate-800">All Imports Failed</h4>
                            <p class="text-sm text-slate-600 mt-1">
                                No students were successfully imported. Please review the error messages above,
                                fix the issues in your Excel file, and try importing again.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start">
                        <div class="bg-amber-100 rounded-full p-2 mr-4 mt-1">
                            <i class="material-icons text-amber-600 text-sm">help</i>
                        </div>
                        <div>
                            <h4 class="font-medium text-slate-800">Need Help?</h4>
                            <p class="text-sm text-slate-600 mt-1">
                                Download the template file and ensure your data matches the required format.
                                Check for duplicate emails, invalid IDs, and missing required fields.
                            </p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    <div class="flex items-start">
                        <div class="bg-green-100 rounded-full p-2 mr-4 mt-1">
                            <i class="material-icons text-green-600 text-sm">check_circle</i>
                        </div>
                        <div>
                            <h4 class="font-medium text-slate-800">Partial Success</h4>
                            <p class="text-sm text-slate-600 mt-1">
                                @Model.SuccessfulImports students were imported successfully, while @Model.FailedImports failed.
                                Review the failed imports and fix any issues for future imports.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start">
                        <div class="bg-amber-100 rounded-full p-2 mr-4 mt-1">
                            <i class="material-icons text-amber-600 text-sm">upload</i>
                        </div>
                        <div>
                            <h4 class="font-medium text-slate-800">Retry Failed Records</h4>
                            <p class="text-sm text-slate-600 mt-1">
                                You can create a new Excel file with just the failed records (after fixing the issues)
                                and import them separately.
                            </p>
                        </div>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="flex flex-wrap gap-3 mt-6 pt-4 border-t border-slate-200">
                <a asp-action="Index" class="inline-flex items-center px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                    <i class="material-icons text-sm mr-1">upload</i>
                    <span>Import More Students</span>
                </a>

                <a href="/Admin/Students" class="inline-flex items-center px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-100 transition-colors">
                    <i class="material-icons text-sm mr-1">people</i>
                    <span>View All Students</span>
                </a>

                @if (Model.FailedRows.Any())
                {
                    <button type="button" onclick="generateFailedReport()" class="inline-flex items-center px-4 py-2 text-amber-600 bg-transparent border border-amber-600 rounded-lg hover:bg-amber-600 hover:text-white transition-colors">
                        <i class="material-icons text-sm mr-1">download</i>
                        <span>Download Failed Records</span>
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<!-- Success/Error Toast Notification -->
<div id="toastNotification" class="hidden fixed bottom-4 right-4 p-4 rounded-lg shadow-lg max-w-xs z-50">
    <div class="flex items-center">
        <i id="toastIcon" class="material-icons mr-2"></i>
        <p id="toastMessage"></p>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tabName) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
            });

            // Remove active classes from all tabs
            document.querySelectorAll('[id$="-tab"]').forEach(tab => {
                tab.classList.remove('border-cyan-600', 'text-cyan-600');
                tab.classList.add('border-transparent', 'text-slate-500');
                tab.setAttribute('aria-selected', 'false');
            });

            // Show selected tab content
            const selectedContent = document.getElementById(tabName + '-content');
            if (selectedContent) {
                selectedContent.classList.remove('hidden');
            }

            // Activate selected tab
            const selectedTab = document.getElementById(tabName + '-tab');
            if (selectedTab) {
                selectedTab.classList.remove('border-transparent', 'text-slate-500');
                selectedTab.classList.add('border-cyan-600', 'text-cyan-600');
                selectedTab.setAttribute('aria-selected', 'true');
            }
        }

        function searchTable(tableId) {
            const input = event.target;
            const filter = input.value.toUpperCase();
            const table = document.getElementById(tableId);
            const rows = table.getElementsByTagName('tr');

            for (let i = 1; i < rows.length; i++) { // Skip header row
                const row = rows[i];
                const cells = row.getElementsByTagName('td');
                let match = false;

                for (let j = 0; j < cells.length; j++) {
                    const cell = cells[j];
                    if (cell && cell.textContent.toUpperCase().indexOf(filter) > -1) {
                        match = true;
                        break;
                    }
                }

                row.style.display = match ? '' : 'none';
            }
        }

        function generateFailedReport() {
            // Create CSV content for failed records
            const failedData = @Html.Raw(Json.Serialize(Model.FailedRows));

            let csvContent = "Row,FullName,Email,StudentId,ErrorMessage\n";

            failedData.forEach(row => {
                const data = row.studentData;
                csvContent += `${row.rowNumber},"${data.fullName || 'N/A'}","${data.email || 'N/A'}","${data.studentId_Number || 'N/A'}","${row.errorMessage}"\n`;
            });

            // Create and download file
            const blob = new Blob([csvContent], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `Failed_Import_Records_${new Date().toISOString().slice(0, 10)}.csv`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);

            showToast('Failed records report downloaded successfully', 'success');
        }

        function showToast(message, type = 'success') {
            window.showAppToast(message, type);
        }

        // Auto-expand appropriate tab based on data
        document.addEventListener('DOMContentLoaded', function() {
            // Show success tab by default if there are successful imports
        @if (Model.ImportedStudents.Any())
        {
            <text>switchTab('success');</text>
        }
        else if (Model.FailedRows.Any())
        {
            <text>switchTab('failed');</text>
        }
        });

        // Display any server messages
        @if (TempData["Error"] != null)
        {
            <text>
                document.addEventListener('DOMContentLoaded', function() {
                    showToast('@Html.Raw(TempData["Error"])', 'error');
                });
            </text>
        }

        @if (TempData["Success"] != null)
        {
            <text>
                document.addEventListener('DOMContentLoaded', function() {
                    showToast('@Html.Raw(TempData["Success"])', 'success');
                });
            </text>
        }

        // Add some celebration for successful imports
        @if (Model.Success && Model.SuccessfulImports > 0)
        {
            <text>
                document.addEventListener('DOMContentLoaded', function() {
                    // Add a subtle celebration effect
                    setTimeout(() => {
                        const successCards = document.querySelectorAll('.bg-green-100, .bg-green-50');
                        successCards.forEach(card => {
                            card.style.animation = 'pulse 0.5s ease-in-out';
                        });
                    }, 500);
                });
            </text>
        }
    </script>
}

<style>
    @@keyframes pulse {
        0%

    {
        transform: scale(1);
    }

    50% {
        transform: scale(1.02);
    }

    100% {
        transform: scale(1);
    }

    }

    .tab-content {
        animation: fadeIn 0.3s ease-in-out;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* Hover effects for table rows */
    .hover\:bg-green-50:hover {
        background-color: #f0fdf4;
    }

    .hover\:bg-red-50:hover {
        background-color: #fef2f2;
    }

    /* Custom scrollbar for tables */
    .overflow-x-auto::-webkit-scrollbar {
        height: 6px;
    }

    .overflow-x-auto::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 3px;
    }

    .overflow-x-auto::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 3px;
    }

        .overflow-x-auto::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
</style>
