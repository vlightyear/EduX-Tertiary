@using SIS.Controllers 
@using SIS.Services.StudentImport
@model SIS.Controllers.StudentImportIndexViewModel

<div class="min-h-screen bg-slate-50 p-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-center h-24 mb-4">
        <div class="flex items-center text-slate-800">
            <i class="material-icons text-3xl mr-2">upload</i>
            <div>
                <h1 class="text-2xl font-bold">Student Import</h1>
                <p class="text-sm text-slate-600">Import student data from Excel files</p>
            </div>
        </div>
        <div class="mt-4 md:mt-0 flex gap-2">
            <a asp-action="DownloadTemplate"
               class="inline-flex items-center px-4 py-2 text-cyan-600 bg-transparent border border-cyan-600 rounded-lg hover:bg-cyan-600 hover:text-white transition-colors">
                <i class="material-icons text-sm mr-1">download</i>
                <span>Download Template</span>
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <!-- Total Students -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <div class="flex items-center">
                    <div class="bg-blue-100 rounded-full p-3 mr-4">
                        <i class="material-icons text-blue-600 text-xl">people</i>
                    </div>
                    <div>
                        <p class="text-sm text-slate-600 font-medium">Total Students</p>
                        <h3 class="text-2xl font-bold text-slate-800">@Model.TotalStudents.ToString("N0")</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Admitted Students -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <div class="flex items-center">
                    <div class="bg-green-100 rounded-full p-3 mr-4">
                        <i class="material-icons text-green-600 text-xl">school</i>
                    </div>
                    <div>
                        <p class="text-sm text-slate-600 font-medium">Admitted Students</p>
                        <h3 class="text-2xl font-bold text-slate-800">@Model.TotalAdmittedStudents.ToString("N0")</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Registered Students -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <div class="flex items-center">
                    <div class="bg-purple-100 rounded-full p-3 mr-4">
                        <i class="material-icons text-purple-600 text-xl">assignment_turned_in</i>
                    </div>
                    <div>
                        <p class="text-sm text-slate-600 font-medium">Registered Students</p>
                        <h3 class="text-2xl font-bold text-slate-800">@Model.TotalRegisteredStudents.ToString("N0")</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Import Card -->
    <div class="bg-white rounded-xl shadow-sm">
        <div class="p-6">
            <h2 class="text-lg font-semibold text-slate-800 mb-6">Import Student Data</h2>

            <!-- Upload Form -->
            <form asp-action="UploadAndPreview" method="post" enctype="multipart/form-data" id="importForm">
                @Html.AntiForgeryToken()

                <!-- File Upload Area -->
                <div class="mb-8">
                    <div class="border-2 border-dashed border-slate-300 rounded-lg p-8 text-center transition-colors hover:border-cyan-400" id="dropArea">
                        <input type="file" name="importFile" id="fileInput" class="hidden" accept=".xlsx" required />
                        <label for="fileInput" class="cursor-pointer">
                            <i class="material-icons text-6xl text-slate-400 mb-4">cloud_upload</i>
                            <h3 class="text-xl font-medium text-slate-700 mb-2">Upload Student Data File</h3>
                            <p class="text-sm text-slate-500 mb-6">Drag and drop your Excel file here, or click to browse</p>
                            <span class="inline-flex items-center px-6 py-3 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                                <i class="material-icons text-sm mr-2">upload_file</i>
                                <span>Select Excel File</span>
                            </span>
                        </label>
                        <div id="selectedFile" class="mt-6 text-slate-700 hidden">
                            <div class="flex items-center justify-center">
                                <i class="material-icons text-green-600 mr-2">check_circle</i>
                                <span>Selected: <span class="font-medium" id="fileName"></span></span>
                            </div>
                            <div class="mt-2">
                                <span class="text-sm text-slate-500">Size: <span id="fileSize"></span></span>
                            </div>
                        </div>
                    </div>
                    <div class="mt-2 text-sm text-slate-500">
                        <span class="font-medium">Supported format:</span> Excel (.xlsx) •
                        <span class="font-medium">Max size:</span> @((Model.MaxFileSize / 1024 / 1024).ToString("F0"))MB •
                        <span class="font-medium">Max rows:</span> @Model.MaxRowsPerImport.ToString("N0")
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="resetForm()" class="inline-flex items-center px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-100 transition-colors">
                        <i class="material-icons text-sm mr-1">refresh</i>
                        <span>Reset</span>
                    </button>
                    <button type="submit" id="previewBtn" class="inline-flex items-center px-6 py-3 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                        <i class="material-icons text-sm mr-2">preview</i>
                        <span>Preview Import</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Requirements Section -->
    <div class="mt-6 grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- File Requirements -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                    <i class="material-icons text-amber-600 mr-2">info</i>
                    File Requirements
                </h3>
                <ul class="space-y-3 text-sm text-slate-600">
                    <li class="flex items-start">
                        <i class="material-icons text-green-600 text-sm mr-2 mt-0.5">check</i>
                        <span>Excel format (.xlsx) only</span>
                    </li>
                    <li class="flex items-start">
                        <i class="material-icons text-green-600 text-sm mr-2 mt-0.5">check</i>
                        <span>Maximum file size: @((Model.MaxFileSize / 1024 / 1024).ToString("F0"))MB</span>
                    </li>
                    <li class="flex items-start">
                        <i class="material-icons text-green-600 text-sm mr-2 mt-0.5">check</i>
                        <span>Maximum @Model.MaxRowsPerImport.ToString("N0") students per import</span>
                    </li>
                    <li class="flex items-start">
                        <i class="material-icons text-green-600 text-sm mr-2 mt-0.5">check</i>
                        <span>First row must contain column headers</span>
                    </li>
                    <li class="flex items-start">
                        <i class="material-icons text-green-600 text-sm mr-2 mt-0.5">check</i>
                        <span>Use the provided template for best results</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Required Columns -->
        <div class="bg-white rounded-xl shadow-sm">
            <div class="p-6">
                <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                    <i class="material-icons text-blue-600 mr-2">view_column</i>
                    Required Columns
                </h3>
                <div class="space-y-2 text-sm text-slate-600 max-h-48 overflow-y-auto">
                    @foreach (var column in Model.RequiredColumns)
                    {
                        <div class="flex items-center">
                            <i class="material-icons text-red-500 text-sm mr-2">fiber_manual_record</i>
                            <span class="font-mono text-xs bg-slate-100 px-2 py-1 rounded">@column</span>
                        </div>
                    }
                </div>
                <div class="mt-4 p-3 bg-blue-50 rounded-lg">
                    <p class="text-xs text-blue-700">
                        <i class="material-icons text-blue-500 text-sm mr-1">lightbulb</i>
                        Download the template to see all required columns with sample data
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Process Information -->
    <div class="mt-6 bg-white rounded-xl shadow-sm">
        <div class="p-6">
            <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center">
                <i class="material-icons text-green-600 mr-2">timeline</i>
                Import Process
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="text-center p-4 bg-slate-50 rounded-lg">
                    <div class="bg-blue-100 rounded-full p-3 w-12 h-12 mx-auto mb-3 flex items-center justify-center">
                        <i class="material-icons text-blue-600">upload</i>
                    </div>
                    <h4 class="font-medium text-slate-800 mb-1">1. Upload</h4>
                    <p class="text-xs text-slate-600">Select and upload your Excel file</p>
                </div>
                <div class="text-center p-4 bg-slate-50 rounded-lg">
                    <div class="bg-amber-100 rounded-full p-3 w-12 h-12 mx-auto mb-3 flex items-center justify-center">
                        <i class="material-icons text-amber-600">preview</i>
                    </div>
                    <h4 class="font-medium text-slate-800 mb-1">2. Preview</h4>
                    <p class="text-xs text-slate-600">Review and validate your data</p>
                </div>
                <div class="text-center p-4 bg-slate-50 rounded-lg">
                    <div class="bg-purple-100 rounded-full p-3 w-12 h-12 mx-auto mb-3 flex items-center justify-center">
                        <i class="material-icons text-purple-600">settings</i>
                    </div>
                    <h4 class="font-medium text-slate-800 mb-1">3. Process</h4>
                    <p class="text-xs text-slate-600">Create student accounts and records</p>
                </div>
                <div class="text-center p-4 bg-slate-50 rounded-lg">
                    <div class="bg-green-100 rounded-full p-3 w-12 h-12 mx-auto mb-3 flex items-center justify-center">
                        <i class="material-icons text-green-600">check_circle</i>
                    </div>
                    <h4 class="font-medium text-slate-800 mb-1">4. Complete</h4>
                    <p class="text-xs text-slate-600">Send welcome emails and generate report</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loading Modal -->
<div id="loadingModal" class="hidden fixed inset-0 bg-gray-500 bg-opacity-75 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl p-8 max-w-sm w-full">
        <div class="text-center">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-cyan-600 mx-auto mb-4"></div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">Processing File...</h3>
            <p class="text-sm text-gray-500">Please wait while we validate your data</p>
        </div>
    </div>
</div>

<!-- Success/Error Toast Notification -->
<div id="toastNotification" class="hidden fixed bottom-4 right-4 p-4 rounded-lg shadow-lg max-w-xs z-50">
    <div class="flex items-center">
        <i id="toastIcon" class="material-icons mr-2"></i>
        <p id="toastMessage"></p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dropArea = document.getElementById('dropArea');
            const fileInput = document.getElementById('fileInput');
            const selectedFile = document.getElementById('selectedFile');
            const fileName = document.getElementById('fileName');
            const fileSize = document.getElementById('fileSize');
            const previewBtn = document.getElementById('previewBtn');
            const importForm = document.getElementById('importForm');

            // Prevent default drag behaviors
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropArea.addEventListener(eventName, preventDefaults, false);
                document.body.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            // Highlight drop area when item is dragged over it
            ['dragenter', 'dragover'].forEach(eventName => {
                dropArea.addEventListener(eventName, highlight, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropArea.addEventListener(eventName, unhighlight, false);
            });

            function highlight() {
                dropArea.classList.remove('border-slate-300');
                dropArea.classList.add('border-cyan-500', 'bg-cyan-50');
            }

            function unhighlight() {
                dropArea.classList.remove('border-cyan-500', 'bg-cyan-50');
                dropArea.classList.add('border-slate-300');
            }

            // Handle dropped files
            dropArea.addEventListener('drop', handleDrop, false);

            function handleDrop(e) {
                const dt = e.dataTransfer;
                const files = dt.files;

                if (files.length > 0) {
                    fileInput.files = files;
                    updateFileInfo();
                }
            }

            // Update file info when selected via input
            fileInput.addEventListener('change', updateFileInfo);

            function updateFileInfo() {
                if (fileInput.files.length > 0) {
                    const file = fileInput.files[0];

                    // Validate file type
                    if (!file.name.toLowerCase().endsWith('.xlsx')) {
                        showToast('Please select an Excel (.xlsx) file', 'error');
                        resetForm();
                        return;
                    }

                    // Validate file size
                    const maxSize = @Model.MaxFileSize;
                    if (file.size > maxSize) {
                        showToast(`File size exceeds ${Math.round(maxSize / 1024 / 1024)}MB limit`, 'error');
                        resetForm();
                        return;
                    }

                    fileName.textContent = file.name;
                    fileSize.textContent = formatFileSize(file.size);
                    selectedFile.classList.remove('hidden');
                    previewBtn.disabled = false;

                    dropArea.classList.remove('border-slate-300');
                    dropArea.classList.add('border-green-500');
                } else {
                    resetForm();
                }
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            // Form submission
            importForm.addEventListener('submit', function(e) {
                e.preventDefault();

                if (!fileInput.files.length) {
                    showToast('Please select a file to upload', 'error');
                    return;
                }

                // Show loading modal
                document.getElementById('loadingModal').classList.remove('hidden');

                // Submit form
                this.submit();
            });
        });

        function resetForm() {
            const fileInput = document.getElementById('fileInput');
            const selectedFile = document.getElementById('selectedFile');
            const previewBtn = document.getElementById('previewBtn');
            const dropArea = document.getElementById('dropArea');

            fileInput.value = '';
            selectedFile.classList.add('hidden');
            previewBtn.disabled = true;

            dropArea.classList.remove('border-green-500', 'border-cyan-500', 'bg-cyan-50');
            dropArea.classList.add('border-slate-300');
        }

        function showToast(message, type = 'success') {
            window.showAppToast(message, type);
        }

        // Display any server messages
        @if (TempData["Error"] != null)
        {
            <text>
                document.addEventListener('DOMContentLoaded', function() {
                    showToast('@Html.Raw(TempData["Error"])', 'error');
                    document.getElementById('loadingModal').classList.add('hidden');
                });
            </text>
        }

        @if (TempData["Success"] != null)
        {
            <text>
                document.addEventListener('DOMContentLoaded', function() {
                    showToast('@Html.Raw(TempData["Success"])', 'success');
                });
            </text>
        }
    </script>
}

<style>
    .animate-spin {
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
</style>
