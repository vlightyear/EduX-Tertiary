            padding: 1rem 1.25rem;
            border-right: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: .75rem;
        }

            .cc-strip-cell:last-child {
                border-right: none;
            }

        .cc-strip-icon {
            width: 34px;
            height: 34px;
            border-radius: .55rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .cc-strip-icon i {
                font-size: 1rem;
            }

        .cc-strip-val {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--ink);
            line-height: 1;
        }

        .cc-strip-lbl {
            font-size: .7rem;
            color: var(--text);
            margin-top: .1rem;
        }

        /* ── Progress bar ─────────────────────── */
        .cc-progress-track {
            height: 6px;
            background: var(--border);
            border-radius: 3px;
            overflow: hidden;
        }

        .cc-progress-fill {
            height: 100%;
            border-radius: 3px;
            background: linear-gradient(90deg, var(--coral) 0%, #f59e0b 100%);
            transition: width .4s ease;
        }

        /* ── Layout ───────────────────────────── */
        .cc-layout {
            display: flex;
            gap: 1.25rem;
            align-items: flex-start;
        }

        .cc-main {
            flex: 1;
            min-width: 0;
        }

        .cc-sidebar {
            width: 280px;
            flex-shrink: 0;
            position: sticky;
            top: 20px;
            max-height: calc(100vh - 40px);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        /* ── Content card ─────────────────────── */
        .cc-card {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            box-shadow: 0 2px 12px rgba(30,45,94,.05);
