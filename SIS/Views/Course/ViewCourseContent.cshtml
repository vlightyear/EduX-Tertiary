            font-size: .72rem;
            color: #f59e0b;
            margin-left: .1rem;
        }

        /* ── Sidebar actions ──────────────────── */
        .sidebar-actions {
            padding: 1rem;
            border-top: 1px solid var(--border);
        }

        .btn-rate {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            width: 100%;
            padding: .6rem;
            border-radius: .65rem;
            font-size: .82rem;
            font-weight: 700;
            background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
            color: #fff;
            border: none;
            cursor: pointer;
            transition: opacity .15s;
            margin-bottom: .6rem;
        }

            .btn-rate:hover {
                opacity: .88;
            }

            .btn-rate i {
                font-size: .9rem;
            }

        .btn-complete {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            width: 100%;
            padding: .6rem;
            border-radius: .65rem;
            font-size: .82rem;
            font-weight: 700;
            background: var(--navy);
            color: #fff;
            border: none;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-complete:hover:not(:disabled) {
                background: var(--navy-l);
            }

            .btn-complete:disabled {
                background: #cbd5e1;
                cursor: not-allowed;
            }

            .btn-complete i {
                font-size: .9rem;
            }

        .completed-note {
            display: flex;
            align-items: flex-start;
            gap: .5rem;
            background: #dcfce7;
            border: 1px solid #86efac;
            color: #166534;
            padding: .75rem;
            border-radius: .65rem;
            font-size: .78rem;
        }

            .completed-note i {
                font-size: 1rem;
                flex-shrink: 0;
            }

        /* ── Rating modal ─────────────────────── */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,20,40,.55);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: opacity .25s, visibility .25s;
        }

            .modal-overlay.show {
                opacity: 1;
                visibility: visible;
            }

        .modal-box {
            background: #fff;
            border-radius: 1.1rem;
            padding: 1.75rem;
            max-width: 440px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            transform: translateY(16px) scale(.97);
            transition: transform .25s;
            box-shadow: 0 24px 48px rgba(15,20,40,.2);
        }

        .modal-overlay.show .modal-box {
            transform: translateY(0) scale(1);
        }

        .modal-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
        }

        .modal-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.1rem;
            color: var(--ink);
        }

        .modal-close {
            width: 28px;
            height: 28px;
            border-radius: .4rem;
            border: 1px solid var(--border);
            background: var(--mist);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text);
            transition: background .15s;
        }

            .modal-close:hover {
                background: #fee2e2;
                color: var(--coral);
            }

            .modal-close i {
                font-size: 1rem;
            }

        /* Stars */
        .star-rating {
            display: flex;
            gap: 6px;
            margin: .5rem 0 .25rem;
        }

        .star {
            font-size: 1.6rem;
            color: #d1d5db;
            cursor: pointer;
            transition: color .15s, transform .15s;
            user-select: none;
        }

            .star:hover, .star.hovered {
                color: #fbbf24;
                transform: scale(1.15);
            }

            .star.selected {
                color: #f59e0b;
            }

            .star.readonly {
                cursor: default;
            }

                .star.readonly:hover {
                    transform: none;
                }

        .rating-display .star {
            font-size: 1rem;
            cursor: default;
        }

            .rating-display .star:hover {
                transform: none;
            }

        .rating-label {
            font-size: .78rem;
            color: var(--text);
            margin-top: .25rem;
            min-height: 1.2em;
        }

        .modal-label {
            font-size: .8rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: .4rem;
            display: block;
        }

        .modal-textarea {
            width: 100%;
            padding: .6rem .75rem;
            border: 1.5px solid var(--border);
            border-radius: .6rem;
            font-size: .82rem;
            font-family: inherit;
            resize: none;
            transition: border-color .15s;
        }

            .modal-textarea:focus {
                outline: none;
                border-color: var(--coral);
            }

        .char-count {
            font-size: .7rem;
            color: var(--text);
            text-align: right;
            margin-top: .2rem;
        }

        .modal-actions {
            display: flex;
            gap: .6rem;
            margin-top: 1.25rem;
        }

        .btn-modal-cancel {
            flex: 1;
            padding: .55rem;
            border-radius: .6rem;
            font-size: .82rem;
            font-weight: 600;
            border: 1.5px solid var(--border);
            background: #fff;
            color: var(--text);
            cursor: pointer;
            transition: background .15s;
        }

            .btn-modal-cancel:hover {
                background: var(--mist);
            }

        .btn-modal-submit {
            flex: 1;
            padding: .55rem;
            border-radius: .6rem;
            font-size: .82rem;
            font-weight: 700;
            background: var(--coral);
            color: #fff;
            border: none;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-modal-submit:hover:not(:disabled) {
                background: var(--coral-d);
            }

            .btn-modal-submit:disabled {
                background: #cbd5e1;
                cursor: not-allowed;
            }

        /* ── Toast ────────────────────────────── */
        .toast {
            position: fixed;
            top: 1.25rem;
            right: 1.25rem;
            padding: .75rem 1.1rem;
            border-radius: .7rem;
            box-shadow: 0 8px 24px rgba(15,20,40,.15);
            z-index: 2000;
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .82rem;
            font-weight: 600;
            transform: translateY(-80px);
            opacity: 0;
            transition: transform .3s, opacity .3s;
        }

            .toast.show {
                transform: translateY(0);
                opacity: 1;
            }

        .toast-success {
            background: #dcfce7;
            color: #166534;
            border-left: 3px solid #16a34a;
        }

        .toast-warning {
            background: #fef3c7;
            color: #92400e;
            border-left: 3px solid #d97706;
        }

        .toast-error {
            background: #fee2e2;
            color: #991b1b;
            border-left: 3px solid #dc2626;
        }

        /* ── Empty state ──────────────────────── */
        .empty-state {
            text-align: center;
            padding: 3rem 1.5rem;
            background: var(--mist);
            border-radius: .8rem;
        }

            .empty-state i {
                font-size: 2.5rem;
                color: #cbd5e1;
                display: block;
                margin-bottom: .75rem;
            }

            .empty-state p {
                font-size: .84rem;
                color: var(--text);
            }

        @@media (max-width: 768px) {
            .cc-layout {
                flex-direction: column;
            }

            .cc-sidebar {
                width: 100%;
                position: static;
                max-height: none;
            }

            .cc-strip {
                flex-wrap: wrap;
            }

            .cc-strip-cell {
                min-width: 50%;
            }
        }
    </style>
}

<div id="toast" class="toast"><span id="toastMessage"></span></div>

<!-- Rating Modal -->
<div id="ratingModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-head">
            <h3 class="modal-title">Rate This Chapter</h3>
            <button id="closeModal" class="modal-close"><i class="material-icons">close</i></button>
        </div>
        <p style="font-size:.82rem;color:var(--text);margin-bottom:.75rem;">
            How would you rate your learning experience with this chapter?
        </p>
        <div class="star-rating" id="starRating">
            <span class="star" data-rating="1">★</span>
            <span class="star" data-rating="2">★</span>
            <span class="star" data-rating="3">★</span>
            <span class="star" data-rating="4">★</span>
            <span class="star" data-rating="5">★</span>
        </div>
        <p id="ratingText" class="rating-label"></p>
        <div style="margin-top:1rem;">
            <label for="reviewText" class="modal-label">Review <span style="font-weight:400;color:var(--text);">(optional)</span></label>
            <textarea id="reviewText" class="modal-textarea" rows="3" maxlength="500"
                      placeholder="Share your thoughts about this chapter…"></textarea>
            <p class="char-count"><span id="charCount">0</span>/500</p>
        </div>
        <div class="modal-actions">
            <button id="cancelRating" class="btn-modal-cancel">Cancel</button>
            <button id="submitRating" class="btn-modal-submit" disabled>Submit Rating</button>
        </div>
    </div>
</div>

<div class="cc-wrap p-4 md:p-6">

    <!-- Hero banner -->
    <div class="cc-hero mb-6">
        <a href="@Url.Action("MyCourses", "Course")" class="cc-back">
            <i class="material-icons">arrow_back</i> My Courses
        </a>
        <span class="cc-code">@course.CourseCode</span>
        <h1 class="cc-title">@course.CourseName</h1>
        <p class="cc-desc">@course.CourseDescription</p>
    </div>

    <!-- Stat strip -->
    <div class="cc-strip mb-5">
        <div class="cc-strip-cell">
            <div class="cc-strip-icon" style="background:#fef2f2;">
                <i class="material-icons" style="color:var(--coral);">layers</i>
            </div>
            <div>
                <div class="cc-strip-val">@ViewBag.TotalChapters</div>
                <div class="cc-strip-lbl">Total Chapters</div>
            </div>
        </div>
        <div class="cc-strip-cell">
            <div class="cc-strip-icon" style="background:#dcfce7;">
                <i class="material-icons" style="color:#16a34a;">check_circle</i>
            </div>
            <div>
                <div class="cc-strip-val">@ViewBag.CompletedChapters</div>
                <div class="cc-strip-lbl">Completed</div>
            </div>
        </div>
        <div class="cc-strip-cell" style="flex:2;flex-direction:column;align-items:flex-start;justify-content:center;">
            <div style="display:flex;justify-content:space-between;width:100%;margin-bottom:.35rem;">
                <span style="font-size:.72rem;font-weight:600;color:var(--text);">Progress</span>
                <span style="font-size:.72rem;font-weight:700;color:var(--ink);">@ViewBag.ProgressPercentage%</span>
            </div>
            <div class="cc-progress-track" style="width:100%;">
                <div class="cc-progress-fill" style="width:@(ViewBag.ProgressPercentage)%;"></div>
            </div>
        </div>
    </div>

    <div class="cc-layout">

        <!-- ── Main content ── -->
        <div class="cc-main">

            <!-- Chapter content card -->
            <div class="cc-card mb-5">
                <div class="cc-card-head">
                    <h2 class="cc-card-title">
                        @if (viewingUncategorized)
                        {
                            <span>Uncategorized Content</span>
                        }
                        else if (currentChapter != null)
                        {

                            <span>@currentChapter.Title</span>
                        }
                        else
                        {

                            <span>Course Content</span>
                        }
                    </h2>
                    @if (currentChapter != null && IsChapterRated(currentChapter.Id))
                    {
                        var rating = chapterRatings[currentChapter.Id];
                        <div style="display:flex;align-items:center;gap:.4rem;">
                            <span style="font-size:.72rem;color:var(--text);">Your rating:</span>
                            <div class="star-rating rating-display" style="gap:2px;margin:0;">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="star readonly @(i <= rating.Rating ? "selected" : "")">★</span>
                                }
                            </div>
                            <button style="font-size:.72rem;color:var(--coral);background:none;border:none;cursor:pointer;padding:0;"
                                    onclick="openRatingModal(@currentChapter.Id, @course.Id, true)">
                                Edit
                            </button>
                        </div>
                    }
                </div>

                <div class="cc-card-body">
                    @if (contentDictionary.Count == 0 && currentAssessments.Count == 0)
                    {
                        <div class="empty-state">
                            <i class="material-icons">folder_open</i>
                            <p>No materials available in this section.</p>
                        </div>
                    }
                    else
                    {
                        <!-- Assessments -->
                        @if (currentAssessments.Count > 0)
                        {
                            <h3 style="font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#94a3b8;margin-bottom:.85rem;">
                                Assessments
                            </h3>
                            @foreach (var assessment in currentAssessments)
                            {
                                var now = DateTime.Now;
                                var isActive = assessment.StartDateTime <= now && assessment.EndDateTime >= now;
                                dynamic attempt = null;
                                if (assessmentData != null)
                                {
                                    foreach (var item in assessmentData)
                                    {
                                        if (item.Assessment.Id == assessment.Id) { attempt = item.StudentAttempt; break; }
                                    }
                                }
                                var timeRemaining = assessment.EndDateTime - now;
                                string status = "Not Available"; string statusPill = "pill-slate";
                                if (isActive)
                                {
                                    if (attempt != null)
                                    {
                                        if (attempt.Status == "Submitted" || attempt.Status == "TimedOut")
                                        { status = "Completed"; statusPill = "pill-green"; }
                                        else if (attempt.Status == "InProgress")
                                        { status = "In Progress"; statusPill = "pill-amber"; }
                                    }
                                    else { status = "Available"; statusPill = "pill-blue"; }
                                }
                                string actionText = "Start"; string actionUrl = $"/StudentAssessment/Details/{assessment.Id}";
                                if (attempt != null)
                                {
                                    if (attempt.Status == "Submitted" || attempt.Status == "TimedOut")
                                    { actionText = "View Results"; actionUrl = $"/StudentAssessment/Results/{attempt.Id}"; }
                                    else if (attempt.Status == "InProgress")
                                    { actionText = "Continue"; actionUrl = $"/StudentAssessment/Take/{attempt.Id}"; }
                                }
                                <div class="asmnt-row">
                                    <div class="asmnt-icon"><i class="material-icons">assignment</i></div>
                                    <div style="flex:1;min-width:0;">
                                        <p class="asmnt-name">@assessment.Assessment.Name</p>
                                        <p class="asmnt-meta">
                                            @assessment.StartDateTime.ToString("MMM dd") → @assessment.EndDateTime.ToString("MMM dd, yyyy HH:mm")
                                            &nbsp;·&nbsp; @assessment.DurationMinutes min
                                        </p>
                                        @if (isActive && timeRemaining.TotalHours < 24 && (attempt == null || attempt.Status == "InProgress"))
                                        {
                                            <p class="asmnt-countdown">
                                                <i class="material-icons" style="font-size:.75rem;vertical-align:middle;">timer</i>
                                                <span class="countdown" data-end="@assessment.EndDateTime.ToString("o")">@FormatTimeRemaining(timeRemaining)</span>
                                            </p>
                                        }
                                    </div>
                                    <span class="pill @statusPill">@status</span>
                                    @if (isActive)
                                    {
                                        <a href="@actionUrl" class="btn-asmnt">
                                            <i class="material-icons">arrow_forward</i>@actionText
                                        </a>
                                    }
                                </div>
                            }
                            <div style="margin-bottom:1.5rem;"></div>
                        }

                        <!-- Materials -->
                        @if (contentDictionary.Count > 0)
                        {
                            <h3 style="font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#94a3b8;margin-bottom:.85rem;">
                                Materials
                            </h3>
                            @if (sortedCategories.Count > 1)
                            {
                                <div class="cc-tabs">
                                    @for (int i = 0; i < sortedCategories.Count; i++)
                                    {
                                        var cat = sortedCategories[i];
                                        <button class="cc-tab category-tab @(i == 0 ? "active" : "")"
                                                data-category="@cat.ToLower().Replace(" ", "-")">
                                            @cat
                                            <span class="tab-count">@contentDictionary[cat].Count</span>
                                        </button>
                                    }
                                </div>
                            }
                            @for (int i = 0; i < sortedCategories.Count; i++)
                            {
                                var cat = sortedCategories[i];
                                var catId = cat.ToLower().Replace(" ", "-");
                                <div class="category-content @(i == 0 ? "" : "hidden")" id="category-@catId">
                                    <div class="file-grid">
                                        @foreach (dynamic content in contentDictionary[cat])
                                        {
                                            string fileType = Convert.ToString(content.FileType);
                                            string title = Convert.ToString(content.Title);
                                            string fileSize = Convert.ToString(content.FileSizeFormatted);
                                            DateTime cAt = content.CreatedAt;
                                            string desc = Convert.ToString(content.Description);
                                            <div class="file-card">
                                                <div class="file-icon @GetFileColorClass(fileType)">
                                                    <i class="material-icons">@GetFileIcon(fileType)</i>
                                                </div>
                                                <div style="flex:1;min-width:0;">
                                                    <p class="file-name">@title</p>
                                                    <p class="file-meta">@fileSize &nbsp;·&nbsp; @cAt.ToString("MMM dd, yyyy")</p>
                                                    @if (!string.IsNullOrEmpty(desc))
                                                    {
                                                        <p class="file-desc">@desc</p>
                                                    }
                                                </div>
                                                @if (content.FileType?.ToLower() == "pdf")
                                                {
                                                    <a href="@Url.Action("ViewPdf", "DocumentViewer", new { filePath = content.FilePath })"
                                                       class="file-action"><i class="material-icons">visibility</i></a>
                                                }
                                                else
                                                {
                                                    <a href="@GetFileUrl(content)" target="_blank" class="file-action">
                                                        <i class="material-icons">open_in_new</i>
                                                    </a>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>
            </div>

            <!-- Active assessments table -->
            @if (assessmentData != null && assessmentData.Count > 0)
            {
                <div id="assessmentsTab" class="cc-card mb-5">
                    <div class="cc-card-head">
                        <h2 class="cc-card-title">Active Assessments</h2>
                        <span class="pill pill-coral">@assessmentData.Count active</span>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="cc-table">
                            <thead>
                                <tr>
                                    <th>Assessment</th>
                                    <th>Academic Year</th>
                                    <th>Duration</th>
                                    <th>Available Until</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in assessmentData)
                                {
                                    var assessment = item.Assessment;
                                    var attempt = item.StudentAttempt;
                                    var tr = item.TimeRemaining;
                                    string st = "Not Started"; string stPill = "pill-blue";
                                    string atText = "Start Assessment"; string atUrl = $"/StudentAssessment/Details/{assessment.Id}";
                                    if (attempt != null)
                                    {
                                        if (attempt.Status == "Submitted" || attempt.Status == "TimedOut")
                                        { st = "Completed"; stPill = "pill-green"; atText = "View Results"; atUrl = $"/StudentAssessment/Results/{attempt.Id}"; }
                                        else if (attempt.Status == "InProgress")
                                        { st = "In Progress"; stPill = "pill-amber"; atText = "Continue"; atUrl = $"/StudentAssessment/Take/{attempt.Id}"; }
                                    }
                                    <tr>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:.5rem;">
                                                <i class="material-icons" style="font-size:1rem;color:#d97706;">assignment</i>
                                                <span style="font-weight:600;">@assessment.Assessment.Name</span>
                                            </div>
                                            @if (tr.TotalHours < 24 && st != "Completed")
                                            {
                                                <div style="font-size:.7rem;font-weight:600;color:var(--coral);margin-top:.2rem;">
                                                    <i class="material-icons" style="font-size:.75rem;vertical-align:middle;">timer</i>
                                                    <span class="countdown" data-end="@assessment.EndDateTime.ToString("o")">@FormatTimeRemaining(tr)</span>
                                                </div>
                                            }
                                        </td>
                                        <td>@assessment.AcademicYear.YearValue</td>
                                        <td>@assessment.DurationMinutes min</td>
                                        <td>@assessment.EndDateTime.ToString("MMM dd, yyyy HH:mm")</td>
                                        <td><span class="pill @stPill">@st</span></td>
                                        <td style="text-align:center;">
                                            <a href="@atUrl" class="btn-asmnt" style="font-size:.72rem;padding:.3rem .7rem;">@atText</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <!-- ── Sidebar ── -->
        <div class="cc-sidebar">
            <div class="cc-card" style="flex:1;">
                <div class="sidebar-head">
                    <i class="material-icons" style="font-size:1.1rem;color:var(--coral);">menu_book</i>
                    <span class="sidebar-head-title">Chapters</span>
                </div>

                <div class="chapter-list">
                    <!-- Uncategorized -->
                    @if ((uncategorizedContent != null && uncategorizedContent.Count > 0) ||
                                        (uncategorizedAssessments != null && uncategorizedAssessments.Count > 0))
                    {
                        <a href="@Url.Action("ViewCourseContent", "Course", new { id = course.Id, chapterId = -1 })"
                           class="chapter-item @(viewingUncategorized ? "active" : "")">
                            <div class="ch-indicator ind-open">
                                <i class="material-icons">folder</i>
                            </div>
                            <div style="flex:1;min-width:0;">
                                <p class="ch-name">Uncategorized</p>
                            </div>
                            <span class="ch-count">@(uncategorizedContent.Count + uncategorizedAssessments.Count)</span>
                        </a>
                    }

                    @foreach (var chapter in chapters)
                    {
                        var isActive = selectedChapterId == chapter.Id;
                        var isComplete = IsChapterComplete(chapter.Id);
                        var isRated = IsChapterRated(chapter.Id);
                        var isAccessible = IsChapterAccessible(chapter.Id);
                        var cCount = (contentByChapter.ContainsKey(chapter.Id) ? contentByChapter[chapter.Id].Count : 0)
                        + (assessmentsByChapter.ContainsKey(chapter.Id) ? assessmentsByChapter[chapter.Id].Count : 0);
                        var indClass = (isComplete && isRated) ? "ind-done"
                        : isActive ? "ind-current"
                        : isAccessible ? "ind-open"
                        : "ind-locked";
                        var indIcon = (isComplete && isRated) ? "done"
                        : isActive ? "play_arrow"
                        : isAccessible ? "radio_button_unchecked"
                        : "lock";

                        if (isAccessible)
                        {
                            <a href="@Url.Action("ViewCourseContent", "Course", new { id = course.Id, chapterId = chapter.Id })"
                               class="chapter-item @(isActive ? "active" : "")">
                                <div class="ch-indicator @indClass"><i class="material-icons">@indIcon</i></div>
                                <div style="flex:1;min-width:0;">
                                    <p class="ch-name">@chapter.Title</p>
                                    <div class="ch-tags">
                                        @if (ChapterHasAssessments(chapter.Id))
                                        {
                                            <span class="ch-tag tag-assessment">Assessment</span>
                                        }
                                        @if (isRated)
                                        {
                                            var r = chapterRatings[chapter.Id];
                                            <span class="ch-stars">@(new string('★', r.Rating))</span>
                                        }
                                        else if (isComplete)
                                        {
                                            <span class="ch-tag tag-rate">Rate Required</span>
                                        }
                                    </div>
                                </div>
                                <span class="ch-count">@cCount</span>
                            </a>
                        }
                        else
                        {
                            <div class="chapter-item chapter-locked" title="Complete and rate previous chapters to unlock">
                                <div class="ch-indicator ind-locked"><i class="material-icons">lock</i></div>
                                <div style="flex:1;min-width:0;">
                                    <p class="ch-name">@chapter.Title</p>
                                    @if (ChapterHasAssessments(chapter.Id))
                                    {
                                        <div class="ch-tags"><span class="ch-tag tag-assessment">Assessment</span></div>
                                    }
                                </div>
                                <span class="ch-count">@cCount</span>
                            </div>
                        }
                    }

                    @if (assessmentData != null && assessmentData.Count > 0)
                    {
                        <a href="#assessmentsTab" class="chapter-item" id="scrollToAssessments">
                            <div class="ch-indicator" style="background:#fef3c7;">
                                <i class="material-icons" style="font-size:.8rem;color:#d97706;">assignment</i>
                            </div>
                            <div style="flex:1;">
                                <p class="ch-name">Active Assessments</p>
                            </div>
                            <span class="ch-count" style="background:#fee2e2;color:var(--coral);">@assessmentData.Count</span>
                        </a>
                    }
                </div>

                <!-- Actions -->
                @if (currentChapter != null && IsChapterAccessible(currentChapter.Id))
                {
                    <div class="sidebar-actions">
                        @if (!IsChapterRated(currentChapter.Id))
                        {
                            <div class="req-banner req-purple" style="margin-bottom:.75rem;">
                                <i class="material-icons">star_border</i>
                                <span>Rate this chapter to unlock the next one.</span>
                            </div>
                            <button onclick="openRatingModal(@currentChapter.Id, @course.Id, false)"
                                    class="btn-rate">
                                <i class="material-icons">star</i> Rate This Chapter
                            </button>
                        }

                        @if (!IsChapterComplete(currentChapter.Id))
                        {
                            @if (ChapterHasAssessments(currentChapter.Id) && !currentChapterHasAttemptedAssessments)
                            {
                                <div class="req-banner req-amber" style="margin-bottom:.75rem;">
                                    <i class="material-icons">warning</i>
                                    <span>Attempt all assessments before completing this chapter.</span>
                                </div>
                                <button class="btn-complete" disabled>
                                    <i class="material-icons">done</i> Complete Assessments First
                                </button>
                            }
                            else if (!IsChapterRated(currentChapter.Id))
                            {
                                <button class="btn-complete" disabled>
                                    <i class="material-icons">done</i> Rate Chapter First
                                </button>
                            }
                            else
                            {
                                <button id="markChapterComplete"
                                        data-chapter-id="@currentChapter.Id"
                                        data-course-id="@course.Id"
                                        class="btn-complete">
                                    <i class="material-icons">done</i> Mark as Complete
                                </button>
                            }
                        }
                        else
                        {
                            <div class="completed-note">
                                <i class="material-icons">check_circle</i>
                                <span>Chapter complete! Move on to the next one.</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div><!-- /cc-layout -->
</div><!-- /cc-wrap -->
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/js/lightbox.min.js"></script>
    <script>
        let currentRatingChapterId = 0;
        let currentRatingCourseId  = 0;
        let selectedRating = 0;
        let isEditMode     = false;

        $(document).ready(function () {

            @if (TempData["Error"] != null)
            {
                <text>showToast('@TempData["Error"]',   'error');  </text>
            }
            @if (TempData["Warning"] != null)
            {
                <text>showToast('@TempData["Warning"]', 'warning');</text>
            }
            @if (TempData["Success"] != null)
            {
                <text>showToast('@TempData["Success"]', 'success');</text>
            }

            function showToast(message, type) {
                window.showAppToast(message, type || 'info');
            }
            window.showToast = showToast;

            // Category tabs
            $('.category-tab').on('click', function () {
                const cat = $(this).data('category');
                $('.category-tab').removeClass('active');
                $(this).addClass('active');
                $('.category-content').addClass('hidden');
                $('#category-' + cat).removeClass('hidden');
            });

            lightbox.option({ resizeDuration: 200, wrapAround: true });

            // Countdown timers
            function updateCountdowns() {
                $('.countdown').each(function () {
                    const end  = new Date($(this).data('end'));
                    const diff = end - new Date();
                    if (diff <= 0) { $(this).text('Expired'); return; }
                    const h = String(Math.floor(diff / 3600000)).padStart(2, '0');
                    const m = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
                    const s = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
                    $(this).text(`${h}:${m}:${s}`);
                });
            }
            updateCountdowns();
            setInterval(updateCountdowns, 1000);

            // Mark chapter complete
            $('#markChapterComplete').on('click', function () {
                const chapterId = $(this).data('chapter-id');
                const courseId  = $(this).data('course-id');
                const $btn = $(this);
                $btn.prop('disabled', true).html('<i class="material-icons">hourglass_empty</i> Processing…');
                $.ajax({
                    url: '/Course/MarkChapterComplete', type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ chapterId, courseId }),
                    success: function (response) {
                        showToast('Chapter marked as complete!', 'success');
                        if (response.nextChapterId) {
                            setTimeout(() => window.location.href = `/Course/ViewCourseContent/${courseId}?chapterId=${response.nextChapterId}`, 1500);
                        } else {
                            setTimeout(() => location.reload(), 1500);
                        }
                    },
                    error: function (xhr) {
                        $btn.prop('disabled', false).html('<i class="material-icons">done</i> Mark as Complete');
                        const msg = xhr.responseJSON?.message || 'An unknown error occurred';
                        showToast('Error: ' + msg, 'error');
                    }
                });
            });

            // Locked chapters
            $('.chapter-locked').on('click', function (e) {
                e.preventDefault();
                showToast('Complete and rate previous chapters first.', 'warning');
            });

            // Scroll to assessments
            $('#scrollToAssessments').on('click', function (e) {
                e.preventDefault();
                $('html, body').animate({ scrollTop: $('#assessmentsTab').offset().top - 20 }, 500);
            });

            // Star hover & click
            $('#starRating .star').hover(function () {
                updateStarDisplay(parseInt($(this).data('rating')), true);
            }, function () {
                updateStarDisplay(selectedRating, false);
            }).click(function () {
                selectedRating = parseInt($(this).data('rating'));
                updateStarDisplay(selectedRating, false);
                updateRatingText(selectedRating);
                $('#submitRating').prop('disabled', false);
            });

            // Char count
            $('#reviewText').on('input', function () {
                const len = Math.min($(this).val().length, 500);
                $(this).val($(this).val().substring(0, 500));
                $('#charCount').text(len);
            });

            // Modal close
            $('#closeModal, #cancelRating').click(closeRatingModal);
            $('#ratingModal').click(function (e) { if (e.target === this) closeRatingModal(); });
            $('#submitRating').click(submitChapterRating);
        });

        function openRatingModal(chapterId, courseId, editMode = false) {
            currentRatingChapterId = chapterId;
            currentRatingCourseId  = courseId;
            isEditMode = editMode;
            selectedRating = 0;
            $('#reviewText').val(''); $('#charCount').text('0');
            updateStarDisplay(0, false); $('#ratingText').text('');
            $('#submitRating').prop('disabled', true);
            if (editMode) {
                $.ajax({
                    url: '/Course/GetChapterRating', type: 'GET',
                    data: { chapterId, courseId },
                    success: function (r) {
                        if (r.hasRated) {
                            selectedRating = r.rating;
                            updateStarDisplay(selectedRating, false);
                            updateRatingText(selectedRating);
                            $('#reviewText').val(r.reviewText || '');
                            $('#charCount').text((r.reviewText || '').length);
                            $('#submitRating').prop('disabled', false);
                        }
                    },
                    error: () => window.showToast('Error loading existing rating', 'error')
                });
            }
            $('#ratingModal').addClass('show');
        }

        function closeRatingModal() {
            $('#ratingModal').removeClass('show');
            selectedRating = 0; currentRatingChapterId = 0;
            currentRatingCourseId = 0; isEditMode = false;
        }

        function updateStarDisplay(rating, isHover) {
            $('#starRating .star').each(function () {
                $(this).removeClass('selected hovered');
                if (parseInt($(this).data('rating')) <= rating)
                    $(this).addClass(isHover ? 'hovered' : 'selected');
            });
        }

        function updateRatingText(rating) {
            const texts = { 1: 'Poor', 2: 'Fair', 3: 'Good', 4: 'Very Good', 5: 'Excellent' };
            $('#ratingText').text(texts[rating] || '');
        }

        function submitChapterRating() {
            if (!selectedRating) { window.showToast('Please select a rating', 'warning'); return; }
            $('#submitRating').prop('disabled', true).text('Submitting…');
            $.ajax({
                url: '/Course/SubmitChapterRating', type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    chapterId: currentRatingChapterId,
                    courseId:  currentRatingCourseId,
                    rating:    selectedRating,
                    reviewText: $('#reviewText').val().trim()
                }),
                success: function (r) {
                    closeRatingModal();
                    window.showToast(r.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                },
                error: function (xhr) {
                    $('#submitRating').prop('disabled', false).text('Submit Rating');
                    window.showToast('Error: ' + (xhr.responseJSON?.message || 'An error occurred'), 'error');
                }
            });
        }
    </script>
}

@functions {
    string GetFileIcon(string fileType)
    {
        if (string.IsNullOrEmpty(fileType)) return "insert_drive_file";
        return fileType.ToLower() switch
        {
            "pdf" => "picture_as_pdf",
            "doc" or "docx" => "description",
            "ppt" or "pptx" => "slideshow",
            "xls" or "xlsx" => "table_chart",
            "txt" => "text_snippet",
            "zip" or "rar" => "folder_zip",
            "mp4" or "avi" or "mov" => "movie",
            "mp3" or "wav" => "music_note",
            "jpg" or "jpeg" or "png" or "gif" => "image",
            "url" => "link",
            _ => "insert_drive_file"
        };
    }
    string GetFileColorClass(string fileType)
    {
        if (string.IsNullOrEmpty(fileType)) return "bg-slate-100 text-slate-600";
        return fileType.ToLower() switch
        {
            "pdf" => "bg-red-50 text-red-500",
            "doc" or "docx" => "bg-blue-50 text-blue-500",
            "ppt" or "pptx" => "bg-orange-50 text-orange-500",
            "xls" or "xlsx" => "bg-green-50 text-green-500",
            "txt" => "bg-slate-100 text-slate-600",
            "zip" or "rar" => "bg-purple-50 text-purple-500",
            "mp4" or "avi" or "mov" => "bg-pink-50 text-pink-500",
            "mp3" or "wav" => "bg-indigo-50 text-indigo-500",
            "jpg" or "jpeg" or "png" or "gif" => "bg-cyan-50 text-cyan-500",
            "url" => "bg-blue-50 text-blue-500",
            _ => "bg-slate-100 text-slate-600"
        };
    }
    string GetFileUrl(dynamic content)
    {
        string filePath = Convert.ToString(content.FilePath);
        if (string.IsNullOrEmpty(filePath)) return "#";
        string fileType = Convert.ToString(content.FileType);
        return fileType?.ToLower() == "url" ? filePath : Url.Content("~/" + filePath);
    }
    string FormatTimeRemaining(TimeSpan time)
        => $"{Math.Floor(time.TotalHours):00}:{time.Minutes:00}:{time.Seconds:00}";
}
