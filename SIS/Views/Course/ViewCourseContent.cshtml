                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(30,45,94,.1);
                border-color: var(--coral);
            }

        .file-icon {
            width: 40px;
            height: 40px;
            border-radius: .55rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .file-icon i {
                font-size: 1.1rem;
            }

        .file-name {
            font-size: .82rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: .2rem;
            line-height: 1.35;
        }

        .file-meta {
            font-size: .7rem;
            color: var(--text);
        }

        .file-desc {
            font-size: .75rem;
            color: var(--text);
            margin-top: .25rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .file-action {
            margin-left: auto;
            flex-shrink: 0;
            align-self: center;
            color: var(--text);
            transition: color .15s;
        }

        .file-card:hover .file-action {
            color: var(--coral);
        }

        .file-action i {
            font-size: 1.1rem;
        }

        /* ── Assessment row ───────────────────── */
        .asmnt-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: .875rem 1rem;
            background: var(--mist);
            border: 1.5px solid var(--border);
            border-radius: .75rem;
            margin-bottom: .6rem;
            transition: border-color .15s;
        }

            .asmnt-row:hover {
                border-color: #f59e0b;
            }

        .asmnt-icon {
            width: 36px;
            height: 36px;
            border-radius: .55rem;
