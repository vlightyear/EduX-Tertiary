@{
    var course = ViewBag.Course;
    var chapters = ViewBag.Chapters;
    var uncategorizedContent = ViewBag.UncategorizedContent;
    var contentByChapter = ViewBag.ContentByChapter;
    var assessmentsByChapter = ViewBag.AssessmentsByChapter;
    var uncategorizedAssessments = ViewBag.UncategorizedAssessments;
    var assessmentData = ViewBag.AssessmentData;
    var selectedChapterId = ViewBag.SelectedChapterId;
    var viewingUncategorized = ViewBag.ViewingUncategorized;
    var studentId = ViewBag.StudentId;
    var chapterProgress = ViewBag.ChapterProgress;
    var accessibleChapters = ViewBag.AccessibleChapters;
    var chapterRatings = ViewBag.ChapterRatings;

    var currentContent = viewingUncategorized
        ? uncategorizedContent
        : (contentByChapter.ContainsKey(selectedChapterId) ? contentByChapter[selectedChapterId] : new List<dynamic>());

    var currentAssessments = viewingUncategorized
        ? uncategorizedAssessments
        : (assessmentsByChapter.ContainsKey(selectedChapterId) ? assessmentsByChapter[selectedChapterId] : new List<dynamic>());

    var contentDictionary = new Dictionary<string, List<object>>();
    if (currentContent != null)
    {
        foreach (var content in currentContent)
        {
            string category = content.ContentCategory ?? "General";
            if (!contentDictionary.ContainsKey(category))
                contentDictionary[category] = new List<object>();
            contentDictionary[category].Add(content);
        }
    }
    var sortedCategories = contentDictionary?.Keys.OrderBy(k => k).ToList() ?? new List<string>();

    dynamic currentChapter = null;
    if (!viewingUncategorized && chapters != null)
    {
        foreach (var chapter in chapters)
        {
            if (chapter.Id == selectedChapterId) { currentChapter = chapter; break; }
        }
    }

    bool IsChapterAccessible(int chapterId) => accessibleChapters?.Contains(chapterId) ?? false;
    bool IsChapterComplete(int chapterId) => chapterProgress?.ContainsKey(chapterId) == true && chapterProgress[chapterId];
    bool IsChapterRated(int chapterId) => chapterRatings?.ContainsKey(chapterId) == true && chapterRatings[chapterId].HasRated;
    bool ChapterHasAssessments(int chapterId)
    {
        if (assessmentsByChapter?.ContainsKey(chapterId) == true)
        {
            var a = assessmentsByChapter[chapterId];
            return a != null && a.Count > 0;
        }
        return false;
    }

    bool currentChapterHasAttemptedAssessments = false;
    if (currentChapter != null && ChapterHasAssessments(currentChapter.Id))
    {
        var chapterAssessments = assessmentsByChapter[currentChapter.Id];
        currentChapterHasAttemptedAssessments = true;
        foreach (var assessment in chapterAssessments)
        {
            if (assessment.IsPublished)
            {
                bool hasAttempt = false;
                if (assessmentData != null)
                {
                    foreach (var item in assessmentData)
                    {
                        if (item.Assessment.Id == assessment.Id && item.StudentAttempt != null) { hasAttempt = true; break; }
                    }
                }
                if (!hasAttempt) { currentChapterHasAttemptedAssessments = false; break; }
            }
        }
    }
    bool currentChapterIsRated = currentChapter != null && IsChapterRated(currentChapter.Id);
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/css/lightbox.min.css" />
    <style>
        :root {
            --coral: #e85c5c;
            --coral-d: #c94040;
            --navy: #1e2d5e;
            --navy-l: #2e3f7a;
            --mist: #f5f7fa;
            --border: #e8ecf2;
            --ink: #1a1f2e;
            --text: #475569;
        }

        .cc-wrap {
            font-family: 'DM Sans', sans-serif;
        }

        /* ── Hero ─────────────────────────────── */
        .cc-hero {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-l) 55%, #3a2060 100%);
            border-radius: 1.25rem;
            padding: 1.75rem 2rem 4rem;
            position: relative;
            overflow: hidden;
            margin-bottom: 0;
        }

            .cc-hero::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 180px;
                height: 180px;
                background: rgba(232,92,92,.15);
                border-radius: 50%;
                pointer-events: none;
            }

        .cc-back {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            color: rgba(255,255,255,.6);
            font-size: .8rem;
            font-weight: 600;
            text-decoration: none;
            margin-bottom: .85rem;
            transition: color .15s;
        }

            .cc-back:hover {
                color: #fff;
            }

            .cc-back i {
                font-size: 1rem;
            }

        .cc-code {
            display: inline-block;
            background: rgba(232,92,92,.25);
            border: 1px solid rgba(232,92,92,.4);
            color: #fca5a5;
            font-size: .7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .08em;
            padding: .25rem .7rem;
            border-radius: .4rem;
            margin-bottom: .5rem;
        }

        .cc-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.6rem;
            color: #fff;
            line-height: 1.2;
            margin-bottom: .35rem;
        }

        .cc-desc {
            font-size: .82rem;
            color: rgba(255,255,255,.55);
            max-width: 520px;
        }

        /* ── Stat strip ───────────────────────── */
        .cc-strip {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            box-shadow: 0 4px 24px rgba(30,45,94,.07);
