            }

            .cc-tab.active .tab-count {
                background: #fef2f2;
                color: var(--coral);
            }

        /* ── File cards ───────────────────────── */
        .file-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: .85rem;
        }

        .file-card {
            background: var(--mist);
            border: 1.5px solid var(--border);
