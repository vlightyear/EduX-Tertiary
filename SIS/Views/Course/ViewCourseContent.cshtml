        }

        .cc-card-head {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .cc-card-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.15rem;
            color: var(--ink);
        }

        .cc-card-body {
            padding: 1.5rem;
        }

        /* ── Assessment-required banner ───────── */
        .req-banner {
            display: flex;
            align-items: flex-start;
            gap: .6rem;
            padding: .75rem 1rem;
            border-radius: .65rem;
            font-size: .8rem;
            margin-bottom: 1rem;
        }

            .req-banner i {
                font-size: 1rem;
                flex-shrink: 0;
                margin-top: .05rem;
            }

        .req-amber {
            background: #fef3c7;
            color: #92400e;
            border: 1px solid #fde68a;
        }

        .req-purple {
            background: #f3e8ff;
            color: #7c3aed;
            border: 1px solid #ddd6fe;
        }

        /* ── Category tabs ────────────────────── */
        .cc-tabs {
            display: flex;
            gap: 0;
            border-bottom: 2px solid var(--border);
            margin-bottom: 1.25rem;
        }

        .cc-tab {
            padding: .55rem 1rem;
            font-size: .8rem;
            font-weight: 600;
            color: var(--text);
            border-bottom: 2px solid transparent;
            margin-bottom: -2px;
