@model SIS.Models.Payments.MockPaymentViewModel

@{
    ViewData["Title"] = "Payment Gateway";
}

<div class="min-h-screen bg-slate-50 p-6">
    <!-- Breadcrumb -->
    <nav class="mb-6">
        <ol class="flex items-center gap-2 text-sm">
            <li><a href="@Url.Action("StudentFinance")" class="text-cyan-950 hover:text-cyan-900">Fee Statement</a></li>
            <li class="text-slate-400">/</li>
            <li class="text-slate-600">Payment Gateway</li>
        </ol>
    </nav>

    <div class="flex flex-col lg:flex-row gap-6">
        <!-- Payment Form Section -->
        <div class="lg:flex-1">
            <div class="bg-white rounded-xl shadow-sm">
                <div class="p-6 border-b border-slate-100">
                    <div class="flex items-center gap-2">
                        <i class="material-icons text-cyan-950">credit_card</i>
                        <h1 class="text-xl font-semibold text-slate-800">Payment Details</h1>
                    </div>
                </div>

                <div class="p-6">
                    <form id="paymentForm" asp-action="ProcessMockPayment" method="post" class="space-y-6">
                        <input type="hidden" name="transactionReference" value="@Model.TransactionReference" />

                        <!-- Amount Section -->
                        <div class="max-w-md">
                            <label class="block text-sm font-medium text-slate-700 mb-2">Amount to Pay (ZMW)</label>
                            <div class="relative rounded-lg shadow-sm">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="text-slate-500">ZMW</span>
                                </div>
                                <input type="number"
                                       class="block w-full pl-12 pr-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-cyan-950/20 focus:border-cyan-950"
                                       name="amount"
                                       min="1"
                                       max="@Model.Amount"
                                       step="0.01"
                                       value="@Model.Amount"
                                       required />
                            </div>
                            @if (!Model.IsRegistered)
                            {
                                <p class="mt-2 flex items-center gap-1 text-sm text-red-600">
                                    <i class="material-icons text-sm">info</i>
                                    Minimum payment required: ZMW @Model.MinRegistrationPayment.ToString("N2")
                                </p>
                            }
                        </div>

                        <!-- Card Information -->
                        <div class="space-y-6">
                            <h2 class="text-lg font-medium text-slate-800">Card Information</h2>

                            <div class="space-y-4">
                                <!-- Card Number -->
                                <div>
                                    <label class="block text-sm font-medium text-slate-700 mb-2">Card Number</label>
                                    <div class="relative">
                                        <input type="text"
                                               class="block w-full pr-10 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-cyan-950/20 focus:border-cyan-950"
                                               placeholder="1234 5678 9012 3456"
                                               pattern="\d{4}\s?\d{4}\s?\d{4}\s?\d{4}"
                                               required />
                                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                            <i class="material-icons text-slate-400">credit_card</i>
                                        </div>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <!-- Expiry Date -->
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-2">Expiry Date</label>
                                        <input type="text"
                                               class="block w-full py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-cyan-950/20 focus:border-cyan-950"
                                               placeholder="MM/YY"
                                               pattern="(0[1-9]|1[0-2])\/([0-9]{2})"
                                               required />
                                    </div>

                                    <!-- CVV -->
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-2">CVV</label>
                                        <div class="relative">
                                            <input type="text"
                                                   class="block w-full pr-10 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-cyan-950/20 focus:border-cyan-950"
                                                   placeholder="123"
                                                   pattern="\d{3}"
                                                   maxlength="3"
                                                   required />
                                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                                <i class="material-icons text-slate-400" title="3-digit security code">help</i>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Cardholder Name -->
                                <div>
                                    <label class="block text-sm font-medium text-slate-700 mb-2">Card Holder Name</label>
                                    <input type="text"
                                           class="block w-full py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-cyan-950/20 focus:border-cyan-950"
                                           placeholder="Name as it appears on card"
                                           required />
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="space-y-3 pt-4">
                            <button type="submit"
                                    class="w-full bg-cyan-950 text-white py-3 px-4 rounded-lg hover:bg-cyan-900 transition-colors flex items-center justify-center gap-2">
                                <span>Pay</span>
                                <span id="payAmount"></span>
                            </button>
                            <a href="@Url.Action("StudentFinance")"
                               class="block w-full text-center py-3 px-4 border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 transition-colors">
                                Cancel Payment
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Payment Summary Section -->
        <div class="lg:w-96 space-y-6">
            <!-- Summary Card -->
            <div class="bg-white rounded-xl shadow-sm">
                <div class="p-6 border-b border-slate-100">
                    <div class="flex items-center gap-2">
                        <i class="material-icons text-cyan-950">info</i>
                        <h2 class="text-lg font-semibold text-slate-800">Payment Summary</h2>
                    </div>
                </div>

                <div class="p-6 space-y-4">
                    <div class="space-y-3">
                        <div class="flex justify-between">
                            <span class="text-slate-600">Transaction Reference</span>
                            <span class="font-medium text-slate-800">@Model.TransactionReference</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-600">Student Name</span>
                            <span class="font-medium text-slate-800">@Model.StudentName</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-600">Student ID</span>
                            <span class="font-medium text-slate-800">@Model.StudentId</span>
                        </div>
                    </div>

                    <div class="border-t border-slate-100 pt-4">
                        <div class="flex justify-between items-center">
                            <span class="font-medium text-slate-800">Outstanding Balance</span>
                            <span class="text-lg font-bold text-red-600">ZMW @Model.Amount.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Security Notice -->
            <div class="bg-slate-50 rounded-xl p-6">
                <div class="flex items-start gap-3">
                    <div class="bg-cyan-950/5 p-2 rounded-lg">
                        <i class="material-icons text-cyan-950">security</i>
                    </div>
                    <div>
                        <h3 class="text-sm font-medium text-slate-800 mb-1">Secure Payment</h3>
                        <p class="text-sm text-slate-600">
                            All payment information is encrypted and securely processed. Your card details are not stored on our servers.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Enable tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });

        // Format card number with spaces
        document.querySelector('input[pattern*="\\d{4}"]').addEventListener('input', function (e) {
            e.target.value = e.target.value.replace(/[^\d]/g, '').replace(/(.{4})/g, '$1 ').trim();
        });

        // Update payment button amount when amount input changes
        const amountInput = document.querySelector('input[name="amount"]');
        const payAmountSpan = document.getElementById('payAmount');

        // Set initial value
        payAmountSpan.textContent = parseFloat(amountInput.value).toFixed(2);

        // Update on input change
        amountInput.addEventListener('input', function(e) {
            const amount = parseFloat(e.target.value) || 0;
            payAmountSpan.textContent = amount.toFixed(2);
        });

        // Handle form submission
        document.getElementById('paymentForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const button = document.getElementById('payButton');
            const originalText = button.innerHTML;
            button.disabled = true;
            button.innerHTML = `<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Processing Payment...`;
            setTimeout(() => {
                this.submit();
            }, 2000);
        });
    </script>
}