@section Scripts {
    <script>
        const maxAmount = @outstandingBalance;

        function showPaymentForm(modalId) {
            document.getElementById(modalId).classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hidePaymentForm(modalId) {
            document.getElementById(modalId).classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function setPaymentAmount(amount) {
            document.getElementById('Amount').value = amount.toFixed(2);
            document.getElementById('MobileAmount').value = amount.toFixed(2);
            updatePaymentButtonText(amount);
        }

        function updatePaymentButtonText(amount) {
            const formatter = new Intl.NumberFormat('en-ZM', { style: 'currency', currency: 'ZMW' });
            const formattedAmount = formatter.format(amount);
            document.getElementById('card-pay-button-text').textContent = `Pay ${formattedAmount}`;
            document.getElementById('mobile-pay-button-text').textContent = `Pay ${formattedAmount}`;
        }

        // Payment button loading state management
        function setCardLoadingState(isLoading) {
            const btn = document.getElementById('card-payment-btn');
            const icon = document.getElementById('card-submit-icon');
            const spinner = document.getElementById('card-loading-spinner');
            const text = document.getElementById('card-pay-button-text');

            if (isLoading) {
                btn.disabled = true;
                icon.classList.add('hidden');
                spinner.classList.remove('hidden');
                text.textContent = 'Processing Payment...';
                btn.classList.add('cursor-not-allowed');
            } else {
                btn.disabled = false;
                icon.classList.remove('hidden');
                spinner.classList.add('hidden');
                text.textContent = 'Complete Payment';
                btn.classList.remove('cursor-not-allowed');
            }
        }

        function setMobileLoadingState(isLoading) {
            const btn = document.getElementById('mobile-payment-btn');
            const icon = document.getElementById('mobile-submit-icon');
            const spinner = document.getElementById('mobile-loading-spinner');
            const text = document.getElementById('mobile-pay-button-text');

            if (isLoading) {
                btn.disabled = true;
                icon.classList.add('hidden');
                spinner.classList.remove('hidden');
                text.textContent = 'Processing Payment...';
                btn.classList.add('cursor-not-allowed');
            } else {
                btn.disabled = false;
                icon.classList.remove('hidden');
                spinner.classList.add('hidden');
                text.textContent = 'Complete Payment';
                btn.classList.remove('cursor-not-allowed');
            }
        }

        // Update button text when amount changes
        document.addEventListener('DOMContentLoaded', function() {
            const paymentInputs = ['Amount', 'MobileAmount'];

            paymentInputs.forEach(inputId => {
                const input = document.getElementById(inputId);
                 if (input) {
                    input.addEventListener('input', function() {
                        const amount = parseFloat(this.value) || 0;
                        updatePaymentButtonText(amount);
                    });
                }
            });

            // Add form submission handlers with loading states
            document.getElementById('card-payment-form').addEventListener('submit', function(e) {
                const amountInput = this.querySelector('input[name="Amount"]');
                const amount = parseFloat(amountInput.value);

                // Validate amount
                if (amount <= 0) {
                    e.preventDefault();
                    window.showAppToast('Please enter a valid payment amount.');
                    return;
                }

                if (amount > maxAmount) {
                    e.preventDefault();
                    window.showAppToast(`Payment amount cannot exceed your outstanding balance of K${maxAmount.toFixed(2)}.`);
                    return;
                }

                // Set loading state
                setCardLoadingState(true);

                // Disable modal close buttons during processing
                document.querySelectorAll('#card-payment-modal button[onclick*="hidePaymentForm"]').forEach(btn => {
                    btn.disabled = true;
                });
            });

            document.getElementById('mobile-payment-form').addEventListener('submit', function(e) {
                const amountInput = this.querySelector('input[name="Amount"]');
                const amount = parseFloat(amountInput.value);

                // Validate amount
                if (amount <= 0) {
                    e.preventDefault();
                    window.showAppToast('Please enter a valid payment amount.');
                    return;
                }

                if (amount > maxAmount) {
                    e.preventDefault();
                    window.showAppToast(`Payment amount cannot exceed your outstanding balance of K${maxAmount.toFixed(2)}.`);
                    return;
                }

                // Set loading state
                setMobileLoadingState(true);

                // Disable modal close buttons during processing
                document.querySelectorAll('#mobile-payment-modal button[onclick*="hidePaymentForm"]').forEach(btn => {
                    btn.disabled = true;
                });
            });
        });

        // Close modal when clicking outside (only if not processing)
        document.querySelectorAll('#card-payment-modal, #mobile-payment-modal').forEach(modal => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    const cardBtn = document.getElementById('card-payment-btn');
                    const mobileBtn = document.getElementById('mobile-payment-btn');

                    // Only allow closing if neither button is disabled (processing)
                    if (!cardBtn.disabled && !mobileBtn.disabled) {
                        hidePaymentForm(modal.id);
                    }
                }
            });
        });

        // Prevent modal close during processing
        function hidePaymentForm(modalId) {
            const cardBtn = document.getElementById('card-payment-btn');
            const mobileBtn = document.getElementById('mobile-payment-btn');

            // Don't allow closing if payment is being processed
            if (cardBtn.disabled || mobileBtn.disabled) {
                return;
            }

            document.getElementById(modalId).classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        // Amount validation on input
        document.getElementById('Amount').addEventListener('input', function() {
            const amount = parseFloat(this.value);
            if (amount > maxAmount) {
                this.setCustomValidity(`Amount cannot exceed K${maxAmount.toFixed(2)}`);
            } else {
                this.setCustomValidity('');
            }
        });

        document.getElementById('MobileAmount').addEventListener('input', function() {
            const amount = parseFloat(this.value);
            if (amount > maxAmount) {
                this.setCustomValidity(`Amount cannot exceed K${maxAmount.toFixed(2)}`);
            } else {
                this.setCustomValidity('');
            }
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', function(event) {
            // Escape key to close modals (only if not processing)
            if (event.key === 'Escape') {
                const cardBtn = document.getElementById('card-payment-btn');
                const mobileBtn = document.getElementById('mobile-payment-btn');

                if (!cardBtn.disabled && !mobileBtn.disabled) {
                    const cardModal = document.getElementById('card-payment-modal');
                    const mobileModal = document.getElementById('mobile-payment-modal');

                    if (!cardModal.classList.contains('hidden')) {
                        hidePaymentForm('card-payment-modal');
                    } else if (!mobileModal.classList.contains('hidden')) {
                        hidePaymentForm('mobile-payment-modal');
                    }
                }
            }
        });

        // Auto-focus amount input when modal opens
        function showPaymentForm(modalId) {
            document.getElementById(modalId).classList.remove('hidden');
            document.body.style.overflow = 'hidden';

            // Auto-focus the amount input
            setTimeout(() => {
                if (modalId === 'card-payment-modal') {
                    document.getElementById('Amount').focus();
                } else if (modalId === 'mobile-payment-modal') {
                    document.getElementById('MobileAmount').focus();
                }
            }, 100);
        }

        // Format card number input
        document.getElementById('CardNumber').addEventListener('input', function() {
            let value = this.value.replace(/\D/g, '');
            if (value.length > 16) {
                value = value.slice(0, 16);
            }
            this.value = value;
        });

        // Format phone number input
        document.getElementById('PhoneNumber').addEventListener('input', function() {
            let value = this.value.replace(/\D/g, '');
            if (value.length > 10) {
                value = value.slice(0, 10);
            }
            this.value = value;
        });

        // Format CVV input
        document.getElementById('Cvv').addEventListener('input', function() {
            let value = this.value.replace(/\D/g, '');
            if (value.length > 4) {
                value = value.slice(0, 4);
            }
            this.value = value;
        });

        // Quick amount buttons (if you want to add them back)
        function setQuickAmount(amount) {
            const validAmount = Math.min(amount, maxAmount);
            setPaymentAmount(validAmount);
        }

        // Show success message after successful payment
        @if (TempData["Success"] != null)
        {
            <text>
                setTimeout(() => {
                    window.showAppToast('@TempData["Success"]');
                }, 500);
            </text>
        }

        // Show error message after failed payment
        @if (TempData["Error"] != null)
        {
            <text>
                setTimeout(() => {
                    window.showAppToast('@TempData["Error"]');
                    // Reset loading states in case of error
                    setCardLoadingState(false);
                    setMobileLoadingState(false);

                    // Re-enable close buttons
                    document.querySelectorAll('button[onclick*="hidePaymentForm"]').forEach(btn => {
                        btn.disabled = false;
                    });
                }, 500);
            </text>
        }
    </script>
}