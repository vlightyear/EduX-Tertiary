@model SIS.Models.Payments.PaymentHistoryViewModel

@{
    ViewData["Title"] = "Financial Statement";
}

<style>
    .fs-expand-btn {
        width: 26px; height: 26px; border-radius: 6px;
        border: 1.5px solid #e2e8f0;
        background: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; transition: background .15s, border-color .15s;
        flex-shrink: 0;
    }
    .fs-expand-btn:hover { background: #eef2ff; border-color: #c2d0ff; }
    .fs-expand-btn .material-icons { font-size: 16px; color: #64748b; transition: transform .25s; }
    .fs-expand-btn.open { background: #eef2ff; border-color: #c2d0ff; }
    .fs-expand-btn.open .material-icons { transform: rotate(180deg); color: #1e2d5e; }

    .fs-detail-row { display: none; }
    .fs-detail-row.open { display: table-row; }
    .fs-detail-panel {
        background: #fafbff;
        border-top: 1px dashed #e2e8f0;
        border-bottom: 2px solid #c2d0ff;
        animation: fsSlideDown .2s ease;
    }
    @@keyframes fsSlideDown {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .fs-items-table { width: 100%; border-collapse: collapse; font-size: .78rem; }
    .fs-items-table thead tr { background: #eef2ff; }
    .fs-items-table thead th {
        padding: .45rem .875rem;
        font-size: .67rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .04em; color: #1e2d5e;
        text-align: left; white-space: nowrap;
    }
    .fs-items-table thead th:last-child { text-align: right; }
    .fs-items-table tbody tr { border-top: 1px solid #e2e8f0; }
    .fs-items-table tbody tr:hover { background: #f0f4ff; }
    .fs-items-table tbody td { padding: .55rem .875rem; color: #1e2d5e; }
    .fs-items-table tbody td:last-child { text-align: right; font-weight: 700; }
    .fs-items-footer {
        display: flex; justify-content: flex-end; align-items: center; gap: .5rem;
        padding: .5rem .875rem .6rem;
        border-top: 1.5px solid #c2d0ff;
        font-size: .78rem; font-weight: 700; color: #1e2d5e;
    }
    .fs-items-footer span { color: #64748b; font-weight: 600; }

    tr.fs-parent-open > td { background: #f5f7ff !important; }
    .fs-has-items { cursor: pointer; }
    .fs-has-items:hover > td { background: #f5f7ff !important; }
</style>

<div class="min-h-screen bg-slate-50 p-6">

    <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div class="flex items-start gap-4">
                <i class="material-icons text-3xl text-cyan-950">history</i>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800 mb-2">Payment History</h1>
                    <div class="text-slate-600">
                        <p><span class="font-medium">Student:</span> @Model.StudentName</p>
                        <p><span class="font-medium">ID:</span> @Model.StudentId</p>
                    </div>
                </div>
            </div>
            <div class="flex items-center gap-2 text-slate-600">
                <i class="material-icons">calendar_month</i>
                <span>Academic Year: @Model.AcademicYear</span>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div class="flex items-center gap-4">
                <div class="bg-cyan-950 p-4 rounded-xl">
                    <i class="material-icons text-2xl text-white">payments</i>
                </div>
                <div>
                    <h3 class="text-sm font-medium text-slate-600">Total Paid</h3>
                    <p class="text-2xl font-bold text-cyan-950">ZMW @Model.TotalPaid.ToString("N2")</p>
                </div>
            </div>
        </div>
    </div>

    @if (Model.FinancialStatement.Any())
    {
        <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
            <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
                <h3 class="text-lg font-semibold text-slate-800 flex items-center">
                    <i class="material-icons text-primary-600 mr-2">history</i>
                    Financial Statement
                </h3>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-slate-700">
                    <thead class="text-xs uppercase bg-slate-50">
                        <tr>
                            <th class="px-4 py-3 w-8"></th>
                            <th class="px-6 py-3">Date</th>
                            <th class="px-6 py-3">Reference</th>
                            <th class="px-6 py-3">Credit</th>
                            <th class="px-6 py-3">Debit</th>
                            <th class="px-6 py-3">Running Balance</th>
                            <th class="px-6 py-3">Narration</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            decimal runningBalance = 0;
                            int rowIndex = 0;
                        }
                        @foreach (var payment in Model.FinancialStatement)
                        {
                            if (payment.Credit)
                                runningBalance -= payment.Amount.Value;
                            else
                                runningBalance += payment.Amount.Value;

                            bool hasItems     = payment.InvoiceItems != null && payment.InvoiceItems.Any();
                            string rowId      = $"detail-{rowIndex}";
                            string btnId      = $"btn-{rowIndex}";
                            string parentId   = $"parent-{rowIndex}";
                            string toggleCall = $"toggleRow('{rowId}','{btnId}','{parentId}')";

                            if (hasItems)
                            {
                                @* ── Expandable row ── *@
                                <tr id="@parentId" class="bg-white border-b fs-has-items"
                                    onclick="@toggleCall">

                                    <td class="px-4 py-4">
                                        <button type="button" id="@btnId" class="fs-expand-btn"
                                                onclick="event.stopPropagation(); @toggleCall">
                                            <i class="material-icons">expand_more</i>
                                        </button>
                                    </td>
                                    <td class="px-6 py-4">
                                        @payment.CreatedAt.ToString("MMM dd, yyyy")
                                        <div class="text-xs text-slate-500">@payment.CreatedAt.ToString("HH:mm")</div>
                                    </td>
                                    <td class="px-6 py-4 font-mono text-xs">@payment.Reference</td>
                                    <td class="px-6 py-4 font-semibold text-green-600">
                                        @if (payment.Credit) { <span>K @payment.Amount.Value.ToString("N2")</span> }
                                        else { <span class="text-slate-300">—</span> }
                                    </td>
                                    <td class="px-6 py-4 font-semibold text-red-600">
                                        @if (!payment.Credit) { <span>K @payment.Amount.Value.ToString("N2")</span> }
                                        else { <span class="text-slate-300">—</span> }
                                    </td>
                                    @if (runningBalance < 0)
                                    {
                                        <td class="px-6 py-4 font-semibold text-green-600">
                                            (@Math.Abs(runningBalance).ToString("N2"))
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="px-6 py-4 font-semibold text-red-600">
                                            K @runningBalance.ToString("N2")
                                        </td>
                                    }
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                            @payment.Narration
                                        </span>
                                    </td>
                                </tr>

                                @* ── Detail row ── *@
                                <tr id="@rowId" class="fs-detail-row">
                                    <td colspan="7" class="p-0">
                                        <div class="fs-detail-panel">
                                            <table class="fs-items-table">
                                                <thead>
                                                    <tr>
                                                        <th style="padding-left:3.5rem;">Fee Type</th>
                                                        <th>Description</th>
                                                        <th style="padding-right:1.5rem;">Amount</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in payment.InvoiceItems!)
                                                    {
                                                        <tr>
                                                            <td style="padding-left:3.5rem;">
                                                                <span class="inline-flex items-center gap-1">
                                                                    <i class="material-icons" style="font-size:14px;color:#e85c5c;">receipt</i>
                                                                    @item.FeeTypeName
                                                                </span>
                                                            </td>
                                                            <td class="text-slate-500">@(item.Description ?? "—")</td>
                                                            <td style="padding-right:1.5rem;">K @item.Amount.ToString("N2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                            <div class="fs-items-footer">
                                                <span>Invoice Total</span>
                                                K @payment.Amount.Value.ToString("N2")
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @* ── Plain row ── *@
                                <tr id="@parentId" class="bg-white border-b hover:bg-slate-50">
                                    <td class="px-4 py-4"></td>
                                    <td class="px-6 py-4">
                                        @payment.CreatedAt.ToString("MMM dd, yyyy")
                                        <div class="text-xs text-slate-500">@payment.CreatedAt.ToString("HH:mm")</div>
                                    </td>
                                    <td class="px-6 py-4 font-mono text-xs">@payment.Reference</td>
                                    <td class="px-6 py-4 font-semibold text-green-600">
                                        @if (payment.Credit) { <span>K @payment.Amount.Value.ToString("N2")</span> }
                                        else { <span class="text-slate-300">—</span> }
                                    </td>
                                    <td class="px-6 py-4 font-semibold text-red-600">
                                        @if (!payment.Credit) { <span>K @payment.Amount.Value.ToString("N2")</span> }
                                        else { <span class="text-slate-300">—</span> }
                                    </td>
                                    @if (runningBalance < 0)
                                    {
                                        <td class="px-6 py-4 font-semibold text-green-600">
                                            (@Math.Abs(runningBalance).ToString("N2"))
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="px-6 py-4 font-semibold text-red-600">
                                            K @runningBalance.ToString("N2")
                                        </td>
                                    }
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                            @payment.Narration
                                        </span>
                                    </td>
                                </tr>
                            }

                            rowIndex++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
            <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
                <h3 class="text-lg font-semibold text-slate-800 flex items-center">
                    <i class="material-icons text-primary-600 mr-2">history</i>
                    Payment History
                </h3>
            </div>
            <div class="p-6 text-center">
                <i class="material-icons text-6xl text-slate-300 mb-4">payment</i>
                <p class="text-slate-500 text-lg font-medium">No Payment History</p>
                <p class="text-slate-400 text-sm mt-2">No payments have been made for this academic year</p>
            </div>
        </div>
    }

</div>

<script>
    function toggleRow(detailRowId, btnId, parentRowId) {
        var detail    = document.getElementById(detailRowId);
        var btn       = document.getElementById(btnId);
        var parentRow = document.getElementById(parentRowId);
        var isOpen    = detail.classList.contains('open');
        detail.classList.toggle('open',              !isOpen);
        btn.classList.toggle('open',                 !isOpen);
        parentRow.classList.toggle('fs-parent-open', !isOpen);
    }
</script>
