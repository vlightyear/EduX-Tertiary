@{
    ViewData["Title"] = "Invoice Not Found";
    Layout = null;

    var reference = Context.Request.Query["ref"].ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice Not Found</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', Arial, sans-serif;
            background: #f0f4f8;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
            color: #1e293b;
        }

        .card {
            background: #fff;
            border-radius: 1.1rem;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 24px rgba(30,45,94,.08);
            width: 100%;
            max-width: 480px;
            overflow: hidden;
            text-align: center;
        }

        /* Red top bar */
        .card-top {
            background: linear-gradient(135deg, #c94040 0%, #e85c5c 100%);
            padding: 2rem 2rem 1.5rem;
        }

        .icon-ring {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: rgba(255,255,255,.15);
            border: 2px solid rgba(255,255,255,.3);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto .85rem;
        }

            .icon-ring .material-icons {
                font-size: 2rem;
                color: #fff;
            }

        .card-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.4rem;
            color: #fff;
            margin-bottom: .35rem;
        }

        .card-sub {
            font-size: .82rem;
            color: rgba(255,255,255,.7);
        }

        /* Body */
        .card-body {
            padding: 1.75rem 2rem;
        }

        .ref-box {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: .6rem;
            padding: .75rem 1rem;
            margin-bottom: 1.25rem;
            text-align: left;
        }

        .ref-box-label {
            font-size: .65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: #94a3b8;
            margin-bottom: .25rem;
        }

        .ref-box-value {
            font-family: monospace;
            font-size: .85rem;
            font-weight: 700;
            color: #c94040;
            word-break: break-all;
        }

        .reason-list {
            text-align: left;
            list-style: none;
            margin-bottom: 1.5rem;
        }

            .reason-list li {
                display: flex;
                align-items: flex-start;
                gap: .6rem;
                font-size: .82rem;
                color: #475569;
                padding: .4rem 0;
                border-bottom: 1px solid #f1f5f9;
            }

                .reason-list li:last-child {
                    border-bottom: none;
                }

            .reason-list .material-icons {
                font-size: .95rem;
                color: #94a3b8;
                flex-shrink: 0;
                margin-top: .05rem;
            }

        .contact-note {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: .6rem;
            padding: .875rem 1rem;
            font-size: .8rem;
            color: #475569;
            line-height: 1.55;
        }

            .contact-note strong {
                color: #1e2d5e;
            }

        /* Footer */
        .page-footer {
            margin-top: 1.5rem;
            font-size: .75rem;
            color: #94a3b8;
            text-align: center;
        }
    </style>
</head>
<body>

    <div class="card">

        <div class="card-top">
            <div class="icon-ring">
                <i class="material-icons">search_off</i>
            </div>
            <h1 class="card-title">Invoice Not Found</h1>
            <p class="card-sub">We could not verify this invoice reference</p>
        </div>

        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(reference))
            {
                <div class="ref-box">
                    <p class="ref-box-label">Searched Reference</p>
                    <p class="ref-box-value">@reference</p>
                </div>
            }

            <ul class="reason-list">
                <li>
                    <i class="material-icons">info</i>
                    The reference may have been entered or scanned incorrectly.
                </li>
                <li>
                    <i class="material-icons">info</i>
                    The invoice may not have been issued by this institution.
                </li>
                <li>
                    <i class="material-icons">info</i>
                    Old invoices may have been archived — contact the finance office.
                </li>
            </ul>

            <div class="contact-note">
                If you believe this is an error, please contact the
                <strong>EduTech</strong> with the reference number
                shown above.
            </div>

        </div>
    </div>

    <p class="page-footer">
        &copy; @DateTime.Now.Year EduTech &nbsp;·&nbsp; Student Information System
    </p>

</body>
</html>
