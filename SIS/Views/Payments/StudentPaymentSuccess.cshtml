@model SIS.Models.Payments.StudentPaymentConfirmationViewModel

@{
    ViewData["Title"] = "Payment Successful";
}

<div class="bg-slate-50 min-h-screen py-8 overflow-auto">
    <div class=" mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Success Header -->
        <div class="text-center mb-8">
            <div class="mx-auto flex items-center justify-center h-24 w-24 rounded-full bg-green-100 mb-6 animate-pulse">
                <svg class="h-12 w-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h1 class="text-4xl font-bold text-slate-800 mb-2">Payment Successful!</h1>
            <p class="text-slate-600 text-lg">Your payment has been processed successfully</p>
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column: Payment Details -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Payment Summary Card -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-xl font-semibold text-slate-800">Payment Summary</h2>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            Completed
                        </span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-4">
                            <div class="bg-green-50 rounded-lg p-4">
                                <dt class="text-sm font-medium text-green-700">Amount Paid</dt>
                                <dd class="text-2xl font-bold text-green-600 mt-1">@Model.Amount.ToString("C2", new System.Globalization.CultureInfo("en-ZM"))</dd>
                            </div>
                            <div class="bg-slate-50 rounded-lg p-4">
                                <dt class="text-sm font-medium text-slate-600">Outstanding Balance</dt>
                                <dd class="text-xl font-semibold text-slate-800 mt-1">@Model.OutstandingBalance.ToString("C2", new System.Globalization.CultureInfo("en-ZM"))</dd>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div class="bg-blue-50 rounded-lg p-4">
                                <dt class="text-sm font-medium text-blue-700">Payment Method</dt>
                                <dd class="text-lg font-semibold text-blue-800 mt-1">@Model.PaymentMethod</dd>
                            </div>
                            <div class="bg-slate-50 rounded-lg p-4">
                                <dt class="text-sm font-medium text-slate-600">Transaction Date</dt>
                                <dd class="text-lg font-medium text-slate-800 mt-1">@Model.PaymentDate.ToString("MMM dd, yyyy")</dd>
                                <dd class="text-sm text-slate-600">@Model.PaymentDate.ToString("HH:mm")</dd>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Transaction Details Card -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                    <h3 class="text-lg font-semibold text-slate-800 mb-4">Transaction Details</h3>
                    <div class="bg-slate-50 rounded-lg p-4 border-l-4 border-blue-500">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-sm font-medium text-slate-600">Transaction Reference</p>
                                <p class="text-lg font-mono font-semibold text-slate-800" id="transaction-ref">@Model.TransactionReference</p>
                            </div>
                            <button onclick="copyToClipboard('@Model.TransactionReference')"
                                    class="ml-4 px-3 py-2 text-sm bg-blue-100 text-blue-700 rounded-lg hover:bg-blue-200 transition-colors flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                                </svg>
                                Copy
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Student Information Card -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                    <h3 class="text-lg font-semibold text-slate-800 mb-4">Student Information</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <p class="text-sm font-medium text-slate-600">Student ID</p>
                            <p class="text-lg font-semibold text-slate-800">@Model.StudentId</p>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-slate-600">Student Name</p>
                            <p class="text-lg font-semibold text-slate-800 break-words">@Model.StudentName</p>
                        </div>
                        <div class="md:col-span-2">
                            <p class="text-sm font-medium text-slate-600">Programme</p>
                            <p class="text-lg font-medium text-slate-800 break-words">@Model.ProgrammeName</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Status & Actions -->
            <div class="lg:col-span-1 space-y-6">
                <!-- Registration Status Card -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 sticky top-8">
                    <h3 class="text-lg font-semibold text-slate-800 mb-4">Registration Status</h3>

                    @if (Model.RegistrationStatus == "Registered")
                    {
                        <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
                            <div class="flex items-center">
                                <div class="flex-shrink-0">
                                    <svg class="w-8 h-8 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                    </svg>
                                </div>
                                <div class="ml-3">
                                    <h4 class="text-green-800 font-semibold">Registration Complete</h4>
                                    <p class="text-green-700 text-sm mt-1">You have successfully registered for this semester.</p>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4">
                            <div class="flex items-center">
                                <div class="flex-shrink-0">
                                    <svg class="w-8 h-8 text-amber-600" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                                    </svg>
                                </div>
                                <div class="ml-3">
                                    <h4 class="text-amber-800 font-semibold">Payment Received</h4>
                                    <p class="text-amber-700 text-sm mt-1">Additional payment required to complete registration.</p>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Next Steps -->
                    @* <div class="bg-blue-50 rounded-lg p-4"> *@
                    @*     <h4 class="text-blue-800 font-medium mb-2">Next Steps</h4> *@
                    @*     <p class="text-blue-700 text-sm">@Model.NextSteps</p> *@
                    @* </div> *@
                </div>

                <!-- Action Buttons -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                    <h3 class="text-lg font-semibold text-slate-800 mb-4">Actions</h3>
                    <div class="space-y-3">
                        <a href="@Url.Action("StudentFinance", "Payments")"
                           class="w-full inline-flex items-center justify-center px-4 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2V7"></path>
                            </svg>
                            Finance Dashboard
                        </a>

                        <button onclick="downloadReceipt()"
                                class="w-full inline-flex items-center justify-center px-4 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            Download Receipt
                        </button>

                        <button onclick="printReceipt()"
                                class="w-full inline-flex items-center justify-center px-4 py-3 bg-white border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 transition-colors">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
                            </svg>
                            Print Receipt
                        </button>

                        @if (Model.OutstandingBalance > 0)
                        {
                            <a href="@Url.Action("StudentPaymentSelection", "Payments")"
                               class="w-full inline-flex items-center justify-center px-4 py-3 bg-amber-600 text-white rounded-lg hover:bg-amber-700 focus:ring-2 focus:ring-amber-500 focus:ring-offset-2 transition-colors">
                                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                </svg>
                                Make Another Payment
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden Receipt Template for Printing/Download -->
    <div id="receipt-template" class="hidden">
        <div class="max-w-2xl mx-auto bg-white p-8" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
            <!-- Header -->
            <div class="text-center border-b-2 border-slate-300 pb-6 mb-6">
                <h1 class="text-3xl font-bold text-slate-800 mb-2">Payment Receipt</h1>
                <p class="text-slate-600 text-lg">eCampus Student Fee System</p>
                <p class="text-sm text-slate-500 mt-2">Generated on @DateTime.Now.ToString("MMMM dd, yyyy HH:mm")</p>
            </div>

            <!-- Payment Status Banner -->
            <div class="bg-green-100 border border-green-300 rounded-lg p-4 mb-6 text-center">
                <h2 class="text-xl font-bold text-green-800">Payment Successful</h2>
                <p class="text-green-700">Transaction completed successfully</p>
            </div>

            <!-- Main Details Grid -->
            <div class="grid grid-cols-2 gap-6 mb-6">
                <!-- Payment Information -->
                <div>
                    <h3 class="text-lg font-semibold text-slate-800 mb-3 border-b border-slate-200 pb-1">Payment Information</h3>
                    <div class="space-y-2">
                        <div class="flex justify-between">
                            <span class="text-slate-600">Amount Paid:</span>
                            <span class="font-bold text-green-600">@Model.Amount.ToString("C2", new System.Globalization.CultureInfo("en-ZM"))</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-600">Payment Method:</span>
                            <span class="font-medium">@Model.PaymentMethod</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-600">Transaction Date:</span>
                            <span class="font-medium">@Model.PaymentDate.ToString("MMM dd, yyyy HH:mm")</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-600">Outstanding Balance:</span>
                            <span class="font-medium">@Model.OutstandingBalance.ToString("C2", new System.Globalization.CultureInfo("en-ZM"))</span>
                        </div>
                    </div>
                </div>

                <!-- Student Information -->
                <div>
                    <h3 class="text-lg font-semibold text-slate-800 mb-3 border-b border-slate-200 pb-1">Student Information</h3>
                    <div class="space-y-2">
                        <div class="flex justify-between">
                            <span class="text-slate-600">Student ID:</span>
                            <span class="font-medium">@Model.StudentId</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-600">Name:</span>
                            <span class="font-medium">@Model.StudentName</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-600">Programme:</span>
                            <span class="font-medium text-sm">@Model.ProgrammeName</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-600">Registration Status:</span>
                            <span class="font-medium">@Model.RegistrationStatus</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Transaction Reference -->
            <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 mb-6">
                <h4 class="font-semibold text-slate-800 mb-2">Transaction Reference</h4>
                <p class="font-mono text-lg font-bold text-slate-800 bg-white border border-slate-300 rounded px-3 py-2">@Model.TransactionReference</p>
            </div>

            <!-- Footer -->
            <div class="border-t-2 border-slate-300 pt-6 text-center">
                <p class="text-sm text-slate-600 mb-2">This is an automatically generated receipt and does not require a signature.</p>
                <p class="text-sm text-slate-600">For queries, please contact the finance office.</p>
                <div class="mt-4 text-xs text-slate-500">
                    <p>&copy; 2025 eCampus Student System. All rights reserved.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <script>
        // Copy transaction reference to clipboard
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                // Show success message
                const button = event.target.closest('button');
                const originalText = button.innerHTML;
                button.innerHTML = '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> Copied!';
                button.classList.remove('bg-blue-100', 'text-blue-700', 'hover:bg-blue-200');
                button.classList.add('bg-green-100', 'text-green-700');

                setTimeout(() => {
                    button.innerHTML = originalText;
                    button.classList.remove('bg-green-100', 'text-green-700');
                    button.classList.add('bg-blue-100', 'text-blue-700', 'hover:bg-blue-200');
                }, 2000);
            }).catch(function() {
                window.showAppToast('Failed to copy to clipboard');
            });
        }

        // Print receipt
        function printReceipt() {
            const receiptContent = document.getElementById('receipt-template').innerHTML;
            const originalContent = document.body.innerHTML;

            document.body.innerHTML = receiptContent;
            document.body.style.margin = '0';
            document.body.style.padding = '20px';

            window.print();

            // Restore original content
            document.body.innerHTML = originalContent;
            location.reload(); // Reload to restore event listeners
        }

        // Download receipt as PDF
        function downloadReceipt() {
            const { jsPDF } = window.jspdf;
            const receiptElement = document.getElementById('receipt-template');

            // Show the receipt temporarily for capture
            receiptElement.classList.remove('hidden');

            html2canvas(receiptElement.firstElementChild, {
                scale: 2,
                useCORS: true,
                backgroundColor: '#ffffff'
            }).then(canvas => {
                // Hide the receipt again
                receiptElement.classList.add('hidden');

                const imgData = canvas.toDataURL('image/png');
                const pdf = new jsPDF('p', 'mm', 'a4');

                // Calculate dimensions to fit the page
                const imgWidth = 210; // A4 width in mm
                const pageHeight = 295; // A4 height in mm
                const imgHeight = (canvas.height * imgWidth) / canvas.width;
                let heightLeft = imgHeight;

                let position = 0;

                // Add first page
                pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight);
                heightLeft -= pageHeight;

                // Add additional pages if needed
                while (heightLeft >= 0) {
                    position = heightLeft - imgHeight;
                    pdf.addPage();
                    pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight);
                    heightLeft -= pageHeight;
                }

                // Download the PDF
                       // Download the PDF
        pdf.save('Receipt_' + '@Model.TransactionReference' + '.pdf');
            }).catch(error => {
                receiptElement.classList.add('hidden');
                console.error('Error generating PDF:', error);
                window.showAppToast('Error generating PDF. Please try again.');
            });
        }

        // Add subtle animations on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Animate cards on load
            const cards = document.querySelectorAll('.bg-white');
            cards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.6s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 100);
            });
        });
    </script>
}