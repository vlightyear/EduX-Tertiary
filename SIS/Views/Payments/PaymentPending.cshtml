@{
    ViewBag.Title = "Payment Processing";
    var txnId = ViewBag.TransactionId as string ?? "";
    var amount = (decimal)(ViewBag.Amount ?? 0m);
    var method = ViewBag.Method as string ?? "Mobile Money";
    var studentId = ViewBag.StudentId as string ?? "";
}

<style>
    .pp-page {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f0f4f8;
        padding: 2rem 1rem;
    }

    .pp-card {
        background: var(--surface,#fff);
        border-radius: var(--radius-xl,18px);
        border: 1px solid var(--border,#e2e8f0);
        box-shadow: var(--shadow-md,0 6px 24px rgba(30,45,94,.11));
        max-width: 480px;
        width: 100%;
        overflow: hidden;
        animation: fadeUp .4s ease;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .pp-band {
        background: linear-gradient(110deg,var(--navy-deep,#141e42) 0%,var(--navy,#1e2d5e) 55%,#2e45a0 100%);
        height: 80px;
        position: relative;
        overflow: hidden;
    }

        .pp-band::before {
            content: '';
            position: absolute;
            right: -40px;
            top: -40px;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle,rgba(232,92,92,.15) 0%,transparent 70%);
            border-radius: 50%;
        }

    .pp-body {
        padding: 2rem 2rem 1.5rem;
        text-align: center;
    }

    .pp-icon-wrap {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        margin: -52px auto 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 4px solid var(--surface,#fff);
        box-shadow: 0 4px 20px rgba(30,45,94,.15);
        background: var(--navy-lt,#eef2ff);
        position: relative;
        transition: background .4s;
    }

    .pp-spinner-ring {
        position: absolute;
        inset: 4px;
        border-radius: 50%;
        border: 3px solid var(--navy-mid,#c2d0ff);
        border-top-color: var(--navy,#1e2d5e);
        animation: ppSpin .8s linear infinite;
    }

    @@keyframes ppSpin {
        to {
            transform: rotate(360deg)
        }
    }

    .pp-icon-wrap .material-icons {
        font-size: 32px;
        display: none;
    }

    .pp-status-label {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .3rem .9rem;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        margin-bottom: 1rem;
        background: var(--navy-lt,#eef2ff);
        color: var(--navy,#1e2d5e);
        border: 1px solid var(--navy-mid,#c2d0ff);
        transition: all .3s;
    }

        .pp-status-label .material-icons {
            font-size: 14px;
        }

    .pp-title {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--navy,#1e2d5e);
        margin-bottom: .4rem;
    }

    .pp-sub {
        font-size: .83rem;
        color: var(--muted,#64748b);
        line-height: 1.55;
    }

    .pp-warn-strip {
        display: none;
        align-items: center;
        gap: .5rem;
        padding: .6rem .9rem;
        margin-top: .875rem;
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 7px;
        font-size: .74rem;
        color: #92400e;
        font-weight: 600;
    }

        .pp-warn-strip .material-icons {
            font-size: 15px;
            flex-shrink: 0;
        }

    .pp-ref-box {
        margin: 1.25rem 0;
        background: var(--navy-lt,#eef2ff);
        border: 1px solid var(--navy-mid,#c2d0ff);
        border-radius: 10px;
        padding: .875rem 1rem;
    }

    .pp-ref-label {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--faint,#94a3b8);
    }

    .pp-ref-value {
        font-family: 'Courier New',monospace;
        font-weight: 700;
        color: var(--navy,#1e2d5e);
        font-size: .82rem;
        word-break: break-all;
        margin-top: .3rem;
    }

    .pp-amount-strip {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .75rem 1rem;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 7px;
        margin-bottom: 1.25rem;
        font-size: .82rem;
    }

        .pp-amount-strip .label {
            color: var(--muted,#64748b);
            font-weight: 600;
        }

        .pp-amount-strip .val {
            color: #15803d;
            font-weight: 800;
            font-size: .95rem;
        }

    .pp-dots {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin: .75rem 0 1.5rem;
    }

    .pp-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--navy-mid,#c2d0ff);
        animation: ppDot 1.4s infinite;
    }

        .pp-dot:nth-child(2) {
            animation-delay: .2s
        }

        .pp-dot:nth-child(3) {
            animation-delay: .4s
        }

    @@keyframes ppDot {
        0%, 80%, 100% {
            opacity: .3;
            transform: scale(.8)
        }

        40% {
            opacity: 1;
            transform: scale(1)
        }
    }

    .pp-footer {
        padding: 0 2rem 1.75rem;
        text-align: center;
    }

    .pp-cancel-link {
        font-size: .75rem;
        color: var(--faint,#94a3b8);
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .25rem;
    }

        .pp-cancel-link:hover {
            color: var(--coral,#e85c5c);
        }

        .pp-cancel-link .material-icons {
            font-size: 14px;
        }
</style>

<div class="pp-page">
    <div class="pp-card">
        <div class="pp-band"></div>
        <div class="pp-body">

            <div class="pp-icon-wrap" id="ppIconWrap">
                <div class="pp-spinner-ring" id="ppSpinner"></div>
                <i class="material-icons" id="ppSuccessIcon" style="color:#22c55e;display:none;">check_circle</i>
                <i class="material-icons" id="ppFailIcon" style="color:#e85c5c;display:none;">cancel</i>
            </div>

            <div class="pp-status-label" id="ppStatusLabel">
                <i class="material-icons" id="ppStatusIcon">schedule</i>
                <span id="ppStatusText">Processing&hellip;</span>
            </div>

            <div class="pp-title" id="ppTitle">Payment Initiated</div>
            <div class="pp-sub" id="ppSub">
                @if (method == "Mobile Money")
                {
                    <text>A USSD prompt has been sent to your phone. Please approve the prompt to complete your payment.</text>
                }
                else
                {
                    <text>Your card payment is being verified. Please wait while we confirm the transaction.</text>
                }
            </div>

            <div class="pp-warn-strip" id="ppWarnStrip">
                <i class="material-icons">wifi</i>
                <span id="ppWarnText">Still waiting for network confirmation&hellip;</span>
            </div>

            <div class="pp-ref-box">
                <div class="pp-ref-label">Transaction Reference</div>
                <div class="pp-ref-value">@txnId</div>
            </div>

            <div class="pp-amount-strip">
                <span class="label">Amount</span>
                <span class="val">K @amount.ToString("N2")</span>
            </div>

            <div class="pp-dots" id="ppDots">
                <div class="pp-dot"></div>
                <div class="pp-dot"></div>
                <div class="pp-dot"></div>
            </div>
        </div>

        <div class="pp-footer">
            <a href="@Url.Action("Student_Dashboard", "Home")" class="pp-cancel-link">
                <i class="material-icons">arrow_back</i> Return to dashboard
            </a>
        </div>
    </div>
</div>

<script>
    (function () {
        var TXN_ID         = '@Html.Raw(txnId)';
        var STUDENT_ID     = '@Html.Raw(studentId)';
        var POLL_URL       = '@Html.Raw(Url.Action("CheckPaymentStatus", "Payments"))';
        var CALLBACK_URL   = '@Html.Raw(Url.Action("PaymentCallback", "Payments"))';
        var HOME_URL       = '@Html.Raw(Url.Action("Student_Dashboard", "Home"))';

        var POLL_MS        = 5000;
        var MAX_POLLS      = 36;   // 3 minutes
        var MAX_ERR_STREAK = 36;    // tolerate 4 consecutive network/server errors before giving up

        var pollCount  = 0;
        var errStreak  = 0;
        var pollTimer;

        function el(id) { return document.getElementById(id); }

        // ── Terminal states ───────────────────────────────────────────
        function setSuccess() {
            clearInterval(pollTimer);
            el('ppSpinner').style.display     = 'none';
            el('ppSuccessIcon').style.display = 'block';
            el('ppWarnStrip').style.display   = 'none';
            el('ppDots').style.display        = 'none';
            el('ppIconWrap').style.background = '#f0fdf4';
            el('ppStatusLabel').style.background  = '#f0fdf4';
            el('ppStatusLabel').style.color        = '#15803d';
            el('ppStatusLabel').style.borderColor  = '#bbf7d0';
            el('ppStatusIcon').textContent    = 'check_circle';
            el('ppStatusText').textContent    = 'Payment Successful';
            el('ppTitle').textContent         = 'Payment Confirmed!';
            el('ppSub').textContent           = 'Your payment has been received. Redirecting you now\u2026';

            setTimeout(function () {
                window.location.href = CALLBACK_URL
                    + '?txnId='     + encodeURIComponent(TXN_ID)
                    + '&studentId=' + encodeURIComponent(STUDENT_ID);
            }, 2000);
        }

        // Only called when PayBoss itself returns status === "failed"
        function setFailed(message) {
            clearInterval(pollTimer);
            el('ppSpinner').style.display    = 'none';
            el('ppFailIcon').style.display   = 'block';
            el('ppWarnStrip').style.display  = 'none';
            el('ppDots').style.display       = 'none';
            el('ppIconWrap').style.background = '#fff1f1';
            el('ppStatusLabel').style.background  = '#fff1f1';
            el('ppStatusLabel').style.color        = '#d43f3f';
            el('ppStatusLabel').style.borderColor  = '#ffc5c5';
            el('ppStatusIcon').textContent   = 'cancel';
            el('ppStatusText').textContent   = 'Payment Failed';
            el('ppTitle').textContent        = 'Payment Unsuccessful';
            el('ppSub').textContent          = message || 'Your payment could not be completed. Please try again.';
        }

        // Called when we hit MAX_POLLS or MAX_ERR_STREAK — payment state is UNKNOWN
        function setTimedOut() {
            clearInterval(pollTimer);
            el('ppSpinner').style.display   = 'none';
            el('ppDots').style.display      = 'none';
            el('ppWarnStrip').style.display = 'none';
            el('ppStatusIcon').textContent  = 'hourglass_empty';
            el('ppStatusText').textContent  = 'Taking longer than expected';
            el('ppTitle').textContent       = 'Verification Timeout';
            el('ppSub').textContent         =
                'We could not confirm your payment in time. Please check your dashboard \u2014 '
                + 'if funds were deducted contact support quoting reference: ' + TXN_ID;
        }

        // ── Polling error handler ─────────────────────────────────────
        // A polling error means OUR server or the network had a problem.
        // It does NOT mean the payment itself failed — never call setFailed here.
        function handlePollError(warningText) {
            errStreak++;
            if (errStreak >= 2) {
                el('ppWarnStrip').style.display = 'flex';
                el('ppWarnText').textContent    = warningText;
            }
            if (errStreak >= MAX_ERR_STREAK) {
                setTimedOut();
            }
        }

        // ── Single poll tick ──────────────────────────────────────────
        async function poll() {
            if (++pollCount > MAX_POLLS) {
                setTimedOut();
                return;
            }

            try {
                var res = await fetch(POLL_URL + '?txnId=' + encodeURIComponent(TXN_ID));

                if (!res.ok) {
                    // HTTP 4xx/5xx from our own controller — transient error, keep polling
                    handlePollError('Server returned ' + res.status + '. Retrying\u2026');
                    return;
                }

                var data   = await res.json();
                // Normalise casing so PayBoss response variations don't matter
                var status = (data.status || '').toLowerCase().trim();

                if (status === 'success' || status === 'successful') {
                    errStreak = 0;
                    setSuccess();
                    window.location.href = HOME_URL;
                    return;

                } else if (status === 'failed') {
                    // PayBoss explicitly reports payment failure
                    errStreak = 0;
                    setFailed(data.description || data.message);

                } else if (status === 'error') {
                    // Our CheckPaymentStatus action threw — poll error, NOT payment failure
                    handlePollError(data.message || 'Status check error. Retrying\u2026');

                } else {
                    // 'pending' or any unrecognised value — keep polling
                    errStreak = 0;
                    el('ppWarnStrip').style.display = 'none';
                }

            } catch (networkErr) {
                // fetch() itself failed — network down / offline
                handlePollError('Network unavailable. Retrying\u2026');
            }
        }

        poll();
        pollTimer = setInterval(poll, POLL_MS);
    })();
</script>
