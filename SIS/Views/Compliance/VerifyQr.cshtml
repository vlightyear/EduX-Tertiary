@model SIS.Models.Compliance.StudentData
@{
    Layout = null; // Standalone page

    // You can set this from your controller or infer from model if stored in DocketType property
    var docketType = Model.DocketType ?? "Examination Docket";

    // Use green for authorized, red for below threshold
    var statusColor = Model.PercentPaid >= 75 ? "#28a745" : "#dc3545";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@docketType Verification - Eden University</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f9f9f9;
            margin: 0;
            padding: 2rem;
        }

        .verify-container {
            background: #fff;
            border-radius: 10px;
            padding: 2rem;
            max-width: 850px;
            margin: auto;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .header {
            text-align: center;
            margin-bottom: 1.5rem;
        }

            .header h2 {
                margin: 0;
                color: #2c3e50;
            }

        .student-photo {
            width: 120px;
            height: 140px;
            border-radius: 6px;
            border: 1px solid #ddd;
            object-fit: cover;
        }

        .info-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

            .info-table th,
            .info-table td {
                text-align: left;
                padding: 0.6rem;
                border-bottom: 1px solid #eee;
            }

            .info-table th {
                width: 30%;
                font-weight: bold;
                color: #333;
            }

        .status {
            margin-top: 1.5rem;
            padding: 1rem;
            border-radius: 8px;
            background-color: @statusColor;
            color: white;
            text-align: center;
            font-size: 1.2rem;
            font-weight: bold;
        }

        .courses-section {
            margin-top: 2rem;
        }

            .courses-section h3 {
                margin-bottom: 0.5rem;
                color: #2c3e50;
                border-bottom: 2px solid #e0e0e0;
                display: inline-block;
            }

        .courses-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

            .courses-table th, .courses-table td {
                padding: 0.6rem;
                border: 1px solid #ddd;
            }

            .courses-table th {
                background-color: #f2f2f2;
                text-align: left;
            }

        .footer {
            margin-top: 2rem;
            text-align: center;
            font-size: 0.9rem;
            color: #666;
        }

        .docket-type {
            text-align: center;
            font-size: 1.3rem;
            color: #007bff;
            font-weight: bold;
            margin-top: -0.5rem;
        }
    </style>
</head>
<body>
    <div class="verify-container">
        <div class="header">
            <img src="/images/institution-logo.png" alt="Logo" height="60" />
            <h2>Eden University — Docket Verification</h2>
            <div class="docket-type">@docketType</div>
            <div class="">@Model.AcademicYear</div>
        </div>

        <div style="display: flex; gap: 1.5rem;">
            <img src="/uploads/student-photos/@($"{Model.StudentIdNumber}.png")"
                 alt="Student Photo"
                 class="student-photo" />

            <table class="info-table">
                <tr><th>Full Name:</th><td>@Model.FullName</td></tr>
                <tr><th>Student Number:</th><td>@Model.StudentIdNumber</td></tr>
                <tr><th>NRC/Passport:</th><td>@Model.NRCNo</td></tr>
                <tr><th>Programme:</th><td>@Model.Programme</td></tr>
                <tr><th>Year/Period:</th><td>@Model.CurrentPeriodLabel</td></tr>
                <tr><th>Percent Paid:</th><td>@Model.PercentPaid?.ToString("N2") %</td></tr>
                <tr><th>Outstanding Fees:</th><td>@Model.OutstandingFees?.ToString("N2")</td></tr>
                <tr><th>Delivery:</th><td>@Model.Delivery</td></tr>
            </table>
        </div>

        <div class="status">
            @if (Model.PercentPaid >= 75)
            {
                <text>✅ Payment Threshold Met — Student Authorized</text>
            }
            else
            {
                <text>❌ Payment Threshold Not Met</text>
            }
        </div>

        <div class="courses-section">
            <h3>Authorized Courses</h3>

            @{
                string[] courses = Model.CoursesRegistered.Split("\r\n");
            }

            @if (courses.Length > 0)
            {
                <table class="courses-table">
                    <thead>
                        <tr>
                            <th>Course Name</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in courses)
                        {
                            <tr>
                                <td>@c</td>
                                <td>Authorized</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>No authorized courses found for this docket.</p>
            }
        </div>

        <div class="footer">
            <p>Verification generated on @DateTime.Now.ToString("dd MMM yyyy HH:mm")</p>
            <p>For authenticity, ensure this page is accessed through an official QR verification link.</p>
        </div>
    </div>
</body>
</html>
