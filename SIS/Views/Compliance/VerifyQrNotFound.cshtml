@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Verification Not Found</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            padding-top: 50px;
            background-color: #f9f9f9;
        }

        .box {
            display: inline-block;
            padding: 2rem;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <div class="box">
        <h2>❌ Verification Record Not Found</h2>
        <p>@ViewBag.Message</p>
    </div>
</body>
</html>
