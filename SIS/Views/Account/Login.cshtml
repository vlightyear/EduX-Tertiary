@model SIS.Models.Admin.LoginViewModel
@inject SIS.Services.IInstitutionConfigService InstitutionConfig

@{
    ViewData["Title"] = "Login";
    Layout = null;
    var institution = InstitutionConfig.GetCurrentInstitution();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - EduTech</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                fontFamily: {
                    sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
                },
                extend: {
                    colors: {
                        primary: {
                            50:  '#fef2f2',
                            100: '#fee2e2',
                            200: '#fecaca',
                            300: '#fca5a5',
                            400: '#f87171',
                            500: '#ef4444',
                            600: '#e85c5c',
                            700: '#c53030',
                            800: '#9b2c2c',
                            900: '#7f1d1d',
                            950: '#450a0a'
                        },
                        secondary: {
                            50:  '#f8fafc',
                            100: '#f1f5f9',
                            200: '#e2e8f0',
                            300: '#cbd5e1',
                            400: '#94a3b8',
                            500: '#64748b',
                            600: '#475569',
                            700: '#334155',
                            800: '#1e293b',
                            900: '#0f172a',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #f0f4f8;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-up {
            animation: fadeUp 0.45s ease forwards;
        }

        .fade-up-1 {
            animation-delay: 0.08s;
            opacity: 0;
        }

        .fade-up-2 {
            animation-delay: 0.16s;
            opacity: 0;
        }

        .fade-up-3 {
            animation-delay: 0.24s;
            opacity: 0;
        }

        .fade-up-4 {
            animation-delay: 0.32s;
            opacity: 0;
        }

        .loader {
            border: 3px solid rgba(232, 92, 92, 0.2);
            border-top: 3px solid #e85c5c;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            animation: spin 0.9s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Override Bootstrap focus to match site.css */
        input:focus, select:focus, textarea:focus {
            box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem #e85c5c !important;
            outline: none;
        }
    </style>
</head>
<body class="font-sans min-h-screen" style="background-color: #f0f4f8;">

    <!-- Loader -->
    <div id="loader" class="fixed inset-0 flex items-center justify-center bg-white z-50 transition-opacity duration-500">
        <div class="flex flex-col items-center gap-3">
            <div class="loader"></div>
            <p class="text-sm text-slate-400 font-medium">Loading EduTech...</p>
        </div>
    </div>

    <!-- Split Layout -->
    <div class="min-h-screen flex">

        <!-- ── Left Panel: Branding ── -->
        <div class="hidden lg:flex lg:w-1/2 xl:w-3/5 relative flex-col items-center justify-center overflow-hidden bg-secondary-900">
            <!-- Campus background -->
            <div class="absolute inset-0 bg-cover bg-center opacity-15" style="background-image: url('/images/campus.jpg');"></div>
            <!-- Gradient overlay -->
            <div class="absolute inset-0" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);"></div>
            <!-- Decorative blobs -->
            <div class="absolute -top-32 -left-32 w-96 h-96 rounded-full blur-3xl opacity-30" style="background-color: #e85c5c;"></div>
            <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full blur-3xl opacity-20" style="background-color: #e85c5c;"></div>

            <!-- Content -->
            <div class="relative z-10 text-center px-12 max-w-lg">
                <div class="w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-white/10 shadow-xl"
                     style="background-color: rgba(232,92,92,0.15);">
                    <i class="material-icons text-white text-4xl">school</i>
                </div>
                <h1 class="text-4xl font-bold text-white mb-2">
                    Edu<span style="color: #e85c5c;">Tech</span>
                </h1>
                <p class="text-slate-400 text-sm mb-10">Learn Smarter. Achieve Greater.</p>

                <div class="space-y-3 text-left">
                    @foreach (var item in new[] {
                                        ("verified_user",   "Secure Access",       "Role-based authentication for all users"),
                                        ("bar_chart",       "Academic Analytics",  "Real-time insights into student performance"),
                                        ("manage_accounts", "Unified Management",  "Courses, grades, and records in one place")
                                        })
                    {
                        <div class="flex items-start gap-4 bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-4">
                            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0"
                                 style="background-color: rgba(232,92,92,0.2);">
                                <i class="material-icons text-sm" style="color: #e85c5c;">@item.Item1</i>
                            </div>
                            <div>
                                <p class="text-white font-semibold text-sm">@item.Item2</p>
                                <p class="text-slate-400 text-xs mt-0.5">@item.Item3</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ── Right Panel: Login Form ── -->
        <div class="w-full lg:w-1/2 xl:w-2/5 flex flex-col items-center justify-center px-6 py-12 bg-white shadow-xl">
            <div class="w-full max-w-sm">

                <!-- Institution Header -->
                <div class="fade-up fade-up-1 flex flex-col items-center mb-8">
                    <div class="w-16 h-16 rounded-xl flex items-center justify-center mb-4 shadow-lg"
                         style="background-color: #1e293b;">
                        <img src="@($"{institution.LogoPath}")"
                             alt="@institution.Name"
                             class="h-10 w-10 object-contain"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <i class="material-icons text-white text-2xl hidden">account_balance</i>
                    </div>
                    <h2 class="text-lg font-bold text-gray-900 text-center leading-tight">@institution.Name</h2>
                    <p class="text-sm text-gray-500 mt-1">Student Information System</p>
                </div>

                <!-- Alert Message -->
                @if (TempData["LoginMessage"] != null)
                {
                    string messageType = TempData["LoginMessageType"]?.ToString() ?? "info";
                    string alertClass = messageType switch
                    {
                                "success" => "bg-green-50 border-green-200 text-green-800",
                                "error" => "bg-red-50 border-red-200 text-red-800",
                                "warning" => "bg-yellow-50 border-yellow-200 text-yellow-800",
                        _ => "bg-blue-50 border-blue-200 text-blue-800"
                    };
                    string iconName = messageType switch
                    {
                                "success" => "check_circle",
                                "error" => "error",
                                "warning" => "warning",
                        _ => "info"
                    };
                    <div id="loginMessage"
                         class="fade-up fade-up-1 @alertClass border rounded-lg px-4 py-3 mb-6 flex items-start gap-2 text-sm">
                        <i class="material-icons text-sm mt-0.5">@iconName</i>
                        <span class="flex-1">@TempData["LoginMessage"]</span>
                        <button type="button" onclick="hideMessage()" class="opacity-50 hover:opacity-100 transition-opacity">
                            <i class="material-icons text-sm">close</i>
                        </button>
                    </div>
                }

                <!-- Form -->
                <form asp-action="Login" method="post" id="loginForm" class="space-y-6">

                    <!-- Email / Student ID — floating label style matching other pages -->
                    <div class="fade-up fade-up-2 relative z-0 w-full group">
                        <input asp-for="EmailOrStudentId"
                               type="text"
                               id="emailInput"
                               class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                               style="border-bottom-color: inherit;"
                               onfocus="this.style.borderBottomColor='#e85c5c'"
                               onblur="this.style.borderBottomColor=''"
                               placeholder=" " />
                        <label for="emailInput"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6"
                               style="--tw-peer-focus-color: #e85c5c;">
                            Email or Student ID
                        </label>
                        <span asp-validation-for="EmailOrStudentId" class="mt-1 text-xs text-red-500"></span>
                    </div>

                    <!-- Password -->
                    <div class="fade-up fade-up-3 relative z-0 w-full group">
                        <input asp-for="Password"
                               type="password"
                               id="passwordInput"
                               class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer pr-8"
                               onfocus="this.style.borderBottomColor='#e85c5c'"
                               onblur="this.style.borderBottomColor=''"
                               placeholder=" " />
                        <label for="passwordInput"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Password
                        </label>
                        <button type="button" id="togglePassword"
                                class="absolute right-0 top-2.5 text-gray-400 transition-colors"
                                onmouseenter="this.style.color='#e85c5c'" onmouseleave="this.style.color=''">
                            <i class="material-icons text-sm" id="toggleIcon">visibility</i>
                        </button>
                        <span asp-validation-for="Password" class="mt-1 text-xs text-red-500"></span>
                    </div>

                    <!-- Remember Me & Forgot Password -->
                    <div class="fade-up fade-up-3 flex items-center justify-between">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input asp-for="RememberMe"
                                   class="w-4 h-4 border-gray-300 rounded transition-colors"
                                   style="accent-color: #e85c5c;" />
                            <span class="text-xs text-gray-600">Remember me</span>
                        </label>
                        <a href="@Url.Action("Index", "ForgotPassword")"
                           class="text-xs font-medium transition-colors"
                           style="color: #e85c5c;"
                           onmouseenter="this.style.color='#c53030'" onmouseleave="this.style.color='#e85c5c'">
                            Forgot password?
                        </a>
                    </div>

                    <!-- Submit -->
                    <div class="fade-up fade-up-4 space-y-3">
                        <button type="submit"
                                class="w-full flex justify-center items-center gap-2 py-2.5 px-4 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md"
                                style="background-color: #e85c5c;"
                                onmouseenter="this.style.backgroundColor='#c53030'"
                                onmouseleave="this.style.backgroundColor='#e85c5c'">
                            Sign In
                            <i class="material-icons text-sm">arrow_forward</i>
                        </button>

                        <p class="text-xs text-center text-gray-500">
                            New student?
                            <a asp-controller="Admin" asp-action="CandidateRegistration"
                               class="font-semibold transition-colors"
                               style="color: #e85c5c;"
                               onmouseenter="this.style.color='#c53030'" onmouseleave="this.style.color='#e85c5c'">
                                Apply Now
                            </a>
                        </p>
                    </div>
                </form>

                <!-- Footer -->
                <p class="fade-up fade-up-4 text-center text-xs text-gray-400 mt-10">
                    &copy; @DateTime.Now.Year @institution.Name. All rights reserved.
                </p>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        window.addEventListener('load', function () {
            const loader = document.getElementById('loader');
            loader.style.opacity = '0';
            setTimeout(() => loader.style.display = 'none', 500);
        });

        document.getElementById('togglePassword').addEventListener('click', function () {
            const input = document.getElementById('passwordInput');
            const icon  = document.getElementById('toggleIcon');
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            icon.textContent = isPassword ? 'visibility_off' : 'visibility';
        });

        function hideMessage() {
            const msg = document.getElementById('loginMessage');
            if (msg) {
                msg.style.opacity = '0';
                msg.style.transform = 'translateY(-8px)';
                msg.style.transition = 'all 0.3s ease';
                setTimeout(() => msg.style.display = 'none', 300);
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const msg = document.getElementById('loginMessage');
            if (msg) setTimeout(hideMessage, 5000);
        });
    </script>
</body>
</html>