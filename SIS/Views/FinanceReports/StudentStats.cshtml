function updateTransactionsPagination() {
    const totalPages = Math.ceil(filteredData.transactions.length / pageSize);
    const totalRecords = filteredData.transactions.length;
    
    console.log('Updating transactions pagination:', totalRecords, 'records', totalPages, 'pages');
    
    // Update total records display in header
    const headerElement = document.getElementById('transactionsTotalCount');
    if (headerElement) {
        headerElement.textContent = totalRecords.toLocaleString();
    }
    
    // Show/hide pagination based on number of pages
    const paginationDiv = document.getElementById('transactionsPagination');
    if (paginationDiv) {
        if (totalPages > 1) {
            paginationDiv.classList.remove('hidden');
            updatePaginationControls('transactions', totalPages, totalRecords);
        } else {
            paginationDiv.classList.add('hidden');
        }
    }
}

function updateOutstandingPagination() {
    const totalPages = Math.ceil(filteredData.outstanding.length / pageSize);
    const totalRecords = filteredData.outstanding.length;
    
    console.log('Updating outstanding pagination:', totalRecords, 'records', totalPages, 'pages');
    
    // Show/hide pagination based on number of pages
    const paginationDiv = document.getElementById('outstandingPagination');
    if (paginationDiv) {
        if (totalPages > 1) {
            paginationDiv.classList.remove('hidden');
            updatePaginationControls('outstanding', totalPages, totalRecords);
        } else {
            paginationDiv.classList.add('hidden');
        }
    }
}

function updatePaginationControls(section, totalPages, totalRecords) {
    const current = currentPage[section];
    const start = totalRecords === 0 ? 0 : (current - 1) * pageSize + 1;
    const end = Math.min(current * pageSize, totalRecords);
    
    // Create pagination HTML dynamically
    const totalPagesForSection = Math.ceil(filteredData[section].length / pageSize);
    const paginationHtml = `
        <div class="flex items-center justify-between bg-slate-50 p-4 rounded-b-2xl">
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 text-sm text-slate-600">
                    <span>Showing</span>
                    <span class="font-semibold">${start}</span>
                    <span>to</span>
                    <span class="font-semibold">${end}</span>
                    <span>of</span>
                    <span class="font-semibold">${totalRecords.toLocaleString()}</span>
                    <span>${section === 'transactions' ? 'payments' : 'students'}</span>
                </div>
                
                <div class="flex items-center gap-2">
                    <button onclick="jumpToPage('${section}')" 
                            class="px-3 py-2 text-sm text-slate-600 hover:text-slate-800 hover:bg-slate-100 rounded-lg transition-colors"
                            title="Jump to specific page">
                        <i class="material-icons text-sm">skip_next</i>
                    </button>
                </div>
            </div>
            
            <div class="flex items-center gap-2">
                ${current > 1 ? `
                    <button onclick="changePage('${section}', 1)" 
                            class="px-3 py-2 text-sm text-slate-600 hover:text-slate-800 hover:bg-slate-100 rounded-lg transition-colors"
                            title="First page">
                        <i class="material-icons text-sm">first_page</i>
                    </button>
                    <button onclick="changePage('${section}', ${current - 1})" 
                            class="px-3 py-2 text-sm text-slate-600 hover:text-slate-800 hover:bg-slate-100 rounded-lg transition-colors"
                            title="Previous page">
                        <i class="material-icons text-sm">chevron_left</i>
                    </button>
                ` : ''}
                
                ${generatePageNumbers(section, current, totalPages)}
                
                ${current < totalPages ? `
                    <button onclick="changePage('${section}', ${current + 1})" 
                            class="px-3 py-2 text-sm text-slate-600 hover:text-slate-800 hover:bg-slate-100 rounded-lg transition-colors"
                            title="Next page">
                        <i class="material-icons text-sm">chevron_right</i>
                    </button>
                    <button onclick="changePage('${section}', ${totalPages})" 
                            class="px-3 py-2 text-sm text-slate-600 hover:text-slate-800 hover:bg-slate-100 rounded-lg transition-colors"
                            title="Last page">
                        <i class="material-icons text-sm">last_page</i>
                    </button>
                ` : ''}
                
                <div class="ml-4 flex items-center gap-2 text-sm text-slate-600">
                    <span>Page ${current} of ${totalPages}</span>
                </div>
            </div>
        </div>
    `;
    
    const paginationDiv = document.getElementById(`${section}Pagination`);
    if (paginationDiv) {
        paginationDiv.innerHTML = paginationHtml;
    }
}

function generatePageNumbers(section, current, totalPages) {
    let pageNumbers = '';
    const startPage = Math.max(1, current - 2);
    const endPage = Math.min(totalPages, current + 2);
    
    for (let i = startPage; i <= endPage; i++) {
        const colorClass = section === 'transactions' ? 'bg-blue-600' : 'bg-amber-600';
        if (i === current) {
            pageNumbers += `<span class="px-3 py-2 text-sm ${colorClass} text-white rounded-lg">${i}</span>`;
        } else {
            pageNumbers += `<button onclick="changePage('${section}', ${i})" 
                                   class="px-3 py-2 text-sm text-slate-600 hover:text-slate-800 hover:bg-slate-100 rounded-lg transition-colors">
                               ${i}
                           </button>`;
        }
    }
    
    return pageNumbers;
}

function changePage(section, page) {
    console.log('Changing page for', section, 'to', page);
    currentPage[section] = page;
    if (section === 'transactions') {
        displayTransactionsPage(page);
    } else {
        displayOutstandingPage(page);
    }
}

function changePageSize() {
    const newPageSize = parseInt(document.getElementById('pageSize').value);
    console.log('Changing page size to:', newPageSize);
    
    pageSize = newPageSize;
    
    // Reset to first page
    currentPage.transactions = 1;
    currentPage.outstanding = 1;
    
    // Refresh both displays
    displayTransactionsPage(1);
    displayOutstandingPage(1);
}

function jumpToPage(section) {
    const input = prompt(`Enter page number (1 to ${Math.ceil(filteredData[section].length / pageSize)}):`);
    if (input) {
        const page = parseInt(input);
        const maxPages = Math.ceil(filteredData[section].length / pageSize);
        
        if (page >= 1 && page <= maxPages) {
            changePage(section, page);
        } else {
            showNotification('Invalid page number. Please enter a valid page number.', 'error');
        }
    }
}

function applyFilters() {
    console.log('Apply filters clicked');
    
    // Apply filters and reset to first page
    currentPage.transactions = 1;
    currentPage.outstanding = 1;
    
    applyTransactionFilters();
    applyOutstandingFilters();
    
    displayTransactionsPage(1);
