// Excel Export Functions
function exportTransactionsToExcel() {
    try {
        showLoading(true);
        
        // Prepare data for Excel
        const dataToExport = filteredData.transactions.map(transaction => ({
            'Student Name': transaction.StudentName || 'Unknown',
            'Student ID': transaction.StudentId || 'N/A',
            'Programme': transaction.Programme || 'Unknown',
            'Amount (K)': transaction.Amount || 0,
            'Payment Method': transaction.PaymentMethod || 'Unknown',
            'Transaction Reference': transaction.TransactionRef || 'N/A',
            'Payment Date': transaction.PaymentDate ? new Date(transaction.PaymentDate).toLocaleDateString('en-US') : 'N/A',
            'Payment Time': transaction.PaymentDate ? new Date(transaction.PaymentDate).toLocaleTimeString('en-US') : 'N/A'
        }));
        
        // Create workbook
        const workbook = XLSX.utils.book_new();
        const worksheet = XLSX.utils.json_to_sheet(dataToExport);
        
        // Set column widths
        const columnWidths = [
            { wch: 25 }, // Student Name
            { wch: 15 }, // Student ID
            { wch: 30 }, // Programme
            { wch: 12 }, // Amount
            { wch: 15 }, // Payment Method
            { wch: 20 }, // Transaction Reference
            { wch: 12 }, // Payment Date
            { wch: 12 }  // Payment Time
        ];
        worksheet['!cols'] = columnWidths;
        
        // Add worksheet to workbook
        XLSX.utils.book_append_sheet(workbook, worksheet, 'Student Payments');
        
        // Generate filename with timestamp
        const timestamp = new Date().toISOString().slice(0, 19).replace(/[:-]/g, '');
        const filename = `Student_Payments_${timestamp}.xlsx`;
        
        // Save file
        XLSX.writeFile(workbook, filename);
        
        showNotification('Excel file exported successfully!', 'success');
        
    } catch (error) {
        console.error('Error exporting transactions to Excel:', error);
        showNotification('Error exporting to Excel. Please try again.', 'error');
    } finally {
        showLoading(false);
    }
}

