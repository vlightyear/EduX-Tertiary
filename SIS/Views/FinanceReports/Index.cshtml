@{
    ViewData["Title"] = "Daily Collections";
}

<style>
    :root {
        --coral: #e85c5c;
        --coral-dk: #d43f3f;
        --coral-lt: #fff1f1;
        --coral-mid: #ffc5c5;
        --navy: #1e2d5e;
        --navy-lt: #eef2ff;
        --navy-mid: #c2d0ff;
        --bg: #f0f4f8;
        --surface: #ffffff;
        --border: #e2e8f0;
        --text: #1e2d5e;
        --muted: #64748b;
        --faint: #94a3b8;
        --green: #22c55e;
        --green-lt: #f0fdf4;
        --amber: #f59e0b;
        --amber-lt: #fffbeb;
        --radius-lg: 14px;
        --radius-md: 10px;
        --radius-sm: 7px;
        --shadow-sm: 0 2px 8px rgba(30,45,94,.07);
        --shadow-md: 0 6px 20px rgba(30,45,94,.10);
    }

    .dc-page {
        background: var(--bg);
        min-height: 100vh;
        padding: 1.5rem;
        font-family: 'Segoe UI', system-ui, sans-serif;
        color: var(--text);
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-up {
        animation: fadeUp .38s ease both;
    }

    .delay-1 {
        animation-delay: .07s;
    }

    .delay-2 {
        animation-delay: .14s;
    }

    .delay-3 {
        animation-delay: .21s;
    }

    .delay-4 {
        animation-delay: .28s;
    }

    .delay-5 {
        animation-delay: .35s;
    }

    /* ── Page Header ── */
    .dc-header {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    @@media(min-width:768px) {
        .dc-header {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }

    .dc-title-block {
        display: flex;
        align-items: center;
        gap: .9rem;
    }

    .dc-icon {
        width: 52px;
        height: 52px;
        border-radius: 13px;
        background: linear-gradient(135deg, var(--coral), var(--coral-dk));
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 14px rgba(232,92,92,.32);
        flex-shrink: 0;
    }

        .dc-icon .material-icons {
            color: #fff;
            font-size: 26px;
        }

    .dc-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--navy);
        margin: 0;
        line-height: 1.15;
    }

    .dc-sub {
        font-size: .78rem;
        color: var(--muted);
        margin: 0;
        margin-top: 3px;
    }

    /* ── Cards ── */
    .dc-card {
        background: var(--surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .dc-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .75rem;
        padding: .95rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(to right, #fafbff, var(--surface));
    }

    .dc-card-header-title {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .9rem;
        font-weight: 700;
        color: var(--navy);
    }

        .dc-card-header-title .material-icons {
            font-size: 19px;
            color: var(--coral);
        }

    .dc-card-body {
        padding: 1.1rem 1.25rem 1.25rem;
    }

    /* ── Collapsible filter toggle ── */
    .filter-toggle-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .75rem;
        padding: .95rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(to right, #fafbff, var(--surface));
        cursor: pointer;
        user-select: none;
        transition: background .18s;
    }

        .filter-toggle-header:hover {
            background: linear-gradient(to right, var(--navy-lt), #f5f7ff);
        }

    .filter-toggle-left {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .filter-toggle-left > span {
            font-size: .9rem;
            font-weight: 700;
            color: var(--navy);
        }

        .filter-toggle-left .material-icons {
            font-size: 19px;
            color: var(--coral);
        }

    .filter-toggle-right {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .filter-active-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .18rem .6rem;
        background: var(--coral-lt);
        border: 1px solid var(--coral-mid);
        border-radius: 999px;
        font-size: .7rem;
        font-weight: 700;
        color: var(--coral-dk);
    }

        .filter-active-badge .material-icons {
            font-size: 12px;
        }

    .chevron-icon {
        font-size: 22px;
        color: var(--muted);
        transition: transform .28s cubic-bezier(.4,0,.2,1);
    }

        .chevron-icon.open {
            transform: rotate(180deg);
        }

    .filter-collapsible {
        overflow: hidden;
        max-height: 800px;
        transition: max-height .35s cubic-bezier(.4,0,.2,1), opacity .25s ease;
        opacity: 1;
    }

        .filter-collapsible.collapsed {
            max-height: 0;
            opacity: 0;
        }

    /* ── Filter grid ── */
    .filter-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: .875rem;
    }

    @@media(min-width:640px) {
        .filter-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(min-width:1024px) {
        .filter-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .filter-section-label {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--navy);
        margin-bottom: .75rem;
    }

        .filter-section-label .material-icons {
            font-size: 15px;
            color: var(--coral);
        }

    .fld-label {
        display: block;
        font-size: .7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--muted);
        margin-bottom: .35rem;
    }

    .fld-control {
        width: 100%;
        padding: .6rem .85rem;
        font-size: .83rem;
        font-family: inherit;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        background: #fafbfc;
        color: var(--text);
        outline: none;
        transition: border-color .18s, box-shadow .18s;
        box-sizing: border-box;
    }

        .fld-control:focus {
            border-color: var(--coral);
            box-shadow: 0 0 0 3px rgba(232,92,92,.11);
            background: #fff;
        }

    .date-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .75rem;
    }

    .filter-stacked {
        display: flex;
        flex-direction: column;
        gap: .65rem;
    }

    .filter-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .75rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
    }

    .btn-apply {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .55rem 1.3rem;
        background: var(--coral);
        color: #fff;
        font-size: .82rem;
        font-weight: 700;
        font-family: inherit;
        border: none;
        border-radius: var(--radius-sm);
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(232,92,92,.28);
        transition: background .18s, box-shadow .18s;
    }

        .btn-apply:hover {
            background: var(--coral-dk);
            box-shadow: 0 4px 14px rgba(232,92,92,.36);
        }

        .btn-apply .material-icons {
            font-size: 17px;
        }

    .btn-reset {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .55rem 1.1rem;
        background: #f1f5f9;
        color: var(--muted);
        font-size: .82rem;
        font-weight: 600;
        font-family: inherit;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition: background .18s, color .18s;
    }

        .btn-reset:hover {
            background: #e2e8f0;
            color: var(--navy);
        }

        .btn-reset .material-icons {
            font-size: 17px;
        }

    /* ── KPI Grid ── */
    .kpi-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    @@media(min-width:640px) {
        .kpi-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(min-width:1024px) {
        .kpi-grid {
            grid-template-columns: repeat(5, 1fr);
        }
    }

    .kpi-card {
        background: var(--surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        padding: 1.1rem;
        position: relative;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }

        .kpi-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .kpi-card.coral::before {
            background: linear-gradient(90deg, var(--coral), var(--coral-dk));
        }

        .kpi-card.navy::before {
            background: linear-gradient(90deg, var(--navy), #2e45a0);
        }

        .kpi-card.green::before {
            background: linear-gradient(90deg, var(--green), #16a34a);
        }

        .kpi-card.amber::before {
            background: linear-gradient(90deg, var(--amber), #d97706);
        }

        .kpi-card.purple::before {
            background: linear-gradient(90deg, #8b5cf6, #7c3aed);
        }

    .kpi-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: .75rem;
    }

    .kpi-icon-wrap {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .kpi-card.coral .kpi-icon-wrap {
        background: var(--coral-lt);
    }

    .kpi-card.navy .kpi-icon-wrap {
        background: var(--navy-lt);
    }

    .kpi-card.green .kpi-icon-wrap {
        background: var(--green-lt);
    }

    .kpi-card.amber .kpi-icon-wrap {
        background: var(--amber-lt);
    }

    .kpi-card.purple .kpi-icon-wrap {
        background: #f5f3ff;
    }

    .kpi-icon-wrap .material-icons {
        font-size: 20px;
    }

    .kpi-card.coral .kpi-icon-wrap .material-icons {
        color: var(--coral);
    }

    .kpi-card.navy .kpi-icon-wrap .material-icons {
        color: var(--navy);
    }

    .kpi-card.green .kpi-icon-wrap .material-icons {
        color: var(--green);
    }

    .kpi-card.amber .kpi-icon-wrap .material-icons {
        color: var(--amber);
    }

    .kpi-card.purple .kpi-icon-wrap .material-icons {
        color: #8b5cf6;
    }

    .kpi-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--navy);
        line-height: 1.1;
    }

    .kpi-label {
        font-size: .68rem;
        color: var(--muted);
        margin-top: .25rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    /* ── Tabs ── */
    .tabs-bar {
        background: var(--surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        padding: .5rem .75rem;
        margin-bottom: 1.25rem;
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
    }

    .tab-btn {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .55rem 1.1rem;
        font-size: .82rem;
        font-weight: 600;
        font-family: inherit;
        border: none;
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition: background .18s, color .18s;
        color: var(--muted);
        background: transparent;
    }

        .tab-btn:hover {
            background: var(--navy-lt);
            color: var(--navy);
        }

        .tab-btn.active {
            background: var(--coral);
            color: #fff;
            box-shadow: 0 2px 8px rgba(232,92,92,.28);
        }

        .tab-btn .material-icons {
            font-size: 16px;
        }

    /* ── Section header right ── */
    .section-header-right {
        display: flex;
        align-items: center;
        gap: .875rem;
        flex-wrap: wrap;
    }

    .count-badge {
        background: var(--navy-lt);
        border: 1px solid var(--navy-mid);
        border-radius: var(--radius-sm);
        padding: .45rem .875rem;
        text-align: center;
    }

        .count-badge .cb-label {
            font-size: .68rem;
            color: var(--muted);
            font-weight: 500;
        }

        .count-badge .cb-value {
            font-size: .92rem;
            font-weight: 700;
            color: var(--navy);
        }

    .btn-export {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .5rem 1rem;
        background: var(--navy);
        color: #fff;
        font-size: .8rem;
        font-weight: 600;
        font-family: inherit;
        border: none;
        border-radius: var(--radius-sm);
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(30,45,94,.2);
        transition: background .18s;
    }

        .btn-export:hover {
            background: #16224a;
        }

        .btn-export .material-icons {
            font-size: 16px;
        }

    /* ── View mode toggle ── */
    .view-toggle {
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .view-toggle-btn {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .4rem .8rem;
        font-size: .78rem;
        font-weight: 600;
        font-family: inherit;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        cursor: pointer;
        background: #f1f5f9;
        color: var(--muted);
        transition: all .18s;
    }

        .view-toggle-btn:hover {
            border-color: var(--navy-mid);
            color: var(--navy);
        }

        .view-toggle-btn.active {
            background: var(--navy-lt);
            border-color: var(--navy-mid);
            color: var(--navy);
        }

        .view-toggle-btn .material-icons {
            font-size: 15px;
        }

    /* ── Table ── */
    .dc-table-wrap {
        overflow-x: auto;
    }

        .dc-table-wrap::-webkit-scrollbar {
            height: 5px;
        }

        .dc-table-wrap::-webkit-scrollbar-thumb {
            background: var(--coral-mid);
            border-radius: 4px;
        }

    .dc-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: .82rem;
    }

        .dc-table thead tr {
            background: linear-gradient(to right, var(--navy-lt), #f5f7ff);
        }

        .dc-table thead th {
            padding: .75rem 1.1rem;
            font-size: .69rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: var(--navy);
            border-bottom: 2px solid var(--navy-mid);
            white-space: nowrap;
        }

        .dc-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background .15s;
        }

            .dc-table tbody tr:last-child {
                border-bottom: none;
            }

            .dc-table tbody tr:hover {
                background: var(--coral-lt);
            }

        .dc-table td {
            padding: .7rem 1.1rem;
            vertical-align: middle;
        }

        .dc-table tbody tr:nth-child(even) td {
            background: rgba(248,250,252,.6);
        }

        .dc-table tbody tr:nth-child(even):hover td {
            background: var(--coral-lt);
        }

    /* ── Group header row ── */
    .group-header-row td {
        background: linear-gradient(to right, var(--navy-lt), #f0f4ff) !important;
        padding: .6rem 1.1rem;
        border-top: 2px solid var(--navy-mid);
        border-bottom: 1px solid var(--navy-mid);
    }

    .group-header-row:hover td {
        background: linear-gradient(to right, var(--navy-lt), #f0f4ff) !important;
    }

    .group-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .group-title {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .8rem;
        font-weight: 700;
        color: var(--navy);
    }

    .group-method-icon {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: var(--coral);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .group-method-icon .material-icons {
            font-size: 15px;
            color: #fff;
        }

    .group-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .18rem .65rem;
        border-radius: 999px;
        font-size: .7rem;
        font-weight: 600;
        background: var(--navy);
        color: #fff;
    }

    .group-subtotal-amt {
        font-size: .8rem;
        font-weight: 700;
        color: var(--green);
    }

    .group-collapse-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        color: var(--navy);
        display: flex;
        align-items: center;
        transition: color .15s;
    }

        .group-collapse-btn:hover {
            color: var(--coral);
        }

        .group-collapse-btn .material-icons {
            font-size: 20px;
            transition: transform .25s;
        }

        .group-collapse-btn.collapsed .material-icons {
            transform: rotate(-90deg);
        }

    /* ── Group subtotal footer row ── */
    .group-footer-row td {
        background: linear-gradient(to right, var(--green-lt), #f8fffe) !important;
        padding: .55rem 1.1rem;
        border-top: 1px solid #bbf7d0;
        border-bottom: 2px solid #86efac;
        font-size: .78rem;
        font-weight: 700;
        color: var(--navy);
    }

    .group-footer-row:hover td {
        background: linear-gradient(to right, var(--green-lt), #f8fffe) !important;
    }

    .student-name {
        font-weight: 700;
        font-size: .84rem;
        color: var(--navy);
    }

    .student-id {
        font-size: .72rem;
        color: var(--faint);
        margin-top: 2px;
    }

    .programme-cell {
        font-size: .8rem;
        color: var(--muted);
    }

    .amount-pos {
        font-size: 1rem;
        font-weight: 700;
        color: var(--green);
    }

    .amount-neg {
        font-size: 1rem;
        font-weight: 700;
        color: var(--coral-dk);
    }

    .method-pill {
        display: inline-flex;
        align-items: center;
        padding: .2rem .7rem;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 600;
        background: var(--navy-lt);
        color: var(--navy);
        border: 1px solid var(--navy-mid);
    }

    .ref-mono {
        font-family: 'Courier New', monospace;
        font-size: .77rem;
        color: var(--muted);
    }

    .date-main {
        font-size: .8rem;
        color: var(--text);
    }

    .date-time {
        font-size: .7rem;
        color: var(--faint);
    }

    .action-btn-sm {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s, color .15s;
    }

        .action-btn-sm.email {
            background: var(--navy-lt);
            color: var(--navy);
        }

            .action-btn-sm.email:hover {
                background: var(--navy-mid);
            }

        .action-btn-sm.view {
            background: #f1f5f9;
            color: var(--muted);
        }

            .action-btn-sm.view:hover {
                background: #e2e8f0;
                color: var(--navy);
            }

        .action-btn-sm .material-icons {
            font-size: 15px;
        }

    .chk-cell input[type="checkbox"] {
        width: 15px;
        height: 15px;
        accent-color: var(--coral);
        cursor: pointer;
    }

    .empty-row td {
        padding: 3rem 1rem;
        text-align: center;
        color: var(--faint);
        font-size: .84rem;
    }

    .empty-row .material-icons {
        font-size: 2.5rem;
        color: var(--navy-mid);
        display: block;
        margin-bottom: .6rem;
    }

    /* ── Pagination bar ── */
    .pg-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .75rem;
        padding: .875rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fafbfc;
        font-size: .78rem;
        color: var(--muted);
    }

    .pg-info strong {
        color: var(--navy);
    }

    .pg-buttons {
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .pg-btn {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid var(--border);
        background: #fff;
        color: var(--muted);
        cursor: pointer;
        font-size: .78rem;
        font-weight: 600;
        transition: all .15s;
    }

        .pg-btn:hover {
            border-color: var(--coral);
            color: var(--coral);
        }

        .pg-btn.active {
            background: var(--coral);
            border-color: var(--coral);
            color: #fff;
        }

        .pg-btn:disabled {
            opacity: .4;
            pointer-events: none;
        }

        .pg-btn .material-icons {
            font-size: 17px;
        }

    /* ── Loading overlay ── */
    .loading-overlay {
        position: fixed;
        inset: 0;
        background: rgba(30,45,94,.45);
        backdrop-filter: blur(3px);
        z-index: 40;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .loading-overlay.hidden {
            display: none;
        }

    .loading-box {
        background: #fff;
        border-radius: var(--radius-lg);
        padding: 1.75rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-md);
    }

    .spinner {
        width: 28px;
        height: 28px;
        border: 3px solid var(--coral-mid);
        border-top-color: var(--coral);
        border-radius: 50%;
        animation: spin .75s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .loading-box span {
        font-size: .88rem;
        font-weight: 600;
        color: var(--navy);
    }

    /* ── Toast ── */
    .toast {
        position: fixed;
        top: 1.25rem;
        right: 1.25rem;
        z-index: 50;
        padding: .875rem 1.25rem;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-md);
        display: flex;
        align-items: center;
        gap: .75rem;
        font-size: .84rem;
        font-weight: 500;
        transform: translateX(calc(100% + 2rem));
        transition: transform .3s ease;
        min-width: 260px;
    }

        .toast.show {
            transform: translateX(0);
        }

        .toast .material-icons {
            font-size: 19px;
        }

        .toast.success {
            background: #f0fdf4;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .toast.error {
            background: var(--coral-lt);
            color: var(--coral-dk);
            border: 1px solid var(--coral-mid);
        }

        .toast.info {
            background: var(--navy-lt);
            color: var(--navy);
            border: 1px solid var(--navy-mid);
        }
</style>

<div class="dc-page">

    <!-- ── Header ── -->
    <div class="dc-header fade-up">
        <div class="dc-title-block">
            <div class="dc-icon"><i class="material-icons">assessment</i></div>
            <div>
                <h1 class="dc-title">Daily Collections Report</h1>
                <p class="dc-sub">Comprehensive transaction &amp; payment records</p>
            </div>
        </div>
    </div>

    <!-- ── Filters (collapsible) ── -->
    <div class="dc-card fade-up delay-1" style="margin-bottom:1.25rem;">

        <!-- Clickable toggle header -->
        <div class="filter-toggle-header" onclick="toggleFilters()">
            <div class="filter-toggle-left">
                <i class="material-icons">tune</i>
                <span>Filters</span>
                <span class="filter-active-badge" id="activeFiltersBadge" style="display:none;">
                    <i class="material-icons">filter_alt</i>
                    <span id="activeFiltersCount">0</span> active
                </span>
            </div>
            <div class="filter-toggle-right">
                <span style="font-size:.75rem; color:var(--muted); font-weight:500;" id="filterToggleHint">Click to collapse</span>
                <i class="material-icons chevron-icon open" id="filterChevron">expand_more</i>
            </div>
        </div>

        <!-- Collapsible body -->
        <div class="filter-collapsible" id="filterCollapsible">
            <div class="dc-card-body">
                <div class="filter-grid">

                    <!-- Date range -->
                    <div>
                        <div class="filter-section-label">
                            <i class="material-icons">date_range</i>
                            Date Range
                        </div>
                        <div class="date-row">
                            <div>
                                <label class="fld-label" for="fromDate">From</label>
                                <input type="date" id="fromDate" class="fld-control" oninput="updateActiveFiltersBadge()">
                            </div>
                            <div>
                                <label class="fld-label" for="toDate">To</label>
                                <input type="date" id="toDate" class="fld-control" oninput="updateActiveFiltersBadge()">
                            </div>
                        </div>
                    </div>

                    <!-- Search fields -->
                    <div>
                        <div class="filter-section-label">
                            <i class="material-icons">search</i>
                            Search
                        </div>
                        <div class="filter-stacked">
                            <div>
                                <label class="fld-label" for="studentNumber">Student Number</label>
                                <input type="text" id="studentNumber" placeholder="Enter student number…" class="fld-control" oninput="updateActiveFiltersBadge()">
                            </div>
                            <div>
                                <label class="fld-label" for="transactionRef">Transaction Reference</label>
                                <input type="text" id="transactionRef" placeholder="Enter reference…" class="fld-control" oninput="updateActiveFiltersBadge()">
                            </div>
                        </div>
                    </div>

                    <!-- Dropdowns -->
                    <div>
                        <div class="filter-section-label">
                            <i class="material-icons">filter_list</i>
                            Categories
                        </div>
                        <div class="filter-stacked">
                            <div>
                                <label class="fld-label" for="paymentMethod">Payment Method</label>
                                <select id="paymentMethod" class="fld-control" onchange="updateActiveFiltersBadge()">
                                    <option value="">All Methods</option>
                                </select>
                            </div>
                            <div>
                                <label class="fld-label" for="programme">Programme</label>
                                <select id="programme" class="fld-control" onchange="updateActiveFiltersBadge()">
                                    <option value="">All Programmes</option>
                                </select>
                            </div>
                            <div>
                                <label class="fld-label" for="school">School</label>
                                <select id="school" class="fld-control" onchange="updateActiveFiltersBadge()">
                                    <option value="">All Schools</option>
                                </select>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="filter-actions">
                    <button onclick="applyFilters()" class="btn-apply">
                        <i class="material-icons">search</i>
                        Apply Filters
                    </button>
                    <button onclick="clearAllFilters()" class="btn-reset">
                        <i class="material-icons">refresh</i>
                        Clear All
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── KPI Cards ── -->
    <div class="kpi-grid">
        <div class="kpi-card green fade-up delay-1">
            <div class="kpi-top">
                <div class="kpi-icon-wrap"><i class="material-icons">account_balance_wallet</i></div>
            </div>
            <div class="kpi-value" id="totalRevenue">K0</div>
            <div class="kpi-label">Total Collections</div>
        </div>
    </div>

    <!-- ── Tabs ── -->
    <div class="tabs-bar fade-up delay-2">
        <button onclick="showSection('transactions')" id="transactionsTab" class="tab-btn active">
            <i class="material-icons">receipt_long</i>
            Collections
        </button>
        <button onclick="showSection('outstanding')" id="outstandingTab" class="tab-btn">
            <i class="material-icons">warning</i>
            Outstanding Payments
        </button>
    </div>

    <!-- ── Student Payments Section ── -->
    <div id="transactionsSection" class="report-section fade-up delay-3">
        <div class="dc-card" style="margin-bottom:1.25rem;">
            <div class="dc-card-header">
                <div class="dc-card-header-title">
                    <i class="material-icons">receipt_long</i>
                    Student Payments
                    <span style="font-size:.72rem; font-weight:500; color:var(--muted); background:var(--navy-lt);
                                 border:1px solid var(--navy-mid); border-radius:999px; padding:.1rem .6rem; margin-left:.25rem;">
                        payment records &amp; transaction history
                    </span>
                </div>
                <div class="section-header-right">
                    <!-- Flat / Grouped toggle -->
                    <div class="view-toggle">
                        <button class="view-toggle-btn active" id="flatViewBtn" onclick="setViewMode('flat')" title="Flat list">
                            <i class="material-icons">view_list</i> Flat
                        </button>
                        <button class="view-toggle-btn" id="groupedViewBtn" onclick="setViewMode('grouped')" title="Group by payment method">
                            <i class="material-icons">view_agenda</i> Grouped
                        </button>
                    </div>
                    <div class="count-badge">
                        <div class="cb-label">Total Records</div>
                        <div class="cb-value" id="transactionsTotalCount">0</div>
                    </div>
                    <button onclick="exportTransactionsToExcel()" class="btn-export">
                        <i class="material-icons">download</i>
                        Export Excel
                    </button>
                </div>
            </div>

            <div class="dc-table-wrap">
                <table class="dc-table">
                    <thead>
                        <tr>
                            <th>Student Details</th>
                            <th>Programme</th>
                            <th>Amount</th>
                            <th>Payment Method</th>
                            <th>Transaction Ref</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody id="transactionsTable"></tbody>
                </table>
            </div>
            <div id="transactionsPagination" class="hidden"></div>
        </div>
    </div>

    <!-- ── Outstanding Payments Section ── -->
    <div id="outstandingSection" class="report-section hidden fade-up delay-3">
        <div class="dc-card" style="margin-bottom:1.25rem;">
            <div class="dc-card-header">
                <div class="dc-card-header-title">
                    <i class="material-icons">warning</i>
                    Outstanding Payments
                    <span style="font-size:.72rem; font-weight:500; color:var(--muted); background:var(--amber-lt);
                                 border:1px solid #fde68a; border-radius:999px; padding:.1rem .6rem; margin-left:.25rem;">
                        students with unpaid balances
                    </span>
                </div>
                <div class="section-header-right">
                    <div class="count-badge" style="background:var(--coral-lt); border-color:var(--coral-mid);">
                        <div class="cb-label">Total Outstanding</div>
                        <div class="cb-value" id="outstandingTotalAmount" style="color:var(--coral-dk);">K0</div>
                    </div>
                    <button onclick="exportOutstandingToExcel()" class="btn-export">
                        <i class="material-icons">download</i>
                        Export Excel
                    </button>
                </div>
            </div>

            <div class="dc-table-wrap">
                <table class="dc-table">
                    <thead>
                        <tr>
                            <th class="chk-cell" style="width:40px;">
                                <input type="checkbox" id="selectAllOutstanding" onchange="toggleSelectAllOutstanding()">
                            </th>
                            <th>Student Details</th>
                            <th>Programme</th>
                            <th>School</th>
                            <th>Outstanding</th>
                            <th>Last Payment</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="outstandingTable"></tbody>
                </table>
            </div>
            <div id="outstandingPagination" class="hidden"></div>
        </div>
    </div>

</div><!-- /dc-page -->
<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay hidden">
    <div class="loading-box">
        <div class="spinner"></div>
        <span>Processing…</span>
    </div>
</div>

<!-- Toast -->
<div id="toastEl" class="toast info">
    <i class="material-icons" id="toastIcon">info</i>
    <span id="toastMsg"></span>
</div>

<script type="application/json" id="transactionsData">@Html.Raw(ViewBag.Transactions ?? "[]")</script>
<script type="application/json" id="outstandingData">@Html.Raw(ViewBag.OutstandingStudents ?? "[]")</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script>
    /* ════════════════════════════════════════════
       STATE
    ════════════════════════════════════════════ */
    let currentPage    = { transactions: 1, outstanding: 1 };
    let pageSize       = 50;
    let filteredData   = { transactions: [], outstanding: [] };
    let originalData   = { transactions: [], outstanding: [] };
    let viewMode       = 'flat';       // 'flat' | 'grouped'
    let filtersOpen    = true;
    let collapsedGroups = new Set();   // which payment-method groups are collapsed

    /* ════════════════════════════════════════════
       INIT
    ════════════════════════════════════════════ */
    document.addEventListener('DOMContentLoaded', function () {
        const params = new URLSearchParams(window.location.search);
        ['fromDate','toDate','studentNumber','transactionRef','paymentMethod','programme','school']
            .forEach(id => { if (params.get(id)) document.getElementById(id).value = params.get(id); });

        loadTransactionsData();
        loadOutstandingData();
    });

    /* ════════════════════════════════════════════
       COLLAPSIBLE FILTERS
    ════════════════════════════════════════════ */
    function toggleFilters() {
        filtersOpen = !filtersOpen;
        document.getElementById('filterCollapsible').classList.toggle('collapsed', !filtersOpen);
        document.getElementById('filterChevron').classList.toggle('open', filtersOpen);
        document.getElementById('filterToggleHint').textContent = filtersOpen ? 'Click to collapse' : 'Click to expand';
    }

    function updateActiveFiltersBadge() {
        const ids = ['fromDate','toDate','studentNumber','transactionRef','paymentMethod','programme','school'];
        const count = ids.filter(id => document.getElementById(id)?.value?.trim()).length;
        document.getElementById('activeFiltersCount').textContent = count;
        document.getElementById('activeFiltersBadge').style.display = count > 0 ? '' : 'none';
    }

    /* ════════════════════════════════════════════
       TABS
    ════════════════════════════════════════════ */
    function showSection(name) {
        document.querySelectorAll('.report-section').forEach(s => s.classList.add('hidden'));
        document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
        document.getElementById(name + 'Section').classList.remove('hidden');
        document.getElementById(name + 'Tab').classList.add('active');
    }

    /* ════════════════════════════════════════════
       VIEW MODE (flat / grouped)
    ════════════════════════════════════════════ */
    function setViewMode(mode) {
        viewMode = mode;
        collapsedGroups.clear();
        document.getElementById('flatViewBtn').classList.toggle('active', mode === 'flat');
        document.getElementById('groupedViewBtn').classList.toggle('active', mode === 'grouped');
        displayTransactionsPage(currentPage.transactions);
    }

    /* ════════════════════════════════════════════
       DROPDOWN POPULATION
    ════════════════════════════════════════════ */
    function populateDropdownFilters() {
        const paymentMethods = new Set();
        const programmes     = new Set();
        const schools        = new Set();

        originalData.transactions.forEach(t => {
            const pm = t.PaymentMethod || t.paymentMethod;
            if (pm?.trim()) paymentMethods.add(pm.trim());
            const pr = t.Programme || t.Program || t.programme;
            if (pr?.trim()) programmes.add(pr.trim());
        });
        originalData.outstanding.forEach(s => {
            const pr = s.Programme || s.Program || s.programme;
            if (pr?.trim()) programmes.add(pr.trim());
            const sc = s.School || s.school || s.Faculty;
            if (sc?.trim()) schools.add(sc.trim());
        });

        const fill = (id, set) => {
            const sel = document.getElementById(id);
            while (sel.children.length > 1) sel.removeChild(sel.lastChild);
            [...set].sort().forEach(v => {
                const o = document.createElement('option');
                o.value = o.textContent = v;
                sel.appendChild(o);
            });
        };
        fill('paymentMethod', paymentMethods);
        fill('programme',     programmes);
        fill('school',        schools);
    }

    /* ════════════════════════════════════════════
       SUMMARY CARDS
    ════════════════════════════════════════════ */
    function updateSummaryCards() {
        const totalRevenue     = filteredData.transactions.reduce((s,t) => s + (t.Amount || 0), 0);
        const totalOutstanding = filteredData.outstanding.reduce((s,t) => s + (t.OutstandingAmount || 0), 0);
        const studentsCount    = filteredData.outstanding.length;
        const avgOutstanding   = studentsCount > 0 ? totalOutstanding / studentsCount : 0;
        const totalExpected    = totalRevenue + totalOutstanding;
        const collectionRate   = totalExpected > 0 ? (totalRevenue / totalExpected * 100) : 0;
        const fmt = v => 'K' + v.toLocaleString(undefined, { minimumFractionDigits:2, maximumFractionDigits:2 });

        document.getElementById('totalRevenue').textContent = fmt(totalRevenue);
        const optionals = {
            totalOutstanding:         fmt(totalOutstanding),
            studentsWithOutstanding:  studentsCount.toLocaleString(),
            averageOutstanding:       fmt(avgOutstanding),
            collectionRate:           collectionRate.toFixed(1) + '%',
            outstandingTotalAmount:   fmt(totalOutstanding),
        };
        Object.entries(optionals).forEach(([id, val]) => {
            const el = document.getElementById(id);
            if (el) el.textContent = val;
        });
    }

    /* ════════════════════════════════════════════
       LOAD DATA
    ════════════════════════════════════════════ */
    function loadTransactionsData() {
        try {
            originalData.transactions = JSON.parse(document.getElementById('transactionsData').textContent || '[]');
            populateDropdownFilters();
            applyTransactionFilters();
            displayTransactionsPage(1);
            updateSummaryCards();
        } catch (e) {
            console.error('Error loading transactions:', e);
            document.getElementById('transactionsTable').innerHTML =
                '<tr class="empty-row"><td colspan="6"><i class="material-icons">error_outline</i>Error loading transaction data</td></tr>';
        }
    }

    function loadOutstandingData() {
        try {
            originalData.outstanding = JSON.parse(document.getElementById('outstandingData').textContent || '[]');
            applyOutstandingFilters();
            displayOutstandingPage(1);
        } catch (e) {
            console.error('Error loading outstanding:', e);
            document.getElementById('outstandingTable').innerHTML =
                '<tr class="empty-row"><td colspan="7"><i class="material-icons">error_outline</i>Error loading outstanding payments data</td></tr>';
        }
    }

    /* ════════════════════════════════════════════
       FILTERS
    ════════════════════════════════════════════ */
    function applyTransactionFilters() {
        const fromDate       = document.getElementById('fromDate').value;
        const toDate         = document.getElementById('toDate').value;
        const studentNumber  = document.getElementById('studentNumber').value.trim().toLowerCase();
        const transactionRef = document.getElementById('transactionRef').value.trim().toLowerCase();
        const paymentMethod  = document.getElementById('paymentMethod').value.trim();
        const programme      = document.getElementById('programme').value.trim();

        filteredData.transactions = originalData.transactions.filter(t => {
            if (fromDate || toDate) {
                const d = new Date(t.PaymentDate);
                if (fromDate && d < new Date(fromDate + 'T00:00:00')) return false;
                if (toDate   && d > new Date(toDate   + 'T23:59:59')) return false;
            }
            if (studentNumber  && !String(t.StudentId     || '').toLowerCase().includes(studentNumber))  return false;
            if (transactionRef && !String(t.TransactionRef || '').toLowerCase().includes(transactionRef)) return false;
            if (paymentMethod  && String(t.PaymentMethod  || '').trim() !== paymentMethod)  return false;
            if (programme      && String(t.Programme      || '').trim() !== programme)      return false;
            return true;
        });
        currentPage.transactions = 1;
    }

    function applyOutstandingFilters() {
        const studentNumber = document.getElementById('studentNumber').value.trim().toLowerCase();
        const programme     = document.getElementById('programme').value.trim();
        const school        = document.getElementById('school').value.trim();

        filteredData.outstanding = originalData.outstanding.filter(s => {
            if (studentNumber && !String(s.StudentId || '').toLowerCase().includes(studentNumber)) return false;
            if (programme     && String(s.Programme  || '').trim() !== programme) return false;
            if (school        && String(s.School     || '').trim() !== school)    return false;
            return true;
        });
        currentPage.outstanding = 1;
    }

    function applyFilters() {
        applyTransactionFilters();
        applyOutstandingFilters();
        collapsedGroups.clear();
        displayTransactionsPage(1);
        displayOutstandingPage(1);
        updateSummaryCards();
        updateActiveFiltersBadge();
    }

    function clearAllFilters() {
        ['fromDate','toDate','studentNumber','transactionRef','paymentMethod','programme','school']
            .forEach(id => document.getElementById(id).value = '');
        applyFilters();
    }

    /* ════════════════════════════════════════════
       HELPERS
    ════════════════════════════════════════════ */
    const fmtAmt  = v => 'K' + (v||0).toLocaleString(undefined, { minimumFractionDigits:2 });
    const fmtDate = d => d ? new Date(d).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) : 'N/A';
    const fmtTime = d => d ? new Date(d).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) : '';

    // Pick a Material Icon that fits the payment method name
    function methodIcon(method) {
        const m = (method || '').toLowerCase();
        if (m.includes('cash'))                                               return 'payments';
        if (m.includes('card') || m.includes('visa') || m.includes('master')) return 'credit_card';
        if (m.includes('bank') || m.includes('transfer') || m.includes('eft'))return 'account_balance';
        if (m.includes('mobile') || m.includes('momo') || m.includes('airtel') || m.includes('mtn') || m.includes('zamtel')) return 'smartphone';
        if (m.includes('cheque') || m.includes('check'))                      return 'description';
        return 'paid';
    }

    // Single data row template (shared by both flat and grouped)
    function txRow(t) {
        return `<tr>
            <td><div class="student-name">${t.StudentName||'Unknown'}</div><div class="student-id">${t.StudentId||'N/A'}</div></td>
            <td class="programme-cell">${t.Programme||'Unknown'}</td>
            <td><span class="amount-pos">${fmtAmt(t.Amount)}</span></td>
            <td><span class="method-pill">${t.PaymentMethod||'Unknown'}</span></td>
            <td><span class="ref-mono">${t.TransactionRef||'N/A'}</span></td>
            <td><div class="date-main">${fmtDate(t.PaymentDate)}</div><div class="date-time">${fmtTime(t.PaymentDate)}</div></td>
        </tr>`;
    }

    /* ════════════════════════════════════════════
       DISPLAY — FLAT MODE  (paginated)
    ════════════════════════════════════════════ */
    function displayFlatPage(page) {
        const tbody = document.getElementById('transactionsTable');
        const start = (page - 1) * pageSize;
        const slice = filteredData.transactions.slice(start, start + pageSize);

        tbody.innerHTML = slice.length === 0
            ? `<tr class="empty-row"><td colspan="6"><i class="material-icons">search_off</i>No transactions found</td></tr>`
            : slice.map(txRow).join('');

        updateTransactionsPagination();
    }

    /* ════════════════════════════════════════════
       DISPLAY — GROUPED MODE  (all rows, no pagination)
    ════════════════════════════════════════════ */
    function displayGroupedView() {
        const tbody = document.getElementById('transactionsTable');

        if (filteredData.transactions.length === 0) {
            tbody.innerHTML = `<tr class="empty-row"><td colspan="6"><i class="material-icons">search_off</i>No transactions found</td></tr>`;
            document.getElementById('transactionsTotalCount').textContent = '0';
            // Hide pagination
            const pg = document.getElementById('transactionsPagination');
            pg.classList.add('hidden'); pg.innerHTML = '';
            return;
        }

        // Build groups map (sorted alpha by method name)
        const groups = {};
        filteredData.transactions.forEach(t => {
            const key = (t.PaymentMethod || 'Unknown').trim();
            (groups[key] = groups[key] || []).push(t);
        });
        const sortedKeys = Object.keys(groups).sort();

        let html = '';
        sortedKeys.forEach(method => {
            const rows      = groups[method];
            const total     = rows.reduce((s,t) => s + (t.Amount||0), 0);
            const count     = rows.length;
            const gkey      = encodeURIComponent(method);
            const collapsed = collapsedGroups.has(method);

            // ── Group header row ──
            html += `
            <tr class="group-header-row">
                <td colspan="6">
                    <div class="group-header-inner">
                        <div class="group-title">
                            <button class="group-collapse-btn${collapsed?' collapsed':''}"
                                    onclick="toggleGroup('${gkey}')"
                                    title="${collapsed?'Expand':'Collapse'} group">
                                <i class="material-icons">expand_more</i>
                            </button>
                            <div class="group-method-icon">
                                <i class="material-icons">${methodIcon(method)}</i>
                            </div>
                            ${method}
                            <span class="group-pill">
                                <i class="material-icons" style="font-size:12px;">receipt</i>
                                ${count} record${count!==1?'s':''}
                            </span>
                        </div>
                        <span class="group-subtotal-amt">${fmtAmt(total)}</span>
                    </div>
                </td>
            </tr>`;

            if (!collapsed) {
                // ── Data rows ──
                html += rows.map(txRow).join('');

                // ── Subtotal footer row ──
                html += `
                <tr class="group-footer-row" data-group-footer="${gkey}">
                    <td colspan="2" style="text-align:right; color:var(--muted); font-weight:600;">
                        <span style="font-size:.7rem; text-transform:uppercase; letter-spacing:.04em;">${method} subtotal</span>
                    </td>
                    <td><span class="amount-pos" style="font-size:.88rem;">${fmtAmt(total)}</span></td>
                    <td colspan="3" style="color:var(--muted); font-size:.75rem; font-weight:500;">
                        ${count} transaction${count!==1?'s':''} &nbsp;·&nbsp; avg ${fmtAmt(total / count)}
                    </td>
                </tr>`;
            }
        });

        tbody.innerHTML = html;
        document.getElementById('transactionsTotalCount').textContent =
            filteredData.transactions.length.toLocaleString();

        // No pagination in grouped mode
        const pg = document.getElementById('transactionsPagination');
        pg.classList.add('hidden'); pg.innerHTML = '';
    }

    function toggleGroup(encodedMethod) {
        const method = decodeURIComponent(encodedMethod);
        if (collapsedGroups.has(method)) collapsedGroups.delete(method);
        else collapsedGroups.add(method);
        displayGroupedView();
    }

    /* ════════════════════════════════════════════
       DISPLAY ROUTER
    ════════════════════════════════════════════ */
    function displayTransactionsPage(page) {
        currentPage.transactions = page;
        if (viewMode === 'grouped') displayGroupedView();
        else displayFlatPage(page);
    }

    /* ════════════════════════════════════════════
       DISPLAY — OUTSTANDING
    ════════════════════════════════════════════ */
    function displayOutstandingPage(page) {
        const tbody = document.getElementById('outstandingTable');
        const start = (page - 1) * pageSize;
        const slice = filteredData.outstanding.slice(start, start + pageSize);

        if (slice.length === 0) {
            tbody.innerHTML = `<tr class="empty-row"><td colspan="7"><i class="material-icons">search_off</i>No outstanding payments found</td></tr>`;
            updateOutstandingPagination(); return;
        }

        tbody.innerHTML = slice.map(s => `
            <tr>
                <td class="chk-cell"><input type="checkbox" class="student-checkbox" value="${s.StudentId||''}"></td>
                <td><div class="student-name">${s.StudentName||'Unknown'}</div><div class="student-id">${s.StudentId||'N/A'}</div></td>
                <td class="programme-cell">${s.Programme||'Unknown'}</td>
                <td class="programme-cell">${s.School||'Unknown'}</td>
                <td><span class="amount-neg">${fmtAmt(s.OutstandingAmount)}</span></td>
                <td class="date-main">${s.LastPaymentDate ? fmtDate(s.LastPaymentDate) : 'No payments'}</td>
                <td>
                    <div style="display:flex;gap:.35rem;">
                        <button onclick="sendReminder('${s.StudentId||''}')" class="action-btn-sm email" title="Send Reminder">
                            <i class="material-icons">email</i>
                        </button>
                        <button onclick="viewDetails('${s.StudentId||''}')" class="action-btn-sm view" title="View Details">
                            <i class="material-icons">visibility</i>
                        </button>
                    </div>
                </td>
            </tr>`).join('');

        updateOutstandingPagination();
    }

    /* ════════════════════════════════════════════
       PAGINATION
    ════════════════════════════════════════════ */
    function updateTransactionsPagination() {
        const total = filteredData.transactions.length;
        document.getElementById('transactionsTotalCount').textContent = total.toLocaleString();
        if (viewMode === 'grouped') return;
        renderPagination('transactions', total);
    }

    function updateOutstandingPagination() {
        renderPagination('outstanding', filteredData.outstanding.length);
    }

    function renderPagination(section, totalRecords) {
        const totalPages = Math.ceil(totalRecords / pageSize);
        const current    = currentPage[section];
        const div        = document.getElementById(section + 'Pagination');
        if (!div) return;
        if (totalPages <= 1) { div.classList.add('hidden'); div.innerHTML = ''; return; }
        div.classList.remove('hidden');

        const start = (current - 1) * pageSize + 1;
        const end   = Math.min(current * pageSize, totalRecords);

        let pages = [];
        if (totalPages <= 7) {
            pages = Array.from({length:totalPages}, (_,i) => i+1);
        } else {
            pages = [1];
            if (current > 3) pages.push('…');
            for (let p = Math.max(2,current-1); p <= Math.min(totalPages-1,current+1); p++) pages.push(p);
            if (current < totalPages-2) pages.push('…');
            pages.push(totalPages);
        }

        const pageNums = pages.map(p =>
            p === '…'
                ? `<span style="padding:0 .25rem;color:var(--faint);">…</span>`
                : `<button class="pg-btn ${p===current?'active':''}" onclick="changePage('${section}',${p})">${p}</button>`
        ).join('');

        div.innerHTML = `
            <div class="pg-bar">
                <span class="pg-info">
                    Showing <strong>${start}–${end}</strong> of <strong>${totalRecords.toLocaleString()}</strong>
                    ${section === 'transactions' ? 'payments' : 'students'}
                </span>
                <div class="pg-buttons">
                    <button class="pg-btn" onclick="changePage('${section}',1)" ${current===1?'disabled':''} title="First">
                        <i class="material-icons">first_page</i>
                    </button>
                    <button class="pg-btn" onclick="changePage('${section}',${current-1})" ${current===1?'disabled':''} title="Prev">
                        <i class="material-icons">chevron_left</i>
                    </button>
                    ${pageNums}
                    <button class="pg-btn" onclick="changePage('${section}',${current+1})" ${current===totalPages?'disabled':''} title="Next">
                        <i class="material-icons">chevron_right</i>
                    </button>
                    <button class="pg-btn" onclick="changePage('${section}',${totalPages})" ${current===totalPages?'disabled':''} title="Last">
                        <i class="material-icons">last_page</i>
                    </button>
                </div>
            </div>`;
    }

    function changePage(section, page) {
        if (page < 1) return;
        const max = Math.ceil(filteredData[section].length / pageSize);
        if (page > max) return;
        currentPage[section] = page;
        if (section === 'transactions') displayTransactionsPage(page);
        else displayOutstandingPage(page);
    }

    /* ════════════════════════════════════════════
       SELECT ALL
    ════════════════════════════════════════════ */
    function toggleSelectAllOutstanding() {
        const checked = document.getElementById('selectAllOutstanding').checked;
        document.querySelectorAll('.student-checkbox').forEach(cb => cb.checked = checked);
    }

    /* ════════════════════════════════════════════
       EXCEL EXPORT
    ════════════════════════════════════════════ */
    function exportTransactionsToExcel() {
        try {
            showLoading(true);
            const data = filteredData.transactions.map(t => ({
                'Student Name':          t.StudentName    || 'Unknown',
                'Student ID':            t.StudentId      || 'N/A',
                'Programme':             t.Programme      || 'Unknown',
                'Amount (K)':            t.Amount         || 0,
                'Payment Method':        t.PaymentMethod  || 'Unknown',
                'Transaction Reference': t.TransactionRef || 'N/A',
                'Payment Date': t.PaymentDate ? fmtDate(t.PaymentDate) : 'N/A',
                'Payment Time': t.PaymentDate ? fmtTime(t.PaymentDate) : 'N/A',
            }));
            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.json_to_sheet(data);
            ws['!cols'] = [{wch:25},{wch:15},{wch:30},{wch:12},{wch:15},{wch:22},{wch:12},{wch:12}];
            XLSX.utils.book_append_sheet(wb, ws, 'Student Payments');
            XLSX.writeFile(wb, `Student_Payments_${new Date().toISOString().slice(0,10)}.xlsx`);
            showNotification('Excel file exported successfully!', 'success');
        } catch (e) {
            console.error(e);
            showNotification('Error exporting to Excel.', 'error');
        } finally { showLoading(false); }
    }

    function exportOutstandingToExcel() {
        try {
            showLoading(true);
            const data = filteredData.outstanding.map(s => ({
                'Student Name':           s.StudentName       || 'Unknown',
                'Student ID':             s.StudentId         || 'N/A',
                'Programme':              s.Programme         || 'Unknown',
                'School':                 s.School            || 'Unknown',
                'Outstanding Amount (K)': s.OutstandingAmount || 0,
                'Last Payment Date':      s.LastPaymentDate ? fmtDate(s.LastPaymentDate) : 'No payments',
            }));
            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.json_to_sheet(data);
            ws['!cols'] = [{wch:25},{wch:15},{wch:30},{wch:20},{wch:18},{wch:15}];
            XLSX.utils.book_append_sheet(wb, ws, 'Outstanding Payments');
            XLSX.writeFile(wb, `Outstanding_Payments_${new Date().toISOString().slice(0,10)}.xlsx`);
            showNotification('Excel file exported successfully!', 'success');
        } catch (e) {
            console.error(e);
            showNotification('Error exporting to Excel.', 'error');
        } finally { showLoading(false); }
    }

    /* ════════════════════════════════════════════
       PLACEHOLDERS
    ════════════════════════════════════════════ */
    function sendReminder(studentId) { window.showAppToast('Send reminder functionality not implemented yet.'); }
    function viewDetails(studentId)  { window.showAppToast('View details functionality not implemented yet.'); }

    /* ════════════════════════════════════════════
       UTILITIES
    ════════════════════════════════════════════ */
    function showLoading(show) {
        document.getElementById('loadingOverlay').classList.toggle('hidden', !show);
    }

    function showNotification(message, type = 'info') {
        const toast   = document.getElementById('toastEl');
        const iconMap = { success:'check_circle', error:'error', info:'info' };
        toast.className = `toast ${type}`;
        document.getElementById('toastIcon').textContent = iconMap[type] || 'info';
        document.getElementById('toastMsg').textContent  = message;
        requestAnimationFrame(() => requestAnimationFrame(() => toast.classList.add('show')));
        setTimeout(() => toast.classList.remove('show'), 3300);
    }

    /* Legacy aliases */
    function loadTransactions(p) { changePage('transactions', p); }
    function loadOutstanding(p)  { changePage('outstanding', p);  }
</script>
