@model SIS.Models.StudentApplication.ApplicationsListViewModel

<div class="min-h-[88vh] bg-slate-50 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-slate-800">My Applications</h1>
                    <p class="text-slate-600 mt-1">View and manage all your application submissions</p>
                </div>
                <a href="@Url.Action("PersonalDetails", "StudentApplication")" class="flex items-center gap-2 px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                    <i class="material-icons">add</i>
                    <span>New Application</span>
                </a>
            </div>
        </div>

        <!-- Filters and Search -->
        <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
            <form method="get" class="space-y-4 lg:space-y-0 lg:flex lg:items-end lg:space-x-4">
                <div class="flex-1">
                    <label for="search" class="block text-sm font-medium text-slate-700 mb-2">Search</label>
                    <div class="relative">
                        <input type="text" id="search" name="search" value="@Model.SearchTerm" placeholder="Search by reference number, program, or school..." class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                            <i class="material-icons text-slate-400">search</i>
                        </div>
                    </div>
                </div>
                
                <!-- Replace the problematic sections with this fixed code -->

                <div class="lg:w-48">
                    <label for="status" class="block text-sm font-medium text-slate-700 mb-2">Status</label>
                    <select id="status" name="status" class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500">
                        < option value="">All Status</ option>
                        @foreach (var option in Model.StatusOptions)
                        {
                            < option value="@option.Value" @(option.Value == Model.SelectedStatus ? "selected" : "")>@option.Text</ option>
                        }
                    </select>
                </div>

                <div class="lg:w-48">
                    <label for="school" class="block text-sm font-medium text-slate-700 mb-2">School</label>
                    <select id="school" name="school" class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500">
                        < option value="">All Schools</ option>
                        @foreach (var option in Model.SchoolOptions)
                        {
                            < option value="@option.Value" @(option.Value == Model.SelectedSchool ? "selected" : "")>@option.Text</ option>
                        }
                    </select>
                </div>
                
                <div class="lg:w-auto">
                    <button type="submit" class="w-full lg:w-auto px-6 py-3 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center justify-center gap-2">
                        <i class="material-icons">filter_list</i>
                        <span>Filter</span>
                    </button>
                </div>
            </form>
        </div>

        <!-- Applications Grid -->
        @if (Model.Applications.Any())
        {
            <div class="space-y-4">
                @foreach (var application in Model.Applications)
                {
                    <div class="bg-white rounded-xl shadow-sm p-6 border border-slate-200 hover:shadow-md transition-shadow">
                        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                            <div class="flex-1">
                                <div class="flex items-center gap-4 mb-3">
                                    <h3 class="text-lg font-semibold text-slate-800">@application.ReferenceNumber</h3>
                                    <span class="px-3 py-1 rounded-full text-sm font-medium
                                        @(application.Status == SIS.Enums.Status.Pending ? "bg-amber-100 text-amber-800" :
                                          application.Status == SIS.Enums.Status.Admitted ? "bg-green-100 text-green-800" :
                                          application.Status == SIS.Enums.Status.Rejected ? "bg-red-100 text-red-800" : "bg-gray-100 text-secondary-800")">
                                        @application.Status.ToString()
                                    </span>
                                </div>
                                
                                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-3 text-sm">
                                    <div>
                                        <p class="text-slate-500">Program</p>
                                        <p class="font-medium text-slate-800">@application.Programme.Name</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500">School</p>
                                        <p class="font-medium text-slate-800">@application.School.Name</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500">Mode of Study</p>
                                        <p class="font-medium text-slate-800">@application.ModeOfStudy.ModeName</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500">Submitted</p>
                                        <p class="font-medium text-slate-800">@application.DateSubmitted.ToString("MMM dd, yyyy")</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex items-center gap-3">
                                @if (application.PaymentStatus == SIS.Enums.Status.Pending)
                                {
                                    <a href="@Url.Action("PaymentSelection", "Payments", new { referenceNumber = application.ReferenceNumber })" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors flex items-center gap-2">
                                        <i class="material-icons text-sm">payment</i>
                                        <span>Pay</span>
                                    </a>
                                }
                                else if (application.PaymentStatus == SIS.Enums.Status.Paid)
                                {
                                    <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-sm font-medium">Paid</span>
                                }
                                
                                <a href="@Url.Action("Details", "StudentApplication", new { id = application.ApplicantId })" class="px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition-colors flex items-center gap-2">
                                    <i class="material-icons text-sm">visibility</i>
                                    <span>View</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            
            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="mt-8 flex justify-center">
                    <nav class="flex items-center space-x-2">
                        @if (Model.HasPreviousPage)
                        {
                            <a href="@Url.Action("ViewAll", new { search = Model.SearchTerm, status = Model.SelectedStatus, school = Model.SelectedSchool, page = Model.CurrentPage - 1 })" class="px-3 py-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-md transition-colors">
                                <i class="material-icons">chevron_left</i>
                            </a>
                        }
                        
                        @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                        {
                            <a href="@Url.Action("ViewAll", new { search = Model.SearchTerm, status = Model.SelectedStatus, school = Model.SelectedSchool, page = i })" class="px-3 py-2 @(i == Model.CurrentPage ? "bg-cyan-600 text-white" : "text-slate-500 hover:text-slate-700 hover:bg-slate-100") rounded-md transition-colors">
                                @i
                            </a>
                        }
                        
                        @if (Model.HasNextPage)
                        {
                            <a href="@Url.Action("ViewAll", new { search = Model.SearchTerm, status = Model.SelectedStatus, school = Model.SelectedSchool, page = Model.CurrentPage + 1 })" class="px-3 py-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-md transition-colors">
                                <i class="material-icons">chevron_right</i>
                            </a>
                        }
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="bg-white rounded-xl shadow-sm p-12 text-center">
                <i class="material-icons text-slate-400 text-6xl mb-4">folder_open</i>
                <h3 class="text-lg font-semibold text-slate-800 mb-2">No Applications Found</h3>
                <p class="text-slate-600 mb-6">
                    @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.SelectedStatus) || !string.IsNullOrEmpty(Model.SelectedSchool))
                    {
                        <span>No applications match your current filters. Try adjusting your search criteria.</span>
                    }
                    else
                    {
                        <span>You haven't submitted any applications yet. Start your journey by creating your first application.</span>
                    }
                </p>
                <a href="@Url.Action("PersonalDetails", "StudentApplication")" class="inline-flex items-center gap-2 px-6 py-3 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                    <i class="material-icons">add</i>
                    <span>Create New Application</span>
                </a>
            </div>
        }
    </div>
</div>