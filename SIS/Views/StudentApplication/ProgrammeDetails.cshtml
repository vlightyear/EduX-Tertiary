@model SIS.Models.StudentApplication.ProgrammeDetailsViewModel

@{
    ViewData["Title"] = $"{Model.Name} - Programme Details";
}

<div class="min-h-screen bg-slate-50 p-6">
    <!-- Breadcrumb -->
    <nav class="flex mb-6" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a href="@Url.Action("Index")" class="text-slate-500 hover:text-cyan-600">
                    <i class="material-icons mr-1">home</i>
                    Dashboard
                </a>
            </li>
            <li>
                <div class="flex items-center">
                    <i class="material-icons text-slate-400">chevron_right</i>
                    <a href="@Url.Action("ViewPrograms")" class="ml-1 text-slate-500 hover:text-cyan-600">Programs</a>
                </div>
            </li>
            <li>
                <div class="flex items-center">
                    <i class="material-icons text-slate-400">chevron_right</i>
                    <span class="ml-1 text-slate-700 font-medium">@Model.Name</span>
                </div>
            </li>
        </ol>
    </nav>

    <!-- Program Header -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 mb-8 overflow-hidden">
        <div class="bg-gradient-to-r from-cyan-600 to-blue-600 p-8 text-white">
            <div class="flex flex-col lg:flex-row justify-between items-start">
                <div class="flex-1">
                    <h1 class="text-4xl font-bold mb-4">@Model.Name</h1>
                    <p class="text-cyan-100 text-lg leading-relaxed">@Model.Description</p>
                    <div class="mt-6 flex flex-wrap gap-3">
                        <span class="px-3 py-1 bg-white/20 rounded-full text-sm font-medium">
                            @Model.SchoolName
                        </span>
                        <span class="px-3 py-1 bg-white/20 rounded-full text-sm font-medium">
                            @Model.DepartmentName
                        </span>
                        <span class="px-3 py-1 bg-white/20 rounded-full text-sm font-medium">
                            @Model.ProgrammeLevelName
                        </span>
                    </div>
                </div>
                <div class="mt-6 lg:mt-0 lg:ml-8">
                    <div class="text-right">
                        <div class="text-3xl font-bold">@Model.DurationYears</div>
                        <div class="text-cyan-100">Years</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Program Information Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
        <!-- Key Information -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Program Details Card -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center">
                    <i class="material-icons mr-3 text-cyan-600">info</i>
                    Program Information
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-4">
                        <div class="flex items-center">
                            <i class="material-icons text-slate-400 mr-3">schedule</i>
                            <div>
                                <div class="text-sm text-slate-600">Duration</div>
                                <div class="font-semibold text-slate-800">@Model.DurationYears years</div>
                            </div>
                        </div>

                        <div class="flex items-center">
                            <i class="material-icons text-slate-400 mr-3">laptop</i>
                            <div>
                                <div class="text-sm text-slate-600">Mode of Study</div>
                                <div class="font-semibold text-slate-800">@Model.ModeOfStudyName</div>
                            </div>
                        </div>

                        <div class="flex items-center">
                            <i class="material-icons text-slate-400 mr-3">grade</i>
                            <div>
                                <div class="text-sm text-slate-600">Minimum Points (Top 5)</div>
                                <div class="font-semibold text-slate-800">@Model.MinimumPointsTop5Subjects points</div>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="flex items-center">
                            <i class="material-icons text-slate-400 mr-3">person</i>
                            <div>
                                <div class="text-sm text-slate-600">Program Coordinator</div>
                                <div class="font-semibold text-slate-800">@Model.CoordinatorName</div>
                            </div>
                        </div>

                        <div class="flex items-center">
                            <i class="material-icons text-slate-400 mr-3">people</i>
                            <div>
                                <div class="text-sm text-slate-600">Current Enrollment</div>
                                <div class="font-semibold text-slate-800">@Model.EnrollmentCount students</div>
                            </div>
                        </div>

                        <div class="flex items-center">
                            <i class="material-icons text-slate-400 mr-3">attach_money</i>
                            <div>
                                <div class="text-sm text-slate-600">Total Fees Per Year</div>
                                <div class="font-semibold text-slate-800">ZMW @Model.TotalFeesPerYear.ToString("N2")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Yearly Requirements -->
            @if (!string.IsNullOrEmpty(Model.YearlyRequirements))
            {
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                    <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center">
                        <i class="material-icons mr-3 text-cyan-600">checklist</i>
                        Yearly Requirements
                    </h2>
                    <div id="yearly-requirements-content">
                        <!-- This will be populated by JavaScript -->
                    </div>
                </div>

                <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        try {
                            const requirementsData = @Html.Raw(Model.YearlyRequirements);
                            const container = document.getElementById('yearly-requirements-content');

                            if (typeof requirementsData === 'object' && requirementsData !== null) {
                                let html = '<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">';

                                Object.keys(requirementsData).forEach(year => {
                                    const yearData = requirementsData[year];
                                    const yearNumber = year.replace('Year', '');

                                    html += `
                                        <div class="bg-gradient-to-br from-cyan-50 to-blue-50 border border-cyan-200 rounded-lg p-4">
                                            <div class="flex items-center justify-between mb-3">
                                                <h3 class="text-lg font-semibold text-cyan-700">Year ${yearNumber}</h3>
                                                <i class="material-icons text-cyan-600">assignment</i>
                                            </div>
                                            <div class="space-y-2">
                                    `;

                                    if (yearData.TotalRequired) {
                                        html += `
                                            <div class="flex items-center justify-between">
                                                <span class="text-sm text-slate-600">Total Required:</span>
                                                <span class="font-semibold text-slate-800">${yearData.TotalRequired}</span>
                                            </div>
                                        `;
                                    }

                                    // Add other properties if they exist
                                    Object.keys(yearData).forEach(key => {
                                        if (key !== 'TotalRequired') {
                                            html += `
                                                <div class="flex items-center justify-between">
                                                    <span class="text-sm text-slate-600">${key.replace(/([A-Z])/g, ' $1').trim()}:</span>
                                                    <span class="font-semibold text-slate-800">${yearData[key]}</span>
                                                </div>
                                            `;
                                        }
                                    });

                                    html += `
                                            </div>
                                        </div>
                                    `;
                                });

                                html += '</div>';
                                container.innerHTML = html;
                            } else {
                                // Fallback to plain text if it's not JSON
                                container.innerHTML = `<div class="prose max-w-none text-slate-600">${requirementsData.replace(/\n/g, '<br>')}</div>`;
                            }
                        } catch (e) {
                            // Fallback for invalid JSON
                            const container = document.getElementById('yearly-requirements-content');
                            container.innerHTML = `<div class="prose max-w-none text-slate-600">@Html.Raw(Model.YearlyRequirements.Replace("\n", "<br>"))</div>`;
                        }
                    });
                </script>
            }
        </div>

        <!-- Fee Breakdown Card -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 h-fit">
            <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center">
                <i class="material-icons mr-3 text-green-600">payment</i>
                Fee Breakdown
            </h2>

            <div class="space-y-4">
                @foreach (var fee in Model.FeeBreakdown)
                {
                    <div class="flex justify-between items-center p-3 bg-slate-50 rounded-lg">
                        <div>
                            <div class="font-medium text-slate-800">@fee.FeeName</div>
                            <div class="text-sm text-slate-600">@fee.Description</div>
                        </div>
                        <div class="text-lg font-bold text-slate-800">
                            ZMW @fee.Amount.ToString("N2")
                        </div>
                    </div>
                }
            </div>

            <div class="mt-6 pt-4 border-t border-slate-200">
                <div class="flex justify-between items-center">
                    <span class="text-lg font-bold text-slate-800">Total Per Year</span>
                    <span class="text-2xl font-bold text-green-600">ZMW @Model.TotalFeesPerYear.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Courses by Year -->
    <div class="space-y-8">
        <h2 class="text-2xl font-bold text-slate-800 flex items-center">
            <i class="material-icons mr-3 text-cyan-600">school</i>
            Course Structure
        </h2>

        @foreach (var year in Model.CoursesByYear)
        {
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <!-- Year Header -->
                <div class="bg-gradient-to-r from-slate-50 to-slate-100 p-6 border-b border-slate-200">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
                        <div>
                            <h3 class="text-2xl font-bold text-slate-800">@year.YearDisplayName</h3>
                            <div class="mt-2 flex flex-wrap gap-4 text-sm text-slate-600">
                                <span class="flex items-center">
                                    <i class="material-icons text-sm mr-1">book</i>
                                    @year.TotalCourses total courses
                                </span>
                                <span class="flex items-center">
                                    <i class="material-icons text-sm mr-1 text-red-500">priority_high</i>
                                    @year.MandatoryCourses mandatory
                                </span>
                                <span class="flex items-center">
                                    <i class="material-icons text-sm mr-1 text-green-500">check_circle</i>
                                    @year.ElectiveCourses elective
                                </span>
                            </div>
                        </div>
                        <a href="@Url.Action("GenerateProgrammeInvoice", new { programmeId = Model.Id, yearOfStudy = year.YearOfStudy })"
                           class="mt-4 sm:mt-0 inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                            <i class="material-icons mr-2">description</i>
                            Generate Fee Invoice
                        </a>
                    </div>
                </div>

                <!-- Semesters -->
                <div class="p-6">
                    @foreach (var semester in year.Semesters)
                    {
                        <div class="mb-8 last:mb-0">
                            <h4 class="text-lg font-semibold text-slate-800 flex items-center mb-4">
                                <i class="material-icons mr-2 text-slate-600">calendar_today</i>
                                @semester.SemesterDisplayName
                                <span class="ml-2 text-sm font-normal text-slate-500">(@semester.Courses.Count courses)</span>
                            </h4>

                            <!-- Responsive Course Grid -->
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                                @foreach (var course in semester.Courses)
                                {
                                    <div class="border border-slate-200 rounded-lg p-4 hover:border-cyan-200 transition-all duration-200 hover:shadow-md bg-white">
                                        <div class="flex justify-between items-start mb-3">
                                            <div class="flex-1">
                                                <h5 class="font-semibold text-slate-800 text-lg">
                                                    @course.CourseCode
                                                </h5>
                                                <h6 class="font-medium text-slate-700 mt-1">
                                                    @course.CourseName
                                                </h6>
                                                <p class="text-sm text-slate-600 mt-2 line-clamp-2">@course.CourseDescription</p>
                                            </div>
                                            <div class="ml-4 flex gap-2">
                                                @if (course.IsMandatory)
                                                {
                                                    <span class="px-2 py-1 bg-red-100 text-red-800 text-xs rounded-full font-medium">
                                                        Mandatory
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs rounded-full font-medium">
                                                        Elective
                                                    </span>
                                                }
                                            </div>
                                        </div>

                                        <div class="grid grid-cols-2 gap-4 text-sm">
                                            <div class="space-y-2">
                                                <div class="flex items-center text-slate-600">
                                                    <i class="material-icons text-sm mr-2">person</i>
                                                    <span>@course.InstructorName</span>
                                                </div>
                                                <div class="flex items-center text-slate-600">
                                                    <i class="material-icons text-sm mr-2">schedule</i>
                                                    <span>@course.MeetingFrequencyPerWeek/week</span>
                                                </div>
                                            </div>
                                            <div class="space-y-2">
                                                <div class="flex items-center text-slate-600">
                                                    <i class="material-icons text-sm mr-2">grade</i>
                                                    <span>Pass: @course.PassMark%</span>
                                                </div>
                                                <div class="flex items-center text-slate-600">
                                                    <i class="material-icons text-sm mr-2">category</i>
                                                    <span>@course.CourseType</span>
                                                </div>
                                            </div>
                                        </div>

                                        @if (course.PrerequisiteCourses.Any())
                                        {
                                            <div class="mt-3 pt-3 border-t border-slate-100">
                                                <div class="text-xs text-slate-500 mb-2 flex items-center">
                                                    <i class="material-icons text-xs mr-1">link</i>
                                                    Prerequisites:
                                                </div>
                                                <div class="flex flex-wrap gap-1">
                                                    @foreach (var prereq in course.PrerequisiteCourses)
                                                    {
                                                        <span class="px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded font-medium">
                                                            @prereq
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Action Buttons -->
    <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="@Url.Action("ViewPrograms")"
           class="inline-flex items-center justify-center px-6 py-3 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition-colors">
            <i class="material-icons mr-2">arrow_back</i>
            Back to Programs
        </a>
        <a href="@Url.Action("PersonalDetails", new { programmeId = Model.Id })"
           class="inline-flex items-center justify-center px-6 py-3 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
            <i class="material-icons mr-2">assignment</i>
            Apply for this Program
        </a>
    </div>
</div>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>