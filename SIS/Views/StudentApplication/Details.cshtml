@model SIS.Models.StudentApplication.ApplicationDetailsViewModel

<div class="min-h-[88vh] bg-slate-50 py-8">
    <div class="mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-slate-800">Application Details</h1>
                    <p class="text-slate-600 mt-1">@Model.Application.ReferenceNumber</p>
                </div>
                <div class="flex items-center gap-3">
                    @if (Model.CanMakePayment)
                    {
                        <a href="@Url.Action("PaymentSelection", "Payments", new { referenceNumber = Model.Application.ReferenceNumber })" class="flex items-center gap-2 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                            <i class="material-icons">payment</i>
                            <span>Make Payment</span>
                        </a>
                    }
                    <a href="@Url.Action("ViewAll", "StudentApplication")" class="flex items-center gap-2 px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition-colors">
                        <i class="material-icons">arrow_back</i>
                        <span>Back to List</span>
                    </a>
                </div>
            </div>

            <!-- Status Cards -->
            <div class="grid md:grid-cols-3 gap-4 mt-6">
                <div class="bg-white rounded-lg p-4 shadow-sm">
                    <p class="text-slate-500 text-sm">Application Status</p>
                    <div class="flex items-center gap-2 mt-1">
                        <span class="px-3 py-1 rounded-full text-sm font-medium @Model.StatusBadgeClass">
                            @Model.Application.Status.ToString()
                        </span>
                    </div>
                </div>
                <div class="bg-white rounded-lg p-4 shadow-sm">
                    <p class="text-slate-500 text-sm">Payment Status</p>
                    <div class="flex items-center gap-2 mt-1">
                        <span class="px-3 py-1 rounded-full text-sm font-medium @Model.PaymentStatusBadgeClass">
                            @Model.Application.PaymentStatus.ToString()
                        </span>
                    </div>
                </div>
                <div class="bg-white rounded-lg p-4 shadow-sm">
                    <p class="text-slate-500 text-sm">Submitted</p>
                    <p class="font-semibold text-slate-800 mt-1">@Model.Application.DateSubmitted.ToString("MMM dd, yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="space-y-6">
            <!-- Personal Information -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i class="material-icons text-cyan-600">person</i>
                    Personal Information
                </h2>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Full Name</label>
                        <p class="mt-1 text-slate-900">@Model.Application.FullName</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Email</label>
                        <p class="mt-1 text-slate-900">@Model.Application.Email</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Phone</label>
                        <p class="mt-1 text-slate-900">@Model.Application.Phone</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Date of Birth</label>
                        <p class="mt-1 text-slate-900">@Model.Application.DateOfBirth.ToString("MMM dd, yyyy")</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Gender</label>
                        <p class="mt-1 text-slate-900">@Model.Application.Gender</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Marital Status</label>
                        <p class="mt-1 text-slate-900">@Model.Application.MaritalStatus</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Nationality</label>
                        <p class="mt-1 text-slate-900">@Model.Application.Nationality</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Religion</label>
                        <p class="mt-1 text-slate-900">@Model.Application.Religion</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">NRC/Passport</label>
                        <p class="mt-1 text-slate-900">@Model.Application.NrcOrPassport</p>
                    </div>
                </div>
            </div>

            <!-- Address Information -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i class="material-icons text-cyan-600">location_on</i>
                    Address Information
                </h2>
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Address Line 1</label>
                        <p class="mt-1 text-slate-900">@Model.Application.AddressLine1</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Address Line 2</label>
                        <p class="mt-1 text-slate-900">@(Model.Application.AddressLine2 ?? "N/A")</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">City</label>
                        <p class="mt-1 text-slate-900">@Model.Application.City</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">State/Province</label>
                        <p class="mt-1 text-slate-900">@Model.Application.State</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Postal Code</label>
                        <p class="mt-1 text-slate-900">@Model.Application.PostalCode</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Country</label>
                        <p class="mt-1 text-slate-900">@Model.Application.Country</p>
                    </div>
                </div>
            </div>

            <!-- Next of Kin Information -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i class="material-icons text-cyan-600">family_restroom</i>
                    Next of Kin Information
                </h2>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Name</label>
                        <p class="mt-1 text-slate-900">@Model.Application.NextOfKinName</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Relationship</label>
                        <p class="mt-1 text-slate-900">@Model.Application.NextOfKinRelation</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Phone</label>
                        <p class="mt-1 text-slate-900">@Model.Application.NextOfKinPhone</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Email</label>
                        <p class="mt-1 text-slate-900">@Model.Application.NextOfKinEmail</p>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-slate-700">Address</label>
                        <p class="mt-1 text-slate-900">@Model.Application.NextOfKinAddress</p>
                    </div>
                </div>
            </div>

            <!-- Program Selection -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i class="material-icons text-cyan-600">school</i>
                    Program Selection
                </h2>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700">School</label>
                        <p class="mt-1 text-slate-900">@Model.Application.School.Name</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Programme</label>
                        <p class="mt-1 text-slate-900">@Model.Application.Programme.Name</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Programme Level</label>
                        <p class="mt-1 text-slate-900">@Model.Application.ProgrammeLevel.Name</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Mode of Study</label>
                        <p class="mt-1 text-slate-900">@Model.Application.ModeOfStudy.ModeName</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Academic Year</label>
                        <p class="mt-1 text-slate-900">@Model.Application.AcademicYear.YearValue</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Foreign Student</label>
                        <p class="mt-1 text-slate-900">@(Model.Application.IsForeigner ? "Yes" : "No")</p>
                    </div>
                </div>
            </div>

            <!-- Educational Background -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i class="material-icons text-cyan-600">history_edu</i>
                    Educational Background
                </h2>

                <!-- Previous School Level -->
                <div class="mb-8">
                    <h3 class="text-lg font-medium text-slate-800 mb-4">Previous Education Level</h3>
                    <div class="grid md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Highest Education Level</label>
                            <p class="mt-1 text-slate-900">@Model.Application.FormerSchoolLevel</p>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Application.FormerSchoolName))
                        {
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Institution Name</label>
                                <p class="mt-1 text-slate-900">@Model.Application.FormerSchoolName</p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Institution Address</label>
                                <p class="mt-1 text-slate-900">@Model.Application.FormerSchoolAddress</p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Year of Completion</label>
                                <p class="mt-1 text-slate-900">@Model.Application.YearOfCompletion</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Secondary School -->
                <div class="mb-8">
                    <h3 class="text-lg font-medium text-slate-800 mb-4">Secondary School</h3>
                    <div class="grid md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700">School Name</label>
                            <p class="mt-1 text-slate-900">@Model.Application.SecondarySchoolName</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">School Address</label>
                            <p class="mt-1 text-slate-900">@Model.Application.SecondarySchoolAddress</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Study Period</label>
                            <p class="mt-1 text-slate-900">@Model.Application.SecondarySchoolPeriod</p>
                        </div>
                    </div>
                </div>

                <!-- Primary School -->
                @if (!string.IsNullOrEmpty(Model.Application.PrimarySchoolName))
                {
                    <div class="mb-8">
                        <h3 class="text-lg font-medium text-slate-800 mb-4">Primary School</h3>
                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-slate-700">School Name</label>
                                <p class="mt-1 text-slate-900">@Model.Application.PrimarySchoolName</p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">School Address</label>
                                <p class="mt-1 text-slate-900">@Model.Application.PrimarySchoolAddress</p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Study Period</label>
                                <p class="mt-1 text-slate-900">@Model.Application.PrimarySchoolPeriod</p>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Subject Grades -->
            @if (Model.Application.SubjectGrades != null && Model.Application.SubjectGrades.Any())
            {
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <h2 class="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
                        <i class="material-icons text-cyan-600">grade</i>
                        Subject Grades
                    </h2>
                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                            <thead>
                                <tr class="border-b border-slate-200">
                                    <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Subject</th>
                                    <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var subjectGrade in Model.Application.SubjectGrades)
                                {
                                    <tr class="border-b border-slate-100 hover:bg-slate-50">
                                        <td class="px-4 py-3 text-slate-900">@subjectGrade.Subject.SubjectName</td>
                                        <td class="px-4 py-3 text-slate-900">@subjectGrade.Grade.GradeValue</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Documents -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
                    <i class="material-icons text-cyan-600">folder</i>
                    Uploaded Documents
                </h2>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                    @if (!string.IsNullOrEmpty(Model.Application.NrcOrPassportCopy))
                    {
                        <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
                            <div class="flex items-center gap-3">
                                <i class="material-icons text-blue-600">picture_as_pdf</i>
                                <div class="flex-1">
                                    <p class="font-medium text-slate-900">NRC/Passport Copy</p>
                                    <p class="text-sm text-slate-600">PDF Document</p>
                                </div>
                                <div class="flex gap-2">
                                    <button onclick="previewDocument('@Url.Action("DownloadDocument", "StudentApplication", new { id = Model.Application.ApplicantId, documentType = "nrc" })', 'NRC/Passport Copy')"
                                            class="text-cyan-600 hover:text-cyan-800 transition-colors"
                                            title="Preview">
                                        <i class="material-icons">visibility</i>
                                    </button>
                                    <a href="@Url.Action("DownloadDocument", "StudentApplication", new { id = Model.Application.ApplicantId, documentType = "nrc" })"
                                       class="text-cyan-600 hover:text-cyan-800 transition-colors"
                                       title="Download">
                                        <i class="material-icons">download</i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Application.ResultsAttachmentCopy))
                    {
                        <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
                            <div class="flex items-center gap-3">
                                <i class="material-icons text-green-600">picture_as_pdf</i>
                                <div class="flex-1">
                                    <p class="font-medium text-slate-900">Results/Transcript</p>
                                    <p class="text-sm text-slate-600">PDF Document</p>
                                </div>
                                <div class="flex gap-2">
                                    <button onclick="previewDocument('@Url.Action("DownloadDocument", "StudentApplication", new { id = Model.Application.ApplicantId, documentType = "results" })', 'Results/Transcript')"
                                            class="text-cyan-600 hover:text-cyan-800 transition-colors"
                                            title="Preview">
                                        <i class="material-icons">visibility</i>
                                    </button>
                                    <a href="@Url.Action("DownloadDocument", "StudentApplication", new { id = Model.Application.ApplicantId, documentType = "results" })"
                                       class="text-cyan-600 hover:text-cyan-800 transition-colors"
                                       title="Download">
                                        <i class="material-icons">download</i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Application.StudyPermitCopy))
                    {
                        <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
                            <div class="flex items-center gap-3">
                                <i class="material-icons text-purple-600">picture_as_pdf</i>
                                <div class="flex-1">
                                    <p class="font-medium text-slate-900">Study Permit</p>
                                    <p class="text-sm text-slate-600">PDF Document</p>
                                </div>
                                <div class="flex gap-2">
                                    <button onclick="previewDocument('@Url.Action("DownloadDocument", "StudentApplication", new { id = Model.Application.ApplicantId, documentType = "studypermit" })', 'Study Permit')"
                                            class="text-cyan-600 hover:text-cyan-800 transition-colors"
                                            title="Preview">
                                        <i class="material-icons">visibility</i>
                                    </button>
                                    <a href="@Url.Action("DownloadDocument", "StudentApplication", new { id = Model.Application.ApplicantId, documentType = "studypermit" })"
                                       class="text-cyan-600 hover:text-cyan-800 transition-colors"
                                       title="Download">
                                        <i class="material-icons">download</i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Payment History -->
            @if (Model.PaymentHistory.Any())
            {
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <h2 class="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
                        <i class="material-icons text-cyan-600">payment</i>
                        Payment History
                    </h2>
                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                            <thead>
                                <tr class="border-b border-slate-200">
                                    <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Transaction Reference</th>
                                    <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Amount</th>
                                    <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Payment Method</th>
                                    <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Date</th>
                                    <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payment in Model.PaymentHistory)
                                {
                                    <tr class="border-b border-slate-100 hover:bg-slate-50">
                                        <td class="px-4 py-3 text-slate-900">@payment.TransactionReference</td>
                                        <td class="px-4 py-3 text-slate-900">K@(payment.Amount.ToString("F2"))</td>
                                        <td class="px-4 py-3 text-slate-900">@payment.PaymentMethod</td>
                                        <td class="px-4 py-3 text-slate-900">
                                            @if (payment.PaymentDate != DateTime.MinValue)
                                            {
                                                @payment.PaymentDate.ToString("MMM dd, yyyy HH:mm")
                                            }
                                            else
                                            {
                                                <span class="text-slate-500">Not Paid</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3">
                                            <span class="px-3 py-1 rounded-full text-sm font-medium
                                    @(payment.Status == SIS.Enums.Status.Pending ? "bg-amber-100 text-amber-800" :
                                      payment.Status == SIS.Enums.Status.Paid ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800")">
                                                @payment.Status.ToString()
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>



    <!-- Document Preview Modal -->
    <div id="documentModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden">
        <div class="fixed inset-0 overflow-y-auto">
            <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
                <div class="relative inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-6xl sm:w-full">
                    <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-semibold text-slate-800" id="modalTitle">Document Preview</h3>
                            <button type="button" onclick="closeModal()" class="text-slate-400 hover:text-slate-600 focus:outline-none">
                                <i class="material-icons">close</i>
                            </button>
                        </div>
                        <div class="w-full h-[80vh]">
                            <iframe id="documentFrame" class="w-full h-full border rounded-lg" src="" frameborder="0"></iframe>
                        </div>
                    </div>
                    <div class="bg-slate-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                        <button type="button" onclick="downloadDocument()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-cyan-600 text-base font-medium text-white hover:bg-cyan-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-cyan-500 sm:ml-3 sm:w-auto sm:text-sm">
                            <i class="material-icons mr-2">download</i>
                            Download
                        </button>
                        <button type="button" onclick="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-cyan-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>


</div>


@section Scripts {
    <script>
        let currentDocumentUrl = '';
        
        function previewDocument(url, title) {
            currentDocumentUrl = url;
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('documentFrame').src = url;
            document.getElementById('documentModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
        
        function closeModal() {
            document.getElementById('documentModal').classList.add('hidden');
            document.getElementById('documentFrame').src = '';
            document.body.style.overflow = 'auto';
        }
        
        function downloadDocument() {
            if (currentDocumentUrl) {
                window.open(currentDocumentUrl, '_blank');
            }
        }
        
        // Close modal when clicking outside
        document.getElementById('documentModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });
        
        // Close modal with Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && !document.getElementById('documentModal').classList.contains('hidden')) {
                closeModal();
            }
        });
    </script>
}
