@using SIS.DTOs.StudentApplication
@using SIS.Models.Admin
@model SIS.Models.StudentApplication.PersonalDetailsViewModel

@{
	var programmes = ViewBag.ActiveProgrammes as List<Programme>;
}

<style>
	/* Select2 fixes for the theme */
	.select2-container--default .select2-selection--single {
		height: 42px;
		padding: 7px 12px;
		border-color: rgb(203, 213, 225);
		border-radius: 0.5rem;
	}

		.select2-container--default .select2-selection--single .select2-selection__arrow {
			height: 42px;
		}

		.select2-container--default .select2-selection--single .select2-selection__rendered {
			line-height: normal;
		}

	.select2-container--default .select2-results__option--highlighted[aria-selected] {
		background-color: rgb(8, 145, 178);
	}

	.select2-dropdown {
		border-color: rgb(203, 213, 225);
		border-radius: 0.5rem;
		overflow: hidden;
	}

	/* Style for phone input fields */
	.iti {
		width: 100%;
	}

	.iti__flag {
		box-shadow: 0 0 1px 0 rgba(0,0,0,0.2);
	}

	.iti__selected-flag {
		padding: 0 6px 0 8px;
		border-radius: 0.5rem 0 0 0.5rem;
		background-color: rgba(0, 0, 0, 0.02);
	}

	/* Move the input text to make room for country code */
	.iti input[type=tel] {
		padding-left: 90px !important;
	}
</style>

<div class="bg-slate-50 min-h-screen py-8">
	<!-- Header -->
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
		<div class="text-center space-y-3">
			<h2 class="text-3xl font-bold text-slate-800">Student Application</h2>
			<p class="text-slate-600 text-lg max-w-3xl mx-auto">
				Welcome! Please complete all sections to submit your application. Your information will be reviewed by our admissions team.
			</p>
			<div id="statusMessage" class="text-red-600 font-medium"></div>
		</div>
	</div>

	<!-- Progress Steps -->
	<div class="mx-auto px-4 sm:px-6 lg:px-8 mb-8">
		<div class="bg-white rounded-xl shadow-sm p-4 border border-slate-200">
			<ol class="flex items-center w-full text-sm font-medium text-center text-gray-500 sm:text-base">
				<li class="flex items-center step-item active flex-1 relative" data-step="1">
					<span class="flex items-center justify-center w-10 h-10 mr-2 text-[#0082bb] border-2 border-[#0082bb] rounded-full shrink-0 bg-white transition-all">
						<span>1</span>
					</span>
					<span class="hidden sm:inline-flex">Personal Info</span>
					<div class="flex-1 h-0.5 bg-slate-200 mx-2 relative hidden sm:block"></div>
				</li>
				<li class="flex items-center step-item flex-1 relative" data-step="2">
					<span class="flex items-center justify-center w-10 h-10 mr-2 text-gray-500 border-2 border-gray-300 rounded-full shrink-0 transition-all">
						<span>2</span>
					</span>
					<span class="hidden sm:inline-flex">Contact Details</span>
					<div class="flex-1 h-0.5 bg-slate-200 mx-2 relative hidden sm:block"></div>
				</li>
				<li class="flex items-center step-item flex-1 relative" data-step="3">
					<span class="flex items-center justify-center w-10 h-10 mr-2 text-gray-500 border-2 border-gray-300 rounded-full shrink-0 transition-all">
						<span>3</span>
					</span>
					<span class="hidden sm:inline-flex">Program Choice</span>
					<div class="flex-1 h-0.5 bg-slate-200 mx-2 relative hidden sm:block"></div>
				</li>
				<li class="flex items-center step-item flex-1 relative" data-step="4">
					<span class="flex items-center justify-center w-10 h-10 mr-2 text-gray-500 border-2 border-gray-300 rounded-full shrink-0 transition-all">
						<span>4</span>
					</span>
					<span class="hidden sm:inline-flex">Education History</span>
					<div class="flex-1 h-0.5 bg-slate-200 mx-2 relative hidden sm:block"></div>
				</li>
				<li class="flex items-center step-item flex-1" data-step="5">
					<span class="flex items-center justify-center w-10 h-10 mr-2 text-gray-500 border-2 border-gray-300 rounded-full shrink-0 transition-all">
						<span>5</span>
					</span>
					<span class="hidden sm:inline-flex">Documents</span>
				</li>
			</ol>
		</div>
	</div>

	<!-- Form Container -->
	<div class=" mx-auto px-4 sm:px-6 lg:px-8">
		<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
			<form id="application-form" asp-action="SubmitApplication" method="post" enctype="multipart/form-data" class="space-y-8">
				<div asp-validation-summary="All" class="text-red-600 bg-red-50 p-4 rounded-lg mb-6 border-l-4 border-red-500" style="display: none;"></div>

				<!-- Steps Content will be placed here -->
				<div class="steps-content">
					<!-- The step content will be placed here in the next artifacts -->
					<!-- Step 1: Personal Details -->
					<div class="step-pane active" data-step="1">
						<div class="border-b border-slate-200 pb-4 mb-6">
							<h4 class="text-xl font-semibold text-slate-800">Personal Details</h4>
							<p class="text-slate-500 text-sm mt-1">Please provide your basic personal information</p>
						</div>

						<!-- First Row -->
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
							

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.FullName">
									Full Name*
								</label>
								<input asp-for="Applicant.FullName"
									   value="@Model.Applicant.FullName"
									   type="text"
									   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 bg-slate-50 transition-colors"
									   id="FirstName"
									   readonly />
								<span asp-validation-for="Applicant.FullName" class="text-red-500 text-sm mt-1 block"></span>
							</div>

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.Email">
									Email Address*
								</label>
								<input asp-for="Applicant.Email"
									   type="email"
									   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 bg-slate-50 transition-colors"
									   id="EmailAddress"
									   readonly />
								<span asp-validation-for="Applicant.Email" class="text-red-500 text-sm mt-1 block"></span>
							</div>

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.Phone">
									Phone Number*
								</label>
								<div class="relative">
									<input asp-for="Applicant.Phone"
										   type="tel"
										   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 transition-colors"
										   placeholder="Phone Number"
										   data-name="Phone Number"
										   id="PhoneNumber"
										   required />
									<input type="hidden" id="FullPhoneNumber" name="Applicant.Phone" />
								</div>
								<span asp-validation-for="Applicant.Phone" class="text-red-500 text-sm mt-1 block"></span>
							</div>

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.Gender">
									Gender*
								</label>
								<select asp-for="Applicant.Gender"
										class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 transition-colors"
										data-name="Gender"
										id="Gender"
										required>
									<option value="" disabled selected>Select Gender</option>
									<option>Male</option>
									<option>Female</option>
								</select>
								<span asp-validation-for="Applicant.Gender" class="text-red-500 text-sm mt-1 block"></span>
							</div>
						</div>

						<!-- Second Row -->
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-6">
							

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.DateOfBirth">
									Date of Birth*
								</label>
								<div class="relative">
									<input asp-for="Applicant.DateOfBirth"
										   type="date"
										   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10 transition-colors"
										   data-name="Date of Birth"
										   id="DateOfBirth"
										   required />
									<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
										<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
											<path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
										</svg>
									</div>
								</div>
								<span asp-validation-for="Applicant.DateOfBirth" class="text-red-500 text-sm mt-1 block"></span>
							</div>

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.MaritalStatus">
									Marital Status*
								</label>
								<select asp-for="Applicant.MaritalStatus"
										class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 transition-colors"
										data-name="Marital Status"
										id="MaritalSts"
										required>
									<option value="" disabled selected>Select Marital Status</option>
									<option>Single</option>
									<option>Married</option>
									<option>Divorced</option>
									<option>Widow</option>
									<option>Widower</option>
								</select>
								<span asp-validation-for="Applicant.MaritalStatus" class="text-red-500 text-sm mt-1 block"></span>
							</div>

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.Nationality">
									Nationality*
								</label>
								<div class="relative">
									<select asp-for="Applicant.Nationality"
											class="nationality-select w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 transition-colors"
											data-name="Nationality"
											id="Nationality"
											required>
										<option value="">Select Nationality</option>
										<!-- Options will be populated by JavaScript -->
									</select>
								</div>
								<span asp-validation-for="Applicant.Nationality" class="text-red-500 text-sm mt-1 block"></span>
							</div>

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.IsForeigner">
									Are you a foreign student?*
								</label>
								<select asp-for="Applicant.IsForeigner"
										class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 transition-colors"
										data-name="Foreign Student Status"
										id="Foreigner"
										required>
									<option value="" disabled selected>Select Option</option>
									<option value="true">Yes</option>
									<option value="false">No</option>
								</select>
								<span asp-validation-for="Applicant.IsForeigner" class="text-red-500 text-sm mt-1 block"></span>
							</div>
						</div>

						<!-- Third Row -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.Religion">
									Religion*
								</label>
								<select asp-for="Applicant.Religion"
										class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 transition-colors"
										data-name="Religion"
										id="Religion"
										required>
									<option value="" disabled selected>Select Religion</option>
									<option>Christianity</option>
									<option>Islam</option>
									<option>Hinduism</option>
									<option>Buddhism</option>
									<option>Judaism</option>
									<option>Sikhism</option>
									<option>Jainism</option>
									<option>Bahá'í Faith</option>
									<option>Shinto</option>
									<option>Taoism</option>
									<option>Confucianism</option>
									<option>Traditional African Religion</option>
									<option>Traditional Chinese Religion</option>
									<option>Zoroastrianism</option>
									<option>Rastafarianism</option>
									<option>Agnosticism</option>
									<option>Atheism</option>
									<option>None</option>
									<option value="Other">Other</option>
								</select>
								<span asp-validation-for="Applicant.Religion" class="text-red-500 text-sm mt-1 block"></span>

								<!-- Other Religion Input Field (Hidden by default) -->
								<div id="otherReligionContainer" class="mt-2 hidden">
									<input type="text"
										   id="otherReligion"
										   placeholder="Please specify your religion"
										   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 transition-colors">
								</div>
							</div>

							<div>
								<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.NRCOrPassport">
									NRC/Passport*
								</label>
								<div class="relative">
									<input asp-for="Applicant.NRCOrPassport"
										   type="text"
										   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10 transition-colors"
										   data-name="NRC/Passport"
										   placeholder="NRC/Passport Number"
										   id="NRCOrPassport"
										   required />
									<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
										<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
											<path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
										</svg>
									</div>
								</div>
								<span asp-validation-for="Applicant.NRCOrPassport" class="text-red-500 text-sm mt-1 block"></span>
							</div>
						</div>

						<!-- Information Card -->
						<div class="mt-8 bg-cyan-50 border-l-4 border-cyan-500 p-4 rounded-lg">
							<div class="flex">
								<div class="flex-shrink-0">
									<svg class="h-5 w-5 text-cyan-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
										<path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
									</svg>
								</div>
								<div class="ml-3">
									<p class="text-sm text-cyan-800">
										All personal information is securely stored and will only be used for academic purposes. Please ensure all information is accurate.
									</p>
								</div>
							</div>
						</div>
					</div>


					<!-- Step 2: Contact Details -->
					<div class="step-pane" data-step="2">
						<!-- Residential Address Section -->
						<div>
							<div class="border-b border-slate-200 pb-4 mb-6">
								<h4 class="text-xl font-semibold text-slate-800">Residential Address</h4>
								<p class="text-slate-500 text-sm mt-1">Please provide your current residential address</p>
							</div>

							<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
								<div>
									<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.Country">
										Country*
									</label>
									<div class="relative">
										<select asp-for="Applicant.Country"
												id="Country"
												asp-items="@(new SelectList(Model.Countries))"
												data-name="Country"
												class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10 transition-colors"
												required>
											<option value="" disabled selected>Select Country</option>
										</select>
										<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
												<path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd" />
											</svg>
										</div>
									</div>
									<span asp-validation-for="Applicant.Country" class="text-red-500 text-sm mt-1 block"></span>
								</div>

								<div>
									<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.State">
										Province/State*
									</label>
									<div class="relative">
										<select asp-for="Applicant.State"
												id="State"
												class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10 transition-colors"
												data-name="Province"
												required>
											<option value="" disabled selected>Select Province</option>
										</select>
										<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
												<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
											</svg>
										</div>
									</div>
									<span asp-validation-for="Applicant.State" class="text-red-500 text-sm mt-1 block"></span>
								</div>

								<div>
									<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.City">
										City*
									</label>
									<div class="relative">
										<select asp-for="Applicant.City"
												id="City"
												class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10 transition-colors"
												data-name="City"
												required>
											<option value="" disabled selected>Select City</option>
										</select>
										<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
												<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
											</svg>
										</div>
									</div>
									<span asp-validation-for="Applicant.City" class="text-red-500 text-sm mt-1 block"></span>
								</div>

								<div>
									<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.PostalCode">
										Postal Code*
									</label>
									<div class="relative">
										<input asp-for="Applicant.PostalCode"
											   placeholder="Postal Code"
											   type="text"
											   data-name="Postal Code"
											   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10 transition-colors"
											   id="PostalCode"
											   required />
										<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
												<path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
											</svg>
										</div>
									</div>
									<span asp-validation-for="Applicant.PostalCode" class="text-red-500 text-sm mt-1 block"></span>
								</div>
							</div>

							<div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
								<div>
									<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.AddressLine1">
										Address Line 1*
									</label>
									<div class="relative">
										<input asp-for="Applicant.AddressLine1"
											   placeholder="Street Address"
											   type="text"
											   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10 transition-colors"
											   data-name="Address Line 1"
											   id="StreetAddress"
											   required />
										<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
												<path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
											</svg>
										</div>
									</div>
									<span asp-validation-for="Applicant.AddressLine1" class="text-red-500 text-sm mt-1 block"></span>
								</div>

								<div>
									<label class="block text-sm font-medium text-slate-700 mb-2" asp-for="Applicant.AddressLine2">
										Address Line 2 <span class="text-slate-400 text-xs">(Optional)</span>
									</label>
									<div class="relative">
										<input asp-for="Applicant.AddressLine2"
											   placeholder="Apartment, Suite, Unit, etc."
											   type="text"
											   class="w-full rounded-lg border-slate-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 pl-10 transition-colors"
											   id="LineAddress2" />
										<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
