@model IEnumerable<SIS.Models.Zoom.ZoomMeeting>

@section Styles {
    <style>
        :root {
            --coral: #e85c5c;
            --coral-d: #c94040;
            --navy: #1e2d5e;
            --navy-l: #2e3f7a;
            --mist: #f5f7fa;
            --border: #e8ecf2;
            --ink: #1a1f2e;
            --text: #475569;
        }

        .oc-wrap {
            font-family: 'DM Sans', sans-serif;
        }

        /* ── Hero ──────────────────────────────────── */
        .oc-hero {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-l) 55%, #3a2060 100%);
            border-radius: 1.25rem;
            padding: 1.75rem 2rem 4rem;
            position: relative;
            overflow: hidden;
        }

            .oc-hero::before {
                content: '';
                position: absolute;
                top: -50px;
                right: -50px;
                width: 200px;
                height: 200px;
                background: rgba(232,92,92,.15);
                border-radius: 50%;
                pointer-events: none;
            }

            .oc-hero::after {
                content: '';
                position: absolute;
                bottom: -60px;
                left: 25%;
                width: 280px;
                height: 280px;
                background: rgba(255,255,255,.03);
                border-radius: 50%;
                pointer-events: none;
            }

        .hero-inner {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .hero-eyebrow {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: rgba(255,255,255,.5);
            margin-bottom: .35rem;
        }

        .hero-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.85rem;
            color: #fff;
            line-height: 1.2;
            margin-bottom: .3rem;
        }

        .hero-sub {
            font-size: .82rem;
            color: rgba(255,255,255,.55);
        }

        /* Schedule button */
        .btn-schedule {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            background: var(--coral);
            color: #fff;
            font-size: .82rem;
            font-weight: 700;
            padding: .65rem 1.25rem;
            border-radius: .7rem;
            text-decoration: none;
            transition: background .15s;
            white-space: nowrap;
            flex-shrink: 0;
            align-self: center;
            box-shadow: 0 4px 16px rgba(232,92,92,.3);
        }

            .btn-schedule:hover {
                background: var(--coral-d);
            }

            .btn-schedule i {
                font-size: .95rem;
            }

        /* ── Stat strip ─────────────────────────────── */
        .oc-strip {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            box-shadow: 0 4px 24px rgba(30,45,94,.07);
            margin-top: -2.25rem;
            position: relative;
            z-index: 2;
            display: flex;
            overflow: hidden;
        }

        .strip-cell {
            flex: 1;
            padding: 1rem 1.5rem;
            border-right: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: .85rem;
        }

            .strip-cell:last-child {
                border-right: none;
            }

        .strip-icon {
            width: 38px;
            height: 38px;
            border-radius: .65rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .strip-icon i {
                font-size: 1.1rem;
            }

        .strip-val {
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--ink);
            line-height: 1;
        }

        .strip-lbl {
            font-size: .7rem;
            color: var(--text);
            margin-top: .1rem;
        }

        /* ── Section header ────────────────────────── */
        .sec-header {
            display: flex;
            align-items: center;
            gap: .65rem;
            margin-bottom: 1.1rem;
        }

        .sec-pip {
            width: 4px;
            height: 20px;
            border-radius: 2px;
            flex-shrink: 0;
        }

        .sec-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.1rem;
            color: var(--ink);
        }

        .sec-count {
            display: inline-flex;
            align-items: center;
            background: var(--mist);
            border: 1px solid var(--border);
            color: var(--text);
            font-size: .7rem;
            font-weight: 700;
            padding: .15rem .5rem;
            border-radius: 2rem;
        }

        /* ── Meeting cards ──────────────────────────── */
        .meeting-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1rem;
        }

        .meeting-card {
            background: #fff;
            border-radius: 1rem;
            border: 1.5px solid var(--border);
            box-shadow: 0 2px 10px rgba(30,45,94,.05);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform .18s, box-shadow .18s, border-color .18s;
        }

            .meeting-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 32px rgba(30,45,94,.12);
            }

            .meeting-card.active-card:hover {
                border-color: #22c55e;
            }

            .meeting-card.sched-card:hover {
                border-color: var(--navy);
            }

        /* Coloured top bar */
        .card-bar {
            height: 4px;
        }

        .bar-green {
            background: linear-gradient(90deg, #22c55e, #4ade80);
        }

        .bar-navy {
            background: linear-gradient(90deg, var(--navy), var(--navy-l));
        }

        .card-inner {
            padding: 1.25rem;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* Top row: status pill + icon */
        .card-top-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: .85rem;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            font-size: .68rem;
            font-weight: 700;
            padding: .2rem .6rem;
            border-radius: 2rem;
        }

            .status-pill i {
                font-size: .75rem;
            }

        .pill-live {
            background: #dcfce7;
            color: #16a34a;
        }

        .pill-sched {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .card-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .card-icon i {
                font-size: 1.1rem;
            }

        .icon-green {
            background: #dcfce7;
            color: #16a34a;
        }

        .icon-navy {
            background: #dbeafe;
            color: var(--navy);
        }

        /* Topic + course */
        .card-topic {
            font-weight: 700;
            font-size: .95rem;
            color: var(--ink);
            margin-bottom: .25rem;
            line-height: 1.35;
        }

        .card-course {
            font-size: .78rem;
            color: var(--text);
            margin-bottom: 1rem;
        }

        /* Meta rows */
        .card-meta {
            display: flex;
            flex-direction: column;
            gap: .4rem;
            margin-bottom: 1rem;
        }

        .meta-row {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .78rem;
            color: var(--text);
        }

            .meta-row i {
                font-size: .9rem;
                color: #94a3b8;
            }

        /* Card footer */
        .card-foot {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: .85rem;
            border-top: 1px solid var(--border);
            margin-top: auto;
        }

        .link-details {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            font-size: .78rem;
            font-weight: 600;
            color: var(--text);
            text-decoration: none;
            transition: color .15s;
        }

            .link-details:hover {
                color: var(--navy);
            }

            .link-details i {
                font-size: .9rem;
            }

        .btn-join {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .45rem 1rem;
            border-radius: .6rem;
            font-size: .78rem;
            font-weight: 700;
            text-decoration: none;
            transition: background .15s;
        }

            .btn-join i {
                font-size: .85rem;
            }

        .btn-green {
            background: #22c55e;
            color: #fff;
        }

            .btn-green:hover {
                background: #16a34a;
            }

        .btn-navy {
            background: var(--navy);
            color: #fff;
        }

            .btn-navy:hover {
                background: var(--navy-l);
            }

        .btn-disabled {
            background: #e2e8f0;
            color: #94a3b8;
            cursor: not-allowed;
        }

        /* ── Past meetings table ────────────────────── */
        .past-card {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            box-shadow: 0 2px 10px rgba(30,45,94,.05);
            overflow: hidden;
        }

        .past-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .82rem;
        }

            .past-table thead tr {
                background: var(--navy);
            }

            .past-table thead th {
                padding: .65rem 1rem;
                text-align: left;
                color: #fff;
                font-size: .68rem;
                text-transform: uppercase;
                letter-spacing: .05em;
                font-weight: 700;
            }

                .past-table thead th:last-child {
                    text-align: right;
                }

            .past-table tbody tr {
                border-bottom: 1px solid var(--border);
            }

                .past-table tbody tr:last-child {
                    border-bottom: none;
                }

                .past-table tbody tr:hover {
                    background: var(--mist);
                }

            .past-table tbody td {
                padding: .75rem 1rem;
                color: var(--ink);
                vertical-align: middle;
            }

                .past-table tbody td:last-child {
                    text-align: right;
                }

        .topic-name {
            font-weight: 600;
            font-size: .84rem;
            color: var(--ink);
        }

        .course-code {
            display: inline-block;
            font-size: .7rem;
            font-weight: 700;
            background: #fef2f2;
            color: var(--coral-d);
            padding: .15rem .5rem;
            border-radius: .35rem;
        }

        .pill-completed {
            background: #dcfce7;
            color: #166534;
        }

        .pill-missed {
            background: #fee2e2;
            color: #991b1b;
        }

        .tbl-pill {
            display: inline-flex;
            align-items: center;
            gap: .2rem;
            font-size: .68rem;
            font-weight: 700;
            padding: .2rem .55rem;
            border-radius: 2rem;
        }

        /* ── Empty states ───────────────────────────── */
        .empty-state {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            padding: 2.5rem 1.5rem;
            text-align: center;
        }

            .empty-state i {
                font-size: 2.5rem;
                color: #cbd5e1;
                display: block;
                margin-bottom: .65rem;
            }

            .empty-state h3 {
                font-size: .9rem;
                font-weight: 700;
                color: var(--ink);
                margin-bottom: .25rem;
            }

            .empty-state p {
                font-size: .78rem;
                color: var(--text);
            }

        /* ── Live pulse animation ───────────────────── */
        .live-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #22c55e;
            display: inline-block;
            position: relative;
        }

            .live-dot::after {
                content: '';
                position: absolute;
                inset: -3px;
                border-radius: 50%;
                border: 2px solid #22c55e;
                animation: pulse-ring 1.5s ease infinite;
            }
        @@keyframes pulse-ring {
            0% {
                transform: scale(1);
                opacity: .8;
            }

            100% {
                transform: scale(2);
                opacity: 0;
            }
        }

        @@media (max-width: 640px) {
            .oc-strip {
                flex-wrap: wrap;
            }

            .strip-cell {
                min-width: 50%;
            }

            .meeting-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@{
    var activeMeetings = Model.Where(m => m.Status == SIS.Enums.Status.Active).ToList();
    var upcomingMeetings = Model.Where(m => m.Status == SIS.Enums.Status.Scheduled).OrderBy(m => m.StartTime).ToList();
    var pastMeetings = Model.Where(m => m.Status == SIS.Enums.Status.Completed ||
                               (m.Status == SIS.Enums.Status.Scheduled && m.StartTime.AddMinutes(m.Duration) < DateTime.Now))
                               .OrderByDescending(m => m.StartTime).Take(10).ToList();
}

<div class="oc-wrap p-4 md:p-6">

    <!-- Hero -->
    <div class="oc-hero mb-6">
        <div class="hero-inner">
            <div>
                <p class="hero-eyebrow">Learning Management</p>
                <h1 class="hero-title">Online Classes</h1>
                <p class="hero-sub">Manage your scheduled and active meetings</p>
            </div>
            <a asp-action="Create" class="btn-schedule">
                <i class="material-icons">add</i> Schedule Meeting
            </a>
        </div>
    </div>

    <!-- Stat strip -->
    <div class="oc-strip mb-7">
        <div class="strip-cell">
            <div class="strip-icon" style="background:#dcfce7;">
                <i class="material-icons" style="color:#16a34a;">fiber_manual_record</i>
            </div>
            <div>
                <div class="strip-val">@activeMeetings.Count</div>
                <div class="strip-lbl">Live Now</div>
            </div>
        </div>
        <div class="strip-cell">
            <div class="strip-icon" style="background:#dbeafe;">
                <i class="material-icons" style="color:var(--navy);">event</i>
            </div>
            <div>
                <div class="strip-val">@upcomingMeetings.Count</div>
                <div class="strip-lbl">Upcoming</div>
            </div>
        </div>
        <div class="strip-cell">
            <div class="strip-icon" style="background:#f1f5f9;">
                <i class="material-icons" style="color:#64748b;">history</i>
            </div>
            <div>
                <div class="strip-val">@pastMeetings.Count</div>
                <div class="strip-lbl">Past (recent)</div>
            </div>
        </div>
        <div class="strip-cell">
            <div class="strip-icon" style="background:#fef2f2;">
                <i class="material-icons" style="color:var(--coral);">videocam</i>
            </div>
            <div>
                <div class="strip-val">@Model.Count()</div>
                <div class="strip-lbl">Total Meetings</div>
            </div>
        </div>
    </div>

    <!-- ── Active Meetings ── -->
    <div class="mb-8">
        <div class="sec-header">
            <div class="sec-pip" style="background:#22c55e;"></div>
            <h2 class="sec-title">Live Classes</h2>
            @if (activeMeetings.Any())
            {
                <span class="live-dot"></span>
            }
            <span class="sec-count">@activeMeetings.Count</span>
        </div>

        @if (activeMeetings.Any())
        {
            <div class="meeting-grid">
                @foreach (var meeting in activeMeetings)
                {
                    <div class="meeting-card active-card">
                        <div class="card-bar bar-green"></div>
                        <div class="card-inner">
                            <div class="card-top-row">
                                <span class="status-pill pill-live">
                                    <i class="material-icons">fiber_manual_record</i> Live
                                </span>
                                <div class="card-icon icon-green">
                                    <i class="material-icons">videocam</i>
                                </div>
                            </div>
                            <p class="card-topic">@meeting.Topic</p>
                            <p class="card-course">@meeting.Course.CourseCode &nbsp;·&nbsp; @meeting.Course.CourseName</p>
                            <div class="card-meta">
                                <div class="meta-row">
                                    <i class="material-icons">schedule</i>
                                    Started at @meeting.StartTime.ToString("hh:mm tt")
                                </div>
                                <div class="meta-row">
                                    <i class="material-icons">timelapse</i>
                                    Duration: @meeting.Duration minutes
                                </div>
                                <div class="meta-row">
                                    <i class="material-icons">calendar_today</i>
                                    @meeting.CreatedAt.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                            <div class="card-foot">
                                <a asp-action="Details" asp-route-id="@meeting.Id" class="link-details">
                                    <i class="material-icons">info</i> Details
                                </a>
                                <a asp-action="StartMeeting" asp-route-id="@meeting.Id" class="btn-join btn-green">
                                    <i class="material-icons">login</i> Rejoin
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="material-icons">videocam_off</i>
                <h3>No live classes right now</h3>
                <p>Active meetings will appear here when they go live.</p>
            </div>
        }
    </div>

    <!-- ── Upcoming Meetings ── -->
    <div class="mb-8">
        <div class="sec-header">
            <div class="sec-pip" style="background:var(--navy);"></div>
            <h2 class="sec-title">Upcoming Meetings</h2>
            <span class="sec-count">@upcomingMeetings.Count</span>
        </div>

        @if (upcomingMeetings.Any())
        {
            <div class="meeting-grid">
                @foreach (var meeting in upcomingMeetings)
                {
                    var canStart = DateTime.Now >= meeting.StartTime.AddMinutes(-5);
                    <div class="meeting-card sched-card">
                        <div class="card-bar bar-navy"></div>
                        <div class="card-inner">
                            <div class="card-top-row">
                                <span class="status-pill pill-sched">
                                    <i class="material-icons">event</i> Scheduled
                                </span>
                                <div class="card-icon icon-navy">
                                    <i class="material-icons">event</i>
                                </div>
                            </div>
                            <p class="card-topic">@meeting.Topic</p>
                            <p class="card-course">@meeting.Course.CourseCode &nbsp;·&nbsp; @meeting.Course.CourseName</p>
                            <div class="card-meta">
                                <div class="meta-row">
                                    <i class="material-icons">calendar_today</i>
                                    @meeting.StartTime.ToString("MMM dd, yyyy")
                                </div>
                                <div class="meta-row">
                                    <i class="material-icons">schedule</i>
                                    @meeting.StartTime.ToString("hh:mm tt")
                                </div>
                                <div class="meta-row">
                                    <i class="material-icons">timelapse</i>
                                    @meeting.Duration minutes
                                </div>
                            </div>
                            <div class="card-foot">
                                <a asp-action="Details" asp-route-id="@meeting.Id" class="link-details">
                                    <i class="material-icons">info</i> Details
                                </a>
                                @if (canStart)
                                {
                                    <a asp-action="StartMeeting" asp-route-id="@meeting.Id" class="btn-join btn-navy">
                                        <i class="material-icons">play_arrow</i> Start
                                    </a>
                                }
                                else
                                {
                                    <span class="btn-join btn-disabled">
                                        <i class="material-icons">play_arrow</i> Start
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="material-icons">event_busy</i>
                <h3>No upcoming meetings</h3>
                <p>Use the Schedule Meeting button above to create one.</p>
            </div>
        }
    </div>

    <!-- ── Past Meetings ── -->
    <div>
        <div class="sec-header">
            <div class="sec-pip" style="background:#94a3b8;"></div>
            <h2 class="sec-title">Past Meetings</h2>
            <span class="sec-count">@pastMeetings.Count</span>
        </div>

        @if (pastMeetings.Any())
        {
            <div class="past-card">
                <div style="overflow-x:auto;">
                    <table class="past-table">
                        <thead>
                            <tr>
                                <th>Topic</th>
                                <th>Course</th>
                                <th>Date &amp; Time</th>
                                <th>Duration</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var meeting in pastMeetings)
                            {
                                <tr>
                                    <td>
                                        <div class="topic-name">@meeting.Topic</div>
                                    </td>
                                    <td>
                                        <span class="course-code">@meeting.Course.CourseCode</span>
                                    </td>
                                    <td>
                                        <div style="font-size:.82rem;font-weight:600;color:var(--ink);">@meeting.StartTime.ToString("MMM dd, yyyy")</div>
                                        <div style="font-size:.72rem;color:var(--text);">@meeting.StartTime.ToString("hh:mm tt")</div>
                                    </td>
                                    <td style="font-size:.82rem;">@meeting.Duration min</td>
                                    <td>
                                        @if (meeting.Status == SIS.Enums.Status.Completed)
                                        {
                                            <span class="tbl-pill pill-completed">
                                                <i class="material-icons" style="font-size:.75rem;">check_circle</i> Completed
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="tbl-pill pill-missed">
                                                <i class="material-icons" style="font-size:.75rem;">cancel</i> Missed
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display:flex;align-items:center;justify-content:flex-end;gap:.75rem;">
                                            <a asp-action="Details" asp-route-id="@meeting.Id"
                                               style="font-size:.78rem;font-weight:600;color:var(--navy);text-decoration:none;">
                                                Details
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@meeting.Id" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        style="font-size:.78rem;font-weight:600;color:var(--coral);background:none;border:none;cursor:pointer;padding:0;"
                                                        onclick="return confirm('Delete this meeting?')">
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="material-icons">history</i>
                <h3>No past meetings</h3>
                <p>Your completed and missed meetings will show up here.</p>
            </div>
        }
    </div>

</div>
