@model IEnumerable<SIS.Models.Zoom.ZoomMeeting>

<div class="min-h-screen bg-slate-50 p-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-center h-24 mb-4">
        <div class="flex items-center text-slate-800">
            <i class="material-icons text-3xl mr-2">videocam</i>
            <div>
                <h1 class="text-2xl font-bold">My Online Meetings</h1>
                <p class="text-sm text-slate-600">Manage your scheduled and active meetings</p>
            </div>
        </div>
        <div class="mt-4 md:mt-0">
            <a asp-action="Create" class="inline-flex items-center px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                <i class="material-icons text-sm mr-1">add</i>
                <span>Schedule Meeting</span>
            </a>
        </div>
    </div>

    <!-- Active Meetings Section -->
    <div class="mb-8">
        <h2 class="text-lg font-semibold text-slate-800 mb-4">Active Meetings</h2>

        @{
            var activeMeetings = Model.Where(m => m.Status == SIS.Enums.Status.Active).ToList();
        }

        @if (activeMeetings.Any())
        {
            <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6">
                @foreach (var meeting in activeMeetings)
                {
                    <div class="bg-white rounded-xl shadow-sm border-l-4 border-green-500 overflow-hidden">
                        <div class="p-5">
                            <div class="flex items-start justify-between">
                                <div>
                                    <div class="flex items-center">
                                        <span class="inline-flex items-center justify-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 mr-2">
                                            <i class="material-icons text-xs mr-1">fiber_manual_record</i>
                                            Active
                                        </span>
                                        <p class="text-xs text-slate-500">@meeting.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                    <h3 class="text-lg font-semibold text-slate-800 mt-2">@meeting.Topic</h3>
                                    <p class="text-sm text-slate-600 mt-1">@meeting.Course.CourseCode - @meeting.Course.CourseName</p>
                                </div>
                                <div class="bg-green-100 rounded-full p-2">
                                    <i class="material-icons text-green-600">videocam</i>
                                </div>
                            </div>

                            <div class="mt-4">
                                <div class="flex items-center text-sm text-slate-600 mb-2">
                                    <i class="material-icons text-slate-400 text-base mr-2">schedule</i>
                                    <span>Started at @meeting.StartTime.ToString("hh:mm tt")</span>
                                </div>
                                <div class="flex items-center text-sm text-slate-600">
                                    <i class="material-icons text-slate-400 text-base mr-2">timelapse</i>
                                    <span>Duration: @meeting.Duration minutes</span>
                                </div>
                            </div>

                            <div class="mt-5 pt-4 border-t border-slate-100 flex justify-between">
                                <a asp-action="Details" asp-route-id="@meeting.Id" class="text-primary-600 hover:text-primary-800 inline-flex items-center">
                                    <i class="material-icons text-sm mr-1">info</i>
                                    Details
                                </a>
                                <a asp-action="StartMeeting" asp-route-id="@meeting.Id" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                                    <i class="material-icons text-sm mr-1">login</i>
                                    Rejoin Meeting
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-xl shadow-sm p-6 text-center">
                <i class="material-icons text-5xl text-slate-300 mb-2">videocam_off</i>
                <h3 class="text-lg font-medium text-slate-700 mb-2">No active meetings</h3>
                <p class="text-sm text-slate-500 mb-4">Your active meetings will appear here.</p>
            </div>
        }
    </div>

    <!-- Upcoming Meetings Section -->
    <div class="mb-8">
        <h2 class="text-lg font-semibold text-slate-800 mb-4">Upcoming Meetings</h2>

        @{
            var upcomingMeetings = Model.Where(m => m.Status == SIS.Enums.Status.Scheduled).OrderBy(m => m.StartTime).ToList();
        }

        @if (upcomingMeetings.Any())
        {
            <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6">
                @foreach (var meeting in upcomingMeetings)
                {
                    <div class="bg-white rounded-xl shadow-sm border-l-4 border-blue-500 overflow-hidden">
                        <div class="p-5">
                            <div class="flex items-start justify-between">
                                <div>
                                    <div class="flex items-center">
                                        <span class="inline-flex items-center justify-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mr-2">
                                            Scheduled
                                        </span>
                                        <p class="text-xs text-slate-500">@meeting.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                    <h3 class="text-lg font-semibold text-slate-800 mt-2">@meeting.Topic</h3>
                                    <p class="text-sm text-slate-600 mt-1">@meeting.Course.CourseCode - @meeting.Course.CourseName</p>
                                </div>
                                <div class="bg-blue-100 rounded-full p-2">
                                    <i class="material-icons text-blue-600">event</i>
                                </div>
                            </div>

                            <div class="mt-4">
                                <div class="flex items-center text-sm text-slate-600 mb-2">
                                    <i class="material-icons text-slate-400 text-base mr-2">event</i>
                                    <span>@meeting.StartTime.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="flex items-center text-sm text-slate-600 mb-2">
                                    <i class="material-icons text-slate-400 text-base mr-2">schedule</i>
                                    <span>@meeting.StartTime.ToString("hh:mm tt")</span>
                                </div>
                                <div class="flex items-center text-sm text-slate-600">
                                    <i class="material-icons text-slate-400 text-base mr-2">timelapse</i>
                                    <span>Duration: @meeting.Duration minutes</span>
                                </div>
                            </div>

                            <div class="mt-5 pt-4 border-t border-slate-100 flex justify-between">
                                <a asp-action="Details" asp-route-id="@meeting.Id" class="text-primary-600 hover:text-primary-800 inline-flex items-center">
                                    <i class="material-icons text-sm mr-1">info</i>
                                    Details
                                </a>
                                @if (DateTime.Now >= meeting.StartTime.AddMinutes(-5))
                                {
                                    <a asp-action="StartMeeting" asp-route-id="@meeting.Id" class="inline-flex items-center px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                                        <i class="material-icons text-sm mr-1">play_arrow</i>
                                        Start Meeting
                                    </a>
                                }
                                else
                                {
                                    <button disabled class="inline-flex items-center px-4 py-2 bg-slate-200 text-slate-500 rounded-lg cursor-not-allowed">
                                        <i class="material-icons text-sm mr-1">play_arrow</i>
                                        Start Meeting
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-xl shadow-sm p-6 text-center">
                <i class="material-icons text-5xl text-slate-300 mb-2">event_busy</i>
                <h3 class="text-lg font-medium text-slate-700 mb-2">No upcoming meetings</h3>
                <p class="text-sm text-slate-500 mb-4">Schedule a meeting using the button above.</p>
            </div>
        }
    </div>

    <!-- Past Meetings Section -->
    <div>
        <h2 class="text-lg font-semibold text-slate-800 mb-4">Past Meetings</h2>

        @{
            var pastMeetings = Model.Where(m => m.Status == SIS.Enums.Status.Completed ||
            (m.Status == SIS.Enums.Status.Scheduled && m.StartTime.AddMinutes(m.Duration) < DateTime.Now))
            .OrderByDescending(m => m.StartTime).Take(10).ToList();
        }

        @if (pastMeetings.Any())
        {
            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Topic</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Course</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Duration</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        @foreach (var meeting in pastMeetings)
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-slate-900">@meeting.Topic</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-slate-700">@meeting.Course.CourseCode</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-slate-700">@meeting.StartTime.ToString("MMM dd, yyyy")</div>
                                    <div class="text-xs text-slate-500">@meeting.StartTime.ToString("hh:mm tt")</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-slate-700">@meeting.Duration min</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (meeting.Status == SIS.Enums.Status.Completed)
                                    {
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Missed</span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a asp-action="Details" asp-route-id="@meeting.Id" class="text-primary-600 hover:text-primary-900 mr-3">
                                        Details
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@meeting.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="text-red-600 hover:text-red-900" onclick="return confirm('Are you sure you want to delete this meeting?');">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="bg-white rounded-xl shadow-sm p-6 text-center">
                <i class="material-icons text-5xl text-slate-300 mb-2">history</i>
                <h3 class="text-lg font-medium text-slate-700 mb-2">No past meetings</h3>
                <p class="text-sm text-slate-500 mb-4">Your past meetings will appear here.</p>
            </div>
        }
    </div>
</div>