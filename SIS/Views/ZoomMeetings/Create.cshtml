@model SIS.Controllers.CreateMeetingViewModel

<div class="min-h-screen bg-slate-50 p-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-center h-24 mb-4">
        <div class="flex items-center text-slate-800">
            <i class="material-icons text-3xl mr-2">videocam</i>
            <div>
                <h1 class="text-2xl font-bold">Create Online Meeting</h1>
                <p class="text-sm text-slate-600">Schedule a new meeting for your course</p>
            </div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-sm mb-6">
        <div class="p-6">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="mb-4 p-4 bg-red-50 text-red-600 border border-red-200 rounded-lg"></div>

                <!-- Course Selection -->
                <div class="mb-6">
                    <label asp-for="CourseId" class="block text-sm font-medium text-slate-700 mb-2">Course</label>
                    <select asp-for="CourseId" class="w-full p-2.5 text-gray-700 bg-white border border-slate-200 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                        <option value="">Select a course</option>
                        @foreach (var course in ViewBag.Courses)
                        {
                            <option value="@course.Id">@course.CourseCode - @course.CourseName</option>
                        }
                    </select>
                    <span asp-validation-for="CourseId" class="text-sm text-red-600"></span>
                </div>

                <!-- Meeting Topic -->
                <div class="mb-6">
                    <label asp-for="Topic" class="block text-sm font-medium text-slate-700 mb-2">Meeting Topic</label>
                    <input asp-for="Topic" type="text" class="w-full p-2.5 text-gray-700 bg-white border border-slate-200 rounded-lg focus:ring-primary-500 focus:border-primary-500" placeholder="Enter meeting topic">
                    <span asp-validation-for="Topic" class="text-sm text-red-600"></span>
                </div>

                <!-- Start Time -->
                <div class="mb-6">
                    <label asp-for="StartTime" class="block text-sm font-medium text-slate-700 mb-2">Start Time</label>
                    <input asp-for="StartTime" type="datetime-local" class="w-full p-2.5 text-gray-700 bg-white border border-slate-200 rounded-lg focus:ring-primary-500 focus:border-primary-500">
                    <span asp-validation-for="StartTime" class="text-sm text-red-600"></span>
                </div>

                <!-- Duration -->
                <div class="mb-6">
                    <label asp-for="Duration" class="block text-sm font-medium text-slate-700 mb-2">Duration (minutes)</label>
                    <input asp-for="Duration" type="number" min="15" max="240" step="5" class="w-full p-2.5 text-gray-700 bg-white border border-slate-200 rounded-lg focus:ring-primary-500 focus:border-primary-500" placeholder="60">
                    <span asp-validation-for="Duration" class="text-sm text-red-600"></span>
                </div>

                <!-- Agenda -->
                <div class="mb-6">
                    <label asp-for="Agenda" class="block text-sm font-medium text-slate-700 mb-2">Agenda (Optional)</label>
                    <textarea asp-for="Agenda" rows="4" class="w-full p-2.5 text-gray-700 bg-white border border-slate-200 rounded-lg focus:ring-primary-500 focus:border-primary-500" placeholder="Enter meeting agenda"></textarea>
                    <span asp-validation-for="Agenda" class="text-sm text-red-600"></span>
                </div>

                <!-- Submit Button -->
                <div class="flex items-center justify-end">
                    <a asp-action="Index" class="px-4 py-2 mr-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
                        Cancel
                    </a>
                    <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                        <i class="material-icons text-sm mr-1">add</i>
                        Create Meeting
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}