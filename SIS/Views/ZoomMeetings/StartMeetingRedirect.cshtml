@model SIS.Models.Zoom.ZoomMeeting
<div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-6">
    <div class="max-w-lg w-full bg-white rounded-xl shadow-md p-8 text-center">
        <i class="material-icons text-5xl text-green-600 mb-4">videocam</i>
        <h1 class="text-2xl font-bold text-slate-800 mb-2">Starting Your Meeting</h1>
        <p class="text-slate-600 mb-6">You're about to host the meeting "<span class="font-medium">@Model.Topic</span>"</p>
        <div class="bg-slate-50 rounded-lg p-4 mb-6 text-left">
            <p class="text-sm text-slate-700 mb-2"><i class="material-icons text-xs mr-1 align-middle">info</i> <span class="align-middle">Hosting meetings requires opening Zoom directly</span></p>
            <p class="text-sm text-slate-600">Click the button below to launch Zoom and start your meeting.</p>
        </div>
        @* <a href="@ViewBag.StartUrl" target="_blank" class="inline-flex items-center justify-center w-full px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors mb-4"> *@
        @*     <i class="material-icons text-lg mr-2">play_circle</i> *@
        @*     Launch Zoom Meeting *@
        @* </a> *@

        @* <a asp-action="Host" asp-route-id="@Model.Id" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors"> *@
        @*     <i class="material-icons text-sm mr-1">login</i> *@
        @*     Launch Meeting *@
        @* </a> *@

        <a asp-action="HostMeeting" asp-route-id="@Model.Id" class="inline-flex items-center justify-center w-full px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors mb-4">
            <i class="material-icons text-lg mr-2">play_circle</i>
            Launch Meeting
        </a>
        <a href="@ViewBag.StartUrl" target="_blank" class="inline-flex items-center justify-center w-full px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors mb-4">
            <i class="material-icons text-lg mr-2">play_circle</i>
            Launch  Meeting in Zoom
        </a>

        <!-- End Meeting Button -->
        <form asp-action="EndMeeting" asp-controller="ZoomMeetings" asp-route-id="@Model.Id" method="post" class="mb-4">
            @Html.AntiForgeryToken()
            <button type="submit" class="inline-flex items-center justify-center w-full px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                <i class="material-icons text-lg mr-2">stop_circle</i>
                End Meeting
            </button>
        </form>

        <div class="mt-6">
            <a href="@Url.Action("Index")" class="text-sm text-slate-600 hover:text-slate-800 transition-colors">
                <i class="material-icons text-xs mr-1 align-middle">arrow_back</i>
                <span class="align-middle">Back to Meetings</span>
            </a>
        </div>
    </div>
</div>