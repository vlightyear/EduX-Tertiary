   @*                   allow="microphone; camera; fullscreen; display-capture; autoplay"  *@
   @*                   style="height: calc(100vh - 140px); width: 100%; border: none;"  *@
   @*                   class="bg-white">  *@
   @*           </iframe>  *@
   @*       </div>  *@
   @*   </div> *@


    <!-- Zoom Meeting Iframe -->
    <div class="flex-grow p-0">
        <div id="iframeContainerA" class="w-full h-full">
            <iframe src='@Url.Action("Join", new { id = @Model.Id })'
                    allow="microphone; camera; fullscreen; display-capture; autoplay"
                    style="height: calc(100vh - 140px); width: 100%; border: none;"
                    class="bg-white">
            </iframe>
        </div>
        <div id="iframeContainerA" class="w-full h-full">
            Exam in progress
        </div>
        <div>

            <script>
                function showIframe(target) {
                    const iframeA = document.getElementById('iframeContainerA');
                    const iframeB = document.getElementById('iframeContainerB');

                    if (target === 'A') {
                        iframeA.style.display = 'block';
                        iframeB.style.display = 'none';
                    } else if (target === 'B') {
                        iframeA.style.display = 'none';
                        iframeB.style.display = 'block';
                    }
                }
            </script>
            <style>
                iframe {
                    width: 100%;
                    height: 500px;
                    border: none;
                }
            </style>
        </div>



    </div>
</div>