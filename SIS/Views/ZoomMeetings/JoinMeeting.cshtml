@model SIS.Models.Zoom.ZoomMeeting

<div class="min-h-screen bg-slate-50 flex flex-col">
    <!-- Header Section -->
    <div class="bg-white border-b border-slate-200 px-6 py-4">
        <div class="flex flex-col md:flex-row justify-between items-center">
            <div class="flex items-center text-slate-800 mb-4 md:mb-0">
                <i class="material-icons text-2xl mr-2 text-green-600">videocam</i>
                <div>
                    <h1 class="text-xl font-bold">@Model.Topic</h1>
                    <p class="text-sm text-slate-600">@Model.Course.CourseCode - @Model.Course.CourseName</p>
                </div>
            </div>
            <div class="flex items-center">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    <i class="material-icons text-xs mr-1">fiber_manual_record</i>
                    Live Meeting
                </span>
                <a href="@Url.Action("Index")" class="ml-3 inline-flex items-center px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
                    <i class="material-icons text-sm mr-1">arrow_back</i>
                    Back to Meetings
                </a>
            </div>
        </div>
    </div>

    <!-- Meeting Info Bar -->
    <div class="bg-slate-100 px-6 py-2 border-b border-slate-200">
        <div class="flex flex-wrap items-center text-sm text-slate-600">
            <div class="flex items-center mr-6 py-1">
                <i class="material-icons text-slate-400 text-base mr-1">person</i>
                <span>Host: @Model.CreatedBy.FullName</span>
            </div>
            <div class="flex items-center mr-6 py-1">
                <i class="material-icons text-slate-400 text-base mr-1">schedule</i>
                <span>Started at @Model.StartTime.ToString("hh:mm tt")</span>
            </div>
            <div class="flex items-center py-1">
                <i class="material-icons text-slate-400 text-base mr-1">info</i>
                <span>Please enable your camera and microphone when prompted</span>
            </div>

            <button onclick="showIframe('A')" class="ml-3 inline-flex items-center px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">Show Meeting</button>
            <button onclick="showIframe('B')" class="ml-3 inline-flex items-center px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">Show Exam In Progress</button>
        </div>
    </div>


    @* <a asp-action="Join" asp-route-id="@Model.Id" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors"> *@
    @*     <i class="material-icons text-sm mr-1">login</i> *@
    @*     Join Live Lesson *@
    @* </a> *@


    <!-- Zoom Meeting Iframe -->
   @* <div class="flex-grow p-0">  *@
   @*      <div class="w-full h-full"> *@
