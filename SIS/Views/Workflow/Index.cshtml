@model IEnumerable<WorkflowTemplate>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">account_tree</i>
            Workflow Templates
        </h1>
        <button type="button"
                onclick="location.href='@Url.Action("CreateTemplate", "Workflow")'"
                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
            <i class="material-icons mr-2">add</i>
            Create Template
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full overflow-auto">
                <div class="p-4">
                    <table id="workflowTable" class="w-full text-sm text-secondary-600">
                        <thead>
                            <tr>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        #
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">
                                    <span class="flex items-center">
                                        Template Name
                                        <svg class="w-4 h-4 ms-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                        </svg>
                                    </span>
                                </th>
                                <th class="px-6 py-4">Entity Type</th>
                                <th class="px-6 py-4">Stages</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Created Date</th>
                                <th class="px-6 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var template in Model)
                            {
                                <tr class="border-b hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4">@(Model.ToList().IndexOf(template) + 1)</td>
                                    <td class="px-6 py-4 font-medium text-gray-900">@template.Name</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                                            @template.EntityType
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                            @template.Stages.Count Stages
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                        @if (template.IsActive)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                <i class="material-icons text-xs mr-1">check_circle</i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-secondary-800">
                                                <i class="material-icons text-xs mr-1">cancel</i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4">@template.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td class="px-6 py-4">
                                        <div class="flex space-x-2">
                                            <button onclick="viewStages('@template.Id')"
                                                    class="inline-flex items-center px-3 py-1 text-sm text-purple-600 bg-purple-50 hover:bg-purple-100 rounded-lg transition-colors">
                                                <i class="material-icons text-sm mr-1">visibility</i> View
                                            </button>
                                            <button onclick="location.href='@Url.Action("EditTemplate", "Workflow", new { id = template.Id })'"
                                                    class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors">
                                                <i class="material-icons text-sm mr-1">edit</i> Edit
                                            </button>
                                            <button onclick="showDeleteModal('@template.Id', '@template.Name')"
                                                    class="inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                                                <i class="material-icons text-sm mr-1">delete</i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Template Summary</h3>
                <div class="space-y-6">
                    <!-- Total Templates -->
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">account_tree</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Templates</p>
                            <p class="text-xl font-semibold">@Model.Count()</p>
                        </div>
                    </div>

                    <!-- Active Templates -->
                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">check_circle</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Active Templates</p>
                            <p class="text-xl font-semibold text-green-600">@Model.Count(x => x.IsActive)</p>
                        </div>
                    </div>

                    <!-- Total Stages -->
                    <div class="flex items-center">
                        <div class="p-3 bg-purple-100 rounded-lg">
                            <i class="material-icons text-purple-600 text-xl">layers</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Stages</p>
                            <p class="text-xl font-semibold text-purple-600">
                                @Model.Sum(x => x.Stages.Count)
                            </p>
                        </div>
                    </div>

                    <!-- Entity Types -->
                    <div class="flex items-center">
                        <div class="p-3 bg-indigo-100 rounded-lg">
                            <i class="material-icons text-indigo-600 text-xl">category</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Entity Types</p>
                            <p class="text-xl font-semibold text-indigo-600">
                                @Model.Select(x => x.EntityType).Distinct().Count()
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Template Distribution Chart -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Status Distribution</h3>
                <div id="statusDistributionChart" class="min-h-64"></div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Template Modal -->
<div id="deleteModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg">
                <div class="bg-red-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">warning</i>
                        Confirm Delete
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200" onclick="hideDeleteModal()">
                        <i class="material-icons">close</i>
                    </button>
                </div>
                <div class="p-6">
                    <form id="deleteForm" method="post" asp-controller="Workflow" asp-action="DeleteTemplate">
                        <input type="hidden" id="deleteId" name="Id" />
                        @Html.AntiForgeryToken()
                        <div class="space-y-4">
                            <div class="flex items-center text-red-600 mb-4">
                                <i class="material-icons mr-2">error_outline</i>
                                <p class="text-lg font-medium">Delete Workflow Template</p>
                            </div>
                            <p class="text-gray-700">Are you sure you want to delete this workflow template?</p>
                            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mt-4">
                                <p class="text-gray-700 font-medium mb-2">Template Details:</p>
                                <p class="text-secondary-600">
                                    <span class="font-medium">Name:</span>
                                    <span id="deleteName" class="ml-2"></span>
                                </p>
                            </div>
                            <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <div class="flex items-center text-red-800">
                                    <i class="material-icons text-red-600 mr-2 text-sm">info</i>
                                    <p class="text-sm">This action cannot be undone. All associated stages will be deleted.</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="bg-gray-50 px-6 py-4 rounded-b-lg flex justify-end space-x-2">
                    <button type="button" class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center" onclick="hideDeleteModal()">
                        <i class="material-icons mr-1">close</i>Cancel
                    </button>
                    <button type="button" onclick="document.getElementById('deleteForm').submit()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                        <i class="material-icons mr-1">delete</i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dataTable = new simpleDatatables.DataTable("#workflowTable", {
                perPage: 10,
                searchable: true,
                sortable: true,
                labels: {
                    placeholder: "Search templates...",
                    perPage: "Show {select} entries",
                    noRows: "No templates found",
                    info: "Showing {start} to {end} of {rows} templates",
                }
            });

            const statusDistributionChart = new ApexCharts(document.querySelector("#statusDistributionChart"), {
                series: [@Model.Count(x => x.IsActive), @Model.Count(x => !x.IsActive)],
                chart: { type: 'donut', height: '100%' },
                labels: ['Active', 'Inactive'],
                colors: ['#10B981', '#6B7280'],
                plotOptions: {
                    pie: {
                        donut: {
                            size: '70%',
                            labels: {
                                show: true,
                                total: {
                                    show: true,
                                    label: 'Total',
                                    formatter: function (w) {
                                        return w.globals.seriesTotals.reduce((a, b) => a + b, 0)
                                    }
                                }
                            }
                        }
                    }
                },
                legend: { show: false },
                dataLabels: { enabled: false }
            });
            statusDistributionChart.render();
        });

        function showDeleteModal(id, name) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteName').textContent = name;
            document.getElementById('deleteModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hideDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function viewStages(templateId) {
            location.href = '@Url.Action("ViewStages", "Workflow")?templateId=' + templateId;
        }
    </script>
}