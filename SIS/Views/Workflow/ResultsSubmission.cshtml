@model ResultSubmissionBatch

<div class="min-h-screen bg-gray-50 p-6">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-6">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900 flex items-center">
                        <i class="material-icons mr-3 text-blue-600">upload_file</i>
                        Submit Results for Approval
                    </h1>
                    <p class="text-secondary-600 mt-2">Upload and submit @(Model.SubmissionType == "AssessmentScores" ? "assessment scores" : "course results") for workflow approval</p>
                </div>
                <button onclick="history.back()" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 flex items-center">
                    <i class="material-icons mr-2">arrow_back</i>Back
                </button>
            </div>
        </div>

        <!-- Progress Steps -->
        <div class="mb-8">
            <div class="flex items-center justify-between">
                <div class="flex items-center flex-1">
                    <div class="flex items-center text-blue-600">
                        <div class="rounded-full h-10 w-10 bg-blue-600 text-white flex items-center justify-center font-semibold">1</div>
                        <span class="ml-2 font-medium">Create Batch</span>
                    </div>
                    <div class="flex-1 border-t-2 border-blue-600 mx-4"></div>
                </div>
                <div class="flex items-center flex-1" id="step2">
                    <div class="flex items-center text-gray-400">
                        <div class="rounded-full h-10 w-10 bg-gray-300 text-white flex items-center justify-center font-semibold">2</div>
                        <span class="ml-2 font-medium">Upload Results</span>
                    </div>
                    <div class="flex-1 border-t-2 border-gray-300 mx-4"></div>
                </div>
                <div class="flex items-center" id="step3">
                    <div class="flex items-center text-gray-400">
                        <div class="rounded-full h-10 w-10 bg-gray-300 text-white flex items-center justify-center font-semibold">3</div>
                        <span class="ml-2 font-medium">Submit</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Batch Information Card -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
            <h2 class="text-xl font-semibold text-secondary-800 mb-4 flex items-center">
                <i class="material-icons mr-2">info</i>
                Batch Information
            </h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="border rounded-lg p-4">
                    <p class="text-sm text-secondary-600">Batch ID</p>
                    <p class="text-lg font-semibold text-gray-900">#@Model.Id</p>
                </div>
                <div class="border rounded-lg p-4">
                    <p class="text-sm text-secondary-600">Course</p>
                    <p class="text-lg font-semibold text-gray-900">@Model.Course.CourseName</p>
                </div>
                <div class="border rounded-lg p-4">
                    <p class="text-sm text-secondary-600">Type</p>
                    <p class="text-lg font-semibold text-gray-900">@Model.SubmissionType</p>
                </div>
                <div class="border rounded-lg p-4">
                    <p class="text-sm text-secondary-600">Status</p>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                        @Model.ApprovalStatus
                    </span>
                </div>
            </div>
        </div>

        <!-- Upload Section -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-semibold text-secondary-800 flex items-center">
                    <i class="material-icons mr-2">cloud_upload</i>
                    Upload Results
                </h2>
                <div class="flex space-x-2">
                    <button onclick="downloadTemplate()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 flex items-center">
                        <i class="material-icons mr-2">download</i>Download Template
                    </button>
                </div>
            </div>

            <!-- Upload Form -->
            <form id="uploadForm" asp-controller="ResultSubmission" asp-action="UploadResults" method="post" enctype="multipart/form-data">
                <input type="hidden" name="batchId" value="@Model.Id" />
                @Html.AntiForgeryToken()

                <!-- File Upload Area -->
                <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-blue-500 transition-colors">
                    <input type="file" id="fileInput" name="file" accept=".xlsx,.xls,.csv" class="hidden" onchange="handleFileSelect(this)" />
                    <label for="fileInput" class="cursor-pointer">
                        <i class="material-icons text-6xl text-gray-400 mb-4">cloud_upload</i>
                        <p class="text-lg font-medium text-gray-700 mb-2">Click to upload or drag and drop</p>
                        <p class="text-sm text-gray-500">Excel (.xlsx, .xls) or CSV (.csv) files only</p>
                        <p class="text-xs text-gray-400 mt-2">Maximum file size: 10MB</p>
                    </label>
                </div>

                <!-- Selected File Display -->
                <div id="selectedFile" class="hidden mt-4 p-4 bg-blue-50 border border-blue-200 rounded-lg">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <i class="material-icons text-blue-600 mr-3">description</i>
                            <div>
                                <p class="font-medium text-gray-900" id="fileName"></p>
                                <p class="text-sm text-secondary-600" id="fileSize"></p>
                            </div>
                        </div>
                        <button type="button" onclick="clearFile()" class="text-red-600 hover:text-red-800">
                            <i class="material-icons">close</i>
                        </button>
                    </div>
                </div>

                <!-- Manual Entry Option -->
                <div class="mt-6">
                    <button type="button" onclick="toggleManualEntry()" class="text-blue-600 hover:text-blue-800 font-medium flex items-center">
                        <i class="material-icons mr-1">edit</i>
                        Or enter results manually
                    </button>
                </div>

                <!-- Upload Button -->
                <div class="mt-6 flex justify-end">
                    <button type="submit" id="uploadBtn" disabled class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed flex items-center">
                        <i class="material-icons mr-2">cloud_upload</i>
                        Upload Results
                    </button>
                </div>
            </form>
        </div>

        <!-- Uploaded Results Preview -->
        @if (Model.TotalRecords > 0)
        {
            <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                <h2 class="text-xl font-semibold text-secondary-800 mb-4 flex items-center">
                    <i class="material-icons mr-2">preview</i>
                    Uploaded Results Preview
                </h2>
                <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
                    <div class="flex items-center">
                        <i class="material-icons text-green-600 mr-3">check_circle</i>
                        <div>
                            <p class="font-medium text-green-800">@Model.TotalRecords results uploaded successfully</p>
                            <p class="text-sm text-green-700">Review the results below before submitting for approval</p>
                        </div>
                    </div>
                </div>

                <!-- Results Table -->
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">#</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Student ID</th>
                                @if (Model.SubmissionType == "AssessmentScores")
                                {
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Score</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Weight %</th>
                                }
                                else
                                {
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Total Score</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Grade</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                                }
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <!-- Results will be loaded dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Submit for Approval Section -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-semibold text-secondary-800 mb-4 flex items-center">
                    <i class="material-icons mr-2">send</i>
                    Submit for Approval
                </h2>

                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
                    <div class="flex items-start">
                        <i class="material-icons text-blue-600 mr-3 mt-1">info</i>
                        <div>
                            <p class="font-medium text-blue-800 mb-2">Before submitting, please ensure:</p>
                            <ul class="text-sm text-blue-700 space-y-1 list-disc list-inside">
                                <li>All results have been uploaded and verified</li>
                                <li>Student IDs and scores are accurate</li>
                                <li>No duplicate entries exist</li>
                                <li>Results match your records</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <form asp-controller="ResultSubmission" asp-action="SubmitForApproval" method="post">
                    <input type="hidden" name="batchId" value="@Model.Id" />
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Additional Comments (Optional)</label>
                        <textarea name="comments" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" placeholder="Add any notes or comments for approvers..."></textarea>
                    </div>

                    <div class="flex justify-end space-x-3">
                        <button type="button" onclick="saveDraft()" class="px-6 py-3 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 flex items-center">
                            <i class="material-icons mr-2">save</i>
                            Save as Draft
                        </button>
                        <button type="submit" class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 flex items-center">
                            <i class="material-icons mr-2">send</i>
                            Submit for Approval
                        </button>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function handleFileSelect(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                const fileSize = (file.size / 1024 / 1024).toFixed(2);

                document.getElementById('fileName').textContent = file.name;
                document.getElementById('fileSize').textContent = fileSize + ' MB';
                document.getElementById('selectedFile').classList.remove('hidden');
                document.getElementById('uploadBtn').disabled = false;

                // Update progress
                updateProgress(2);
            }
        }

        function clearFile() {
            document.getElementById('fileInput').value = '';
            document.getElementById('selectedFile').classList.add('hidden');
            document.getElementById('uploadBtn').disabled = true;
        }

        function updateProgress(step) {
            const steps = ['step2', 'step3'];
            steps.forEach((s, index) => {
                const stepEl = document.getElementById(s);
                if (index < step - 1) {
                    stepEl.querySelector('div').classList.remove('text-gray-400');
                    stepEl.querySelector('div').classList.add('text-blue-600');
                    stepEl.querySelector('.rounded-full').classList.remove('bg-gray-300');
                    stepEl.querySelector('.rounded-full').classList.add('bg-blue-600');
                    stepEl.previousElementSibling.querySelector('.border-t-2').classList.remove('border-gray-300');
                    stepEl.previousElementSibling.querySelector('.border-t-2').classList.add('border-blue-600');
                }
            });
        }

        function downloadTemplate() {
            const submissionType = '@Model.SubmissionType';
            const templateUrl = submissionType === 'AssessmentScores'
                ? '@Url.Action("DownloadAssessmentTemplate", "ResultSubmission")'
                : '@Url.Action("DownloadCourseResultTemplate", "ResultSubmission")';
            window.location.href = templateUrl;
        }

        function toggleManualEntry() {
            window.location.href = '@Url.Action("ManualEntry", "ResultSubmission", new { batchId = Model.Id })';
        }

        function saveDraft() {
            if (confirm('Save current progress as draft? You can continue editing later.')) {
                // Implement save draft logic
                alert('Draft saved successfully!');
            }
        }

        // Drag and drop functionality
        const uploadArea = document.querySelector('.border-dashed');

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            uploadArea.addEventListener(eventName, preventDefaults, false);
        });

        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }

        ['dragenter', 'dragover'].forEach(eventName => {
            uploadArea.addEventListener(eventName, () => {
                uploadArea.classList.add('border-blue-500', 'bg-blue-50');
            }, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            uploadArea.addEventListener(eventName, () => {
                uploadArea.classList.remove('border-blue-500', 'bg-blue-50');
            }, false);
        });

        uploadArea.addEventListener('drop', (e) => {
            const dt = e.dataTransfer;
            const files = dt.files;
            document.getElementById('fileInput').files = files;
            handleFileSelect(document.getElementById('fileInput'));
        });
    </script>
}