@section Scripts {
    <script>
        // Approve Modal Functions
        function showApproveModal(workflowId, entityName) {
            document.getElementById('approveWorkflowId').value = workflowId;
            document.getElementById('approveEntityName').textContent = entityName;
            document.getElementById('approveConfirm').checked = false;
            document.getElementById('approveModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hideApproveModal() {
            document.getElementById('approveModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function submitApprove() {
            const checkbox = document.getElementById('approveConfirm');
            if (!checkbox.checked) {
                window.showAppToast('Please confirm that you have reviewed the submission before approving.');
                return;
            }
            document.getElementById('approveForm').submit();
        }

        // Reject Modal Functions
        function showRejectModal(workflowId, entityName) {
            document.getElementById('rejectWorkflowId').value = workflowId;
            document.getElementById('rejectEntityName').textContent = entityName;
            document.getElementById('rejectComments').value = '';
            document.getElementById('rejectCharCount').textContent = '0';
            document.getElementById('rejectModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hideRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function submitReject() {
            const form = document.getElementById('rejectForm');
            const comments = form.querySelector('[name="comments"]').value;

            if (comments.length < 20) {
                window.showAppToast('Please provide a detailed reason for rejection (at least 20 characters)');
                return;
            }

            window.showAppConfirm('Are you sure you want to reject this submission? This action cannot be undone.', { title: 'Reject Submission', icon: 'warning', confirmButtonText: 'Reject' }).then(confirmed => {
                if (confirmed) form.submit();
            });
        }

        function addRejectionReason(reason) {
            const textarea = document.getElementById('rejectComments');
            if (textarea.value) {
                textarea.value += '\n• ' + reason;
            } else {
                textarea.value = '• ' + reason;
            }
            updateCharCount();
        }

        // Character counter for rejection comments
        document.addEventListener('DOMContentLoaded', function() {
            const rejectComments = document.getElementById('rejectComments');
            if (rejectComments) {
                rejectComments.addEventListener('input', updateCharCount);
            }
        });

        function updateCharCount() {
            const textarea = document.getElementById('rejectComments');
            const counter = document.getElementById('rejectCharCount');
            if (textarea && counter) {
                counter.textContent = textarea.value.length;
                if (textarea.value.length >= 20) {
                    counter.classList.remove('text-red-500');
                    counter.classList.add('text-green-500');
                } else {
                    counter.classList.remove('text-green-500');
                    counter.classList.add('text-red-500');
                }
            }
        }

        // Return for Revision Modal Functions
        function showReturnModal(workflowId, entityName) {
            document.getElementById('returnWorkflowId').value = workflowId;
            document.getElementById('returnEntityName').textContent = entityName;
            document.getElementById('returnModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hideReturnModal() {
            document.getElementById('returnModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function submitReturn() {
            const form = document.getElementById('returnForm');
            const comments = form.querySelector('[name="comments"]').value;

            if (comments.length < 10) {
                window.showAppToast('Please provide detailed information about required changes (at least 10 characters)');
                return;
            }

            form.submit();
        }

        // Delegate Modal Functions
        function showDelegateModal(workflowId) {
            document.getElementById('delegateWorkflowId').value = workflowId;
            document.getElementById('delegateModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hideDelegateModal() {
            document.getElementById('delegateModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function submitDelegate() {
            const form = document.getElementById('delegateForm');
            if (form.checkValidity()) {
                form.submit();
            } else {
                window.showAppToast('Please fill in all required fields');
            }
        }

        // Cancel Modal Functions
        function showCancelModal(workflowId) {
            document.getElementById('cancelModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hideCancelModal() {
            document.getElementById('cancelModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function submitCancel() {
            const form = document.getElementById('cancelForm');
            const reason = form.querySelector('[name="reason"]').value;
            if (reason.length < 10) {
                window.showAppToast('Please provide a detailed reason (at least 10 characters)');
                return;
            }
            window.showAppConfirm('Are you absolutely sure? This action cannot be undone.', { title: 'Confirm Action', icon: 'warning', confirmButtonText: 'Confirm' }).then(confirmed => {
                if (confirmed) form.submit();
            });
        }

        // Results Table Functions
        function filterResults() {
            const searchText = document.getElementById('searchResults').value.toLowerCase();
            const filterStatus = document.getElementById('filterStatus').value;
            const rows = document.querySelectorAll('.result-row');
            let visibleCount = 0;

            rows.forEach(row => {
                const studentData = row.getAttribute('data-student');
                const status = row.getAttribute('data-status');
                const hasIntegrity = row.getAttribute('data-integrity') === 'true';

                let showRow = true;

                // Search filter
                if (searchText && !studentData.includes(searchText)) {
                    showRow = false;
                }

                // Status filter
                if (filterStatus !== 'all') {
                    if (filterStatus === 'pass' && status !== 'pass') showRow = false;
                    if (filterStatus === 'fail' && status !== 'fail') showRow = false;
                    if (filterStatus === 'integrity' && !hasIntegrity) showRow = false;
                }

                row.style.display = showRow ? '' : 'none';
                if (showRow) visibleCount++;
            });

            document.getElementById('resultsCount').textContent =
                `Showing ${visibleCount} of @Model.SubmittedResults.Count results`;
        }

        function sortTable(columnIndex) {
            const table = document.getElementById('resultsTable');
            const tbody = table.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            const isNumeric = columnIndex === 0 || columnIndex === 4;

            rows.sort((a, b) => {
                const aValue = a.cells[columnIndex].textContent.trim();
                const bValue = b.cells[columnIndex].textContent.trim();

                if (isNumeric) {
                    const aNum = parseFloat(aValue.replace('%', ''));
                    const bNum = parseFloat(bValue.replace('%', ''));
                    return aNum - bNum;
                } else {
                    return aValue.localeCompare(bValue);
                }
            });

            rows.forEach(row => tbody.appendChild(row));
        }

        function toggleResultsView() {
            const container = document.getElementById('resultsTableContainer');
            const button = document.getElementById('toggleText');

            if (container.classList.contains('max-h-96')) {
                container.classList.remove('max-h-96', 'overflow-y-auto');
                button.textContent = 'Collapse';
            } else {
                container.classList.add('max-h-96', 'overflow-y-auto');
                button.textContent = 'Expand All';
            }
        }

        function exportResults() {
            // Create CSV content
            let csv = 'Row,Student Number,Full Name,Scores Recorded,Total,Grade,Status,Integrity Issue\n';

            const rows = document.querySelectorAll('.result-row');
            rows.forEach(row => {
                if (row.style.display !== 'none') {
                    const cells = row.querySelectorAll('td');
                    const rowData = [
                        cells[0].textContent.trim(),
                        cells[1].textContent.trim(),
                        cells[2].textContent.trim(),
                        cells[3].textContent.trim(),
                        cells[4].textContent.trim(),
                        cells[5].textContent.trim(),
                        cells[6].textContent.trim().split('\n')[0],
                        row.getAttribute('data-integrity') === 'true' ? 'Yes' : 'No'
                    ];
                    csv += rowData.join(',') + '\n';
                }
            });

            // Download CSV
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.setAttribute('hidden', '');
            a.setAttribute('href', url);
            a.setAttribute('download', 'workflow_@Model.WorkflowInstance.Id' + '_results.csv');
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        // Close modal when clicking outside
        document.getElementById('cancelModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                hideCancelModal();
            }
        });

        // Handle Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && !document.getElementById('cancelModal').classList.contains('hidden')) {
                hideCancelModal();
            }
        });

        // Initialize default view (collapsed if more than 20 rows)
        document.addEventListener('DOMContentLoaded', function() {
            const resultsCount = @Model.SubmittedResults.Count;
            if (resultsCount > 20) {
                document.getElementById('resultsTableContainer').classList.add('max-h-96', 'overflow-y-auto');
            }
        });
    </script>
}

@functions {
    string GetStatusBannerClass(WorkflowStatus status)
    {
        return status switch
        {
            WorkflowStatus.Approved => "bg-green-50 border border-green-200 text-green-800",
            WorkflowStatus.Rejected => "bg-red-50 border border-red-200 text-red-800",
            WorkflowStatus.Cancelled => "bg-gray-50 border border-gray-200 text-secondary-800",
            WorkflowStatus.InProgress => "bg-blue-50 border border-blue-200 text-blue-800",
            _ => "bg-yellow-50 border border-yellow-200 text-yellow-800"
        };
    }

    string GetStatusIcon(WorkflowStatus status)
    {
        return status switch
        {
            WorkflowStatus.Approved => "check_circle",
            WorkflowStatus.Rejected => "cancel",
            WorkflowStatus.Cancelled => "block",
            WorkflowStatus.InProgress => "pending",
            _ => "schedule"
        };
    }

    string GetTimelineMarkerClass(bool isCompleted, bool isActive)
    {
        if (isCompleted) return "bg-green-500 text-white";
        if (isActive) return "bg-blue-500 text-white animate-pulse";
        return "bg-gray-300 text-secondary-600";
    }

    string GetApprovalActionIcon(ApprovalAction action)
    {
        return action switch
        {
            ApprovalAction.Approved => "check",
            ApprovalAction.Rejected => "close",
            ApprovalAction.Returned => "undo",
            _ => "pending"
        };
    }

    string GetActionBadgeClass(ApprovalAction action)
    {
        return action switch
        {
            ApprovalAction.Approved => "bg-green-100 text-green-800",
            ApprovalAction.Rejected => "bg-red-100 text-red-800",
            ApprovalAction.Returned => "bg-amber-100 text-amber-800",
            _ => "bg-gray-100 text-secondary-800"
        };
    }
}
