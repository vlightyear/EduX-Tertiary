@model List<WorkflowInstanceDto>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-gray-800 flex items-center">
            <i class="material-icons mr-2">history</i>
            Approval History
        </h1>
        <div class="flex space-x-2">
            <button onclick="exportHistory()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 flex items-center">
                <i class="material-icons mr-2">download</i>Export
            </button>
            <button onclick="location.href='@Url.Action("PendingApprovals", "Workflow")'" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center">
                <i class="material-icons mr-2">pending_actions</i>Pending
            </button>
        </div>
    </div>

    <!-- Filters Section -->
    <div class="bg-white rounded-lg shadow-md p-4 mb-4">
        <div class="flex items-center space-x-4">
            <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">Date Range</label>
                <input type="date" id="startDate" class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full" />
            </div>
            <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">To</label>
                <input type="date" id="endDate" class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full" />
            </div>
            <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                <select id="statusFilter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full">
                    <option value="">All Statuses</option>
                    <option value="Approved">Approved</option>
                    <option value="Rejected">Rejected</option>
                    <option value="Cancelled">Cancelled</option>
                    <option value="InProgress">In Progress</option>
                </select>
            </div>
            <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">Entity Type</label>
                <select id="entityFilter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full">
                    <option value="">All Types</option>
                    <option value="ResultSubmissionBatch">Result Submissions</option>
                    <option value="CourseModification">Course Modifications</option>
                </select>
            </div>
            <div class="pt-6">
                <button onclick="applyFilters()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center">
                    <i class="material-icons mr-1">filter_list</i>Apply
                </button>
            </div>
        </div>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-240px)]">
        <!-- History List (70% width) -->
        <div class="w-[70%]">
            <div class="bg-white rounded-lg shadow-md h-full overflow-auto">
                <div class="p-4">
                    @if (!Model.Any())
                    {
                        <div class="flex flex-col items-center justify-center py-12">
                            <i class="material-icons text-gray-300 text-6xl mb-4">history</i>
                            <h3 class="text-xl font-semibold text-gray-700 mb-2">No History Found</h3>
                            <p class="text-gray-500">There are no approval records matching your criteria.</p>
                        </div>
                    }
                    else
                    {
                        <table id="historyTable" class="w-full text-sm text-gray-600">
                            <thead>
                                <tr>
                                    <th class="px-4 py-3 text-left">
                                        <span class="flex items-center">
                                            ID
                                            <svg class="w-4 h-4 ms-1" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                            </svg>
                                        </span>
                                    </th>
                                    <th class="px-4 py-3 text-left">Entity Type</th>
                                    <th class="px-4 py-3 text-left">Template</th>
                                    <th class="px-4 py-3 text-left">Initiated By</th>
                                    <th class="px-4 py-3 text-left">Status</th>
                                    <th class="px-4 py-3 text-left">Duration</th>
                                    <th class="px-4 py-3 text-left">Completed</th>
                                    <th class="px-4 py-3 text-left">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var workflow in Model.OrderByDescending(w => w.StartedAt))
                                {
                                    <tr class="border-b hover:bg-gray-50 transition-colors">
                                        <td class="px-4 py-3 font-medium">#@workflow.Id</td>
                                        <td class="px-4 py-3">
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                                                @workflow.EntityType
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-gray-900">@workflow.TemplateName</td>
                                        <td class="px-4 py-3">@workflow.InitiatedByName</td>
                                        <td class="px-4 py-3">
                                            @switch (workflow.Status)
                                            {
                                                case WorkflowStatus.Approved:
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                        <i class="material-icons text-xs mr-1">check_circle</i> Approved
                                                    </span>
                                                    break;
                                                case WorkflowStatus.Rejected:
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                        <i class="material-icons text-xs mr-1">cancel</i> Rejected
                                                    </span>
                                                    break;
                                                case WorkflowStatus.Cancelled:
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                                        <i class="material-icons text-xs mr-1">block</i> Cancelled
                                                    </span>
                                                    break;
                                                case WorkflowStatus.InProgress:
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                                        <i class="material-icons text-xs mr-1">pending</i> In Progress
                                                    </span>
                                                    break;
                                                default:
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                                        <i class="material-icons text-xs mr-1">schedule</i> Pending
                                                    </span>
                                                    break;
                                            }
                                        </td>
                                        <td class="px-4 py-3">
                                            @if (workflow.CompletedAt.HasValue)
                                            {
                                                var duration = (workflow.CompletedAt.Value - workflow.StartedAt).TotalDays;
                                                <span class="text-gray-600">@duration.ToString("0.0") days</span>
                                            }
                                            else
                                            {
                                                var elapsed = (DateTime.Now - workflow.StartedAt).TotalDays;
                                                <span class="text-blue-600">@elapsed.ToString("0.0") days (ongoing)</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3">
                                            @if (workflow.CompletedAt.HasValue)
                                            {
                                                @workflow.CompletedAt.Value.ToString("MMM dd, yyyy")
                                            }
                                            else
                                            {
                                                <span class="text-gray-400">-</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3">
                                            <button onclick="viewWorkflowDetails(@workflow.Id)" class="inline-flex items-center px-3 py-1 text-sm text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg">
                                                <i class="material-icons text-sm mr-1">visibility</i> View
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (30% width) -->
        <div class="w-[30%] space-y-4">
            <!-- Overview Stats -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Overview</h3>
                <div class="space-y-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">history</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Workflows</p>
                            <p class="text-2xl font-semibold">@Model.Count()</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">check_circle</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Approved</p>
                            <p class="text-2xl font-semibold text-green-600">@Model.Count(w => w.Status == WorkflowStatus.Approved)</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="p-3 bg-red-100 rounded-lg">
                            <i class="material-icons text-red-600 text-xl">cancel</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Rejected</p>
                            <p class="text-2xl font-semibold text-red-600">@Model.Count(w => w.Status == WorkflowStatus.Rejected)</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="p-3 bg-yellow-100 rounded-lg">
                            <i class="material-icons text-yellow-600 text-xl">schedule</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Avg. Duration</p>
                            <p class="text-2xl font-semibold text-yellow-600">
                                @{
                                    var completed = Model.Where(w => w.CompletedAt.HasValue).ToList();
                                    var avgDuration = completed.Any() 
                                        ? completed.Average(w => (w.CompletedAt.Value - w.StartedAt).TotalDays)
                                        : 0;
                                }
                                @avgDuration.ToString("0.0") days
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status Distribution -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Status Distribution</h3>
                <div id="statusChart" class="min-h-64"></div>
            </div>

            <!-- Monthly Trend -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Monthly Trend</h3>
                <div id="trendChart" class="min-h-48"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize DataTable
            if (document.getElementById('historyTable')) {
                const dataTable = new simpleDatatables.DataTable("#historyTable", {
                    perPage: 10,
                    searchable: true,
                    sortable: true,
                    labels: {
                        placeholder: "Search history...",
                        perPage: "Show {select} entries",
                        noRows: "No history found",
                        info: "Showing {start} to {end} of {rows} entries",
                    }
                });
            }

            // Status Distribution Chart
            const statusChart = new ApexCharts(document.querySelector("#statusChart"), {
                series: [
                    @Model.Count(w => w.Status == WorkflowStatus.Approved),
                    @Model.Count(w => w.Status == WorkflowStatus.Rejected),
                    @Model.Count(w => w.Status == WorkflowStatus.InProgress),
                    @Model.Count(w => w.Status == WorkflowStatus.Cancelled)
                ],
                chart: { type: 'donut', height: 250 },
                labels: ['Approved', 'Rejected', 'In Progress', 'Cancelled'],
                colors: ['#10B981', '#EF4444', '#3B82F6', '#6B7280'],
                legend: { position: 'bottom' },
                dataLabels: {
                    enabled: true,
                    formatter: function(val, opts) {
                        return opts.w.globals.series[opts.seriesIndex];
                    }
                }
            });
            statusChart.render();

            // Monthly Trend Chart
            var monthlyData = @Html.Raw(Json.Serialize(
                Model.Where(w => w.CompletedAt.HasValue)
                     .GroupBy(w => new { w.CompletedAt.Value.Year, w.CompletedAt.Value.Month })
                     .OrderBy(g => g.Key.Year).ThenBy(g => g.Key.Month)
                     .Take(6)
                     .Select(g => new { 
                         month = $"{g.Key.Year}-{g.Key.Month:00}", 
                         count = g.Count() 
                     })
            ));

            const trendChart = new ApexCharts(document.querySelector("#trendChart"), {
                series: [{
                    name: 'Completed Workflows',
                    data: monthlyData.map(d => d.count)
                }],
                chart: { type: 'area', height: 200, sparkline: { enabled: true } },
                stroke: { curve: 'smooth', width: 2 },
                fill: { opacity: 0.3 },
                colors: ['#3B82F6'],
                xaxis: { categories: monthlyData.map(d => d.month) }
            });
            trendChart.render();
        });

        function viewWorkflowDetails(workflowId) {
            location.href = '@Url.Action("WorkflowDetails", "Workflow")?id=' + workflowId;
        }

        function applyFilters() {
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;
            const status = document.getElementById('statusFilter').value;
            const entityType = document.getElementById('entityFilter').value;
            
            let url = '@Url.Action("ApprovalHistory", "Workflow")?';
            if (startDate) url += `startDate=${startDate}&`;
            if (endDate) url += `endDate=${endDate}&`;
            if (status) url += `status=${status}&`;
            if (entityType) url += `entityType=${entityType}&`;
            
            location.href = url;
        }

        function exportHistory() {
            location.href = '@Url.Action("ExportHistory", "Workflow")';
        }
    </script>
}