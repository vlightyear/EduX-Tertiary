@{
    ViewData["Title"] = "Executive Dashboard";
}

<div class="p-6 space-y-6 bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-4">
            <div class="bg-gradient-to-r from-blue-600 to-purple-600 p-4 rounded-2xl shadow-lg">
                <i class="material-icons text-white text-3xl">analytics</i>
            </div>
            <div>
                <h1 class="text-3xl font-bold bg-gradient-to-r from-slate-800 to-slate-600 bg-clip-text text-transparent">
                    Executive Dashboard
                </h1>
                <p class="text-slate-600 text-lg">Strategic Overview & Performance Metrics</p>
            </div>
        </div>
        <div class="text-right bg-white/70 backdrop-blur-sm rounded-xl p-4 shadow-md">
            <p class="text-sm text-slate-500">Last Updated</p>
            <p class="font-semibold text-slate-800">@DateTime.Now.ToString("MMM dd, yyyy HH:mm")</p>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total Students Card -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
            <div class="flex flex-col items-center text-center">
                <div class="bg-gradient-to-r from-blue-500 to-blue-600 p-4 rounded-2xl mb-4 shadow-lg">
                    <i class="material-icons text-white text-3xl">school</i>
                </div>
                <h3 class="text-slate-600 font-medium mb-2">Active Students</h3>
                <span class="text-4xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">@ViewBag.ActiveStudents.ToString("N0")</span>
                <p class="text-xs text-slate-500 mt-1">Registered & Active</p>
            </div>
        </div>

        <!-- Total Revenue Card -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
            <div class="flex flex-col items-center text-center">
                <div class="bg-gradient-to-r from-green-500 to-emerald-600 p-4 rounded-2xl mb-4 shadow-lg">
                    <i class="material-icons text-white text-3xl">account_balance</i>
                </div>
                <h3 class="text-slate-600 font-medium mb-2">Total Revenue</h3>
                <span class="text-4xl font-bold bg-gradient-to-r from-green-600 to-emerald-600 bg-clip-text text-transparent">K @ViewBag.TotalRevenue.ToString("N0")</span>
            </div>
        </div>

        <!-- Outstanding Fees Card -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
            <div class="flex flex-col items-center text-center">
                <div class="bg-gradient-to-r from-amber-500 to-orange-600 p-4 rounded-2xl mb-4 shadow-lg">
                    <i class="material-icons text-white text-3xl">pending_actions</i>
                </div>
                <h3 class="text-slate-600 font-medium mb-2">Outstanding Fees</h3>
                <span class="text-4xl font-bold bg-gradient-to-r from-amber-600 to-orange-600 bg-clip-text text-transparent">K @ViewBag.OutstandingFees.ToString("N0")</span>
            </div>
        </div>

        <!-- New Admissions Card -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
            <div class="flex flex-col items-center text-center">
                <div class="bg-gradient-to-r from-purple-500 to-pink-600 p-4 rounded-2xl mb-4 shadow-lg">
                    <i class="material-icons text-white text-3xl">person_add</i>
                </div>
                <h3 class="text-slate-600 font-medium mb-2">New Admissions (YTD)</h3>
                <span class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">@ViewBag.NewAdmissions.ToString("N0")</span>
                <p class="text-xs text-slate-500 mt-1">Recently Admitted</p>
            </div>
        </div>
    </div>

    <!-- Performance Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <!-- Collection Rate -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="bg-green-100 p-2 rounded-lg">
                        <i class="material-icons text-green-600">trending_up</i>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-slate-800">Collection Rate</h3>
                        <p class="text-xs text-slate-500">Revenue ÷ (Revenue + Outstanding)</p>
                    </div>
                </div>
                <span class="text-2xl font-bold text-green-600">@ViewBag.CollectionRate%</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3">
                <div class="bg-gradient-to-r from-green-400 to-green-600 h-3 rounded-full shadow-sm" style="width: @(Math.Min(ViewBag.CollectionRate, 100))%"></div>
            </div>
            <div class="mt-2 text-xs text-slate-600">
                <div class="flex justify-between">
                    <span>Collected: K @ViewBag.TotalRevenue.ToString("N0")</span>
                    <span>Outstanding: K @ViewBag.OutstandingFees.ToString("N0")</span>
                </div>
            </div>
        </div>

        <!-- Registration Rate -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="bg-blue-100 p-2 rounded-lg">
                        <i class="material-icons text-blue-600">how_to_reg</i>
                    </div>
                    <h3 class="text-lg font-semibold text-slate-800">Registration Completion Rate</h3>
                </div>
                <span class="text-2xl font-bold text-blue-600">@ViewBag.RegistrationRate%</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3">
                <div class="bg-gradient-to-r from-blue-400 to-blue-600 h-3 rounded-full shadow-sm" style="width: @(Math.Min(ViewBag.RegistrationRate, 100))%"></div>
            </div>
            <p class="text-xs text-slate-600 mt-1">Students who completed registration process</p>
            @if (ViewBag.RegistrationRate > 100)
            {
                <p class="text-xs text-blue-700 mt-1">Exceeded target by @((ViewBag.RegistrationRate - 100).ToString("F1"))%</p>
            }
        </div>
    </div>

    <!-- Charts Section -->
    <div class="grid lg:grid-cols-3 gap-6">
        <!-- Revenue Trends Chart -->
        <div class="lg:col-span-2 bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
            <div class="flex items-center gap-3 mb-6">
                <div class="bg-blue-100 p-2 rounded-lg">
                    <i class="material-icons text-blue-600">show_chart</i>
                </div>
                <h2 class="text-xl font-bold text-slate-800">Revenue Trends (12 Months)</h2>
            </div>
            <div id="revenueChart" class="w-full h-[350px]"></div>
        </div>

        <!-- Payment Methods Distribution -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
            <div class="flex items-center gap-3 mb-6">
                <div class="bg-purple-100 p-2 rounded-lg">
                    <i class="material-icons text-purple-600">pie_chart</i>
                </div>
                <h2 class="text-xl font-bold text-slate-800">Payment Methods</h2>
            </div>
            <div id="paymentMethodsChart" class="w-full h-[300px]"></div>
        </div>
    </div>

    <!-- School Performance Chart -->
    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
        <div class="flex items-center gap-3 mb-6">
            <div class="bg-green-100 p-2 rounded-lg">
                <i class="material-icons text-green-600">bar_chart</i>
            </div>
            <h2 class="text-xl font-bold text-slate-800">School Performance (Revenue)</h2>
        </div>
        <div id="schoolPerformanceChart" class="w-full h-[400px]"></div>
    </div>

    <!-- Data Tables -->
    <div class="grid lg:grid-cols-2 gap-6">
        <!-- Recent High-Value Transactions -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
            <div class="flex items-center gap-3 mb-6">
                <div class="bg-emerald-100 p-2 rounded-lg">
                    <i class="material-icons text-emerald-600">receipt_long</i>
                </div>
                <h2 class="text-xl font-bold text-slate-800">Recent High-Value Transactions</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-slate-50 rounded-lg">
                        <tr>
                            <th class="py-3 px-4 text-left text-sm font-medium text-slate-600">Student</th>
                            <th class="py-3 px-4 text-left text-sm font-medium text-slate-600">Amount</th>
                            <th class="py-3 px-4 text-left text-sm font-medium text-slate-600">Method</th>
                            <th class="py-3 px-4 text-left text-sm font-medium text-slate-600">Date</th>
                        </tr>
                    </thead>
                    <tbody id="recentTransactionsTable" class="divide-y divide-slate-200">
                        <!-- Populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Students with Overdue Payments -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
            <div class="flex items-center gap-3 mb-6">
                <div class="bg-red-100 p-2 rounded-lg">
                    <i class="material-icons text-red-600">warning</i>
                </div>
                <h2 class="text-xl font-bold text-slate-800">Students with Outstanding Payments</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-slate-50 rounded-lg">
                        <tr>
                            <th class="py-3 px-4 text-left text-sm font-medium text-slate-600">Student</th>
                            <th class="py-3 px-4 text-left text-sm font-medium text-slate-600">Programme</th>
                            <th class="py-3 px-4 text-left text-sm font-medium text-slate-600">Outstanding</th>
                        </tr>
                    </thead>
                    <tbody id="overdueStudentsTable" class="divide-y divide-slate-200">
                        <!-- Populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Hidden data for JavaScript -->
<script type="application/json" id="monthLabels">@Html.Raw(ViewBag.MonthLabels)</script>
<script type="application/json" id="revenueAmounts">@Html.Raw(ViewBag.RevenueAmounts)</script>
<script type="application/json" id="schoolNames">@Html.Raw(ViewBag.SchoolNames)</script>
<script type="application/json" id="schoolRevenues">@Html.Raw(ViewBag.SchoolRevenues)</script>
<script type="application/json" id="paymentMethods">@Html.Raw(ViewBag.PaymentMethods)</script>
<script type="application/json" id="paymentAmounts">@Html.Raw(ViewBag.PaymentAmounts)</script>
<script type="application/json" id="recentTransactions">@Html.Raw(ViewBag.RecentTransactions)</script>
<script type="application/json" id="overdueStudents">@Html.Raw(ViewBag.OverdueStudents)</script>
<script src="~/js/vc_dashboard.js"></script>