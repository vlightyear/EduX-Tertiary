@{
    ViewData["Title"] = "Dashboard";
}

<div class="min-h-screen p-6 space-y-6" style="background-color: #f0f4f8;">

    <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="p-2 rounded-lg" style="background-color: #fef2f2;">
                <i class="material-icons text-2xl" style="color: #e85c5c;">dashboard</i>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-slate-800">Dashboard</h1>
                <p class="text-xs text-slate-400 mt-0.5">Overview of your institution</p>
            </div>
        </div>
        <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 bg-white rounded-lg border border-gray-100 shadow-sm text-xs text-slate-500">
            <i class="material-icons text-sm" style="color: #e85c5c;">schedule</i>
            <span id="dashboardClock"></span>
        </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

        <!-- Users -->
        <div onclick="location.href='@Url.Action("Users", "Admin")'"
             class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 cursor-pointer transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md group">
            <div class="flex items-start justify-between mb-4">
                <div class="p-2.5 rounded-lg" style="background-color: #fef2f2;">
                    <i class="material-icons text-xl" style="color: #e85c5c;">group</i>
                </div>
                <i class="material-icons text-sm text-gray-300 group-hover:text-gray-400 transition-colors">arrow_forward</i>
            </div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Users</p>
            <p class="text-3xl font-bold text-slate-800">@ViewBag.UserCount</p>
        </div>

        <!-- Schools -->
        <div onclick="location.href='@Url.Action("Schools", "Admin")'"
             class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 cursor-pointer transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md group">
            <div class="flex items-start justify-between mb-4">
                <div class="p-2.5 rounded-lg" style="background-color: #fef2f2;">
                    <i class="material-icons text-xl" style="color: #e85c5c;">account_balance</i>
                </div>
                <i class="material-icons text-sm text-gray-300 group-hover:text-gray-400 transition-colors">arrow_forward</i>
            </div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Schools</p>
            <p class="text-3xl font-bold text-slate-800">@ViewBag.SchoolCount</p>
        </div>

        <!-- Programmes -->
        <div onclick="location.href='@Url.Action("Programmes", "Admin")'"
             class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 cursor-pointer transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md group">
            <div class="flex items-start justify-between mb-4">
                <div class="p-2.5 rounded-lg" style="background-color: #fef2f2;">
                    <i class="material-icons text-xl" style="color: #e85c5c;">local_library</i>
                </div>
                <i class="material-icons text-sm text-gray-300 group-hover:text-gray-400 transition-colors">arrow_forward</i>
            </div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Programmes</p>
            <p class="text-3xl font-bold text-slate-800">@ViewBag.ProgrammeCount</p>
        </div>

        <!-- Departments -->
        <div onclick="location.href='@Url.Action("Departments", "Admin")'"
             class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 cursor-pointer transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md group">
            <div class="flex items-start justify-between mb-4">
                <div class="p-2.5 rounded-lg" style="background-color: #fef2f2;">
                    <i class="material-icons text-xl" style="color: #e85c5c;">corporate_fare</i>
                </div>
                <i class="material-icons text-sm text-gray-300 group-hover:text-gray-400 transition-colors">arrow_forward</i>
            </div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Departments</p>
            <p class="text-3xl font-bold text-slate-800">@ViewBag.DepartmentCount</p>
        </div>

    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

        <!-- Total Students -->
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 flex items-center gap-4">
            <div class="p-2.5 rounded-full shrink-0" style="background-color: #fef2f2;">
                <i class="material-icons" style="color: #e85c5c;">person</i>
            </div>
            <div>
                <p class="text-xs text-slate-500 mb-0.5">Total Students</p>
                <p class="text-2xl font-bold text-slate-800">@ViewBag.TotalStudents</p>
            </div>
        </div>

        <!-- New Admissions -->
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 flex items-center gap-4">
            <div class="p-2.5 rounded-full shrink-0" style="background-color: #fef2f2;">
                <i class="material-icons" style="color: #e85c5c;">person_add</i>
            </div>
            <div>
                <p class="text-xs text-slate-500 mb-0.5">New Admissions</p>
                <p class="text-2xl font-bold text-slate-800">@ViewBag.NewAdmissions</p>
            </div>
        </div>

        <!-- Registered Students -->
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 flex items-center gap-4">
            <div class="p-2.5 rounded-full shrink-0" style="background-color: #fef2f2;">
                <i class="material-icons" style="color: #e85c5c;">how_to_reg</i>
            </div>
            <div>
                <p class="text-xs text-slate-500 mb-0.5">Registered</p>
                <p class="text-2xl font-bold text-slate-800">@ViewBag.ActiveStudents</p>
            </div>
        </div>

        <!-- Graduated -->
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 flex items-center gap-4">
            <div class="p-2.5 rounded-full shrink-0" style="background-color: #fef2f2;">
                <i class="material-icons" style="color: #e85c5c;">school</i>
            </div>
            <div>
                <p class="text-xs text-slate-500 mb-0.5">Graduated</p>
                <p class="text-2xl font-bold text-slate-800">@ViewBag.GraduatedStudents</p>
            </div>
        </div>

    </div>

