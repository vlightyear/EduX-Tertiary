@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="p-6 space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-2">
        <i class="material-icons text-3xl text-slate-800">dashboard</i>
        <h1 class="text-2xl font-bold text-slate-800">Dashboard</h1>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Users Card -->
        <div onclick="location.href='@Url.Action("Users", "Admin")'"
             class="bg-white rounded-xl shadow-sm p-6 cursor-pointer transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <div class="flex flex-col items-center text-center">
                <div class="bg-blue-50 p-3 rounded-lg mb-4">
                    <i class="material-icons text-blue-600 text-3xl">group</i>
                </div>
                <h3 class="text-slate-600 font-medium mb-2">Users</h3>
                <span class="text-3xl font-bold text-slate-800">@ViewBag.UserCount</span>
            </div>
        </div>

        <!-- Schools Card -->
        <div onclick="location.href='@Url.Action("Schools", "Admin")'"
             class="bg-white rounded-xl shadow-sm p-6 cursor-pointer transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <div class="flex flex-col items-center text-center">
                <div class="bg-green-50 p-3 rounded-lg mb-4">
                    <i class="material-icons text-green-600 text-3xl">school</i>
                </div>
                <h3 class="text-slate-600 font-medium mb-2">Schools</h3>
                <span class="text-3xl font-bold text-slate-800">@ViewBag.SchoolCount</span>
            </div>
        </div>

        <!-- Programmes Card -->
        <div onclick="location.href='@Url.Action("Programmes", "Admin")'"
             class="bg-white rounded-xl shadow-sm p-6 cursor-pointer transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <div class="flex flex-col items-center text-center">
                <div class="bg-purple-50 p-3 rounded-lg mb-4">
                    <i class="material-icons text-purple-600 text-3xl">local_library</i>
                </div>
                <h3 class="text-slate-600 font-medium mb-2">Programmes</h3>
                <span class="text-3xl font-bold text-slate-800">@ViewBag.ProgrammeCount</span>
            </div>
        </div>

        <!-- Departments Card -->
        <div onclick="location.href='@Url.Action("Departments", "Admin")'"
             class="bg-white rounded-xl shadow-sm p-6 cursor-pointer transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <div class="flex flex-col items-center text-center">
                <div class="bg-amber-50 p-3 rounded-lg mb-4">
                    <i class="material-icons text-amber-600 text-3xl">account_balance</i>
                </div>
                <h3 class="text-slate-600 font-medium mb-2">Departments</h3>
                <span class="text-3xl font-bold text-slate-800">@ViewBag.DepartmentCount</span>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="grid lg:grid-cols-3 gap-6">
        <!-- Main Charts Container -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Bar Chart -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-lg font-semibold text-slate-800 mb-4">School Enrollment Statistics</h2>
                <div id="chart" class="w-full h-[400px]"></div>
            </div>
            <!-- Line Chart -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-lg font-semibold text-slate-800 mb-4">Grade Performance Trends</h2>
                <div id="chart2" class="w-full h-[370px]"></div>
            </div>
        </div>

        <!-- Side Stats -->
        <div class="space-y-6">
            <!-- Student Summary Card -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-lg font-semibold text-slate-800 mb-6">Student Summary Info</h2>
                <div class="space-y-4">
                    <!-- Total Students -->
                    <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-lg">
                        <div class="bg-blue-100 p-2 rounded-lg">
                            <i class="material-icons text-blue-600">person</i>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-slate-600">Total Students</p>
                            <p class="text-xl font-bold text-slate-800">@ViewBag.TotalStudents</p>
                        </div>
                    </div>

                    <!-- New Admissions -->
                    <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-lg">
                        <div class="bg-green-100 p-2 rounded-lg">
                            <i class="material-icons text-green-600">person_add</i>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-slate-600">New Admissions</p>
                            <p class="text-xl font-bold text-slate-800">@ViewBag.NewAdmissions</p>
                        </div>
                    </div>

                    <!-- Registered Students -->
                    <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-lg">
                        <div class="bg-emerald-100 p-2 rounded-lg">
                            <i class="material-icons text-emerald-600">how_to_reg</i>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-slate-600">Registered Students</p>
                            <p class="text-xl font-bold text-slate-800">@ViewBag.ActiveStudents</p>
                        </div>
                    </div>

                    <!-- Graduated Students -->
                    <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-lg">
                        <div class="bg-cyan-100 p-2 rounded-lg">
                            <i class="material-icons text-cyan-600">school</i>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-slate-600">Graduated Students</p>
                            <p class="text-xl font-bold text-slate-800">@ViewBag.GraduatedStudents</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Donut Chart -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <h2 class="text-lg font-semibold text-slate-800 mb-4">Student Distribution</h2>
                <div id="chart3" class="w-full min-h-[280px]"></div>
            </div>
        </div>
    </div>
</div>

<!-- Scripts with hidden data for charts -->
<script type="application/json" id="faculties">@Html.Raw(ViewBag.Faculties)</script>
<script type="application/json" id="enrolledStudents">@Html.Raw(ViewBag.EnrolledStudents)</script>
<script type="application/json" id="applicationsReceived">@Html.Raw(ViewBag.ApplicationsReceived)</script>
<script type="application/json" id="admittedStudents">@Html.Raw(ViewBag.AdmittedStudents)</script>
<script type="application/json" id="months">@Html.Raw(ViewBag.Months)</script>
<script type="application/json" id="highGrades">@Html.Raw(ViewBag.HighGrades)</script>
<script type="application/json" id="lowGrades">@Html.Raw(ViewBag.LowGrades)</script>
<script type="application/json" id="donutChartData">@Html.Raw(ViewBag.DonutChartData)</script>
<script src="~/js/admin_dashboard.js"></script>
