<script type="application/json" id="faculties">@Html.Raw(ViewBag.Faculties)</script>
<script type="application/json" id="enrolledStudents">@Html.Raw(ViewBag.EnrolledStudents)</script>
<script type="application/json" id="applicationsReceived">@Html.Raw(ViewBag.ApplicationsReceived)</script>
<script type="application/json" id="admittedStudents">@Html.Raw(ViewBag.AdmittedStudents)</script>
<script type="application/json" id="months">@Html.Raw(ViewBag.Months)</script>
<script type="application/json" id="highGrades">@Html.Raw(ViewBag.HighGrades)</script>
<script type="application/json" id="lowGrades">@Html.Raw(ViewBag.LowGrades)</script>
<script type="application/json" id="donutChartData">@Html.Raw(ViewBag.DonutChartData)</script>
<script src="~/js/admin_dashboard.js"></script>

<script>
    // Live clock in header
    (function tick() {
        const el = document.getElementById('dashboardClock');
        if (el) {
            el.textContent = new Date().toLocaleString('en-GB', {
                weekday: 'short', day: '2-digit', month: 'short',
                hour: '2-digit', minute: '2-digit'
            });
        }
        setTimeout(tick, 1000);
    })();
</script>
