@* @model SIS.Models.Lecturer *@

<div class="row m-1" style="height: 88vh;">
    <!-- Main Content Area -->
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center" style="height: 8vh;">
            <h3 class="pt-2">
                <i class="material-icons">dashboard</i>
                Lecturer Dashboard
            </h3>
            <div class="d-flex align-items-center">
                <span class="badge bg-dark me-2">2023/2024 - Semester 2</span>
                <span class="badge bg-success">Active Courses: 4</span>
            </div>
        </div>

        <!-- Quick Stats Row -->
        <div class="row g-3 mb-3">
            <!-- Assignments Pending -->
            <div class="col-md-3">
                <div class="card" style="background: linear-gradient(45deg, rgba(255,236,204,0.5), rgba(255,248,236,0.5)); border: none;">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle p-3 me-3" style="background-color: rgba(255, 159, 67, 0.2)">
                                <i class="material-icons" style="font-size: 2rem; color: #FF9F43;">assignment</i>
                            </div>
                            <div>
                                <p class="text-muted mb-1" style="font-size: 0.9rem;">Pending Assignments</p>
                                <h3 class="mb-0 fw-bold">24</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Graded Assignments -->
            <div class="col-md-3">
                <div class="card" style="background: linear-gradient(45deg, rgba(240,233,255,0.5), rgba(246,240,255,0.5)); border: none;">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle p-3 me-3" style="background-color: rgba(115, 103, 240, 0.2)">
                                <i class="material-icons" style="font-size: 2rem; color: #7367F0;">grading</i>
                            </div>
                            <div>
                                <p class="text-muted mb-1" style="font-size: 0.9rem;">Graded Assignments</p>
                                <h3 class="mb-0 fw-bold">18</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!-- Today's Classes -->
            <div class="col-md-3">
                <div class="card" style="background: linear-gradient(45deg, rgba(220,244,231,0.5), rgba(236,253,245,0.5)); border: none;">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle p-3 me-3" style="background-color: rgba(40, 199, 111, 0.2)">
                                <i class="material-icons" style="font-size: 2rem; color: #28C76F;">class</i>
                            </div>
                            <div>
                                <p class="text-muted mb-1" style="font-size: 0.9rem;">Today's Classes</p>
                                <h3 class="mb-0 fw-bold">3</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Office Hours Requests -->
            <div class="col-md-3">
                <div class="card" style="background: linear-gradient(45deg, rgba(221,234,255,0.5), rgba(236,242,255,0.5)); border: none;">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle p-3 me-3" style="background-color: rgba(0, 129, 255, 0.2)">
                                <i class="material-icons" style="font-size: 2rem; color: #0081FF;">event_available</i>
                            </div>
                            <div>
                                <p class="text-muted mb-1" style="font-size: 0.9rem;">Consultation Requests</p>
                                <h3 class="mb-0 fw-bold">5</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content Grid -->
        <div class="row g-3" style="height: calc(80vh - 180px);">
            <!-- Active Courses Section -->
            <div class="col-md-8">
                <div class="card h-100">
                    <div class="card-header bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="material-icons align-middle text-primary me-2">book</i>
                                Active Courses Overview
                            </h5>
                            <button class="btn btn-sm btn-outline-primary">View All Courses</button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="height: calc(100% - 20px);">
                            <table class="table table-hover">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Course Code</th>
                                        <th>Course Name</th>
                                        <th>Students</th>
                                        <th>Average</th>
                                        <th>Next Class</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>ICT3102</td>
                                        <td>Database Systems</td>
                                        <td>45</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="progress flex-grow-1" style="height: 6px;">
                                                    <div class="progress-bar bg-success" style="width: 75%"></div>
                                                </div>
                                                <span class="ms-2">75%</span>
                                            </div>
                                        </td>
                                        <td>Today 14:00</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1">Grade</button>
                                            <button class="btn btn-sm btn-outline-info">Resources</button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>ICT3103</td>
                                        <td>Web Development</td>
                                        <td>38</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="progress flex-grow-1" style="height: 6px;">
                                                    <div class="progress-bar bg-warning" style="width: 68%"></div>
                                                </div>
                                                <span class="ms-2">68%</span>
                                            </div>
                                        </td>
                                        <td>Tomorrow 10:00</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1">Grade</button>
                                            <button class="btn btn-sm btn-outline-info">Resources</button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>ICT3104</td>
                                        <td>Software Engineering</td>
                                        <td>42</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="progress flex-grow-1" style="height: 6px;">
                                                    <div class="progress-bar bg-success" style="width: 82%"></div>
                                                </div>
                                                <span class="ms-2">82%</span>
                                            </div>
                                        </td>
                                        <td>Wed 15:30</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1">Grade</button>
                                            <button class="btn btn-sm btn-outline-info">Resources</button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Upcoming Activities Section -->
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="material-icons align-middle text-warning me-2">event</i>
                            Upcoming Activities
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Database Systems Lecture</h6>
                                    <small class="text-danger">In 30 mins</small>
                                </div>
                                <p class="mb-1 text-muted small">Room 405, IT Building</p>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Department Meeting</h6>
                                    <small class="text-muted">Today 15:00</small>
                                </div>
                                <p class="mb-1 text-muted small">Conference Room</p>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Assignment Deadline</h6>
                                    <small class="text-warning">Tomorrow</small>
                                </div>
                                <p class="mb-1 text-muted small">ICT3103 - Project Milestone 2</p>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">Student Consultation</h6>
                                    <small class="text-muted">Tomorrow 14:00</small>
                                </div>
                                <p class="mb-1 text-muted small">John Smith - ICT3102</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    window.lecturerData = {
        hasActiveCourses: true
    };
</script>
<script type="module" src="~/js/lecturer_dashboard.js"></script>