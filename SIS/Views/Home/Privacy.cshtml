@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
        <!-- Header with Ecobank branding -->
        <div class="flex items-center justify-between mb-8 pb-6 border-b border-gray-200">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">@ViewData["Title"]</h1>
                <p class="mt-2 text-sm text-secondary-600">Last updated: February 2025</p>
            </div>
        </div>

        <!-- Main content -->
        <div class="bg-white shadow-sm rounded-xl p-8">
            <!-- Introduction -->
            <div class="prose max-w-none">
                <p class="text-lg text-gray-700 leading-relaxed mb-8">
                    Welcome to the eCampus Privacy Policy. We are committed to protecting your privacy and ensuring the security of your personal information. This policy outlines how we collect, use, and protect your data while using our eCampus platform.
                </p>

                <!-- Information Collection Section -->
                <section class="mb-8">
                    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Information We Collect</h2>
                    <div class="space-y-4">
                        <div class="flex items-start">
                            <div class="flex-shrink-0 h-6 w-6 text-[#0082bb] mt-0.5">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <p class="ml-3 text-secondary-600">Personal identification information (Name, email address, phone number, etc.)</p>
                        </div>
                        <div class="flex items-start">
                            <div class="flex-shrink-0 h-6 w-6 text-[#0082bb] mt-0.5">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <p class="ml-3 text-secondary-600">Academic records and performance data</p>
                        </div>
                        <div class="flex items-start">
                            <div class="flex-shrink-0 h-6 w-6 text-[#0082bb] mt-0.5">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <p class="ml-3 text-secondary-600">Financial information for payment processing</p>
                        </div>
                    </div>
                </section>

                <!-- Data Protection Section -->
                <section class="mb-8">
                    <h2 class="text-2xl font-semibold text-gray-900 mb-4">How We Protect Your Data</h2>
                    <div class="bg-blue-50 border-l-4 border-[#0082bb] p-4 rounded">
                        <div class="flex">
                            <div class="flex-shrink-0">
                                <svg class="h-5 w-5 text-[#0082bb]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-blue-800">
                                    We implement industry-standard security measures to protect your personal information. All data is encrypted and stored securely in compliance with relevant data protection regulations.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Third-Party Integration -->
                <section class="mb-8">
                    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Integration with Ecobank Services</h2>
                    <p class="text-secondary-600 mb-4">
                        Our eCampus platform integrates seamlessly with Ecobank's secure payment systems to process your financial transactions safely and efficiently.
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-gray-50 p-4 rounded-lg">
                            <h3 class="font-medium text-gray-900 mb-2">Secure Payments</h3>
                            <p class="text-sm text-secondary-600">All financial transactions are processed through Ecobank's secure payment gateway.</p>
                        </div>
                        <div class="bg-gray-50 p-4 rounded-lg">
                            <h3 class="font-medium text-gray-900 mb-2">Data Privacy</h3>
                            <p class="text-sm text-secondary-600">Your financial information is protected according to banking industry standards.</p>
                        </div>
                    </div>
                </section>
            </div>

            <!-- Contact Information -->
            <div class="mt-8 pt-8 border-t border-gray-200">
                <h2 class="text-2xl font-semibold text-gray-900 mb-4">Contact Us</h2>
                <p class="text-secondary-600">
                    If you have any questions about our privacy policy or how we handle your data, please contact us:
                </p>
                <div class="mt-4 flex items-center text-[#0082bb]">
                    <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <a href="mailto:privacy@ecampus.com" class="hover:underline">privacy@ecampus.com</a>
                </div>
            </div>
        </div>
    </div>
</div>