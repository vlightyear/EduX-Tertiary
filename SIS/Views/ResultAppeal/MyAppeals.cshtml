@{
    ViewData["Title"] = "My Result Appeals";
    var remarkFee = ViewBag.RemarkFee ?? 500.00m;
}

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap');

        :root {
            --coral: #e85c5c;
            --coral-d: #c94040;
            --navy: #1e2d5e;
            --navy-l: #2e3f7a;
            --mist: #f5f7fa;
            --border: #e8ecf2;
            --ink: #1a1f2e;
            --text: #475569;
        }

        .ra-wrap {
            font-family: 'DM Sans', sans-serif;
        }

        /* ── Hero ──────────────────────────────── */
        .ra-hero {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-l) 55%, #3a2060 100%);
            border-radius: 1.25rem;
            padding: 1.75rem 2rem 4rem;
            position: relative;
            overflow: hidden;
        }

            .ra-hero::before {
                content: '';
                position: absolute;
                top: -50px;
                right: -50px;
                width: 200px;
                height: 200px;
                background: rgba(232,92,92,.15);
                border-radius: 50%;
                pointer-events: none;
            }

            .ra-hero::after {
                content: '';
                position: absolute;
                bottom: -60px;
                left: 25%;
                width: 280px;
                height: 280px;
                background: rgba(255,255,255,.03);
                border-radius: 50%;
                pointer-events: none;
            }

        .hero-inner {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .hero-eyebrow {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: rgba(255,255,255,.5);
            margin-bottom: .35rem;
        }

        .hero-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.85rem;
            color: #fff;
            line-height: 1.2;
            margin-bottom: .3rem;
        }

        .hero-sub {
            font-size: .82rem;
            color: rgba(255,255,255,.55);
        }

        .btn-new-appeal {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            background: var(--coral);
            color: #fff;
            font-size: .82rem;
            font-weight: 700;
            padding: .65rem 1.25rem;
            border-radius: .7rem;
            border: none;
            cursor: pointer;
            transition: background .15s;
            white-space: nowrap;
            align-self: center;
            box-shadow: 0 4px 16px rgba(232,92,92,.3);
            font-family: inherit;
        }

            .btn-new-appeal:hover {
                background: var(--coral-d);
            }

            .btn-new-appeal i {
                font-size: .95rem;
            }

        /* ── Info banner ────────────────────────── */
        .info-banner {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            box-shadow: 0 4px 24px rgba(30,45,94,.07);
            margin-top: -2.25rem;
            position: relative;
            z-index: 2;
            overflow: hidden;
        }

        .info-banner-inner {
            display: flex;
            align-items: flex-start;
            gap: .85rem;
            padding: 1.1rem 1.5rem;
            border-left: 4px solid #f59e0b;
        }

        .info-banner-icon {
            font-size: 1.2rem;
            color: #d97706;
            flex-shrink: 0;
            margin-top: .1rem;
        }

        .info-banner-title {
            font-size: .82rem;
            font-weight: 700;
            color: #92400e;
            margin-bottom: .35rem;
        }

        .info-banner ul {
            list-style: disc;
            padding-left: 1.1rem;
        }

        .info-banner li {
            font-size: .78rem;
            color: #92400e;
            margin-bottom: .2rem;
        }

        .info-banner strong {
            font-weight: 700;
        }

        /* ── Card ───────────────────────────────── */
        .ra-card {
            background: #fff;
            border-radius: 1rem;
            border: 1px solid var(--border);
            box-shadow: 0 2px 12px rgba(30,45,94,.06);
            overflow: hidden;
        }

        .ra-card-head {
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        .ra-card-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1rem;
            color: var(--ink);
            display: flex;
            align-items: center;
            gap: .5rem;
        }

            .ra-card-title i {
                font-size: 1rem;
                color: var(--coral);
            }

        /* ── Appeals table ──────────────────────── */
        .bgs-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .82rem;
        }

            .bgs-table thead tr {
                background: var(--navy);
            }

            .bgs-table thead th {
                padding: .65rem 1rem;
                text-align: left;
                color: #fff;
                font-size: .68rem;
                text-transform: uppercase;
                letter-spacing: .05em;
                font-weight: 700;
            }

                .bgs-table thead th:last-child {
                    text-align: right;
                }

            .bgs-table tbody tr {
                border-bottom: 1px solid var(--border);
            }

                .bgs-table tbody tr:last-child {
                    border-bottom: none;
                }

                .bgs-table tbody tr:hover {
                    background: var(--mist);
                }

            .bgs-table tbody td {
                padding: .75rem 1rem;
                color: var(--ink);
                vertical-align: middle;
            }

                .bgs-table tbody td:last-child {
                    text-align: right;
                }

        .course-name {
            font-weight: 600;
            font-size: .84rem;
            color: var(--ink);
        }

        .course-sub {
            font-size: .72rem;
            color: var(--text);
        }

        .tbl-pill {
            display: inline-flex;
            align-items: center;
            gap: .2rem;
            font-size: .68rem;
            font-weight: 700;
            padding: .2rem .55rem;
            border-radius: 2rem;
        }

            .tbl-pill i {
                font-size: .72rem;
            }

        .pill-pending {
            background: #fef3c7;
            color: #92400e;
        }

        .pill-review {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .pill-approved {
            background: #dcfce7;
            color: #166534;
        }

        .pill-rejected {
            background: #fee2e2;
            color: #991b1b;
        }

        .pill-completed {
            background: #f3e8ff;
            color: #7c3aed;
        }

        .pill-cancelled {
            background: #f1f5f9;
            color: #475569;
        }

        .pill-remark {
            background: #fee2e2;
            color: #991b1b;
        }

        .pill-review-t {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .pill-recalc {
            background: #fef3c7;
            color: #92400e;
        }

        .pill-missing {
            background: #ffedd5;
            color: #9a3412;
        }

        .pill-dispute {
            background: #f3e8ff;
            color: #7c3aed;
        }

        .pill-other {
            background: #f1f5f9;
            color: #475569;
        }

        .pill-fee {
            background: #fee2e2;
            color: #991b1b;
        }

        /* Action buttons */
        .btn-view {
            display: inline-flex;
            align-items: center;
            gap: .2rem;
            padding: .3rem .7rem;
            border-radius: .45rem;
            font-size: .72rem;
            font-weight: 700;
            background: #dbeafe;
            color: #1d4ed8;
            border: none;
            cursor: pointer;
            transition: background .15s;
            font-family: inherit;
        }

            .btn-view:hover {
                background: #bfdbfe;
            }

        .btn-cancel {
            display: inline-flex;
            align-items: center;
            gap: .2rem;
            padding: .3rem .7rem;
            border-radius: .45rem;
            font-size: .72rem;
            font-weight: 700;
            background: #fee2e2;
            color: #991b1b;
            border: none;
            cursor: pointer;
            transition: background .15s;
            font-family: inherit;
        }

            .btn-cancel:hover {
                background: #fecaca;
            }

        /* ── Empty / Loading states ─────────────── */
        .empty-state {
            text-align: center;
            padding: 3rem 1.5rem;
        }

            .empty-state i {
                font-size: 2.5rem;
                color: #cbd5e1;
                display: block;
                margin-bottom: .65rem;
            }

            .empty-state h3 {
                font-size: .9rem;
                font-weight: 700;
                color: var(--ink);
                margin-bottom: .25rem;
            }

            .empty-state p {
                font-size: .78rem;
                color: var(--text);
            }

        /* ── Global loading overlay ─────────────── */
        .loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,20,40,.45);
            backdrop-filter: blur(3px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .loading-box {
            background: #fff;
            border-radius: .85rem;
            padding: 1.25rem 1.75rem;
            display: flex;
            align-items: center;
            gap: .85rem;
            box-shadow: 0 12px 32px rgba(15,20,40,.18);
        }

        .spin {
            animation: spin 1s linear infinite;
            font-size: 1.4rem;
            color: var(--coral);
        }
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .loading-box span {
            font-size: .85rem;
            font-weight: 600;
            color: var(--ink);
        }

        /* ── Modals ─────────────────────────────── */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15,20,40,.55);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

            .modal-overlay.show {
                display: flex;
            }

        .modal-box {
            background: #fff;
            border-radius: 1.1rem;
            width: 90%;
            max-width: 540px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 24px 48px rgba(15,20,40,.2);
            animation: modalIn .22s ease;
            display: flex;
            flex-direction: column;
        }
        @@keyframes modalIn {
            from {
                transform: translateY(16px) scale(.97);
                opacity: 0;
            }

            to {
                transform: translateY(0) scale(1);
                opacity: 1;
            }
        }

        .modal-head {
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: linear-gradient(135deg, var(--navy), var(--navy-l));
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .modal-head-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.05rem;
            color: #fff;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

            .modal-head-title i {
                font-size: 1rem;
            }

        .modal-close {
            width: 28px;
            height: 28px;
            border-radius: .4rem;
            background: rgba(255,255,255,.15);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #fff;
            transition: background .15s;
        }

            .modal-close:hover {
                background: rgba(255,255,255,.3);
            }

            .modal-close i {
                font-size: 1rem;
            }

        .modal-body {
            padding: 1.5rem;
            flex: 1;
        }

        .modal-foot {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: .6rem;
            position: sticky;
            bottom: 0;
            background: #fff;
        }

        /* Form fields */
        .form-section {
            margin-bottom: 1.25rem;
        }

        .form-section-title {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: #94a3b8;
            margin-bottom: .75rem;
            display: flex;
            align-items: center;
            gap: .35rem;
        }

            .form-section-title i {
                font-size: .85rem;
            }

        .field-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .85rem;
        }

        .field-label {
            display: block;
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #94a3b8;
            margin-bottom: .35rem;
        }

        .field-select, .field-input, .field-textarea {
            width: 100%;
            padding: .55rem .8rem;
            border: 1.5px solid var(--border);
            border-radius: .55rem;
            font-size: .82rem;
            font-family: inherit;
            color: var(--ink);
            background: #fff;
            transition: border-color .15s;
        }

            .field-select:focus, .field-input:focus, .field-textarea:focus {
                outline: none;
                border-color: var(--coral);
            }

            .field-select:disabled {
                background: var(--mist);
                color: #94a3b8;
                cursor: not-allowed;
            }

        /* Student info box */
        .student-box {
            background: var(--mist);
            border: 1px solid var(--border);
            border-radius: .65rem;
            padding: .875rem 1rem;
            margin-bottom: 1.25rem;
        }

        .student-box-title {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #94a3b8;
            margin-bottom: .5rem;
        }

        .student-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .4rem;
        }

        .student-cell-lbl {
            font-size: .7rem;
            color: var(--text);
        }

        .student-cell-val {
            font-size: .82rem;
            font-weight: 600;
            color: var(--ink);
        }

        /* Course list */
        .courses-box {
            border: 1.5px solid var(--border);
            border-radius: .65rem;
            max-height: 200px;
            overflow-y: auto;
        }

        .course-row {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .65rem .9rem;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            transition: background .15s;
        }

            .course-row:last-child {
                border-bottom: none;
            }

            .course-row:hover {
                background: var(--mist);
            }

            .course-row input[type="radio"] {
                accent-color: var(--coral);
                flex-shrink: 0;
            }

        .course-row-code {
            font-size: .82rem;
            font-weight: 700;
            color: var(--ink);
        }

        .course-row-name {
            font-size: .75rem;
            color: var(--text);
        }

        /* Selected course chip */
        .selected-course-chip {
            display: flex;
            align-items: center;
            gap: .75rem;
            background: #fef2f2;
            border: 1.5px solid #fca5a5;
            border-radius: .65rem;
            padding: .65rem .9rem;
            margin-top: .5rem;
        }

            .selected-course-chip i {
                color: var(--coral);
                font-size: 1rem;
            }

            .selected-course-chip .code {
                font-size: .82rem;
                font-weight: 700;
                color: var(--coral-d);
            }

            .selected-course-chip .name {
                font-size: .75rem;
                color: var(--text);
            }

        /* Fee alert */
        .fee-alert {
            display: flex;
            align-items: flex-start;
            gap: .65rem;
            background: #fff7ed;
            border: 1.5px solid #fed7aa;
            border-radius: .65rem;
            padding: .875rem 1rem;
            margin-top: .75rem;
        }

            .fee-alert i {
                color: #ea580c;
                font-size: 1rem;
                flex-shrink: 0;
                margin-top: .05rem;
            }

        .fee-alert-title {
            font-size: .8rem;
            font-weight: 700;
            color: #9a3412;
            margin-bottom: .2rem;
        }

        .fee-alert-text {
            font-size: .75rem;
            color: #c2410c;
        }

        /* View modal info blocks */
        .info-block {
            background: var(--mist);
            border: 1px solid var(--border);
            border-radius: .65rem;
            padding: .875rem 1rem;
            margin-bottom: .75rem;
        }

        .info-block-title {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #94a3b8;
            margin-bottom: .6rem;
            display: flex;
            align-items: center;
            gap: .3rem;
        }

            .info-block-title i {
                font-size: .85rem;
            }

        .info-block-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .5rem;
        }

        .info-cell-lbl {
            font-size: .7rem;
            color: var(--text);
            margin-bottom: .1rem;
        }

        .info-cell-val {
            font-size: .82rem;
            font-weight: 600;
            color: var(--ink);
        }

        .info-block.green {
            background: #f0fdf4;
            border-color: #86efac;
        }

        .info-block.blue {
            background: #eff6ff;
            border-color: #93c5fd;
        }

        .info-block.amber {
            background: #fffbeb;
            border-color: #fde68a;
        }

        .info-block.purple {
            background: #faf5ff;
            border-color: #d8b4fe;
        }

        /* Modal action buttons */
        .btn-modal-cancel {
            padding: .55rem 1.1rem;
            border-radius: .6rem;
            font-size: .82rem;
            font-weight: 600;
            border: 1.5px solid var(--border);
            background: #fff;
            color: var(--text);
            cursor: pointer;
            transition: background .15s;
            font-family: inherit;
        }

            .btn-modal-cancel:hover {
                background: var(--mist);
            }

        .btn-modal-submit {
            padding: .55rem 1.25rem;
            border-radius: .6rem;
            font-size: .82rem;
            font-weight: 700;
            background: var(--coral);
            color: #fff;
            border: none;
            cursor: pointer;
            transition: background .15s;
            font-family: inherit;
        }

            .btn-modal-submit:hover {
                background: var(--coral-d);
            }

        /* Toast */
        .toast {
            position: fixed;
            top: 1.25rem;
            right: 1.25rem;
            padding: .75rem 1.1rem;
            border-radius: .7rem;
            box-shadow: 0 8px 24px rgba(15,20,40,.15);
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .82rem;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            transform: translateX(120%);
            transition: transform .3s;
        }

            .toast.show {
                transform: translateX(0);
            }

        .toast-success {
            background: #dcfce7;
            color: #166534;
            border-left: 3px solid #16a34a;
        }

        .toast-error {
            background: #fee2e2;
            color: #991b1b;
            border-left: 3px solid #dc2626;
        }

        .toast i {
            font-size: .9rem;
        }
    </style>
}

<!-- Loading overlay -->
<div id="loadingIndicator" class="loading-overlay">
    <div class="loading-box">
        <i class="material-icons spin">refresh</i>
        <span>Processing…</span>
    </div>
</div>

<!-- Create Appeal Modal -->
<div id="appealModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-head">
            <span class="modal-head-title"><i class="material-icons">rate_review</i> Submit Result Appeal</span>
            <button class="modal-close" onclick="hideModal()"><i class="material-icons">close</i></button>
        </div>
        <form id="appealForm" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-body">

                <!-- Student info -->
                @if (ViewBag.Student != null)
                {
                    <div class="student-box">
                        <p class="student-box-title">Student Information</p>
                        <div class="student-grid">
                            <div><p class="student-cell-lbl">Student ID</p><p class="student-cell-val">@ViewBag.Student.StudentId_Number</p></div>
                            <div><p class="student-cell-lbl">Name</p><p class="student-cell-val">@ViewBag.Student.FullName</p></div>
                            <div><p class="student-cell-lbl">Programme</p><p class="student-cell-val">@ViewBag.Student.Programme?.Name</p></div>
                            <div><p class="student-cell-lbl">Year / Period</p><p class="student-cell-val">Year @(ViewBag.Student.StudentCurrentYear ?? 1) / @ViewBag.CurrentPeriodLabel</p></div>
                        </div>
                    </div>
                }

                <!-- Academic Year + Period -->
                <div class="form-section">
                    <p class="form-section-title"><i class="material-icons">calendar_today</i> Academic Period</p>
                    <div class="field-grid-2">
                        <div>
                            <label class="field-label" for="academicYearId">Academic Year *</label>
                            <select required name="AcademicYearId" id="academicYearId" onchange="loadCourses()" class="field-select">
                                <option value="">Select year…</option>
                                @if (ViewBag.AcademicYears != null)
                                {
                                    foreach (var item in ViewBag.AcademicYears)
                                    {
                                        var sel = (bool)item.Selected ? "selected" : null;
                                        <option value="@item.Value" selected="@sel">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="field-label" for="yearPeriodId">Academic Period *</label>
                            <select required name="YearPeriodId" id="yearPeriodId" onchange="loadCourses()" class="field-select">
                                <option value="">Select…</option>
                                @if (ViewBag.YearPeriods != null)
                                {
                                    foreach (var item in ViewBag.YearPeriods)
                                    {
                                        var sel = (bool)item.Selected ? "selected" : null;
                                        <option value="@item.Value" selected="@sel">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Course selection -->
                <div class="form-section">
                    <p class="form-section-title"><i class="material-icons">school</i> Select Course *</p>
                    <div id="coursesLoadingIndicator" class="hidden" style="text-align:center;padding:.75rem;font-size:.78rem;color:var(--text);">
                        <i class="material-icons spin" style="font-size:1rem;vertical-align:middle;">refresh</i> Loading courses…
                    </div>
                    <div id="coursesContainer" class="courses-box">
                        <div class="empty-state" style="padding:1.5rem;">
                            <i class="material-icons" style="font-size:1.8rem;">school</i>
                            <p style="font-size:.75rem;margin-top:.25rem;">Select year &amp; academic period first</p>
                        </div>
                    </div>
                    <input type="hidden" id="courseId" name="CourseId" required />
                    <div id="selectedCourseInfo" class="selected-course-chip hidden">
                        <i class="material-icons">check_circle</i>
                        <div>
                            <p id="selectedCourseCode" class="code">—</p>
                            <p id="selectedCourseName" class="name">—</p>
                        </div>
                    </div>
                </div>

                <!-- Appeal type -->
                <div class="form-section">
                    <p class="form-section-title"><i class="material-icons">label</i> Appeal Type</p>
                    <select required name="AppealType" id="appealType" onchange="handleAppealTypeChange()" class="field-select">
                        <option value="">Select type…</option>
                        @if (ViewBag.AppealTypes != null)
                        {
                            foreach (var item in ViewBag.AppealTypes)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                    <div id="feeAlert" class="fee-alert hidden">
                        <i class="material-icons">warning_amber</i>
                        <div>
                            <p class="fee-alert-title">Remark Fee Required</p>
                            <p class="fee-alert-text">
                                A remark appeal attracts a <strong>non-refundable fee of K@remarkFee.ToString("N2")</strong>.
                                Payment instructions will be provided after submission.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Reason -->
                <div class="form-section">
                    <label class="form-section-title" for="reason"><i class="material-icons">edit_note</i> Reason for Appeal *</label>
                    <textarea required name="Reason" id="reason" rows="5" class="field-textarea"
                              placeholder="Provide a detailed explanation (minimum 50 characters)…"></textarea>
                    <p style="font-size:.7rem;color:#94a3b8;margin-top:.25rem;">Minimum 50 characters required</p>
                </div>

                <!-- Original mark -->
                <div class="form-section">
                    <label class="field-label" for="originalMark">Original Mark (if known)</label>
                    <input type="number" step="0.01" min="0" max="100" name="OriginalMark" id="originalMark"
                           class="field-input" placeholder="e.g. 42.5" />
                </div>

            </div>
            <div class="modal-foot">
                <button type="button" onclick="hideModal()" class="btn-modal-cancel">Cancel</button>
                <button type="submit" class="btn-modal-submit">
                    <i class="material-icons" style="font-size:.9rem;vertical-align:middle;margin-right:.25rem;">send</i>
                    Submit Appeal
                </button>
            </div>
        </form>
    </div>
</div>

<!-- View Appeal Details Modal -->
<div id="viewModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-head">
            <span class="modal-head-title"><i class="material-icons">visibility</i> Appeal Details</span>
            <button class="modal-close" onclick="hideViewModal()"><i class="material-icons">close</i></button>
        </div>
        <div id="viewModalContent" class="modal-body"></div>
        <div class="modal-foot">
            <button type="button" onclick="hideViewModal()" class="btn-modal-cancel">Close</button>
        </div>
    </div>
</div>

<div class="ra-wrap p-4 md:p-6">

    <!-- Hero -->
    <div class="ra-hero mb-6">
        <div class="hero-inner">
            <div>
                <p class="hero-eyebrow">Student Portal</p>
                <h1 class="hero-title">Appeals</h1>
                <p class="hero-sub">Submit and track appeals for your examination results</p>
            </div>
            <button type="button" onclick="showCreateModal()" class="btn-new-appeal">
                <i class="material-icons">add_circle</i> New Appeal
            </button>
        </div>
    </div>

    <!-- Info banner -->
    <div class="info-banner mb-6">
        <div class="info-banner-inner">
            <i class="material-icons info-banner-icon">info</i>
            <div>
                <p class="info-banner-title">Important Information</p>
                <ul>
                    <li><strong>Remark appeals</strong> attract a non-refundable fee of <strong>K@(remarkFee.ToString("N2"))</strong></li>
                    <li>Appeals must be submitted within the stipulated appeal period</li>
                    <li>Provide detailed reasons — vague submissions may be rejected</li>
                    <li>You will be notified via email when your appeal status changes</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Appeals list card -->
    <div class="ra-card">
        <div class="ra-card-head">
            <h2 class="ra-card-title"><i class="material-icons">list_alt</i> My Appeals</h2>
        </div>
        <div id="appealsContainer" style="padding:1.5rem;">
            <div class="empty-state">
                <i class="material-icons">hourglass_empty</i>
                <h3>Loading appeals…</h3>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const REMARK_FEE = @remarkFee;
        let studentCourses = [];

        document.addEventListener('DOMContentLoaded', () => loadAppeals());

        /* ── Load & display appeals ── */
        async function loadAppeals() {
            showLoading(true);
            try {
                const r = await fetch('/ResultAppeal/GetMyAppeals');
                const res = await r.json();
                if (res.success) displayAppeals(res.data);
                else showToast(res.message, 'error');
            } catch { showToast('Error loading appeals', 'error'); }
            finally { showLoading(false); }
        }

        function displayAppeals(appeals) {
            const container = document.getElementById('appealsContainer');
            if (!appeals || !appeals.length) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="material-icons">inbox</i>
                        <h3>No appeals yet</h3>
                        <p>Click "New Appeal" to submit your first appeal</p>
                    </div>`;
                return;
            }
            container.innerHTML = `
                <div style="overflow-x:auto;">
                    <table class="bgs-table">
                        <thead><tr>
                            <th>Course</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Submitted</th>
                            <th>Actions</th>
                        </tr></thead>
                        <tbody>
                            ${appeals.map(a => `
                                <tr>
                                    <td>
                                        <div class="course-name">${a.courseCode}</div>
                                        <div class="course-sub">${a.courseName}</div>
                                        <div class="course-sub">${a.academicYear} · ${a.periodLabel || `Period ${a.yearPeriodId || ''}`}</div>
                                    </td>
                                    <td>
                                        <span class="tbl-pill ${getAppealTypeClass(a.appealType)}">${formatAppealType(a.appealType)}</span>
                                        ${a.appealType === 'Remark' && !a.feePaid
                                            ? '<br><span class="tbl-pill pill-fee" style="margin-top:.3rem;">Fee Pending</span>'
                                            : ''}
                                    </td>
                                    <td><span class="tbl-pill ${getStatusClass(a.status)}">${formatStatus(a.status)}</span></td>
                                    <td style="font-size:.78rem;">${new Date(a.submissionDate).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' })}</td>
                                    <td>
                                        <div style="display:flex;gap:.4rem;justify-content:flex-end;flex-wrap:wrap;">
                                            <button onclick="viewAppeal(${a.id})" class="btn-view">
                                                <i class="material-icons" style="font-size:.75rem;">visibility</i> View
                                            </button>
                                            ${a.status === 'Pending' ? `
                                            <button onclick="cancelAppeal(${a.id})" class="btn-cancel">
                                                <i class="material-icons" style="font-size:.75rem;">cancel</i> Cancel
                                            </button>` : ''}
                                        </div>
                                    </td>
                                </tr>`).join('')}
                        </tbody>
                    </table>
                </div>`;
        }

        /* ── Modal helpers ── */
        function showCreateModal() {
            document.getElementById('appealForm').reset();
            document.getElementById('courseId').value = '';
            document.getElementById('selectedCourseInfo').classList.add('hidden');
            document.getElementById('feeAlert').classList.add('hidden');
            document.getElementById('coursesContainer').innerHTML = `
                <div class="empty-state" style="padding:1.5rem;">
                    <i class="material-icons" style="font-size:1.8rem;">school</i>
                    <p style="font-size:.75rem;margin-top:.25rem;">Select year &amp; academic period first</p>
                </div>`;
            document.getElementById('appealModal').classList.add('show');
        }
        function hideModal()     { document.getElementById('appealModal').classList.remove('show'); }
        function hideViewModal() { document.getElementById('viewModal').classList.remove('show'); }

        /* ── Load courses ── */
        async function loadCourses() {
            const yr  = document.getElementById('academicYearId').value;
            const sem = document.getElementById('yearPeriodId').value;
            if (!yr || !sem) return;
            document.getElementById('coursesLoadingIndicator').classList.remove('hidden');
            document.getElementById('coursesContainer').innerHTML = '';
            try {
                const r = await fetch(`/ResultAppeal/GetMyCourses?academicYearId=${yr}&period=${sem}`);
                const res = await r.json();
                if (res.success) { studentCourses = res.data; displayCourses(res.data); }
                else showToast(res.message, 'error');
            } catch { showToast('Error loading courses', 'error'); }
            finally { document.getElementById('coursesLoadingIndicator').classList.add('hidden'); }
        }

        function displayCourses(courses) {
            const c = document.getElementById('coursesContainer');
            if (!courses || !courses.length) {
                c.innerHTML = `<div class="empty-state" style="padding:1.5rem;"><i class="material-icons" style="font-size:1.8rem;">school</i><p style="font-size:.75rem;margin-top:.25rem;">No courses found for this period</p></div>`;
                return;
            }
            c.innerHTML = courses.map(course => `
                <div class="course-row" onclick="selectCourse(${JSON.stringify(course).replace(/"/g, '&quot;')})">
                    <input type="radio" name="courseSelection" class="course-radio"
                           data-course-id="${course.id}" data-course-code="${course.courseCode}" data-course-name="${course.courseName}" />
                    <div>
                        <p class="course-row-code">${course.courseCode}</p>
                        <p class="course-row-name">${course.courseName}</p>
                    </div>
                </div>`).join('');
        }

        function selectCourse(course) {
            document.querySelectorAll('.course-radio').forEach(r => { r.checked = r.dataset.courseId == course.id; });
            document.getElementById('selectedCourseInfo').classList.remove('hidden');
            document.getElementById('selectedCourseCode').textContent = course.courseCode;
            document.getElementById('selectedCourseName').textContent = course.courseName;
            document.getElementById('courseId').value = course.id;
        }

        function handleAppealTypeChange() {
            const t = document.getElementById('appealType').value;
            document.getElementById('feeAlert').classList.toggle('hidden', t !== 'Remark');
        }

        /* ── Submit ── */
        document.getElementById('appealForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!document.getElementById('courseId').value) { showToast('Please select a course', 'error'); return; }
            if (document.getElementById('reason').value.length < 50) { showToast('Reason must be at least 50 characters', 'error'); return; }
            showLoading(true);
            try {
                const r = await fetch('/ResultAppeal/SubmitAppeal', { method: 'POST', body: new FormData(e.target) });
                const res = await r.json();
                if (res.success) { showToast(res.message, 'success'); hideModal(); await loadAppeals(); }
                else showToast(res.message, 'error');
            } catch { showToast('Error submitting appeal', 'error'); }
            finally { showLoading(false); }
        });

        /* ── View appeal ── */
        async function viewAppeal(id) {
            showLoading(true);
            try {
                const r = await fetch(`/ResultAppeal/GetAppeal?id=${id}`);
                const res = await r.json();
                if (res.success) {
                    const a = res.data;
                    document.getElementById('viewModalContent').innerHTML = `
                        <div class="info-block">
                            <p class="info-block-title"><i class="material-icons">school</i> Course Information</p>
                            <div class="info-block-grid">
                                <div><p class="info-cell-lbl">Course</p><p class="info-cell-val">${a.courseCode} — ${a.courseName}</p></div>
                                <div><p class="info-cell-lbl">Academic Period</p><p class="info-cell-val">${a.academicYear} · ${a.periodLabel || `Period ${a.yearPeriodId || ''}`}</p></div>
                            </div>
                        </div>

                        <div class="info-block blue">
                            <p class="info-block-title"><i class="material-icons">rate_review</i> Appeal Details</p>
                            <div class="info-block-grid" style="margin-bottom:.6rem;">
                                <div>
                                    <p class="info-cell-lbl">Type</p>
                                    <span class="tbl-pill ${getAppealTypeClass(a.appealType)}">${formatAppealType(a.appealType)}</span>
                                </div>
                                <div>
                                    <p class="info-cell-lbl">Status</p>
                                    <span class="tbl-pill ${getStatusClass(a.status)}">${formatStatus(a.status)}</span>
                                </div>
                                <div>
                                    <p class="info-cell-lbl">Submitted</p>
                                    <p class="info-cell-val">${new Date(a.submissionDate).toLocaleString('en-GB', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })}</p>
                                </div>
                                ${a.appealType === 'Remark' ? `
                                <div>
                                    <p class="info-cell-lbl">Fee Status</p>
                                    <p class="info-cell-val" style="color:${a.feePaid ? '#16a34a' : '#dc2626'}">
                                        ${a.feePaid ? 'Paid' : 'Pending (K' + REMARK_FEE + ')'}
                                    </p>
                                </div>` : ''}
                            </div>
                            <p class="info-cell-lbl">Reason</p>
                            <p style="font-size:.82rem;color:var(--text);margin-top:.2rem;line-height:1.6;">${a.reason}</p>
                        </div>

                        ${(a.originalMark !== null || a.revisedMark !== null) ? `
                        <div class="info-block amber">
                            <p class="info-block-title"><i class="material-icons">grade</i> Marks</p>
                            <div class="info-block-grid">
                                <div><p class="info-cell-lbl">Original Mark</p><p class="info-cell-val">${a.originalMark !== null ? a.originalMark + '%' : 'N/A'}</p></div>
                                <div><p class="info-cell-lbl">Revised Mark</p><p class="info-cell-val">${a.revisedMark !== null ? a.revisedMark + '%' : 'Pending'}</p></div>
                            </div>
                        </div>` : ''}

                        ${a.response ? `
                        <div class="info-block green">
                            <p class="info-block-title"><i class="material-icons">reply</i> Response</p>
                            <p style="font-size:.82rem;color:var(--text);line-height:1.6;">${a.response}</p>
                            ${a.responseDate ? `<p style="font-size:.7rem;color:#94a3b8;margin-top:.4rem;">Responded: ${new Date(a.responseDate).toLocaleString('en-GB', { day:'numeric', month:'short', year:'numeric' })}</p>` : ''}
                        </div>` : ''}

                        ${a.finalDecision ? `
                        <div class="info-block purple">
                            <p class="info-block-title"><i class="material-icons">gavel</i> Final Decision</p>
                            <p style="font-size:.82rem;color:var(--text);line-height:1.6;">${a.finalDecision}</p>
                            ${a.decisionDate ? `<p style="font-size:.7rem;color:#94a3b8;margin-top:.4rem;">Decided: ${new Date(a.decisionDate).toLocaleString('en-GB', { day:'numeric', month:'short', year:'numeric' })}</p>` : ''}
                        </div>` : ''}
                    `;
                    document.getElementById('viewModal').classList.add('show');
                } else showToast(res.message, 'error');
            } catch { showToast('Error loading appeal details', 'error'); }
            finally { showLoading(false); }
        }

        /* ── Cancel appeal ── */
        async function cancelAppeal(id) {
            if (!confirm('Are you sure you want to cancel this appeal?')) return;
            showLoading(true);
            try {
                const fd = new FormData();
                fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                const r = await fetch(`/ResultAppeal/CancelAppeal?id=${id}`, { method: 'POST', body: fd });
                const res = await r.json();
                if (res.success) { showToast(res.message, 'success'); await loadAppeals(); }
                else showToast(res.message, 'error');
            } catch { showToast('Error cancelling appeal', 'error'); }
            finally { showLoading(false); }
        }

        /* ── Helpers ── */
        function getStatusClass(s) {
            return { Pending:'pill-pending', UnderReview:'pill-review', Approved:'pill-approved', Rejected:'pill-rejected', Completed:'pill-completed', Cancelled:'pill-cancelled' }[s] || 'pill-cancelled';
        }
        function formatStatus(s) {
            return { Pending:'Pending Review', UnderReview:'Under Review', Approved:'Approved', Rejected:'Rejected', Completed:'Completed', Cancelled:'Cancelled' }[s] || s;
        }
        function getAppealTypeClass(t) {
            return { Remark:'pill-remark', Review:'pill-review-t', Recalculation:'pill-recalc', MissingMarks:'pill-missing', GradeDispute:'pill-dispute', Other:'pill-other' }[t] || 'pill-other';
        }
        function formatAppealType(t) {
            return { Remark:'Remark', Review:'Review', Recalculation:'Recalculation', MissingMarks:'Missing Marks', GradeDispute:'Grade Dispute', Other:'Other' }[t] || t;
        }

        function showLoading(v) {
            document.getElementById('loadingIndicator').style.display = v ? 'flex' : 'none';
        }

        let _toastTimer;
        function showToast(msg, type = 'success') {
            let t = document.getElementById('globalToast');
            if (!t) {
                t = document.createElement('div');
                t.id = 'globalToast';
                document.body.appendChild(t);
            }
            t.className = `toast toast-${type}`;
            t.innerHTML = `<i class="material-icons">${type === 'success' ? 'check_circle' : 'error'}</i><span>${msg}</span>`;
            requestAnimationFrame(() => t.classList.add('show'));
            clearTimeout(_toastTimer);
            _toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { hideModal(); hideViewModal(); }
        });
    </script>
}
