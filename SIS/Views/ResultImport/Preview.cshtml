@model SIS.Models.Results.ResultImportPreviewResult

@{
    ViewData["Title"] = "Preview Import Results";
}

<div class="min-h-[90vh] p-6 bg-gray-50">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-3xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-3 text-primary-600">preview</i>
            Import Preview & Validation
        </h1>
        <p class="text-secondary-600 mt-2">
            @Model.CourseCode - @Model.CourseName | 
            Academic Year: @Model.AcademicYearValue | 
            Semester: @Model.Semester
        </p>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-secondary-600">Total Rows</p>
                    <p class="text-3xl font-bold text-secondary-800">@Model.TotalRows</p>
                </div>
                <i class="material-icons text-4xl text-blue-500">description</i>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-secondary-600">Valid</p>
                    <p class="text-3xl font-bold text-green-600">@Model.ValidResults.Count</p>
                </div>
                <i class="material-icons text-4xl text-green-500">check_circle</i>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-secondary-600">Invalid</p>
                    <p class="text-3xl font-bold text-red-600">@Model.InvalidResults.Count</p>
                </div>
                <i class="material-icons text-4xl text-red-500">error</i>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-secondary-600">Success Rate</p>
                    <p class="text-3xl font-bold text-primary-600">@Model.Summary.SuccessRate%</p>
                </div>
                <i class="material-icons text-4xl text-primary-500">analytics</i>
            </div>
        </div>
    </div>

    @if (Model.InvalidResults.Any())
    {
        <!-- Error Alert -->
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-lg">
            <div class="flex items-start">
                <i class="material-icons text-red-600 mr-3">warning</i>
                <div class="flex-1">
                    <h3 class="font-semibold text-red-900 mb-2">Validation Errors Found</h3>
                    <p class="text-red-800 text-sm mb-3">
                        @Model.InvalidResults.Count row(s) contain errors and will not be imported. 
                        Please download the error report, fix the issues, and try again.
                    </p>
                    <a href="@Url.Action("DownloadErrorReport", new { previewKey = TempData["PreviewKey"] })"
                       class="inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors text-sm">
                        <i class="material-icons text-sm mr-2">download</i>
                        Download Error Report
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Valid Results Section -->
    @if (Model.ValidResults.Any())
    {
        <div class="bg-white rounded-lg shadow-sm mb-6">
            <div class="p-6 border-b border-gray-200 bg-green-50">
                <h2 class="text-xl font-semibold text-green-900 flex items-center">
                    <i class="material-icons mr-2">check_circle</i>
                    Valid Results (@Model.ValidResults.Count)
                </h2>
                <p class="text-green-700 text-sm mt-1">
                    These records passed validation and are ready to be imported.
                </p>
            </div>

            <div class="p-6">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-gray-50 border-b-2 border-gray-200">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold text-gray-700">Row</th>
                                <th class="px-4 py-3 text-left font-semibold text-gray-700">Student Number</th>
                                <th class="px-4 py-3 text-left font-semibold text-gray-700">Full Name</th>
                                <th class="px-4 py-3 text-center font-semibold text-gray-700">Assessments</th>
                                <th class="px-4 py-3 text-center font-semibold text-gray-700">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var result in Model.ValidResults.Take(10))
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-3 text-secondary-600">@result.RowNumber</td>
                                    <td class="px-4 py-3 font-medium text-gray-900">@result.StudentNumber</td>
                                    <td class="px-4 py-3 text-gray-700">@result.FullName</td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-medium">
                                            @result.AssessmentScores.Count score(s)
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="px-2 py-1 bg-green-100 text-green-800 rounded-full text-xs font-medium flex items-center justify-center">
                                            <i class="material-icons text-xs mr-1">check</i>
                                            @(result.HasExistingScores ? "Update" : "New")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (Model.ValidResults.Count > 10)
                    {
                        <div class="mt-4 text-center text-sm text-secondary-600">
                            Showing 10 of @Model.ValidResults.Count valid records
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Invalid Results Section -->
    @if (Model.InvalidResults.Any())
    {
        <div class="bg-white rounded-lg shadow-sm mb-6">
            <div class="p-6 border-b border-gray-200 bg-red-50">
                <h2 class="text-xl font-semibold text-red-900 flex items-center">
                    <i class="material-icons mr-2">error</i>
                    Invalid Results (@Model.InvalidResults.Count)
                </h2>
                <p class="text-red-700 text-sm mt-1">
                    These records have validation errors and will not be imported.
                </p>
            </div>

            <div class="p-6">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-gray-50 border-b-2 border-gray-200">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold text-gray-700">Row</th>
                                <th class="px-4 py-3 text-left font-semibold text-gray-700">Student Number</th>
                                <th class="px-4 py-3 text-left font-semibold text-gray-700">Full Name</th>
                                <th class="px-4 py-3 text-left font-semibold text-gray-700">Errors</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var result in Model.InvalidResults.Take(10))
                            {
                                var validation = Model.ValidationResults.FirstOrDefault(v => v.RowNumber == result.RowNumber);
                                <tr class="hover:bg-red-50">
                                    <td class="px-4 py-3 text-secondary-600">@result.RowNumber</td>
                                    <td class="px-4 py-3 font-medium text-gray-900">@result.StudentNumber</td>
                                    <td class="px-4 py-3 text-gray-700">@result.FullName</td>
                                    <td class="px-4 py-3">
                                        @if (validation != null && validation.Errors.Any())
                                        {
                                            <ul class="list-disc list-inside text-red-700 text-xs space-y-1">
                                                @foreach (var error in validation.Errors)
                                                {
                                                    <li>@error</li>
                                                }
                                            </ul>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (Model.InvalidResults.Count > 10)
                    {
                        <div class="mt-4 text-center text-sm text-secondary-600">
                            Showing 10 of @Model.InvalidResults.Count invalid records
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Action Buttons -->
    <div class="flex items-center justify-between bg-white rounded-lg shadow-sm p-6">
        <div class="flex space-x-4">
            <a asp-action="Index"
               class="px-6 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors flex items-center">
                <i class="material-icons mr-2">arrow_back</i>
                Cancel
            </a>

            @if (Model.InvalidResults.Any())
            {
                <a href="@Url.Action("DownloadErrorReport", new { previewKey = ViewBag.PreviewKey })"
                   class="px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center">
                    <i class="material-icons mr-2">download</i>
                    Download Error Report
                </a>
            }
        </div>

        @if (Model.ValidResults.Any())
        {
            <form asp-action="ProcessImport" method="post" id="processImportForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="previewKey" value="@ViewBag.PreviewKey" />

                <button type="submit"
                        id="btnProcessImport"
                        class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors flex items-center font-semibold">
                    <i class="material-icons mr-2">upload</i>
                    Confirm and Import (@Model.ValidResults.Count Students)
                </button>
            </form>
        }
        else
        {
            <button type="button"
                    disabled
                    class="px-6 py-2 bg-gray-400 text-white rounded-lg cursor-not-allowed flex items-center">
                <i class="material-icons mr-2">block</i>
                No Valid Results to Import
            </button>
        }
    </div>

    <!-- Assessment Summary -->
    @if (Model.Assessments.Any())
    {
        <div class="bg-white rounded-lg shadow-sm mt-6 p-6">
            <h3 class="text-lg font-semibold text-secondary-800 mb-4 flex items-center">
                <i class="material-icons mr-2">assignment</i>
                Assessment Configuration
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                @foreach (var assessment in Model.Assessments)
                {
                    <div class="p-4 bg-blue-50 rounded-lg border border-blue-200">
                        <div class="font-semibold text-blue-900">@assessment.Name</div>
                        <div class="text-2xl font-bold text-blue-600">@assessment.WeightPercentage%</div>
                        <div class="text-xs text-blue-700">Weight</div>
                    </div>
                }
            </div>
            <div class="mt-4 text-sm text-secondary-600">
                Total Weight: <span class="font-semibold">@Model.Assessments.Sum(a => a.WeightPercentage)%</span>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Debug: Log preview key on page load
        console.log('Preview Key loaded:', '@ViewBag.PreviewKey');

        // Validate preview key before submission
        document.getElementById('processImportForm')?.addEventListener('submit', function(e) {
            const previewKeyInput = document.querySelector('input[name="previewKey"]');
            const previewKey = previewKeyInput?.value;

            console.log('Submitting with Preview Key:', previewKey);

            if (!previewKey || previewKey === '') {
                e.preventDefault();
                alert('ERROR: Preview key is missing. Please refresh the page and try again.');
                return false;
            }

            // Rest of your existing confirmation code...
            e.preventDefault();

            const validCount = @Model.ValidResults.Count;
            const invalidCount = @Model.InvalidResults.Count;

            let message = `You are about to import results for ${validCount} student(s).`;

            if (invalidCount > 0) {
                message += `\n\n${invalidCount} invalid record(s) will be skipped.`;
            }

            message += '\n\nThis action cannot be undone. Continue?';

            if (confirm(message)) {
                const btn = document.getElementById('btnProcessImport');
                btn.innerHTML = '<i class="material-icons animate-spin mr-2">sync</i> Processing Import...';
                btn.disabled = true;

                this.submit();
            }
        });

        // Auto-scroll to invalid results if present
        @if (Model.InvalidResults.Any())
        {
            <text>
                setTimeout(() => {
                    const invalidSection = document.querySelector('.bg-red-50');
                    if (invalidSection) {
                        invalidSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }, 500);
            </text>
        }
    </script>
}