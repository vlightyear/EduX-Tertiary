@section Scripts {
    <script>
        let studentRowCounter = 0;
        let currentPage = 1;
        let currentPageSize = 10;

        document.addEventListener('DOMContentLoaded', function () {
            setTodayDate();
            addStudentRow();
        });

        function setTodayDate() {
            const now = new Date();
            const today = now.toISOString().split('T')[0];
            
            if (document.getElementById('transactionDate')) {
                document.getElementById('transactionDate').value = today;
            }
            if (document.getElementById('groupDate')) {
                document.getElementById('groupDate').value = today;
            }
            document.getElementById('dateStart').value = today;
            document.getElementById('dateEnd').value = today;
        }

        function numberToWords(num) {
            const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
            const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
            const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];

            if (num === 0) return 'Zero';

            let words = '';

            if (Math.floor(num / 1000000) > 0) {
                words += numberToWords(Math.floor(num / 1000000)) + ' Million ';
                num %= 1000000;
            }

            if (Math.floor(num / 1000) > 0) {
                words += numberToWords(Math.floor(num / 1000)) + ' Thousand ';
                num %= 1000;
            }

            if (Math.floor(num / 100) > 0) {
                words += ones[Math.floor(num / 100)] + ' Hundred ';
                num %= 100;
            }

            if (num > 0) {
                if (num < 10) {
                    words += ones[num];
                } else if (num >= 10 && num < 20) {
                    words += teens[num - 10];
                } else {
                    words += tens[Math.floor(num / 10)];
                    if (num % 10 > 0) {
                        words += ' ' + ones[num % 10];
                    }
                }
            }

            return words.trim();
        }

        function formatAmountInWords(amount) {
            const integerPart = Math.floor(amount);
            const decimalPart = Math.round((amount - integerPart) * 100);

            let result = numberToWords(integerPart);
            
            if (decimalPart > 0) {
                result += ' and ' + decimalPart + '/100';
            }

            return result + ' Only.';
        }

        @*function printCreditNote(creditNoteData) {
            const printWindow = window.open('', '', 'height=800,width=800');
            const template = document.getElementById('printCreditNoteTemplate').innerHTML;
            
            printWindow.document.write('<html><head><title>Credit Note - ' + creditNoteData.transactionId + '</title>');
            printWindow.document.write('</head><body>');
            printWindow.document.write(template);
            printWindow.document.write('</body></html>');
            
            printWindow.document.close();

            const date = creditNoteData.date ? new Date(creditNoteData.date) : new Date();
            const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

            setTimeout(() => {
                printWindow.document.getElementById('print-credit-note-id').textContent = creditNoteData.transactionId || 'N/A';
                printWindow.document.getElementById('print-date').textContent = formattedDate;
                printWindow.document.getElementById('print-student-name').textContent = creditNoteData.studentName || '';
                printWindow.document.getElementById('print-amount').textContent = parseFloat(creditNoteData.amount).toFixed(2);
                printWindow.document.getElementById('print-amount-words').textContent = formatAmountInWords(creditNoteData.amount);
                
                printWindow.document.getElementById('print-table-name').textContent = creditNoteData.studentName || '';
                printWindow.document.getElementById('print-table-number').textContent = creditNoteData.studentNumber || '';
                printWindow.document.getElementById('print-table-amount').textContent = parseFloat(creditNoteData.amount).toFixed(2);
                printWindow.document.getElementById('print-total-amount').textContent = parseFloat(creditNoteData.amount).toFixed(2);
                
                printWindow.document.getElementById('print-reason').textContent = creditNoteData.reason || '';
                printWindow.document.getElementById('print-reference').textContent = creditNoteData.reference || '';
                printWindow.document.getElementById('print-prepared-by').textContent = creditNoteData.postedBy || '';

                printWindow.print();
                printWindow.close();
            }, 250);
        }*@

        function switchTab(tab) {
            const entryTab = document.getElementById('entryTab');
            const groupTab = document.getElementById('groupTab');
            const recentTab = document.getElementById('recentTab');
            const entryContent = document.getElementById('entryContent');
            const groupContent = document.getElementById('groupContent');
            const recentContent = document.getElementById('recentContent');

            entryTab.classList.remove('active', 'border-red-600', 'text-red-600');
            groupTab.classList.remove('active', 'border-red-600', 'text-red-600');
            recentTab.classList.remove('active', 'border-red-600', 'text-red-600');
            entryTab.classList.add('border-transparent', 'text-gray-500');
            groupTab.classList.add('border-transparent', 'text-gray-500');
            recentTab.classList.add('border-transparent', 'text-gray-500');

            entryContent.classList.add('hidden');
            groupContent.classList.add('hidden');
            recentContent.classList.add('hidden');

            if (tab === 'entry') {
                entryTab.classList.add('active', 'border-red-600', 'text-red-600');
                entryTab.classList.remove('border-transparent', 'text-gray-500');
                entryContent.classList.remove('hidden');
            } else if (tab === 'group') {
                groupTab.classList.add('active', 'border-red-600', 'text-red-600');
                groupTab.classList.remove('border-transparent', 'text-gray-500');
                groupContent.classList.remove('hidden');
            } else {
                recentTab.classList.add('active', 'border-red-600', 'text-red-600');
                recentTab.classList.remove('border-transparent', 'text-gray-500');
                recentContent.classList.remove('hidden');
                loadCreditNotesList();
            }
        }

        function addStudentRow() {
            studentRowCounter++;
            const html = `
                <div class="student-row border border-gray-200 rounded-md p-4 bg-gray-50" data-id="${studentRowCounter}">
                    <div class="flex justify-between items-center mb-3">
                        <h5 class="font-semibold text-gray-700">Student #${studentRowCounter}</h5>
                        <button type="button" onclick="removeStudentRow(${studentRowCounter})" class="text-red-600 hover:text-red-800 text-xl">&times;</button>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Student Number *</label>
                            <input type="text" class="student-number w-full px-3 py-2 border border-gray-300 rounded-md text-sm" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Amount (ZMW) *</label>
                            <input type="number" class="student-amount w-full px-3 py-2 border border-gray-300 rounded-md text-sm" step="0.01" min="0.01" required oninput="calculateGroupTotal()">
                        </div>
                    </div>
                </div>
            `;
            document.getElementById('studentsBox').insertAdjacentHTML('beforeend', html);
            console.log("src: ", studentRowCounter);
        }

        function removeStudentRow(id) {
            const rows = document.querySelectorAll('.student-row');
            if (rows.length <= 1) {
                alert('At least one student is required');
                return;
            }
            document.querySelector(`[data-id="${id}"]`).remove();
            calculateGroupTotal();
        }

        function calculateGroupTotal() {
            let total = 0;
            document.querySelectorAll('.student-amount').forEach(input => {
                total += parseFloat(input.value) || 0;
            });
            document.getElementById('groupTotal').textContent = `K ${total.toFixed(2)}`;
        }

        function resetGroupForm() {
            document.getElementById('groupForm').reset();
            document.getElementById('studentsBox').innerHTML = '';
            studentRowCounter = 0;
            addStudentRow();
            calculateGroupTotal();
            clearGroupFile();
        }

        document.getElementById('groupForm').addEventListener('submit', function (e) {
            const rows = document.querySelectorAll('.student-row');
            const studentNumbers = [];
            const studentAmounts = [];

            rows.forEach(row => {
                const num = row.querySelector('.student-number').value.trim();
                const amt = row.querySelector('.student-amount').value.trim();

                if (num && amt) {
                    studentNumbers.push(num);
                    studentAmounts.push(amt);
                }
            });

            if (studentNumbers.length === 0) {
                e.preventDefault();
                alert('Please add at least one valid student');
                return;
            }

            document.getElementById('hiddenStudentNumbers').value = studentNumbers.join(',');
            document.getElementById('hiddenStudentAmounts').value = studentAmounts.join(',');

            document.getElementById('groupSubmitBtn').disabled = true;
            document.getElementById('groupSubmitBtn').innerHTML = '<i class="material-icons animate-spin mr-2">refresh</i>Processing...';
        });

        async function verifyStudent() {
            const studentNumber = document.getElementById('studentNumber').value.trim();
            const verificationDiv = document.getElementById('studentVerification');
            const consumerNameInput = document.getElementById('consumerName');
    
            if (!studentNumber) {
                verificationDiv.classList.add('hidden');
                // Hide invoice dropdown if it exists
                const invoiceDropdownContainer = document.getElementById('invoiceDropdownContainer');
                if (invoiceDropdownContainer) {
                    invoiceDropdownContainer.classList.add('hidden');
                }
                return;
            }

            try {
                const response = await fetch(`/Admin/VerifyStudentForCreditNote/${encodeURIComponent(studentNumber)}`);
                const data = await response.json();

                if (data.exists) {
                    verificationDiv.className = 'mb-4 p-4 bg-green-50 border border-green-200 rounded-lg flex items-start';
                    verificationDiv.innerHTML = `
                        <i class="material-icons text-green-600 mr-3">check_circle</i>
                        <div class="flex-1">
                            <p class="text-green-800 font-medium">Student Verified ✓</p>
                            <div class="text-green-700 text-sm mt-1">
                                <p><strong>Name:</strong> ${data.studentName}</p>
                                <p><strong>Student ID:</strong> ${data.studentIdNumber}</p>
                                ${data.programme ? `<p><strong>Programme:</strong> ${data.programme}</p>` : ''}
                            </div>
                        </div>
                    `;
            
                    if (consumerNameInput.value === '') {
                        consumerNameInput.value = data.studentName;
                    }

                    // Display invoices from the response
                    displayInvoices(data.invoices);
            
                } else {
                    verificationDiv.className = 'mb-4 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start';
                    verificationDiv.innerHTML = `
                        <i class="material-icons text-red-600 mr-3">error</i>
                        <div>
                            <p class="text-red-800 font-medium">Student Not Found</p>
                            <p class="text-red-700 text-sm">${data.message}</p>
                        </div>
                    `;
                    // Hide invoice dropdown
                    const invoiceDropdownContainer = document.getElementById('invoiceDropdownContainer');
                    if (invoiceDropdownContainer) {
                        invoiceDropdownContainer.classList.add('hidden');
                    }
                }
        
                verificationDiv.classList.remove('hidden');
            } catch (error) {
                console.error('Error verifying student:', error);
                verificationDiv.className = 'mb-4 p-4 bg-yellow-50 border border-yellow-200 rounded-lg flex items-start';
                verificationDiv.innerHTML = `
                    <i class="material-icons text-yellow-600 mr-3">warning</i>
                    <div>
                        <p class="text-yellow-800 font-medium">Verification Error</p>
                        <p class="text-yellow-700 text-sm">Could not verify student. Please check the student number.</p>
                    </div>
                `;
                verificationDiv.classList.remove('hidden');
        
                // Hide invoice dropdown
                const invoiceDropdownContainer = document.getElementById('invoiceDropdownContainer');
                if (invoiceDropdownContainer) {
                    invoiceDropdownContainer.classList.add('hidden');
                }
            }
        }

        function displayInvoices(invoices) {
            const invoiceDropdownContainer = document.getElementById('invoiceDropdownContainer');
    
            if (!invoiceDropdownContainer) {
                console.error('Invoice dropdown container not found');
                return;
            }

            if (invoices && invoices.length > 0) {
                let invoiceOptions = '<option value="">Select invoice to reverse</option>';
                invoices.forEach(invoice => {
                    const invoiceDate = new Date(invoice.createdDate).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'short', 
                        day: 'numeric' 
                    });
                    const outstandingAmount = parseFloat(invoice.outstandingAmount || invoice.totalAmount || 0);
                    const totalAmount = parseFloat(invoice.totalAmount || 0);
            
                    invoiceOptions += `<option value="${invoice.id}" 
                        data-invoice-number="${invoice.invoiceReference || ''}" 
                        data-amount="${outstandingAmount}">
                        ${invoice.invoiceReference || 'N/A'} - K${totalAmount.toFixed(2)} 
                        ${outstandingAmount > 0 ? `(Outstanding: K${outstandingAmount.toFixed(2)})` : '(Fully Paid)'} 
                        - ${invoiceDate}
                    </option>`;
                });

                invoiceDropdownContainer.innerHTML = `
                    <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg">
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="material-icons text-sm align-middle mr-1">receipt</i>
                            Invoice to Reverse *
                        </label>
                        <select id="invoiceSelect" name="InvoiceId" required 
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500">
                            ${invoiceOptions}
                        </select>
                        <p class="text-xs text-gray-600 mt-2">
                            <i class="material-icons text-xs align-middle">info</i>
                            Select the invoice you are reversing with this credit note
                        </p>
                    </div>
                `;
                invoiceDropdownContainer.classList.remove('hidden');
        
                // Add event listener to populate reference number and amount when invoice is selected
                document.getElementById('invoiceSelect').addEventListener('change', function() {
                    const selectedOption = this.options[this.selectedIndex];
                    const invoiceNumber = selectedOption.getAttribute('data-invoice-number');
                    const amount = selectedOption.getAttribute('data-amount');
    
                    const amountInput = document.getElementById('amount');
    
                    if (this.value) {
                        // Auto-populate reference number
                        const refInput = document.getElementById('referenceNumber');
                        if (refInput && refInput.value === '') {
                            refInput.value = invoiceNumber + '-CRN';
                        }
        
                        // Auto-populate amount with outstanding amount and set max
                        if (amountInput && amount) {
                            const invoiceAmount = parseFloat(amount);
                            if (amountInput.value === '') {
                                amountInput.value = invoiceAmount.toFixed(2);
                            }
                            // Set max attribute to invoice amount
                            amountInput.setAttribute('max', invoiceAmount.toFixed(2));
                        }
                    } else {
                        // Remove max attribute when no invoice is selected
                        if (amountInput) {
                            amountInput.removeAttribute('max');
                        }
                    }
                });
            } else {
                invoiceDropdownContainer.innerHTML = `
                    <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg">
                        <p class="text-sm text-gray-600">
                            <i class="material-icons text-sm align-middle mr-1">info</i>
                            No invoices found for this student
                        </p>
                    </div>
                `;
                invoiceDropdownContainer.classList.remove('hidden');
            }
        }

        function displayFileName(input) {
            const fileNameDisplay = document.getElementById('fileNameDisplay');
            const fileName = document.getElementById('fileName');

            if (input.files && input.files[0]) {
                const file = input.files[0];
                const fileSize = file.size / 1024 / 1024;

                if (fileSize > 5) {
                    alert('File size exceeds 5 MB. Please upload a smaller file.');
                    input.value = '';
                    fileNameDisplay.classList.add('hidden');
                    return;
                }

                fileName.textContent = file.name;
                fileNameDisplay.classList.remove('hidden');
            }
        }

        function clearFile() {
            document.getElementById('proofOfDocument').value = '';
            document.getElementById('fileNameDisplay').classList.add('hidden');
        }

        function displayGroupFileName(input) {
            const fileNameDisplay = document.getElementById('groupFileNameDisplay');
            const fileName = document.getElementById('groupFileName');

            if (input.files && input.files[0]) {
                const file = input.files[0];
                const fileSize = file.size / 1024 / 1024;

                if (fileSize > 5) {
                    alert('File size exceeds 5 MB. Please upload a smaller file.');
                    input.value = '';
                    fileNameDisplay.classList.add('hidden');
                    return;
                }

                fileName.textContent = file.name;
                fileNameDisplay.classList.remove('hidden');
            }
        }

        function clearGroupFile() {
            document.getElementById('groupProofOfDocument').value = '';
            document.getElementById('groupFileNameDisplay').classList.add('hidden');
        }

        document.getElementById('creditNoteForm').addEventListener('submit', function(e) {
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="material-icons animate-spin mr-2">refresh</i>Processing...';
        });

        async function loadCreditNotesList() {
            const searchTerm = document.getElementById('searchBox').value;
            const startDate = document.getElementById('dateStart').value;
            const endDate = document.getElementById('dateEnd').value;
            const status = document.getElementById('statusBox').value;

            const params = new URLSearchParams({
                pageNumber: currentPage,
                pageSize: currentPageSize,
                searchTerm: searchTerm || '',
                startDate: startDate || '',
                endDate: endDate || '',
                status: status || ''
            });

            try {
                const response = await fetch(`/Admin/GetCreditNotesList?${params.toString()}`);
                const data = await response.json();
                displayCreditNotesList(data);
                updatePagination(data);
            } catch (error) {
                console.error('Error loading credit notes:', error);
            }
        }

        function displayCreditNotesList(data) {
            const tbody = document.getElementById('creditNoteTableBody');

            if (!data.items || data.items.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" class="px-6 py-8 text-center text-gray-500"><i class="material-icons text-4xl text-gray-300 mb-2">inbox</i><p>No credit notes found</p></td></tr>';
                document.getElementById('countText').textContent = 'No records';
                return;
            }

            tbody.innerHTML = data.items.map(p => `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        <div>
                            <div class="font-medium">${new Date(p.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
                            <div class="text-gray-500 text-xs">${new Date(p.createdAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}</div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        ${p.transactionDate ? `
                            <div>
                                <div class="font-medium">${new Date(p.transactionDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
                                <div class="text-gray-500 text-xs">${new Date(p.transactionDate).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}</div>
                            </div>
                        ` : '<span class="text-gray-400">N/A</span>'}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 py-1 text-xs font-mono bg-red-100 text-red-800 rounded">${p.merchantTransactionId}</span>
                        ${p.isGroupPayment === '1' ? `<div class="text-xs text-red-600 mt-1 flex items-center"><i class="material-icons text-xs mr-1">group</i>${p.groupPaymentReference}</div>` : ''}
                    </td>
                    <td class="px-6 py-4">
                        <div class="text-sm">
                            <div class="font-medium text-gray-900">${p.fullName || 'N/A'}</div>
                            <div class="text-gray-500">${p.accountNumber}</div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="text-sm font-semibold text-red-600">K ${parseFloat(p.amount).toFixed(2)}</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${p.referenceNumber || 'N/A'}</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center text-sm text-gray-900">
                            <i class="material-icons text-sm mr-1 text-gray-500">person</i>
                            ${p.postedBy || 'Admin'}
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                        <div class="flex gap-2">
                            <button onclick='printCreditNote(${JSON.stringify({
                                studentName: p.fullName,
                                studentNumber: p.accountNumber,
                                amount: p.amount,
                                reference: p.referenceNumber,
                                transactionId: p.merchantTransactionId,
                                reason: p.callbackPayload,
                                date: p.transactionDate,
                                postedBy: p.postedBy,
                                isCreditNote: true
                            })})' class="inline-flex items-center px-3 py-1 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                                <i class="material-icons text-sm mr-1">print</i>
                                Print
                            </button>
                            ${p.proofOfPaymentPath ? `
                                <button onclick="viewDocument('${p.proofOfPaymentPath}', '${p.merchantTransactionId}')" class="inline-flex items-center px-3 py-1 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                                    <i class="material-icons text-sm mr-1">visibility</i>
                                    View
                                </button>
                            ` : ''}
                        </div>
                    </td>
                </tr>
            `).join('');

            document.getElementById('countText').textContent =
                `Showing ${((currentPage - 1) * currentPageSize) + 1} to ${Math.min(currentPage * currentPageSize, data.totalCount)} of ${data.totalCount} records`;
        }

        function updatePagination(data) {
            document.getElementById('paginationInfo').textContent = `Page ${data.pageNumber} of ${data.totalPages}`;
            document.getElementById('prevBtn').disabled = !data.hasPreviousPage;
            document.getElementById('nextBtn').disabled = !data.hasNextPage;
        }

        function goToPrevPage() {
            if (currentPage > 1) {
                currentPage--;
                loadCreditNotesList();
            }
        }

        function goToNextPage() {
            currentPage++;
            loadCreditNotesList();
        }

        function changePageSize() {
            currentPageSize = parseInt(document.getElementById('pageSizeBox').value);
            currentPage = 1;
            loadCreditNotesList();
        }

        function applyFilters() {
            currentPage = 1;
            loadCreditNotesList();
        }

        function clearFilters() {
            document.getElementById('searchBox').value = '';
            document.getElementById('statusBox').value = '';
            setTodayDate();
            currentPage = 1;
            loadCreditNotesList();
        }

        function viewDocument(path, txnId) {
            const modal = document.getElementById('documentModal');
            const content = document.getElementById('documentContent');
            const modalTxnId = document.getElementById('modalTxnId');
            const downloadBtn = document.getElementById('downloadDocumentBtn');

            modalTxnId.textContent = txnId;
            downloadBtn.href = path;
            
            modal.classList.remove('hidden');
            
            const fileExtension = path.split('.').pop().toLowerCase();
            
            if (fileExtension === 'pdf') {
                content.innerHTML = `<iframe src="${path}" class="w-full rounded-lg" style="height: 600px;" frameborder="0"></iframe>`;
            } else if (['jpg', 'jpeg', 'png'].includes(fileExtension)) {
                content.innerHTML = `<img src="${path}" alt="Supporting Document" class="max-w-full h-auto rounded-lg mx-auto" style="max-height: 600px;" />`;
            } else {
                content.innerHTML = `
                    <div class="text-center py-12">
                        <i class="material-icons text-6xl text-gray-400 mb-4">description</i>
                        <p class="text-gray-600 mb-4">Cannot preview this file type</p>
                        <a href="${path}" target="_blank" class="inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
                            <i class="material-icons text-sm mr-2">open_in_new</i>
                            Open in New Tab
                        </a>
                    </div>
                `;
            }
        }

        function closeDocumentModal() {
            document.getElementById('documentModal').classList.add('hidden');
        }

        document.getElementById('documentModal').addEventListener('click', function(e) {
            if (e.target === this) closeDocumentModal();
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeDocumentModal();
        });
    </script>
}
