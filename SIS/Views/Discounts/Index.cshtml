@model IEnumerable<SIS.Models.Payments.OnlinePayments>

@{
    ViewData["Title"] = "Credit Note Entry";
}

<div class="min-h-screen p-4 bg-gray-50">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-red-800 flex items-center">
            <i class="material-icons mr-2 text-red-600">receipt</i>
            Credit Note Entry
        </h1>
    </div>

    <!-- Tab Navigation -->
    <div class="mb-6">
        <div class="border-b border-gray-200">
            <nav class="-mb-px flex space-x-8">
                <button onclick="switchTab('entry')" id="entryTab" class="tab-button active border-b-2 border-red-600 py-4 px-1 text-sm font-medium text-red-600">
                    <i class="material-icons text-sm align-middle mr-1">person</i>
                    New Credit Note
                </button>
                <button onclick="switchTab('group')" id="groupTab" class="tab-button border-b-2 border-transparent py-4 px-1 text-sm font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300">
                    <i class="material-icons text-sm align-middle mr-1">group</i>
                    Group Credit Note
                </button>
                <button onclick="switchTab('recent')" id="recentTab" class="tab-button border-b-2 border-transparent py-4 px-1 text-sm font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300">
                    <i class="material-icons text-sm align-middle mr-1">receipt_long</i>
                    Recent Credit Notes
                </button>
            </nav>
        </div>
    </div>

    <!-- Entry Tab -->
    <div id="entryContent" class="tab-content">
        <div class="flex gap-4">
            <!-- Credit Note Form Section (2/3 width) -->
            <div class="w-2/3">
                <div class="bg-white rounded-lg shadow-lg overflow-hidden border border-gray-100">
                    <div class="p-6">
                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg flex items-start">
                                <i class="material-icons text-green-600 mr-3">check_circle</i>
                                <div class="flex-1">
                                    <p class="text-green-800 font-medium">Success!</p>
                                    <p class="text-green-700 text-sm">@TempData["SuccessMessage"]</p>
                                </div>
                                @if (TempData["LastCreditNoteData"] != null)
                                {
                                    <button onclick='printCreditNote(@Html.Raw(TempData["LastCreditNoteData"]))' class="ml-3 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center">
                                        <i class="material-icons text-sm mr-2">print</i>
                                        Print Credit Note
                                    </button>
                                }
                            </div>
                        }

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start">
                                <i class="material-icons text-red-600 mr-3">error</i>
                                <div>
                                    <p class="text-red-800 font-medium">Error!</p>
                                    <p class="text-red-700 text-sm">@TempData["ErrorMessage"]</p>
                                </div>
                            </div>
                        }

                        <!-- Student Verification Alert -->
                        <div id="studentVerification" class="hidden mb-4"></div>

                        <form method="post" asp-controller="Admin" asp-action="ProcessCreditNote" enctype="multipart/form-data" id="creditNoteForm">
                            @Html.AntiForgeryToken()

                            <div class="grid grid-cols-2 gap-6">
                                <!-- Student Number with Verification -->
                                <div class="relative z-0 w-full group">
                                    <div class="flex items-center gap-2">
                                        <div class="flex-1">
                                            <input type="text" name="StudentNumber" id="studentNumber"
                                                   class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                                                   placeholder=" " required onblur="verifyStudent()" />
                                            <label for="studentNumber" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                                Student Number *
                                            </label>
                                        </div>
                                        <button type="button" onclick="verifyStudent()" class="mt-2 p-2 text-red-600 hover:bg-red-50 rounded-full transition-colors" title="Verify Student">
                                            <i class="material-icons">search</i>
                                        </button>
                                    </div>
                                </div>

                                <!-- Student Name -->
                                <div class="relative z-0 w-full group">
                                    <input type="text" name="ConsumerName" id="consumerName"
                                           class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                                           placeholder=" " required />
                                    <label for="consumerName" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Student Name *
                                    </label>
                                </div>
                                <!-- Invoice -->
                                <div id="invoiceDropdownContainer" class="hidden col-span-2"></div>
                                <!-- Amount -->
                                <div class="relative z-0 w-full group">
                                    <input type="number" name="Amount" id="amount" step="0.01" min="0"
                                           class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                                           placeholder=" " required />
                                    <label for="amount" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Amount (ZMW) *
                                    </label>
                                </div>

                                <!-- Reference Number -->
                                <div class="relative z-0 w-full group">
                                    <input type="text" name="ReferenceNumber" id="referenceNumber"
                                           class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                                           placeholder=" " required />
                                    <label for="referenceNumber" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Credit Note Reference Number *
                                    </label>
                                </div>

                                <!-- Reason -->
                                <div class="relative z-0 w-full group col-span-2">
                                    <textarea name="Reason" id="reason" rows="3"
                                              class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                                              placeholder=" " required></textarea>
                                    <label for="reason" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Reason for Credit Note *
                                    </label>
                                </div>

                                <!-- Transaction Date -->
                                <div class="relative z-0 w-full group">
                                    <input type="date" name="TransactionDate" id="transactionDate"
                                           value="@DateTime.Now.ToString("yyyy-MM-dd")"
                                           max="@DateTime.Now.ToString("yyyy-MM-dd")"
                                           class="block py-3 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-red-600 peer"
                                           required />
                                    <label for="transactionDate" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-red-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                        Transaction Date *
                                    </label>
                                </div>
                            </div>

                            <!-- Supporting Document Upload -->
                            <div class="mt-6 p-4 bg-gray-50 rounded-lg border border-gray-200">
                                <h4 class="text-md font-semibold text-gray-800 mb-2 flex items-center">
                                    <i class="material-icons text-red-600 mr-2">attach_file</i>
                                    Supporting Document
                                    <span class="ml-2 text-xs font-normal text-gray-500">(Optional)</span>
                                </h4>
                                <div class="space-y-3">
                                    <div class="flex items-center justify-center w-full">
                                        <label for="proofOfDocument" class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-white hover:bg-gray-50 transition-colors">
                                            <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                                <i class="material-icons text-4xl text-gray-400 mb-2">cloud_upload</i>
                                                <p class="mb-2 text-sm text-gray-500">
                                                    <span class="font-semibold">Click to upload</span> or drag and drop
                                                </p>
                                                <p class="text-xs text-gray-500">PDF, JPG, PNG (MAX. 5MB) - Optional</p>
                                            </div>
                                            <input id="proofOfDocument" name="ProofOfDocument" type="file" class="hidden" accept=".pdf,.jpg,.jpeg,.png" onchange="displayFileName(this)" />
                                        </label>
                                    </div>
                                    <div id="fileNameDisplay" class="hidden">
                                        <div class="flex items-center p-3 bg-red-50 border border-red-200 rounded-lg">
                                            <i class="material-icons text-red-600 mr-2">description</i>
                                            <span id="fileName" class="text-sm text-gray-700 font-medium"></span>
                                            <button type="button" onclick="clearFile()" class="ml-auto text-red-600 hover:text-red-800">
                                                <i class="material-icons text-sm">close</i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Submit Buttons -->
                            <div class="mt-6 flex space-x-3">
                                <button type="submit" id="submitBtn" class="flex-1 px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors flex items-center justify-center shadow-md hover:shadow-lg">
                                    <i class="material-icons mr-2">check_circle</i>
                                    Submit Credit Note
                                </button>
                                <a href="@Url.Action("Index", "Home")" class="px-6 py-3 text-gray-700 bg-white hover:bg-gray-100 rounded-lg transition-colors flex items-center border border-gray-300">
                                    <i class="material-icons mr-2">close</i>
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Instructions Sidebar (1/3 width) -->
            <div class="w-1/3 space-y-4">
                <!-- Instructions Card -->
                <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-100">
                    <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                        <i class="material-icons text-red-600 mr-2">info</i>
                        Credit Note Instructions
                    </h3>
                    <div class="space-y-4">
                        <div class="flex items-start">
                            <div class="flex-shrink-0">
                                <div class="flex items-center justify-center w-8 h-8 bg-red-100 rounded-full">
                                    <span class="text-red-700 font-bold text-sm">1</span>
                                </div>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-gray-700">Enter student number - system will verify if student exists</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="flex-shrink-0">
                                <div class="flex items-center justify-center w-8 h-8 bg-red-100 rounded-full">
                                    <span class="text-red-700 font-bold text-sm">2</span>
                                </div>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-gray-700">Enter the credit note amount in ZMW</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="flex-shrink-0">
                                <div class="flex items-center justify-center w-8 h-8 bg-red-100 rounded-full">
                                    <span class="text-red-700 font-bold text-sm">3</span>
                                </div>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-gray-700">Provide a clear reason for the credit note</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="flex-shrink-0">
                                <div class="flex items-center justify-center w-8 h-8 bg-red-100 rounded-full">
                                    <span class="text-red-700 font-bold text-sm">4</span>
                                </div>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-gray-700">Upload supporting documentation (optional)</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="flex-shrink-0">
                                <div class="flex items-center justify-center w-8 h-8 bg-red-100 rounded-full">
                                    <span class="text-red-700 font-bold text-sm">5</span>
                                </div>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-gray-700">Print the credit note after successful submission</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Important Notice -->
                <div class="bg-amber-50 border border-amber-200 rounded-lg p-6">
                    <div class="flex items-start">
                        <i class="material-icons text-amber-600 mr-3 text-2xl">warning</i>
                        <div>
                            <h4 class="text-amber-900 font-semibold mb-2">Important Notice</h4>
                            <ul class="text-sm text-amber-800 space-y-1">
                                <li>• All fields except document are required</li>
                                <li>• Student must exist in system</li>
                                <li>• Supporting document is optional</li>
                                <li>• File size must not exceed 5MB</li>
                                <li>• Accepted formats: PDF, JPG, PNG</li>
                                <li>• Credit notes are final</li>
                                <li>• Processing may take a few moments</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Support Card -->
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
                    <div class="flex items-start">
                        <i class="material-icons text-blue-600 mr-3 text-2xl">help</i>
                        <div>
                            <h4 class="text-blue-900 font-semibold mb-2">Need Help?</h4>
                            <p class="text-sm text-blue-800 mb-3">Contact the Finance Office for assistance with credit note processing.</p>
                            <a href="mailto:finance@edenuniversity.edu.zm" class="text-sm text-blue-600 hover:text-blue-800 font-medium flex items-center">
                                <i class="material-icons text-sm mr-1">email</i>
                                finance@edenuniversity.edu.zm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Group Credit Note Tab -->
    <div id="groupContent" class="tab-content hidden">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden border border-gray-100">
            <div class="p-6">
                <h3 class="text-xl font-semibold text-gray-900 mb-4">Submit Group Credit Note</h3>

                <form method="post" asp-action="ProcessGroupCreditNote" enctype="multipart/form-data" id="groupForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="StudentNumbers" id="hiddenStudentNumbers" />
                    <input type="hidden" name="StudentAmounts" id="hiddenStudentAmounts" />

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Group Credit Note Reference (Optional)</label>
                            <input type="text" name="GroupCreditNoteReference" id="groupRef" class="w-full px-3 py-2 border border-gray-300 rounded-md" placeholder="Auto-generated if empty">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Reason <span class="text-red-500">*</span></label>
                            <textarea name="Reason" id="groupReason" required class="w-full px-3 py-2 border border-gray-300 rounded-md" rows="1"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Transaction Date <span class="text-red-500">*</span></label>
                            <input type="date" name="TransactionDate" id="groupDate" required class="w-full px-3 py-2 border border-gray-300 rounded-md">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="material-icons text-sm align-middle mr-1">attach_file</i>
                            Supporting Document (Optional - PDF, JPG, PNG, Max 5MB)
                        </label>
                        <label class="flex items-center px-4 py-3 bg-white border-2 border-dashed border-gray-300 rounded-lg cursor-pointer hover:border-red-400 transition-colors">
                            <i class="material-icons text-gray-400 mr-2">cloud_upload</i>
                            <span class="text-sm text-gray-600">Choose file or drag here</span>
                            <input type="file" name="ProofOfDocument" id="groupProofOfDocument"
                                   class="hidden" accept=".pdf,.jpg,.jpeg,.png"
                                   onchange="displayGroupFileName(this)" />
                        </label>
                        <div id="groupFileNameDisplay" class="hidden mt-2 p-3 bg-blue-50 rounded-lg flex items-center justify-between">
                            <div class="flex items-center">
                                <i class="material-icons text-blue-600 mr-2">description</i>
                                <span id="groupFileName" class="text-sm text-blue-800"></span>
                            </div>
                            <button type="button" onclick="clearGroupFile()" class="text-red-600 hover:text-red-800">
                                <i class="material-icons text-sm">close</i>
                            </button>
                        </div>
                    </div>

                    <div class="border-t pt-4">
                        <div class="flex justify-between items-center mb-3">
                            <h4 class="text-lg font-semibold text-gray-800">Students</h4>
                            <button type="button" onclick="addStudentRow()" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">
                                <i class="material-icons text-sm align-middle mr-1">add</i> Add Student
                            </button>
                        </div>
                        <div id="studentsBox" class="space-y-3 max-h-96 overflow-y-auto"></div>
                    </div>

                    <div class="mt-4 p-3 bg-gray-50 rounded-md">
                        <div class="flex justify-between items-center">
                            <span class="text-lg font-semibold text-gray-700">Total Amount:</span>
                            <span id="groupTotal" class="text-2xl font-bold text-red-600">K 0.00</span>
                        </div>
                    </div>

                    <div class="flex justify-end space-x-3 mt-6 pt-4 border-t">
                        <button type="button" onclick="resetGroupForm()" class="px-4 py-2 bg-gray-200 text-gray-800 rounded-md hover:bg-gray-300">Reset</button>
                        <button type="submit" id="groupSubmitBtn" class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700">
                            <i class="material-icons text-sm align-middle mr-1">check</i> Submit Group Credit Note
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Recent Credit Notes Tab -->
    <div id="recentContent" class="tab-content hidden">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden border border-gray-100">
            <div class="p-6 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center mb-4">
                    <i class="material-icons mr-2 text-red-600">today</i>
                    Recent Credit Notes
                </h3>

                <!-- Filters -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Search</label>
                        <input type="text" id="searchBox" placeholder="Student number, name..." class="w-full px-3 py-2 border border-gray-300 rounded-md">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Start Date</label>
                        <input type="date" id="dateStart" class="w-full px-3 py-2 border border-gray-300 rounded-md">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">End Date</label>
                        <input type="date" id="dateEnd" class="w-full px-3 py-2 border border-gray-300 rounded-md">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                        <select id="statusBox" class="w-full px-3 py-2 border border-gray-300 rounded-md">
                            <option value="">All</option>
                            <option value="Paid">Paid</option>
                            <option value="Pending">Pending</option>
                            <option value="Failed">Failed</option>
                        </select>
                    </div>
                </div>

                <div class="flex justify-between items-center">
                    <div class="flex space-x-2">
                        <button onclick="applyFilters()" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">
                            <i class="material-icons text-sm align-middle mr-1">search</i> Apply
                        </button>
                        <button onclick="clearFilters()" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-md hover:bg-gray-300">
                            <i class="material-icons text-sm align-middle mr-1">clear</i> Clear
                        </button>
                    </div>
                    <span id="countText" class="text-sm text-gray-600">Loading...</span>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Submitted At</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Transaction Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Transaction ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reference</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Posted By</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="creditNoteTableBody" class="bg-white divide-y divide-gray-200">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var creditNote in Model)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                        <div>
                                            <div class="font-medium">@creditNote.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                            <div class="text-gray-500 text-xs">@creditNote.CreatedAt.ToLocalTime().ToString("hh:mm tt")</div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                        @if (creditNote.TransactionDate.HasValue)
                                        {
                                            <div>
                                                <div class="font-medium">@creditNote.TransactionDate.Value.ToString("MMM dd, yyyy")</div>
                                                <div class="text-gray-500 text-xs">@creditNote.TransactionDate.Value.ToString("hh:mm tt")</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400">N/A</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-2 py-1 text-xs font-mono bg-red-100 text-red-800 rounded">
                                            @creditNote.MerchantTransactionId
                                        </span>
                                        @if (creditNote.IsGroupPayment == "1")
