@inject SIS.Services.IInstitutionConfigService InstitutionConfig

@{
    var institution = InstitutionConfig.GetCurrentInstitution();
}



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eCampus</title>
    <link href="https://cdn.lineicons.com/4.0/lineicons.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Include DataTables CSS -->
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/dataTables.tailwindcss.min.css">
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@latest/dist/style.css" rel="stylesheet" type="text/css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Intl Tel Input library for phone input -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.13/css/intlTelInput.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.13/js/intlTelInput.min.js"></script>

    <!-- Select2 for searchable dropdowns -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- Choices.js for searchable dropdowns -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>

    <!-- Quill.js -->
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

    <!-- KaTeX for math equations -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>

    <!-- Quill Formula Module -->
    <script src="https://cdn.jsdelivr.net/npm/quill-formula@1.0.0/dist/formula.min.js"></script>
    <link rel="stylesheet" href="~/css/tailwind.css">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Poppins', 'ui-sans-serif', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50:  '#fdf2f2',
                            100: '#fce4e4',
                            200: '#f9cccc',
                            300: '#f4a4a4',
                            400: '#ed7a7a',
                            500: '#e85c5c',
                            600: '#d43a3a',
                            700: '#c94040',
                            800: '#942828',
                            900: '#7a2626',
                            950: '#420f0f'
                        },
                        secondary: {
                            50:  '#f0f4f8',
                            100: '#e2e8f0',
                            200: '#cbd5e1',
                            300: '#94a3b8',
                            400: '#64748b',
                            500: '#475569',
                            600: '#334155',
                            700: '#1e293b',
                            800: '#1a2f45',
                            900: '#0e2238',
                            950: '#070f1a'
                        }
                    }
                }
            }
        }
    </script>

    <!-- Keep necessary third-party CSS -->
    <link href="https://cdn.datatables.net/1.13.5/css/jquery.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/buttons/2.3.8/css/buttons.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">

    @RenderSection("Styles", required: false)

    @Html.AntiForgeryToken()
</head>
<body class="bg-slate-50 font-sans">
    <div class="min-h-screen flex">
        <!-- Sidebar -->
        <aside id="sidebar" class="fixed inset-y-0 left-0 bg-primary-50 text-white w-72 transform transition-transform duration-200 ease-in-out -translate-x-full lg:translate-x-0 z-50 shadow-lg">
            <!-- Sidebar Header -->
            <div class="flex items-center justify-between h-16 px-4 border-b border-primary-700">
                <div class="flex items-center gap-2">
                    <button id="sidebar-toggle" class="p-2 rounded-lg hover:bg-primary-700 lg:hidden">
                        <i class="lni lni-grid-alt text-xl"></i>
                    </button>
                    <a href="#" class="text-xl font-bold flex items-center">
                        <!-- Dynamic Institution Logo -->
                        <img src="@($"{institution.ContactInfo?.Website?.TrimEnd('/')}{institution.LogoPath}")"
                             alt="@institution.Name Logo"
                             class="h-8 w-auto mr-3">

                        <span class="text-secondary-600">Edu<span class="text-lg text-secondary-500">Max</span></span>
                    </a>
                </div>
            </div>

            <!-- Sidebar Content -->
            <div class="py-2 flex flex-col h-[calc(100vh-4rem)] overflow-y-auto">
                <div class="px-4 py-2 text-xs font-semibold text-secondary-500 @* text-primary-200 *@ uppercase tracking-wider">
                    Main
                </div>

                <!-- Navigation partial will go here -->
                <partial name="_Navigation" />

                <div class="mt-auto p-4 border-t border-primary-700">
                    <div class="bg-primary-700/50 rounded-lg p-3">
                        <div class="flex items-center mb-3">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-800 to-secondary-700 flex items-center justify-center mr-3">
                                @* <span class="text-white text-sm font-medium">
                                    @(User.Identity?.Name?[0].ToString().ToUpper() ?? "U")
                                </span> *@
                            </div>
                            <div>
                                <div class="text-sm font-medium text-white">
                                    @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value ?? User.Identity?.Name)
                                </div>
                                <div class="text-xs text-primary-200">
                                    @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Member")
                                </div>
                            </div>
                        </div>
                        <a asp-controller="Account" asp-action="Logout"
                           class="flex items-center justify-center gap-2 w-full py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-md text-sm font-medium transition-colors">
                            <i class="material-icons text-sm">logout</i>
                            <span>Sign out</span>
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 lg:ml-72 flex flex-col">
            <!-- Top Navigation Bar -->
            <nav class="sticky top-0 z-40 bg-white border-b border-slate-200 shadow-sm">
                <div class="h-16 flex items-center justify-between px-4">
                    <!-- Left Side -->
                    <div class="flex items-center gap-4">
                        <button id="mobile-menu" class="p-2 rounded-lg hover:bg-slate-100 lg:hidden">
                            <i class="material-icons">menu</i>
                        </button>

                        <!-- Breadcrumb -->
                        <div class="hidden md:flex items-center text-sm">
                            <a href="/" class="text-slate-500 hover:text-primary-700">EduMax</a>
                            <span class="mx-2 text-slate-400">/</span>
                            <span class="font-medium text-slate-800">@ViewData["Title"]</span>
                        </div>
                    </div>

                    <div class="flex items-center gap-4">
                        @* <!-- Search Bar -->
                        <div class="hidden md:flex items-center">
                            <div class="relative">
                                <input type="search"
                                       placeholder="Search..."
                                       class="w-64 pl-10 pr-4 py-2 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-sm" />
                                <i class="material-icons absolute left-3 top-2 text-slate-400 text-sm">search</i>
                            </div>
                        </div> *@

                        <!-- Action Buttons -->
                        <div class="flex items-center gap-2">
                            @* <!-- Notification Button -->
                            <div class="relative">
                                <button class="p-2 rounded-lg hover:bg-slate-100 transition-all duration-200 relative">
                                    <i class="material-icons text-slate-600">notifications</i>
                                    <span class="absolute -top-0.5 -right-0.5 w-2 h-2 bg-secondary-500 rounded-full border-2 border-white"></span>
                                </button>
                            </div>

                            <!-- Settings Button -->
                            <button class="p-2 rounded-lg hover:bg-slate-100 transition-all duration-200">
                                <i class="material-icons text-slate-600">settings</i>
                            </button> *@

                            <!-- Profile Button -->
                            <div class="relative">
                                <button onclick="toggleDropdown()"
                                        class="flex items-center gap-3 pl-2 pr-1 py-1 rounded-lg hover:bg-slate-100 transition-all duration-200">
                                    <div class="relative">
                                        <div class="h-8 w-8 rounded-full bg-gradient-to-br from-primary-700 to-secondary-600 flex items-center justify-center">
                                            <span class="text-white text-sm font-medium">
                                                @(User.Identity?.Name?[0].ToString().ToUpper() ?? "U")
                                            </span>
                                        </div>
                                        <span class="absolute -bottom-1 -right-1 w-3 h-3 bg-green-400 rounded-full border-2 border-white"></span>
                                    </div>
                                    <i class="material-icons text-slate-400 text-lg">expand_more</i>
                                </button>

                                <!-- Dropdown Menu -->
                                <div id="userDropdown"
                                     class="hidden absolute right-0 top-full mt-1 w-56 bg-white rounded-lg shadow-lg border border-slate-200 py-1.5 z-50">
                                    <!-- User Info -->
                                    <div class="px-4 py-2 border-b border-slate-100">
                                        <div class="text-sm font-semibold text-slate-800">
                                            @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value ?? User.Identity?.Name)
                                        </div>
                                        <div class="text-xs text-slate-500">
                                            @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Member")
                                        </div>
                                    </div>

                                    <!-- Menu Items -->
                                    @* <a asp-controller="Profile" asp-action="Index" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors duration-200">
                                        <i class="material-icons text-slate-400 text-lg">person</i>
                                        Profile
                                    </a>
                                    <a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors duration-200">
                                        <i class="material-icons text-slate-400 text-lg">settings</i>
                                        Settings
                                    </a>

                                    <div class="h-px bg-slate-100 mx-3 my-1"></div> *@

                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <a asp-controller="Account" asp-action="Logout"
                                           class="flex items-center gap-3 px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors duration-200">
                                            <i class="material-icons text-red-500 text-lg">logout</i>
                                            Logout
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Page Content -->
            <main class="flex-1 overflow-x-hidden overflow-y-auto bg-slate-50 flex flex-col min-h-screen">

                <!-- Main Content Area -->
                <div class="p-2 flex-1">
                    @RenderBody()
                    <partial name="_Toast" />
                </div>

                <!-- Footer -->
                <footer class="bg-white border-t border-slate-200 px-6 py-4 mt-auto">
                    <div class="flex flex-col md:flex-row justify-between items-center">
                        <div class="text-sm text-slate-500">
                            &copy; @DateTime.Now.Year EduMax. All rights reserved.
                        </div>
                        <div class="text-sm text-slate-500 mt-2 md:mt-0">
                            Version 1.0.0
                        </div>
                    </div>
                </footer>
            </main>
        </div>
    </div>

    <!-- Required Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@2.8.2/dist/alpine.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

    <!-- Include DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.tailwindcss.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/simple-datatables@latest"></script>

    <!-- DataTables and related plugins -->
    <script src="https://cdn.datatables.net/buttons/2.3.8/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.3.8/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.3.8/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script>
        const currentPath = window.location.pathname;
        // Sidebar Toggle
        document.getElementById('mobile-menu').addEventListener('click', function() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('-translate-x-full');
        });

        document.getElementById('sidebar-toggle').addEventListener('click', function() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('-translate-x-full');
        });

        // User dropdown toggle
        function toggleDropdown() {
            const dropdown = document.getElementById('userDropdown');
            dropdown.classList.toggle('hidden');

            // Close dropdown when clicking outside
            document.addEventListener('click', function closeDropdown(e) {
                if (!e.target.closest('.relative')) {
                    dropdown.classList.add('hidden');
                    document.removeEventListener('click', closeDropdown);
                }
            });
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            const dropdown = document.getElementById('userDropdown');
            if (dropdown && !dropdown.classList.contains('hidden')) {
                if (!e.target.closest('.relative')) {
                    dropdown.classList.add('hidden');
                }
            }
        });

        // Add active class to current nav item
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('#sidebar a');

            navLinks.forEach(link => {
                const href = link.getAttribute('href');
                if (href === currentPath || currentPath.startsWith(href) && href !== '/') {
                    link.classList.add('bg-primary-700', 'text-white');
                    link.classList.remove('text-primary-100');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>