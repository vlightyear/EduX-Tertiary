<!-- _ApplicantDetails.cshtml -->
@model SIS.Models.HostelManager.ApplicantDetailViewModel

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6" data-has-allocation="@Model.HasAllocation">
    <!-- Student Basic Information -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 mb-6">
            <h4 class="text-lg font-semibold text-gray-700 mb-4">Student Information</h4>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <p class="text-sm text-gray-500">Full Name</p>
                    <p class="font-medium">@Model.StudentName</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Student ID</p>
                    <p class="font-medium">@Model.MatricNumber</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Email</p>
                    <p class="font-medium">@Model.Email</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Phone</p>
                    <p class="font-medium">@Model.Phone</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Gender</p>
                    <p class="font-medium">@Model.Gender</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Date of Birth</p>
                    <p class="font-medium">@Model.DateOfBirth.ToString("dd MMMM yyyy")</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Nationality</p>
                    <p class="font-medium">
                        @Model.Nationality
                        @if (Model.IsInternational)
                        {
                            <span class="ml-2 px-2 py-0.5 bg-purple-100 text-purple-800 text-xs rounded-full">
                                International
                            </span>
                        }
                    </p>
                </div>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Academic Information -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
                <h4 class="text-lg font-semibold text-gray-700 mb-4">Academic Information</h4>
                
                <div class="space-y-3">
                    <div>
                        <p class="text-sm text-gray-500">Programme</p>
                        <p class="font-medium">@Model.Programme</p>
                    </div>
                    
                    <div>
                        <p class="text-sm text-gray-500">School</p>
                        <p class="font-medium">@Model.School</p>
                    </div>
                    
                    <div>
                        <p class="text-sm text-gray-500">Mode of Study</p>
                        <p class="font-medium">@Model.ModeOfStudy</p>
                    </div>
                    
                    <div>
                        <p class="text-sm text-gray-500">Programme Level</p>
                        <p class="font-medium">@Model.ProgrammeLevel</p>
                    </div>
                    
                    <div>
                        <p class="text-sm text-gray-500">Year of Study</p>
                        <p class="font-medium">Year @Model.YearOfStudy</p>
                    </div>
                </div>
            </div>
            
            <!-- Contact Information -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
                <h4 class="text-lg font-semibold text-gray-700 mb-4">Contact Information</h4>
                
                <div class="space-y-3">
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div>
                            <p class="text-sm text-gray-500">Address</p>
                            <p class="font-medium">@Model.Address</p>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(Model.City))
                    {
                        <div>
                            <p class="text-sm text-gray-500">City</p>
                            <p class="font-medium">@Model.City</p>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(Model.Country))
                    {
                        <div>
                            <p class="text-sm text-gray-500">Country</p>
                            <p class="font-medium">@Model.Country</p>
                        </div>
                    }
                    
                    <div class="pt-2 border-t border-gray-200">
                        <h5 class="text-sm font-medium text-gray-700 mb-2">Next of Kin</h5>
                        
                        @if (!string.IsNullOrEmpty(Model.NextOfKinName))
                        {
                            <div>
                                <p class="text-sm text-gray-500">Name</p>
                                <p class="font-medium">@Model.NextOfKinName</p>
                            </div>
                            
                            <div class="flex space-x-4 mt-2">
                                <div>
                                    <p class="text-sm text-gray-500">Phone</p>
                                    <p class="font-medium">@Model.NextOfKinPhone</p>
                                </div>
                                
                                <div>
                                    <p class="text-sm text-gray-500">Relationship</p>
                                    <p class="font-medium">@Model.NextOfKinRelationship</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-sm text-gray-500">No next of kin information available</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Application Information -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 mb-6">
            <h4 class="text-lg font-semibold text-gray-700 mb-4">Application Details</h4>
            
            <div class="space-y-3">
                <div>
                    <p class="text-sm text-gray-500">Application ID</p>
                    <p class="font-medium">@Model.ApplicationId</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Date Applied</p>
                    <p class="font-medium">@Model.ApplicationDate.ToString("dd MMMM yyyy")</p>
                </div>
                
                <div>
                    <p class="text-sm text-gray-500">Status</p>
                    <p class="font-medium">
                        <span class="px-2 py-1 @(Model.ApplicationStatus == SIS.Enums.Status.Approved ? "bg-green-100 text-green-800" : 
                                               Model.ApplicationStatus == SIS.Enums.Status.Rejected ? "bg-red-100 text-red-800" : 
                                               Model.ApplicationStatus == SIS.Enums.Status.WaitListed ? "bg-yellow-100 text-yellow-800" : 
                                               "bg-blue-100 text-blue-800") text-xs rounded-full">
                            @Model.ApplicationStatus
                        </span>
                        
                        @if (Model.HasAllocation)
                        {
                            <span class="ml-1 px-2 py-1 bg-emerald-100 text-emerald-800 text-xs rounded-full">
                                Allocated
                            </span>
                        }
                    </p>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div>
                        <p class="text-sm text-gray-500">Notes</p>
                        <p class="text-sm mt-1 p-2 bg-gray-50 rounded">@Model.Notes</p>
                    </div>
                }
            </div>
        </div>
        
        @if (Model.HasAllocation && Model.AllocationDetails != null)
        {
            <div class="bg-emerald-50 rounded-lg shadow-sm border border-emerald-200 p-4">
                <h4 class="text-lg font-semibold text-emerald-700 mb-4 flex items-center">
                    <i class="material-icons mr-2">home</i> Room Allocation
                </h4>

                <div class="space-y-3">
                    <div>
                        <p class="text-sm text-gray-500">Hostel</p>
                        <p class="font-medium">@Model.AllocationDetails.HostelName</p>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500">Room</p>
                        <p class="font-medium">Room @Model.AllocationDetails.RoomNumber (@Model.AllocationDetails.RoomType)</p>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500">Floor</p>
                        <p class="font-medium">Floor @Model.AllocationDetails.Floor</p>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500">Bed</p>
                        <p class="font-medium">Bed @Model.AllocationDetails.BedIdentifier</p>
                    </div>

                    <div class="pt-2 border-t border-emerald-200">
                        <div>
                            <p class="text-sm text-gray-500">Allocation Date</p>
                            <p class="font-medium">@Model.AllocationDetails.AllocationDate.ToString("dd MMMM yyyy")</p>
                        </div>

                        <div>
                            <p class="text-sm text-gray-500">Duration</p>
                            <p class="font-medium">
                                @Model.AllocationDetails.StartDate.ToString("dd MMM yyyy") -
                                @(Model.AllocationDetails.IsGraduationBased ? "Until Graduation" : Model.AllocationDetails.EndDate?.ToString("dd MMM yyyy"))
                            </p>
                        </div>

                        <div>
                            <p class="text-sm text-gray-500">Status</p>
                            <p class="font-medium">
                                <span class="px-2 py-1 @(Model.AllocationDetails.Status == SIS.Enums.Status.Active ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800") text-xs rounded-full">
                                    @Model.AllocationDetails.Status
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>