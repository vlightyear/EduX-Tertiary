    <script src="https://cdn.datatables.net/buttons/2.3.8/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.3.8/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script>
        const currentPath = window.location.pathname;

        // ── Horizontal nav group toggle ──────────────────────
        let activeHnGroup = null;

        function toggleHnGroup(btn) {
            const group = btn.closest('.hn-group');
            const dropdown = group.querySelector('.hn-dropdown');
            const isOpen = dropdown.classList.contains('open');

            // Close any other open group
            if (activeHnGroup && activeHnGroup !== group) {
                activeHnGroup.querySelector('.hn-trigger').classList.remove('open');
                activeHnGroup.querySelector('.hn-dropdown').classList.remove('open');
            }

            if (isOpen) {
                btn.classList.remove('open');
                dropdown.classList.remove('open');
                activeHnGroup = null;
            } else {
                // Calculate position from the trigger button
                const rect = btn.getBoundingClientRect();
                dropdown.style.top  = rect.bottom + 4 + 'px';
                dropdown.style.left = rect.left + 'px';

                // Prevent going off-screen right edge
                btn.classList.add('open');
                dropdown.classList.add('open');

                // Nudge left if it overflows viewport
                const ddRect = dropdown.getBoundingClientRect();
                if (ddRect.right > window.innerWidth - 8) {
                    dropdown.style.left = (rect.right - ddRect.width) + 'px';
                }

                activeHnGroup = group;
            }
        }

        // Close horizontal dropdowns when clicking outside
        document.addEventListener('click', function (e) {
            if (!e.target.closest('.hn-group')) {
                document.querySelectorAll('.hn-trigger.open').forEach(t => t.classList.remove('open'));
                document.querySelectorAll('.hn-dropdown.open').forEach(d => d.classList.remove('open'));
                activeHnGroup = null;
            }
        });

        // ── Mobile drawer ────────────────────────────────────
        function openMobileNav() {
            const drawer = document.getElementById('mobile-drawer');
            drawer.classList.add('open');
            drawer.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }
        function closeMobileNav() {
            const drawer = document.getElementById('mobile-drawer');
            drawer.classList.remove('open');
            drawer.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        document.getElementById('mobile-nav-btn').addEventListener('click', openMobileNav);

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { closeMobileNav(); }
        });

        // ── Profile dropdown ─────────────────────────────────
        function toggleProfileDropdown() {
            document.getElementById('profile-dropdown').classList.toggle('hidden');
        }
        document.addEventListener('click', function (e) {
            const pd = document.getElementById('profile-dropdown');
            if (pd && !pd.classList.contains('hidden') && !e.target.closest('.relative')) {
                pd.classList.add('hidden');
            }
        });

        // ── Active link highlight (desktop horizontal nav) ───
        document.addEventListener('DOMContentLoaded', function () {
            // Highlight hn-item matching current path
            document.querySelectorAll('.hn-item').forEach(link => {
                const href = link.getAttribute('href');
                if (!href || href === '#') return;
                if (currentPath === href || (href !== '/' && currentPath.startsWith(href))) {
                    link.style.backgroundColor = '#fef2f2';
                    link.style.color = '#e85c5c';
                    // Open its parent dropdown visually to show context
                    const trigger = link.closest('.hn-group')?.querySelector('.hn-trigger');
                    if (trigger) trigger.style.color = '#e85c5c';
                }
            });

            // Highlight mobile nav links (handled by _Navigation.cshtml script)
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
