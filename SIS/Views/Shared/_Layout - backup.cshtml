@inject SIS.Services.IInstitutionConfigService InstitutionConfig

@{
    var institution = InstitutionConfig.GetCurrentInstitution();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduTech</title>
    <link href="https://cdn.lineicons.com/4.0/lineicons.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/dataTables.tailwindcss.min.css">
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@latest/dist/style.css" rel="stylesheet" type="text/css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.13/css/intlTelInput.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.13/js/intlTelInput.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/quill-formula@1.0.0/dist/formula.min.js"></script>
    <link rel="stylesheet" href="~/css/tailwind.css">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', '-apple-system', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50:  '#fdf2f2', 100: '#fce4e4', 200: '#f9cccc',
                            300: '#f4a4a4', 400: '#ed7a7a', 500: '#e85c5c',
                            600: '#d43a3a', 700: '#c94040', 800: '#942828',
                            900: '#7a2626', 950: '#420f0f'
                        },
                        secondary: {
                            50:  '#f0f4f8', 100: '#e2e8f0', 200: '#cbd5e1',
                            300: '#94a3b8', 400: '#64748b', 500: '#475569',
                            600: '#334155', 700: '#1e293b', 800: '#1a2f45',
                            900: '#0e2238', 950: '#070f1a'
                        }
                    }
                }
            }
        }
    </script>

    <link href="https://cdn.datatables.net/1.13.5/css/jquery.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/buttons/2.3.8/css/buttons.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">

    <style>
        /* ── Horizontal nav dropdown ───────────────────── */
        .hn-group {
            position: relative;
        }

        .hn-trigger {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.375rem 0.625rem;
            border-radius: 0.375rem;
            font-size: 0.8rem;
            font-weight: 500;
            color: #334155;
            white-space: nowrap;
            transition: background 0.15s, color 0.15s;
            cursor: pointer;
            border: none;
            background: none;
        }

            .hn-trigger:hover,
            .hn-trigger.open {
                background: #fef2f2;
                color: #e85c5c;
            }

            .hn-trigger .chevron {
                font-size: 1rem;
                transition: transform 0.2s;
            }

            .hn-trigger.open .chevron {
                transform: rotate(180deg);
            }

        .hn-dropdown {
            display: none;
            position: fixed; /* ← escapes ALL overflow contexts */
            background: #fff;
            border: 1px solid #f1f5f9;
            border-radius: 0.75rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
            padding: 0.5rem;
            min-width: 13rem;
            z-index: 9999; /* ← above everything */
        }

            .hn-dropdown.open {
                display: block;
            }

            .hn-dropdown.wide.open {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 0.125rem;
                min-width: 28rem;
            }

            .hn-dropdown.open {
                display: block;
            }

            /* Wide dropdowns for sections with many items */
            .hn-dropdown.wide {
                display: none;
                min-width: 28rem;
                display: none;
            }

                .hn-dropdown.wide.open {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 0.125rem;
                }

        .hn-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            font-size: 0.8rem;
            color: #475569;
            text-decoration: none;
            transition: background 0.12s, color 0.12s;
        }

            .hn-item:hover {
                background: #fef2f2;
                color: #e85c5c;
            }

            .hn-item .material-icons,
            .hn-item .lni {
                font-size: 0.95rem;
                color: #94a3b8;
                flex-shrink: 0;
            }

            .hn-item:hover .material-icons,
            .hn-item:hover .lni {
                color: #e85c5c;
            }

        .hn-divider {
            height: 1px;
            background: #f1f5f9;
            margin: 0.25rem 0.5rem;
            grid-column: 1 / -1;
        }

        .hn-label {
            padding: 0.375rem 0.75rem 0.125rem;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: #94a3b8;
            grid-column: 1 / -1;
        }

        /* ── Mobile nav drawer ─────────────────────────── */
        #mobile-drawer {
            position: fixed;
            inset: 0;
            z-index: 300;
            display: none;
        }

            #mobile-drawer.open {
                display: block;
            }

        #mobile-drawer-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.45);
        }

        #mobile-drawer-panel {
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            width: 17rem;
            background: #fff;
            overflow-y: auto;
            box-shadow: 4px 0 20px rgba(0,0,0,0.15);
            transform: translateX(-100%);
            transition: transform 0.25s ease;
        }

        #mobile-drawer.open #mobile-drawer-panel {
            transform: translateX(0);
        }

        /* ── Active nav link ───────────────────────────── */
        .nav-link.active,
        .nav-link:hover {
            background-color: #e85c5c;
            color: #fff !important;
        }

            .nav-link.active .material-icons,
            .nav-link.active .lni,
            .nav-link:hover .material-icons,
            .nav-link:hover .lni {
                color: #fff;
            }

        .nav-section-label {
            padding: 0.5rem 1rem 0.25rem;
            margin-top: 0.5rem;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #94a3b8;
        }
    </style>

    @RenderSection("Styles", required: false)
    @Html.AntiForgeryToken()
</head>

<body class="font-sans" style="background-color: #f0f4f8;">

    <div class="min-h-screen flex flex-col">
        <header class="sticky top-0 bg-white border-b border-slate-200 shadow-sm" style="z-index: 500;">

            <div class="h-14 flex items-center px-4 gap-3">

                <button id="mobile-nav-btn"
                        class="lg:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors"
                        aria-label="Open navigation">
                    <i class="material-icons text-slate-600">menu</i>
                </button>

                <a href="/" class="flex items-center gap-2 shrink-0">
                    <img src="@($"{institution.ContactInfo?.Website?.TrimEnd('/')}{institution.LogoPath}")"
                         alt="@institution.Name"
                         class="h-8 w-auto">
                    <span class="font-bold text-slate-800 text-lg hidden sm:block">
                        Edu<span class="text-primary-500">Tech</span>
                    </span>
                </a>

                <div class="hidden md:flex items-center text-sm text-slate-400 ml-1">
                    <span class="mx-2">/</span>
                    <span class="font-medium text-slate-700">@ViewData["Title"]</span>
                </div>

                <div class="flex-1"></div>

                <div class="relative">
                    <button onclick="toggleProfileDropdown()"
                            class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-slate-100 transition-colors">
                        <div class="relative">
                            <div class="h-8 w-8 rounded-full flex items-center justify-center text-white text-sm font-semibold"
                                 style="background: linear-gradient(135deg, #e85c5c, #1e293b);">
                                @(User.Identity?.Name?[0].ToString().ToUpper() ?? "U")
                            </div>
                            <span class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 bg-green-400 rounded-full border-2 border-white"></span>
                        </div>
                        <div class="hidden sm:block text-left">
                            <div class="text-xs font-semibold text-slate-700 leading-tight">
                                @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value ?? User.Identity?.Name)
                            </div>
                            <div class="text-xs text-slate-400 leading-tight">
                                @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Member")
                            </div>
                        </div>
                        <i class="material-icons text-slate-400 text-base">expand_more</i>
                    </button>

                    <div id="profile-dropdown"
                         class="hidden absolute right-0 top-full mt-1 w-52 bg-white rounded-xl shadow-lg border border-slate-100 py-1.5 z-50">
                        <div class="px-4 py-2 border-b border-slate-100 mb-1">
                            <div class="text-sm font-semibold text-slate-800">
                                @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value ?? User.Identity?.Name)
                            </div>
                            <div class="text-xs text-slate-500">
                                @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Member")
                            </div>
                        </div>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Account" asp-action="Logout"
                               class="flex items-center gap-3 px-4 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg mx-1 transition-colors">
                                <i class="material-icons text-red-400 text-lg">logout</i>
                                Sign out
                            </a>
                        }
                    </div>
                </div>
            </div>


            <nav class="hidden lg:block" id="desktop-nav" style="border-top: 1px solid #f1f5f9;">
                <div class="flex items-center px-4 gap-0.5 pb-1.5" style="overflow-x: auto; overflow-y: visible;">

                @if (User.IsInRole("Admin") || User.IsInRole("Registrar") || User.IsInRole("HOD") || User.IsInRole("Dean"))
                {
                    <a asp-controller="Home" asp-action="Index" class="hn-trigger">
                        <i class="material-icons" style="font-size:0.9rem;">home</i>Home
                    </a>
                }
                else if (User.IsInRole("Student"))
                {
                    <a asp-controller="Home" asp-action="Student_Dashboard" class="hn-trigger">
                        <i class="material-icons" style="font-size:0.9rem;">home</i>Home
                    </a>
                }
                else if (User.IsInRole("Candidate"))
                {
                    <a asp-controller="StudentApplication" asp-action="Index" class="hn-trigger">
                        <i class="material-icons" style="font-size:0.9rem;">home</i>Home
                    </a>
                }
                else if (User.IsInRole("VC") || User.IsInRole("DVC"))
                {
