@* _Navigation.cshtml *@

<style>
    .nav-link:hover,
    .nav-link.active {
        background-color: #e85c5c;
        color: #ffffff;
    }
    .nav-section-label {
        padding: 0.5rem 1rem;
        margin-top: 0.75rem;
        margin-bottom: 0.25rem;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #94a3b8;
    }
</style>

<div class="space-y-1 py-2">

    @if (User.IsInRole("Admin") || User.IsInRole("Registrar") || User.IsInRole("HOD") || User.IsInRole("Dean"))
    {
        <a asp-controller="Home" asp-action="Index"
           class="nav-link flex items-center gap-2 px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <i class="lni lni-home text-lg"></i>
            <span>Home</span>
        </a>
    }
    else if (User.IsInRole("Student"))
    {
        <a asp-controller="Home" asp-action="Student_Dashboard"
           class="nav-link flex items-center gap-2 px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <i class="lni lni-home text-lg"></i>
            <span>Home</span>
        </a>
    }
    else if (User.IsInRole("Candidate"))
    {
        <a asp-controller="StudentApplication" asp-action="Index"
           class="nav-link flex items-center gap-2 px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <i class="lni lni-home text-lg"></i>
            <span>Home</span>
        </a>
    }
    else if (User.IsInRole("VC") || User.IsInRole("DVC"))
    {
        <a asp-controller="Home" asp-action="VCDashboard"
           class="nav-link flex items-center gap-2 px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <i class="lni lni-home text-lg"></i>
            <span>Home</span>
        </a>
    }

    @if (User.IsInRole("Admin"))
    {
        <div class="nav-section-label">Institution</div>

        <button onclick="toggleMenu('campusesBuildings')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">location_city</i>
                <span>Campus Management</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="campusesBuildings-icon">expand_more</i>
        </button>
        <ul id="campusesBuildings" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="Admin" asp-action="Campuses"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">location_city</i>
                    <span>Campuses</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="Schools"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="lni lni-apartment text-lg"></i>
                    <span>Schools</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="Departments"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">account_balance</i>
                    <span>Departments</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="Buildings"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">real_estate_agent</i>
                    <span>Buildings</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="LearningRooms"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">meeting_room</i>
                    <span>Learning Rooms</span>
                </a>
            </li>
            <li>
                <a asp-controller="ResourceType" asp-action="Index"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">inventory</i>
                    <span>Accommodation Resource Types</span>
                </a>
            </li>
        </ul>

        <div class="nav-section-label">Academic</div>

        <button onclick="toggleMenu('programsCourses')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="lni lni-graduation text-lg"></i>
                <span>Programs & Courses</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="programsCourses-icon">expand_more</i>
        </button>
        <ul id="programsCourses" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="Admin" asp-action="Programmes"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="lni lni-graduation text-lg"></i>
                    <span>Programmes</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="ProgramLevels"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">collections_bookmark</i>
                    <span>Programme Levels</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="Courses"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">book</i>
                    <span>Courses</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="ProgressionRules"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">gavel</i>
                    <span>Progression Rules</span>
                </a>
            </li>
        </ul>

        <button onclick="toggleMenu('assessmentGrading')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">assessment</i>
                <span>Assessment & Grading</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="assessmentGrading-icon">expand_more</i>
        </button>
        <ul id="assessmentGrading" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="Admin" asp-action="Assessments"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">assessment</i>
                    <span>Assessments</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="GradeConfigurations"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">grade</i>
                    <span>Grade Configurations</span>
                </a>
            </li>
        </ul>

        <div class="nav-section-label">Schedule</div>

        <button onclick="toggleMenu('timeManagement')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">schedule</i>
                <span>Time Management</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="timeManagement-icon">expand_more</i>
        </button>
        <ul id="timeManagement" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="Admin" asp-action="TimeSlotConfigurations"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">view_timeline</i>
                    <span>Time Slots</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="WorkingDayConfigurations"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">calendar_month</i>
                    <span>Working Days</span>
                </a>
            </li>
        </ul>

        <div class="nav-section-label">Finance</div>

        <button onclick="toggleMenu('fees')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">price_change</i>
                <span>Fees Management</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="fees-icon">expand_more</i>
        </button>
        <ul id="fees" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="Admin" asp-action="FeeTypes"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">request_quote</i>
                    <span>Fee Types</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="FeeConfigurations"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">paid</i>
                    <span>Fees</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="OtherFees"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">add_card</i>
                    <span>Configure Other Fees</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="OtherFeesInvoices"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">receipt_long</i>
                    <span>Invoice Other Fees</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="CreditNotes"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">receipt_long</i>
                    <span>Credit Notes</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="DebitNotes"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">receipt_long</i>
                    <span>Debit Notes</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="ManualPayments"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">payment</i>
                    <span>Manual Payments</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="Quotations"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">payment</i>
                    <span>Issue Quotation</span>
                </a>
            </li>
        </ul>

        <div class="nav-section-label">System</div>

        <a asp-controller="Admin" asp-action="Users"
           class="nav-link flex items-center gap-2 px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <i class="lni lni-users text-lg"></i>
            <span>Users</span>
        </a>
        <a asp-controller="Workflow" asp-action="Index"
           class="nav-link flex items-center gap-2 px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <i class="lni lni-network text-lg"></i>
            <span>Workflows</span>
        </a>
    }

    @if (User.IsInRole("Registrar") || User.IsInRole("Admin"))
    {
        <div class="nav-section-label">Registration</div>

        <button onclick="toggleMenu('registration')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">app_registration</i>
                <span>Registration</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="registration-icon">expand_more</i>
        </button>
        <ul id="registration" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="ApplicationPeriod" asp-action="Index"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">event</i>
                    <span>Application Periods</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="AcademicYear"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">subject</i>
                    <span>Academic Year</span>
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="Subjects"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">subject</i>
                    <span>GCE/GCSE Subjects</span>
                </a>
            </li>
        </ul>
    }

    @if (User.IsInRole("Registrar") || User.IsInRole("Admin") || User.IsInRole("Dean") ||
         User.IsInRole("VC") || User.IsInRole("DVC") || User.IsInRole("ProgramCoordinator"))
    {
        <div class="nav-section-label">Admissions</div>

        <button onclick="toggleMenu('admissions')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="lni lni-grid text-lg"></i>
                <span>Admission</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="admissions-icon">expand_more</i>
        </button>
        <ul id="admissions" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="AdmissionProcess" asp-action="PendingAdmission"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">person_remove</i>
                    <span>Pending Admission</span>
                </a>
            </li>
            <li>
                <a asp-controller="AdmissionProcess" asp-action="PendingWaitlist"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">how_to_reg</i>
                    <span>Waitlisted Applicants</span>
                </a>
            </li>
            <li>
                <a asp-controller="StudentLookup" asp-action="Index"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">people_alt</i>
                    <span>Students</span>
                </a>
            </li>
        </ul>
    }

    @if (User.IsInRole("Registrar") || User.IsInRole("Admin") || User.IsInRole("Dean"))
    {
        <div class="nav-section-label">Academic Requests</div>

        <button onclick="toggleMenu('academicRequests')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">assignment</i>
                <span>Academic Requests</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="academicRequests-icon">expand_more</i>
        </button>
        <ul id="academicRequests" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="AcademicRequest" asp-action="Manage"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">dashboard</i>
                    <span>Manage Requests</span>
                </a>
            </li>
            <li>
                <a asp-controller="AcademicRequest" asp-action="QuotaRequests"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">dashboard</i>
                    <span>Quota Requests</span>
                </a>
            </li>
            <li>
                <a asp-controller="ResultAppeal" asp-action="Index"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">rate_review</i>
                    <span>Result Appeals</span>
                </a>
            </li>
        </ul>
    }

    @if (User.IsInRole("Admin") || User.IsInRole("Registrar") || User.IsInRole("Dean") ||
         User.IsInRole("VC") || User.IsInRole("DVC"))
    {
        <div class="nav-section-label">Calendar</div>

        <button onclick="toggleMenu('academicCalendar')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">calendar_month</i>
                <span>Academic Calendar</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="academicCalendar-icon">expand_more</i>
        </button>
        <ul id="academicCalendar" class="hidden mt-1 ml-2 space-y-0.5">
            @if (User.IsInRole("Admin") || User.IsInRole("Registrar"))
            {
                <li>
                    <a asp-controller="AcademicEventType" asp-action="Index"
                       class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                        <i class="material-icons text-lg">category</i>
                        <span>Event Types</span>
                    </a>
                </li>
            }
            <li>
                <a asp-controller="AcademicCalendar" asp-action="Index"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">calendar_month</i>
                    <span>Academic Calendar</span>
                </a>
            </li>
            @if (User.IsInRole("Admin"))
            {
                <li>
                    <a asp-controller="Admin" asp-action="AcademicYear"
                       class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                        <i class="material-icons text-lg">subject</i>
                        <span>Academic Year</span>
                    </a>
                </li>
            }
        </ul>
    }

    @if (User.IsInRole("Compliance") || User.IsInRole("Admin"))
    {
        <div class="nav-section-label">Compliance</div>

        <button onclick="toggleMenu('complianceManagement')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">menu_book</i>
                <span>Compliance</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="compliance-icon">expand_more</i>
        </button>
        <ul id="complianceManagement" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="Compliance" asp-action="Index"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">menu_book</i>
                    <span>Dockets</span>
                </a>
            </li>
        </ul>
    }

    @if (User.IsInRole("Admin") || User.IsInRole("Dean"))
    {
        <div class="nav-section-label">Disciplinary</div>

        <a asp-controller="Disqualification" asp-action="Index"
           class="nav-link flex items-center gap-2 px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <i class="material-icons text-lg">gavel</i>
            <span>Disqualified Students</span>
        </a>
    }

    @if (User.IsInRole("Admin"))
    {
        <div class="nav-section-label">Student ID Cards</div>

        <button onclick="toggleMenu('studentidcards')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">badge</i>
                <span>Student ID Cards</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="studentidcards-icon">expand_more</i>
        </button>
        <ul id="studentidcards" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="StudentLookup" asp-action="Cards"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">badge</i>
                    <span>ID Cards</span>
                </a>
            </li>
        </ul>
    }

    @if (User.IsInRole("VC") || User.IsInRole("DVC"))
    {
        <div class="nav-section-label">University Management</div>

        <button onclick="toggleMenu('vcManagement')"
                class="nav-link w-full flex items-center justify-between px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <div class="flex items-center gap-2">
                <i class="material-icons text-lg">account_balance</i>
                <span>University Management</span>
            </div>
            <i class="material-icons transform transition-transform duration-200" id="vcManagement-icon">expand_more</i>
        </button>
        <ul id="vcManagement" class="hidden mt-1 ml-2 space-y-0.5">
            <li>
                <a asp-controller="StudentLookup" asp-action="Index"
                   class="nav-link flex items-center gap-2 px-4 py-2 text-secondary-500 transition-colors rounded-md mx-3 text-sm">
                    <i class="material-icons text-lg">people_alt</i>
                    <span>All Students</span>
                </a>
            </li>
        </ul>
    }

    @if (User.IsInRole("Dean"))
    {
        <a asp-controller="Workflow" asp-action="PendingApprovals"
           class="nav-link flex items-center gap-2 px-4 py-2.5 text-secondary-600 transition-colors rounded-md mx-3 my-0.5">
            <i class="lni lni-network text-lg"></i>
            <span>Pending Approvals</span>
