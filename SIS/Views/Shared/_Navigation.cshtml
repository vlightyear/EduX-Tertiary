</div>

<script>
    function toggleMenu(menuId) {
        const menu = document.getElementById(menuId);
        const icon = document.getElementById(menuId + '-icon');
        if (!menu) return;
        menu.classList.toggle('hidden');
        if (icon) icon.style.transform = menu.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
        const menuStates = JSON.parse(localStorage.getItem('menuStates') || '{}');
        menuStates[menuId] = !menu.classList.contains('hidden');
        localStorage.setItem('menuStates', JSON.stringify(menuStates));
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Restore open/closed states
        const menuStates = JSON.parse(localStorage.getItem('menuStates') || '{}');
        for (const menuId in menuStates) {
            const menu = document.getElementById(menuId);
            const icon = document.getElementById(menuId + '-icon');
            if (menu && menuStates[menuId]) {
                menu.classList.remove('hidden');
                if (icon) icon.style.transform = 'rotate(180deg)';
            }
        }

        // Highlight active link
        const navLinks = document.querySelectorAll('a.nav-link[href]');
        navLinks.forEach(link => {
            const href = link.getAttribute('href');
            if (!href || href === '#') return;
            if (currentPath === href || (href !== '/' && currentPath.includes(href))) {
                link.classList.add('active');
                link.style.color = '#ffffff';

                // Auto-open parent submenu
                const parentMenu = link.closest('ul[id]');
                if (parentMenu) {
                    parentMenu.classList.remove('hidden');
                    const parentIcon = document.getElementById(parentMenu.id + '-icon');
                    if (parentIcon) parentIcon.style.transform = 'rotate(180deg)';
                }
            }
        });
    });
</script>
