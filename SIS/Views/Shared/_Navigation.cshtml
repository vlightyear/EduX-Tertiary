<script>
    // Define toggleMenu in the global scope so it's available immediately
    function toggleMenu(menuId) {
        const menu = document.getElementById(menuId);
        const icon = document.getElementById(menuId + '-icon');
        menu.classList.toggle('hidden');
        if (menu.classList.contains('hidden')) {
            icon.style.transform = 'rotate(0deg)';
        } else {
            icon.style.transform = 'rotate(180deg)';
        }
        // Save menu state to localStorage
        const menuStates = JSON.parse(localStorage.getItem('menuStates') || '{}');
        menuStates[menuId] = !menu.classList.contains('hidden');
        localStorage.setItem('menuStates', JSON.stringify(menuStates));

    }

    // Restore menu state on page load
    document.addEventListener('DOMContentLoaded', function() {
        console.log('DOM fully loaded');

        const menuStates = JSON.parse(localStorage.getItem('menuStates') || '{}');
        for (const menuId in menuStates) {
            const menu = document.getElementById(menuId);
            const icon = document.getElementById(menuId + '-icon');
            if (menu && icon && menuStates[menuId]) {
                menu.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
            }
        }


        const navLinks = document.querySelectorAll('a[href]');
        navLinks.forEach(link => {
            if (link.getAttribute('href') === currentPath ||
                (currentPath.includes(link.getAttribute('href')) && link.getAttribute('href') !== '/')) {
                // Add styles to highlight active link
                link.classList.add('bg-primary-700', 'text-white');
                link.classList.remove('text-secondary-600', 'text-secondary-500');

                // If link is in a submenu, make sure parent menu is open
                const parentMenu = link.closest('ul[id]');
                if (parentMenu && parentMenu.id) {
                    parentMenu.classList.remove('hidden');
                    const parentIcon = document.getElementById(parentMenu.id + '-icon');
                    if (parentIcon) {
                        parentIcon.style.transform = 'rotate(180deg)';
                    }
                }
            }
        });
    });
</script>