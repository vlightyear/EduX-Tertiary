<!-- _AllocationDetails.cshtml -->
@model SIS.Models.HostelManager.AllocationDetailsViewModel


<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Student Information -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <h4 class="text-lg font-semibold text-gray-700 mb-4">Student Information</h4>

            <div class="space-y-3">
                <div>
                    <p class="text-sm text-gray-500">Full Name</p>
                    <p class="font-medium">@Model.StudentName</p>
                </div>

                <div>
                    <p class="text-sm text-gray-500">Student ID</p>
                    <p class="font-medium">@Model.MatricNumber</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Accommodation Details -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <h4 class="text-lg font-semibold text-gray-700 mb-4">Accommodation Details</h4>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div>
                    <p class="text-sm text-gray-500">Hostel</p>
                    <p class="font-medium">@Model.HostelName</p>
                </div>

                <div>
                    <p class="text-sm text-gray-500">Room Number</p>
                    <p class="font-medium">Room @Model.RoomNumber (@Model.RoomType)</p>
                </div>

                <div>
                    <p class="text-sm text-gray-500">Floor</p>
                    <p class="font-medium">Floor @Model.Floor</p>
                </div>

                <div>
                    <p class="text-sm text-gray-500">Bed</p>
                    <p class="font-medium">Bed @Model.BedIdentifier</p>
                </div>
            </div>

            <div class="pt-4 border-t border-gray-200">
                <h5 class="text-md font-medium text-gray-700 mb-3">Allocation Information</h5>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <p class="text-sm text-gray-500">Allocation ID</p>
                        <p class="font-medium">@Model.AllocationId</p>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500">Allocation Type</p>
                        <p class="font-medium capitalize">@Model.AllocationType</p>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500">Allocation Date</p>
                        <p class="font-medium">@Model.AllocationDate.ToString("dd MMMM yyyy")</p>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500">Status</p>
                        <p class="font-medium">
                            <span class="px-2 py-1 @(Model.Status == SIS.Enums.Status.Active ? "bg-green-100 text-green-800" :
                                                   Model.Status == SIS.Enums.Status.Pending ? "bg-yellow-100 text-yellow-800" :
                                                   Model.Status == SIS.Enums.Status.Completed ? "bg-blue-100 text-blue-800" :
                                                   "bg-red-100 text-red-800") text-xs rounded-full">
                                @Model.Status
                            </span>
                        </p>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500">Start Date</p>
                        <p class="font-medium">@Model.StartDate.ToString("dd MMMM yyyy")</p>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500">End Date</p>
                        <p class="font-medium">
                            @if (Model.IsGraduationBased)
                            {
                                <span>Until Graduation</span>
                            }
                            else
                            {
                                <span>@(Model.EndDate?.ToString("dd MMMM yyyy") ?? "Not specified")</span>
                            }
                        </p>
                    </div>
                </div>

                @if (Model.IsCheckedIn || Model.IsCheckedOut)
                {
                    <div class="mt-4 pt-4 border-t border-gray-200">
                        <h5 class="text-md font-medium text-gray-700 mb-3">Check-in / Check-out</h5>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            @if (Model.IsCheckedIn)
                            {
                                <div>
                                    <p class="text-sm text-gray-500">Check-in Date</p>
                                    <p class="font-medium">@Model.CheckInDate?.ToString("dd MMMM yyyy")</p>
                                </div>
                            }

                            @if (Model.IsCheckedOut)
                            {
                                <div>
                                    <p class="text-sm text-gray-500">Check-out Date</p>
                                    <p class="font-medium">@Model.CheckOutDate?.ToString("dd MMMM yyyy")</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>