<!-- _AllocateRoom.cshtml -->
@model SIS.Models.HostelManager.AllocateRoomViewModel

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Student Information (Left Column) -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <h4 class="text-lg font-semibold text-gray-700 mb-4">Student Information</h4>

            <div class="space-y-3">
                <div>
                    <p class="text-sm text-gray-500">Full Name</p>
                    <p class="font-medium">@Model.StudentName</p>
                </div>

                <div>
                    <p class="text-sm text-gray-500">Student ID</p>
                    <p class="font-medium">@Model.MatricNumber</p>
                </div>

                <div>
                    <p class="text-sm text-gray-500">Gender</p>
                    <p class="font-medium">@Model.Gender</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Allocation Form (Right Column) -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <h4 class="text-lg font-semibold text-gray-700 mb-4">Room Allocation</h4>

            <!-- Hostel Selection -->
            <div class="mb-4">
                <label for="HostelId" class="block text-sm font-medium text-gray-700 mb-1">Select Hostel</label>
                <select id="HostelId" name="HostelId" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-cyan-500 focus:border-cyan-500" required>
                    <option value="">Select a hostel</option>
                    @foreach (var hostel in Model.Hostels)
                    {
                        <option value="@hostel.HostelId">@hostel.HostelName (@hostel.AvailableRooms available rooms)</option>
                    }
                </select>
                <p class="mt-1 text-xs text-gray-500">Only hostels with available rooms for @Model.Gender.ToLower() students are shown</p>
            </div>

            <!-- Room Selection -->
            <div class="mb-4">
                <label for="RoomId" class="block text-sm font-medium text-gray-700 mb-1">Select Room</label>
                <select id="RoomId" name="RoomId" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-cyan-500 focus:border-cyan-500" required disabled>
                    <option value="">Select a hostel first</option>
                </select>
            </div>

            <!-- Bed Selection -->
            <div class="mb-4">
                <label for="BedId" class="block text-sm font-medium text-gray-700 mb-1">Select Bed</label>
                <select id="BedId" name="BedId" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-cyan-500 focus:border-cyan-500" required disabled>
                    <option value="">Select a room first</option>
                </select>
            </div>

            <!-- Allocation Details -->
            <div class="pt-4 border-t border-gray-200">
                <h5 class="text-md font-medium text-gray-700 mb-3">Allocation Details</h5>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Allocation Type -->
                    <div>
                        <label for="AllocationType" class="block text-sm font-medium text-gray-700 mb-1">Allocation Type</label>
                        <select id="AllocationType" name="AllocationType" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-cyan-500 focus:border-cyan-500" required>
                            @foreach (var type in Model.AllocationTypes)
                            {
                                <option value="@type">@type.ToUpper()</option>
                            }
                        </select>
                    </div>

                    <!-- Start Date -->
                    <div>
                        <label for="StartDate" class="block text-sm font-medium text-gray-700 mb-1">Start Date</label>
                        <input type="date" id="StartDate" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")"
                               class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-cyan-500 focus:border-cyan-500" required>
                    </div>

                    <!-- Is Graduation Based -->
                    <div class="md:col-span-2">
                        <div class="flex items-center mb-2">
                            <input type="checkbox" id="IsGraduationBased" name="IsGraduationBased" value="true"
                                   class="h-4 w-4 text-cyan-600 focus:ring-cyan-500 border-gray-300 rounded"
                            @(Model.IsGraduationBased ? "checked" : "")
                                   onchange="toggleEndDateVisibility()">
                            <label for="IsGraduationBased" class="ml-2 block text-sm text-gray-700">
                                Permanent until graduation
                            </label>
                        </div>
                    </div>

                    <!-- End Date -->
                    <div id="endDateContainer" class="@(Model.IsGraduationBased ? "hidden" : "")">
                        <label for="EndDate" class="block text-sm font-medium text-gray-700 mb-1">End Date</label>
                        <input type="date" id="EndDate" name="EndDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))"
                               class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-cyan-500 focus:border-cyan-500"
                        @(Model.IsGraduationBased ? "" : "required")>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleEndDateVisibility() {
        const isGraduationBased = document.getElementById('IsGraduationBased').checked;
        const endDateContainer = document.getElementById('endDateContainer');
        const endDateInput = document.getElementById('EndDate');

        if (isGraduationBased) {
            endDateContainer.classList.add('hidden');
            endDateInput.removeAttribute('required');
        } else {
            endDateContainer.classList.remove('hidden');
            endDateInput.setAttribute('required', 'required');
        }
    }
</script>
