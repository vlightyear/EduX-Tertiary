    // Improve the renderPerformanceSummary function
    function renderPerformanceSummary(summary) {
        const tbody = document.getElementById('performanceSummaryBody');
        tbody.innerHTML = '';

        const rows = [
            { no: 1, desc: 'Students with Clear Pass', value: summary.studentsWithClearPass, isData: true },
            { no: 2, desc: 'Students with Supplementary Exams', value: summary.studentsWithSupplementaryExams, isData: true },
            { no: 3, desc: 'Students with Proceed with Repeats', value: summary.studentsWithProceedWithRepeats, isData: true },
            { no: 4, desc: 'Students with Repeat Semester', value: summary.studentsWithRepeatSemester, isData: true },
            { no: 5, desc: 'Students with Deferred Exams', value: summary.studentsWithDeferredExams, isData: true },
            { no: 6, desc: 'Students Excluded', value: summary.studentsExcluded, isData: true },
            { no: 7, desc: 'Students Disqualified', value: summary.studentsDisqualified, isData: true },
            { no: 8, desc: 'Percentage with Clear Pass', value: summary.percentageWithClearPass + '%', highlight: true, isPercentage: true },
            { no: 9, desc: 'TOTAL', value: summary.totalStudents, isTotal: true }
        ];

        rows.forEach(row => {
            const tr = document.createElement('tr');

            if (row.isTotal) {
                tr.className = 'bg-slate-200 font-bold';
            } else if (row.highlight) {
                tr.className = 'bg-blue-50';
            } else if (row.no % 2 === 0) {
                tr.className = 'bg-slate-50';
            } else {
                tr.className = 'bg-white';
            }

            tr.innerHTML = `
                <td class="border border-gray-400 px-3 py-2 text-center ${row.isTotal ? 'font-bold text-slate-900' : 'text-slate-700'}">${row.no}</td>
                <td class="border border-gray-400 px-3 py-2 ${row.isTotal ? 'font-bold text-slate-900' : 'text-slate-800'}">${row.desc}</td>
                <td class="border border-gray-400 px-3 py-2 text-right ${row.isTotal ? 'font-bold text-slate-900' : row.highlight ? 'text-blue-700 font-bold' : 'text-slate-700'}">${row.value}</td>
            `;
            tbody.appendChild(tr);
        });

        // Show the performance summary section
        document.getElementById('performanceSummarySection').classList.remove('hidden');
