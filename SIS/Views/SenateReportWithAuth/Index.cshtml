            //updateReportMetadata(reportData);
            //showState('results');
        }*/

        function displayReportResults(reportData) {
            // Check if this is programme-level data with student details
            if (reportData.data && Array.isArray(reportData.data) && reportData.data.length > 0 && reportData.data[0].studentProgression) {
                // Render student-level performance table
                renderStudentPerformanceTable(reportData.data);
                showState('results');
            } else {
                // Original summary table rendering
                updateSummaryStats(reportData.totals);
                updateBreadcrumbs(reportData.breadcrumbs);
                updateReportTable(reportData);
                updateReportMetadata(reportData);
                showState('results');
            }
        }

