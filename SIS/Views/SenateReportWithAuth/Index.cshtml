<script>
    // ===================================================================
    // PRELOADED DATA FROM SERVER (for restricted users HOD/Dean)
    // ===================================================================
    const preloadedData = {
        filteredDepartments: @Html.Raw(Json.Serialize(filteredDepartments.Select(d => new { id = d.Id, name = d.Name, schoolId = d.SchoolId }))),
        filteredProgrammes: @Html.Raw(Json.Serialize(filteredProgrammes.Select(p => new { id = p.Id, name = p.Name, departmentId = p.DepartmentId }))),
        defaultSchoolId: '@(ViewBag.DefaultSchoolId ?? "")',
        defaultDepartmentId: '@(ViewBag.DefaultDepartmentId ?? "")',
        defaultProgrammeId: '@(ViewBag.DefaultProgrammeId ?? "")',
        isHOD: @Json.Serialize(isHOD),
        isDean: @Json.Serialize(isDean),
        hasFullAccess: @Json.Serialize(hasFullAccess)
    };

    // Global variables for batch publishing
    let currentProgrammeData = null;
    let allBatches = [];
    let selectedBatchIds = new Set();
    let viewModel = null; // Will store the report data

    // Initialize page data
    const pageData = {
        currentUser: '@ViewBag.CurrentUser',
        isAdmin: @Json.Serialize(ViewBag.IsAdmin ?? false),
        isDean: @Json.Serialize(ViewBag.IsDean ?? false),
        isRegistrar: @Json.Serialize(ViewBag.IsRegistrar ?? false),
        isProgramCoordinator: @Json.Serialize(ViewBag.IsProgramCoordinator ?? false),
        currentFilters: {},
        currentReportData: null,
        breadcrumbHistory: []
    };

    // Global variables for detail views
    let currentEntityDetails = null;
    let filteredStudents = [];

    // ===================================================================
    // UTILITY FUNCTIONS (GLOBAL SCOPE)
    // ===================================================================

    function showModal(modalElement) {
        if (modalElement) {
            modalElement.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
    }

    function hideModal(modalElement) {
        if (modalElement) {
            modalElement.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }
    }

    // ===================================================================
    // PERFORMANCE SUMMARY FUNCTIONS (NEW)
    // ===================================================================

    function renderPerformanceSummary(summary) {
        const tbody = document.getElementById('performanceSummaryBody');
        tbody.innerHTML = '';

        const rows = [
            { no: 1, desc: 'Students with Clear Pass', value: summary.studentsWithClearPass },
            { no: 2, desc: 'Students with Supplementary Exams', value: summary.studentsWithSupplementaryExams },
            { no: 3, desc: 'Students with Proceed with Repeats', value: summary.studentsWithProceedWithRepeats },
            { no: 5, desc: 'Students with Repeat Semester', value: summary.studentsWithRepeatSemester },
            { no: 6, desc: 'Students with Deferred Exams', value: summary.studentsWithDeferredExams },
            { no: 7, desc: 'Students Excluded', value: summary.studentsExcluded },
            { no: 8, desc: 'Students Disqualified', value: summary.studentsDisqualified },
            { no: 9, desc: 'Percentage with Clear Pass', value: summary.percentageWithClearPass + '%', highlight: true },
            { no: 10, desc: 'TOTAL', value: summary.totalStudents, isTotal: true }
        ];

        rows.forEach(row => {
            const tr = document.createElement('tr');
            if (row.highlight) {
                tr.className = 'bg-blue-50';
            } else if (row.isTotal) {
                tr.className = 'bg-gray-100';
            }

            tr.innerHTML = `
                <td class="border border-gray-400 px-3 py-2 text-center ${row.isTotal ? 'font-bold' : ''}">${row.no}</td>
                <td class="border border-gray-400 px-3 py-2 ${row.isTotal ? 'font-bold' : ''}">${row.desc}</td>
                <td class="border border-gray-400 px-3 py-2 text-right ${row.isTotal ? 'font-bold' : ''} ${row.highlight ? 'text-blue-700 font-bold' : ''}">${row.value}</td>
            `;
            tbody.appendChild(tr);
        });

        // Show the performance summary section
        document.getElementById('performanceSummarySection').classList.remove('hidden');
    }

    function renderGradingOverviewTable(gradingData) {
        console.log("Grading Data: ", gradingData);
        // Check if gradingData exists
        if (!gradingData || !gradingData.courses || gradingData.courses.length === 0) {
            return;
        }

        // Create or show the grading overview section
        let gradingSection = document.getElementById('gradingOverviewSection');
        if (!gradingSection) {
            // Create the section if it doesn't exist
            const performanceSection = document.getElementById('performanceSummarySection');
            gradingSection = document.createElement('div');
            gradingSection.id = 'gradingOverviewSection';
            gradingSection.className = 'bg-white rounded-xl shadow-sm mb-6 overflow-hidden';

            if (performanceSection && performanceSection.nextSibling) {
                performanceSection.parentNode.insertBefore(gradingSection, performanceSection.nextSibling);
            } else {
                document.getElementById('summaryStats').insertAdjacentElement('afterend', gradingSection);
            }
        }

        // Build the grading overview HTML
        gradingSection.innerHTML = `
            <div class="px-6 py-4 border-b bg-gradient-to-r from-green-50 to-teal-50">
                <h2 class="text-lg font-semibold text-slate-800 flex items-center">
                    <i class="material-icons mr-2 text-green-600">assessment</i>
                    Grading Overview
                </h2>
                <p class="text-sm text-slate-600 mt-1">
                    ${gradingData.programmeName} - ${gradingData.modeOfStudy} - ${gradingData.academicYear} - Semester ${gradingData.semester}
                </p>
            </div>
            <div class="p-6">
                <div class="overflow-x-auto">
                    <table class="w-full border-collapse border border-gray-300 text-sm">
