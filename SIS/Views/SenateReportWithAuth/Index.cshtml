        hideModal(modal);
        currentGradingOverviewData = null;
    }

    function exportGradingOverview() {
        if (!currentGradingOverviewData) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'No data to export',
                confirmButtonColor: '#dc2626'
            });
            return;
        }

        // Get the table
        const table = document.querySelector('#gradingOverviewContent table');
        if (!table) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'No data to export',
                confirmButtonColor: '#dc2626'
            });
            return;
        }

        // Convert table to CSV
        let csv = [];

        // Add title and subtitle
        const subtitle = document.getElementById('gradingOverviewSubtitle').textContent;
        csv.push(['Grading Overview']);
        csv.push([subtitle]);
        csv.push([]); // Empty row

        // Get headers
        const headers = [];
        table.querySelectorAll('thead th').forEach(th => {
            headers.push(th.textContent.replace(/\n/g, ' ').trim());
        });
        csv.push(headers);

        // Get body rows
        table.querySelectorAll('tbody tr').forEach(tr => {
            const row = [];
            tr.querySelectorAll('td').forEach(td => {
                row.push(td.textContent.trim());
            });
            csv.push(row);
        });

        // Get totals row
        const totalsRow = [];
        table.querySelectorAll('tfoot tr td').forEach(td => {
            totalsRow.push(td.textContent.trim());
        });
        csv.push(totalsRow);

        // Convert to CSV string
        const csvContent = csv.map(row => row.join(',')).join('\n');

        // Download
        const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement('a');
        const url = URL.createObjectURL(blob);

        link.setAttribute('href', url);
        link.setAttribute('download', `Grading_Overview_${Date.now()}.csv`);
        link.style.visibility = 'hidden';

        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

        Swal.fire({
            icon: 'success',
            title: 'Exported!',
            text: 'Grading overview has been exported to CSV',
            timer: 2000,
            showConfirmButton: false
        });
    }

    function escapeHtml(text) {
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text ? text.replace(/[&<>"']/g, m => map[m]) : '';
    }

