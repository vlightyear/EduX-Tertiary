        function getTableHeaders(reportLevel) {
            return [
                reportLevel === 'School' ? 'School' :
                reportLevel === 'Department' ? 'Department' : 'Programme',
                'Total Students',
                'With Results',
                'Without Results',
                'Pass Rate',
                'Avg GPA',
                'Progression Breakdown',
                'Actions'
            ];
        }

        function getProgressionBreakdown(progressionCounts) {
            if (!progressionCounts || Object.keys(progressionCounts).length === 0) {
                return '<span class="text-slate-400">No data</span>';
            }

            const breakdown = Object.entries(progressionCounts)
                .map(([rule, count]) => `${getProgressionRuleShortName(rule)}: ${count}`)
                .join(' | ');

            return `<span class="text-xs">${breakdown}</span>`;
        }

        function getProgressionRuleShortName(rule) {
            const shortNames = {
                'Proceed': 'Pass',
                'ProceedWithRepeat': 'Pass+Rep',
                'ProceedOnProbation': 'Probation',
                'RepeatYear': 'Repeat Yr',
                'RepeatSemester': 'Repeat Sem',
                'Exclude': 'Exclude',
                'Withdraw': 'Withdraw'
            };
            return shortNames[rule] || rule;
        }

        function updateReportMetadata(reportData) {
            const metadata = `Generated: ${new Date(reportData.generatedAt).toLocaleString()} |
                             ${reportData.summaries.length} ${reportData.reportLevel}(s) |
                             ${reportData.totals.totalStudents} Students`;

            document.getElementById('reportMetadata').textContent = metadata;
            document.getElementById('reportTitle').textContent = `${reportData.reportLevel} Level Report`;
        }

        async function performDrillDown(level, entityId) {
            showState('loading');

            // Hide performance summary when drilling down
            hidePerformanceSummary();

            try {
                const params = new URLSearchParams({
                    level: level,
                    entityId: entityId,
                    ...pageData.currentFilters
                });

                const response = await fetch(`/SenateReportWithAuth/DrillDown?${params}`);
                const data = await response.json();

                if (data.success) {
                    pageData.breadcrumbHistory.push({
                        filters: { ...pageData.currentFilters },
                        reportData: { ...pageData.currentReportData }
                    });

                    pageData.currentFilters.reportLevel = data.level;
                    pageData.currentReportData = data.data;
                    viewModel = data.data; // Update for batch publishing

                    displayReportResults(data.data);
                    document.getElementById('backToParent').classList.remove('hidden');
                    showAlert('success', 'Success', data.message);
                } else {
                    showErrorState(data.message);
                }
            } catch (error) {
                console.error('Error in drill-down:', error);
                showErrorState('Failed to load drill-down report');
            }
        }

        // Entity Details Functions
        async function showEntityDetails(entityId) {
            const modal = elements.entityDetailsModal;
            const loadingState = document.getElementById('entityDetailsLoading');
            const tableBody = document.getElementById('entityStudentsTableBody');
            const emptyState = document.getElementById('entityDetailsEmpty');

            showModal(modal);
            loadingState.classList.remove('hidden');
            tableBody.innerHTML = '';
            emptyState.classList.add('hidden');

            try {
                const entity = pageData.currentReportData.summaries.find(s => s.entityId === entityId);
                if (!entity) {
                    throw new Error('Entity not found');
                }

                const params = new URLSearchParams({
                    entityId: entityId,
                    entityType: entity.entityType,
                    ...pageData.currentFilters
                });

                const response = await fetch(`/SenateReportWithAuth/GetEntityStudentDetails?${params}`);
                const result = await response.json();

                loadingState.classList.add('hidden');

                if (result.success) {
                    currentEntityDetails = result.data;
                    filteredStudents = result.data.students;
                    displayEntityStudentDetails(result.data);
                } else {
                    throw new Error(result.message);
                }
            } catch (error) {
                console.error('Error loading entity details:', error);
                loadingState.classList.add('hidden');
                emptyState.classList.remove('hidden');
                showAlert('error', 'Error', 'Failed to load student details: ' + error.message);
            }
        }

