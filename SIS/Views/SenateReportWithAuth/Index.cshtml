    function updateGradingSummary(courses) {
        const totalCourses = courses.length;
        const totalPassed = courses.reduce((sum, c) => sum + c.totalPassed, 0);
        const totalFailed = courses.reduce((sum, c) => sum + c.totalFailed, 0);
        const total = totalPassed + totalFailed;
        const passRate = total > 0 ? Math.round((totalPassed / total) * 100) : 0;

        document.getElementById('summaryTotalCourses').textContent = totalCourses;
        document.getElementById('summaryTotalPassed').textContent = totalPassed;
        document.getElementById('summaryTotalFailed').textContent = totalFailed;
        document.getElementById('summaryPassRate').textContent = passRate + '%';
    }

