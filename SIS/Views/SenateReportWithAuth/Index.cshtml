                </div>
                <div class="bg-white border border-slate-200 rounded-lg p-4">
                    <div class="flex items-center">
                        <div class="bg-amber-100 rounded-full p-2 mr-3">
                            <i class="material-icons text-amber-600">pending</i>
                        </div>
                        <div>
                            <p class="text-xs text-slate-500 font-medium">Pending Results</p>
                            <p class="text-2xl font-bold text-slate-800">${data.studentsWithoutResults}</p>
                        </div>
                    </div>
                </div>
                <div class="bg-white border border-slate-200 rounded-lg p-4">
                    <div class="flex items-center">
                        <div class="bg-purple-100 rounded-full p-2 mr-3">
                            <i class="material-icons text-purple-600">grade</i>
                        </div>
                        <div>
                            <p class="text-xs text-slate-500 font-medium">Average GPA</p>
                            <p class="text-2xl font-bold text-slate-800">${data.averageGPA.toFixed(2)}</p>
                        </div>
                    </div>
                </div>
            `;

            if (data.students && data.students.length > 0) {
                renderEntityStudentsTable(data.students);
                countElement.textContent = `${data.students.length} student${data.students.length !== 1 ? 's' : ''}`;
            } else {
                document.getElementById('entityDetailsEmpty').classList.remove('hidden');
                countElement.textContent = '0 students';
            }
        }

        function renderEntityStudentsTable(students) {
            const tableBody = document.getElementById('entityStudentsTableBody');
            tableBody.innerHTML = '';

            students.forEach((student, index) => {
                const row = document.createElement('tr');
                row.className = `${index % 2 === 0 ? 'bg-white' : 'bg-slate-50'} hover:bg-slate-100 transition-colors`;

                const progressionBadge = getProgressionBadge(student.progressionRule);
                const gpaDisplay = student.hasPublishedResults ? student.gpa.toFixed(2) : 'N/A';

                row.innerHTML = `
                    <td class="px-4 py-3 whitespace-nowrap font-medium text-slate-900">${student.studentNumber}</td>
                    <td class="px-4 py-3">${student.studentName}</td>
                    <td class="px-4 py-3 text-center">${student.totalCourses}</td>
                    <td class="px-4 py-3 text-center">
                        ${student.hasPublishedResults ?
                            `<span class="${student.failedCourses > 0 ? 'text-red-600 font-semibold' : 'text-slate-600'}">${student.failedCourses}</span>` :
                            '<span class="text-slate-400">-</span>'}
                    </td>
                    <td class="px-4 py-3 text-center font-medium">
                        ${student.hasPublishedResults ?
                            `<span class="${getGPAColorClass(student.gpa)}">${gpaDisplay}</span>` :
                            '<span class="text-slate-400">N/A</span>'}
                    </td>
                    <td class="px-4 py-3">${progressionBadge}</td>
                    <td class="px-4 py-3 text-center">
                        <button class="inline-flex items-center px-3 py-1 text-xs text-secondary-600 bg-secondary-50 hover:bg-secondary-100 rounded-lg transition-colors view-student-detail-btn"
                                data-student-id="${student.studentId}"
                                ${!student.hasPublishedResults ? 'disabled title="No published results"' : ''}>
                            <i class="material-icons text-xs mr-1">visibility</i>
                            View Detail
                        </button>
                    </td>
                `;

                tableBody.appendChild(row);
            });

            document.querySelectorAll('.view-student-detail-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const studentId = parseInt(this.dataset.studentId);
                    showStudentDetail(studentId);
                });
            });
        }

        function filterEntityStudents() {
            if (!currentEntityDetails) return;

            const searchTerm = document.getElementById('studentSearch').value.toLowerCase();
            const progressionFilterValue = document.getElementById('progressionFilter').value;

            filteredStudents = currentEntityDetails.students.filter(student => {
                const matchesSearch = student.studentNumber.toLowerCase().includes(searchTerm) ||
                                    student.studentName.toLowerCase().includes(searchTerm);
                const matchesProgression = !progressionFilterValue || student.progressionRule === progressionFilterValue;

                return matchesSearch && matchesProgression;
            });

            renderEntityStudentsTable(filteredStudents);
            document.getElementById('entityDetailsCount').textContent =
                `${filteredStudents.length} student${filteredStudents.length !== 1 ? 's' : ''}`;
        }

        // Student Detail Functions
        async function showStudentDetail(studentId) {
            const modal = elements.studentDetailModal;
            const loadingState = document.getElementById('studentDetailLoading');
            const studentInfo = document.getElementById('studentInfoSection');
            const performanceSummary = document.getElementById('performanceSummary');
            const coursesTableBody = document.getElementById('studentCoursesTableBody');

            showModal(modal);
            loadingState.classList.remove('hidden');
            studentInfo.innerHTML = '';
            performanceSummary.innerHTML = '';
            coursesTableBody.innerHTML = '';

            try {
                const params = new URLSearchParams({
                    studentId: studentId,
                    ...pageData.currentFilters
                });

                const response = await fetch(`/SenateReportWithAuth/GetStudentProgressionDetail?${params}`);
                const result = await response.json();

                loadingState.classList.add('hidden');

                if (result.success) {
                    displayStudentProgressionDetail(result.data);
                } else {
                    throw new Error(result.message);
                }
            } catch (error) {
                console.error('Error loading student detail:', error);
                loadingState.classList.add('hidden');
                showAlert('error', 'Error', 'Failed to load student progression detail: ' + error.message);
                hideModal(modal);
            }
        }

        function displayStudentProgressionDetail(data) {
            const titleElement = document.getElementById('studentDetailTitle');
            const studentInfo = document.getElementById('studentInfoSection');
            const performanceSummary = document.getElementById('performanceSummary');
            const coursesTableBody = document.getElementById('studentCoursesTableBody');

            titleElement.textContent = `${data.studentNumber} - ${data.studentName}`;

            studentInfo.innerHTML = `
                <div class="space-y-2">
                    <div class="flex items-start">
                        <i class="material-icons text-secondary-600 mr-2">badge</i>
                        <div>
                            <p class="text-xs text-slate-500">Student Number</p>
                            <p class="font-semibold text-slate-800">${data.studentNumber}</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <i class="material-icons text-secondary-600 mr-2">school</i>
                        <div>
                            <p class="text-xs text-slate-500">Programme</p>
                            <p class="font-semibold text-slate-800">${data.programme}</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <i class="material-icons text-secondary-600 mr-2">domain</i>
                        <div>
                            <p class="text-xs text-slate-500">Department</p>
                            <p class="font-semibold text-slate-800">${data.department}</p>
                        </div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex items-start">
                        <i class="material-icons text-secondary-600 mr-2">business</i>
                        <div>
                            <p class="text-xs text-slate-500">School</p>
                            <p class="font-semibold text-slate-800">${data.school}</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <i class="material-icons text-secondary-600 mr-2">calendar_today</i>
                        <div>
                            <p class="text-xs text-slate-500">Year & Semester</p>
                            <p class="font-semibold text-slate-800">Year ${data.yearOfStudy}, Semester ${data.semester}</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <i class="material-icons text-secondary-600 mr-2">trending_up</i>
                        <div>
                            <p class="text-xs text-slate-500">Academic Standing</p>
                            <p class="font-semibold text-slate-800">${data.academicStanding}</p>
                        </div>
                    </div>
                </div>
            `;

            performanceSummary.innerHTML = `
                <div class="bg-white border border-slate-200 rounded-lg p-4 text-center">
                    <i class="material-icons text-purple-600 mb-2">grade</i>
                    <p class="text-xs text-slate-500 font-medium">GPA</p>
                    <p class="text-2xl font-bold ${getGPAColorClass(data.gpa)}">${data.gpa.toFixed(2)}</p>
                </div>
                <div class="bg-white border border-slate-200 rounded-lg p-4 text-center">
                    <i class="material-icons text-blue-600 mb-2">assignment</i>
                    <p class="text-xs text-slate-500 font-medium">Total Courses</p>
                    <p class="text-2xl font-bold text-slate-800">${data.totalCourses}</p>
                </div>
                <div class="bg-white border border-slate-200 rounded-lg p-4 text-center">
                    <i class="material-icons ${data.failedCourses > 0 ? 'text-red-600' : 'text-green-600'} mb-2">
                        ${data.failedCourses > 0 ? 'close' : 'check_circle'}
                    </i>
                    <p class="text-xs text-slate-500 font-medium">Failed Courses</p>
                    <p class="text-2xl font-bold ${data.failedCourses > 0 ? 'text-red-600' : 'text-green-600'}">${data.failedCourses}</p>
                </div>
                <div class="bg-white border border-slate-200 rounded-lg p-4 text-center">
                    <i class="material-icons text-secondary-600 mb-2">rule</i>
                    <p class="text-xs text-slate-500 font-medium">Progression</p>
                    <p class="text-sm font-bold text-slate-800">${formatProgressionRule(data.progressionRule)}</p>
                </div>
            `;

            if (data.courses && data.courses.length > 0) {
                data.courses.forEach((course, index) => {
                    const row = document.createElement('tr');
                    row.className = `${index % 2 === 0 ? 'bg-white' : 'bg-slate-50'}`;

                    const statusBadge = getStatusBadge(course.status, course.isPassed);

                    row.innerHTML = `
                        <td class="px-4 py-3 font-medium text-slate-900">${course.courseCode}</td>
                        <td class="px-4 py-3">${course.courseName}</td>
                        <td class="px-4 py-3 text-center">${course.credits}</td>
                        <td class="px-4 py-3 text-center">${course.semester}</td>
                        <td class="px-4 py-3 text-center font-medium">${course.totalScore > 0 ? course.totalScore.toFixed(1) : '-'}</td>
                        <td class="px-4 py-3 text-center font-bold ${getGradeColorClass(course.grade)}">${course.grade || '-'}</td>
                        <td class="px-4 py-3 text-center">${course.gradePoints > 0 ? course.gradePoints.toFixed(2) : '-'}</td>
                        <td class="px-4 py-3 text-center">${statusBadge}</td>
                    `;

                    coursesTableBody.appendChild(row);
                });
            } else {
                coursesTableBody.innerHTML = `
                    <tr>
                        <td colspan="8" class="px-4 py-8 text-center text-slate-500">
                            <i class="material-icons text-4xl text-slate-300 mb-2">inbox</i>
                            <p>No course data available</p>
                        </td>
                    </tr>
                `;
            }
        }

        // Helper Functions
        function getProgressionBadge(rule) {
            const badges = {
                'Proceed': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Proceed</span>',
                'ProceedWithRepeat': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Proceed + Repeat</span>',
                'ProceedOnProbation': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-800">Probation</span>',
                'RepeatYear': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800">Repeat Year</span>',
                'RepeatSemester': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800">Repeat Semester</span>',
                'Exclude': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">Exclude</span>',
                'Withdraw': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">Withdraw</span>',
                'Results Pending': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-800">Pending</span>',
                'Academic Exclusion': '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">Exclusion</span>'
            };
            return badges[rule] || `<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-800">${rule}</span>`;
        }

        function getStatusBadge(status, isPassed) {
            if (status === 'Pass' || isPassed) {
                return '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Pass</span>';
            } else if (status === 'Fail') {
                return '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">Fail</span>';
            } else {
                return `<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-800">${status}</span>`;
            }
        }

        function getGPAColorClass(gpa) {
            if (gpa >= 3.5) return 'text-green-600';
            if (gpa >= 3.0) return 'text-blue-600';
            if (gpa >= 2.5) return 'text-amber-600';
            if (gpa >= 2.0) return 'text-orange-600';
            return 'text-red-600';
        }

        function getGradeColorClass(grade) {
            if (['A+', 'A', 'A-'].includes(grade)) return 'text-green-600';
            if (['B+', 'B', 'B-'].includes(grade)) return 'text-blue-600';
            if (['C+', 'C', 'C-'].includes(grade)) return 'text-amber-600';
            if (['D+', 'D', 'D-'].includes(grade)) return 'text-orange-600';
            return 'text-red-600';
        }

        function formatProgressionRule(rule) {
            return rule.replace(/([A-Z])/g, ' $1').trim();
        }

        function exportEntityDetailsList() {
            if (!currentEntityDetails) return;
            showAlert('info', 'Export Started', 'Exporting entity details list...');
        }

        function printStudentDetail() {
            window.print();
        }

        function refreshCurrentReport() {
            if (pageData.currentFilters && Object.keys(pageData.currentFilters).length > 0) {
                generateReport();
            } else {
                showAlert('warning', 'No Report to Refresh', 'Please generate a report first');
            }
        }

        async function exportToPdf() {
            if (!pageData.currentFilters || Object.keys(pageData.currentFilters).length === 0) {
                showAlert('warning', 'No Report to Export', 'Please generate a report first');
                return;
            }

            try {
                hideModal(elements.exportModal);

                // Show loading
                Swal.fire({
                    title: 'Generating PDF...',
                    html: 'Please wait while we generate your report.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                const response = await fetch('/SenateReportWithAuth/ExportToPdf', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(pageData.currentFilters)
                });

                // Check if it's an error (JSON) or success (file)
                const contentType = response.headers.get('content-type');

                if (contentType && contentType.includes('application/json')) {
                    // Error response
                    const data = await response.json();
                    Swal.close();
                    showAlert('error', 'Export Failed', data.message);
                } else {
                    // SUCCESS - Download the file
                    const blob = await response.blob(); // ✅ CORRECT - Handle binary data

                    // Create download link
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `Senate_Report_${new Date().getTime()}.pdf`;
                    document.body.appendChild(a);
                    a.click();

                    // Cleanup
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);

                    Swal.fire({
                        icon: 'success',
                        title: 'PDF Generated!',
                        text: 'Your report has been downloaded.',
                        timer: 3000,
                        showConfirmButton: false
                    });
                }
            } catch (error) {
                console.error('Error exporting to PDF:', error);
                Swal.close();
                showAlert('error', 'Export Failed', 'An error occurred');
            }
        }

        async function exportToExcel() {
            if (!pageData.currentFilters || Object.keys(pageData.currentFilters).length === 0) {
                showAlert('warning', 'No Report to Export', 'Please generate a report first');
                return;
            }

            try {
                hideModal(elements.exportModal);
                showAlert('info', 'Export Started', 'Generating Excel report...');

                const response = await fetch('/SenateReportWithAuth/ExportToExcel', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(pageData.currentFilters)
                });

                const data = await response.json();

                if (data.success) {
                    showAlert('success', 'Success', data.message);
                } else {
                    showAlert('error', 'Export Failed', data.message);
                }
            } catch (error) {
                console.error('Error exporting to Excel:', error);
                showAlert('error', 'Export Failed', 'An error occurred while generating the Excel file');
            }
        }

        // State management functions
        function showState(state) {
            elements.welcomeMessage.classList.add('hidden');
            elements.loadingState.classList.add('hidden');
            elements.reportResults.classList.add('hidden');
            elements.errorState.classList.add('hidden');

            switch (state) {
                case 'welcome':
                    elements.welcomeMessage.classList.remove('hidden');
                    break;
                case 'loading':
                    elements.loadingState.classList.remove('hidden');
                    break;
                case 'results':
                    elements.reportResults.classList.remove('hidden');
                    break;
                case 'error':
                    elements.errorState.classList.remove('hidden');
                    break;
            }
        }

        function showErrorState(message) {
            document.getElementById('errorMessage').textContent = message;
            showState('error');
        }

        // Alert function
        function showAlert(type, title, text) {
            const alertTemplate = elements.alertTemplate;
            const alertEl = alertTemplate.cloneNode(true);
            alertEl.id = '';
            alertEl.classList.remove('hidden');

            const alertIcon = alertEl.querySelector('.alert-icon');
            const alertTitle = alertEl.querySelector('.alert-title');
            const alertText = alertEl.querySelector('.alert-text');
            const alertButtons = alertEl.querySelector('.alert-buttons');

            let iconName, colorClass;
            switch (type) {
                case 'error':
                    iconName = 'error';
                    colorClass = 'text-red-600';
                    break;
                case 'success':
                    iconName = 'check_circle';
                    colorClass = 'text-green-600';
                    break;
                case 'warning':
                    iconName = 'warning';
                    colorClass = 'text-amber-600';
                    break;
                default:
                    iconName = 'info';
                    colorClass = 'text-blue-600';
            }

            alertIcon.textContent = iconName;
            alertTitle.textContent = title;
            alertTitle.className = `text-lg font-semibold ${colorClass}`;
            alertText.textContent = text;

            alertButtons.innerHTML = `
                <button class="w-full bg-primary-600 text-white py-2 px-4 rounded-lg hover:bg-primary-700 transition-colors">
                    OK
                </button>
            `;

            document.body.appendChild(alertEl);

            const closeBtn = alertEl.querySelector('button');
            closeBtn.onclick = () => {
                alertEl.remove();
            };

            setTimeout(() => {
                if (alertEl.parentNode) {
                    alertEl.remove();
                }
            }, 5000);
        }

        // Initialize validation on page load
        validateFilters();
    });
</script>
