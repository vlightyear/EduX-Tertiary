                button.addEventListener('click', () => hideModal(elements.studentDetailModal));
            });

            // Student search
            const studentSearch = document.getElementById('studentSearch');
            if (studentSearch) {
                studentSearch.addEventListener('input', filterEntityStudents);
            }

            // Progression filter
            const progressionFilter = document.getElementById('progressionFilter');
            if (progressionFilter) {
                progressionFilter.addEventListener('change', filterEntityStudents);
            }

            // Export entity details button
            const exportEntityDetailsBtn = document.getElementById('exportEntityDetailsBtn');
            if (exportEntityDetailsBtn) {
                exportEntityDetailsBtn.addEventListener('click', exportEntityDetailsList);
            }

            // Print student detail button
            const printStudentDetailBtn = document.getElementById('printStudentDetailBtn');
            if (printStudentDetailBtn) {
                printStudentDetailBtn.addEventListener('click', printStudentDetail);
            }
        }

        function initializeCascadingFilters() {
            // School filter change
            elements.schoolFilter.addEventListener('change', function() {
                const schoolId = this.value;
                if (schoolId) {
                    loadDepartments(schoolId);
                } else {
                    resetDepartmentFilter();
                    resetProgrammeFilter();
                }
            });

            // Department filter change
            elements.departmentFilter.addEventListener('change', function() {
                const departmentId = this.value;
                if (departmentId) {
                    loadProgrammes(departmentId);
                } else {
                    resetProgrammeFilter();
                }
            });
        }

        // ===================================================================
        // NEW: Initialize Default Selections for Restricted Users
        // ===================================================================
        function initializeDefaultSelections() {
            console.log('Initializing default selections...');
            console.log('Preloaded data:', preloadedData);

            // Check if user has restricted access (HOD or Dean)
            if (preloadedData.hasFullAccess) {
                console.log('User has full access, skipping default selections');
                return;
            }

            // Set default school if available
            if (preloadedData.defaultSchoolId) {
                console.log('Setting default school:', preloadedData.defaultSchoolId);
                elements.schoolFilter.value = preloadedData.defaultSchoolId;
            }

            // Pre-populate departments from ViewBag data if available
            if (preloadedData.filteredDepartments && preloadedData.filteredDepartments.length > 0) {
                console.log('Pre-populating departments from ViewBag:', preloadedData.filteredDepartments.length, 'departments');
                populateDepartmentFilterFromPreloaded(preloadedData.filteredDepartments);
                elements.departmentFilter.disabled = false;

                // Set default department if available
                if (preloadedData.defaultDepartmentId) {
                    console.log('Setting default department:', preloadedData.defaultDepartmentId);
                    elements.departmentFilter.value = preloadedData.defaultDepartmentId;
                }
            }

            // Pre-populate programmes from ViewBag data if available
            if (preloadedData.filteredProgrammes && preloadedData.filteredProgrammes.length > 0) {
                console.log('Pre-populating programmes from ViewBag:', preloadedData.filteredProgrammes.length, 'programmes');
                populateProgrammeFilterFromPreloaded(preloadedData.filteredProgrammes);
                elements.programmeFilter.disabled = false;

                // Set default programme if available
                if (preloadedData.defaultProgrammeId) {
                    console.log('Setting default programme:', preloadedData.defaultProgrammeId);
                    elements.programmeFilter.value = preloadedData.defaultProgrammeId;
                }
            }

            console.log('Default selections initialized');
        }

        // Populate department filter from preloaded data (handles camelCase from JSON)
        function populateDepartmentFilterFromPreloaded(departments) {
            elements.departmentFilter.innerHTML = '<option value="">All Departments</option>';
            departments.forEach(dept => {
                const option = document.createElement('option');
                // Handle both camelCase (JSON) and PascalCase (C#) property names
                option.value = dept.id !== undefined ? dept.id : dept.Id;
                option.textContent = dept.name !== undefined ? dept.name : dept.Name;
                elements.departmentFilter.appendChild(option);
            });
        }

        // Populate programme filter from preloaded data (handles camelCase from JSON)
        function populateProgrammeFilterFromPreloaded(programmes) {
            elements.programmeFilter.innerHTML = '<option value="">All Programmes</option>';
            programmes.forEach(prog => {
                const option = document.createElement('option');
                // Handle both camelCase (JSON) and PascalCase (C#) property names
                option.value = prog.id !== undefined ? prog.id : prog.Id;
                option.textContent = prog.name !== undefined ? prog.name : prog.Name;
                elements.programmeFilter.appendChild(option);
            });
        }

        async function loadDepartments(schoolId) {
            try {
                // First check if we have preloaded data that matches this school
                if (preloadedData.filteredDepartments && preloadedData.filteredDepartments.length > 0) {
                    const matchingDepartments = preloadedData.filteredDepartments.filter(d => {
                        const deptSchoolId = d.schoolId !== undefined ? d.schoolId : d.SchoolId;
                        return deptSchoolId == schoolId;
                    });

                    if (matchingDepartments.length > 0) {
                        console.log('Using preloaded departments for school', schoolId);
                        populateDepartmentFilterFromPreloaded(matchingDepartments);
                        elements.departmentFilter.disabled = false;
                        resetProgrammeFilter();
                        return;
                    }
                }

                // Fall back to AJAX call
                console.log('Loading departments from server for school', schoolId);
                const response = await fetch(`/SenateReportWithAuth/GetDepartmentsBySchool?schoolId=${schoolId}`);
                const data = await response.json();console.log(data);

                if (data.success) {
                    populateDepartmentFilter(data.departments);
                    elements.departmentFilter.disabled = false;
                } else {
                    showAlert('error', 'Error', 'Failed to load departments');
                }
            } catch (error) {
                console.error('Error loading departments:', error);
                showAlert('error', 'Error', 'Failed to load departments');
            }
        }

        async function loadProgrammes(departmentId) {
            try {
                // First check if we have preloaded data that matches this department
                if (preloadedData.filteredProgrammes && preloadedData.filteredProgrammes.length > 0) {
                    const matchingProgrammes = preloadedData.filteredProgrammes.filter(p => {
                        const progDeptId = p.departmentId !== undefined ? p.departmentId : p.DepartmentId;
                        return progDeptId == departmentId;
                    });

                    if (matchingProgrammes.length > 0) {
                        console.log('Using preloaded programmes for department', departmentId);
                        populateProgrammeFilterFromPreloaded(matchingProgrammes);
                        elements.programmeFilter.disabled = false;
                        return;
                    }
                }

                // Fall back to AJAX call
                console.log('Loading programmes from server for department', departmentId);
                const response = await fetch(`/SenateReportWithAuth/GetProgrammesByDepartment?departmentId=${departmentId}`);
                const data = await response.json();

                if (data.success) {
                    populateProgrammeFilter(data.programmes);
                    elements.programmeFilter.disabled = false;
                } else {
                    showAlert('error', 'Error', 'Failed to load programmes');
                }
            } catch (error) {
                console.error('Error loading programmes:', error);
                showAlert('error', 'Error', 'Failed to load programmes');
            }
        }

        function populateDepartmentFilter(departments) {
            elements.departmentFilter.innerHTML = '<option value="">All Departments</option>';
            departments.forEach(dept => {
                const option = document.createElement('option');
                // Handle both camelCase and PascalCase property names
                option.value = dept.id !== undefined ? dept.id : dept.Id;
                option.textContent = dept.name !== undefined ? dept.name : dept.Name;
                elements.departmentFilter.appendChild(option);
            });
            resetProgrammeFilter();
        }

        function populateProgrammeFilter(programmes) {
            elements.programmeFilter.innerHTML = '<option value="">All Programmes</option>';
            programmes.forEach(prog => {
                const option = document.createElement('option');
                // Handle both camelCase and PascalCase property names
                option.value = prog.id !== undefined ? prog.id : prog.Id;
                option.textContent = prog.name !== undefined ? prog.name : prog.Name;
                elements.programmeFilter.appendChild(option);
            });
        }

        function resetDepartmentFilter() {
            elements.departmentFilter.innerHTML = '<option value="">All Departments</option>';
            elements.departmentFilter.disabled = true;
            resetProgrammeFilter();
        }

        function resetProgrammeFilter() {
            elements.programmeFilter.innerHTML = '<option value="">All Programmes</option>';
            elements.programmeFilter.disabled = true;
        }

        function handleReportLevelChange() {
            validateFilters();
        }

        function validateFilters() {
            const academicYear = elements.academicYearFilter.value;
            const isValid = academicYear !== '';

            elements.generateReportBtn.disabled = !isValid;

            if (!isValid) {
                elements.generateReportBtn.classList.add('opacity-50', 'cursor-not-allowed');
            } else {
                elements.generateReportBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            }
        }

        function getFilterValues() {
            return {
                academicYearId: elements.academicYearFilter.value || null,
                reportLevel: elements.reportLevelFilter.value || 'School',
                schoolId: elements.schoolFilter.value || null,
                departmentId: elements.departmentFilter.value || null,
                programmeId: elements.programmeFilter.value || null,
                modeOfStudyId: elements.modeOfStudyFilter.value || null,
                yearOfStudy: elements.yearOfStudyFilter.value || null,
                academicPeriod: elements.semesterFilter.value || null,
                period: 'Current'
            };
        }

