    async function loadGradingOverview() {
        const loadingDiv = document.getElementById('gradingOverviewLoading');
        const contentDiv = document.getElementById('gradingOverviewContent');
        const emptyDiv = document.getElementById('gradingOverviewEmpty');

        // Show loading
        loadingDiv.classList.remove('hidden');
        contentDiv.classList.add('hidden');
        emptyDiv.classList.add('hidden');

        try {
            const response = await fetch(
                `/SenateReportWithAuth/GetProgrammeGradingOverview?programmeId=${currentGradingOverviewData.programmeId}&academicYearId=${pageData.currentFilters.academicYearId}&semester=${pageData.currentFilters.academicPeriod}&yearOfStudy=${pageData.currentFilters.yearOfStudy || 0}`
            );

            const result = await response.json();

            if (result.success && result.data) {
                // Update subtitle
                const subtitle = `${result.data.programmeName} - ${result.data.modeOfStudy} - ${result.data.academicYear} - Semester ${result.data.semester}`;
                document.getElementById('gradingOverviewSubtitle').textContent = subtitle;

                // Check if there are courses
                if (result.data.courses && result.data.courses.length > 0) {
                    renderGradingOverview(result.data);
                    contentDiv.classList.remove('hidden');
                } else {
                    emptyDiv.classList.remove('hidden');
                }
            } else {
                throw new Error(result.message || 'Failed to load grading overview');
            }
        } catch (error) {
            console.error('Error loading grading overview:', error);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to load grading overview',
                confirmButtonColor: '#dc2626'
            });
            hideGradingOverviewModal();
        } finally {
            loadingDiv.classList.add('hidden');
        }
    }

    function renderGradingOverview(data) {
        const tbody = document.getElementById('gradingOverviewTableBody');
        tbody.innerHTML = '';

        // Initialize totals
        const totals = {
            'A+': 0, 'A': 0, 'B+': 0, 'B': 0,
            'C+': 0, 'C': 0, 'D+': 0, 'D': 0,
            'EXP': 0, 'NE/INC': 0, 'DEF': 0, 'P': 0, 'F': 0,
            totalFailed: 0,
            totalPassed: 0
        };

        // Render each course row
        data.courses.forEach(course => {
            const row = document.createElement('tr');
            row.className = 'hover:bg-gray-50';

            const gradeOrder = ['A+', 'A', 'B+', 'B', 'C+', 'C', 'D+', 'D', 'EXP', 'NE/INC', 'DEF', 'P', 'F'];

            // Build row HTML
            let rowHTML = `
                <td class="px-4 py-3 font-medium text-gray-900">${escapeHtml(course.courseNo)}</td>
                <td class="px-4 py-3 text-gray-900">${escapeHtml(course.courseName)}</td>
            `;

            // Add grade columns with background colors
            const gradeColors = {
                'A+': 'bg-purple-50', 'A': 'bg-purple-50',
                'B+': 'bg-blue-50', 'B': 'bg-blue-50',
                'C+': 'bg-green-50', 'C': 'bg-green-50',
                'D+': 'bg-yellow-50', 'D': 'bg-yellow-50',
                'EXP': 'bg-orange-50',
                'NE/INC': 'bg-gray-50', 'DEF': 'bg-gray-50',
                'P': 'bg-teal-50',
                'F': 'bg-red-50'
            };

            gradeOrder.forEach((grade, index) => {
                const count = course.gradeDistribution[grade] || 0;
                const borderClass = (index === 0 || index === 9 || index === 15) ? 'border-l' : '';
                const bgColor = gradeColors[grade] || '';

                rowHTML += `<td class="px-3 py-3 text-center ${borderClass} ${bgColor}">${count}</td>`;

                // Add to totals
                totals[grade] += count;
            });

            // Add summary columns
            rowHTML += `
                <td class="px-4 py-3 text-center font-semibold border-l bg-red-50">${course.totalFailed}</td>
                <td class="px-4 py-3 text-center font-semibold bg-green-50">${course.totalPassed}</td>
                <td class="px-4 py-3 text-center font-semibold bg-blue-50">${course.passRate}%</td>
            `;

            row.innerHTML = rowHTML;
            tbody.appendChild(row);

            // Add to summary totals
            totals.totalFailed += course.totalFailed;
            totals.totalPassed += course.totalPassed;
        });

        // Render totals row
        renderGradingTotals(totals, data.courses.length);

        // Update summary cards
        updateGradingSummary(data.courses);
    }

    function renderGradingTotals(totals, courseCount) {
        const totalsRow = document.getElementById('gradingOverviewTotals');

        const gradeOrder = ['A+', 'A', 'B+', 'B', 'C+', 'C', 'D+', 'D', 'EXP', 'NE/INC', 'DEF', 'P', 'F'];

