    function showBatchPublishModal(entityId, entityType) {
        // Only allow publishing at programme level
        if (entityType.toLowerCase() !== 'programme') {
            Swal.fire({
                icon: 'info',
                title: 'Programme Level Only',
                text: 'Result batch publishing is only available at the programme level. Please drill down to a specific programme.',
                confirmButtonColor: '#0d6efd'
            });
            return;
        }

        // Find the entity in the current report
        const entity = viewModel.summaries.find(s => s.entityId === entityId && s.entityType.toLowerCase() === 'programme');
        if (!entity) {
            showErrorToast('Programme not found');
            return;
        }

        // Store current programme data
        currentProgrammeData = {
            programmeId: entityId,
            programmeName: entity.entityName,
            academicYearId: viewModel.appliedFilters.academicYearId,
            semester: viewModel.appliedFilters.academicPeriod
        };

        // Reset state
        selectedBatchIds.clear();
        allBatches = [];

        // Show modal
        showModal(document.getElementById('batchPublishModal'));

        // Update modal header info
        document.getElementById('batchProgrammeName').textContent = currentProgrammeData.programmeName;
        document.getElementById('batchAcademicYear').textContent = `Academic Year: ${currentProgrammeData.academicYearId}`;
        document.getElementById('batchSemester').textContent = `Semester ${currentProgrammeData.semester}`;

        // Load batches
        loadProgrammeBatches();
    }

    async function loadProgrammeBatches() {
        const loadingDiv = document.getElementById('batchesLoading');
        const tableContainer = document.querySelector('#batchesTableBody').parentElement.parentElement;
        const emptyDiv = document.getElementById('batchesEmpty');

        // Show loading
        loadingDiv.classList.remove('hidden');
        tableContainer.classList.add('hidden');
        emptyDiv.classList.add('hidden');

        try {
            const response = await fetch(`/SenateReportWithAuth/GetProgrammeBatches?` +
                `programmeId=${currentProgrammeData.programmeId}&` +
                `academicYearId=${currentProgrammeData.academicYearId}&` +
                `semester=${currentProgrammeData.semester}`);

            const result = await response.json();

            if (result.success) {
                allBatches = result.data || [];

                // Update counts
                document.getElementById('pendingBatchCount').textContent = result.pendingCount || 0;
                document.getElementById('approvedBatchCount').textContent = result.approvedCount || 0;

                if (allBatches.length > 0) {
                    renderBatchesTable();
                    tableContainer.classList.remove('hidden');
                } else {
                    emptyDiv.classList.remove('hidden');
                }
            } else {
                showErrorToast(result.message || 'Failed to load batches');
                emptyDiv.classList.remove('hidden');
            }
        } catch (error) {
            console.error('Error loading batches:', error);
            showErrorToast('Error loading batches');
            emptyDiv.classList.remove('hidden');
        } finally {
            loadingDiv.classList.add('hidden');
        }
    }

    function renderBatchesTable() {
        const tbody = document.getElementById('batchesTableBody');
        tbody.innerHTML = '';

        allBatches.forEach((batch, index) => {
            const row = document.createElement('tr');
            row.className = `${index % 2 === 0 ? 'bg-white' : 'bg-slate-50'} ${batch.approvalStatus === 'Approved' ? 'bg-green-50' : ''}`;

            const canSelect = batch.canPublish;
            const isChecked = selectedBatchIds.has(batch.id);

            row.innerHTML = `
                <td class="px-4 py-3">
                    ${canSelect ? `
                        <input type="checkbox"
                               class="form-checkbox h-4 w-4 text-primary-600 rounded batch-checkbox"
                               data-batch-id="${batch.id}"
                               ${isChecked ? 'checked' : ''}>
                    ` : ''}
                </td>
                <td class="px-4 py-3">
                    <div class="font-medium text-slate-900">${batch.courseCode}</div>
                    <div class="text-xs text-slate-500">${batch.courseName}</div>
                </td>
                <td class="px-4 py-3 text-slate-600">${batch.assessmentName || '-'}</td>
                <td class="px-4 py-3">
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                        ${batch.submissionType}
                    </span>
                </td>
                <td class="px-4 py-3 text-center text-slate-600">${batch.totalRecords}</td>
                <td class="px-4 py-3">${getStatusBadgeForBatch(batch.approvalStatus, batch.approvalStatusText)}</td>
                <td class="px-4 py-3 text-sm text-slate-500">${formatDateTime(batch.uploadedAt)}</td>
                <td class="px-4 py-3 text-sm text-slate-500">${batch.uploadedByName}</td>
            `;

            tbody.appendChild(row);
        });

        // Attach event listeners
        document.querySelectorAll('.batch-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', handleBatchCheckboxChange);
        });

        updateSelectedCount();
    }

    function handleBatchCheckboxChange(event) {
        const batchId = parseInt(event.target.dataset.batchId);

        if (event.target.checked) {
            selectedBatchIds.add(batchId);
        } else {
            selectedBatchIds.delete(batchId);
        }

        updateSelectedCount();
    }

    function updateSelectedCount() {
        const count = selectedBatchIds.size;
        document.getElementById('selectedBatchCount').textContent = `${count} selected`;
        document.getElementById('publishCount').textContent = count;

        const publishBtn = document.getElementById('publishSelectedBtn');
        publishBtn.disabled = count === 0;
    }

    async function publishSelectedBatches() {
        if (selectedBatchIds.size === 0) {
            showErrorToast('No batches selected');
            return;
        }

        const result = await Swal.fire({
            title: 'Publish Selected Batches?',
            html: `You are about to publish <strong>${selectedBatchIds.size}</strong> result batch(es).<br><br>` +
                  `This will make the results visible to students and cannot be easily undone.<br><br>` +
                  `Are you sure you want to continue?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#16a34a',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, Publish',
            cancelButtonText: 'Cancel'
        });

        if (!result.isConfirmed) {
            return;
        }

        // Show progress
        Swal.fire({
            title: 'Publishing...',
            html: 'Please wait while we publish the selected batches.',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        try {
            const response = await fetch('/SenateReportWithAuth/PublishBatches', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    batchIds: Array.from(selectedBatchIds)
                })
            });

            const result = await response.json();

            if (result.success) {
                await Swal.fire({
                    icon: 'success',
                    title: 'Published!',
                    html: `<strong>${result.publishedCount}</strong> batch(es) published successfully.` +
                          (result.failedCount > 0 ? `<br><br><strong>${result.failedCount}</strong> batch(es) failed.` : ''),
                    confirmButtonColor: '#16a34a'
                });

                // Clear selection and reload
                selectedBatchIds.clear();
                await loadProgrammeBatches();

                // Close the modal
                const modal = document.getElementById('batchPublishModal');
                if (modal) {
                    hideModal(modal);
                }

                // Refresh the main report - use global reference
                if (window.triggerReportRefresh) {
                    window.triggerReportRefresh();
                }
            } else {
                await Swal.fire({
                    icon: 'error',
                    title: 'Publishing Failed',
                    text: result.message || 'Failed to publish batches',
                    confirmButtonColor: '#dc2626'
                });
            }
        } catch (error) {
            console.error('Error publishing batches:', error);
            await Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'An error occurred while publishing batches',
                confirmButtonColor: '#dc2626'
            });
        }
    }

    async function publishAllPendingBatches() {
        const pendingCount = allBatches.filter(b => b.canPublish).length;

        if (pendingCount === 0) {
            showErrorToast('No pending batches to publish');
            return;
        }

        const result = await Swal.fire({
            title: 'Publish All Pending Batches?',
            html: `You are about to publish <strong>ALL ${pendingCount}</strong> pending result batch(es) for this programme.<br><br>` +
                  `This will make all results visible to students and cannot be easily undone.<br><br>` +
                  `Are you sure you want to continue?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#16a34a',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, Publish All',
            cancelButtonText: 'Cancel'
        });

        if (!result.isConfirmed) {
            return;
        }

        // Show progress
        Swal.fire({
            title: 'Publishing...',
            html: 'Please wait while we publish all pending batches.',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        try {
            const response = await fetch('/SenateReportWithAuth/PublishAllProgrammeBatches', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    programmeId: currentProgrammeData.programmeId,
                    academicYearId: currentProgrammeData.academicYearId,
                    semester: currentProgrammeData.semester
                })
            });

            const result = await response.json();

            if (result.success) {
                await Swal.fire({
                    icon: 'success',
                    title: 'Published!',
                    html: `<strong>${result.publishedCount}</strong> batch(es) published successfully.` +
                          (result.failedCount > 0 ? `<br><br><strong>${result.failedCount}</strong> batch(es) failed.` : ''),
                    confirmButtonColor: '#16a34a'
                });

                // Clear selection and reload
                selectedBatchIds.clear();
                await loadProgrammeBatches();

                // Close the modal
                const modal = document.getElementById('batchPublishModal');
                if (modal) {
                    hideModal(modal);
                }

                // Refresh the main report - use global reference
                if (window.triggerReportRefresh) {
                    window.triggerReportRefresh();
                }
            } else {
                await Swal.fire({
                    icon: 'error',
                    title: 'Publishing Failed',
                    text: result.message || 'Failed to publish batches',
                    confirmButtonColor: '#dc2626'
                });
            }
        } catch (error) {
            console.error('Error publishing all batches:', error);
            await Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'An error occurred while publishing batches',
                confirmButtonColor: '#dc2626'
            });
        }
    }

    // Helper function for status badges (used in batch table)
    function getStatusBadgeForBatch(status, statusText) {
        const badges = {
            'Draft': { color: 'slate', label: statusText },
            'PendingApproval': { color: 'amber', label: statusText },
            'InReview': { color: 'blue', label: statusText },
            'Approved': { color: 'green', label: statusText },
            'Rejected': { color: 'red', label: statusText }
        };

        const badge = badges[status] || { color: 'slate', label: statusText };
        return `<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-${badge.color}-100 text-${badge.color}-800">${badge.label}</span>`;
    }

    // Helper function for date formatting
    function formatDateTime(dateString) {
        const date = new Date(dateString);
        return date.toLocaleString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function showErrorToast(message) {
        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: message,
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000
        });
    }

    // ===================================================================
    // EVENT LISTENERS FOR BATCH PUBLISHING
    // ===================================================================

    document.addEventListener('DOMContentLoaded', function() {
        // Batch publishing modal close
        document.querySelectorAll('.close-batch-publish').forEach(button => {
            button.addEventListener('click', () => hideModal(document.getElementById('batchPublishModal')));
        });

        // Select All Batches
        document.getElementById('selectAllBatches')?.addEventListener('click', function() {
            allBatches.forEach(batch => {
                if (batch.canPublish) {
                    selectedBatchIds.add(batch.id);
                }
            });
            renderBatchesTable();
        });

        // Deselect All Batches
        document.getElementById('deselectAllBatches')?.addEventListener('click', function() {
            selectedBatchIds.clear();
            renderBatchesTable();
        });

        // Select All Checkbox
        document.getElementById('selectAllCheckbox')?.addEventListener('change', function(e) {
            if (e.target.checked) {
                allBatches.forEach(batch => {
                    if (batch.canPublish) {
                        selectedBatchIds.add(batch.id);
                    }
                });
            } else {
                selectedBatchIds.clear();
            }
            renderBatchesTable();
        });

        // Publish Selected Button
        document.getElementById('publishSelectedBtn')?.addEventListener('click', publishSelectedBatches);

        // Publish All Pending Button
        document.getElementById('publishAllPendingBtn')?.addEventListener('click', publishAllPendingBatches);
    });
</script>

