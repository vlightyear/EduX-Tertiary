        /*totalsHTML += `
            <td class="px-4 py-3 text-center border-l">${totals.totalFailed}</td>
            <td class="px-4 py-3 text-center">${totals.totalPassed}</td>
            <td class="px-4 py-3 text-center">${overallPassRate}%</td>
        `;*/

        totalsRow.innerHTML = totalsHTML;
