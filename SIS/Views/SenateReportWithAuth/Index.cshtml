        async function generateReport() {
            const filters = getFilterValues();

            if (!filters.academicYearId) {
                showAlert('warning', 'Missing Information', 'Please select an Academic Year');
                return;
            }

            pageData.currentFilters = filters;
            showState('loading');
            hidePerformanceSummary();
            hideGradingOverview();

            try {
                const response = await fetch('/SenateReportWithAuth/GenerateReport', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(filters)
                });

                const data = await response.json();

                if (data.success) {
                    pageData.currentReportData = data.data || data;
                    viewModel = data.data || data;

                    // Render performance summary if available
                    if (data.performanceSummary && data.performanceSummary.totalStudents > 0) {
                        renderPerformanceSummary(data.performanceSummary);
                    }

                    // Render grading overview if available
                    if (data.gradingOverview && data.performanceSummary.totalStudents > 0) {
                        renderGradingOverviewTable(data.gradingOverview);
                    }

                    // Display results
                    displayReportResults(data);

                    showAlert('success', 'Success', data.message || 'Report generated successfully');
                } else {
                    showErrorState(data.message || 'Failed to generate report');
                }
            } catch (error) {
                console.error('Error generating report:', error);
                showErrorState('Network error occurred while generating report');
            }
        }

        // Make report generation accessible globally
        window.triggerReportRefresh = generateReport;

