@model SIS.Models.Reports.SenateReportViewModel
@using SIS.Models.Admin
@{
    ViewData["Title"] = "Senate Academic Progress Report";
    Layout = "_Layout";

    var isAdmin = ViewBag.IsAdmin ?? false;
    var isDean = ViewBag.IsDean ?? false;
    var isHOD = ViewBag.IsHOD ?? false;
    var isVC = ViewBag.IsVC ?? false;
    var isDVC = ViewBag.IsDVC ?? false;
    var isRegistrar = ViewBag.IsRegistrar ?? false;

    var hasFullAccess = isAdmin || isRegistrar || isVC || isDVC;
    var accessLevel = hasFullAccess ? "Full Access" :
                      isDean ? "School Level Access" :
                      isHOD ? "Department/Programme Level Access" : "No Access";

    // Prepare filtered data from ViewBag for JavaScript
    var filteredDepartments = ViewBag.FilteredDepartments as List<Department> ?? new List<Department>();
    var filteredProgrammes = ViewBag.FilteredProgrammes as List<Programme> ?? new List<Programme>();
}

<!-- Add SweetAlert2 for alerts -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="min-h-screen bg-slate-50 p-4">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-6">
        <div class="flex items-center text-slate-800">
            <i class="material-icons text-primary-600 text-3xl mr-2">assessment</i>
            <div>
                <h1 class="text-2xl font-bold">Senate Academic Progress Report</h1>
                <p class="text-sm text-slate-600">Comprehensive student progression analysis</p>
                <p class="text-xs text-slate-500 mt-1">
                    <i class="material-icons text-xs align-middle">shield</i>
                    Access Level: <span class="font-medium">@accessLevel</span>
                    @if (hasFullAccess)
                    {
                        <span class="ml-2 text-green-600">(Institution-wide)</span>
                    }
                    else if (isDean)
                    {
                        <span class="ml-2 text-blue-600">(Your Schools)</span>
                    }
                    else if (isHOD)
                    {
                        <span class="ml-2 text-purple-600">(Your Department)</span>
                    }
                </p>
            </div>
        </div>
        <div class="mt-4 md:mt-0 flex items-center gap-2">
            <button id="refreshReport" class="inline-flex items-center px-4 py-2 text-sm text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors">
                <i class="material-icons text-sm mr-1">refresh</i>
                Refresh
            </button>
            <button id="exportOptions" class="inline-flex items-center px-4 py-2 text-sm text-white bg-secondary-600 hover:bg-secondary-700 rounded-lg transition-colors">
                <i class="material-icons text-sm mr-1">file_download</i>
                Export Report
            </button>
        </div>
    </div>

    @if (!hasFullAccess && !isDean && !isHOD)
    {
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
            <div class="flex items-start">
                <i class="material-icons text-red-600 mr-2">error</i>
                <div>
                    <h3 class="font-semibold text-red-800">Access Restricted</h3>
                    <p class="text-sm text-red-700 mt-1">
                        You do not have the required role to access this report. Please contact your administrator.
                    </p>
                </div>
            </div>
        </div>
    }

    <!-- Filter Panel -->
    <div class="bg-white rounded-xl shadow-sm mb-6 overflow-hidden">
        <div class="px-6 py-4 border-b bg-gradient-to-r from-primary-50 to-secondary-50">
            <h2 class="text-lg font-semibold text-slate-800 flex items-center">
                <i class="material-icons mr-2 text-primary-600">filter_list</i>
                Report Filters
                @if (!hasFullAccess)
                {
                    <span class="ml-3 text-xs font-normal text-slate-600 bg-slate-100 px-2 py-1 rounded">
                        @if (isDean)
                        {
                            <i class="material-icons text-xs align-middle">business</i>
                        }
                        else if (isHOD)
                        {
                            <i class="material-icons text-xs align-middle">domain</i>
                        }
                    </span>
                }
            </h2>
        </div>
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
                <!-- Academic Year Filter -->
                <div>
                    <label for="academicYearFilter" class="block text-sm font-medium text-slate-700 mb-1">
                        Academic Year <span class="text-red-500">*</span>
                    </label>
                    <select id="academicYearFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                        <option value="">Select Academic Year</option>
                        @foreach (var year in Model.AcademicYears)
                        {
                            <option value="@year.YearId">@year.YearValue</option>
                        }
                    </select>
                </div>

                <!-- Report Level Filter -->
                <div>
                    <label for="reportLevelFilter" class="block text-sm font-medium text-slate-700 mb-1">
                        Report Level <span class="text-red-500">*</span>
                    </label>
                    <select id="reportLevelFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                        @if (hasFullAccess || isDean)
                        {
                            <option value="School">School Level</option>
                        }
                        @if (hasFullAccess || isDean || isHOD)
                        {
                            <option value="Department">Department Level</option>
                            <option value="Programme" selected>Programme Level</option>
                        }
                    </select>
                </div>

                <!-- School Filter -->
                <div>
                    <label for="schoolFilter" class="block text-sm font-medium text-slate-700 mb-1">
                        School
                        @if (!hasFullAccess)
                        {
                            <i class="material-icons text-xs text-amber-600 align-middle" title="Restricted to your schools">lock</i>
                        }
                    </label>
                    <select id="schoolFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                        <option value="">All Schools</option>
                        @foreach (var school in Model.Schools)
                        {
                            <option value="@school.Id">@school.Name</option>
                        }
                    </select>
                </div>

                <!-- Department Filter - Pre-populated for restricted users -->
                <div>
                    <label for="departmentFilter" class="block text-sm font-medium text-slate-700 mb-1">
                        Department
                        @if (isHOD)
                        {
                            <i class="material-icons text-xs text-amber-600 align-middle" title="Restricted to your department">lock</i>
                        }
                    </label>
                    <select id="departmentFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" @(filteredDepartments.Any() ? "" : "disabled")>
                        <option value="">All Departments</option>
                        @if (filteredDepartments.Any())
                        {
                            @foreach (var dept in filteredDepartments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
                <!-- Programme Filter - Pre-populated for restricted users -->
                <div>
                    <label for="programmeFilter" class="block text-sm font-medium text-slate-700 mb-1">Programme</label>
                    <select id="programmeFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" @(filteredProgrammes.Any() ? "" : "disabled")>
                        <option value="">All Programmes</option>
                        @if (filteredProgrammes.Any())
                        {
                            @foreach (var prog in filteredProgrammes)
                            {
                                <option value="@prog.Id">@prog.Name</option>
                            }
                        }
                    </select>
                </div>

                <!-- Mode of Study Filter -->
                <div>
                    <label for="modeOfStudyFilter" class="block text-sm font-medium text-slate-700 mb-1">Mode of Study</label>
                    <select id="modeOfStudyFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                        <option value="">All Modes</option>
                        @foreach (var mode in Model.ModesOfStudy)
                        {
                            <option value="@mode.ModeId">@mode.ModeName</option>
                        }
                    </select>
                </div>

                <!-- Year of Study Filter -->
                <div>
                    <label for="yearOfStudyFilter" class="block text-sm font-medium text-slate-700 mb-1">Year of Study</label>
                    <select id="yearOfStudyFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                        <option value="">All Years</option>
                        <option value="1">Year 1</option>
                        <option value="2">Year 2</option>
                        <option value="3">Year 3</option>
                        <option value="4">Year 4</option>
                        <option value="5">Year 5</option>
                        <option value="6">Year 6</option>
                        <option value="7">Year 7</option>
                    </select>
                </div>

                <!-- Academic Period Filter -->
                <div>
                    <label for="semesterFilter" class="block text-sm font-medium text-slate-700 mb-1">Academic Period</label>
                    <select id="semesterFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                        <option value="">All Periods</option>
                        @foreach (var period in Model.AcademicPeriods)
                        {
                            <option value="@period.Id">@period.PeriodName</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Generate Report Button -->
            <div class="flex justify-center">
                <button id="generateReportBtn" class="inline-flex items-center px-6 py-3 text-white bg-primary-600 hover:bg-primary-700 rounded-lg font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                    <i class="material-icons mr-2">analytics</i>
                    Generate Report
                </button>
            </div>
        </div>
    </div>

    <!-- Breadcrumb Navigation -->
    <div id="breadcrumbContainer" class="hidden bg-white rounded-lg shadow-sm mb-6 p-4">
        <nav class="flex" aria-label="Breadcrumb">
            <ol id="breadcrumbList" class="inline-flex items-center space-x-1 md:space-x-3">
                <!-- Breadcrumbs will be dynamically populated -->
            </ol>
        </nav>
    </div>

    <!-- Performance Summary Section (NEW) -->
    <div id="performanceSummarySection" class="hidden bg-white rounded-xl shadow-sm mb-6 overflow-hidden">
        <div class="px-6 py-4 border-b bg-gradient-to-r from-blue-50 to-indigo-50">
            <h2 class="text-lg font-semibold text-slate-800 flex items-center">
                <i class="material-icons mr-2 text-blue-600">analytics</i>
                Performance Summary
            </h2>
        </div>
        <div class="p-6">
            <div class="overflow-x-auto">
                <table class="w-full border-collapse border border-gray-400">
                    <thead>
                        <tr class="bg-gray-200">
                            <th class="border border-gray-400 px-3 py-2 text-left font-bold text-sm w-12">No.</th>
                            <th class="border border-gray-400 px-3 py-2 text-left font-bold text-sm">Description</th>
                            <th class="border border-gray-400 px-3 py-2 text-right font-bold text-sm w-32">No. of Students</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm" id="performanceSummaryBody">
                        <!-- Populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="gradingOverviewSection" class="hidden bg-white rounded-xl shadow-sm mb-6 overflow-hidden">
        <!-- Content will be dynamically populated -->
    </div>

    <!-- Summary Statistics -->
    <div id="summaryStats" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Statistics cards will be dynamically populated -->
    </div>

    <!-- Report Content Area -->
    <div id="reportContainer" class="bg-white rounded-xl shadow-sm overflow-hidden">
        <!-- Welcome Message -->
        <div id="welcomeMessage" class="p-12 text-center">
            <div class="max-w-2xl mx-auto">
                <i class="material-icons text-6xl text-slate-300 mb-4">assessment</i>
                <h3 class="text-xl font-semibold text-slate-700 mb-2">Welcome to Senate Academic Progress Report</h3>
                <p class="text-slate-500 mb-6">
                    Generate comprehensive reports on student academic progression, including pass rates,
                    progression rules, and institutional performance metrics.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
                    <div class="bg-slate-50 p-4 rounded-lg">
                        <i class="material-icons text-primary-600 mb-2">school</i>
                        <div class="font-medium">School Level</div>
                        <div class="text-slate-600">Institutional overview</div>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-lg">
                        <i class="material-icons text-secondary-600 mb-2">domain</i>
                        <div class="font-medium">Department Level</div>
                        <div class="text-slate-600">Departmental analysis</div>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-lg">
                        <i class="material-icons text-accent-600 mb-2">book</i>
                        <div class="font-medium">Programme Level</div>
                        <div class="text-slate-600">Detailed breakdown</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Loading State -->
        <div id="loadingState" class="hidden p-12 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-100 rounded-full mb-4">
                <i class="material-icons text-primary-600 animate-spin">refresh</i>
            </div>
            <h3 class="text-lg font-semibold text-slate-700 mb-2">Generating Report...</h3>
            <p class="text-slate-500">Please wait while we analyze the academic data.</p>
        </div>

        <!-- Report Results -->
        <div id="reportResults" class="hidden">
            <div class="px-6 py-4 border-b bg-gradient-to-r from-primary-50 to-secondary-50">
                <div class="flex justify-between items-center">
                    <h2 id="reportTitle" class="text-lg font-semibold text-slate-800">Report Results</h2>
                    <div class="flex items-center space-x-2">
                        <span id="reportMetadata" class="text-sm text-slate-600"></span>
                        <button id="backToParent" class="hidden inline-flex items-center px-3 py-1 text-sm text-primary-600 bg-primary-100 hover:bg-primary-200 rounded-md transition-colors">
                            <i class="material-icons text-sm mr-1">arrow_back</i>
                            Back
                        </button>
                    </div>
                </div>
            </div>

            <!-- Report Table -->
            <div class="overflow-x-auto">
                <table id="reportTable" class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600 border-b">
                        <tr id="tableHeader">
                            <!-- Headers will be dynamically populated -->
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        <!-- Data will be dynamically populated -->
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div id="paginationContainer" class="hidden px-6 py-4 border-t bg-slate-50">
                <div class="flex items-center justify-between">
                    <div class="text-sm text-slate-600">
                        Showing <span id="pageStart">1</span> to <span id="pageEnd">10</span> of <span id="totalEntries">0</span> entries
                    </div>
                    <div class="flex space-x-1">
                        <button id="prevPage" class="px-3 py-1 text-sm text-slate-600 hover:bg-slate-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">
                            Previous
                        </button>
                        <div id="paginationNumbers" class="flex space-x-1">
                            <!-- Pagination numbers will be added by JS -->
                        </div>
                        <button id="nextPage" class="px-3 py-1 text-sm text-slate-600 hover:bg-slate-100 rounded-md disabled:opacity-50 disabled:cursor-not-allowed">
                            Next
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Error State -->
        <div id="errorState" class="hidden p-12 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-red-100 rounded-full mb-4">
                <i class="material-icons text-red-600">error</i>
            </div>
            <h3 class="text-lg font-semibold text-slate-700 mb-2">Report Generation Failed</h3>
            <p id="errorMessage" class="text-slate-500 mb-4">An error occurred while generating the report.</p>
            <button id="retryReport" class="inline-flex items-center px-4 py-2 text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors">
                <i class="material-icons mr-2">refresh</i>
                Try Again
            </button>
        </div>
    </div>
</div>

<!-- Export Options Modal -->
<div id="exportModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-md">
                <!-- Modal Header -->
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">file_download</i>
                        Export Report
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200 close-modal">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6">
                    <div class="space-y-4">
                        <!-- PDF Export Option -->
                        <div class="border border-slate-200 rounded-lg p-4 hover:bg-slate-50 transition-colors">
                            <div class="flex items-start">
                                <div class="bg-red-100 rounded-full p-2 mr-3">
                                    <i class="material-icons text-red-600">picture_as_pdf</i>
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-medium text-slate-800">Official PDF Report</h4>
                                    <p class="text-sm text-slate-600 mt-1">Formatted report for official use with signature blocks</p>
                                    <button id="exportPdfBtn" class="mt-2 inline-flex items-center px-3 py-1 text-sm text-red-600 bg-red-50 hover:bg-red-100 rounded-md transition-colors">
                                        <i class="material-icons text-sm mr-1">download</i>
                                        Generate PDF
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Excel Export Option -->
                        <div class="border border-slate-200 rounded-lg p-4 hover:bg-slate-50 transition-colors">
                            <div class="flex items-start">
                                <div class="bg-green-100 rounded-full p-2 mr-3">
                                    <i class="material-icons text-green-600">table_chart</i>
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-medium text-slate-800">Detailed Excel Report</h4>
                                    <p class="text-sm text-slate-600 mt-1">Complete data breakdown for analysis and audit purposes</p>
                                    <button id="exportExcelBtn" class="mt-2 inline-flex items-center px-3 py-1 text-sm text-green-600 bg-green-50 hover:bg-green-100 rounded-md transition-colors">
                                        <i class="material-icons text-sm mr-1">download</i>
                                        Generate Excel
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal Footer -->
                <div class="bg-slate-50 px-6 py-4 rounded-b-lg flex justify-end">
                    <button type="button" class="px-4 py-2 text-slate-700 bg-slate-200 hover:bg-slate-300 rounded-lg transition-colors close-modal">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Entity Student Details Modal -->
<div id="entityDetailsModal" class="hidden fixed inset-0 z-50">
    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-6xl max-h-[90vh] overflow-hidden">
                <!-- Modal Header -->
                <div class="bg-primary-600 text-white px-6 py-4 rounded-t-lg flex items-center justify-between">
                    <h3 class="text-lg font-semibold flex items-center">
                        <i class="material-icons mr-2">people</i>
                        <span id="entityDetailsTitle">Student Details</span>
                    </h3>
                    <button type="button" class="text-white hover:text-gray-200 close-entity-details">
                        <i class="material-icons">close</i>
                    </button>
                </div>

                <!-- Modal Body -->
                <div class="p-6 overflow-y-auto max-h-[calc(90vh-180px)]">
                    <!-- Summary Cards -->
                    <div id="entityDetailsSummary" class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                        <!-- Dynamically populated -->
                    </div>

                    <!-- Search and Filter Bar -->
                    <div class="flex flex-col md:flex-row justify-between items-center mb-4 gap-4">
                        <div class="relative flex-1 w-full">
                            <i class="material-icons absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400">search</i>
                            <input type="text" id="studentSearch"
                                   placeholder="Search by student number or name..."
                                   class="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
                        </div>
                        <div class="flex gap-2">
                            <select id="progressionFilter" class="px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
                                <option value="">All Progressions</option>
                                <option value="Proceed">Proceed</option>
                                <option value="ProceedWithRepeat">Proceed with Repeat</option>
                                <option value="ProceedOnProbation">Proceed on Probation</option>
                                <option value="RepeatYear">Repeat Year</option>
                                <option value="RepeatSemester">Repeat Semester</option>
                                <option value="Exclude">Academic Exclusion</option>
                                <option value="Results Pending">Results Pending</option>
                            </select>
                        </div>
                    </div>

                    <!-- Students Table -->
                    <div class="overflow-x-auto border border-slate-200 rounded-lg">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-50 text-slate-600 border-b">
                                <tr>
                                    <th class="px-4 py-3 text-left font-medium">Student Number</th>
                                    <th class="px-4 py-3 text-left font-medium">Name</th>
                                    <th class="px-4 py-3 text-center font-medium">Courses</th>
                                    <th class="px-4 py-3 text-center font-medium">Failed</th>
                                    <th class="px-4 py-3 text-center font-medium">GPA</th>
                                    <th class="px-4 py-3 text-left font-medium">Progression</th>
                                    <th class="px-4 py-3 text-center font-medium">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="entityStudentsTableBody">
                                <!-- Dynamically populated -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Loading State -->
                    <div id="entityDetailsLoading" class="hidden text-center py-12">
                        <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-100 rounded-full mb-4">
                            <i class="material-icons text-primary-600 animate-spin">refresh</i>
                        </div>
                        <p class="text-slate-600">Loading student details...</p>
                    </div>

                    <!-- Empty State -->
                    <div id="entityDetailsEmpty" class="hidden text-center py-12">
                        <i class="material-icons text-6xl text-slate-300 mb-4">inbox</i>
                        <p class="text-slate-600">No students found</p>
                    </div>
                </div>

                <!-- Modal Footer -->
                <div class="bg-slate-50 px-6 py-4 rounded-b-lg flex justify-between items-center">
                    <div class="text-sm text-slate-600">
                        <span id="entityDetailsCount">0 students</span>
                    </div>
                    <div class="flex gap-2">
                        <button type="button" id="exportEntityDetailsBtn"
                                class="inline-flex items-center px-4 py-2 text-sm text-primary-600 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors">
                            <i class="material-icons text-sm mr-1">file_download</i>
                            Export List
                        </button>
