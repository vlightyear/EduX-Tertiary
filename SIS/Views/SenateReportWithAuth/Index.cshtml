            // Content areas
            welcomeMessage: document.getElementById('welcomeMessage'),
            loadingState: document.getElementById('loadingState'),
            reportResults: document.getElementById('reportResults'),
            errorState: document.getElementById('errorState'),
            reportContainer: document.getElementById('reportContainer'),
            summaryStats: document.getElementById('summaryStats'),
            breadcrumbContainer: document.getElementById('breadcrumbContainer'),

            // Modal elements
            exportModal: document.getElementById('exportModal'),
            entityDetailsModal: document.getElementById('entityDetailsModal'),
            studentDetailModal: document.getElementById('studentDetailModal'),
            batchPublishModal: document.getElementById('batchPublishModal'),
            alertTemplate: document.getElementById('alertTemplate')
        };

        // Initialize all event listeners
        initializeEventListeners();
        initializeCascadingFilters();
        initializeDetailViews();

        // NEW: Initialize default selections for restricted users (HOD/Dean)
        initializeDefaultSelections();

        function initializeEventListeners() {
            // Generate report button
            elements.generateReportBtn.addEventListener('click', generateReport);

            // Refresh button
            elements.refreshReport.addEventListener('click', refreshCurrentReport);

            // Export buttons
            elements.exportOptions.addEventListener('click', () => showModal(elements.exportModal));
            elements.exportPdfBtn.addEventListener('click', exportToPdf);
            elements.exportExcelBtn.addEventListener('click', exportToExcel);

            // Modal close buttons
            document.querySelectorAll('.close-modal').forEach(button => {
                button.addEventListener('click', function() {
                    const modal = this.closest('[id$="Modal"]');
