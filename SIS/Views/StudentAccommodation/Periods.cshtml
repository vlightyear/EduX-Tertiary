@model IEnumerable<SIS.Models.StudentAccommodation.AccommodationPeriod>
@using SIS.Enums

<style>
    .payment-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
    }

        .payment-type-badge.semester {
            background: #e3f2fd;
            color: #1565c0;
        }

        .payment-type-badge.year {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .payment-type-badge.perday {
            background: #fff3e0;
            color: #e65100;
        }

        .payment-type-badge.fixed {
            background: #f3e5f5;
            color: #7b1fa2;
        }
</style>

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <div class="flex items-center text-secondary-800">
            <i class="material-icons text-3xl mr-2">date_range</i>
            <div>
                <h1 class="text-2xl font-bold">Accommodation Periods</h1>
                <p class="text-sm text-slate-600">Manage accommodation application periods</p>
            </div>
        </div>
        <button type="button"
                onclick="showCreatePeriodModal()"
                class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
            <i class="material-icons mr-2">add_circle</i>
            Create Period
        </button>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full">
                <div class="p-4">
                    <div class="flex justify-between items-center mb-4">
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <i class="material-icons text-slate-400 text-sm">search</i>
                            </div>
                            <input type="text" id="searchInput"
                                   class="block w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                   placeholder="Search periods..." />
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center">
                                <label for="filterStatus" class="text-sm text-slate-600 mr-2">Status:</label>
                                <select id="filterStatus"
                                        class="px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500">
                                    <option value="all">All Periods</option>
                                    <option value="active">Active Periods</option>
                                    <option value="upcoming">Upcoming Periods</option>
                                    <option value="closed">Closed Periods</option>
                                </select>
                            </div>
                            <div class="flex items-center">
                                <label for="filterPaymentType" class="text-sm text-slate-600 mr-2">Payment:</label>
                                <select id="filterPaymentType"
                                        class="px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500">
                                    <option value="all">All Types</option>
                                    <option value="semester">Semester</option>
                                    <option value="year">Year</option>
                                    <option value="perday">Per Day</option>
                                    <option value="fixed">Fixed</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="overflow-y-auto h-[calc(100%-60px)]">
                        @if (TempData["Success"] != null)
                        {
                            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
                                <p>@TempData["Success"]</p>
                            </div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
                                <p>@TempData["Error"]</p>
                            </div>
                        }

                        <table id="periodsTable" class="w-full text-sm text-secondary-600">
                            <thead class="sticky top-0 bg-slate-50">
                                <tr>
                                    <th class="px-4 py-3 text-left">#</th>
                                    <th class="px-4 py-3 text-left">Period Info</th>
                                    <th class="px-4 py-3 text-left">Payment Type</th>
                                    <th class="px-4 py-3 text-left">Fee</th>
                                    <th class="px-4 py-3 text-left">Duration</th>
                                    <th class="px-4 py-3 text-left">Apps</th>
                                    <th class="px-4 py-3 text-left">Status</th>
                                    <th class="px-4 py-3 text-left">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="periodsTableBody">
                                @if (Model != null && Model.Any())
                                {
                                    @for (int i = 0; i < Model.Count(); i++)
                                    {
                                        var period = Model.ElementAt(i);
                                        var statusClass = period.Status == Status.Active ? "bg-green-100 text-green-800" :
                                        period.Status == Status.Upcoming ? "bg-blue-100 text-blue-800" :
                                        "bg-gray-100 text-secondary-800";
                                        var applications = period.Applications?.Count ?? 0;
                                        var endDateDisplay = period.EndDate.HasValue
                                        ? period.EndDate.Value.ToString("MMM dd, yyyy")
                                        : "Permanent";
                                        var isPermanent = period.IsPermanentUntilGraduation ? "(Permanent)" : "";
                                        var periodDisplayName = string.IsNullOrEmpty(period.Type) ? "General" : period.Type;

                                        <tr class="hover:bg-slate-50 border-b"
                                            data-status="@period.Status.ToString().ToLower()"
                                            data-payment-type="@(period.TypeOfPayment?.ToLower() ?? "")">
                                            <td class="px-4 py-4">@(i + 1)</td>
                                            <td class="px-4 py-4">
                                                <div>
                                                    <span class="font-medium text-cyan-600">@periodDisplayName</span>
                                                    <p class="text-xs text-slate-500 mt-1">
                                                        @period.StartDate.ToString("MMM dd") - @endDateDisplay
                                                    </p>
                                                </div>
                                            </td>
                                            <td class="px-4 py-4">
                                                <span class="payment-type-badge @(period.TypeOfPayment?.ToLower() ?? "")">
                                                    @(period.TypeOfPayment ?? "N/A")
                                                </span>
                                            </td>
                                            <td class="px-4 py-4">
                                                <div>
                                                    <span class="font-semibold text-slate-800">K @period.TypeOfPaymentAmount.ToString("N2")</span>
                                                    @if (period.TypeOfPayment == "PerDay")
                                                    {
                                                        <p class="text-xs text-orange-600">/day</p>
                                                    }
                                                </div>
                                            </td>
                                            <td class="px-4 py-4">
                                                <div class="flex flex-col">
                                                    <span class="text-xs">@period.StartDate.ToString("MMM dd, yyyy") - @endDateDisplay @isPermanent</span>
                                                    <span class="text-xs text-slate-500">
                                                        Apps: @period.ApplicationStartDate.ToString("MMM dd") - @period.ApplicationEndDate.ToString("MMM dd")
                                                    </span>
                                                </div>
                                            </td>
                                            <td class="px-4 py-4">
                                                <span class="font-medium">@applications</span>
                                            </td>
                                            <td class="px-4 py-4">
                                                <span class="px-2 py-1 @statusClass text-xs rounded-full">
                                                    @period.Status.ToDisplayString()
                                                </span>
                                            </td>
                                            <td class="px-4 py-4">
                                                <div class="flex space-x-2">
                                                    <button onclick="showUpdatePeriodModal('@period.PeriodId')"
                                                            class="text-slate-600 hover:text-cyan-600" title="Edit">
                                                        <i class="material-icons text-base">edit</i>
                                                    </button>
                                                    <button data-id="@period.PeriodId"
                                                            data-name="@periodDisplayName"
                                                            data-applications="@applications"
                                                            onclick="showDeletePeriodModalFromData(this)"
                                                            class="text-slate-600 hover:text-red-600" title="Delete">
                                                        <i class="material-icons text-base">delete</i>
                                                    </button>
                                                    <div class="relative">
                                                        <button onclick="toggleStatusDropdown('@period.PeriodId')"
                                                                class="text-slate-600 hover:text-amber-600" title="Change Status">
                                                            <i class="material-icons text-base">sync</i>
                                                        </button>
                                                        <div id="statusDropdown-@period.PeriodId" class="absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg hidden z-30">
                                                            <div class="py-1">
                                                                <form method="post" asp-action="ChangePeriodStatus">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="id" value="@period.PeriodId" />
                                                                    <button type="submit" name="status" value="@Status.Active"
                                                                            class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                                                        Set as Active
                                                                    </button>
                                                                    <button type="submit" name="status" value="@Status.Upcoming"
                                                                            class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                                                        Set as Upcoming
                                                                    </button>
                                                                    <button type="submit" name="status" value="@Status.Closed"
                                                                            class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                                                        Set as Closed
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                        <!-- Empty state message -->
                        <div id="emptyStateMessage" class="flex flex-col items-center justify-center h-[calc(100%-60px)] text-slate-500"
                             style="@(Model != null && Model.Any() ? "display: none;" : "")">
                            <i class="material-icons text-5xl mb-4">event_busy</i>
                            <h3 class="text-xl font-medium mb-2">No Accommodation Periods Found</h3>
                            <p class="text-sm mb-4">You haven't created any accommodation periods yet.</p>
                            <button onclick="showCreatePeriodModal()"
                                    class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
                                <i class="material-icons mr-2">add_circle</i>
                                Create First Period
                            </button>
                        </div>

                        <!-- Loading indicator -->
                        <div id="loadingIndicator" class="flex justify-center items-center h-[calc(100%-60px)]" style="display: none;">
                            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-cyan-600"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="grid grid-cols-1 gap-4">
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-cyan-100 rounded-lg">
                            <i class="material-icons text-cyan-600 text-xl">date_range</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Periods</p>
                            <div id="totalPeriods" class="text-xl font-semibold">@ViewBag.TotalPeriods</div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">check_circle</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Active Periods</p>
                            <div id="activePeriods" class="text-xl font-semibold text-green-600">@ViewBag.ActivePeriods</div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">schedule</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Upcoming Periods</p>
                            <div id="upcomingPeriods" class="text-xl font-semibold text-blue-600">@ViewBag.UpcomingPeriods</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Types Summary -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Payment Types</h3>
                <div class="space-y-3">
                    @{
                        var semesterCount = Model?.Count(p => p.TypeOfPayment == "Semester") ?? 0;
                        var yearCount = Model?.Count(p => p.TypeOfPayment == "Year") ?? 0;
                        var perDayCount = Model?.Count(p => p.TypeOfPayment == "PerDay") ?? 0;
                        var fixedCount = Model?.Count(p => p.TypeOfPayment == "Fixed") ?? 0;
                    }
                    <div class="flex justify-between items-center">
                        <span class="payment-type-badge semester">Semester</span>
                        <span class="font-semibold">@semesterCount</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="payment-type-badge year">Year</span>
                        <span class="font-semibold">@yearCount</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="payment-type-badge perday">Per Day</span>
                        <span class="font-semibold">@perDayCount</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="payment-type-badge fixed">Fixed</span>
                        <span class="font-semibold">@fixedCount</span>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-secondary-800 mb-4">Recent Activity</h3>
                <div id="recentActivityList" class="space-y-3">
                    @if (Model != null && Model.Any())
                    {
                        var recentPeriods = Model.OrderByDescending(p => p.CreatedAt).Take(3);
                        foreach (var period in recentPeriods)
                        {
                            var periodDisplayName = string.IsNullOrEmpty(period.Type) ? "General" : period.Type;
                            <div class="flex items-start">
                                <div class="bg-cyan-100 p-2 rounded-full mr-3">
                                    <i class="material-icons text-cyan-600 text-sm">date_range</i>
                                </div>
                                <div>
                                    <p class="text-sm font-medium">
                                        <span class="text-cyan-600">@periodDisplayName</span>
                                        <span class="payment-type-badge @(period.TypeOfPayment?.ToLower() ?? "") ml-1">@period.TypeOfPayment</span>
                                    </p>
                                    <p class="text-xs text-slate-500">
                                        @period.CreatedAt.ToString("MMM dd, yyyy") by @period.CreatedBy
                                    </p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-slate-500">No recent activity</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Period Modal -->
<div id="createPeriodModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideCreatePeriodModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-2/3 z-10 overflow-hidden max-h-[90vh] overflow-y-auto">
        <div class="px-6 py-4 bg-cyan-600 text-white sticky top-0">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2">add_circle</i>
                Create New Accommodation Period
            </h3>
        </div>
        <form id="createPeriodForm" method="post" asp-action="CreatePeriod">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4">
                <div class="space-y-4">
                    <!-- Basic Information -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Period Type -->
                        <div class="relative z-0 w-full group">
                            <select name="Type" id="Type"
                                    class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer">
                                <option value="">General</option>
                                <option value="New Students">New Students</option>
                                <option value="Returning Students">Returning Students</option>
                                <option value="Graduation">Graduation</option>
                                <option value="Short Stay">Short Stay</option>
                                <option value="Custom">Custom</option>
                            </select>
                            <label for="Type"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Period Type
                            </label>
                        </div>

                        <!-- Payment Type -->
                        <div class="relative z-0 w-full group">
                            <select name="TypeOfPayment" id="TypeOfPayment"
                                    class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                    required onchange="togglePerDayInfo(this)">
                                <option value="">Select Payment Type</option>
                                <option value="Semester">Semester</option>
                                <option value="Year">Year</option>
                                <option value="PerDay">Per Day</option>
                                <option value="Fixed">Fixed</option>
                            </select>
                            <label for="TypeOfPayment"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Payment Type *
                            </label>
                        </div>
                    </div>

                    <!-- Payment Amount -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="relative z-0 w-full group">
                            <input type="number" step="0.01" name="TypeOfPaymentAmount" id="TypeOfPaymentAmount"
                                   class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer"
                                   placeholder=" " required />
                            <label for="TypeOfPaymentAmount"
                                   class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Amount (K) *
                            </label>
                        </div>
                        <div id="perDayInfo" class="hidden items-center text-orange-600 text-sm">
                            <i class="material-icons text-sm mr-1">info</i>
                            <span>Students will enter number of days when applying. Total = Amount × Days</span>
                        </div>
                    </div>

                    <!-- For IsPermanentUntilGraduation -->
                    <div class="flex items-center mt-4">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="IsPermanentUntilGraduation" id="IsPermanentUntilGraduation" value="true" class="sr-only peer" onchange="handlePermanentToggle(this)">
                            <input type="hidden" name="IsPermanentUntilGraduation" value="false">
                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                            <span class="ms-3 text-sm font-medium text-gray-700">Permanent Until Graduation</span>
                        </label>
                    </div>

                    <!-- For AppliesUniversally -->
                    <div class="flex items-center mt-2">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="AppliesUniversally" id="AppliesUniversally" value="true" class="sr-only peer" onchange="handleUniversalToggle(this)">
                            <input type="hidden" name="AppliesUniversally" value="false">
                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                            <span class="ms-3 text-sm font-medium text-gray-700">Applies Universally (to all students)</span>
                        </label>
                    </div>

                    <!-- Filter Section (School, Programme, etc) -->
                    <div id="filterFields" class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
                        <!-- School -->
                        <div class="relative z-0 w-full group">
                            <select name="SchoolId" id="SchoolId" class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer">
                                <option value="">Any School</option>
                                @foreach (var school in ViewBag.Schools)
                                {
                                    <option value="@school.Id">@school.Name</option>
                                }
                            </select>
                            <label for="SchoolId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                School
                            </label>
                        </div>

                        <!-- Programme -->
                        <div class="relative z-0 w-full group">
                            <select name="ProgrammeId" id="ProgrammeId" class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer">
                                <option value="">Any Programme</option>
                                @foreach (var programme in ViewBag.Programmes)
                                {
                                    <option value="@programme.Id">@programme.Name</option>
                                }
                            </select>
                            <label for="ProgrammeId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Programme
                            </label>
                        </div>

                        <!-- Mode of Study -->
                        <div class="relative z-0 w-full group">
                            <select name="ModeOfStudyId" id="ModeOfStudyId" class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer">
                                <option value="">Any Mode</option>
                                @foreach (var mode in ViewBag.ModesOfStudy)
                                {
                                    <option value="@mode.ModeId">@mode.ModeName</option>
                                }
                            </select>
                            <label for="ModeOfStudyId" class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-focus:text-cyan-600 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                                Mode of Study
                            </label>
                        </div>

                        <!-- Year of Study -->
                        <div class="relative z-0 w-full group">
                            <select name="YearOfStudy" id="YearOfStudy" class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-cyan-600 peer">
                                <option value="">Any Year</option>
                                <option value="1">Year 1</option>
                                <option value="2">Year 2</option>
                                <option value="3">Year 3</option>
                                <option value="4">Year 4</option>
                                <option value="5">Year 5</option>
