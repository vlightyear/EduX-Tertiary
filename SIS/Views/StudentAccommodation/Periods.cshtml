<!-- Delete Period Modal -->
<div id="deletePeriodModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideDeletePeriodModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 bg-red-600 text-white">
            <h3 class="text-xl font-semibold flex items-center">
                <i class="material-icons mr-2">warning</i>
                Confirm Deletion
            </h3>
        </div>
        <form id="deletePeriodForm" method="post" asp-action="DeletePeriod">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deletePeriodId" name="id" />
            <div class="px-6 py-4">
                <p class="text-gray-700 mb-4">Are you sure you want to delete this accommodation period?</p>
                <div class="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-4">
                    <p id="deletePeriodName" class="font-medium text-sm mb-2 text-slate-800"></p>
                    <div class="flex flex-wrap gap-1 mt-2" id="deletePeriodDetails">
                        <span id="deletePeriodApplicationCount" class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full"></span>
                    </div>
                </div>
                <div id="deleteWarning" class="text-sm text-red-600 mb-4">
                    This action cannot be undone and will permanently remove this period from the system.
                </div>
                <div id="hasApplicationsWarning" class="bg-yellow-50 border-l-4 border-yellow-400 p-4 hidden">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i class="material-icons text-yellow-400">warning</i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-yellow-700">
                                This period has associated applications. Deletion will not be possible.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
                <button type="button" onclick="hideDeletePeriodModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit" id="deleteButton" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                    Delete Period
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/periods.js"></script>
    <script>
        // Toggle Per Day info message for Create modal
        function togglePerDayInfo(select) {
            const perDayInfo = document.getElementById('perDayInfo');
            if (select.value === 'PerDay') {
                perDayInfo.classList.remove('hidden');
                perDayInfo.classList.add('flex');
            } else {
                perDayInfo.classList.add('hidden');
                perDayInfo.classList.remove('flex');
            }
        }

        // Toggle Per Day info message for Update modal
        function toggleUpdatePerDayInfo(select) {
            const perDayInfo = document.getElementById('updatePerDayInfo');
            if (select.value === 'PerDay') {
                perDayInfo.classList.remove('hidden');
                perDayInfo.classList.add('flex');
            } else {
                perDayInfo.classList.add('hidden');
                perDayInfo.classList.remove('flex');
            }
        }

        // Combined filter function
        function filterTable() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const statusValue = document.getElementById('filterStatus').value;
            const paymentTypeValue = document.getElementById('filterPaymentType').value;
            const rows = document.querySelectorAll('#periodsTableBody tr');

            rows.forEach(row => {
                const rowText = row.textContent.toLowerCase();
                const rowStatus = row.getAttribute('data-status');
                const rowPaymentType = row.getAttribute('data-payment-type');

                const matchesSearch = rowText.includes(searchTerm);
                const matchesStatus = statusValue === 'all' || rowStatus === statusValue;
                const matchesPaymentType = paymentTypeValue === 'all' || rowPaymentType === paymentTypeValue;

                if (matchesSearch && matchesStatus && matchesPaymentType) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        // Event listeners for filters
        document.getElementById('searchInput')?.addEventListener('input', filterTable);
        document.getElementById('filterStatus')?.addEventListener('change', filterTable);
        document.getElementById('filterPaymentType')?.addEventListener('change', filterTable);
    </script>
}
