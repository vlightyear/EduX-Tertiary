@model SIS.Models.StudentApplication.Student
<div class="min-h-[88vh] p-6 bg-slate-50">
    <div class="flex flex-col lg:flex-row gap-6">
        <!-- Main Content -->
        <div class="flex-1 space-y-6">
            <!-- Header -->
            <div class="flex items-center gap-2">
                <i class="material-icons text-3xl text-slate-800">apartment</i>
                <h1 class="text-2xl font-bold text-slate-800">Accommodation Portal</h1>
            </div>
            @if (ViewBag.HasAccommodation)
            {
                <!-- Current Accommodation Card -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <!-- Accommodation Header -->
                    <div class="p-6 bg-cyan-950 text-white">
                        <div class="flex flex-col md:flex-row justify-between items-center">
                            <div>
                                <h2 class="text-2xl font-bold">Your Accommodation</h2>
                                <p>@ViewBag.Allocation.Bed.Room.Hostel.HostelName</p>
                            </div>
                            <div class="mt-4 md:mt-0 flex items-center gap-2 bg-white/20 px-4 py-2 rounded-lg">
                                <i class="material-icons">check_circle</i>
                                <span>Active Allocation</span>
                            </div>
                        </div>
                    </div>

                    <!-- Accommodation Details -->
                    <div class="p-6">
                        <div class="grid md:grid-cols-2 gap-6">
                            <!-- Room Details -->
                            <div>
                                <h3 class="text-lg font-semibold text-slate-800 mb-4">Room Details</h3>
                                <div class="space-y-4">
                                    <div class="flex items-start gap-3">
                                        <div class="bg-blue-50 p-2 rounded-lg">
                                            <i class="material-icons text-blue-600">meeting_room</i>
                                        </div>
                                        <div>
                                            <p class="text-sm text-slate-500">Room Number</p>
                                            <p class="font-semibold text-slate-800">@ViewBag.Allocation.Bed.Room.RoomNumber</p>
                                        </div>
                                    </div>

                                    <div class="flex items-start gap-3">
                                        <div class="bg-green-50 p-2 rounded-lg">
                                            <i class="material-icons text-green-600">hotel</i>
                                        </div>
                                        <div>
                                            <p class="text-sm text-slate-500">Bed Space</p>
                                            <p class="font-semibold text-slate-800">@ViewBag.Allocation.Bed.BedIdentifier</p>
                                        </div>
                                    </div>

                                    <div class="flex items-start gap-3">
                                        <div class="bg-amber-50 p-2 rounded-lg">
                                            <i class="material-icons text-amber-600">people</i>
                                        </div>
                                        <div>
                                            <p class="text-sm text-slate-500">Room Type</p>
                                            <p class="font-semibold text-slate-800">@ViewBag.Allocation.Bed.Room.RoomType (@ViewBag.Allocation.Bed.Room.Capacity Person)</p>
                                        </div>
                                    </div>

                                    <div class="flex items-start gap-3">
                                        <div class="bg-purple-50 p-2 rounded-lg">
                                            <i class="material-icons text-purple-600">stairs</i>
                                        </div>
                                        <div>
                                            <p class="text-sm text-slate-500">Floor</p>
                                            <p class="font-semibold text-slate-800">@ViewBag.Allocation.Bed.Room.Floor</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Allocation Details -->
                            <div>
                                <h3 class="text-lg font-semibold text-slate-800 mb-4">Allocation Details</h3>
                                <div class="space-y-4">
                                    <div class="flex items-start gap-3">
                                        <div class="bg-indigo-50 p-2 rounded-lg">
                                            <i class="material-icons text-indigo-600">calendar_today</i>
                                        </div>
                                        <div>
                                            <p class="text-sm text-slate-500">Start Date</p>
                                            <p class="font-semibold text-slate-800">@ViewBag.Allocation.StartDate.ToString("MMMM d, yyyy")</p>
                                        </div>
                                    </div>

                                    <div class="flex items-start gap-3">
                                        <div class="bg-red-50 p-2 rounded-lg">
                                            <i class="material-icons text-red-600">event</i>
                                        </div>
                                        <div>
                                            <p class="text-sm text-slate-500">End Date</p>
                                            <p class="font-semibold text-slate-800">
                                                @if (ViewBag.Allocation.IsGraduationBased)
                                                {
                                                    <span>Until Graduation</span>
                                                }
                                                else if (ViewBag.Allocation.EndDate.HasValue)
                                                {
                                                    @ViewBag.Allocation.EndDate.Value.ToString("MMMM d, yyyy")
                                                }
                                                else
                                                {
                                                    <span>No end date specified</span>
                                                }
                                            </p>
                                        </div>
                                    </div>

                                    <div class="flex items-start gap-3">
                                        <div class="bg-cyan-50 p-2 rounded-lg">
                                            <i class="material-icons text-cyan-600">assignment</i>
                                        </div>
                                        <div>
                                            <p class="text-sm text-slate-500">Allocation Type</p>
                                            <p class="font-semibold text-slate-800">@ViewBag.Allocation.AllocationType</p>
                                        </div>
                                    </div>

                                    <div class="flex items-start gap-3">
                                        <div class="bg-teal-50 p-2 rounded-lg">
                                            <i class="material-icons text-teal-600">verified</i>
                                        </div>
                                        <div>
                                            <p class="text-sm text-slate-500">Status</p>
                                            <p class="font-semibold text-slate-800">@ViewBag.Allocation.Status</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-6 pt-6 border-t border-slate-100">
                            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-blue-50 p-2 rounded-lg">
                                        <i class="material-icons text-blue-600">info</i>
                                    </div>
                                    <div>
                                        <p class="text-sm text-slate-500">Academic Period</p>
                                        <p class="font-semibold text-slate-800">@ViewBag.Allocation.Application.Period.AcademicYear.YearValue</p>
                                    </div>
                                </div>

                                <div class="flex gap-3">
                                    <a href="@Url.Action("MyApplications", "StudentAccommodation")" class="px-4 py-2 border border-cyan-950 text-cyan-950 rounded-lg hover:bg-cyan-950 hover:text-white transition-colors flex items-center gap-2">
                                        <i class="material-icons">history</i>
                                        <span>View Applications</span>
                                    </a>
                                    <button type="button" id="reportIssueBtn" class="px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 transition-colors flex items-center gap-2">
                                        <i class="material-icons">report_problem</i>
                                        <span>Report Issue</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Check-in/Check-out Info -->
                @if (ViewBag.CheckInOutInfo != null)
                {
                    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                        <div class="p-4 bg-slate-100">
                            <h3 class="font-semibold text-slate-800">Check-in/Check-out Information</h3>
                        </div>
                        <div class="p-6 grid md:grid-cols-2 gap-6">
                            <div>
                                <h4 class="text-sm font-medium text-slate-500 mb-2">Check-in Details</h4>
                                <div class="space-y-3">
                                    <div class="flex items-center gap-2">
                                        <i class="material-icons text-green-600">calendar_today</i>
                                        <span class="text-slate-800">@(ViewBag.CheckInOutInfo.CheckInDate?.ToString("MMMM d, yyyy") ?? "Not checked in yet")</span>
                                    </div>
                                    <div class="flex items-start gap-2">
                                        <i class="material-icons text-slate-600">description</i>
                                        <span class="text-slate-600">@(ViewBag.CheckInOutInfo.CheckInCondition ?? "No condition notes")</span>
                                    </div>
                                </div>
                            </div>

                            @if (ViewBag.CheckInOutInfo.CheckOutDate.HasValue)
                            {
                                <div>
                                    <h4 class="text-sm font-medium text-slate-500 mb-2">Check-out Details</h4>
                                    <div class="space-y-3">
                                        <div class="flex items-center gap-2">
                                            <i class="material-icons text-red-600">calendar_today</i>
                                            <span class="text-slate-800">@ViewBag.CheckInOutInfo.CheckOutDate.Value.ToString("MMMM d, yyyy")</span>
                                        </div>
                                        <div class="flex items-start gap-2">
                                            <i class="material-icons text-slate-600">description</i>
                                            <span class="text-slate-600">@(ViewBag.CheckInOutInfo.CheckOutCondition ?? "No condition notes")</span>
                                        </div>
                                        @if (ViewBag.CheckInOutInfo.DamageCharges > 0)
                                        {
                                            <div class="flex items-center gap-2 text-red-600">
                                                <i class="material-icons">warning</i>
                                                <span>Damage Charges: ZMW @ViewBag.CheckInOutInfo.DamageCharges.ToString("N2")</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }

            <!-- Accommodation Periods -->
            <div id="accommodationPeriods">
                @if (!ViewBag.HasAccommodation && (ViewBag.EligiblePeriods == null || ((List<SIS.Models.StudentAccommodation.AccommodationPeriod>)ViewBag.EligiblePeriods).Count == 0))
                {
                    <div class="bg-white rounded-xl shadow-sm p-6">
                        <div class="flex items-center gap-2 p-4 bg-amber-50 text-amber-800 rounded-lg">
                            <i class="material-icons">info</i>
                            <p>There are no accommodation periods available for application at this time. Please check back later.</p>
                        </div>
                    </div>
                }
                else if (!ViewBag.HasAccommodation)
                {
                    <div class="bg-white rounded-xl shadow-sm p-6">
                        <div class="flex items-center gap-2 mb-6">
                            <i class="material-icons text-blue-600">home</i>
                            <h2 class="text-lg font-semibold text-slate-800">Available Accommodation Periods</h2>
                        </div>

                        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                            @foreach (var period in ViewBag.EligiblePeriods)
                            {
                                <div class="border border-slate-200 rounded-xl overflow-hidden hover:border-blue-300 hover:shadow-md transition-all">
                                    <div class="bg-cyan-950 text-white p-4">
                                        <h3 class="font-semibold">@period.AcademicYear.YearValue</h3>
                                        <p class="text-sm text-cyan-100">@period.Type</p>
                                    </div>
                                    <div class="p-4">
                                        <div class="space-y-3 mb-4">
                                            <div class="flex items-center gap-2">
                                                <i class="material-icons text-blue-600 text-sm">calendar_today</i>
                                                <span class="text-sm text-slate-600">Start: @period.StartDate.ToString("MMM d, yyyy")</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <i class="material-icons text-red-600 text-sm">event</i>
                                                <span class="text-sm text-slate-600">
                                                    @if (period.IsPermanentUntilGraduation)
                                                    {
                                                        <span>Until Graduation</span>
                                                    }
                                                    else if (period.EndDate.HasValue)
                                                    {
                                                        @period.EndDate.Value.ToString("MMM d, yyyy")
                                                    }
                                                    else
                                                    {
                                                        <span>No end date specified</span>
                                                    }
                                                </span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <i class="material-icons text-green-600 text-sm">school</i>
                                                <span class="text-sm text-slate-600">
                                                    @if (period.AppliesUniversally)
                                                    {
                                                        <span>All Students</span>
                                                    }
                                                    else
                                                    {
                                                        <span>
                                                            @(period.School?.Name ?? "Any School"),
                                                            @(period.Programme?.Name ?? "Any Programme")
                                                        </span>
                                                    }
                                                </span>
                                            </div>
                                            @if (period.FeeConfiguration != null)
                                            {
                                                <div class="flex items-center gap-2">
                                                    <i class="material-icons text-amber-600 text-sm">payments</i>
                                                    <span class="text-sm text-slate-600">Fee: ZMW @period.FeeConfiguration.Amount.ToString("N2")</span>
                                                </div>
                                            }
                                        </div>

                                        <div class="pt-3 border-t border-slate-100">
                                            <form asp-action="Apply" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="periodId" value="@period.PeriodId" />
                                                <button type="submit" class="w-full px-4 py-2 bg-cyan-950 text-white rounded-lg hover:bg-cyan-900 transition-colors flex items-center justify-center gap-2">
                                                    <i class="material-icons">check_circle</i>
                                                    <span>Apply Now</span>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Recent Applications Section (shown even if accommodated) -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center gap-2">
                        <i class="material-icons text-indigo-600">history</i>
                        <h2 class="text-lg font-semibold text-slate-800">Recent Applications</h2>
                    </div>
                    <a href="@Url.Action("MyApplications", "StudentAccommodation")" class="text-cyan-950 hover:text-cyan-700 transition-colors flex items-center gap-1">
                        <span>View All</span>
                        <i class="material-icons text-sm">arrow_forward</i>
                    </a>
                </div>

                <div id="recentApplications">
                    <!-- This will be populated via AJAX -->
                    <div class="flex justify-center p-8">
                        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-cyan-950"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Side Panel -->
        <div class="lg:w-1/3 space-y-6">
            <!-- Accommodation Status Card -->
            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                <div class="p-6 bg-cyan-950 text-white">
                    <h2 class="text-xl font-semibold">Accommodation Status</h2>
                </div>
                <div class="p-6">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="bg-@(ViewBag.HasAccommodation ? "green" : "amber")-100 p-3 rounded-full">
                            <i class="material-icons text-@(ViewBag.HasAccommodation ? "green" : "amber")-600 text-2xl">
                                @(ViewBag.HasAccommodation ? "check_circle" : "home")
                            </i>
                        </div>
                        <div>
                            <h3 class="font-semibold text-slate-800">@(ViewBag.HasAccommodation ? "Accommodated" : "Not Accommodated")</h3>
                            <p class="text-sm text-slate-600">
                                @(ViewBag.HasAccommodation
                                    ? $"You are currently accommodated in {ViewBag.Allocation.Bed.Room.Hostel.HostelName}"
                                    : "You do not have active accommodation")
                            </p>
                        </div>
                    </div>

                    <div class="space-y-4">
                        @if (!ViewBag.HasAccommodation)
                        {
                            <div class="flex items-start gap-2 p-3 bg-blue-50 text-blue-800 rounded-lg">
                                <i class="material-icons">info</i>
                                <div>
                                    <p class="font-medium">Looking for accommodation?</p>
                                    <p class="text-sm">Check the available accommodation periods and click "Apply Now" to submit your application.</p>
                                </div>
                            </div>
                        }

                        <div class="flex items-start gap-2 p-3 bg-slate-50 rounded-lg">
                            <i class="material-icons text-slate-600">tips_and_updates</i>
                            <div>
                                <p class="font-medium text-slate-800">Accommodation Tips</p>
                                <ul class="text-sm text-slate-600 list-disc pl-4 mt-1 space-y-1">
                                    <li>Keep your room clean and tidy</li>
                                    <li>Report maintenance issues promptly</li>
                                    <li>Follow hostel rules and regulations</li>
                                    <li>Be respectful of your roommates</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Hostel Information Card -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <div class="flex items-center gap-2 mb-6">
                    <i class="material-icons text-blue-600">apartment</i>
                    <h2 class="text-lg font-semibold text-slate-800">Hostel Information</h2>
                </div>

                <div class="space-y-6">
                    @if (ViewBag.HasAccommodation)
                    {
                        <div>
                            <h3 class="font-medium text-slate-800 mb-2">@ViewBag.Allocation.Bed.Room.Hostel.HostelName Rules</h3>
                            <ul class="text-sm text-slate-600 space-y-2">
                                <li class="flex items-start gap-2">
                                    <i class="material-icons text-amber-600 text-sm">schedule</i>
                                    <span>Curfew: 10:00 PM (weekdays), 11:00 PM (weekends)</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <i class="material-icons text-red-600 text-sm">no_meeting_room</i>
                                    <span>No opposite gender visitors after 8:00 PM</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <i class="material-icons text-green-600 text-sm">cleaning_services</i>
                                    <span>Room cleaning schedule: Every Saturday</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <i class="material-icons text-blue-600 text-sm">electrical_services</i>
                                    <span>No electrical appliances except laptops and phone chargers</span>
                                </li>
                            </ul>
                        </div>

                        <div>
                            <h3 class="font-medium text-slate-800 mb-2">Contact Information</h3>
                            <div class="space-y-2">
                                <div class="flex items-center gap-2 text-sm text-slate-600">
                                    <i class="material-icons text-cyan-950 text-sm">person</i>
                                    <span>Hostel Warden: John Doe</span>
                                </div>
                                <div class="flex items-center gap-2 text-sm text-slate-600">
                                    <i class="material-icons text-cyan-950 text-sm">phone</i>
                                    <span>+260 97 123 4567</span>
                                </div>
                                <div class="flex items-center gap-2 text-sm text-slate-600">
                                    <i class="material-icons text-cyan-950 text-sm">email</i>
                                    <span>warden@university.edu</span>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="flex items-start gap-2 p-3 bg-slate-50 text-slate-800 rounded-lg">
                            <i class="material-icons text-blue-600">info</i>
                            <p class="text-sm">Hostel information will be available once you are allocated accommodation.</p>
                        </div>

                        <div>
                            <h3 class="font-medium text-slate-800 mb-2">Accommodation Office</h3>
                            <div class="space-y-2">
                                <div class="flex items-center gap-2 text-sm text-slate-600">
                                    <i class="material-icons text-cyan-950 text-sm">location_on</i>
                                    <span>Administration Block, Ground Floor, Room 15</span>
                                </div>
                                <div class="flex items-center gap-2 text-sm text-slate-600">
                                    <i class="material-icons text-cyan-950 text-sm">access_time</i>
                                    <span>Office Hours: 8:00 AM - 4:00 PM (Mon-Fri)</span>
                                </div>
                                <div class="flex items-center gap-2 text-sm text-slate-600">
                                    <i class="material-icons text-cyan-950 text-sm">phone</i>
                                    <span>+260 97 987 6543</span>
                                </div>
                                <div class="flex items-center gap-2 text-sm text-slate-600">
                                    <i class="material-icons text-cyan-950 text-sm">email</i>
                                    <span>accommodation@university.edu</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Important Dates Card -->
            <div class="bg-white rounded-xl shadow-sm p-6">
                <div class="flex items-center gap-2 mb-6">
                    <i class="material-icons text-red-600">event</i>
                    <h2 class="text-lg font-semibold text-slate-800">Important Dates</h2>
                </div>

                <div class="space-y-4">
                    <div class="flex items-start gap-3 p-3 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors">
                        <div class="bg-cyan-950 text-white w-10 h-10 rounded-lg flex flex-col items-center justify-center">
                            <span class="text-xs">APR</span>
                            <span class="font-bold">15</span>
                        </div>
                        <div>
                            <p class="font-medium text-slate-800">Accommodation Application Deadline</p>
                            <p class="text-sm text-slate-600">For next semester allocation</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-3 p-3 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors">
                        <div class="bg-cyan-950 text-white w-10 h-10 rounded-lg flex flex-col items-center justify-center">
                            <span class="text-xs">APR</span>
                            <span class="font-bold">30</span>
                        </div>
                        <div>
                            <p class="font-medium text-slate-800">Accommodation Fee Payment Deadline</p>
                            <p class="text-sm text-slate-600">For approved applications</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-3 p-3 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors">
                        <div class="bg-cyan-950 text-white w-10 h-10 rounded-lg flex flex-col items-center justify-center">
                            <span class="text-xs">MAY</span>
                            <span class="font-bold">10</span>
                        </div>
                        <div>
                            <p class="font-medium text-slate-800">Hostel Check-in Begins</p>
                            <p class="text-sm text-slate-600">For next semester</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-3 p-3 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors">
                        <div class="bg-cyan-950 text-white w-10 h-10 rounded-lg flex flex-col items-center justify-center">
                            <span class="text-xs">JUL</span>
                            <span class="font-bold">25</span>
                        </div>
                        <div>
                            <p class="font-medium text-slate-800">Current Semester Hostel Check-out</p>
                            <p class="text-sm text-slate-600">All rooms must be vacated by 4:00 PM</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Report Issue Modal -->
<div id="reportIssueModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-lg relative z-10 mx-4">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-semibold text-slate-800">Report Maintenance Issue</h3>
            <button type="button" id="closeIssueModal" class="text-slate-400 hover:text-slate-600">
                <i class="material-icons">close</i>
            </button>
        </div>
        <form id="reportIssueForm">
            <div class="space-y-4">
                <div>
                    <label for="issueType" class="block text-sm font-medium text-slate-700 mb-1">Issue Type</label>
                    <select id="issueType" name="issueType" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-950">
                        <option value="">Select Issue Type</option>
                        <option value="plumbing">Plumbing</option>
                        <option value="electrical">Electrical</option>
                        <option value="furniture">Furniture</option>
                        <option value="cleaning">Cleaning</option>
                        <option value="security">Security</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <div>
                    <label for="issuePriority" class="block text-sm font-medium text-slate-700 mb-1">Priority</label>
                    <div class="flex gap-4">
                        <label class="flex items-center gap-2">
                            <input type="radio" name="issuePriority" value="low" class="h-4 w-4 text-cyan-950 focus:ring-cyan-950">
                            <span class="text-sm text-slate-700">Low</span>
                        </label>
                        <label class="flex items-center gap-2">
                            <input type="radio" name="issuePriority" value="medium" class="h-4 w-4 text-cyan-950 focus:ring-cyan-950" checked>
                            <span class="text-sm text-slate-700">Medium</span>
                        </label>
                        <label class="flex items-center gap-2">
                            <input type="radio" name="issuePriority" value="high" class="h-4 w-4 text-cyan-950 focus:ring-cyan-950">
                            <span class="text-sm text-slate-700">High</span>
                        </label>
                    </div>
                </div>

                <div>
                    <label for="issueDescription" class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                    <textarea id="issueDescription" name="issueDescription" rows="4" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-950 resize-none" placeholder="Please describe the issue in detail..."></textarea>
                </div>
            </div>

            <div class="mt-6 flex justify-end gap-3">
                <button type="button" id="cancelIssueReport" class="px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-4 py-2 bg-cyan-950 text-white rounded-lg hover:bg-cyan-900 transition-colors flex items-center gap-2">
                    <i class="material-icons text-sm">send</i>
                    <span>Submit Report</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/accommodation_dashboard.js"></script>
}