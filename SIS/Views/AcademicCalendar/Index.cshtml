        }

        // Delete event with specific ID
        function deleteEvent(eventId) {
            console.log("Deleting event with ID:", eventId);

            // Show loading indicator
            const deleteBtn = document.getElementById('confirmButton');
            const originalBtnText = deleteBtn.innerHTML;
            deleteBtn.innerHTML = '<i class="material-icons text-sm animate-spin mr-2">refresh</i><span>Deleting...</span>';
            deleteBtn.disabled = true;

            fetch(`/AcademicCalendar/DeleteEvent/${eventId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': csrfToken
                }
            })
            .then(response => {
                if (!response.ok) {
                    return response.text().then(text => {
                        console.error("Server error:", text);
                        throw new Error(`Server error: ${response.status}`);
                    });
                }
                return response.json();
            })
            .then(result => {
                console.log("Delete response:", result);
                if (result.success) {
                    showToast('Event deleted successfully', 'success');
                    closeEventFormModal();
                    calendar.refetchEvents();
                } else {
                    showToast(result.message || 'Error deleting event', 'error');
                }
                // Reset button
                deleteBtn.innerHTML = originalBtnText;
                deleteBtn.disabled = false;
            })
            .catch(error => {
                console.error("Delete error:", error);
                showToast('Error deleting event. Please try again.', 'error');
                // Reset button
                deleteBtn.innerHTML = originalBtnText;
                deleteBtn.disabled = false;
            });
        }

        // Confirm delete event
        function confirmDeleteEvent() {
            const eventId = parseInt(document.getElementById('eventId').value);

            if (!eventId) {
                showToast('Invalid event ID', 'error');
                return;
            }

            console.log("Confirming delete for event ID:", eventId);

            // Populate confirmation modal
            document.getElementById('confirmationTitle').innerHTML = '<i class="material-icons text-red-600 mr-2">warning</i><span>Confirm Delete</span>';
            document.getElementById('confirmationMessage').innerHTML = '<i class="material-icons text-red-600 mr-2 mt-0.5">error_outline</i><span>Are you sure you want to delete this event? This action cannot be undone.</span>';

            // Set up the confirm button
            const confirmButton = document.getElementById('confirmButton');
            confirmButton.innerHTML = '<i class="material-icons text-sm mr-2">delete</i><span>Delete</span>';
            confirmButton.className = 'px-4 py-2.5 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors border border-red-600 shadow-sm flex items-center';
            confirmButton.onclick = function() {
                deleteEvent(eventId);
                closeConfirmationModal();
            };

            // Show the modal
            document.getElementById('confirmationModal').classList.remove('hidden');
        }

        // Set calendar view and update button styles
        function setCalendarView(view, button) {
            // Update current view
            currentView = view;
            calendar.changeView(view);

            // Update button styles
            const buttons = [
                document.getElementById('monthViewBtn'),
                document.getElementById('weekViewBtn'),
                document.getElementById('listViewBtn')
            ];

            buttons.forEach(btn => {
                btn.classList.remove('bg-primary-600', 'text-white');
                btn.classList.add('bg-slate-100', 'text-slate-700');
            });

            button.classList.remove('bg-slate-100', 'text-slate-700');
            button.classList.add('bg-primary-600', 'text-white');
        }

        // Helper function to format date as YYYY-MM-DD
        function formatDate(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        // Helper function to format time as HH:MM
        function formatTime(date) {
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');
            return `${hours}:${minutes}`;
        }

        // Set color for color picker
        function setColor(color) {
            document.getElementById('eventColor').value = color;
            document.getElementById('eventColorHex').value = color;
        }

        // Show toast notification with improved styling
        function showToast(message, type = 'success') {
            window.showAppToast(message, type);
        }

        // Hide toast with animation
        function hideToast() {
            const toast = document.getElementById('toastNotification');
            toast.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                toast.classList.add('hidden');
                toast.classList.remove('scale-95', 'opacity-0');
            }, 300);
        }

        // Open add event modal
        function openAddEventModal() {
            // Reset form
            document.getElementById('eventForm').reset();

            // Set form title
            document.getElementById('eventFormTitle').innerHTML = '<i class="material-icons text-primary-600 mr-2">add_circle</i><span>Add New Event</span>';

            // Set default values
            document.getElementById('eventId').value = '0';
            document.getElementById('eventSystemEvent').value = 'false';
            document.getElementById('eventIsPublished').checked = true;
            document.getElementById('eventColor').value = '#3788d8';
            document.getElementById('eventColorHex').value = '#3788d8';

            // Update publish status indicator
            updatePublishStatusIndicator(true);

            // Set today's date
            const today = new Date();
            document.getElementById('eventStartDate').value = formatDate(today);
            document.getElementById('eventEndDate').value = formatDate(today);

            // Set default times (9 AM - 10 AM)
            document.getElementById('eventStartTime').value = '09:00';
            document.getElementById('eventEndTime').value = '10:00';

            // Hide delete button for new events
            document.getElementById('deleteEventBtn').classList.add('hidden');

            // Set current event to null
            currentEvent = null;

            // Update time fields visibility
            toggleTimeFields();

            // Update color based on selected event type
            updateEventTypeColor();

            // Open the modal with animation
            const modal = document.getElementById('eventFormModal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.querySelector('.relative').classList.add('animate-fadeIn');
            }, 10);
        }

        function closeEventFormModal() {
            // Close with animation
            const modal = document.getElementById('eventFormModal');
            const modalContent = modal.querySelector('.relative');
            modalContent.classList.add('animate-fadeOut');
            setTimeout(() => {
                modal.classList.add('hidden');
                modalContent.classList.remove('animate-fadeOut', 'animate-fadeIn');
            }, 200);
        }

        function openBulkCreateModal() {
            // Reset form
            document.getElementById('bulkCreateForm').reset();

            // Set default values
            document.getElementById('bulkIsPublished').checked = true;
            document.getElementById('bulkColor').value = '#3788d8';
            document.getElementById('bulkColorHex').value = '#3788d8';

            // Update publish status indicator
            updateBulkPublishStatusIndicator(true);

