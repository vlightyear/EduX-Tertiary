            const today = new Date();
            document.getElementById('bulkStartDate').value = formatDate(today);
            document.getElementById('bulkEndDate').value = formatDate(today);

            // Update time fields visibility
            toggleBulkTimeFields();

            // Update color based on selected event type
            updateBulkEventTypeColor();

            // Open the modal with animation
            const modal = document.getElementById('bulkCreateModal');
