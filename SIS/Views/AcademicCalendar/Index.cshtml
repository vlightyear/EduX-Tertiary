            modalContent.classList.add('animate-fadeOut');
            setTimeout(() => {
                modal.classList.add('hidden');
                modalContent.classList.remove('animate-fadeOut', 'animate-fadeIn');
            }, 200);
        }

        function openGenerateSystemEventsModal() {
            // Open the modal with animation
            const modal = document.getElementById('generateSystemEventsModal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.querySelector('.relative').classList.add('animate-fadeIn');
            }, 10);
        }

        function closeGenerateSystemEventsModal() {
            // Close with animation
            const modal = document.getElementById('generateSystemEventsModal');
            const modalContent = modal.querySelector('.relative');
            modalContent.classList.add('animate-fadeOut');
            setTimeout(() => {
                modal.classList.add('hidden');
                modalContent.classList.remove('animate-fadeOut', 'animate-fadeIn');
            }, 200);
        }

        function closeConfirmationModal() {
            // Close with animation
            const modal = document.getElementById('confirmationModal');
            const modalContent = modal.querySelector('.relative');
            modalContent.classList.add('animate-fadeOut');
            setTimeout(() => {
                modal.classList.add('hidden');
                modalContent.classList.remove('animate-fadeOut', 'animate-fadeIn');
            }, 200);
        }

        // Click outside modal to close it
        window.addEventListener('click', function(event) {
            const modals = [
                { element: document.getElementById('eventFormModal'), close: closeEventFormModal },
                { element: document.getElementById('bulkCreateModal'), close: closeBulkCreateModal },
                { element: document.getElementById('generateSystemEventsModal'), close: closeGenerateSystemEventsModal },
                { element: document.getElementById('confirmationModal'), close: closeConfirmationModal }
            ];

            modals.forEach(modal => {
                if (event.target === modal.element) {
                    modal.close();
                }
            });
        });

        // Add animations
        document.head.insertAdjacentHTML('beforeend', `
            <style>
        @@keyframes fadeIn {
                    from { opacity: 0; transform: translateY(10px); }
                    to { opacity: 1; transform: translateY(0); }
                }

        @@keyframes fadeOut {
                    from { opacity: 1; transform: translateY(0); }
                    to { opacity: 0; transform: translateY(10px); }
                }

                .animate-fadeIn {
                    animation: fadeIn 0.2s ease-out forwards;
                }

                .animate-fadeOut {
                    animation: fadeOut 0.2s ease-in forwards;
                }

                .animate-spin {
                    animation: spin 1s linear infinite;
                }

        @@keyframes spin {
                    from { transform: rotate(0deg); }
                    to { transform: rotate(360deg); }
                }
            </style>
        `);
    </script>
}
