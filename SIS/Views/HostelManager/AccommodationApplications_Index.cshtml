@model IEnumerable<SIS.Models.StudentAccommodation.AccommodationApplication>

@{
    ViewData["Title"] = "Accommodation Applications";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .payment-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
    }

        .payment-type-badge.semester {
            background: #e3f2fd;
            color: #1565c0;
        }

        .payment-type-badge.year {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .payment-type-badge.perday {
            background: #fff3e0;
            color: #e65100;
        }

        .payment-type-badge.fixed {
            background: #f3e5f5;
            color: #7b1fa2;
        }
</style>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50 p-4 md:p-6">
    <!-- Header Section -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 md:p-6 mb-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div class="flex items-center">
                <div class="bg-gradient-to-br from-purple-500 to-purple-600 rounded-lg p-3 mr-4">
                    <i class="material-icons text-white text-3xl">assignment</i>
                </div>
                <div>
                    <h1 class="text-2xl md:text-3xl font-bold text-slate-800">Accommodation Applications</h1>
                    <p class="text-sm text-slate-600 mt-1">Manage and process student accommodation requests</p>
                </div>
            </div>
            <div class="flex gap-2">
                <a href="@Url.Action("Index", "AccommodationPeriod")" class="px-6 py-3 bg-blue-100 text-blue-700 text-sm font-medium rounded-lg hover:bg-blue-200 transition-colors flex items-center">
                    <i class="material-icons text-xl mr-2">event</i>
                    Periods
                </a>
                <a href="@Url.Action("Index", "StudentAccommodationApplication")" class="px-6 py-3 bg-gradient-to-r from-purple-600 to-purple-700 text-white text-sm font-medium rounded-lg hover:from-purple-700 hover:to-purple-800 transition-colors flex items-center shadow-sm">
                    <i class="material-icons text-xl mr-2">add_circle</i>
                    Student Portal
                </a>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <!-- Total Applications -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-600 mb-1">Total Applications</p>
                    <p class="text-3xl font-bold text-slate-800">@Model.Count()</p>
                </div>
                <div class="bg-blue-100 rounded-full p-3">
                    <i class="material-icons text-blue-600 text-2xl">inbox</i>
                </div>
            </div>
        </div>

        <!-- Pending Applications -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-600 mb-1">Pending</p>
                    <p class="text-3xl font-bold text-amber-600">@Model.Count(a => a.Status == SIS.Enums.Status.Pending)</p>
                </div>
                <div class="bg-amber-100 rounded-full p-3">
                    <i class="material-icons text-amber-600 text-2xl">hourglass_empty</i>
                </div>
            </div>
        </div>

        <!-- Approved Applications -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-600 mb-1">Approved</p>
                    <p class="text-3xl font-bold text-green-600">@Model.Count(a => a.Status == SIS.Enums.Status.Approved)</p>
                </div>
                <div class="bg-green-100 rounded-full p-3">
                    <i class="material-icons text-green-600 text-2xl">check_circle</i>
                </div>
            </div>
        </div>

        <!-- Rejected Applications -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-600 mb-1">Rejected</p>
                    <p class="text-3xl font-bold text-red-600">@Model.Count(a => a.Status == SIS.Enums.Status.Rejected)</p>
                </div>
                <div class="bg-red-100 rounded-full p-3">
                    <i class="material-icons text-red-600 text-2xl">cancel</i>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters and Search -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
            <!-- Search -->
            <div class="lg:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    <i class="material-icons text-xs align-middle mr-1 text-blue-600">search</i>
                    Search
                </label>
                <input type="text" id="searchInput" placeholder="Search by student name, ID, or email..." class="w-full px-4 py-3 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500">
            </div>

            <!-- Status Filter -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    <i class="material-icons text-xs align-middle mr-1 text-blue-600">filter_list</i>
                    Status
                </label>
                <select id="statusFilter" class="w-full px-4 py-3 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500">
                    <option value="">All Status</option>
                    <option value="pending">Pending</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                </select>
            </div>

            <!-- Period Filter -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    <i class="material-icons text-xs align-middle mr-1 text-blue-600">calendar_today</i>
                    Period
                </label>
                <select id="periodFilter" class="w-full px-4 py-3 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500">
                    <option value="">All Periods</option>
                    @foreach (var period in Model.Select(a => a.Period).Where(p => p != null).DistinctBy(p => p.PeriodId))
                    {
                        <option value="@period.PeriodId">@period.Type - @period.TypeOfPayment</option>
                    }
                </select>
            </div>

            <!-- Payment Type Filter -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    <i class="material-icons text-xs align-middle mr-1 text-blue-600">payment</i>
                    Payment Type
                </label>
                <select id="paymentTypeFilter" class="w-full px-4 py-3 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500">
                    <option value="">All Payment Types</option>
                    <option value="semester">Semester</option>
                    <option value="year">Year</option>
                    <option value="perday">Per Day</option>
                    <option value="fixed">Fixed</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Applications Table -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-gradient-to-r from-purple-600 to-purple-700 text-white py-4 px-6">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                <h5 class="text-lg font-semibold flex items-center">
                    <i class="material-icons mr-2">list</i>
                    Applications List
                </h5>
                <div class="flex gap-2">
                    <button onclick="exportToExcel()" class="px-4 py-2 bg-white bg-opacity-20 hover:bg-opacity-30 text-white text-sm font-medium rounded-lg transition-colors flex items-center">
                        <i class="material-icons text-sm mr-1">download</i>
                        Export
                    </button>
                    <button onclick="printTable()" class="px-4 py-2 bg-white bg-opacity-20 hover:bg-opacity-30 text-white text-sm font-medium rounded-lg transition-colors flex items-center">
                        <i class="material-icons text-sm mr-1">print</i>
                        Print
                    </button>
                </div>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-700 uppercase tracking-wider">
                                Student
                            </th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-700 uppercase tracking-wider">
                                Programme
                            </th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-700 uppercase tracking-wider">
                                Accommodation Details
                            </th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-700 uppercase tracking-wider">
                                Period & Payment
                            </th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-700 uppercase tracking-wider">
                                Application Date
                            </th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-700 uppercase tracking-wider">
                                Status
                            </th>
                            <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-slate-700 uppercase tracking-wider">
                                Actions
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        @foreach (var application in Model)
                        {
                            // Calculate fee for display
                            var period = application.Period;
                            decimal calculatedFee = 0;
                            string feeDisplay = "";
                            if (period != null)
                            {
                                if (period.TypeOfPayment == "PerDay")
                                {
                                    var numberOfDays = application.NumberOfDays ?? 1;
                                    calculatedFee = period.TypeOfPaymentAmount * numberOfDays;
                                    feeDisplay = $"K{calculatedFee:N2} ({numberOfDays}d)";
                                }
                                else
                                {
                                    calculatedFee = period.TypeOfPaymentAmount;
                                    feeDisplay = $"K{calculatedFee:N2}";
                                }
                            }
                            
                            <tr class="application-row hover:bg-slate-50 transition-colors"
                                data-search="@application.Student.FullName.ToLower() @application.Student.StudentId_Number.ToLower() @application.Student.Email.ToLower()"
                                data-status="@application.Status.ToString().ToLower()"
                                data-period="@application.PeriodId"
                                data-payment-type="@(application.Period?.TypeOfPayment?.ToLower() ?? "")">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10">
                                            <div class="h-10 w-10 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center text-white font-semibold">
                                                @application.Student.FullName.Substring(0, 1).ToUpper()
                                            </div>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-semibold text-slate-900">@application.Student.FullName</div>
                                            <div class="text-xs text-slate-500">@application.Student.StudentId_Number</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-slate-800">@application.Student.Programme?.Name</div>
                                    <div class="text-xs text-slate-500">@application.Student.Gender</div>
                                </td>
                                <td class="px-6 py-4">
                                    @* FIXED: Check allocation instead of application.Bed *@
                                    @if (application.Allocation != null)
                                    {
                                        <div class="text-sm text-slate-800">
                                            <div class="font-semibold flex items-center">
                                                <i class="material-icons text-xs text-green-600 mr-1">check_circle</i>
                                                @application.Allocation.Bed.Room.Hostel.HostelName
                                            </div>
                                            <div class="text-xs text-slate-500">
                                                Room @application.Allocation.Bed.Room.RoomNumber - Bed @application.Allocation.Bed.BedIdentifier
                                            </div>
                                            <div class="text-xs text-slate-500">
                                                Floor @application.Allocation.Bed.Room.Floor
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-sm text-slate-500 italic flex items-center">
                                            <i class="material-icons text-xs text-amber-500 mr-1">pending</i>
                                            Not yet allocated
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-slate-800">
                                        <div class="font-semibold">@(application.Period?.Type ?? "N/A")</div>
                                        <div class="mt-1">
                                            <span class="payment-type-badge @(application.Period?.TypeOfPayment?.ToLower() ?? "")">
                                                @(application.Period?.TypeOfPayment ?? "N/A")
                                            </span>
                                        </div>
                                        <div class="text-xs text-slate-500 mt-1">
                                            @feeDisplay
                                            @if (application.Period?.TypeOfPayment == "PerDay" && application.NumberOfDays.HasValue)
                                            {
                                                <span class="text-orange-600">(@application.NumberOfDays days)</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-slate-800">@application.ApplicationDate.ToString("MMM dd, yyyy")</div>
                                    <div class="text-xs text-slate-500">@application.ApplicationDate.ToString("hh:mm tt")</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @switch (application.Status)
                                    {
                                        case SIS.Enums.Status.Pending:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                                <i class="material-icons text-xs mr-1">hourglass_empty</i>
                                                Pending
                                            </span>
                                            break;
                                        case SIS.Enums.Status.Approved:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                <i class="material-icons text-xs mr-1">check_circle</i>
                                                Approved
                                            </span>
                                            break;
                                        case SIS.Enums.Status.Rejected:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                <i class="material-icons text-xs mr-1">cancel</i>
                                                Rejected
                                            </span>
                                            break;
                                        case SIS.Enums.Status.Canceled:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-800">
                                                <i class="material-icons text-xs mr-1">block</i>
                                                Cancelled
                                            </span>
                                            break;
                                        default:
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-800">
                                                @application.Status
                                            </span>
                                            break;
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="flex justify-end gap-2">
                                        <a href="@Url.Action("ApplicationDetails", "HostelManager", new { id = application.ApplicationId })"
                                           class="text-cyan-600 hover:text-cyan-900 transition-colors"
                                           title="View Details">
                                            <i class="material-icons text-xl">visibility</i>
                                        </a>

                                        @if (application.Status == SIS.Enums.Status.Pending && application.Allocation == null)
                                        {
                                            <a href="@Url.Action("AllocateRoom", "HostelManager", new { id = application.ApplicationId })"
                                               class="text-green-600 hover:text-green-900 transition-colors"
                                               title="Allocate Bed">
                                                <i class="material-icons text-xl">add_home</i>
                                            </a>
                                        }

                                        @if (application.Allocation != null)
                                        {
                                            <button onclick="confirmDeallocation(@application.Allocation.AllocationId, '@application.Student.FullName')"
                                                    class="text-orange-600 hover:text-orange-900 transition-colors"
                                                    title="Deallocate Bed">
                                                <i class="material-icons text-xl">remove_circle</i>
                                            </button>
                                        }

                                        @if (application.Status == SIS.Enums.Status.Pending && application.Allocation == null)
                                        {
                                            <button onclick="confirmRejection(@application.ApplicationId, '@application.Student.FullName')"
                                                    class="text-red-600 hover:text-red-900 transition-colors"
                                                    title="Reject Application">
                                                <i class="material-icons text-xl">cancel</i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-16">
                <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-slate-100 mb-4">
                    <i class="material-icons text-slate-400 text-5xl">inbox</i>
                </div>
                <h3 class="text-xl font-semibold text-slate-800 mb-2">No Applications Found</h3>
                <p class="text-slate-600 mb-6">There are no accommodation applications to display.</p>
                <a href="@Url.Action("Index", "StudentAccommodationApplication")" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-purple-600 to-purple-700 text-white text-sm font-medium rounded-lg hover:from-purple-700 hover:to-purple-800 transition-colors shadow-sm">
                    <i class="material-icons mr-2">add_circle</i>
                    Go to Student Portal
                </a>
            </div>
        }
    </div>
</div>

<!-- Rejection Modal -->
<div id="rejectionModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-slate-800">Reject Application</h3>
            <button onclick="closeRejectionModal()" class="text-slate-400 hover:text-slate-600">
                <i class="material-icons">close</i>
            </button>
        </div>
        <p class="text-slate-600 mb-4">Are you sure you want to reject the application for <strong id="rejectStudentName"></strong>?</p>

        <form id="rejectionForm" method="post" action="">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Reason for Rejection</label>
                <textarea name="notes" rows="4" required
                          class="w-full px-4 py-3 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
                          placeholder="Please provide a reason for rejecting this application..."></textarea>
            </div>

            <div class="flex gap-3">
                <button type="button" onclick="closeRejectionModal()"
                        class="flex-1 px-4 py-2 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit"
                        class="flex-1 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                    Reject Application
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Deallocation Modal -->
<div id="deallocationModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-slate-800">Deallocate Bed</h3>
            <button onclick="closeDeallocationModal()" class="text-slate-400 hover:text-slate-600">
                <i class="material-icons">close</i>
            </button>
        </div>
        <p class="text-slate-600 mb-4">Are you sure you want to deallocate the bed for <strong id="deallocateStudentName"></strong>?</p>

        <form id="deallocationForm" method="post" action="">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Reason for Deallocation</label>
                <textarea name="reason" rows="4" required
                          class="w-full px-4 py-3 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
                          placeholder="Please provide a reason for deallocating this bed..."></textarea>
            </div>

            <div class="flex gap-3">
                <button type="button" onclick="closeDeallocationModal()"
                        class="flex-1 px-4 py-2 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 transition-colors">
                    Cancel
                </button>
                <button type="submit"
                        class="flex-1 px-4 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition-colors">
                    Deallocate Bed
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            const statusFilter = document.getElementById('statusFilter');
            const periodFilter = document.getElementById('periodFilter');
            const paymentTypeFilter = document.getElementById('paymentTypeFilter');
            const rows = document.querySelectorAll('.application-row');

            function filterTable() {
                const searchTerm = searchInput.value.toLowerCase();
                const statusValue = statusFilter.value;
                const periodValue = periodFilter.value;
                const paymentTypeValue = paymentTypeFilter.value;

                rows.forEach(row => {
                    const searchData = row.getAttribute('data-search');
                    const rowStatus = row.getAttribute('data-status');
                    const rowPeriod = row.getAttribute('data-period');
                    const rowPaymentType = row.getAttribute('data-payment-type');

                    const matchesSearch = searchData.includes(searchTerm);
                    const matchesStatus = !statusValue || rowStatus === statusValue;
                    const matchesPeriod = !periodValue || rowPeriod === periodValue;
                    const matchesPaymentType = !paymentTypeValue || rowPaymentType === paymentTypeValue;

                    if (matchesSearch && matchesStatus && matchesPeriod && matchesPaymentType) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });

                updateEmptyState();
            }

            function updateEmptyState() {
                const visibleRows = Array.from(rows).filter(row => row.style.display !== 'none');
                // You can add logic here to show/hide a "no results" message
            }

            searchInput.addEventListener('input', filterTable);
            statusFilter.addEventListener('change', filterTable);
            periodFilter.addEventListener('change', filterTable);
            paymentTypeFilter.addEventListener('change', filterTable);
        });

        function confirmRejection(applicationId, studentName) {
            document.getElementById('rejectStudentName').textContent = studentName;
            document.getElementById('rejectionForm').action = '@Url.Action("RejectApplication", "HostelManager")/' + applicationId;
            document.getElementById('rejectionModal').classList.remove('hidden');
        }

        function closeRejectionModal() {
            document.getElementById('rejectionModal').classList.add('hidden');
        }

        function confirmDeallocation(allocationId, studentName) {
            document.getElementById('deallocateStudentName').textContent = studentName;
            document.getElementById('deallocationForm').action = '@Url.Action("DeallocateBed", "HostelManager")';

            // Add hidden input for allocationId
            const existingInput = document.querySelector('#deallocationForm input[name="allocationId"]');
            if (existingInput) {
                existingInput.remove();
            }

            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'allocationId';
            input.value = allocationId;
            document.getElementById('deallocationForm').appendChild(input);

            document.getElementById('deallocationModal').classList.remove('hidden');
        }

        function closeDeallocationModal() {
            document.getElementById('deallocationModal').classList.add('hidden');
        }

        function exportToExcel() {
            // Simple CSV export
            const rows = Array.from(document.querySelectorAll('.application-row')).filter(row => row.style.display !== 'none');
            let csv = 'Student Name,Student ID,Programme,Gender,Accommodation,Period Type,Payment Type,Fee,Application Date,Status\n';

            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                const studentName = cells[0].querySelector('.text-sm.font-semibold').textContent;
                const studentId = cells[0].querySelector('.text-xs').textContent;
                const programme = cells[1].querySelector('.text-sm').textContent;
                const gender = cells[1].querySelector('.text-xs').textContent;
                const accommodation = cells[2].textContent.trim().replace(/\s+/g, ' ');
                const periodType = cells[3].querySelector('.font-semibold')?.textContent || 'N/A';
                const paymentType = cells[3].querySelector('.payment-type-badge')?.textContent.trim() || 'N/A';
                const fee = cells[3].querySelectorAll('.text-xs')[0]?.textContent.trim() || 'N/A';
                const date = cells[4].querySelector('.text-sm').textContent;
                const status = cells[5].textContent.trim();

                csv += `"${studentName}","${studentId}","${programme}","${gender}","${accommodation}","${periodType}","${paymentType}","${fee}","${date}","${status}"\n`;
            });

            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `accommodation-applications-${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
            window.URL.revokeObjectURL(url);
        }

        function printTable() {
            window.print();
        }
    </script>
}

@section Styles {
    <style>
        @@media print {
            .no-print {
                display: none !important;
            }

            body {
                print-color-adjust: exact;
                -webkit-print-color-adjust: exact;
            }
        }
    </style>
}
