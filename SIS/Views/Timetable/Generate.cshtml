@model SIS.Models.TimeTabling.GenerateTimetableViewModel

<div class="min-h-[90vh] bg-gray-50 p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-secondary-800 flex items-center">
            <i class="material-icons mr-2">schedule</i>
            Generate Department Timetable
        </h1>
        <a asp-action="TimetableManagement" class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors flex items-center shadow-sm">
            <i class="material-icons mr-2">arrow_back</i>
            Back to List
        </a>
    </div>

    <!-- Main Content with Sidebar Layout -->
    <div class="flex flex-col md:flex-row gap-6">
        <!-- Main Form Area -->
        <div class="bg-white min-h-[75vh] rounded-lg shadow-md p-6 flex-grow">
            <form asp-action="Generate" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="mb-4 text-red-500"></div>

                <div class="max-w-4xl mx-auto">
                    <!-- Form Fields in Same Row -->
                    <div class="flex flex-col md:flex-row gap-6 mb-8">
                        <!-- Academic Year -->
                        <div class="flex-1">
                            <label asp-for="AcademicYearId" class="block text-sm font-medium text-gray-700 mb-2">Academic Year</label>
                            <select asp-for="AcademicYearId"
                                    asp-items="@(new SelectList(ViewBag.AcademicYears, "YearId", "YearValue"))"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 shadow-sm">
                                <option value="">Select Academic Year</option>
                            </select>
                            <span asp-validation-for="AcademicYearId" class="text-sm text-red-500 mt-1 block"></span>
                        </div>

                        <!-- Mode of Study -->
                        <div class="flex-1">
                            <label asp-for="ModeOfStudyId" class="block text-sm font-medium text-gray-700 mb-2">Mode of Study</label>
                            <select asp-for="ModeOfStudyId"
                                    asp-items="@(new SelectList(ViewBag.ModesOfStudy, "ModeId", "ModeName"))"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 shadow-sm">
                                <option value="">Select Mode of Study</option>
                            </select>
                            <span asp-validation-for="ModeOfStudyId" class="text-sm text-red-500 mt-1 block"></span>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="flex justify-end mt-8">
                        <button type="submit" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center shadow-md">
                            <i class="material-icons mr-2">schedule</i>
                            Generate Department Timetable
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Side Info Bar -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 md:w-80 shadow-md">
            <div class="sticky top-6">
                <h3 class="text-lg font-semibold text-blue-800 mb-4 flex items-center">
                    <i class="material-icons mr-2">info</i>
                    Process Information
                </h3>

                <div class="text-blue-800">
                    <p class="font-medium mb-3">The system will:</p>
                    <ul class="space-y-2 text-sm">
                        <li class="flex items-start">
                            <i class="material-icons text-blue-600 mr-2 text-sm">check_circle</i>
                            <span>Generate timetables for all programmes in your department</span>
                        </li>
                        <li class="flex items-start">
                            <i class="material-icons text-blue-600 mr-2 text-sm">check_circle</i>
                            <span>Prioritize preferred learning rooms for each course</span>
                        </li>
                        <li class="flex items-start">
                            <i class="material-icons text-blue-600 mr-2 text-sm">check_circle</i>
                            <span>Check room capacity and availability</span>
                        </li>
                        <li class="flex items-start">
                            <i class="material-icons text-blue-600 mr-2 text-sm">check_circle</i>
                            <span>Verify instructor availability</span>
                        </li>
                        <li class="flex items-start">
                            <i class="material-icons text-blue-600 mr-2 text-sm">check_circle</i>
                            <span>Avoid scheduling conflicts for student groups</span>
                        </li>
                        <li class="flex items-start">
                            <i class="material-icons text-blue-600 mr-2 text-sm">check_circle</i>
                            <span>Use working days configuration for the selected academic year and mode of study</span>
                        </li>
                    </ul>
                </div>

                <div class="mt-6 pt-6 border-t border-blue-200">
                    <div class="flex items-center text-blue-800">
                        <i class="material-icons text-yellow-600 mr-2">lightbulb</i>
                        <p class="text-sm font-medium">For best results, ensure all course preferences and instructor availability are up to date.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}