@{
    ViewData["Title"] = "Import Questions";
    var questionGroup = ViewBag.QuestionGroup as SIS.Models.Assessments.QuestionGroup;
}

<div class="h-full p-4">
    <!-- Header Section -->
    <div class="flex items-center mb-4">
        <a asp-controller="Assessments" asp-action="QuestionGroupDetails" asp-route-id="@questionGroup.Id"
           class="bg-slate-100 hover:bg-slate-200 p-2 rounded-full mr-2">
            <i class="material-icons text-slate-600">arrow_back</i>
        </a>
        <div class="text-gray-800">
            <h1 class="text-2xl font-bold">Import Questions</h1>
            <p class="text-sm text-slate-600">Group: @questionGroup.Name | Course: @questionGroup.Course?.CourseName</p>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
            <p>@TempData["Success"]</p>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
            <p>@TempData["Error"]</p>
        </div>
    }

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-full">
        <!-- Upload Section (2/3 width) -->
        <div class="w-2/3">
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-semibold text-gray-800 mb-4">Upload Question File</h2>

                <form asp-controller="Assessments" asp-action="UploadImportFile" method="post"
                      enctype="multipart/form-data" id="uploadForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="questionGroupId" value="@questionGroup.Id" />

                    <!-- File Upload Area -->
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            Select Text File (.txt)
                        </label>

                        <div class="flex items-center justify-center w-full">
                            <label for="importFile" class="flex flex-col items-center justify-center w-full h-64 border-2 border-slate-300 border-dashed rounded-lg cursor-pointer bg-slate-50 hover:bg-slate-100 transition-colors">
                                <div class="flex flex-col items-center justify-center pt-5 pb-6" id="uploadPrompt">
                                    <i class="material-icons text-6xl text-slate-400 mb-3">upload_file</i>
                                    <p class="mb-2 text-sm text-slate-600">
                                        <span class="font-semibold">Click to upload</span> or drag and drop
                                    </p>
                                    <p class="text-xs text-slate-500">Text files only (.txt), maximum 2MB</p>
                                </div>
                                <div class="hidden flex-col items-center justify-center pt-5 pb-6" id="fileSelected">
                                    <i class="material-icons text-6xl text-green-500 mb-3">check_circle</i>
                                    <p class="mb-2 text-sm text-slate-600 font-semibold" id="fileName"></p>
                                    <p class="text-xs text-slate-500" id="fileSize"></p>
                                </div>
                                <input id="importFile" name="importFile" type="file" class="hidden"
                                       accept=".txt" required />
                            </label>
                        </div>
                        <p class="text-xs text-slate-500 mt-2">
                            <i class="material-icons text-xs align-middle">info</i>
                            Upload a text file following the template format. Invalid questions will be flagged during preview.
                        </p>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex justify-between items-center">
                        <a asp-controller="Assessments" asp-action="DownloadTemplate"
                           class="px-4 py-2 bg-slate-100 text-slate-800 rounded-lg hover:bg-slate-200 transition-colors flex items-center">
                            <i class="material-icons text-sm mr-1">download</i>
                            Download Template
                        </a>
                        <div class="flex gap-2">
                            <a asp-controller="Assessments" asp-action="QuestionGroupDetails" asp-route-id="@questionGroup.Id"
                               class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                                Cancel
                            </a>
                            <button type="submit" id="uploadBtn" disabled
                                    class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center disabled:bg-slate-300 disabled:cursor-not-allowed">
                                <i class="material-icons text-sm mr-1">cloud_upload</i>
                                Upload & Preview
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Instructions Section (1/3 width) -->
        <div class="w-1/3 space-y-4">
            <!-- Format Instructions Card -->
            <div class="bg-white rounded-lg shadow p-5">
                <h3 class="text-lg font-semibold text-gray-800 mb-3">File Format Guide</h3>

                <div class="space-y-4 text-sm">
                    <div>
                        <h4 class="font-medium text-gray-700 mb-1">Required Fields:</h4>
                        <ul class="list-disc list-inside text-slate-600 space-y-1">
                            <li><code class="bg-slate-100 px-1 rounded">QUESTION:</code> Your question text</li>
                            <li><code class="bg-slate-100 px-1 rounded">POINTS:</code> Point value (must be > 0)</li>
                            <li><code class="bg-slate-100 px-1 rounded">A)</code>, <code class="bg-slate-100 px-1 rounded">B)</code>, etc. - At least 2 options</li>
                            <li><code class="bg-slate-100 px-1 rounded">[CORRECT]</code> - Mark correct answer(s)</li>
                        </ul>
                    </div>

                    <div>
                        <h4 class="font-medium text-gray-700 mb-1">Optional Fields:</h4>
                        <ul class="list-disc list-inside text-slate-600 space-y-1">
                            <li><code class="bg-slate-100 px-1 rounded">INFO:</code> Additional instructions</li>
                        </ul>
                    </div>

                    <div>
                        <h4 class="font-medium text-gray-700 mb-1">Formatting Rules:</h4>
                        <ul class="list-disc list-inside text-slate-600 space-y-1">
                            <li>Separate questions with <code class="bg-slate-100 px-1 rounded">---</code></li>
                            <li>Lines starting with <code class="bg-slate-100 px-1 rounded">#</code> are comments</li>
                            <li>Options must be sequential (A, B, C, D...)</li>
                            <li>Multiple correct answers allowed</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Example Card -->
            <div class="bg-white rounded-lg shadow p-5">
                <h3 class="text-lg font-semibold text-gray-800 mb-3">Example Questions</h3>

                <div class="space-y-3">
                    <!-- Multiple Choice Example -->
                    <div class="bg-slate-50 p-3 rounded border border-slate-200">
                        <p class="text-xs font-semibold text-slate-700 mb-1">Multiple Choice:</p>
                        <pre class="text-xs text-slate-700 whitespace-pre-wrap"><code>TYPE: MultipleChoice
QUESTION: What is 2 + 2?
POINTS: 1
A) 3
B) 4 [CORRECT]
C) 5
---</code></pre>
                    </div>

                    <!-- True/False Example -->
                    <div class="bg-slate-50 p-3 rounded border border-slate-200">
                        <p class="text-xs font-semibold text-slate-700 mb-1">True/False:</p>
                        <pre class="text-xs text-slate-700 whitespace-pre-wrap"><code>TYPE: TrueFalse
QUESTION: The Earth is flat.
POINTS: 1
ANSWER: False
---</code></pre>
                    </div>

                    <!-- Short Answer Example -->
                    <div class="bg-slate-50 p-3 rounded border border-slate-200">
                        <p class="text-xs font-semibold text-slate-700 mb-1">Short Answer:</p>
                        <pre class="text-xs text-slate-700 whitespace-pre-wrap"><code>TYPE: ShortAnswer
QUESTION: What is H2O?
POINTS: 2
EXPECTED_ANSWER: Water
MAX_LENGTH: 50
---</code></pre>
                    </div>

                    <!-- Long Text Example -->
                    <div class="bg-slate-50 p-3 rounded border border-slate-200">
                        <p class="text-xs font-semibold text-slate-700 mb-1">Long Text:</p>
                        <pre class="text-xs text-slate-700 whitespace-pre-wrap"><code>TYPE: LongText
QUESTION: Explain photosynthesis.
POINTS: 5
MIN_LENGTH: 100
MAX_LENGTH: 500
EXPECTED_KEYWORDS: chlorophyll, sunlight
---</code></pre>
                    </div>
                </div>
            </div>
           

            <!-- Tips Card -->
            <div class="bg-blue-50 rounded-lg border border-blue-200 p-4">
                <div class="flex items-start">
                    <i class="material-icons text-blue-600 mr-2">lightbulb</i>
                    <div class="text-sm text-blue-800">
                        <p class="font-medium mb-1">Pro Tip:</p>
                        <p>Download the template to get started quickly. It includes detailed instructions and examples.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const fileInput = document.getElementById('importFile');
            const uploadBtn = document.getElementById('uploadBtn');
            const uploadPrompt = document.getElementById('uploadPrompt');
            const fileSelected = document.getElementById('fileSelected');
            const fileName = document.getElementById('fileName');
            const fileSize = document.getElementById('fileSize');
            const uploadForm = document.getElementById('uploadForm');

            // File input change handler
            fileInput.addEventListener('change', function(e) {
                const file = e.target.files[0];

                if (file) {
                    // Validate file type
                    if (!file.name.endsWith('.txt')) {
                        alert('Please select a .txt file');
                        fileInput.value = '';
                        return;
                    }

                    // Validate file size (2MB)
                    const maxSize = 2 * 1024 * 1024; // 2MB in bytes
                    if (file.size > maxSize) {
                        alert('File size must not exceed 2MB');
                        fileInput.value = '';
                        return;
                    }

                    // Update UI
                    uploadPrompt.classList.add('hidden');
                    fileSelected.classList.remove('hidden');
                    fileSelected.classList.add('flex');
                    fileName.textContent = file.name;
                    fileSize.textContent = formatFileSize(file.size);
                    uploadBtn.disabled = false;
                } else {
                    // Reset UI
                    uploadPrompt.classList.remove('hidden');
                    fileSelected.classList.add('hidden');
                    uploadBtn.disabled = true;
                }
            });

            // Drag and drop handlers
            const dropArea = fileInput.parentElement;

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropArea.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                dropArea.addEventListener(eventName, () => {
                    dropArea.classList.add('border-cyan-400', 'bg-cyan-50');
                }, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropArea.addEventListener(eventName, () => {
                    dropArea.classList.remove('border-cyan-400', 'bg-cyan-50');
                }, false);
            });

            dropArea.addEventListener('drop', function(e) {
                const dt = e.dataTransfer;
                const files = dt.files;

                if (files.length > 0) {
                    fileInput.files = files;
                    // Trigger change event
                    const event = new Event('change', { bubbles: true });
                    fileInput.dispatchEvent(event);
                }
            }, false);

            // Form submission
            uploadForm.addEventListener('submit', function(e) {
                uploadBtn.disabled = true;
                uploadBtn.innerHTML = '<i class="material-icons text-sm mr-1 animate-spin">refresh</i> Processing...';
            });

            // Format file size
            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
            }
        });
    </script>
}