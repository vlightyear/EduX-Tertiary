@model SIS.Models.Assessments.QuestionGroup
@{
    ViewData["Title"] = "Question Group Details";
}

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <div class="flex items-center">
            <a asp-controller="Assessments" asp-action="QuestionGroups" asp-route-courseId="@Model.CourseId"
               class="bg-slate-100 hover:bg-slate-200 p-2 rounded-full mr-2">
                <i class="material-icons text-slate-600">arrow_back</i>
            </a>
            <div class="text-secondary-800">
                <h1 class="text-2xl font-bold">@Model.Name</h1>
                <p class="text-sm text-slate-600">Course: @Model.Course?.CourseName</p>
            </div>
        </div>
        <div class="flex gap-2">
            <a asp-controller="Assessments" asp-action="EditQuestionGroup" asp-route-id="@Model.Id"
               class="px-4 py-2 bg-slate-100 text-slate-800 rounded-lg hover:bg-slate-200 transition-colors flex items-center">
                <i class="material-icons text-sm mr-1">edit</i>
                Edit Group
            </a>

            <a asp-controller="Assessments" asp-action="ImportQuestions" asp-route-questionGroupId="@Model.Id"
               class="px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-700 transition-colors flex items-center">
                <i class="material-icons text-sm mr-1">upload_file</i>
                Import Questions
            </a>

            <a asp-controller="Assessments" asp-action="CreateQuestion" asp-route-questionGroupId="@Model.Id"
               class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
                <i class="material-icons mr-2">add_circle</i>
                Add Question
            </a>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
            <p>@TempData["Success"]</p>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
            <p>@TempData["Error"]</p>
        </div>
    }

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-120px)]">
        <!-- Questions Table Section (3/4 width) -->
        <div class="w-3/4 flex flex-col">
            <div class="bg-white rounded-lg shadow-md flex flex-col" style="height: calc(90vh - 140px);">
                <!-- Search and Filter Bar - Fixed at top -->
                <div class="p-4 flex-shrink-0 border-b border-slate-200">
                    <div class="flex justify-between items-center gap-4">
                        <div class="relative flex-1 max-w-md">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <i class="material-icons text-slate-400 text-sm">search</i>
                            </div>
                            <input type="text" id="searchInput"
                                   class="block w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                   placeholder="Search questions..." />
                        </div>
                        <div class="flex items-center">
                            <label for="filterType" class="text-sm text-slate-600 mr-2">Filter:</label>
                            <select id="filterType"
                                    class="px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500">
                                <option value="all">All Types</option>
                                <option value="MultipleChoice">Multiple Choice</option>
                                <option value="ShortAnswer">Short Answer</option>
                                <option value="LongText">Essay</option>
                                <option value="TrueFalse">True/False</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Scrollable Table Container -->
                <div class="flex-1 overflow-y-auto">
                    <table id="questionsTable" class="w-full text-sm text-secondary-600">
                        <thead class="sticky top-0 bg-slate-50 z-10">
                            <tr>
                                <th class="px-6 py-3 text-left">
                                    <span class="flex items-center">
                                        #
                                        <button class="sort-btn ml-1" data-sort="index">
                                            <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                            </svg>
                                        </button>
                                    </span>
                                </th>
                                <th class="px-6 py-3 text-left">
                                    <span class="flex items-center">
                                        Question
                                    </span>
                                </th>
                                <th class="px-6 py-3 text-left">
                                    <span class="flex items-center">
                                        Type
                                        <button class="sort-btn ml-1" data-sort="type">
                                            <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                            </svg>
                                        </button>
                                    </span>
                                </th>
                                <th class="px-6 py-3 text-left">
                                    <span class="flex items-center">
                                        Points
                                        <button class="sort-btn ml-1" data-sort="points">
                                            <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                            </svg>
                                        </button>
                                    </span>
                                </th>
                                <th class="px-6 py-3 text-left">
                                    <span class="flex items-center">
                                        Status
                                    </span>
                                </th>
                                <th class="px-6 py-3 text-left">
                                    <span class="flex items-center">
                                        Actions
                                    </span>
                                </th>
                            </tr>
                        </thead>
                        <tbody id="questionsTableBody">
                            @if (Model.Questions != null && Model.Questions.Any())
                            {
                                @for (int i = 0; i < Model.Questions.Count; i++)
                                {
                                    var question = Model.Questions.ElementAt(i);
                                    <tr class="hover:bg-slate-50 border-b border-slate-100">
                                        <td class="px-6 py-4">@(i + 1)</td>
                                        <td class="px-6 py-4">
                                            <span class="text-secondary-800 font-medium">
                                                @{
                                                    var displayText = question.QuestionText ?? "";
                                                    // Remove HTML tags safely
                                                    displayText = System.Text.RegularExpressions.Regex.Replace(displayText, "<.*?>", "");
                                                    // Handle special characters and whitespace
                                                    displayText = displayText.Trim();

                                                    if (string.IsNullOrWhiteSpace(displayText))
                                                    {
                                                        displayText = "Question with rich content";
                                                    }
                                                    else if (displayText.Length > 60)
                                                    {
                                                        displayText = displayText.Substring(0, 60) + "...";
                                                    }
                                                }
                                                @Html.Raw(Html.Encode(displayText))
                                            </span>
                                        </td>
                                        <td class="px-6 py-4">
                                            @switch (question.QuestionType)
                                            {
                                                case "MultipleChoice":
                                                    <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full">Multiple Choice</span>
                                                    break;
                                                case "ShortAnswer":
                                                    <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full">Short Answer</span>
                                                    break;
                                                case "LongText":
                                                    <span class="bg-amber-100 text-amber-800 text-xs px-2 py-1 rounded-full">Essay</span>
                                                    break;
                                                case "TrueFalse":
                                                    <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded-full">True/False</span>
                                                    break;
                                                default:
                                                    <span class="bg-slate-100 text-slate-800 text-xs px-2 py-1 rounded-full">@question.QuestionType</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="font-medium">@question.Points</span>
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (question.IsActive)
                                            {
                                                <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full">Active</span>
                                            }
                                            else
                                            {
                                                <span class="bg-slate-100 text-slate-800 text-xs px-2 py-1 rounded-full">Inactive</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex space-x-2">
                                                <a asp-controller="Assessments" asp-action="EditQuestion" asp-route-id="@question.Id"
                                                   class="text-slate-600 hover:text-cyan-600" title="Edit">
                                                    <i class="material-icons text-base">edit</i>
                                                </a>
                                                <a asp-controller="Assessments" asp-action="DeleteQuestion" asp-route-id="@question.Id"
                                                   class="text-slate-600 hover:text-red-600" title="Delete">
                                                    <i class="material-icons text-base">delete</i>
                                                </a>
                                                <a href="#" class="text-slate-600 hover:text-amber-600 preview-question"
                                                   data-id="@question.Id"
                                                   data-text="@Html.Raw(Html.Encode(question.QuestionText))"
                                                   data-type="@question.QuestionType"
                                                   data-info="@Html.Raw(Html.Encode(question.AdditionalInfo ?? ""))"
                                                   data-image-path="@question.ImagePath"
                                                   data-image-desc="@question.ImageDescription"
                                                   data-image-position="@question.ImageDisplayPosition"
                                                   onclick="event.preventDefault(); previewQuestion(this);"
                                                   title="Preview">
                                                    <i class="material-icons text-base">visibility</i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <!-- Empty state message - shown/hidden via JS -->
                    <div id="emptyStateMessage" class="flex flex-col items-center justify-center py-20 text-slate-500"
                         style="@(Model.Questions != null && Model.Questions.Any() ? "display: none;" : "")">
                        <i class="material-icons text-5xl mb-4">help_outline</i>
                        <h3 class="text-xl font-medium mb-2">No Questions Yet</h3>
                        <p class="text-sm mb-4">This question group doesn't have any questions yet.</p>
                        <a asp-controller="Assessments" asp-action="CreateQuestion" asp-route-questionGroupId="@Model.Id"
                           class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
                            <i class="material-icons mr-2">add_circle</i>
                            Add First Question
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Information Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Group Details Card -->
            <div class="bg-white rounded-lg shadow p-5">
                <h3 class="text-lg font-semibold text-secondary-800 mb-3">Group Details</h3>

                <div class="space-y-4">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div>
                            <h4 class="text-sm font-medium text-secondary-600 mb-1">Description</h4>
                            <p class="text-sm text-secondary-800">@Model.Description</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Topics))
                    {
                        <div>
                            <h4 class="text-sm font-medium text-secondary-600 mb-1">Topics</h4>
                            <div class="flex flex-wrap gap-1 mt-1">
                                @foreach (var topic in Model.Topics.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="bg-slate-100 text-slate-800 text-xs px-2 py-1 rounded-full">@topic.Trim()</span>
                                }
                            </div>
                        </div>
                    }

                    <div class="pt-2 border-t border-slate-200">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-medium text-secondary-600">Created by</span>
                            <span class="text-sm text-secondary-800">@Model.CreatedBy</span>
                        </div>
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-medium text-secondary-600">Created on</span>
                            <span class="text-sm text-secondary-800">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.UpdatedBy))
                        {
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-medium text-secondary-600">Last updated</span>
                                <span class="text-sm text-secondary-800">@Model.UpdatedAt?.ToString("MMM dd, yyyy")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Statistics Cards -->
            <div class="bg-white rounded-lg shadow p-5">
                <h3 class="text-lg font-semibold text-secondary-800 mb-3">Statistics</h3>

                <div class="grid grid-cols-2 gap-3">
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <div class="flex flex-col items-center">
                            <span class="text-2xl font-bold text-cyan-600">@Model.Questions.Count</span>
                            <span class="text-xs text-slate-600">Total Questions</span>
                        </div>
                    </div>

                    <div class="bg-slate-50 p-3 rounded-lg">
                        <div class="flex flex-col items-center">
                            <span class="text-2xl font-bold text-cyan-600">@Model.Questions.Sum(q => q.Points)</span>
                            <span class="text-xs text-slate-600">Total Points</span>
                        </div>
                    </div>

                    <div class="bg-slate-50 p-3 rounded-lg">
                        <div class="flex flex-col items-center">
                            <span class="text-2xl font-bold text-cyan-600">
                                @(Model.Questions.Count > 0 ? Model.Questions.Average(q => q.Points).ToString("F1") : "0")
                            </span>
                            <span class="text-xs text-slate-600">Avg Points/Question</span>
                        </div>
                    </div>

                    <div class="bg-slate-50 p-3 rounded-lg">
                        <div class="flex flex-col items-center">
                            <span class="text-2xl font-bold text-cyan-600">
                                @Model.Questions.Count(q => q.IsActive)
                            </span>
                            <span class="text-xs text-slate-600">Active Questions</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Question Type Distribution -->
            <div class="bg-white rounded-lg shadow p-5">
                <h3 class="text-lg font-semibold text-secondary-800 mb-3">Question Types</h3>
                <div id="questionTypeChart" class="h-48"></div>
            </div>
        </div>
    </div>
</div>

<!-- Question Preview Modal -->
<div id="previewQuestionModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hidePreviewModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/2 z-10 overflow-hidden">
        <div class="px-6 py-4 border-b flex justify-between items-center">
            <h3 class="text-xl font-semibold text-secondary-800">Question Preview</h3>
            <span class="text-xs text-slate-500">How students will see this question</span>
        </div>
        <div class="px-6 py-4">
            <div class="bg-slate-50 p-4 rounded-lg border border-slate-200">
                <!-- Image container (above) -->
                <div id="modalPreviewImageAbove" class="text-center mb-3 hidden">
                    <img id="modalPreviewImageElementAbove" src="" alt="" class="max-h-40 rounded mx-auto" />
                </div>

                <div id="modalPreviewQuestion" class="text-sm font-medium text-secondary-800 mb-3"></div>

                <div id="modalPreviewInstructions" class="text-xs italic text-slate-600 mb-4 hidden"></div>

                <!-- Image container (below) -->
                <div id="modalPreviewImageBelow" class="text-center mb-3 hidden">
                    <img id="modalPreviewImageElementBelow" src="" alt="" class="max-h-40 rounded mx-auto" />
                </div>

                <!-- Multiple Choice Preview -->
                <div id="modalPreviewMultipleChoice" class="space-y-2 hidden">
                    <!-- Options will be added dynamically -->
                </div>

                <!-- Short Answer Preview -->
                <div id="modalPreviewShortAnswer" class="hidden">
                    <div class="w-full px-4 py-2 border border-slate-300 rounded-lg bg-white text-sm text-slate-400">
                        Enter your answer here...
                    </div>
                </div>

                <!-- Essay Preview -->
                <div id="modalPreviewLongText" class="hidden">
                    <div class="w-full h-24 px-4 py-2 border border-slate-300 rounded-lg bg-white text-sm text-slate-400">
                        Enter your essay response here...
                    </div>
                </div>

                <!-- True/False Preview -->
                <div id="modalPreviewTrueFalse" class="hidden space-y-2">
                    <div class="flex items-center">
                        <input type="radio" disabled class="mr-2" />
                        <span class="text-sm text-slate-800">True</span>
                    </div>
                    <div class="flex items-center">
                        <input type="radio" disabled class="mr-2" />
                        <span class="text-sm text-slate-800">False</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="px-6 py-4 bg-gray-50 flex justify-end">
            <button type="button" onclick="hidePreviewModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                Close
            </button>
        </div>
    </div>
</div>

<!-- Delete Question Confirmation Modal -->
<div id="deleteQuestionModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideDeleteModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 border-b">
            <h3 class="text-xl font-semibold text-secondary-800">Confirm Deletion</h3>
        </div>
        <div class="px-6 py-4">
            <p class="text-gray-700 mb-4">Are you sure you want to delete this question?</p>
            <div class="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-4">
                <p id="deleteQuestionText" class="font-medium text-sm mb-2 text-slate-800"></p>
                <div class="flex flex-wrap gap-1 mt-2">
                    <span id="deleteQuestionType" class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full"></span>
                    <span id="deleteQuestionPoints" class="bg-slate-100 text-slate-800 text-xs px-2 py-1 rounded-full"></span>
                </div>
            </div>
            <p class="text-sm text-red-600 mb-4">This action cannot be undone and will permanently remove this question and all associated options.</p>
            <div id="deleteQuestionError" class="text-red-600 text-sm hidden"></div>
        </div>
        <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
            <button type="button" onclick="hideDeleteModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                Cancel
            </button>
            <button type="button" id="confirmDeleteButton" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                Delete Question
            </button>
        </div>
    </div>
</div>

<!-- Delete Question Confirmation Form -->
@using (Html.BeginForm("DeleteQuestionConfirmed", "Assessments", FormMethod.Post, new { id = "deleteForm" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteQuestionId" name="id" value="" />
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize variables and elements
            const searchInput = document.getElementById('searchInput');
            const filterType = document.getElementById('filterType');
            const questionsTable = document.getElementById('questionsTable');
            const questionsTableBody = document.getElementById('questionsTableBody');
            const emptyStateMessage = document.getElementById('emptyStateMessage');
            const deleteForm = document.getElementById('deleteForm');
    
            // Question data table filtering
            searchInput.addEventListener('input', filterTable);
            filterType.addEventListener('change', filterTable);
    
            // Setup sorting buttons
            document.querySelectorAll('.sort-btn').forEach(button => {
                button.addEventListener('click', function() {
                    const sortKey = this.getAttribute('data-sort');
                    sortTable(sortKey);
                });
            });
    
            // Initialize chart if we have data
            if (questionsTableBody.children.length > 0) {
                initializeQuestionTypeChart();
            }
    
            // Table filtering function
            function filterTable() {
                const searchTerm = searchInput.value.toLowerCase();
                const filterValue = filterType.value;
                let visibleRows = 0;
        
                // Get all rows
                const rows = questionsTableBody.querySelectorAll('tr');
        
                rows.forEach(row => {
                    const questionText = row.children[1].textContent.toLowerCase();
                    const questionType = row.children[2].querySelector('span').textContent.toLowerCase();
            
                    // Combine search term and filter conditions
                    let showRow = questionText.includes(searchTerm);
            
                    if (filterValue !== 'all') {
                        // Map display text back to database values for filtering
                        let typeValue = '';
                        switch (questionType) {
                            case 'multiple choice':
                                typeValue = 'MultipleChoice';
                                break;
                            case 'short answer':
                                typeValue = 'ShortAnswer';
                                break;
                            case 'essay':
                                typeValue = 'LongText';
                                break;
                            case 'true/false':
                                typeValue = 'TrueFalse';
                                break;
                            default:
                                typeValue = questionType;
                        }
                
                        showRow = showRow && (typeValue === filterValue);
                    }
            
                    // Show/hide the row
                    row.style.display = showRow ? '' : 'none';
                    if (showRow) visibleRows++;
                });
        
                // Show empty state if no visible rows
                emptyStateMessage.style.display = visibleRows === 0 ? 'flex' : 'none';
                questionsTable.style.display = visibleRows === 0 ? 'none' : '';
            }
    
            // Table sorting function
            function sortTable(key) {
                const rows = Array.from(questionsTableBody.querySelectorAll('tr'));
        
                // Define sort functions for different columns
                const sortFunctions = {
                    'index': (a, b) => {
                        return parseInt(a.children[0].textContent) - parseInt(b.children[0].textContent);
                    },
                    'type': (a, b) => {
                        return a.children[2].textContent.localeCompare(b.children[2].textContent);
                    },
                    'points': (a, b) => {
                        return parseFloat(a.children[3].textContent) - parseFloat(b.children[3].textContent);
                    }
                };
        
                // Sort the rows
                rows.sort(sortFunctions[key]);
        
                // Check if we need to reverse the order (if already sorted)
                const button = document.querySelector(`.sort-btn[data-sort="${key}"]`);
                if (button.classList.contains('sorted-asc')) {
                    rows.reverse();
                    button.classList.remove('sorted-asc');
                    button.classList.add('sorted-desc');
                } else {
                    // Clear all other sort classes
                    document.querySelectorAll('.sort-btn').forEach(btn => {
                        btn.classList.remove('sorted-asc');
                        btn.classList.remove('sorted-desc');
                    });
                    button.classList.add('sorted-asc');
                }
        
                // Reorder the table
                questionsTableBody.innerHTML = '';
                rows.forEach(row => questionsTableBody.appendChild(row));
            }

                   // Initialize donut chart for question types
        function initializeQuestionTypeChart() {
            const chartContainer = document.getElementById('questionTypeChart');

            // Count question types
            const rows = questionsTableBody.querySelectorAll('tr');
            let mcCount = 0, saCount = 0, essayCount = 0, tfCount = 0, otherCount = 0;

            rows.forEach(row => {
                const type = row.children[2].textContent.trim();
                if (type.includes('Multiple Choice')) mcCount++;
                else if (type.includes('Short Answer')) saCount++;
                else if (type.includes('Essay')) essayCount++;
                else if (type.includes('True/False')) tfCount++;
                else otherCount++;
            });

            // Enhanced fallback layout with better alignment
            chartContainer.innerHTML = `
                <div class="space-y-3">
                    <div class="grid grid-cols-2 gap-2 text-center">
                        <div class="bg-blue-100 p-3 rounded-lg">
                            <div class="text-xl font-bold text-blue-800">${mcCount}</div>
                            <div class="text-xs text-slate-600 leading-tight">Multiple Choice</div>
                        </div>
                        <div class="bg-green-100 p-3 rounded-lg">
                            <div class="text-xl font-bold text-green-800">${saCount}</div>
                            <div class="text-xs text-slate-600 leading-tight">Short Answer</div>
                        </div>
                        <div class="bg-amber-100 p-3 rounded-lg">
                            <div class="text-xl font-bold text-amber-800">${essayCount}</div>
                            <div class="text-xs text-slate-600 leading-tight">Essay</div>
                        </div>
                        <div class="bg-red-100 p-3 rounded-lg">
                            <div class="text-xl font-bold text-red-800">${tfCount}</div>
                            <div class="text-xs text-slate-600 leading-tight">True/False</div>
                        </div>
                    </div>
                </div>
            `;

            // If you have ApexCharts, use it with better configuration
            if (typeof ApexCharts !== 'undefined') {
                // Clear the fallback content first
                chartContainer.innerHTML = '';

                const options = {
                    series: [mcCount, saCount, essayCount, tfCount].filter(count => count > 0),
                    chart: {
                        type: 'donut',
                        height: 190, // Reduced height to fit better
                        width: '100%'
                    },
                    labels: [
                        ...(mcCount > 0 ? ['Multiple Choice'] : []),
                        ...(saCount > 0 ? ['Short Answer'] : []),
                        ...(essayCount > 0 ? ['Essay'] : []),
                        ...(tfCount > 0 ? ['True/False'] : [])
                    ],
                    colors: ['#3B82F6', '#10B981', '#F59E0B', '#EF4444'],
                    plotOptions: {
                        pie: {
                            donut: {
                                size: '60%', // Reduced donut size
                                labels: {
                                    show: true,
                                    total: {
                                        show: true,
                                        label: 'Total',
                                        fontSize: '14px',
                                        fontWeight: 600,
                                        color: '#374151',
                                        formatter: function (w) {
                                            return w.globals.seriesTotals.reduce((a, b) => {
                                                return a + b;
                                            }, 0);
                                        }
                                    }
                                }
                            }
                        }
                    },
                    legend: {
                        position: 'bottom',
                        fontSize: '11px',
                        fontFamily: 'Inter, sans-serif',
                        fontWeight: 400,
                        offsetY: 5,
                        itemMargin: {
                            horizontal: 8,
                            vertical: 2
                        },
                        markers: {
                            width: 8,
                            height: 8,
                            radius: 2
                        }
                    },
                    dataLabels: {
                        enabled: false // Disable data labels on slices for cleaner look
                    },
                    tooltip: {
                        y: {
                            formatter: function(val) {
                                return val + ' questions';
                            }
                        }
                    },
                    responsive: [{
                        breakpoint: 480,
                        options: {
                            chart: {
                                height: 180
                            },
                            legend: {
                                fontSize: '10px',
                                itemMargin: {
                                    horizontal: 5,
                                    vertical: 1
                                }
                            }
                        }
                    }]
                };

                const chart = new ApexCharts(chartContainer, options);
                chart.render();
            }
        }
    
            // Delete Question Modal functionality
            let deleteQuestionId = null;
    
            function showDeleteModal(id, text, type, points) {
                deleteQuestionId = id;
        
                // Set modal content
                document.getElementById('deleteQuestionText').textContent = text;
        
                const typeEl = document.getElementById('deleteQuestionType');
                typeEl.textContent = type;
        
                // Set type badge color
                typeEl.className = 'text-xs px-2 py-1 rounded-full'; // Reset classes
                if (type.includes('Multiple Choice')) {
                    typeEl.classList.add('bg-blue-100', 'text-blue-800');
                } else if (type.includes('Short Answer')) {
                    typeEl.classList.add('bg-green-100', 'text-green-800');
                } else if (type.includes('Essay')) {
                    typeEl.classList.add('bg-amber-100', 'text-amber-800');
                } else if (type.includes('True/False')) {
                    typeEl.classList.add('bg-red-100', 'text-red-800');
                } else {
                    typeEl.classList.add('bg-slate-100', 'text-slate-800');
                }
        
                document.getElementById('deleteQuestionPoints').textContent = `${points} points`;
        
                // Show modal
                document.getElementById('deleteQuestionModal').classList.remove('hidden');
                document.getElementById('deleteQuestionError').classList.add('hidden');
            }
    
            function hideDeleteModal() {
                document.getElementById('deleteQuestionModal').classList.add('hidden');
                deleteQuestionId = null;
            }
    
            function deleteQuestion() {
                if (!deleteQuestionId) return;
        
                // Set the hidden input value
                document.getElementById('deleteQuestionId').value = deleteQuestionId;
        
                // Submit the form
                document.getElementById('deleteForm').submit();
            }
    
            // Add click handlers for delete buttons
            document.querySelectorAll('a[href*="DeleteQuestion"]').forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault(); // Always prevent default navigation
            
                    const id = this.getAttribute('href').split('/').pop();
                    const row = this.closest('tr');
                    const questionText = row.querySelector('td:nth-child(2)').textContent.trim();
                    const questionType = row.querySelector('td:nth-child(3)').textContent.trim();
                    const points = row.querySelector('td:nth-child(4)').textContent.trim();
            
                    showDeleteModal(id, questionText, questionType, points);
                });
            });
    
            // Set up confirm delete button
            document.getElementById('confirmDeleteButton').addEventListener('click', deleteQuestion);


            // Question Preview Modal functionality
            let previewQuestionId = null;

            function showPreviewModal(id, text, type, info, imagePath, imageDesc, imagePosition) {
                previewQuestionId = id;

                // Set modal content
                document.getElementById('modalPreviewQuestion').innerHTML  = text;

                // Handle additional info/instructions
                const instructionsEl = document.getElementById('modalPreviewInstructions');
                if (info && info.trim() !== '' && info.trim() !== ' ') {
                    instructionsEl.innerHTML = info;
                    instructionsEl.classList.remove('hidden');
                } else {
                    instructionsEl.classList.add('hidden');
                }

                // Handle image display
                const imageAboveContainer = document.getElementById('modalPreviewImageAbove');
                const imageBelowContainer = document.getElementById('modalPreviewImageBelow');
                const imageAboveElement = document.getElementById('modalPreviewImageElementAbove');
                const imageBelowElement = document.getElementById('modalPreviewImageElementBelow');

                // Hide both containers initially
                imageAboveContainer.classList.add('hidden');
                imageBelowContainer.classList.add('hidden');

                // If there's an image, show it in the appropriate position
                if (imagePath) {
                    const imageContainer = imagePosition === 'Below' ? imageBelowContainer : imageAboveContainer;
                    const imageElement = imagePosition === 'Below' ? imageBelowElement : imageAboveElement;

                    imageElement.src = imagePath;
                    imageElement.alt = imageDesc || 'Question image';
                    imageContainer.classList.remove('hidden');
                }

                // Hide all preview containers first
                document.getElementById('modalPreviewMultipleChoice').classList.add('hidden');
                document.getElementById('modalPreviewShortAnswer').classList.add('hidden');
                document.getElementById('modalPreviewLongText').classList.add('hidden');
                document.getElementById('modalPreviewTrueFalse').classList.add('hidden');

                // Show the appropriate container based on question type
                switch (type) {
                    case 'MultipleChoice':
                        // Fetch options for multiple choice questions
                        fetchQuestionOptions(id);
                        break;
                    case 'ShortAnswer':
                        document.getElementById('modalPreviewShortAnswer').classList.remove('hidden');
                        break;
                    case 'LongText':
                        document.getElementById('modalPreviewLongText').classList.remove('hidden');
                        break;
                    case 'TrueFalse':
                        document.getElementById('modalPreviewTrueFalse').classList.remove('hidden');
                        break;
                }

                // Show modal
                document.getElementById('previewQuestionModal').classList.remove('hidden');
            }

            // Fetch options for multiple choice questions
            function fetchQuestionOptions(questionId) {
                fetch(`/Assessments/GetQuestionOptions/${questionId}`)
                .then(response => response.json())
                .then(options => {
                    const container = document.getElementById('modalPreviewMultipleChoice');
                    container.innerHTML = '';

                    options.forEach(option => {
                        const optionEl = document.createElement('div');
                        optionEl.className = 'flex items-center';

                        const input = document.createElement('input');
                        input.type = 'radio';
                        input.disabled = true;
                        input.className = 'mr-2';

                        const text = document.createElement('span');
                        text.className = 'text-sm text-slate-800';
                        text.textContent = option.optionText;

                        optionEl.appendChild(input);
                        optionEl.appendChild(text);
                        container.appendChild(optionEl);
                    });

                    container.classList.remove('hidden');
                })
                .catch(error => {
                    console.error('Error fetching question options:', error);
                    // Fallback to show the container with default options
                    document.getElementById('modalPreviewMultipleChoice').classList.remove('hidden');
                });
            }

            // Add click handlers for preview buttons
            window.previewQuestion = function (element) {
                const id = element.getAttribute('data-id');
                const text = element.getAttribute('data-text');
                const type = element.getAttribute('data-type');
                const info = element.getAttribute('data-info');
                const imagePath = element.getAttribute('data-image-path');
                const imageDesc = element.getAttribute('data-image-desc');
                const imagePosition = element.getAttribute('data-image-position') || 'Above';

                showPreviewModal(id, text, type, info, imagePath, imageDesc, imagePosition);
            };


            window.hidePreviewModal = function () {
                document.getElementById('previewQuestionModal').classList.add('hidden');
                previewQuestionId = null;
            }
            console.log('Side G');

        });
    </script>
