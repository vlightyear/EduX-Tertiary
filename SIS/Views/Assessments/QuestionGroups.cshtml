@model List<SIS.Models.Assessments.QuestionGroup>
@{
    ViewData["Title"] = "Question Groups";
    var courseId = (int)(ViewData["CourseId"] ?? 0);
}

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <div class="flex items-center text-gray-800">
            <i class="material-icons text-3xl mr-2">folder</i>
            <div>
                <h1 class="text-2xl font-bold">My Question Groups</h1>
                @if (ViewBag.Course != null)
                {
                    <p class="text-sm text-slate-600">Course: @ViewBag.Course.CourseName</p>
                }
                else
                {
                    <p class="text-sm text-slate-600">All My Question Groups</p>
                }
            </div>
        </div>
        <a asp-controller="Assessments" asp-action="CreateQuestionGroup" asp-route-courseId="@courseId"
           class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
            <i class="material-icons mr-2">add_circle</i>
            Create Question Group
        </a>
    </div>

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-80px)]">
        <!-- Main Table Section (3/4 width) -->
        <div class="w-3/4">
            <div class="bg-white rounded-lg shadow-md h-full">
                <div class="p-4">
                    <div class="flex justify-between items-center mb-4">
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <i class="material-icons text-slate-400 text-sm">search</i>
                            </div>
                            <input type="text" id="searchInput"
                                   class="block w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                   placeholder="Search question groups..." />
                        </div>
                        <div class="flex items-center">
                            <label for="filterStatus" class="text-sm text-slate-600 mr-2">Filter:</label>
                            <select id="filterStatus"
                                    class="px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500">
                                <option value="all">All Groups</option>
                                <option value="withQuestions">With Questions</option>
                                <option value="empty">Empty Groups</option>
                            </select>
                        </div>
                    </div>

                    <div class="overflow-y-auto h-[calc(100%-60px)]">
                        @if (TempData["Success"] != null)
                        {
                            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
                                <p>@TempData["Success"]</p>
                            </div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
                                <p>@TempData["Error"]</p>
                            </div>
                        }

                        <table id="questionGroupsTable" class="w-full text-sm text-gray-600">
                            <thead class="sticky top-0 bg-slate-50">
                                <tr>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            #
                                            <button class="sort-btn ml-1" data-sort="index">
                                                <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                                </svg>
                                            </button>
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Name
                                            <button class="sort-btn ml-1" data-sort="name">
                                                <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                                </svg>
                                            </button>
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">Course</th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Topics
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Questions
                                            <button class="sort-btn ml-1" data-sort="questions">
                                                <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m8 15 4 4 4-4m0-6-4-4-4 4" />
                                                </svg>
                                            </button>
                                        </span>
                                    </th>
                                    <th class="px-6 py-3 text-left">
                                        <span class="flex items-center">
                                            Actions
                                        </span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="questionGroupsTableBody">
                                @if (Model != null && Model.Any())
                                {
                                    @for (int i = 0; i < Model.Count; i++)
                                    {
                                        var group = Model[i];
                                        <tr class="hover:bg-slate-50">
                                            <td class="px-6 py-4">@(i + 1)</td>
                                            <td class="px-6 py-4 font-medium">
                                                <a asp-controller="Assessments" asp-action="QuestionGroupDetails" asp-route-id="@group.Id"
                                                   class="text-cyan-600 hover:text-cyan-800 hover:underline">
                                                    @group.Name
                                                </a>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full">
                                                    @group.Course.CourseName
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                @if (!string.IsNullOrEmpty(group.Topics))
                                                {
                                                    <div class="flex flex-wrap gap-1">
                                                        @foreach (var topic in group.Topics.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                                        {
                                                            <span class="bg-slate-100 text-slate-800 text-xs px-2 py-1 rounded-full">@topic.Trim()</span>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-slate-400">-</span>
                                                }
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="font-medium">@group.Questions.Count</span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex space-x-2">
                                                    <a asp-controller="Assessments" asp-action="EditQuestionGroup" asp-route-id="@group.Id"
                                                       class="text-slate-600 hover:text-cyan-600" title="Edit">
                                                        <i class="material-icons text-base">edit</i>
                                                    </a>
                                                    <a href="javascript:void(0)"
                                                       onclick="showDeleteModal(@group.Id, '@group.Name.Replace("'", "\\'")', '@group.Questions.Count')"
                                                       class="text-slate-600 hover:text-red-600" title="Delete">
                                                        <i class="material-icons text-base">delete</i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                        <!-- Empty state message -->
                        <div id="emptyStateMessage" class="flex flex-col items-center justify-center h-[calc(100%-60px)] text-slate-500"
                             style="@(Model != null && Model.Any() ? "display: none;" : "")">
                            <i class="material-icons text-5xl mb-4">folder_off</i>
                            <h3 class="text-xl font-medium mb-2">No Question Groups</h3>
                            <p class="text-sm mb-4">You haven't created any question groups for your courses yet.</p>
                            <a asp-controller="Assessments" asp-action="CreateQuestionGroup" asp-route-courseId="@courseId"
                               class="px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center">
                                <i class="material-icons mr-2">add_circle</i>
                                Create First Question Group
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Sidebar (1/4 width) -->
        <div class="w-1/4 space-y-4">
            <!-- Statistics Cards -->
            <div class="grid grid-cols-1 gap-4">
                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-cyan-100 rounded-lg">
                            <i class="material-icons text-cyan-600 text-xl">folder</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Question Groups</p>
                            <div id="totalGroups" class="text-xl font-semibold">@(Model?.Count ?? 0)</div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 rounded-lg">
                            <i class="material-icons text-blue-600 text-xl">question_answer</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Total Questions</p>
                            <div id="totalQuestions" class="text-xl font-semibold text-blue-600">
                                @(Model?.Sum(g => g.Questions.Count) ?? 0)
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 rounded-lg">
                            <i class="material-icons text-green-600 text-xl">analytics</i>
                        </div>
                        <div class="ml-4">
                            <p class="text-gray-500 text-sm">Avg. Questions Per Group</p>
                            <div id="avgQuestions" class="text-xl font-semibold text-green-600">
                                @{
                                    var avgQuestions = Model != null && Model.Any()
                                    ? Math.Round((double)Model.Sum(g => g.Questions.Count) / Model.Count, 1)
                                    : 0;
                                }
                                @avgQuestions
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Question Types Chart -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Question Type Distribution</h3>
                <div id="questionTypeChart" class="h-64"></div>
            </div>

            <!-- Recent Activity -->
            <div class="bg-white rounded-lg shadow p-4">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Recent Activity</h3>
                <div id="recentActivityList" class="space-y-3">
                    @if (Model != null && Model.Any())
                    {
                        var recentGroups = Model.OrderByDescending(g => g.CreatedAt).Take(3);
                        foreach (var group in recentGroups)
                        {
                            <div class="flex items-start">
                                <div class="bg-cyan-100 p-2 rounded-full mr-3">
                                    <i class="material-icons text-cyan-600 text-sm">folder</i>
                                </div>
                                <div>
                                    <p class="text-sm font-medium">
                                        <span class="text-cyan-600">@group.Name</span> created
                                    </p>
                                    <p class="text-xs text-slate-500">
                                        @group.CreatedAt.ToString("MMM dd, yyyy") by @group.CreatedBy
                                    </p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-slate-500">No recent activity</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Question Group Confirmation Modal -->
<div id="deleteGroupModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideDeleteModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 border-b">
            <h3 class="text-xl font-semibold text-gray-800">Confirm Deletion</h3>
        </div>
        <div class="px-6 py-4">
            <p class="text-gray-700 mb-4">Are you sure you want to delete this question group?</p>
            <div class="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-4">
                <p id="deleteGroupName" class="font-medium text-sm mb-2 text-slate-800"></p>
                <div class="flex flex-wrap gap-1 mt-2">
                    <span id="deleteGroupQuestionCount" class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full"></span>
                </div>
            </div>
            <p class="text-sm text-red-600 mb-4">This action cannot be undone and will permanently remove this question group and all its questions.</p>
            <div id="deleteGroupError" class="text-red-600 text-sm hidden"></div>
        </div>
        <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
            <button type="button" onclick="hideDeleteModal()" class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                Cancel
            </button>
            <button type="button" id="confirmDeleteGroupButton" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                Delete Question Group
            </button>
        </div>
    </div>
</div>

<!-- Delete Confirmation Form -->
@using (Html.BeginForm("DeleteQuestionGroupConfirmed", "Assessments", FormMethod.Post, new { id = "deleteForm" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteGroupId" name="id" value="" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script>
        // Pass the question type distribution data from controller to JavaScript
        var questionTypeDistribution = @Html.Raw(Json.Serialize(ViewBag.QuestionTypeDistribution ?? new List<object>()));

        document.addEventListener('DOMContentLoaded', function () {
            // Initialize variables and elements
            const searchInput = document.getElementById('searchInput');
            const filterStatus = document.getElementById('filterStatus');
            const questionGroupsTable = document.getElementById('questionGroupsTable');
            const questionGroupsTableBody = document.getElementById('questionGroupsTableBody');
            const emptyStateMessage = document.getElementById('emptyStateMessage');
            const totalGroups = document.getElementById('totalGroups');
            const totalQuestions = document.getElementById('totalQuestions');
            const avgQuestions = document.getElementById('avgQuestions');
            const deleteForm = document.getElementById('deleteForm');

            // Store original values for statistics
            const originalTotalGroups = @(Model?.Count ?? 0);
            const originalTotalQuestions = @(Model?.Sum(g => g.Questions.Count) ?? 0);
            const originalAvgQuestions = @avgQuestions;

            // Modal elements
            const deleteGroupModal = document.getElementById('deleteGroupModal');
            const deleteGroupName = document.getElementById('deleteGroupName');
            const deleteGroupQuestionCount = document.getElementById('deleteGroupQuestionCount');
            const confirmDeleteGroupButton = document.getElementById('confirmDeleteGroupButton');
            const deleteGroupId = document.getElementById('deleteGroupId');

            // Question data table filtering
            searchInput.addEventListener('input', filterTable);
            filterStatus.addEventListener('change', filterTable);

            // Setup sorting buttons
            document.querySelectorAll('.sort-btn').forEach(button => {
                button.addEventListener('click', function() {
                    const sortKey = this.getAttribute('data-sort');
                    sortTable(sortKey);
                });
            });

            // Initialize chart if we have data
            initializeQuestionTypeChart();

            // Table filtering function
            function filterTable() {
                const searchTerm = searchInput.value.toLowerCase();
                const filterValue = filterStatus.value;
                let visibleRows = 0;
                let visibleQuestions = 0;

                // Get all rows
                const rows = questionGroupsTableBody.querySelectorAll('tr');

                rows.forEach(row => {
                    const name = row.children[1].textContent.toLowerCase();
                    const questionCount = parseInt(row.children[4].textContent.trim());

                    // Combine search term and filter conditions
                    let showRow = name.includes(searchTerm);

                    if (filterValue === 'withQuestions' && questionCount === 0) {
                        showRow = false;
                    } else if (filterValue === 'empty' && questionCount > 0) {
                        showRow = false;
                    }

                    // Show/hide the row
                    row.style.display = showRow ? '' : 'none';
                    if (showRow) {
                        visibleRows++;
                        visibleQuestions += questionCount;
                    }
                });

                // Update stats for filtered view
                totalGroups.textContent = visibleRows;
                totalQuestions.textContent = visibleQuestions;
                avgQuestions.textContent = visibleRows > 0 ? (visibleQuestions / visibleRows).toFixed(1) : '0';

                // Show empty state if no visible rows
                emptyStateMessage.style.display = visibleRows === 0 ? 'flex' : 'none';
                questionGroupsTable.style.display = visibleRows === 0 ? 'none' : '';
            }

            // Table sorting function
            function sortTable(key) {
                const rows = Array.from(questionGroupsTableBody.querySelectorAll('tr'));

                // Define sort functions for different columns
                const sortFunctions = {
                    'index': (a, b) => {
                        return parseInt(a.children[0].textContent) - parseInt(b.children[0].textContent);
                    },
                    'name': (a, b) => {
                        return a.children[1].textContent.localeCompare(b.children[1].textContent);
                    },
                    'questions': (a, b) => {
                        return parseInt(a.children[4].textContent) - parseInt(b.children[4].textContent);
                    }
                };

                // Sort the rows
                rows.sort(sortFunctions[key]);

                // Check if we need to reverse the order (if already sorted)
                const button = document.querySelector(`.sort-btn[data-sort="${key}"]`);
                if (button.classList.contains('sorted-asc')) {
                    rows.reverse();
                    button.classList.remove('sorted-asc');
                    button.classList.add('sorted-desc');
                } else {
                    // Clear all other sort classes
                    document.querySelectorAll('.sort-btn').forEach(btn => {
                        btn.classList.remove('sorted-asc');
                        btn.classList.remove('sorted-desc');
                    });
                    button.classList.add('sorted-asc');
                }

                // Reorder the table
                questionGroupsTableBody.innerHTML = '';
                rows.forEach(row => questionGroupsTableBody.appendChild(row));
            }

            // Initialize ApexCharts donut chart with actual data
            function initializeQuestionTypeChart() {
                const chartContainer = document.getElementById('questionTypeChart');

                // Check if we have actual data
                if (!questionTypeDistribution || questionTypeDistribution.length === 0) {
                    chartContainer.innerHTML = `
                        <div class="flex flex-col items-center justify-center h-full text-slate-500">
                            <i class="material-icons text-4xl mb-2">pie_chart</i>
                            <p class="text-sm text-center">Chart will appear here once you create questions.</p>
                        </div>
                    `;
                    return;
                }

                // Extract chart data
                let chartData = [];
                let chartLabels = [];

                questionTypeDistribution.forEach(item => {
                    chartData.push(item.count);
                    chartLabels.push(item.type);
                });

                const options = {
                    series: chartData,
                    chart: {
                        type: 'donut',
                        height: '100%'
                    },
                    labels: chartLabels,
                    colors: ['#3B82F6', '#10B981', '#F59E0B', '#EF4444', '#8B5CF6', '#EC4899'],
                    plotOptions: {
                        pie: {
                            donut: {
                                size: '65%',
                                labels: {
                                    show: true,
                                    name: {
                                        show: true,
                                        fontSize: '14px',
                                        fontWeight: 600
                                    },
                                    value: {
                                        show: true,
                                        fontSize: '16px',
                                        fontWeight: 600,
                                        formatter: function (val) {
                                            return val;
                                        }
                                    },
                                    total: {
                                        show: true,
                                        label: 'Total',
                                        fontSize: '14px',
                                        fontWeight: 600,
                                        formatter: function (w) {
                                            return w.globals.seriesTotals.reduce((a, b) => a + b, 0);
                                        }
                                    }
                                }
                            }
                        }
                    },
                    dataLabels: {
                        enabled: false
                    },
                    responsive: [{
                        breakpoint: 480,
                        options: {
                            chart: {
                                height: 200
                            },
                            legend: {
                                show: false
                            }
                        }
                    }],
                    legend: {
                        position: 'bottom',
                        fontSize: '12px',
                        labels: {
                            colors: '#64748B'
                        }
                    }
                };

                // Create the chart
                const chart = new ApexCharts(chartContainer, options);
                chart.render();
            }

            // Show delete modal function
            window.showDeleteModal = function(id, name, questionCount) {
                deleteGroupName.textContent = name;
                deleteGroupQuestionCount.textContent = `${questionCount} Questions`;
                deleteGroupId.value = id;

                // Show the modal
                deleteGroupModal.classList.remove('hidden');

                // Setup the confirm button
                confirmDeleteGroupButton.onclick = function() {
                    deleteForm.submit();
                };
            };

            // Hide delete modal function
            window.hideDeleteModal = function() {
                deleteGroupModal.classList.add('hidden');
            };
        });
    </script>
}