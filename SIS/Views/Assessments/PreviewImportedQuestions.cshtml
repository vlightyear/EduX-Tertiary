@model SIS.Models.Import.BulkImportPreviewViewModel
@{
    ViewData["Title"] = "Preview Imported Questions";
}

<div class="h-[90vh] p-4">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-4">
        <div class="flex items-center">
            <a asp-controller="Assessments" asp-action="ImportQuestions" asp-route-questionGroupId="@Model.QuestionGroupId"
               class="bg-slate-100 hover:bg-slate-200 p-2 rounded-full mr-2">
                <i class="material-icons text-slate-600">arrow_back</i>
            </a>
            <div class="text-secondary-800">
                <h1 class="text-2xl font-bold">Preview Imported Questions</h1>
                <p class="text-sm text-slate-600">Group: @Model.QuestionGroup?.Name | Course: @Model.QuestionGroup?.Course?.CourseName</p>
            </div>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4" role="alert">
            <p>@TempData["Success"]</p>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4" role="alert">
            <p>@TempData["Error"]</p>
        </div>
    }

    <!-- Main Content Layout -->
    <div class="flex gap-4 h-[calc(90vh-120px)]">
        <!-- Questions Table Section (70% width) -->
        <div class="w-[70%] flex flex-col">
            <div class="bg-white rounded-lg shadow-md flex flex-col" style="height: calc(90vh - 140px);">
                <div class="p-4 flex-shrink-0">
                    <!-- Filter/Search Bar -->
                    <div class="flex justify-between items-center mb-4">
                        <div class="flex items-center gap-2">
                            <button type="button" id="filterAll" class="filter-btn px-3 py-1 text-sm rounded bg-slate-200 text-slate-800">
                                All (@Model.TotalQuestions)
                            </button>
                            <button type="button" id="filterValid" class="filter-btn px-3 py-1 text-sm rounded text-slate-600 hover:bg-slate-100">
                                Valid (@Model.ValidQuestions)
                            </button>
                            <button type="button" id="filterInvalid" class="filter-btn px-3 py-1 text-sm rounded text-slate-600 hover:bg-slate-100">
                                Invalid (@Model.InvalidQuestions)
                            </button>
                        </div>
                        <span class="text-sm text-slate-600">
                            <span id="visibleCount">@Model.TotalQuestions</span> question(s) shown
                        </span>
                    </div>
                </div>

               <!-- Questions Container - SCROLLABLE -->
<div class="flex-1 overflow-y-auto px-4 pb-4 space-y-3" id="questionsContainer">
    @foreach (var question in Model.ImportedQuestions)
    {
        <div class="question-card border rounded-lg p-4 @(question.IsValid ? "border-slate-200 bg-white" : "border-red-200 bg-red-50")"
             data-question-id="@question.TemporaryId"
             data-is-valid="@question.IsValid.ToString().ToLower()"
             data-question-type="@question.QuestionType">

            <!-- Question Header -->
            <div class="flex justify-between items-start mb-3">
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-xs font-medium text-slate-500">Line @question.LineNumber</span>
                    
                    <!-- Question Type Badge -->
                    <span class="bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded-full">
                        @question.GetQuestionTypeDisplay()
                    </span>
                    
                    @if (question.IsValid)
                    {
                        <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full flex items-center">
                            <i class="material-icons text-xs mr-1">check_circle</i>
                            Valid
                        </span>
                    }
                    else
                    {
                        <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded-full flex items-center">
                            <i class="material-icons text-xs mr-1">error</i>
                            Invalid
                        </span>
                    }
                    
                    @if (question.QuestionType == "MultipleChoice" || question.QuestionType == "TrueFalse")
                    {
                        <span class="text-xs text-slate-600">
                            @question.Options.Count option(s) | @question.GetCorrectAnswersCount() correct
                        </span>
                    }
                    else
                    {
                        <span class="text-xs text-slate-600">Open-ended question</span>
                    }
                </div>
                <div class="flex gap-1 flex-shrink-0">
                    <button type="button" class="edit-btn text-slate-600 hover:text-cyan-600 p-1" title="Edit">
                        <i class="material-icons text-base">edit</i>
                    </button>
                    <button type="button" class="delete-btn text-slate-600 hover:text-red-600 p-1"
                            data-temp-id="@question.TemporaryId" title="Delete">
                        <i class="material-icons text-base">delete</i>
                    </button>
                </div>
            </div>

            <!-- Question Content (View Mode) -->
            <div class="question-view">
                <div class="mb-3">
                    <p class="text-sm font-medium text-secondary-800">@question.QuestionText</p>
                    @if (!string.IsNullOrEmpty(question.AdditionalInfo))
                    {
                        <p class="text-xs italic text-slate-600 mt-1">@question.AdditionalInfo</p>
                    }
                </div>

                @if (question.QuestionType == "MultipleChoice" || question.QuestionType == "TrueFalse")
                {
                    <div class="grid grid-cols-2 gap-2 mb-3">
                        @foreach (var option in question.Options)
                        {
                            <div class="flex items-center text-sm @(option.IsCorrect ? "text-green-700 font-medium" : "text-slate-700")">
                                @if (option.IsCorrect)
                                {
                                    <i class="material-icons text-sm mr-1 text-green-600">check_circle</i>
                                }
                                else
                                {
                                    <i class="material-icons text-sm mr-1 text-slate-400">radio_button_unchecked</i>
                                }
                                <span>@option.OptionLetter) @option.OptionText</span>
                            </div>
                        }
                    </div>
                }
                else if (question.QuestionType == "ShortAnswer")
                {
                    <div class="bg-slate-50 p-3 rounded mb-3">
                        <p class="text-xs text-slate-600 mb-2">
                            <i class="material-icons text-xs align-middle">edit_note</i>
                            Students will provide a short text answer
                        </p>
                        @if (!string.IsNullOrEmpty(question.ExpectedAnswer))
                        {
                            <p class="text-xs text-slate-700">
                                <strong>Expected Answer:</strong> @question.ExpectedAnswer
                            </p>
                        }
                        @if (question.MaxLength.HasValue)
                        {
                            <p class="text-xs text-slate-700">
                                <strong>Max Length:</strong> @question.MaxLength characters
                            </p>
                        }
                    </div>
                }
                else if (question.QuestionType == "LongText")
                {
                    <div class="bg-slate-50 p-3 rounded mb-3">
                        <p class="text-xs text-slate-600 mb-2">
                            <i class="material-icons text-xs align-middle">article</i>
                            Students will provide a detailed text answer
                        </p>
                        @if (!string.IsNullOrEmpty(question.ExpectedAnswer))
                        {
                            <p class="text-xs text-slate-700 mb-1">
                                <strong>Expected Answer:</strong> @question.ExpectedAnswer
                            </p>
                        }
                        @if (question.MinLength.HasValue)
                        {
                            <p class="text-xs text-slate-700">
                                <strong>Min Length:</strong> @question.MinLength characters
                            </p>
                        }
                        @if (question.MaxLength.HasValue)
                        {
                            <p class="text-xs text-slate-700">
                                <strong>Max Length:</strong> @question.MaxLength characters
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(question.ExpectedKeywords))
                        {
                            <p class="text-xs text-slate-700">
                                <strong>Expected Keywords:</strong> @question.ExpectedKeywords
                            </p>
                        }
                    </div>
                }

                <div class="flex items-center gap-4 text-xs text-slate-600">
                    <span class="flex items-center">
                        <i class="material-icons text-xs mr-1">star</i>
                        <span class="points-display">@question.Points</span> point(s)
                    </span>
                </div>

                @if (!question.IsValid)
                {
                    <div class="mt-2 p-2 bg-red-100 rounded text-xs text-red-700">
                        <strong>Validation Errors:</strong>
                        <ul class="list-disc list-inside mt-1">
                            @foreach (var error in question.ValidationErrors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }
            </div>

            <!-- Question Content (Edit Mode) - Hidden by default -->
            <div class="question-edit hidden">
                <div class="mb-3">
                    <label class="block text-xs font-medium text-slate-700 mb-1">Question Type</label>
                    <input type="text" value="@question.GetQuestionTypeDisplay()" readonly
                           class="w-full px-3 py-2 text-sm border border-slate-300 rounded-lg bg-slate-100" />
                </div>

                <div class="mb-3">
                    <label class="block text-xs font-medium text-slate-700 mb-1">Question Text</label>
                    <textarea class="edit-question-text w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                              rows="2">@question.QuestionText</textarea>
                </div>

                <div class="mb-3">
                    <label class="block text-xs font-medium text-slate-700 mb-1">Additional Info (Optional)</label>
                    <textarea class="edit-additional-info w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                              rows="1">@question.AdditionalInfo</textarea>
                </div>

                <div class="mb-3">
                    <label class="block text-xs font-medium text-slate-700 mb-1">Points</label>
                    <input type="number" step="0.25" min="0.25"
                           class="edit-points w-32 px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                           value="@question.Points" />
                </div>

                @if (question.QuestionType == "MultipleChoice")
                {
                    <div class="mb-3">
                        <label class="block text-xs font-medium text-slate-700 mb-1">Options (check correct answers)</label>
                        <div class="space-y-2 edit-options-container">
                            @for (int i = 0; i < question.Options.Count; i++)
                            {
                                var option = question.Options[i];
                                <div class="flex items-center gap-2">
                                    <input type="checkbox" class="option-correct"
                                           data-letter="@option.OptionLetter"
                                    @(option.IsCorrect ? "checked" : "") />
                                    <span class="text-sm font-medium">@option.OptionLetter)</span>
                                    <input type="text" class="option-text flex-1 px-3 py-1 text-sm border border-slate-300 rounded focus:ring-cyan-500 focus:border-cyan-500"
                                           value="@option.OptionText"
                                           data-letter="@option.OptionLetter" />
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (question.QuestionType == "TrueFalse")
                {
                                    <div class="mb-3">
                                        <label class="block text-xs font-medium text-slate-700 mb-1">Correct Answer</label>
                                        <select class="edit-truefalse-answer w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500">
                                            @if (question.TrueFalseAnswer == true)
                                            {
                                                <option value="true" selected>True</option>
                                                <option value="false">False</option>
                                            }
                                            else
                                            {
                                                <option value="true">True</option>
                                                <option value="false" selected>False</option>
                                            }
                                        </select>
                                    </div>
                }
                else if (question.QuestionType == "ShortAnswer")
                {
                    <div class="mb-3">
                        <label class="block text-xs font-medium text-slate-700 mb-1">Expected Answer (Optional)</label>
                        <input type="text" class="edit-expected-answer w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                               value="@question.ExpectedAnswer" />
                    </div>
                    <div class="mb-3">
                        <label class="block text-xs font-medium text-slate-700 mb-1">Max Length (Optional)</label>
                        <input type="number" class="edit-max-length w-32 px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                               value="@question.MaxLength" min="1" />
                    </div>
                }
                else if (question.QuestionType == "LongText")
                {
                    <div class="mb-3">
                        <label class="block text-xs font-medium text-slate-700 mb-1">Expected Answer (Optional)</label>
                        <textarea class="edit-expected-answer w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                  rows="2">@question.ExpectedAnswer</textarea>
                    </div>
                    <div class="grid grid-cols-2 gap-2 mb-3">
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">Min Length (Optional)</label>
                            <input type="number" class="edit-min-length w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                   value="@question.MinLength" min="1" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">Max Length (Optional)</label>
                            <input type="number" class="edit-max-length w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                                   value="@question.MaxLength" min="1" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="block text-xs font-medium text-slate-700 mb-1">Expected Keywords (Optional, comma-separated)</label>
                        <input type="text" class="edit-expected-keywords w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"
                               value="@question.ExpectedKeywords" />
                    </div>
                }

                <div class="flex justify-end gap-2">
                    <button type="button" class="cancel-edit-btn px-3 py-1 text-sm bg-slate-200 text-slate-800 rounded hover:bg-slate-300">
                        Cancel
                    </button>
                    <button type="button" class="save-edit-btn px-3 py-1 text-sm bg-cyan-600 text-white rounded hover:bg-cyan-700">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    }
</div>
            </div>
        </div>

        <!-- Summary Sidebar (30% width) -->
        <div class="w-[30%] space-y-4">
            <!-- Statistics Card -->
            <div class="bg-white rounded-lg shadow p-5">
                <h3 class="text-lg font-semibold text-secondary-800 mb-3">Import Summary</h3>

                <div class="grid grid-cols-2 gap-3 mb-4">
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <div class="flex flex-col items-center">
                            <span class="text-2xl font-bold text-cyan-600" id="totalCount">@Model.TotalQuestions</span>
                            <span class="text-xs text-slate-600">Total</span>
                        </div>
                    </div>

                    <div class="bg-green-50 p-3 rounded-lg">
                        <div class="flex flex-col items-center">
                            <span class="text-2xl font-bold text-green-600" id="validCount">@Model.ValidQuestions</span>
                            <span class="text-xs text-slate-600">Valid</span>
                        </div>
                    </div>

                    <div class="bg-red-50 p-3 rounded-lg col-span-2">
                        <div class="flex flex-col items-center">
                            <span class="text-2xl font-bold text-red-600" id="invalidCount">@Model.InvalidQuestions</span>
                            <span class="text-xs text-slate-600">Invalid (Will be skipped)</span>
                        </div>
                    </div>
                </div>

                @if (Model.InvalidQuestions > 0)
                {
                    <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mb-4">
                        <div class="flex items-start">
                            <i class="material-icons text-amber-600 mr-2 text-sm">warning</i>
                            <p class="text-xs text-amber-800">
                                @Model.InvalidQuestions question(s) have validation errors and will not be imported.
                                You can edit them above or remove them from the import.
                            </p>
                        </div>
                    </div>
                }

                <div class="pt-3 border-t border-slate-200">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-sm font-medium text-secondary-600">Question Group</span>
                    </div>
                    <p class="text-sm text-secondary-800">@Model.QuestionGroup?.Name</p>
                    <p class="text-xs text-slate-600 mt-1">@Model.QuestionGroup?.Course?.CourseName</p>
                </div>
            </div>

            <!-- Actions Card -->
            <div class="bg-white rounded-lg shadow p-5">
                <h3 class="text-lg font-semibold text-secondary-800 mb-3">Actions</h3>

                <form asp-controller="Assessments" asp-action="ConfirmImport" method="post" id="confirmImportForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="questionGroupId" value="@Model.QuestionGroupId" />

                    <button type="submit"
                            class="w-full px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors flex items-center justify-center mb-2 disabled:bg-slate-300 disabled:cursor-not-allowed"
                    @(Model.ValidQuestions == 0 ? "disabled" : "")
                            id="confirmImportBtn">
                        <i class="material-icons text-sm mr-1">save</i>
                        Import @Model.ValidQuestions Valid Question(s)
                    </button>
                </form>

                <form asp-controller="Assessments" asp-action="CancelImport" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="questionGroupId" value="@Model.QuestionGroupId" />

                    <button type="submit"
                            class="w-full px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                        Cancel Import
                    </button>
                </form>
            </div>

            <!-- Help Card -->
            <div class="bg-blue-50 rounded-lg border border-blue-200 p-4">
                <div class="flex items-start">
                    <i class="material-icons text-blue-600 mr-2">info</i>
                    <div class="text-xs text-blue-800">
                        <p class="font-medium mb-1">Preview & Edit</p>
                        <p>Review all questions before importing. Click the edit icon to make changes or delete unwanted questions. Only valid questions will be imported.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black opacity-40" onclick="hideDeleteModal()"></div>
    <div class="bg-white rounded-lg shadow-lg w-11/12 md:w-1/3 z-10 overflow-hidden">
        <div class="px-6 py-4 border-b">
            <h3 class="text-xl font-semibold text-secondary-800">Confirm Deletion</h3>
        </div>
        <div class="px-6 py-4">
            <p class="text-gray-700">Are you sure you want to remove this question from the import?</p>
            <p class="text-sm text-slate-600 mt-2">This action cannot be undone.</p>
        </div>
        <div class="px-6 py-4 bg-gray-50 flex justify-end gap-2">
            <button type="button" onclick="hideDeleteModal()"
                    class="px-4 py-2 bg-slate-200 text-slate-800 rounded-lg hover:bg-slate-300 transition-colors">
                Cancel
            </button>
            <button type="button" id="confirmDeleteBtn"
                    class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                Delete Question
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentDeleteId = null;

        document.addEventListener('DOMContentLoaded', function() {
            // Filter buttons
            const filterBtns = document.querySelectorAll('.filter-btn');
            const questionCards = document.querySelectorAll('.question-card');
            const visibleCount = document.getElementById('visibleCount');

            filterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    // Update active button
                    filterBtns.forEach(b => {
                        b.classList.remove('bg-slate-200', 'text-slate-800');
                        b.classList.add('text-slate-600', 'hover:bg-slate-100');
                    });
                    this.classList.add('bg-slate-200', 'text-slate-800');
                    this.classList.remove('text-slate-600', 'hover:bg-slate-100');

                    // Filter questions
                    let visible = 0;
                    const filter = this.id.replace('filter', '').toLowerCase();

                    questionCards.forEach(card => {
                        const isValid = card.getAttribute('data-is-valid') === 'true';
                        let show = false;

                        if (filter === 'all') {
                            show = true;
                        } else if (filter === 'valid' && isValid) {
                            show = true;
                        } else if (filter === 'invalid' && !isValid) {
                            show = true;
                        }

                        card.style.display = show ? 'block' : 'none';
                        if (show) visible++;
                    });

                    visibleCount.textContent = visible;
                });
            });

            // Edit button handlers
            document.querySelectorAll('.edit-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const card = this.closest('.question-card');
                    const viewMode = card.querySelector('.question-view');
                    const editMode = card.querySelector('.question-edit');

                    viewMode.classList.add('hidden');
                    editMode.classList.remove('hidden');
                });
            });

            // Cancel edit handlers
            document.querySelectorAll('.cancel-edit-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const card = this.closest('.question-card');
                    const viewMode = card.querySelector('.question-view');
                    const editMode = card.querySelector('.question-edit');

                    viewMode.classList.remove('hidden');
                    editMode.classList.add('hidden');
                });
            });

                   // Save edit handlers
        document.querySelectorAll('.save-edit-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const card = this.closest('.question-card');
                const tempId = parseInt(card.getAttribute('data-question-id'));
                const questionType = card.getAttribute('data-question-type');

                const questionText = card.querySelector('.edit-question-text').value;
                const additionalInfo = card.querySelector('.edit-additional-info').value;
                const points = parseFloat(card.querySelector('.edit-points').value);

                const updatedQuestion = {
                    TemporaryId: tempId,
                    QuestionText: questionText,
                    AdditionalInfo: additionalInfo,
                    Points: points,
                    QuestionType: questionType
                };

                // Type-specific data collection
                if (questionType === 'MultipleChoice') {
                    const options = [];
                    const optionElements = card.querySelectorAll('.edit-options-container > div');

                    optionElements.forEach(optionEl => {
                        const checkbox = optionEl.querySelector('.option-correct');
                        const textInput = optionEl.querySelector('.option-text');
                        const letter = checkbox.getAttribute('data-letter');

                        options.push({
                            OptionLetter: letter,
                            OptionText: textInput.value,
                            IsCorrect: checkbox.checked
                        });
                    });

                    updatedQuestion.Options = options;
                } else if (questionType === 'TrueFalse') {
                    const answer = card.querySelector('.edit-truefalse-answer').value;
                    updatedQuestion.TrueFalseAnswer = answer === 'true';
                    updatedQuestion.Options = [];
                } else if (questionType === 'ShortAnswer') {
                    const expectedAnswer = card.querySelector('.edit-expected-answer').value;
                    const maxLength = card.querySelector('.edit-max-length').value;

                    updatedQuestion.ExpectedAnswer = expectedAnswer;
                    updatedQuestion.MaxLength = maxLength ? parseInt(maxLength) : null;
                    updatedQuestion.Options = [];
                } else if (questionType === 'LongText') {
                    const expectedAnswer = card.querySelector('.edit-expected-answer').value;
                    const minLength = card.querySelector('.edit-min-length').value;
                    const maxLength = card.querySelector('.edit-max-length').value;
                    const keywords = card.querySelector('.edit-expected-keywords').value;

                    updatedQuestion.ExpectedAnswer = expectedAnswer;
                    updatedQuestion.MinLength = minLength ? parseInt(minLength) : null;
                    updatedQuestion.MaxLength = maxLength ? parseInt(maxLength) : null;
                    updatedQuestion.ExpectedKeywords = keywords;
                    updatedQuestion.Options = [];
                }

                // Send update to server
                saveQuestionEdit(tempId, updatedQuestion, card);
            });
        });

            // Delete button handlers
            document.querySelectorAll('.delete-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    currentDeleteId = parseInt(this.getAttribute('data-temp-id'));
                    showDeleteModal();
                });
            });

            // Confirm delete
            document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
                if (currentDeleteId !== null) {
                    deleteQuestion(currentDeleteId);
                }
            });

            // Form submission
            document.getElementById('confirmImportForm').addEventListener('submit', function(e) {
                const btn = document.getElementById('confirmImportBtn');
                btn.disabled = true;
                btn.innerHTML = '<i class="material-icons text-sm mr-1 animate-spin">refresh</i> Importing...';
            });
        });

               async function saveQuestionEdit(tempId, updatedQuestion, card) {
            try {
                const response = await fetch('/Assessments/UpdateImportedQuestion', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(updatedQuestion)
                });

                const result = await response.json();

                if (result.success) {
                    // Update view mode
                    const viewMode = card.querySelector('.question-view');
                    const editMode = card.querySelector('.question-edit');

                    // Update question text
                    viewMode.querySelector('p.font-medium').textContent = updatedQuestion.QuestionText;

                    // Update additional info
                    const additionalInfoP = viewMode.querySelector('p.italic');
                    if (updatedQuestion.AdditionalInfo) {
                        if (additionalInfoP) {
                            additionalInfoP.textContent = updatedQuestion.AdditionalInfo;
                        } else {
                            const p = document.createElement('p');
                            p.className = 'text-xs italic text-slate-600 mt-1';
                            p.textContent = updatedQuestion.AdditionalInfo;
                            viewMode.querySelector('.mb-3').appendChild(p);
                        }
                    } else if (additionalInfoP) {
                        additionalInfoP.remove();
                    }

                    // Update points
                    viewMode.querySelector('.points-display').textContent = updatedQuestion.Points;

                    const questionType = card.getAttribute('data-question-type');

                    // Update type-specific content
                    if (questionType === 'MultipleChoice' || questionType === 'TrueFalse') {
                        // Update options display
                        const optionsGrid = viewMode.querySelector('.grid');
                        if (optionsGrid && updatedQuestion.Options) {
                            optionsGrid.innerHTML = '';

                            updatedQuestion.Options.forEach(option => {
                                const optionDiv = document.createElement('div');
                                optionDiv.className = `flex items-center text-sm ${option.IsCorrect ? 'text-green-700 font-medium' : 'text-slate-700'}`;
                                optionDiv.innerHTML = `
                                    ${option.IsCorrect
                                        ? '<i class="material-icons text-sm mr-1 text-green-600">check_circle</i>'
                                        : '<i class="material-icons text-sm mr-1 text-slate-400">radio_button_unchecked</i>'}
                                    <span>${option.OptionLetter}) ${option.OptionText}</span>
                                `;
                                optionsGrid.appendChild(optionDiv);
                            });

                            // Update correct answers count
                            const countSpan = card.querySelector('.text-xs.text-slate-600');
                            if (countSpan) {
                                const currentText = countSpan.textContent;
                                countSpan.textContent = currentText.replace(/\d+ correct/, `${result.correctAnswersCount} correct`);
                            }
                        }
                    } else {
                        // For ShortAnswer and LongText, update metadata display
                        const metadataDiv = viewMode.querySelector('.bg-slate-50');
                        if (metadataDiv && updatedQuestion.QuestionType) {
                            // Rebuild metadata display based on updated values
                            let metadataHtml = '';

                            if (questionType === 'ShortAnswer') {
                                metadataHtml = `<p class="text-xs text-slate-600 mb-2">
                                    <i class="material-icons text-xs align-middle">edit_note</i>
                                    Students will provide a short text answer
                                </p>`;

                                if (updatedQuestion.ExpectedAnswer) {
                                    metadataHtml += `<p class="text-xs text-slate-700"><strong>Expected Answer:</strong> ${updatedQuestion.ExpectedAnswer}</p>`;
                                }
                                if (updatedQuestion.MaxLength) {
                                    metadataHtml += `<p class="text-xs text-slate-700"><strong>Max Length:</strong> ${updatedQuestion.MaxLength} characters</p>`;
                                }
                            } else if (questionType === 'LongText') {
                                metadataHtml = `<p class="text-xs text-slate-600 mb-2">
                                    <i class="material-icons text-xs align-middle">article</i>
                                    Students will provide a detailed text answer
                                </p>`;

                                if (updatedQuestion.ExpectedAnswer) {
                                    metadataHtml += `<p class="text-xs text-slate-700 mb-1"><strong>Expected Answer:</strong> ${updatedQuestion.ExpectedAnswer}</p>`;
                                }
                                if (updatedQuestion.MinLength) {
                                    metadataHtml += `<p class="text-xs text-slate-700"><strong>Min Length:</strong> ${updatedQuestion.MinLength} characters</p>`;
                                }
                                if (updatedQuestion.MaxLength) {
                                    metadataHtml += `<p class="text-xs text-slate-700"><strong>Max Length:</strong> ${updatedQuestion.MaxLength} characters</p>`;
                                }
                                if (updatedQuestion.ExpectedKeywords) {
                                    metadataHtml += `<p class="text-xs text-slate-700"><strong>Expected Keywords:</strong> ${updatedQuestion.ExpectedKeywords}</p>`;
                                }
                            }

                            metadataDiv.innerHTML = metadataHtml;
                        }
                    }

                    // Update validation status
                    if (result.isValid) {
                        card.classList.remove('border-red-200', 'bg-red-50');
                        card.classList.add('border-slate-200', 'bg-white');
                        card.setAttribute('data-is-valid', 'true');

                        // Update badge
                        const badge = card.querySelector('.bg-red-100, .bg-green-100');
                        if (badge && !badge.classList.contains('bg-purple-100')) {
                            badge.className = 'bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full flex items-center';
                            badge.innerHTML = '<i class="material-icons text-xs mr-1">check_circle</i>Valid';
                        }

                        // Remove error message if exists
                        const errorDiv = viewMode.querySelector('.bg-red-100');
                        if (errorDiv) errorDiv.remove();
                    } else {
                        card.classList.add('border-red-200', 'bg-red-50');
                        card.classList.remove('border-slate-200', 'bg-white');
                        card.setAttribute('data-is-valid', 'false');

                        // Update badge
                        const badge = card.querySelector('.bg-green-100, .bg-red-100');
                        if (badge && !badge.classList.contains('bg-purple-100')) {
                            badge.className = 'bg-red-100 text-red-800 text-xs px-2 py-1 rounded-full flex items-center';
                            badge.innerHTML = '<i class="material-icons text-xs mr-1">error</i>Invalid';
                        }

                        // Show validation errors
                        let errorDiv = viewMode.querySelector('.bg-red-100.mt-2');
                        if (!errorDiv) {
                            errorDiv = document.createElement('div');
                            errorDiv.className = 'mt-2 p-2 bg-red-100 rounded text-xs text-red-700';
                            viewMode.appendChild(errorDiv);
                        }

                        errorDiv.innerHTML = '<strong>Validation Errors:</strong><ul class="list-disc list-inside mt-1">';
                        result.validationErrors.forEach(error => {
                            errorDiv.innerHTML += `<li>${error}</li>`;
                        });
                        errorDiv.innerHTML += '</ul>';
                    }

                    // Switch back to view mode
                    viewMode.classList.remove('hidden');
                    editMode.classList.add('hidden');

                    // Update summary counts
                    updateSummaryCounts();

                    // Show success message
                    showToast('Question updated successfully', 'success');
                } else {
                    window.showAppToast('Error updating question: ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                window.showAppToast('Error updating question. Please try again.');
            }
        }

        async function deleteQuestion(tempId) {
            try {
                const formData = new FormData();
                formData.append('temporaryId', tempId);

                const response = await fetch('/Assessments/DeleteImportedQuestion', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    // Remove the card from DOM
                    const card = document.querySelector(`[data-question-id="${tempId}"]`);
                    if (card) {
                        card.remove();
                    }

                    // Update counts in UI
                    document.getElementById('totalCount').textContent = result.remainingCount;
                    document.getElementById('validCount').textContent = result.validCount;
                    document.getElementById('invalidCount').textContent = result.invalidCount;

                    // Update filter button counts
                    document.getElementById('filterAll').textContent = `All (${result.remainingCount})`;
                    document.getElementById('filterValid').textContent = `Valid (${result.validCount})`;
                    document.getElementById('filterInvalid').textContent = `Invalid (${result.invalidCount})`;

                    // Update visible count
                    const visibleCount = document.querySelectorAll('.question-card:not([style*="display: none"])').length;
                    document.getElementById('visibleCount').textContent = visibleCount - 1;

                    // Update confirm button
                    const confirmBtn = document.getElementById('confirmImportBtn');
                    if (result.validCount === 0) {
                        confirmBtn.disabled = true;
                        confirmBtn.textContent = 'No Valid Questions to Import';
                    } else {
                        confirmBtn.innerHTML = `<i class="material-icons text-sm mr-1">save</i>Import ${result.validCount} Valid Question(s)`;
                    }

                    hideDeleteModal();
                    showToast('Question removed successfully', 'success');
                } else {
                    window.showAppToast('Error deleting question: ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                window.showAppToast('Error deleting question. Please try again.');
            }
        }

        function updateSummaryCounts() {
            const cards = document.querySelectorAll('.question-card');
            let total = cards.length;
            let valid = 0;
            let invalid = 0;

            cards.forEach(card => {
                if (card.getAttribute('data-is-valid') === 'true') {
                    valid++;
                } else {
                    invalid++;
                }
            });

            document.getElementById('totalCount').textContent = total;
            document.getElementById('validCount').textContent = valid;
            document.getElementById('invalidCount').textContent = invalid;

            // Update filter buttons
            document.getElementById('filterAll').textContent = `All (${total})`;
            document.getElementById('filterValid').textContent = `Valid (${valid})`;
            document.getElementById('filterInvalid').textContent = `Invalid (${invalid})`;

            // Update confirm button
            const confirmBtn = document.getElementById('confirmImportBtn');
            if (valid === 0) {
                confirmBtn.disabled = true;
                confirmBtn.innerHTML = 'No Valid Questions to Import';
            } else {
                confirmBtn.disabled = false;
                confirmBtn.innerHTML = `<i class="material-icons text-sm mr-1">save</i>Import ${valid} Valid Question(s)`;
            }
        }

        function showDeleteModal() {
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function hideDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
            currentDeleteId = null;
        }

        function showToast(message, type) {
            window.showAppToast(message, type || 'info');
        }
    </script>
}
