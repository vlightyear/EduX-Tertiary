@{
    ViewData["Title"] = "Submit Academic Request";
}

<!-- Work in Progress Banner -->
<div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
    <div class="flex items-center">
        <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
            </svg>
        </div>
        <div class="ml-3">
            <p class="text-sm text-yellow-700">
                <span class="font-medium">Work in Progress!</span> This feature is currently under development. Some functionality may be limited.
            </p>
        </div>
    </div>
</div>

<div class="container mx-auto px-4 max-w-5xl">
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <!-- Header -->
        <div class="p-6 bg-[#0082bb]/5 border-b border-gray-200">
            <h2 class="text-2xl font-bold text-secondary-800">Submit Academic Request</h2>
            <p class="mt-1 text-sm text-secondary-600">Use this form to submit various academic-related requests</p>
        </div>

        <div class="p-6">
            <form asp-action="SubmitRequest" method="post">
                <input type="hidden" name="studentId" value="@Model.Id" />

                <!-- Request Type Selection -->
                <div class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="requestType" class="block text-sm font-medium text-gray-700 mb-2">Request Type</label>
                            <select name="requestType" id="requestType"
                                    class="w-full rounded-lg border-gray-300 focus:border-[#0082bb] focus:ring focus:ring-[#0082bb]/20 transition-colors text-secondary-600">
                                <option disabled selected>Select Request Type</option>
                                <option value="Withdrawal">Withdrawal</option>
                                <option value="Programme Change">Change of Programme</option>
                                <option value="Exemption">Exemption</option>
                            </select>
                        </div>
                    </div>

                    <!-- Programme Change Fields -->
                    <div id="changeProgramFields" class="hidden space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="school" class="block text-sm font-medium text-gray-700 mb-2">Select School</label>
                                <select id="school" name="schoolId"
                                        class="w-full rounded-lg border-gray-300 focus:border-[#0082bb] focus:ring focus:ring-[#0082bb]/20 transition-colors text-secondary-600">
                                    <option value="">Select a School</option>
                                </select>
                            </div>
                            <div>
                                <label for="program" class="block text-sm font-medium text-gray-700 mb-2">Select Program</label>
                                <select id="program" name="programId"
                                        class="w-full rounded-lg border-gray-300 focus:border-[#0082bb] focus:ring focus:ring-[#0082bb]/20 transition-colors text-secondary-600" disabled>
                                    <option value="">Select a Program</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Description -->
                    <div>
                        <label for="description" class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                        <textarea name="description" rows="4"
                                  class="w-full rounded-lg border-gray-300 focus:border-[#0082bb] focus:ring focus:ring-[#0082bb]/20 transition-colors text-secondary-600"
                                  placeholder="Please provide details about your request..."></textarea>
                    </div>

                    <!-- Submit Button -->
                    <div class="flex justify-end">
                        <button type="submit"
                                class="px-6 py-2 bg-[#0082bb] text-white rounded-lg hover:bg-[#0082bb]/90 transition-colors flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L10.586 9H7a1 1 0 100 2h3.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" clip-rule="evenodd" />
                            </svg>
                            Submit Request
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Coming Soon Features -->
    <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <div class="flex items-center justify-center h-12 w-12 rounded-full bg-blue-100 mb-4">
                <svg class="h-6 w-6 text-[#0082bb]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
                </svg>
            </div>
            <h3 class="text-lg font-semibold text-secondary-800 mb-2">Request Tracking</h3>
            <p class="text-secondary-600 text-sm">Track your request status in real-time</p>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mt-4">Coming Soon!</span>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <div class="flex items-center justify-center h-12 w-12 rounded-full bg-purple-100 mb-4">
                <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
            <h3 class="text-lg font-semibold text-secondary-800 mb-2">Schedule Appointments</h3>
            <p class="text-secondary-600 text-sm">Schedule meetings with academic advisors</p>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 mt-4">Coming Soon!</span>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <div class="flex items-center justify-center h-12 w-12 rounded-full bg-green-100 mb-4">
                <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h3 class="text-lg font-semibold text-secondary-800 mb-2">Auto-Approvals</h3>
            <p class="text-secondary-600 text-sm">Instant approvals for eligible requests</p>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 mt-4">Coming Soon!</span>
        </div>
    </div>
</div>



@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}

@section Scripts {
    <script>
        $(document).on("change", "#requestType", function () {
            const requestType = $(this).val();
            const changeProgramFields = $("#changeProgramFields");
            const schoolDropdown = $('#school');
            const programDropdown = $('#program');

            if (requestType === "ProgramChange") {
                changeProgramFields.show();
                schoolDropdown.prop('disabled', false).prop('required', true);  // Enable and set required
                loadSchools();  // Load schools dynamically
            } else {
                changeProgramFields.hide();
                schoolDropdown.prop('disabled', true).prop('required', false); // Disable and remove required
                programDropdown.prop('disabled', true).prop('required', false); // Disable and remove required from program
            }
        });

        // Function to load schools dynamically via AJAX
        function loadSchools() {
            $.ajax({
                url: '/AcademicRequest/GetSchools', // Replace with your endpoint
                method: 'GET',
                success: function (response) {
                    if (response.success) {
                        const schoolDropdown = $('#school');
                        schoolDropdown.empty(); // Clear existing options
                        schoolDropdown.append($('<option>', {
                            text: 'Select School',
                            value: '',
                            disabled: true,
                            selected: true
                        }));
                        response.schools.forEach(function (school) {
                            schoolDropdown.append($('<option>', {
                                text: school.name,  // Displayed name
                                value: school.id    // Value of the option
                            }));
                        });

                        // Bind the change event to populate programs
                        schoolDropdown.on('change', function () {
                            const schoolId = $(this).val();
                            if (schoolId) {
                                loadPrograms(schoolId); // Populate programs
                            } else {
                                $('#program').empty().append('<option value="">Select Program</option>').prop('disabled', true).prop('required', false); // Disable the program dropdown if no school selected
                            }
                        });
                    } else {
                        Swal.fire('Error', 'Failed to load schools.', 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'Failed to load schools.', 'error');
                }
            });
        }

        // Function to load programs dynamically based on the selected school
        function loadPrograms(schoolId) {
            $.ajax({
                url: '/AcademicRequest/GetProgramsBySchool',  // Replace with your endpoint
                method: 'GET',
                data: { schoolId: schoolId },
                success: function (response) {
                    const programDropdown = $('#program');
                    programDropdown.empty(); // Clear existing options
                    programDropdown.append($('<option>', {
                        text: 'Select Program',
                        value: '',
                        disabled: true,
                        selected: true
                    }));

                    if (response.success) {
                        if (response.programs.length > 0) {
                            response.programs.forEach(function (program) {
                                programDropdown.append(new Option(program.name, program.id));
                            });
                            programDropdown.prop('disabled', false).prop('required', true); // Enable and set required when programs are loaded
                        } else {
                            programDropdown.append(new Option("No programs available", ""));
                            programDropdown.prop('disabled', true).prop('required', false); // Disable if no programs available
                        }
                    } else {
                        Swal.fire('Error', 'Failed to load programs.', 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'Failed to load programs for the selected school.', 'error');
                }
            });
        }

    </script>
}
<style>
    .form-select {
        border-radius: .375rem; /* Round the corners of the select */
        height: calc(2.25rem + 2px); /* Slightly increase height for better touch experience */
    }

        .form-select:focus {
            border-color: #007bff; /* Change border color when focused */
            box-shadow: 0 0 0 0.2rem rgba(38, 143, 255, 0.25); /* Add a light shadow on focus */
        }
</style>

