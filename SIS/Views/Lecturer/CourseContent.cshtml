<!-- Delete Chapter Modal -->
<div id="deleteChapterModal" class="hidden fixed inset-0 bg-gray-500 bg-opacity-75 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Confirm Delete Chapter</h3>
        <p class="text-sm text-gray-500 mb-4">Are you sure you want to delete this chapter? This won't delete the content inside the chapter, but will move it to "Uncategorized Content".</p>
        <div class="flex justify-end gap-3">
            <button type="button" onclick="closeModal('deleteChapterModal')" class="px-4 py-2 bg-gray-200 text-secondary-800 rounded-lg hover:bg-gray-300">
                Cancel
            </button>
            <button type="button" onclick="deleteChapter()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
                Delete
            </button>
        </div>
    </div>
</div>

<!-- Success/Error Toast Notification -->
<div id="toastNotification" class="hidden fixed bottom-4 right-4 p-4 rounded-lg shadow-lg max-w-xs z-50">
    <div class="flex items-center">
        <i id="toastIcon" class="material-icons mr-2"></i>
        <p id="toastMessage"></p>
    </div>
</div>





@section Scripts {
    <script>
        function searchContent() {
            const searchInput = document.getElementById('contentSearch');
            const filter = searchInput.value.toUpperCase();
            const contentRows = document.querySelectorAll('.content-row');

            contentRows.forEach(row => {
                const rowText = row.textContent || row.innerText;
                if (rowText.toUpperCase().indexOf(filter) > -1) {
                    row.style.display = '';
                    // Make parent chapter visible
                    const chapterSection = row.closest('[id^="chapter-"]');
                    if (chapterSection) {
                        chapterSection.style.display = 'block';
                    }
                } else {
                    row.style.display = 'none';
                }
            });
        }

        function toggleSection(id) {
            const section = document.getElementById(id);
            const icon = document.getElementById(id + '-icon');

            if (section.style.display === 'none') {
                section.style.display = 'block';
                icon.classList.remove('rotate-180');
            } else {
                section.style.display = 'none';
                icon.classList.add('rotate-180');
            }
        }

        function confirmDelete(id) {
            document.getElementById('deleteContentId').value = id;
            document.getElementById('deleteForm').action = '@Url.Action("DeleteContent", "Lecturer")';
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        // Initialize all sections as expanded
        document.addEventListener('DOMContentLoaded', function() {
            // Expand all sections by default
            const sections = document.querySelectorAll('[id^="chapter-"], #uncategorized-content');
            sections.forEach(section => {
                section.style.display = 'block';
            });
        });





        // Chapter CRUD functions
        function openAddChapterModal() {
            document.getElementById('addChapterModal').classList.remove('hidden');
            document.getElementById('addChapterTitle').focus();
    
            // Set default order as highest order + 1
            const chapters = document.querySelectorAll('[id^="chapter-"]:not([id$="-icon"])');
            let maxOrder = 0;
    
            if (chapters.length > 0) {
                chapters.forEach(chapter => {
                    const chapterId = chapter.id.replace('chapter-', '');
                    const orderElement = document.querySelector(`[data-chapter-order="${chapterId}"]`);
                    if (orderElement) {
                        const order = parseInt(orderElement.value || '0');
                        maxOrder = Math.max(maxOrder, order);
                    }
                });
            }
    
            document.getElementById('addChapterOrder').value = maxOrder + 1;
        }

        function openEditChapterModal(chapterId) {
            // Prevent event propagation to avoid toggling the chapter
            event.stopPropagation();
    
            // Get chapter data via AJAX
            fetch(`/Lecturer/GetChapter/${chapterId}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    // Populate form
                    document.getElementById('editChapterId').value = data.id;
                    document.getElementById('editChapterCourseId').value = data.courseId;
                    document.getElementById('editChapterTitle').value = data.title;
                    document.getElementById('editChapterDescription').value = data.description || '';
                    document.getElementById('editChapterOrder').value = data.orderIndex;
                    document.getElementById('editChapterIsActive').checked = data.isActive;
            
                    // Show modal
                    document.getElementById('editChapterModal').classList.remove('hidden');
                    document.getElementById('editChapterTitle').focus();
                })
                .catch(error => {
                    showToast('Error loading chapter data. Please try again.', 'error');
                    console.error('Error fetching chapter:', error);
                });
        }

                function confirmDeleteChapter(chapterId) {
            // Prevent event propagation to avoid toggling the chapter
            event.stopPropagation();

            // Store the chapter ID for deletion
            window.chapterToDelete = chapterId;

            // Show confirmation modal
            document.getElementById('deleteChapterModal').classList.remove('hidden');
        }

                function deleteChapter() {
            const chapterId = window.chapterToDelete;
            if (!chapterId) return;

            // Send delete request via AJAX
            fetch(`/Lecturer/DeleteChapter/${chapterId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    // Show success message
                    showToast('Chapter deleted successfully', 'success');

                    // Reload the page after a short delay (to allow the toast to be seen)
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000); // 1-second delay
                } else {
                    showToast(data.message || 'Failed to delete chapter', 'error');
                    closeModal('deleteChapterModal');
                }
            })
            .catch(error => {
                console.error("Error in deleteChapter:", error);
                showToast('Error deleting chapter. Please try again.', 'error');
                closeModal('deleteChapterModal');
            });
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('hidden');
        }

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toastNotification');
            const toastMessage = document.getElementById('toastMessage');
            const toastIcon = document.getElementById('toastIcon');
    
            // Set message
            toastMessage.textContent = message;
    
            // Set colors and icon based on type
            if (type === 'error') {
                toast.className = 'fixed bottom-4 right-4 p-4 rounded-lg shadow-lg max-w-xs z-50 bg-red-100 text-red-800';
                toastIcon.textContent = 'error';
                toastIcon.className = 'material-icons mr-2 text-red-500';
            } else {
                toast.className = 'fixed bottom-4 right-4 p-4 rounded-lg shadow-lg max-w-xs z-50 bg-green-100 text-green-800';
                toastIcon.textContent = 'check_circle';
                toastIcon.className = 'material-icons mr-2 text-green-500';
            }
    
            // Show toast
            toast.classList.remove('hidden');
    
            // Hide after 3 seconds
            setTimeout(() => {
                toast.classList.add('hidden');
            }, 5000);
        }

        // Initialize forms with AJAX submission
        document.addEventListener('DOMContentLoaded', function() {
            // Add Chapter Form
        const addChapterForm = document.getElementById('addChapterForm');
            if (addChapterForm) {
                addChapterForm.addEventListener('submit', function(e) {
                    e.preventDefault();

                    // Create data object directly (instead of using FormData)
                    const chapterData = {
                        CourseId: document.getElementById('addChapterCourseId').value,
                        Title: document.getElementById('addChapterTitle').value,
                        Description: document.getElementById('addChapterDescription').value,
                        OrderIndex: parseInt(document.getElementById('addChapterOrder').value),
                        CreatedAt: new Date().toISOString()
                    };

                    console.log("Sending data:", JSON.stringify(chapterData));

                    fetch('/Lecturer/CreateChapter', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(chapterData)
                    })
                    .then(response => response.json())
                    .then(data => {
                        console.log("Response:", data);
                        if (data.success) {
                            window.location.reload();
                        } else {
                            showToast(data.message || 'Failed to create chapter', 'error');
                        }
                    })
                    .catch(error => {
                        console.error("Error:", error);
                        showToast('Error creating chapter. Please try again.', 'error');
                    });
                });
            }
    
            // Edit Chapter Form
            const editChapterForm = document.getElementById('editChapterForm');
            if (editChapterForm) {
                editChapterForm.addEventListener('submit', function(e) {
                    e.preventDefault();
            
                    const formData = new FormData(editChapterForm);
                    const chapterData = {};
            
                    formData.forEach((value, key) => {
                        if (key === 'IsActive') {
                            chapterData[key] = true; // Checkbox is checked
                        } else {
                            chapterData[key] = value;
                        }
                    });
            
                    // Handle unchecked checkbox (not included in FormData)
                    if (!formData.has('IsActive')) {
                        chapterData['IsActive'] = false;
                    }
            
                    // Add UpdatedAt and UpdatedBy fields
                    chapterData.UpdatedAt = new Date().toISOString();
            
                    fetch('/Lecturer/UpdateChapter', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(chapterData)
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            // Reload page to show updated chapter
                            window.location.reload();
                        } else {
                            showToast(data.message || 'Failed to update chapter', 'error');
                        }
                    })
                    .catch(error => {
                        showToast('Error updating chapter. Please try again.', 'error');
                        console.error('Error updating chapter:', error);
                    });
                });
            }
        });
    </script>
}