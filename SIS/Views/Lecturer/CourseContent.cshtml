            <div>
                <label for="addChapterTitle" class="block text-sm font-medium text-gray-700">Chapter Title</label>
                <input type="text" id="addChapterTitle" name="Title" required
                       class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 sm:text-sm" />
            </div>
            <div>
                <label for="addChapterDescription" class="block text-sm font-medium text-gray-700">Description (Optional)</label>
