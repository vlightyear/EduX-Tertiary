    <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-medium text-gray-900">Edit Chapter</h3>
            <button type="button" onclick="closeModal('editChapterModal')" class="text-gray-400 hover:text-gray-500">
                <i class="material-icons">close</i>
            </button>
        </div>
        <form id="editChapterForm" class="space-y-4">
            <input type="hidden" id="editChapterId" name="Id" />
            <input type="hidden" id="editChapterCourseId" name="CourseId" />
            <div>
                <label for="editChapterTitle" class="block text-sm font-medium text-gray-700">Chapter Title</label>
                <input type="text" id="editChapterTitle" name="Title" required
                       class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 sm:text-sm" />
            </div>
            <div>
                <label for="editChapterDescription" class="block text-sm font-medium text-gray-700">Description (Optional)</label>
                <textarea id="editChapterDescription" name="Description" rows="3"
                          class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 sm:text-sm"></textarea>
            </div>
            <div>
                <label for="editChapterOrder" class="block text-sm font-medium text-gray-700">Order</label>
                <input type="number" id="editChapterOrder" name="OrderIndex" min="1"
                       class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-cyan-500 focus:ring-cyan-500 sm:text-sm" />
            </div>
            <div class="flex items-center">
                <input type="checkbox" id="editChapterIsActive" name="IsActive" class="h-4 w-4 rounded border-gray-300 text-cyan-600 focus:ring-cyan-500" />
                <label for="editChapterIsActive" class="ml-2 block text-sm text-gray-700">Active</label>
            </div>
            <div class="flex justify-end gap-3 pt-4">
