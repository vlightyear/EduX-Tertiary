@model SIS.Models.Lecturer.CourseContent

<div class="min-h-screen bg-slate-50 p-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-center h-24 mb-4">
        <div class="flex items-center text-slate-800">
            <i class="material-icons text-3xl mr-2">upload_file</i>
            <div>
                <h1 class="text-2xl font-bold">Upload Course Content</h1>
                <p class="text-sm text-slate-600">@ViewBag.Course.CourseCode - @ViewBag.Course.CourseName</p>
            </div>
        </div>
        <div class="mt-4 md:mt-0">
            <a asp-controller="Lecturer" asp-action="CourseContent" asp-route-id="@Model.CourseId"
               class="inline-flex items-center px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-100 transition-colors">
                <i class="material-icons text-sm mr-1">arrow_back</i>
                <span>Back to Content</span>
            </a>
        </div>
    </div>

    <!-- Main Content Card -->
    <div class="bg-white rounded-xl shadow-sm">
        <div class="p-6">
            <form asp-action="UploadContent" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>
                <input type="hidden" asp-for="CourseId" />

                <!-- Tab Navigation -->
                <div class="mb-6 border-b border-slate-200">
                    <ul class="flex flex-wrap -mb-px" id="contentTabs" role="tablist">
                        <li class="mr-2" role="presentation">
                            <button type="button"
                                    class="inline-block py-3 px-5 border-b-2 border-cyan-600 rounded-t-lg active text-cyan-600"
                                    id="file-tab"
                                    data-tab="file-content"
                                    onclick="showTab('file-content')"
                                    role="tab"
                                    aria-selected="true">
                                <i class="material-icons align-middle mr-1">attach_file</i>
                                Upload File
                            </button>
                        </li>
                        <li class="mr-2" role="presentation">
                            <button type="button"
                                    class="inline-block py-3 px-5 border-b-2 border-transparent rounded-t-lg hover:border-slate-300 text-slate-600 hover:text-slate-800"
                                    id="link-tab"
                                    data-tab="link-content"
                                    onclick="showTab('link-content')"
                                    role="tab"
                                    aria-selected="false">
                                <i class="material-icons align-middle mr-1">link</i>
                                Add Link
                            </button>
                        </li>
                    </ul>
                </div>

                <!-- Tab Content -->
                <div class="tab-content">
                    <!-- File Upload Tab -->
                    <div id="file-content" class="tab-pane active">
                        <div class="mb-6">
                            <div class="border-2 border-dashed border-slate-300 rounded-lg p-6 text-center" id="dropArea">
                                <input type="file" asp-for="UploadFile" id="fileInput" class="hidden" />
                                <label for="fileInput" class="cursor-pointer">
                                    <i class="material-icons text-5xl text-slate-400 mb-2">cloud_upload</i>
                                    <h3 class="text-lg font-medium text-slate-700 mb-1">Drag and drop your file here</h3>
                                    <p class="text-sm text-slate-500 mb-4">or click to browse</p>
                                    <span class="inline-flex items-center px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                                        <i class="material-icons text-sm mr-1">upload_file</i>
                                        <span>Select File</span>
                                    </span>
                                </label>
                                <p id="selectedFile" class="mt-4 text-slate-700 hidden">
                                    Selected: <span class="font-medium"></span>
                                </p>
                            </div>
                            <span asp-validation-for="UploadFile" class="text-red-500 text-xs"></span>
                        </div>
                    </div>

                    <!-- Link Tab -->
                    <div id="link-content" class="tab-pane hidden">
                        <div class="mb-6">
                            <label asp-for="FilePath" class="block text-sm font-medium text-slate-700 mb-1">URL / Web Link</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                    <i class="material-icons text-slate-400 text-sm">link</i>
                                </div>
                                <input type="url" asp-for="FilePath" class="block w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500" placeholder="https://example.com/resource" />
                            </div>
                            <span asp-validation-for="FilePath" class="text-red-500 text-xs"></span>
                            <p class="text-xs text-slate-500 mt-1">Enter a valid URL starting with http:// or https://</p>
                        </div>
                    </div>

                    <!-- Common Fields for Both Tabs -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label asp-for="Title" class="block text-sm font-medium text-slate-700 mb-1">Title*</label>
                            <input type="text" asp-for="Title" class="block w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500" required />
                            <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="ContentCategory" class="block text-sm font-medium text-slate-700 mb-1">Category</label>
                            <select asp-for="ContentCategory" class="block w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500">
                                @foreach (var category in ViewBag.ContentCategories)
                                {
                                    <option value="@category">@category</option>
                                }
                            </select>
                            <span asp-validation-for="ContentCategory" class="text-red-500 text-xs"></span>
                        </div>
                    </div>

                    <!-- Chapter Selection - Add this as a new row after the grid above -->
                    <div class="mb-6">
                        <label asp-for="ChapterId" class="block text-sm font-medium text-slate-700 mb-1">Chapter</label>
                        <select asp-for="ChapterId" class="block w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500">
                            <option value="">-- Uncategorized --</option>
                            @if (ViewBag.Chapters != null)
                            {
                                foreach (var chapter in ViewBag.Chapters)
                                {
                                    <option value="@chapter.Id">@chapter.Title</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="ChapterId" class="text-red-500 text-xs"></span>
                        <p class="text-xs text-slate-500 mt-1">Select a chapter to organize this content, or leave as "Uncategorized"</p>
                    </div>



                    <div class="mb-6">
                        <label asp-for="Description" class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                        <textarea asp-for="Description" rows="4" class="block w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-cyan-500 focus:border-cyan-500"></textarea>
                        <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
                    </div>

                    <div class="flex justify-end gap-3">
                        <a asp-controller="Course" asp-action="CourseContent" asp-route-id="@Model.CourseId"
                           class="inline-flex items-center px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-100 transition-colors">
                            Cancel
                        </a>
                        <button type="submit" class="inline-flex items-center px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
                            <i class="material-icons text-sm mr-1">save</i>
                            <span>Upload Content</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tab switching functionality
        function showTab(tabId) {
            // Hide all tab panes
            document.querySelectorAll('.tab-pane').forEach(pane => {
                pane.classList.add('hidden');
                pane.classList.remove('active');
            });

            // Deactivate all tabs
            document.querySelectorAll('[data-tab]').forEach(tab => {
                tab.classList.remove('border-cyan-600', 'text-cyan-600');
                tab.classList.add('border-transparent', 'text-slate-600');
                tab.setAttribute('aria-selected', 'false');
            });

            // Show selected tab pane
            const selectedPane = document.getElementById(tabId);
            selectedPane.classList.remove('hidden');
            selectedPane.classList.add('active');

            // Activate selected tab
            const selectedTab = document.querySelector(`[data-tab="${tabId}"]`);
            selectedTab.classList.remove('border-transparent', 'text-slate-600');
            selectedTab.classList.add('border-cyan-600', 'text-cyan-600');
            selectedTab.setAttribute('aria-selected', 'true');
        }

        // File upload functionality
        document.addEventListener('DOMContentLoaded', function() {
            const dropArea = document.getElementById('dropArea');
            const fileInput = document.getElementById('fileInput');
            const selectedFile = document.getElementById('selectedFile');

            // Prevent default drag behaviors
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropArea.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            // Highlight drop area when item is dragged over it
            ['dragenter', 'dragover'].forEach(eventName => {
                dropArea.addEventListener(eventName, highlight, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropArea.addEventListener(eventName, unhighlight, false);
            });

            function highlight() {
                dropArea.classList.add('border-cyan-500', 'bg-cyan-50');
            }

            function unhighlight() {
                dropArea.classList.remove('border-cyan-500', 'bg-cyan-50');
            }

            // Handle dropped files
            dropArea.addEventListener('drop', handleDrop, false);

            function handleDrop(e) {
                const dt = e.dataTransfer;
                const files = dt.files;
                fileInput.files = files;
                updateFileInfo();
            }

            // Update file info when selected via input
            fileInput.addEventListener('change', updateFileInfo);

            function updateFileInfo() {
                if (fileInput.files.length > 0) {
                    const fileName = fileInput.files[0].name;
                    selectedFile.querySelector('span').textContent = fileName;
                    selectedFile.classList.remove('hidden');
                    dropArea.classList.add('border-green-500');
                } else {
                    selectedFile.classList.add('hidden');
                    dropArea.classList.remove('border-green-500');
                }
            }
        });
    </script>
}