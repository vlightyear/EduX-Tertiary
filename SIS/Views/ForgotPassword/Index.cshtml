@inject SIS.Services.IInstitutionConfigService InstitutionConfig

@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
    var institution = InstitutionConfig.GetCurrentInstitution();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password Recovery - AcademiX</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                fontFamily: {
                    sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
                },
                extend: {
                    colors: {
                        primary: {
                            50:  '#fef2f2',
                            100: '#fee2e2',
                            200: '#fecaca',
                            300: '#fca5a5',
                            400: '#f87171',
                            500: '#ef4444',
                            600: '#e85c5c',
                            700: '#c53030',
                            800: '#9b2c2c',
                            900: '#7f1d1d',
                            950: '#450a0a'
                        },
                        secondary: {
                            50:  '#f8fafc',
                            100: '#f1f5f9',
                            200: '#e2e8f0',
                            300: '#cbd5e1',
                            400: '#94a3b8',
                            500: '#64748b',
                            600: '#475569',
                            700: '#334155',
                            800: '#1e293b',
                            900: '#0f172a',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #f0f4f8; }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0);    }
        }
        .fade-up   { animation: fadeUp 0.45s ease forwards; }
        .fade-up-1 { animation-delay: 0.08s; opacity: 0; }
        .fade-up-2 { animation-delay: 0.16s; opacity: 0; }
        .fade-up-3 { animation-delay: 0.24s; opacity: 0; }
        .fade-up-4 { animation-delay: 0.32s; opacity: 0; }

        .loader {
            border: 3px solid rgba(232, 92, 92, 0.2);
            border-top: 3px solid #e85c5c;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            animation: spin 0.9s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        @@keyframes spin-slow {
            to { transform: rotate(360deg); }
        }
        .animate-spin-slow { animation: spin-slow 1s linear infinite; }
    </style>
</head>
<body class="font-sans min-h-screen" style="background-color: #f0f4f8;">
    @Html.AntiForgeryToken()

    <!-- Loader -->
    <div id="loader" class="fixed inset-0 flex items-center justify-center bg-white z-50 transition-opacity duration-500">
        <div class="flex flex-col items-center gap-3">
            <div class="loader"></div>
            <p class="text-sm text-slate-400 font-medium">Loading AcademiX...</p>
        </div>
    </div>

    <!-- Split Layout -->
    <div class="min-h-screen flex">

        <!-- ── Left Panel: Branding ── -->
        <div class="hidden lg:flex lg:w-1/2 xl:w-3/5 relative flex-col items-center justify-center overflow-hidden bg-secondary-900">
            <div class="absolute inset-0 bg-cover bg-center opacity-15" style="background-image: url('/images/campus.jpg');"></div>
            <div class="absolute inset-0" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);"></div>
            <div class="absolute -top-32 -left-32 w-96 h-96 rounded-full blur-3xl opacity-30" style="background-color: #e85c5c;"></div>
            <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full blur-3xl opacity-20" style="background-color: #e85c5c;"></div>

            <div class="relative z-10 text-center px-12 max-w-lg">
                <div class="w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-white/10 shadow-xl"
                     style="background-color: rgba(232,92,92,0.15);">
                    <i class="material-icons text-white text-4xl">lock_reset</i>
                </div>
                <h1 class="text-4xl font-bold text-white mb-2">
                    Password <span style="color: #e85c5c;">Recovery</span>
                </h1>
                <p class="text-slate-400 text-sm mb-10">Reset your account access securely</p>

                <div class="space-y-3 text-left">
                    @foreach (var item in new[] {
                        ("mark_email_read", "Check Your Email",     "A temporary password will be sent to your inbox"),
                        ("lock_open",       "Regain Access",        "Use the temporary password to sign back in"),
                        ("manage_accounts", "Update Credentials",   "Change your password after your first login")
                    })
                    {
                        <div class="flex items-start gap-4 bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-4">
                            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0"
                                 style="background-color: rgba(232,92,92,0.2);">
                                <i class="material-icons text-sm" style="color: #e85c5c;">@item.Item1</i>
                            </div>
                            <div>
                                <p class="text-white font-semibold text-sm">@item.Item2</p>
                                <p class="text-slate-400 text-xs mt-0.5">@item.Item3</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ── Right Panel: Form ── -->
        <div class="w-full lg:w-1/2 xl:w-2/5 flex flex-col items-center justify-center px-6 py-12 bg-white shadow-xl">
            <div class="w-full max-w-sm">

                <!-- Institution Header -->
                <div class="fade-up fade-up-1 flex flex-col items-center mb-8">
                    <div class="w-16 h-16 rounded-xl flex items-center justify-center mb-4 shadow-lg"
                         style="background-color: #1e293b;">
                        <img src="@($"{institution.ContactInfo?.Website?.TrimEnd('/')}{institution.LogoPath}")"
                             alt="@institution.Name"
                             class="h-10 w-10 object-contain"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <i class="material-icons text-white text-2xl hidden">account_balance</i>
                    </div>
                    <h2 class="text-lg font-bold text-gray-900 text-center leading-tight">@institution.Name</h2>
                    <p class="text-sm text-gray-500 mt-1">Password Recovery</p>
                </div>

                <!-- Security Notice -->
                <div class="fade-up fade-up-2 rounded-lg p-4 mb-6 border text-sm"
                     style="background-color: #fef2f2; border-color: #fecaca;">
                    <div class="flex items-center gap-2 mb-2">
                        <i class="material-icons text-sm" style="color: #e85c5c;">security</i>
                        <span class="font-semibold text-sm" style="color: #9b2c2c;">Security Notice</span>
                    </div>
                    <ul class="space-y-1 text-xs" style="color: #c53030;">
                        <li class="flex items-start gap-1"><i class="material-icons text-xs mt-0.5">chevron_right</i> A secure password will be generated and sent to your email</li>
                        <li class="flex items-start gap-1"><i class="material-icons text-xs mt-0.5">chevron_right</i> All existing sessions will be logged out for security</li>
                        <li class="flex items-start gap-1"><i class="material-icons text-xs mt-0.5">chevron_right</i> Change the temporary password after logging in</li>
                    </ul>
                </div>

                <!-- Form -->
                <form id="forgotPasswordForm" class="space-y-6">

                    <!-- Email — floating label matching login page -->
                    <div class="fade-up fade-up-3 relative z-0 w-full group">
                        <input type="email"
                               id="email"
                               name="Email"
                               required
                               autocomplete="email"
                               class="block py-2.5 px-0 w-full text-sm text-gray-900 bg-transparent border-0 border-b-2 border-gray-300 appearance-none focus:outline-none focus:ring-0 peer"
                               onfocus="this.style.borderBottomColor='#e85c5c'"
                               onblur="this.style.borderBottomColor=''"
                               placeholder=" " />
                        <label for="email"
                               class="peer-focus:font-medium absolute text-sm text-gray-500 duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0] peer-focus:start-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6">
                            Email Address
                        </label>
                        <span class="mt-1 text-xs text-red-500" id="emailError"></span>
                    </div>

                    <!-- Submit -->
                    <div class="fade-up fade-up-4 space-y-3">
                        <button type="submit"
                                id="submitBtn"
                                class="w-full flex justify-center items-center gap-2 py-2.5 px-4 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
                                style="background-color: #e85c5c;"
                                onmouseenter="if(!this.disabled) this.style.backgroundColor='#c53030'"
                                onmouseleave="if(!this.disabled) this.style.backgroundColor='#e85c5c'">
                            <i class="material-icons text-sm hidden animate-spin-slow" id="loadingIcon">refresh</i>
                            <span id="submitText">Reset Password</span>
                            <i class="material-icons text-sm" id="submitIcon">send</i>
                        </button>

                        <p class="text-xs text-center text-gray-500">
                            Remember your password?
                            <a href="/Account/Login"
                               class="font-semibold transition-colors"
                               style="color: #e85c5c;"
                               onmouseenter="this.style.color='#c53030'" onmouseleave="this.style.color='#e85c5c'">
                                Back to Login
                            </a>
                        </p>
                    </div>
                </form>

                <!-- Help Section -->
                <div class="fade-up fade-up-4 mt-8 p-4 rounded-lg border border-gray-200 bg-gray-50">
                    <h4 class="text-xs font-semibold text-gray-700 mb-2 flex items-center gap-1">
                        <i class="material-icons text-sm" style="color: #e85c5c;">help_outline</i>
                        Need Help?
                    </h4>
                    <p class="text-xs text-gray-500 mb-2">Contact support if you don't receive the email:</p>
                    <div class="space-y-1 text-xs text-gray-600">
                        <p class="flex items-center gap-1">
                            <i class="material-icons text-xs text-gray-400">email</i>
                            @institution.EmailSettings.SenderEmail
                        </p>
                        <p class="flex items-center gap-1">
                            <i class="material-icons text-xs text-gray-400">phone</i>
                            @(institution.ContactInfo?.Phone ?? "+260-XXX-XXXX")
                            <span class="text-gray-400">(Mon–Fri, 8AM–5PM)</span>
                        </p>
                    </div>
                </div>

                <p class="fade-up fade-up-4 text-center text-xs text-gray-400 mt-6">
                    &copy; @DateTime.Now.Year @institution.Name. All rights reserved.
                </p>
            </div>
        </div>
    </div>

    <!-- Result Modal -->
    <div id="resultModal" class="hidden fixed inset-0 z-50">
        <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity backdrop-blur-sm"></div>
        <div class="fixed inset-0 z-10 overflow-y-auto">
            <div class="flex min-h-full items-center justify-center p-4">
                <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-md border border-gray-200">
                    <!-- Modal Header -->
                    <div id="modalHeader" class="px-6 py-4 rounded-t-xl flex items-center justify-between border-b">
                        <h3 class="text-lg font-semibold flex items-center">
                            <i class="material-icons mr-2" id="modalIcon"></i>
                            <span id="modalTitleText"></span>
                        </h3>
                        <button type="button" onclick="closeResultModal()" class="text-gray-400 hover:text-gray-500 transition-colors">
                            <i class="material-icons">close</i>
                        </button>
                    </div>
                    <!-- Modal Body -->
                    <div class="p-6">
                        <p class="text-gray-700 text-sm" id="modalMessage"></p>
                    </div>
                    <!-- Modal Footer -->
                    <div class="bg-gray-50 px-6 py-4 rounded-b-xl flex justify-end gap-2">
                        <button type="button"
                                onclick="closeResultModal()"
                                class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors flex items-center text-sm">
                            <i class="material-icons text-sm mr-1">close</i>Close
                        </button>
                        <a href="/Account/Login"
                           id="loginLink"
                           class="hidden px-4 py-2 text-white rounded-lg transition-colors flex items-center text-sm font-semibold"
                           style="background-color: #e85c5c;"
                           onmouseenter="this.style.backgroundColor='#c53030'" onmouseleave="this.style.backgroundColor='#e85c5c'">
                            <i class="material-icons text-sm mr-1">login</i>Go to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Hide loader
        window.addEventListener('load', function () {
            const loader = document.getElementById('loader');
            loader.style.opacity = '0';
            setTimeout(() => loader.style.display = 'none', 500);
        });

        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('email').focus();

            const form       = document.getElementById('forgotPasswordForm');
            const submitBtn  = document.getElementById('submitBtn');
            const loadingIcon = document.getElementById('loadingIcon');
            const submitText = document.getElementById('submitText');
            const submitIcon = document.getElementById('submitIcon');
            const emailInput = document.getElementById('email');

            function isValidEmail(email) {
                const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                return emailRegex.test(email);
            }

            function setLoadingState(loading) {
                submitBtn.disabled = loading;
                loadingIcon.classList.toggle('hidden', !loading);
                submitIcon.classList.toggle('hidden', loading);
                submitText.textContent = loading ? 'Resetting Password...' : 'Reset Password';
            }

            // Real-time validation
            emailInput.addEventListener('input', function () {
                const valid = !this.value.trim() || isValidEmail(this.value.trim());
                document.getElementById('emailError').textContent = valid ? '' : 'Please enter a valid email address';
            });

            // Form submit
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                const email = emailInput.value.trim();

                if (!email)               { showResultModal('error', 'Error', 'Please enter your email address.'); return; }
                if (!isValidEmail(email)) { showResultModal('error', 'Error', 'Please enter a valid email address.'); return; }

                setLoadingState(true);
                try {
                    const response = await fetch('/ForgotPassword/ResetPassword', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify({ Email: email })
                    });
                    const result = await response.json();
                    if (result.success) {
                        showResultModal('success', 'Password Reset Successful!', result.message, true);
                        form.reset();
                    } else {
                        showResultModal('error', 'Password Reset Failed', result.message);
                    }
                } catch (error) {
                    showResultModal('error', 'Connection Error', 'Unable to connect to the server. Please check your connection and try again.');
                } finally {
                    setLoadingState(false);
                }
            });

            // Modal helpers
            window.showResultModal = function (type, title, message, showLogin = false) {
                const header     = document.getElementById('modalHeader');
                const icon       = document.getElementById('modalIcon');
                const titleEl    = document.getElementById('modalTitleText');
                const messageEl  = document.getElementById('modalMessage');
                const loginLink  = document.getElementById('loginLink');

                if (type === 'success') {
                    header.className   = 'px-6 py-4 rounded-t-xl flex items-center justify-between border-b bg-green-50 border-green-200';
                    icon.className     = 'material-icons mr-2 text-green-600';
                    icon.textContent   = 'check_circle';
                    titleEl.className  = 'text-green-800 font-semibold';
                } else {
                    header.className   = 'px-6 py-4 rounded-t-xl flex items-center justify-between border-b bg-red-50 border-red-200';
                    icon.className     = 'material-icons mr-2 text-red-600';
                    icon.textContent   = 'error';
                    titleEl.className  = 'text-red-800 font-semibold';
                }

                titleEl.textContent  = title;
                messageEl.textContent = message;
                loginLink.classList.toggle('hidden', !showLogin);
                document.getElementById('resultModal').classList.remove('hidden');
            };

            window.closeResultModal = function () {
                document.getElementById('resultModal').classList.add('hidden');
            };

            document.getElementById('resultModal').addEventListener('click', function (e) {
                if (e.target === this) closeResultModal();
            });

            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') closeResultModal();
            });
        });
    </script>
</body>
</html>
